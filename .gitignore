# Generated pipeline artifacts — never committed
/workspaces/
/traces/raw/
/traces/meta/
/traces/diffs/
/traces/probes/
/traces/archive/
/traces/reviews/archive/
/runs/
/data/full/
/data/next_step/
/data/security/
/data/harvest/
/data/harness/
/data/*.jsonl
/data/manifest.json

# Security phase private material (imported from ../fable-secure; ephemeral runtime)
/security/catalog/
/security/keys/
/security/corpus/
/security/traces/
/security/runtime/

# Node / Pi runtime
/node_modules/
/package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coding-agent runtime state (session scheduler locks, etc.) — never source
/.claude/

# Local overrides & staged secrets
/config.local.json
*.key
