{
  "teacher": {
    "runtime": "pi",
    "model": "moonshotai/kimi-k3",
    "reasoning": "max",
    "timeout_s": 3600
  },
  "judge": {
    "runtime": "codex",
    "model": "gpt-5.6-sol",
    "reasoning": "xhigh",
    "timeout_s": 1800
  },
  "seed_author": {
    "runtime": "pi",
    "model": "moonshotai/kimi-k3",
    "reasoning": "max",
    "timeout_s": 3600
  },
  "seed_judge": {
    "runtime": "codex",
    "model": "gpt-5.6-sol",
    "reasoning": "xhigh",
    "timeout_s": 1800
  },
  "runtimes": {
    "claude-code": {
      "cli": "claude",
      "disallowed_tools": null,
      "paid_unlock_required": true
    },
    "codex": {
      "cli": "codex",
      "sandbox": "workspace-write",
      "web_search": "live",
      "ignore_user_config": true,
      "ignore_rules": true
    },
    "pi": {
      "cli": "pi",
      "runtime": "pi-coding-agent",
      "runtime_version": "0.80.7",
      "provider": "openrouter",
      "display_provider": "openrouter",
      "base_url": "https://openrouter.ai/api/v1",
      "thinking_format": "openrouter",
      "key_env": "OPENROUTER_API_KEY",
      "require_observed_model": true
    }
  },
  "quality": {
  },
  "pipeline": {
    "queues": {
      "seed_authoring": false,
      "tracing": true
    },
    "trace": {
      "max_attempts": 2,
      "default_limit": 1,
      "workers": 1
    },
    "seed": {
      "max_attempts": 2,
      "default_count": 1,
      "workers": 2
    }
  },
  "student": {
    "base_model": "unsloth/NVIDIA-Nemotron-3-Super-120B-A12B",
    "output_dir": "~/nemotron-super-finetune/data-moonshiner"
  },
  "build": {
    "keep_reasoning": true,
    "keep_thinking": true,
    "val_frac": 0.08
  },
  "publish": {
    "hf_dataset": null,
    "private": true,
    "batch_size": 1,
    "filename": "traces.jsonl",
    "check_before_append": false
  },
  "storage": {
    "root": null
  },
  "source": {
    "seed_repository": "../fable-code",
    "fallback_repository": "../sol-code"
  },
  "holdout_tasks": [
    "ts-event-emitter",
    "go-interval-merge"
  ]
}
