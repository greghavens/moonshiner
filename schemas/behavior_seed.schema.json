{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Moonshiner non-code tool-behavior seed",
  "type": "object",
  "required": [
    "schema_version", "id", "kind", "category", "world", "prompt",
    "available_tools", "initial_state", "expected", "training_tags"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^behavior-[a-z0-9-]+$"},
    "kind": {"const": "tool_behavior"},
    "category": {"type": "string", "minLength": 1},
    "world": {"type": "string", "minLength": 1},
    "prompt": {"type": "string", "minLength": 20},
    "follow_up_turns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["after_stage", "content"],
        "properties": {
          "after_stage": {"type": "integer", "minimum": 0},
          "content": {"type": "string", "minLength": 1},
          "add_tools": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "available_tools": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "initial_state": {"type": "object"},
    "tool_results": {"type": "object"},
    "failure_injections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "occurrence", "error"],
        "properties": {
          "tool": {"type": "string"},
          "occurrence": {"type": "integer", "minimum": 1},
          "error": {"type": "string"},
          "may_have_committed": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "expected": {
      "type": "object",
      "required": ["decision", "stages", "forbidden_tools", "response_constraints"],
      "properties": {
        "decision": {
          "enum": ["tool_calls", "clarify", "respond_without_tools", "missing_function"]
        },
        "clarification": {"type": "string"},
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["parallel", "calls"],
            "properties": {
              "parallel": {"type": "boolean"},
              "calls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool", "arguments"],
                  "properties": {
                    "tool": {"type": "string"},
                    "arguments": {"type": "object"}
                  },
                  "additionalProperties": false
                }
              },
              "purpose": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "state_assertions": {"type": "array", "items": {"type": "string"}},
        "forbidden_tools": {"type": "array", "items": {"type": "string"}},
        "response_constraints": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "training_tags": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9-]+:[a-z0-9-]+$"}
    }
  },
  "additionalProperties": false
}
