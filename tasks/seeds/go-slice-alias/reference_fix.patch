diff --git a/batch.go b/batch.go
index 5ef9b33..a667797 100644
--- a/batch.go
+++ b/batch.go
@@ -19,12 +19,15 @@ type Batch struct {
 // FromLines builds a batch from existing lines. The batch does not
 // track the caller's slice afterwards.
 func FromLines(lines []Line) Batch {
-	return Batch{lines: lines}
+	return Batch{lines: cloneLines(lines)}
 }
 
 // Append returns a new batch with l added at the end.
 func (b Batch) Append(l Line) Batch {
-	return Batch{lines: append(b.lines, l)}
+	out := make([]Line, len(b.lines)+1)
+	copy(out, b.lines)
+	out[len(out)-1] = l
+	return Batch{lines: out}
 }
 
 // Head returns a batch holding the first n lines (all of them when the
@@ -36,7 +39,7 @@ func (b Batch) Head(n int) Batch {
 	if n > len(b.lines) {
 		n = len(b.lines)
 	}
-	return Batch{lines: b.lines[:n]}
+	return Batch{lines: cloneLines(b.lines[:n])}
 }
 
 // Len reports the number of lines in the batch.
@@ -47,5 +50,16 @@ func (b Batch) Len() int {
 // Lines returns the batch contents in pick order. The caller owns the
 // returned slice.
 func (b Batch) Lines() []Line {
-	return b.lines
+	return cloneLines(b.lines)
+}
+
+// cloneLines copies ls so no two batches (or callers) share a backing
+// array.
+func cloneLines(ls []Line) []Line {
+	if len(ls) == 0 {
+		return nil
+	}
+	out := make([]Line, len(ls))
+	copy(out, ls)
+	return out
 }
