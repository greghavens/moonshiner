diff --git a/renew.ps1 b/renew.ps1
new file mode 100644
index 0000000..0b09aa6
--- /dev/null
+++ b/renew.ps1
@@ -0,0 +1,161 @@
+# renew.ps1 — per-directory certificate renewal ledger.
+# One switch on the command word; per-command options are parsed into a
+# hashtable and splatted into the command's function.
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+$StoreName = 'renewals.json'
+
+$usage = @'
+usage: renew.ps1 <command> [options]
+
+commands:
+  init      create renewals.json in the current directory
+  add       -Name <cert> -ExpiresOn <yyyy-MM-dd> [-Owner <team>]
+  report    [-Before <yyyy-MM-dd>] [-Owner <team>]
+  help      print this help
+
+exit codes: 0 ok, 64 usage error, 65 data error
+'@
+
+function Exit-Usage {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    [Console]::Error.WriteLine($usage)
+    exit 64
+}
+
+function Exit-Data {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit 65
+}
+
+function ConvertTo-OptionTable {
+    # Turn "-Name value -Owner value" tails into a hashtable fit for splatting.
+    param([string]$Command, [string[]]$Tokens, [string[]]$Known)
+    $opts = @{}
+    $i = 0
+    while ($i -lt $Tokens.Count) {
+        $tok = $Tokens[$i]
+        if (-not $tok.StartsWith('-')) {
+            Exit-Usage "renew: ${Command}: unexpected argument: $tok"
+        }
+        if ($Known -cnotcontains $tok) {
+            Exit-Usage "renew: unknown option: $tok"
+        }
+        if ($i + 1 -ge $Tokens.Count) {
+            Exit-Usage "renew: option $tok requires a value"
+        }
+        $opts[$tok.Substring(1)] = $Tokens[$i + 1]
+        $i += 2
+    }
+    return $opts
+}
+
+function Read-Store {
+    if (-not (Test-Path -LiteralPath $StoreName -PathType Leaf)) {
+        Exit-Data "renew: not initialized (run 'renew.ps1 init' first)"
+    }
+    return Get-Content -LiteralPath $StoreName -Raw | ConvertFrom-Json -AsHashtable
+}
+
+function Write-Store {
+    param([hashtable]$Store)
+    $json = ConvertTo-Json -InputObject $Store -Depth 5
+    [System.IO.File]::WriteAllText((Join-Path (Get-Location).Path $StoreName), $json + "`n")
+}
+
+function Invoke-Init {
+    if (Test-Path -LiteralPath $StoreName -PathType Leaf) {
+        Exit-Data 'renew: already initialized'
+    }
+    Write-Store @{ entries = @() }
+    Write-Output "initialized $StoreName"
+}
+
+function Invoke-Add {
+    param([string]$Name, [string]$ExpiresOn, [string]$Owner = '-')
+    $store = Read-Store
+    if (-not $Name -or -not $ExpiresOn) {
+        Exit-Usage 'renew: add: -Name and -ExpiresOn are required'
+    }
+    if ($Name -cnotmatch '^[A-Za-z0-9][A-Za-z0-9._-]*$') {
+        Exit-Data "renew: invalid certificate name: $Name"
+    }
+    if ($ExpiresOn -cnotmatch '^\d{4}-\d{2}-\d{2}$') {
+        Exit-Data "renew: invalid date: $ExpiresOn"
+    }
+    foreach ($entry in @($store['entries'])) {
+        if ([string]$entry['name'] -ceq $Name) {
+            Exit-Data "renew: duplicate certificate: $Name"
+        }
+    }
+    $store['entries'] = @($store['entries']) + @(
+        [ordered]@{ name = $Name; expiresOn = $ExpiresOn; owner = $Owner }
+    )
+    Write-Store $store
+    Write-Output "added $Name (expires $ExpiresOn)"
+}
+
+function Invoke-Report {
+    param([string]$Before, [string]$Owner)
+    $store = Read-Store
+    if ($Before -and $Before -cnotmatch '^\d{4}-\d{2}-\d{2}$') {
+        Exit-Data "renew: invalid date: $Before"
+    }
+    $rows = @($store['entries'])
+    if ($Before) {
+        $rows = @($rows | Where-Object {
+            [string]::CompareOrdinal([string]$_['expiresOn'], $Before) -lt 0
+        })
+    }
+    if ($Owner) {
+        $rows = @($rows | Where-Object { [string]$_['owner'] -ceq $Owner })
+    }
+    # Ordinal sort by expiry, then name — never the culture collation.
+    $keys = [string[]]@($rows | ForEach-Object { '{0}|{1}' -f $_['expiresOn'], $_['name'] })
+    [Array]::Sort($keys, [System.StringComparer]::Ordinal)
+    $byKey = @{}
+    foreach ($row in $rows) {
+        $byKey[[string]('{0}|{1}' -f $row['expiresOn'], $row['name'])] = $row
+    }
+    $lines = @(foreach ($k in $keys) {
+        $row = $byKey[$k]
+        '{0} {1} {2}' -f $row['expiresOn'], $row['name'], $row['owner']
+    })
+    if ($lines.Count -gt 0) {
+        Write-Output ($lines -join "`n")
+    }
+}
+
+if ($args.Count -eq 0) {
+    Exit-Usage 'renew: missing command'
+}
+
+$command = [string]$args[0]
+$tail = [string[]]@(if ($args.Count -gt 1) { $args[1..($args.Count - 1)] } else { @() })
+
+switch ($command) {
+    'init' {
+        if ($tail.Count -gt 0) {
+            Exit-Usage "renew: init: unexpected argument: $($tail[0])"
+        }
+        Invoke-Init
+    }
+    'add' {
+        $opts = ConvertTo-OptionTable 'add' $tail @('-Name', '-ExpiresOn', '-Owner')
+        Invoke-Add @opts
+    }
+    'report' {
+        $opts = ConvertTo-OptionTable 'report' $tail @('-Before', '-Owner')
+        Invoke-Report @opts
+    }
+    'help' {
+        Write-Output $usage
+    }
+    default {
+        Exit-Usage "renew: unknown command: $command"
+    }
+}
+exit 0
