+// envfile.ts — reader/writer for our .env files.
+//
+// The format rules live in one place (here) on purpose:
+// - '$' is literal everywhere; this tool never expands variables.
+// - single quotes are fully literal; double quotes know exactly five
+//   escapes (\n \t \r \" \\); unquoted values are trimmed and end at a
+//   blank-preceded '#'.
+// - serializeEnv picks the plainest form that parses back identically.
+
+export class EnvParseError extends Error {
+  line: number;
+
+  constructor(message: string, line: number) {
+    super(`line ${line}: ${message}`);
+    this.name = "EnvParseError";
+    this.line = line;
+  }
+}
+
+const KEY_RE = /^[A-Za-z_][A-Za-z0-9_]*$/;
+
+function isBlank(ch: string): boolean {
+  return ch === " " || ch === "\t";
+}
+
+// After a closing quote only blanks are allowed, optionally a comment.
+function checkQuoteTail(tail: string, lineNo: number): void {
+  let k = 0;
+  while (k < tail.length && isBlank(tail[k])) k++;
+  if (k < tail.length && tail[k] !== "#") {
+    throw new EnvParseError("unexpected text after quoted value", lineNo);
+  }
+}
+
+function parseDoubleQuoted(rest: string, lineNo: number): string {
+  let value = "";
+  let k = 1;
+  while (k < rest.length) {
+    const ch = rest[k];
+    if (ch === '"') {
+      checkQuoteTail(rest.slice(k + 1), lineNo);
+      return value;
+    }
+    if (ch === "\\") {
+      const next = rest[k + 1];
+      if (next === "n") value += "\n";
+      else if (next === "t") value += "\t";
+      else if (next === "r") value += "\r";
+      else if (next === '"') value += '"';
+      else if (next === "\\") value += "\\";
+      else throw new EnvParseError("unknown escape in double-quoted value", lineNo);
+      k += 2;
+      continue;
+    }
+    value += ch;
+    k++;
+  }
+  throw new EnvParseError("unterminated double-quoted value", lineNo);
+}
+
+export function parseEnv(text: string): Record<string, string> {
+  const out: Record<string, string> = {};
+  const lines = text.split("\n");
+
+  for (let i = 0; i < lines.length; i++) {
+    const lineNo = i + 1;
+    let line = lines[i];
+    if (line.endsWith("\r")) line = line.slice(0, -1);
+
+    let p = 0;
+    while (p < line.length && isBlank(line[p])) p++;
+    if (p === line.length || line[p] === "#") continue;
+
+    const eq = line.indexOf("=", p);
+    if (eq < 0) throw new EnvParseError("missing '='", lineNo);
+    const key = line.slice(p, eq).replace(/[ \t]+$/, "");
+    if (!KEY_RE.test(key)) throw new EnvParseError(`invalid key ${JSON.stringify(key)}`, lineNo);
+
+    let v = eq + 1;
+    while (v < line.length && isBlank(line[v])) v++;
+    const rest = line.slice(v);
+
+    let value: string;
+    if (rest.startsWith("'")) {
+      const end = rest.indexOf("'", 1);
+      if (end < 0) throw new EnvParseError("unterminated single-quoted value", lineNo);
+      value = rest.slice(1, end);
+      checkQuoteTail(rest.slice(end + 1), lineNo);
+    } else if (rest.startsWith('"')) {
+      value = parseDoubleQuoted(rest, lineNo);
+    } else if (rest.startsWith("#")) {
+      value = ""; // nothing before the comment
+    } else {
+      let cut = rest.length;
+      for (let k = 1; k < rest.length; k++) {
+        if (rest[k] === "#" && isBlank(rest[k - 1])) {
+          cut = k;
+          break;
+        }
+      }
+      value = rest.slice(0, cut).replace(/[ \t]+$/, "");
+    }
+    out[key] = value;
+  }
+  return out;
+}
+
+function renderValue(value: string): string {
+  for (const ch of value) {
+    const code = ch.codePointAt(0) as number;
+    if (code < 0x20 && ch !== "\n" && ch !== "\t" && ch !== "\r") {
+      throw new TypeError("value contains an unsupported control character");
+    }
+  }
+  const hasControl = /[\n\t\r]/.test(value);
+  const plainOk =
+    value !== "" &&
+    !isBlank(value[0]) &&
+    !isBlank(value[value.length - 1]) &&
+    !/[#"'\\]/.test(value) &&
+    !hasControl;
+  if (plainOk) return value;
+  if (!value.includes("'") && !hasControl) return `'${value}'`;
+  const escaped = value
+    .replace(/\\/g, "\\\\")
+    .replace(/"/g, '\\"')
+    .replace(/\n/g, "\\n")
+    .replace(/\t/g, "\\t")
+    .replace(/\r/g, "\\r");
+  return `"${escaped}"`;
+}
+
+export function serializeEnv(entries: Record<string, string>): string {
+  let out = "";
+  for (const [key, value] of Object.entries(entries)) {
+    if (!KEY_RE.test(key)) throw new TypeError(`invalid key ${JSON.stringify(key)}`);
+    out += `${key}=${renderValue(value)}\n`;
+  }
+  return out;
+}
