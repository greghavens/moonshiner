@@ -0,0 +1,31 @@
+# Conservative retention selection: expired, unowned, label-matched only.
+
+Set-StrictMode -Version Latest
+
+function Select-OntapSnapshotsForDeletion {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [AllowEmptyCollection()] [object[]] $Snapshots,
+        [Parameter(Mandatory)] [datetime] $AsOf,
+        [string] $SnapmirrorLabel
+    )
+    $asOfUtc = $AsOf.ToUniversalTime()
+    $eligible = foreach ($snap in $Snapshots) {
+        $expiryProp = $snap.PSObject.Properties['expiry_time']
+        if ($null -eq $expiryProp -or [string]::IsNullOrEmpty([string]$expiryProp.Value)) { continue }
+        $expiry = [datetimeoffset]::Parse([string]$expiryProp.Value, [cultureinfo]::InvariantCulture)
+        if ($expiry.UtcDateTime -gt $asOfUtc) { continue }
+        $ownersProp = $snap.PSObject.Properties['owners']
+        if ($null -ne $ownersProp -and @($ownersProp.Value).Count -gt 0) { continue }
+        if ($PSBoundParameters.ContainsKey('SnapmirrorLabel')) {
+            $labelProp = $snap.PSObject.Properties['snapmirror_label']
+            if ($null -eq $labelProp -or -not ([string]$labelProp.Value).Equals($SnapmirrorLabel, [System.StringComparison]::Ordinal)) {
+                continue
+            }
+        }
+        $snap
+    }
+    @($eligible | Sort-Object -Property `
+        @{ Expression = { [datetimeoffset]::Parse([string]$_.create_time, [cultureinfo]::InvariantCulture).UtcTicks } },
+        @{ Expression = { $_.name } })
+}
diff --git a/Transport.ps1 b/Transport.ps1
new file mode 100644
index 0000000..5bdaa1a
--- /dev/null
+++ b/Transport.ps1
@@ -0,0 +1,49 @@
+# HTTP transport for the ONTAP cluster-management /api endpoint.
+
+Set-StrictMode -Version Latest
+
+function Invoke-OntapRequest {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [object] $Session,
+        [Parameter(Mandatory)] [string] $Method,
+        [Parameter(Mandatory)] [string] $PathAndQuery
+    )
+    $uri = $Session.BaseUri + $PathAndQuery
+    $headers = @{ Authorization = $Session.AuthHeader; Accept = 'application/hal+json' }
+    $resp = Invoke-WebRequest -Uri $uri -Method $Method -Headers $headers -SkipHttpErrorCheck
+    $doc = $null
+    if ($null -ne $resp.Content -and $resp.Content.Length -gt 0) {
+        # pwsh hands application/hal+json back as raw bytes, not text
+        $text = if ($resp.Content -is [byte[]]) {
+            [System.Text.Encoding]::UTF8.GetString($resp.Content)
+        } else {
+            [string]$resp.Content
+        }
+        $doc = $text | ConvertFrom-Json
+    }
+    if ([int]$resp.StatusCode -ge 400) {
+        $code = 'unknown'
+        $message = 'no error body'
+        if ($null -ne $doc -and $doc.PSObject.Properties['error']) {
+            if ($doc.error.PSObject.Properties['code']) { $code = $doc.error.code }
+            if ($doc.error.PSObject.Properties['message']) { $message = $doc.error.message }
+        }
+        throw "ONTAP API error $([int]$resp.StatusCode) (code $code): $message"
+    }
+    [pscustomobject]@{ Status = [int]$resp.StatusCode; Body = $doc }
+}
+
+function New-OntapSession {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [string] $BaseUri,
+        [Parameter(Mandatory)] [pscredential] $Credential
+    )
+    $plain = $Credential.GetNetworkCredential().Password
+    $token = [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("$($Credential.UserName):$plain"))
+    [pscustomobject]@{
+        BaseUri    = $BaseUri.TrimEnd('/')
+        AuthHeader = "Basic $token"
+    }
+}
