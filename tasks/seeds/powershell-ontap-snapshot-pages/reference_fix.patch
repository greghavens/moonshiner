+# Paged snapshot inventory following HAL _links.next.
+
+Set-StrictMode -Version Latest
+
+function Get-OntapSnapshotInventory {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [object] $Session,
+        [Parameter(Mandatory)] [string] $VolumeUuid,
+        [Parameter(Mandatory)] [string[]] $Fields,
+        [Parameter(Mandatory)] [int] $MaxRecords,
+        [Parameter(Mandatory)] [string] $OrderBy
+    )
+    $records = [System.Collections.Generic.List[object]]::new()
+    $pages = 0
+    $query = "fields=$($Fields -join ',')&max_records=$MaxRecords&order_by=$([uri]::EscapeDataString($OrderBy))"
+    $next = "/api/storage/volumes/$VolumeUuid/snapshots?$query"
+    while ($null -ne $next) {
+        $page = (Invoke-OntapRequest -Session $Session -Method GET -PathAndQuery $next).Body
+        $pages++
+        foreach ($record in @($page.records)) { $records.Add($record) }
+        $next = $null
+        if ($page.PSObject.Properties['_links'] -and $page._links.PSObject.Properties['next']) {
+            $next = $page._links.next.href
+        }
+    }
+    [pscustomobject]@{
+        Records    = $records.ToArray()
+        Pages      = $pages
+        NumRecords = $records.Count
+    }
+}
diff --git a/Jobs.ps1 b/Jobs.ps1
new file mode 100644
index 0000000..7d2ee97
--- /dev/null
+++ b/Jobs.ps1
@@ -0,0 +1,60 @@
+# Asynchronous deletion through the documented 202-plus-job flow.
+
+Set-StrictMode -Version Latest
+
+function Wait-OntapJob {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [object] $Session,
+        [Parameter(Mandatory)] [string] $JobHref,
+        [Parameter(Mandatory)] [int] $PollLimit,
+        [Parameter(Mandatory)] [scriptblock] $Sleep
+    )
+    for ($poll = 1; $poll -le $PollLimit; $poll++) {
+        $job = (Invoke-OntapRequest -Session $Session -Method GET -PathAndQuery $JobHref).Body
+        switch ([string]$job.state) {
+            'success' { return [pscustomobject]@{ Outcome = 'success'; ErrorCode = $null; ErrorMessage = $null } }
+            'failure' {
+                $code = $null
+                $message = 'job failed'
+                if ($job.PSObject.Properties['error'] -and $null -ne $job.error) {
+                    if ($job.error.PSObject.Properties['code']) { $code = [string]$job.error.code }
+                    if ($job.error.PSObject.Properties['message']) { $message = [string]$job.error.message }
+                }
+                return [pscustomobject]@{ Outcome = 'failure'; ErrorCode = $code; ErrorMessage = $message }
+            }
+        }
+        if ($poll -lt $PollLimit) { & $Sleep 1 }
+    }
+    [pscustomobject]@{
+        Outcome      = 'timeout'
+        ErrorCode    = $null
+        ErrorMessage = "job still not terminal after poll limit of $PollLimit polls"
+    }
+}
+
+function Remove-OntapSnapshots {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)] [object] $Session,
+        [Parameter(Mandatory)] [string] $VolumeUuid,
+        [Parameter(Mandatory)] [AllowEmptyCollection()] [object[]] $Snapshots,
+        [Parameter(Mandatory)] [int] $PollLimit,
+        [Parameter(Mandatory)] [scriptblock] $Sleep
+    )
+    $results = [System.Collections.Generic.List[object]]::new()
+    foreach ($snap in $Snapshots) {
+        $path = "/api/storage/volumes/$VolumeUuid/snapshots/$($snap.uuid)?return_timeout=0"
+        $resp = Invoke-OntapRequest -Session $Session -Method DELETE -PathAndQuery $path
+        $verdict = Wait-OntapJob -Session $Session -JobHref $resp.Body.job._links.self.href `
+            -PollLimit $PollLimit -Sleep $Sleep
+        $results.Add([pscustomobject]@{
+            Uuid         = $snap.uuid
+            Name         = $snap.name
+            Deleted      = ($verdict.Outcome -ceq 'success')
+            ErrorCode    = $verdict.ErrorCode
+            ErrorMessage = $verdict.ErrorMessage
+        })
+    }
+    $results.ToArray()
+}
