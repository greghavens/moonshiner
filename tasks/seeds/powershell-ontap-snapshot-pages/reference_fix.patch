+# OntapSnapshots — ONTAP REST snapshot inventory and retention over /api.
+
+Set-StrictMode -Version Latest
+
+. (Join-Path $PSScriptRoot 'Transport.ps1')
+. (Join-Path $PSScriptRoot 'Inventory.ps1')
+. (Join-Path $PSScriptRoot 'Retention.ps1')
+. (Join-Path $PSScriptRoot 'Jobs.ps1')
+
+Export-ModuleMember -Function New-OntapSession, Get-OntapSnapshotInventory,
+    Select-OntapSnapshotsForDeletion, Remove-OntapSnapshots
