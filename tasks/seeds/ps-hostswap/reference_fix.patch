diff --git a/hostswap.ps1 b/hostswap.ps1
index 508ba3b..da0641a 100644
--- a/hostswap.ps1
+++ b/hostswap.ps1
@@ -25,16 +25,21 @@ if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
 
 function Read-ConfigText {
     param([string]$ConfigPath)
-    $content = Get-Content -LiteralPath $ConfigPath
