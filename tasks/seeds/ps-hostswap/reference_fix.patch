-    return "$content"
+    # -Raw keeps the file as one string, line breaks and trailing newline
+    # intact; the line-array form would lose both.
+    $content = Get-Content -LiteralPath $ConfigPath -Raw
+    if ($null -eq $content) { return '' }
+    return $content
 }
 
 $text = Read-ConfigText -ConfigPath $Path
-$hits = [regex]::Matches($text, $From).Count
+# -From is a literal from the runbook table, not a pattern; escape it so
+# regex metacharacters (the dots in keys and hostnames) match themselves.
+$pattern = [regex]::Escape($From)
+$hits = [regex]::Matches($text, $pattern).Count
 
 if ($hits -gt 0) {
-    $updated = $text -replace $From, $To
+    $updated = $text -replace $pattern, $To
     Set-Content -LiteralPath $Path -Value $updated -NoNewline
 }
 
