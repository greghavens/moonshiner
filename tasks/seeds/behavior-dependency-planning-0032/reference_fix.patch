+#!/usr/bin/env python3
+"""Reference proof using the genuine course executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Community Soil Science", "West Campus"),
+    ("Introduction to Museum Lighting", "Arts Campus"),
+)
+PHASE_WORKER = r"""
+import json
+import subprocess
+import sys
+
+commands = json.loads(sys.argv[1])
+processes = [
+    subprocess.Popen(
+        command,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    for command in commands
+]
+outputs = []
+for process in processes:
+    stdout, stderr = process.communicate(timeout=15)
+    if process.returncode != 0:
+        raise RuntimeError(stderr.strip() or "course operation failed")
+    outputs.append(json.loads(stdout))
+print(json.dumps(outputs))
+"""
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Give each phase its own parent while overlapping its direct clients."""
+    completed = subprocess.run(
+        [sys.executable, "-B", "-c", PHASE_WORKER, json.dumps(commands)],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=20,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "course phase failed")
+    payload = json.loads(completed.stdout)
+    if not isinstance(payload, list) or len(payload) != len(commands):
+        raise RuntimeError("course phase returned an invalid payload")
+    return payload
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./coursectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    identifiers: list[str] = []
+    for search in searches:
+        matches = search.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        stable_id = matches[0].get("id")
+        if not isinstance(stable_id, str) or not stable_id:
+            raise RuntimeError("reference branch returned no stable ID")
+        identifiers.append(stable_id)
+
+    gets = run_phase(
+        [["./coursectl", "get", "--id", stable_id] for stable_id in identifiers]
+    )
+    records: list[dict[str, Any]] = []
+    for result in gets:
+        record = result.get("record")
+        if not isinstance(record, dict):
+            raise RuntimeError("full-record retrieval failed")
+        records.append(record)
+
+    earlier, later = sorted(
+        records,
+        key=lambda record: (record["course_date"], record["id"]),
+    )
+    comparison = "same" if earlier["status"] == later["status"] else "different"
+    report = (
+        f"{earlier['course_date']} | {earlier['name']} | "
+        f"{earlier['id']} | {earlier['status']}\n"
+        f"{later['course_date']} | {later['name']} | "
+        f"{later['id']} | {later['status']}\n"
+        f"Status comparison: {comparison} "
+        f"({earlier['status']} vs {later['status']}).\n"
+    )
+    (ROOT / "course-reconciliation.txt").write_text(report, encoding="utf-8")
+    if not (ROOT / "course-reconciliation.receipt.json").is_file():
+        raise RuntimeError("course executable did not emit its receipt")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
