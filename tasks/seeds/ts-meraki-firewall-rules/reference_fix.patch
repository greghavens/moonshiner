+// MX L3 firewall-rule reconciler over the Meraki Dashboard API v1
+// l3FirewallRules resource. The dashboard replaces the ENTIRE ordered rule
+// list on PUT and appends its special default rule to GET responses, so we
+// normalize, strip the default rule, compare, and only write on drift.
+
+import { MerakiClient } from "./client.ts";
+
+export interface L3Rule {
+  comment?: string;
+  policy: string;
+  protocol: string;
+  srcPort?: string;
+  srcCidr: string;
+  destPort?: string;
+  destCidr: string;
+  syslogEnabled?: boolean;
+}
+
+export interface NormalizedL3Rule {
+  comment: string;
+  policy: string;
+  protocol: string;
+  srcPort: string;
+  srcCidr: string;
+  destPort: string;
+  destCidr: string;
+  syslogEnabled: boolean;
+}
+
+export interface ReconcileOptions {
+  syslogDefaultRule?: boolean;
+}
+
+export interface ReconcileResult {
+  changed: boolean;
+  ruleCount: number;
+  rules: NormalizedL3Rule[];
+}
+
+export const DEFAULT_RULE_COMMENT = "Default rule";
+
+const POLICIES = new Set(["allow", "deny"]);
+const PROTOCOLS = new Set(["tcp", "udp", "icmp", "icmp6", "any"]);
+const PORT_TOKEN = /^\d{1,5}$/;
+
+// The dashboard renders the wildcard as "Any"; only that literal is
+// case-normalized. Every other value keeps its exact spelling.
+function normalizeValue(value: string | undefined): string {
+  if (value === undefined || value === "") {
+    return "any";
+  }
+  return value.toLowerCase() === "any" ? "any" : value;
+}
+
+export function normalizeRule(rule: L3Rule): NormalizedL3Rule {
+  return {
+    comment: rule.comment ?? "",
+    policy: String(rule.policy).toLowerCase(),
+    protocol: String(rule.protocol).toLowerCase(),
+    srcPort: normalizeValue(rule.srcPort),
+    srcCidr: normalizeValue(rule.srcCidr),
+    destPort: normalizeValue(rule.destPort),
+    destCidr: normalizeValue(rule.destCidr),
+    syslogEnabled: rule.syslogEnabled ?? false,
+  };
+}
+
+export function normalizeRules(rules: L3Rule[]): NormalizedL3Rule[] {
+  return rules.map(normalizeRule);
+}
+
+export function stripDefaultRule(rules: L3Rule[]): L3Rule[] {
+  const last = rules[rules.length - 1];
+  if (last !== undefined && (last.comment ?? "") === DEFAULT_RULE_COMMENT) {
+    return rules.slice(0, -1);
+  }
+  return rules.slice();
+}
+
+function portSpecProblem(spec: string): boolean {
+  if (spec.toLowerCase() === "any") {
+    return false;
+  }
+  return !spec.split(",").every((token) => {
+    const trimmed = token.trim();
+    if (!PORT_TOKEN.test(trimmed)) {
+      return false;
+    }
+    const port = Number(trimmed);
+    return port >= 1 && port <= 65535;
+  });
+}
+
+export function validateRules(rules: L3Rule[]): string[] {
+  const problems: string[] = [];
+  rules.forEach((rule, index) => {
+    if (!POLICIES.has(String(rule.policy).toLowerCase())) {
+      problems.push(`rule ${index}: invalid policy "${rule.policy}"`);
+    }
+    if (!PROTOCOLS.has(String(rule.protocol).toLowerCase())) {
+      problems.push(`rule ${index}: invalid protocol "${rule.protocol}"`);
+    }
+    if (portSpecProblem(rule.srcPort ?? "any")) {
+      problems.push(`rule ${index}: invalid srcPort "${rule.srcPort}"`);
+    }
+    if (portSpecProblem(rule.destPort ?? "any")) {
+      problems.push(`rule ${index}: invalid destPort "${rule.destPort}"`);
+    }
+    if (!rule.srcCidr || rule.srcCidr.trim() === "") {
+      problems.push(`rule ${index}: missing srcCidr`);
+    }
+    if (!rule.destCidr || rule.destCidr.trim() === "") {
+      problems.push(`rule ${index}: missing destCidr`);
+    }
+  });
+  return problems;
+}
+
+function rulesEqual(a: NormalizedL3Rule[], b: NormalizedL3Rule[]): boolean {
+  if (a.length !== b.length) {
+    return false;
+  }
+  return a.every((rule, i) => JSON.stringify(rule) === JSON.stringify(b[i]));
+}
+
+export async function reconcileL3FirewallRules(
+  client: MerakiClient,
+  networkId: string,
+  desired: L3Rule[],
+  opts?: ReconcileOptions,
+): Promise<ReconcileResult> {
+  const problems = validateRules(desired);
+  if (problems.length > 0) {
+    throw new Error(`invalid desired rules: ${problems.join("; ")}`);
+  }
+  const path = `/networks/${encodeURIComponent(networkId)}/appliance/firewall/l3FirewallRules`;
+  const current = (await client.get(path)) as { rules?: L3Rule[] };
+  const currentNorm = normalizeRules(stripDefaultRule(current.rules ?? []));
+  const desiredNorm = normalizeRules(desired);
+  if (rulesEqual(currentNorm, desiredNorm)) {
+    return { changed: false, ruleCount: desiredNorm.length, rules: desiredNorm };
+  }
+  const body: { rules: NormalizedL3Rule[]; syslogDefaultRule?: boolean } = {
+    rules: desiredNorm,
+  };
+  if (opts?.syslogDefaultRule !== undefined) {
+    body.syslogDefaultRule = opts.syslogDefaultRule;
+  }
+  const updated = (await client.put(path, body)) as { rules?: L3Rule[] };
+  const updatedNorm = normalizeRules(stripDefaultRule(updated.rules ?? []));
+  return { changed: true, ruleCount: updatedNorm.length, rules: updatedNorm };
+}
