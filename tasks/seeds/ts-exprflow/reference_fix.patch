+// exprflow — the ${ } expression engine for our workflow templates.
+// See test_exprflow.ts for the contract.
+
+export class ExprError extends Error {
+  pos: number;
+  constructor(pos: number, detail: string) {
+    super(`position ${pos}: ${detail}`);
+    this.name = 'ExprError';
+    this.pos = pos;
+  }
+}
+
+// ------------------------------------------------------------------ tokens
+
+type Tok =
+  | { kind: 'num'; value: number; pos: number; text: string }
+  | { kind: 'str'; value: string; pos: number; text: string }
+  | { kind: 'kw'; value: boolean | null; pos: number; text: string }
+  | { kind: 'ident'; pos: number; text: string }
+  | { kind: 'path'; segs: Seg[]; pos: number; text: string }
+  | { kind: 'op'; pos: number; text: string }
+  | { kind: 'rbrace'; pos: number; text: string };
+
+type Seg = { key: string } | { index: number };
+
+const TWO_CHAR = ['&&', '||', '==', '!=', '<=', '>='];
+const ONE_CHAR = ['+', '-', '*', '/', '%', '!', '<', '>', '(', ')'];
+
+function isIdentStart(c: string): boolean {
+  return /[A-Za-z_]/.test(c);
+}
+function isIdentChar(c: string): boolean {
+  return /[A-Za-z0-9_]/.test(c);
+}
+
+/** Lex tokens from template starting just after `${`, through the matching `}`. */
+function lex(template: string, start: number, exprPos: number): { toks: Tok[]; end: number } {
+  const toks: Tok[] = [];
+  let i = start;
+  for (;;) {
+    while (i < template.length && /\s/.test(template[i])) i++;
+    if (i >= template.length) throw new ExprError(exprPos, 'unterminated expression');
+    const c = template[i];
+    if (c === '}') {
+      toks.push({ kind: 'rbrace', pos: i, text: '}' });
+      return { toks, end: i + 1 };
+    }
+    if (/[0-9]/.test(c)) {
+      let j = i;
+      while (j < template.length && /[0-9]/.test(template[j])) j++;
+      if (template[j] === '.' && /[0-9]/.test(template[j + 1] ?? '')) {
+        j++;
+        while (j < template.length && /[0-9]/.test(template[j])) j++;
+      }
+      const text = template.slice(i, j);
+      toks.push({ kind: 'num', value: Number(text), pos: i, text });
+      i = j;
+      continue;
+    }
+    if (c === '"' || c === "'") {
+      let j = i + 1;
+      let out = '';
+      let closed = false;
+      while (j < template.length) {
+        const d = template[j];
+        if (d === '\\') {
+          const e = template[j + 1];
+          if (e === 'n') out += '\n';
+          else if (e === 't') out += '\t';
+          else if (e === '\\' || e === '"' || e === "'") out += e;
+          else out += e ?? '';
+          j += 2;
+          continue;
+        }
+        if (d === c) { closed = true; j++; break; }
+        out += d;
+        j++;
+      }
+      if (!closed) throw new ExprError(i, 'unterminated string');
+      toks.push({ kind: 'str', value: out, pos: i, text: template.slice(i, j) });
+      i = j;
+      continue;
+    }
+    if (c === '.') {
+      const pos = i;
+      i++;
+      const segs: Seg[] = [];
+      if (i < template.length && isIdentStart(template[i])) {
+        let j = i;
+        while (j < template.length && isIdentChar(template[j])) j++;
+        segs.push({ key: template.slice(i, j) });
+        i = j;
+      }
+      for (;;) {
+        if (template[i] === '.') {
+          i++;
+          if (!(i < template.length && isIdentStart(template[i]))) {
+            throw new ExprError(i, 'invalid path segment');
+          }
+          let j = i;
+          while (j < template.length && isIdentChar(template[j])) j++;
+          segs.push({ key: template.slice(i, j) });
+          i = j;
+          continue;
+        }
+        if (template[i] === '[') {
+          i++;
+          if (!(i < template.length && /[0-9]/.test(template[i]))) {
+            throw new ExprError(i, 'invalid path segment');
+          }
+          let j = i;
+          while (j < template.length && /[0-9]/.test(template[j])) j++;
+          if (template[j] !== ']') throw new ExprError(j, 'invalid path segment');
+          segs.push({ index: Number(template.slice(i, j)) });
+          i = j + 1;
+          continue;
+        }
+        break;
+      }
+      toks.push({ kind: 'path', segs, pos, text: template.slice(pos, i) });
+      continue;
+    }
+    if (isIdentStart(c)) {
+      let j = i;
+      while (j < template.length && isIdentChar(template[j])) j++;
+      const text = template.slice(i, j);
+      if (text === 'true') toks.push({ kind: 'kw', value: true, pos: i, text });
+      else if (text === 'false') toks.push({ kind: 'kw', value: false, pos: i, text });
+      else if (text === 'null') toks.push({ kind: 'kw', value: null, pos: i, text });
+      else toks.push({ kind: 'ident', pos: i, text });
+      i = j;
+      continue;
+    }
+    const two = template.slice(i, i + 2);
+    if (TWO_CHAR.includes(two)) {
+      toks.push({ kind: 'op', pos: i, text: two });
+      i += 2;
+      continue;
+    }
+    if (ONE_CHAR.includes(c)) {
+      toks.push({ kind: 'op', pos: i, text: c });
+      i++;
+      continue;
+    }
+    throw new ExprError(i, `unexpected token "${c}"`);
+  }
+}
+
+// --------------------------------------------------------------------- ast
+
+type Node =
+  | { t: 'lit'; v: unknown }
+  | { t: 'path'; segs: Seg[] }
+  | { t: 'un'; op: string; pos: number; e: Node }
+  | { t: 'bin'; op: string; pos: number; l: Node; r: Node };
+
+class ExprParser {
+  toks: Tok[];
+  i = 0;
+  constructor(toks: Tok[]) {
+    this.toks = toks;
+  }
+  peek(): Tok {
+    return this.toks[this.i];
+  }
+  unexpected(tok: Tok): never {
+    throw new ExprError(tok.pos, `unexpected token "${tok.text}"`);
+  }
+  takeOp(texts: string[]): Tok | null {
+    const t = this.peek();
+    if (t.kind === 'op' && texts.includes(t.text)) { this.i++; return t; }
+    return null;
+  }
+  parse(): Node {
+    const node = this.or();
+    const t = this.peek();
+    if (t.kind !== 'rbrace') this.unexpected(t);
+    return node;
+  }
+  or(): Node {
+    let l = this.and();
+    for (let op; (op = this.takeOp(['||']));) l = { t: 'bin', op: '||', pos: op.pos, l, r: this.and() };
+    return l;
+  }
+  and(): Node {
+    let l = this.equality();
+    for (let op; (op = this.takeOp(['&&']));) l = { t: 'bin', op: '&&', pos: op.pos, l, r: this.equality() };
+    return l;
+  }
+  equality(): Node {
+    let l = this.relational();
+    for (let op; (op = this.takeOp(['==', '!=']));) {
+      l = { t: 'bin', op: op.text, pos: op.pos, l, r: this.relational() };
+    }
+    return l;
+  }
+  relational(): Node {
+    let l = this.additive();
+    for (let op; (op = this.takeOp(['<', '<=', '>', '>=']));) {
+      l = { t: 'bin', op: op.text, pos: op.pos, l, r: this.additive() };
+    }
+    return l;
+  }
+  additive(): Node {
+    let l = this.multiplicative();
+    for (let op; (op = this.takeOp(['+', '-']));) {
+      l = { t: 'bin', op: op.text, pos: op.pos, l, r: this.multiplicative() };
+    }
+    return l;
+  }
+  multiplicative(): Node {
+    let l = this.unary();
+    for (let op; (op = this.takeOp(['*', '/', '%']));) {
+      l = { t: 'bin', op: op.text, pos: op.pos, l, r: this.unary() };
+    }
+    return l;
+  }
+  unary(): Node {
+    const op = this.takeOp(['!', '-']);
+    if (op) return { t: 'un', op: op.text, pos: op.pos, e: this.unary() };
+    return this.primary();
+  }
+  primary(): Node {
+    const t = this.peek();
+    if (t.kind === 'num' || t.kind === 'str') { this.i++; return { t: 'lit', v: t.value }; }
+    if (t.kind === 'kw') { this.i++; return { t: 'lit', v: t.value }; }
+    if (t.kind === 'path') { this.i++; return { t: 'path', segs: t.segs }; }
+    if (t.kind === 'op' && t.text === '(') {
+      this.i++;
+      const inner = this.or();
+      const close = this.peek();
+      if (!(close.kind === 'op' && close.text === ')')) this.unexpected(close);
+      this.i++;
+      return inner;
+    }
+    this.unexpected(t);
+  }
+}
+
+// -------------------------------------------------------------- evaluation
+
+function isPlainObject(v: unknown): v is Record<string, unknown> {
+  return typeof v === 'object' && v !== null && !Array.isArray(v);
+}
+
+export function truthy(v: unknown): boolean {
+  if (v === false || v === null || v === undefined || v === '' || v === 0) return false;
+  if (typeof v === 'number' && Number.isNaN(v)) return false;
+  if (Array.isArray(v) && v.length === 0) return false;
+  return true;
+}
+
+function stringify(v: unknown): string {
+  if (v === null || v === undefined) return '';
+  if (typeof v === 'string') return v;
+  if (typeof v === 'number' || typeof v === 'boolean') return String(v);
+  return JSON.stringify(v);
+}
+
+function deepEq(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    return a.length === b.length && a.every((x, i) => deepEq(x, b[i]));
+  }
+  if (isPlainObject(a) && isPlainObject(b)) {
+    const ka = Object.keys(a);
+    const kb = Object.keys(b);
+    return ka.length === kb.length && ka.every((k) => k in b && deepEq(a[k], b[k]));
+  }
+  return false;
+}
+
+function resolvePath(segs: Seg[], context: unknown): unknown {
+  let cur: unknown = context;
+  for (const seg of segs) {
+    if ('key' in seg) {
+      if (!isPlainObject(cur) || !Object.prototype.hasOwnProperty.call(cur, seg.key)) return null;
+      cur = cur[seg.key];
+    } else {
+      if (!Array.isArray(cur) || seg.index >= cur.length) return null;
+      cur = cur[seg.index];
+    }
+    if (cur === undefined) return null;
+  }
+  return cur === undefined ? null : cur;
+}
+
+function evalNode(node: Node, context: unknown): unknown {
+  switch (node.t) {
+    case 'lit':
+      return node.v;
+    case 'path':
+      return resolvePath(node.segs, context);
+    case 'un': {
+      const v = evalNode(node.e, context);
+      if (node.op === '!') return !truthy(v);
+      if (typeof v !== 'number') throw new ExprError(node.pos, 'arithmetic requires numbers');
+      return -v;
+    }
+    case 'bin': {
+      const { op, pos } = node;
+      if (op === '&&') {
+        const l = evalNode(node.l, context);
+        return truthy(l) ? evalNode(node.r, context) : l;
+      }
+      if (op === '||') {
+        const l = evalNode(node.l, context);
+        return truthy(l) ? l : evalNode(node.r, context);
+      }
+      const l = evalNode(node.l, context);
+      const r = evalNode(node.r, context);
+      switch (op) {
+        case '==':
+          return deepEq(l, r);
+        case '!=':
+          return !deepEq(l, r);
+        case '<':
+        case '<=':
+        case '>':
+        case '>=': {
+          const both =
+            (typeof l === 'number' && typeof r === 'number') ||
+            (typeof l === 'string' && typeof r === 'string');
+          if (!both) throw new ExprError(pos, 'comparison requires two numbers or two strings');
+          if (op === '<') return (l as number) < (r as number);
+          if (op === '<=') return (l as number) <= (r as number);
+          if (op === '>') return (l as number) > (r as number);
+          return (l as number) >= (r as number);
+        }
+        case '+':
+          if (typeof l === 'number' && typeof r === 'number') return l + r;
+          return stringify(l) + stringify(r);
+        default: {
+          if (typeof l !== 'number' || typeof r !== 'number') {
+            throw new ExprError(pos, 'arithmetic requires numbers');
+          }
+          if (op === '-') return l - r;
+          if (op === '*') return l * r;
+          if (op === '/') return l / r;
+          return l % r;
+        }
+      }
+    }
+  }
+}
+
+// ---------------------------------------------------------------- template
+
+export function evaluate(template: string, context: unknown): unknown {
+  const parts: Array<{ kind: 'text'; text: string } | { kind: 'expr'; value: unknown }> = [];
+  let i = 0;
+  for (;;) {
+    const open = template.indexOf('${', i);
+    if (open < 0) {
+      if (i < template.length || parts.length === 0) {
+        parts.push({ kind: 'text', text: template.slice(i) });
+      }
+      break;
+    }
+    if (open > i) parts.push({ kind: 'text', text: template.slice(i, open) });
+    const { toks, end } = lex(template, open + 2, open);
+    if (toks.length === 1) throw new ExprError(open, 'empty expression');
+    const node = new ExprParser(toks).parse();
+    parts.push({ kind: 'expr', value: evalNode(node, context) });
+    i = end;
+  }
+  if (parts.length === 1 && parts[0].kind === 'expr') return parts[0].value;
+  return parts.map((p) => (p.kind === 'text' ? p.text : stringify(p.value))).join('');
+}
