+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Map;
+import java.util.NavigableMap;
+import java.util.TreeMap;
+import java.util.function.Predicate;
+import java.util.function.ToLongFunction;
+import java.util.stream.Collector;
+
+/**
+ * Custom stream collectors for the espresso-fleet telemetry pipeline.
+ * All of them carry honest characteristics and real combiners so they are
+ * safe inside parallel pipelines.
+ */
+public final class BrewCollectors {
+
+    private BrewCollectors() {
+    }
+
+    /**
+     * The k greatest elements per {@code order}, greatest first; order-equal
+     * elements keep encounter order (earlier input first). Claims no
+     * characteristics: the result is order-sensitive and the finisher is real.
+     */
+    public static <T> Collector<T, ?, List<T>> topK(int k, Comparator<? super T> order) {
+        if (k < 0) {
+            throw new IllegalArgumentException("k must be >= 0");
+        }
+        if (order == null) {
+            throw new IllegalArgumentException("order must not be null");
+        }
+        // Accumulator: an ArrayList kept sorted descending, ties in insertion
+        // order (new order-equal elements go AFTER the existing run), trimmed to k.
+        return Collector.of(
+                ArrayList<T>::new,
+                (acc, t) -> {
+                    int i = 0;
+                    while (i < acc.size() && order.compare(acc.get(i), t) >= 0) {
+                        i++;
+                    }
+                    acc.add(i, t);
+                    if (acc.size() > k) {
+                        acc.remove(acc.size() - 1);
+                    }
+                },
+                (left, right) -> {
+                    // Merge two descending runs; on ties the left part wins,
+                    // which is exactly "earlier encounter order first".
+                    ArrayList<T> merged = new ArrayList<>(Math.min(k, left.size() + right.size()));
+                    int i = 0;
+                    int j = 0;
+                    while (merged.size() < k && (i < left.size() || j < right.size())) {
+                        if (j >= right.size()
+                                || (i < left.size() && order.compare(left.get(i), right.get(j)) >= 0)) {
+                            merged.add(left.get(i++));
+                        } else {
+                            merged.add(right.get(j++));
+                        }
+                    }
+                    return merged;
+                },
+                List::copyOf);
+    }
+
+    /**
+     * Splits the stream by {@code match} and reduces each side to BrewStats
+     * over {@code value}. Both keys are always present; an empty side is all
+     * zeros. Order-insensitive, hence honestly UNORDERED.
+     */
+    public static <T> Collector<T, ?, Map<Boolean, BrewStats>> partitionStats(
+            Predicate<? super T> match, ToLongFunction<? super T> value) {
+        if (match == null) {
+            throw new IllegalArgumentException("match must not be null");
+        }
+        if (value == null) {
+            throw new IllegalArgumentException("value must not be null");
+        }
+        return Collector.of(
+                Partition::new,
+                (acc, t) -> (match.test(t) ? acc.yes : acc.no).add(value.applyAsLong(t)),
+                (a, b) -> {
+                    a.yes.merge(b.yes);
+                    a.no.merge(b.no);
+                    return a;
+                },
+                acc -> Map.of(Boolean.TRUE, acc.yes.snapshot(), Boolean.FALSE, acc.no.snapshot()),
+                Collector.Characteristics.UNORDERED);
+    }
+
+    /**
+     * Fixed-width histogram keyed by each bucket's lower bound — the greatest
+     * multiple of {@code bucketWidth} at or below the value, which floors
+     * correctly for negatives. Only non-empty buckets appear.
+     */
+    public static <T> Collector<T, ?, NavigableMap<Long, Long>> histogram(
+            ToLongFunction<? super T> value, long bucketWidth) {
+        if (value == null) {
+            throw new IllegalArgumentException("value must not be null");
+        }
+        if (bucketWidth <= 0) {
+            throw new IllegalArgumentException("bucketWidth must be positive");
+        }
+        return Collector.of(
+                TreeMap<Long, Long>::new,
+                (acc, t) -> {
+                    long bucket = Math.floorDiv(value.applyAsLong(t), bucketWidth) * bucketWidth;
+                    acc.merge(bucket, 1L, Long::sum);
+                },
+                (a, b) -> {
+                    b.forEach((bucket, n) -> a.merge(bucket, n, Long::sum));
+                    return a;
+                },
+                Collections::unmodifiableNavigableMap,
+                Collector.Characteristics.UNORDERED);
+    }
+
+    /** Mutable min/max/sum/count accumulator for one partition side. */
+    private static final class LongAcc {
+        private long count;
+        private long sum;
+        private long min;
+        private long max;
+
+        void add(long v) {
+            if (count == 0) {
+                min = v;
+                max = v;
+            } else {
+                min = Math.min(min, v);
+                max = Math.max(max, v);
+            }
+            count++;
+            sum += v;
+        }
+
+        void merge(LongAcc other) {
+            if (other.count == 0) {
+                return;
+            }
+            if (count == 0) {
+                min = other.min;
+                max = other.max;
+            } else {
+                min = Math.min(min, other.min);
+                max = Math.max(max, other.max);
+            }
+            count += other.count;
+            sum += other.sum;
+        }
+
+        BrewStats snapshot() {
+            return count == 0 ? new BrewStats(0, 0, 0, 0) : new BrewStats(count, sum, min, max);
+        }
+    }
+
+    private static final class Partition {
+        final LongAcc yes = new LongAcc();
+        final LongAcc no = new LongAcc();
+    }
+}
