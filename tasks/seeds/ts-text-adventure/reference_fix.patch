+export type Command =
+  | { kind: 'empty' }
+  | { kind: 'go'; direction: string }
+  | { kind: 'look' }
+  | { kind: 'inventory' }
+  | { kind: 'take'; item: string }
+  | { kind: 'drop'; item: string }
+  | { kind: 'unknown'; input: string };
+
+const COMPASS: Record<string, string> = {
+  n: 'north', north: 'north',
+  s: 'south', south: 'south',
+  e: 'east', east: 'east',
+  w: 'west', west: 'west',
+};
+
+export function parse(input: string): Command {
+  const normalized = input.trim().replace(/\s+/g, ' ').toLowerCase();
+  if (normalized === '') return { kind: 'empty' };
+
+  const words = normalized.split(' ');
+  const [head, ...rest] = words;
+  const restText = rest.join(' ');
+
+  if (words.length === 1 && COMPASS[head]) return { kind: 'go', direction: COMPASS[head] };
+  if (head === 'go' && restText !== '') return { kind: 'go', direction: restText };
+  if (normalized === 'look' || normalized === 'l') return { kind: 'look' };
+  if (normalized === 'inventory' || normalized === 'inv' || normalized === 'i') return { kind: 'inventory' };
+  if ((head === 'take' || head === 'get') && restText !== '') return { kind: 'take', item: restText };
+  if (head === 'pick' && rest[0] === 'up' && rest.length > 1) return { kind: 'take', item: rest.slice(1).join(' ') };
+  if (head === 'drop' && restText !== '') return { kind: 'drop', item: restText };
+
+  return { kind: 'unknown', input: normalized };
+}
