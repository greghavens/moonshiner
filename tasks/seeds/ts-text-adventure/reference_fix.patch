+export type Exit = string | { to: string; requires?: string; lockedMessage?: string };
+
+export type Room = {
+  name: string;
+  description: string;
+  exits: Record<string, Exit>;
+  items?: string[];
+};
+
+export type World = {
+  start: string;
+  win: { room: string; item: string };
+  rooms: Record<string, Room>;
+};
+
+export function exitTarget(exit: Exit): string {
+  return typeof exit === 'string' ? exit : exit.to;
+}
+
+/** Every room id referenced by start, win.room or an exit must exist. */
+export function validateWorld(world: World): void {
+  const known = (id: string) => {
+    if (!Object.prototype.hasOwnProperty.call(world.rooms, id)) {
+      throw new Error(`unknown room "${id}"`);
+    }
+  };
+  known(world.start);
+  known(world.win.room);
+  for (const room of Object.values(world.rooms)) {
+    for (const exit of Object.values(room.exits)) {
+      known(exitTarget(exit));
+    }
+  }
+}
