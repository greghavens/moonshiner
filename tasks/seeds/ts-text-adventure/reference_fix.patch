+import { parse } from './parser.ts';
+import { exitTarget, validateWorld, type World } from './world.ts';
+
+export class Game {
+  private world: World;
+  private roomItems = new Map<string, string[]>();
+  private carried: string[] = [];
+  private at: string;
+  private won = false;
+
+  constructor(world: World) {
+    validateWorld(world);
+    this.world = world;
+    this.at = world.start;
+    for (const [id, room] of Object.entries(world.rooms)) {
+      this.roomItems.set(id, [...(room.items ?? [])]);
+    }
+  }
+
+  location(): string {
+    return this.at;
+  }
+
+  inventory(): string[] {
+    return [...this.carried].sort();
+  }
+
+  isWon(): boolean {
+    return this.won;
+  }
+
+  execute(input: string): string {
+    if (this.won) return 'The adventure is over.';
+    const command = parse(input);
+    switch (command.kind) {
+      case 'empty':
+        return 'Say something.';
+      case 'unknown':
+        return `I don't understand "${command.input}".`;
+      case 'look':
+        return this.describe();
+      case 'inventory': {
+        const items = this.inventory();
+        return items.length === 0
+          ? 'You are carrying nothing.'
+          : `You are carrying: ${items.join(', ')}.`;
+      }
+      case 'go':
+        return this.go(command.direction);
+      case 'take':
+        return this.take(command.item);
+      case 'drop':
+        return this.drop(command.item);
+    }
+  }
+
+  private describe(): string {
+    const room = this.world.rooms[this.at];
+    const lines = [room.name, room.description];
+    const items = [...(this.roomItems.get(this.at) ?? [])].sort();
+    if (items.length > 0) lines.push(`You see: ${items.join(', ')}.`);
+    const directions = Object.keys(room.exits).sort();
+    lines.push(directions.length > 0 ? `Exits: ${directions.join(', ')}.` : 'Exits: none.');
+    return lines.join('\n');
+  }
+
+  private go(direction: string): string {
+    const exit = this.world.rooms[this.at].exits[direction];
+    if (exit === undefined) return `You can't go ${direction}.`;
+    if (typeof exit !== 'string' && exit.requires && !this.carried.includes(exit.requires)) {
+      return exit.lockedMessage ?? `The way ${direction} is locked.`;
+    }
+    this.at = exitTarget(exit);
+    return this.withWinCheck(this.describe());
+  }
+
+  private take(item: string): string {
+    const here = this.roomItems.get(this.at) ?? [];
+    const index = here.indexOf(item);
+    if (index === -1) return `There is no ${item} here.`;
+    here.splice(index, 1);
+    this.carried.push(item);
+    return this.withWinCheck(`You take the ${item}.`);
+  }
+
+  private drop(item: string): string {
+    const index = this.carried.indexOf(item);
+    if (index === -1) return `You aren't carrying a ${item}.`;
+    this.carried.splice(index, 1);
+    (this.roomItems.get(this.at) ?? []).push(item);
+    return this.withWinCheck(`You drop the ${item}.`);
+  }
+
+  private withWinCheck(message: string): string {
+    const { room, item } = this.world.win;
+    if (!this.won && this.at === room && this.carried.includes(item)) {
+      this.won = true;
+      return `${message}\n\nYou have won!`;
+    }
+    return message;
+  }
+}
