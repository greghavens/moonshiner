+++ b/proxy.go
@@ -0,0 +1,64 @@
+package proxy
+
+import (
+	"context"
+	"errors"
+	"io"
+	"net"
+	"net/http"
+	"net/url"
+)
+
+// Proxy relays requests to a single upstream after rewriting them.
+type Proxy struct {
+	upstream    *url.URL
+	stripPrefix string
+
+	// Transport performs the upstream round trips. Tests inject fakes;
+	// it defaults to http.DefaultTransport.
+	Transport http.RoundTripper
+}
+
+// New builds a proxy for the given upstream, stripping stripPrefix from
+// inbound paths.
+func New(upstream *url.URL, stripPrefix string) *Proxy {
+	return &Proxy{
+		upstream:    upstream,
+		stripPrefix: stripPrefix,
+		Transport:   http.DefaultTransport,
+	}
+}
+
+func (p *Proxy) ServeHTTP(w http.ResponseWriter, r *http.Request) {
+	rt := p.Transport
+	if rt == nil {
+		rt = http.DefaultTransport
+	}
+
+	resp, err := rt.RoundTrip(RewriteRequest(r, p.upstream, p.stripPrefix))
+	if err != nil {
+		status, msg := mapUpstreamError(err)
+		http.Error(w, msg, status)
+		return
+	}
+	defer resp.Body.Close()
+
+	StripHopByHop(resp.Header)
+	for k, vv := range resp.Header {
+		for _, v := range vv {
+			w.Header().Add(k, v)
+		}
+	}
+	w.WriteHeader(resp.StatusCode)
+	io.Copy(w, resp.Body) // stream; the client may be slower than the upstream
+}
+
+// mapUpstreamError turns a round-trip failure into a gateway status:
+// timeout-flavored errors are 504, everything else 502.
+func mapUpstreamError(err error) (int, string) {
+	var nerr net.Error
+	if errors.Is(err, context.DeadlineExceeded) || (errors.As(err, &nerr) && nerr.Timeout()) {
+		return http.StatusGatewayTimeout, "upstream timed out"
+	}
+	return http.StatusBadGateway, "upstream request failed"
+}
diff --git a/rewrite.go b/rewrite.go
