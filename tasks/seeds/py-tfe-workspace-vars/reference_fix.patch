+"""Workspace-variable reconciler for the Terraform Enterprise /api/v2 API.
+
+Fetches the current variable set, plans the minimum create/update/delete
+set against a desired list, and applies it. Sensitive variable values are
+never read or compared: the API returns them as null and treats them as
+write-once.
+"""
+
+_VARS_PATH = "/api/v2/workspaces/%s/vars"
+_DEFAULTS = {"value": "", "description": "", "hcl": False, "sensitive": False}
+_ATTR_NAMES = ("key", "value", "description", "category", "hcl", "sensitive")
+
+
+class TFEAPIError(Exception):
+    """A non-2xx TFE response, with the decoded JSON:API error document.
+
+    Note TFE answers 404 both for resources that do not exist and for
+    resources the token is not authorized to see.
+    """
+
+    def __init__(self, status, errors, completed=None):
+        self.status = status
+        self.errors = list(errors or [])
+        self.completed = list(completed or [])
+        detail = "; ".join(
+            "%s %s: %s" % (e.get("status"), e.get("title"), e.get("detail"))
+            for e in self.errors
+        ) or ("HTTP %d" % status)
+        super().__init__("TFE API error: " + detail)
+
+
+def _check(status, body, completed=None):
+    if not 200 <= status <= 299:
+        raise TFEAPIError(status, (body or {}).get("errors"), completed)
+
+
+def fetch_workspace_vars(client, workspace_id):
+    """List the workspace's variables (the endpoint is not paginated)."""
+    status, body = client.request("GET", _VARS_PATH % workspace_id)
+    _check(status, body)
+    out = []
+    for item in body.get("data", []):
+        attrs = item.get("attributes", {})
+        entry = {"id": item["id"]}
+        for name in _ATTR_NAMES:
+            entry[name] = attrs.get(name)
+        out.append(entry)
+    return out
+
+
+def _normalize(entry):
+    want = {"key": entry["key"], "category": entry["category"]}
+    for name, default in _DEFAULTS.items():
+        want[name] = entry.get(name, default)
+    return want
+
+
+def _needs_update(cur, want):
+    if cur["sensitive"]:
+        # The secret value is unreadable (null); compare metadata only.
+        if not want["sensitive"]:
+            return True
+        return bool(cur["hcl"]) != bool(want["hcl"]) or (cur["description"] or "") != want["description"]
+    if want["sensitive"]:
+        return True
+    return (
+        cur["value"] != want["value"]
+        or (cur["description"] or "") != want["description"]
+        or bool(cur["hcl"]) != bool(want["hcl"])
+    )
+
+
+def _ident(entry):
+    return (entry["category"], entry["key"])
+
+
+def plan_changes(current, desired):
+    """Plan the minimum change set; identity is the (category, key) pair."""
+    current_by_ident = {_ident(c): c for c in current}
+    want_list = [_normalize(d) for d in desired]
+    want_idents = {_ident(w) for w in want_list}
+
+    create, update, delete = [], [], []
+    for want in want_list:
+        cur = current_by_ident.get(_ident(want))
+        if cur is None:
+            create.append(dict(want))
+        elif _needs_update(cur, want):
+            entry = dict(want)
+            entry["id"] = cur["id"]
+            update.append(entry)
+    for ident, cur in current_by_ident.items():
+        if ident not in want_idents:
+            delete.append({"id": cur["id"], "key": cur["key"], "category": cur["category"]})
+
+    return {
+        "create": sorted(create, key=_ident),
+        "update": sorted(update, key=_ident),
+        "delete": sorted(delete, key=_ident),
+    }
+
+
+def _attributes(entry):
+    return {name: entry[name] for name in _ATTR_NAMES}
+
+
+def apply_plan(client, workspace_id, plan):
+    """Apply creates, then updates, then deletes; stop at the first error."""
+    base = _VARS_PATH % workspace_id
+    completed = []
+    for entry in plan["create"]:
+        body = {"data": {"type": "vars", "attributes": _attributes(entry)}}
+        status, resp = client.request("POST", base, body=body)
+        _check(status, resp, completed)
+        completed.append("create %s/%s" % _ident(entry))
+    for entry in plan["update"]:
+        body = {"data": {"type": "vars", "id": entry["id"], "attributes": _attributes(entry)}}
+        status, resp = client.request("PATCH", "%s/%s" % (base, entry["id"]), body=body)
+        _check(status, resp, completed)
+        completed.append("update %s/%s" % _ident(entry))
+    for entry in plan["delete"]:
+        status, resp = client.request("DELETE", "%s/%s" % (base, entry["id"]))
+        _check(status, resp, completed)
+        completed.append("delete %s/%s" % _ident(entry))
+    return completed
+
+
+def reconcile(client, workspace_id, desired, dry_run=False):
+    """Fetch, plan, and (unless dry_run) apply. Dry runs never write."""
+    current = fetch_workspace_vars(client, workspace_id)
+    plan = plan_changes(current, desired)
+    report = [] if dry_run else apply_plan(client, workspace_id, plan)
+    return {"plan": plan, "report": report}
