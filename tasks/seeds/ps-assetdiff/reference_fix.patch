diff --git a/assetdiff.ps1 b/assetdiff.ps1
new file mode 100644
index 0000000..67c05f7
--- /dev/null
+++ b/assetdiff.ps1
@@ -0,0 +1,90 @@
+# assetdiff.ps1 — reconcile two asset-inventory CSV snapshots.
+# Usage: pwsh -NoProfile -File assetdiff.ps1 -Before <csv> -After <csv> [-Key <column>]
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Before,
+    [Parameter(Mandatory)][string]$After,
+    [string]$Key = 'Tag'
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message, [int]$Code)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+foreach ($p in @($Before, $After)) {
+    if (-not (Test-Path -LiteralPath $p -PathType Leaf)) {
+        Fail "assetdiff: file not found: $p" 66
+    }
+}
+
+function Read-Snapshot {
+    param([string]$SnapPath)
+    $map = [ordered]@{}
+    foreach ($row in @(Import-Csv -LiteralPath $SnapPath)) {
+        if (@($row.PSObject.Properties.Name) -cnotcontains $Key) {
+            Fail "assetdiff: key column '$Key' not found in $SnapPath" 65
+        }
+        $k = [string]$row.$Key
+        if ($map.Contains($k)) {
+            Fail "assetdiff: duplicate key '$k' in $SnapPath" 65
+        }
+        $map[$k] = $row
+    }
+    return , $map
+}
+
+$beforeMap = Read-Snapshot -SnapPath $Before
+$afterMap = Read-Snapshot -SnapPath $After
+
+$addedKeys = [string[]]@(@($afterMap.Keys) | Where-Object { -not $beforeMap.Contains($_) })
+$removedKeys = [string[]]@(@($beforeMap.Keys) | Where-Object { -not $afterMap.Contains($_) })
+$commonKeys = [string[]]@(@($beforeMap.Keys) | Where-Object { $afterMap.Contains($_) })
+[Array]::Sort($addedKeys, [System.StringComparer]::Ordinal)
+[Array]::Sort($removedKeys, [System.StringComparer]::Ordinal)
+[Array]::Sort($commonKeys, [System.StringComparer]::Ordinal)
+
+function ConvertTo-Bag {
+    param($Row)
+    $bag = [ordered]@{}
+    foreach ($prop in $Row.PSObject.Properties) { $bag[$prop.Name] = $prop.Value }
+    return [pscustomobject]$bag
+}
+
+function Get-Cell {
+    param($Row, [string]$Name)
+    $prop = $Row.PSObject.Properties[$Name]
+    if ($null -eq $prop) { return $null }
+    return $prop.Value
+}
+
+$added = @(foreach ($k in $addedKeys) { ConvertTo-Bag $afterMap[$k] })
+$removed = @(foreach ($k in $removedKeys) { ConvertTo-Bag $beforeMap[$k] })
+
+$changed = @(foreach ($k in $commonKeys) {
+    $b = $beforeMap[$k]
+    $a = $afterMap[$k]
+    $names = [string[]]@(@($b.PSObject.Properties.Name) + @($a.PSObject.Properties.Name) | Select-Object -Unique)
+    [Array]::Sort($names, [System.StringComparer]::Ordinal)
+    $fields = @(foreach ($n in $names) {
+        $bv = Get-Cell $b $n
+        $av = Get-Cell $a $n
+        $same = if (($null -eq $bv) -and ($null -eq $av)) { $true }
+        elseif (($null -eq $bv) -or ($null -eq $av)) { $false }
+        else { [string]::Equals([string]$bv, [string]$av, [System.StringComparison]::Ordinal) }
+        if (-not $same) {
+            [pscustomobject][ordered]@{ name = $n; before = $bv; after = $av }
+        }
+    })
+    if ($fields.Count -gt 0) {
+        [pscustomobject][ordered]@{ key = $k; fields = $fields }
+    }
+})
+
+$report = [ordered]@{ added = $added; removed = $removed; changed = $changed }
+Write-Output (ConvertTo-Json $report -Depth 6)
+exit 0
