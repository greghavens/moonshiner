index 0000000..07ac541
--- /dev/null
+++ b/report.cpp
@@ -0,0 +1,84 @@
+#include "report.hpp"
+
+#include <algorithm>
+#include <numeric>
+
+namespace {
+
+/* Billing for a single closed order: parts plus labor, labor truncated in
+ * integer arithmetic per order (the accountant reconciles order by order). */
+long order_total_cents(const WorkOrder &o, long rate_cents_per_hour) {
+    return o.parts_cents + o.minutes * rate_cents_per_hour / 60;
+}
+
+} // namespace
+
+long shop_revenue_cents(const std::vector<WorkOrder> &orders,
+                        long rate_cents_per_hour) {
+    return std::accumulate(
+            orders.begin(), orders.end(), 0L,
+            [rate_cents_per_hour](long acc, const WorkOrder &o) {
+                return o.closed ? acc + order_total_cents(o, rate_cents_per_hour)
+                                : acc;
+            });
+}
+
+std::map<std::string, long> revenue_by_mechanic(
+        const std::vector<WorkOrder> &orders, long rate_cents_per_hour) {
+    std::map<std::string, long> by_mechanic;
+    std::for_each(orders.begin(), orders.end(),
+                  [&](const WorkOrder &o) {
+                      if (o.closed)
+                          by_mechanic[o.mechanic] +=
+                                  order_total_cents(o, rate_cents_per_hour);
+                  });
+    return by_mechanic;
+}
+
+std::vector<std::string> backlog_ids(const std::vector<WorkOrder> &orders) {
+    std::vector<const WorkOrder *> open;
+    std::for_each(orders.begin(), orders.end(), [&](const WorkOrder &o) {
+        if (!o.closed)
+            open.push_back(&o);
+    });
+    std::sort(open.begin(), open.end(),
+              [](const WorkOrder *a, const WorkOrder *b) {
+                  if (a->minutes != b->minutes)
+                      return a->minutes > b->minutes;
+                  return a->id < b->id;
+              });
+    std::vector<std::string> ids;
+    ids.reserve(open.size());
+    std::transform(open.begin(), open.end(), std::back_inserter(ids),
+                   [](const WorkOrder *o) { return o->id; });
+    return ids;
+}
+
+PartsSplit split_by_parts(const std::vector<WorkOrder> &orders,
+                          long threshold_cents) {
+    PartsSplit split;
+    std::for_each(orders.begin(), orders.end(), [&](const WorkOrder &o) {
+        if (!o.closed)
+            return;
+        if (o.parts_cents >= threshold_cents)
+            split.heavy.push_back(o.id);
+        else
+            split.light.push_back(o.id);
+    });
+    return split;
+}
+
+std::string busiest_category(const std::vector<WorkOrder> &orders) {
+    std::map<std::string, long> minutes_by_category;
+    std::for_each(orders.begin(), orders.end(), [&](const WorkOrder &o) {
+        minutes_by_category[o.category] += o.minutes;
+    });
+    auto best = std::max_element(
+            minutes_by_category.begin(), minutes_by_category.end(),
+            [](const auto &a, const auto &b) {
+                /* strictly more minutes wins; the map is already sorted by
+                 * name, so the first of equal totals is the smallest name */
+                return a.second < b.second;
+            });
+    return best == minutes_by_category.end() ? std::string() : best->first;
+}
