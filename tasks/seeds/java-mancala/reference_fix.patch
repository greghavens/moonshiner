+import java.util.ArrayList;
+import java.util.List;
+
+/** Kalah (mancala) referee engine: two players A and B, six pits each plus a store. */
+public final class Kalah {
+
+    private final int[][] pits = new int[2][6];
+    private final int[] stores = new int[2];
+    private int turn; // 0 = A, 1 = B
+    private boolean over;
+
+    private Kalah() {}
+
+    /** Parses a position fixture: a turn line followed by the A row and the B row. */
+    public static Kalah parse(String text) {
+        List<String> lines = new ArrayList<>();
+        for (String raw : text.split("\n", -1)) {
+            String line = raw.trim();
+            if (!line.isEmpty()) lines.add(line);
+        }
+        if (lines.size() != 3) {
+            throw new IllegalArgumentException("expected 3 lines, got " + lines.size());
+        }
+        Kalah g = new Kalah();
+        String[] t = lines.get(0).split("\\s+");
+        if (t.length != 2 || !t[0].equals("turn") || !(t[1].equals("A") || t[1].equals("B"))) {
+            throw new IllegalArgumentException("bad turn line: " + lines.get(0));
+        }
+        g.turn = t[1].equals("A") ? 0 : 1;
+        parseRow(g, lines.get(1), 0, "A");
+        parseRow(g, lines.get(2), 1, "B");
+        return g;
+    }
+
+    private static void parseRow(Kalah g, String line, int side, String label) {
+        String[] tok = line.split("\\s+");
+        if (tok.length != 9 || !tok[0].equals(label) || !tok[7].equals("|")) {
+            throw new IllegalArgumentException("bad row for " + label + ": " + line);
+        }
+        for (int i = 0; i < 6; i++) g.pits[side][i] = stones(tok[i + 1], line);
+        g.stores[side] = stones(tok[8], line);
+    }
+
+    private static int stones(String tok, String line) {
+        int n;
+        try {
+            n = Integer.parseInt(tok);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("bad stone count in: " + line);
+        }
+        if (n < 0) throw new IllegalArgumentException("negative stone count in: " + line);
+        return n;
+    }
+
+    public String render() {
+        StringBuilder sb = new StringBuilder();
+        sb.append("turn ").append(over ? '-' : name(turn)).append('\n');
+        for (int side = 0; side < 2; side++) {
+            sb.append(name(side));
+            for (int i = 0; i < 6; i++) sb.append(' ').append(pits[side][i]);
+            sb.append(" | ").append(stores[side]);
+            if (side == 0) sb.append('\n');
+        }
+        return sb.toString();
+    }
+
+    public char turn() {
+        return name(turn);
+    }
+
+    public boolean isOver() {
+        return over;
+    }
+
+    public String winner() {
+        if (!over) throw new IllegalStateException("game still in progress");
+        if (stores[0] > stores[1]) return "A";
+        if (stores[1] > stores[0]) return "B";
+        return "draw";
+    }
+
+    /**
+     * Sows pit 1..6 for the side to move. Returns the event: "move", "extra" or
+     * "capture n", with " / sweep P n / game over" appended when the game ends.
+     */
+    public String move(int pit) {
+        if (over) throw new IllegalStateException("game over");
+        if (pit < 1 || pit > 6) throw new IllegalArgumentException("pit out of range: " + pit);
+        int me = turn, opp = 1 - turn;
+        int stones = pits[me][pit - 1];
+        if (stones == 0) throw new IllegalArgumentException("pit " + pit + " is empty");
+        pits[me][pit - 1] = 0;
+
+        // ring of 13 slots: my pits 0..5, my store (6), opponent pits 7..12
+        int pos = pit - 1;
+        while (stones > 0) {
+            pos = (pos + 1) % 13;
+            if (pos <= 5) pits[me][pos]++;
+            else if (pos == 6) stores[me]++;
+            else pits[opp][pos - 7]++;
+            stones--;
+        }
+
+        String event;
+        boolean extra = pos == 6;
+        if (extra) {
+            event = "extra";
+        } else if (pos <= 5 && pits[me][pos] == 1 && pits[opp][5 - pos] > 0) {
+            int haul = 1 + pits[opp][5 - pos];
+            stores[me] += haul;
+            pits[me][pos] = 0;
+            pits[opp][5 - pos] = 0;
+            event = "capture " + haul;
+        } else {
+            event = "move";
+        }
+
+        int next = extra ? me : opp;
+        if (empty(next)) {
+            int sweeper = 1 - next;
+            int swept = 0;
+            for (int i = 0; i < 6; i++) {
+                swept += pits[sweeper][i];
+                pits[sweeper][i] = 0;
+            }
+            stores[sweeper] += swept;
+            over = true;
+            event += " / sweep " + name(sweeper) + " " + swept + " / game over";
+        } else {
+            turn = next;
+        }
+        return event;
+    }
+
+    /** Replays a move list over a fixture position and returns the archive transcript. */
+    public static String transcript(String fixture, int[] moves) {
+        Kalah g = parse(fixture);
+        StringBuilder sb = new StringBuilder();
+        sb.append("=== start ===\n").append(g.render()).append("\n\n");
+        for (int i = 0; i < moves.length; i++) {
+            char mover = g.turn();
+            String event = g.move(moves[i]);
+            sb.append("move ").append(i + 1).append(' ').append(mover)
+              .append(" pit ").append(moves[i]).append(": ").append(event).append('\n');
+            sb.append(g.render()).append("\n\n");
+        }
+        if (g.isOver()) sb.append("result: winner ").append(g.winner()).append('\n');
+        else sb.append("result: next ").append(g.turn()).append('\n');
+        return sb.toString();
+    }
+
+    private boolean empty(int side) {
+        for (int i = 0; i < 6; i++) if (pits[side][i] > 0) return false;
+        return true;
+    }
+
+    private static char name(int side) {
+        return side == 0 ? 'A' : 'B';
+    }
+}
