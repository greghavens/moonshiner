diff --git a/src/PipelineProfiler.psm1 b/src/PipelineProfiler.psm1
index 43f0ccc..4397bd9 100644
--- a/src/PipelineProfiler.psm1
+++ b/src/PipelineProfiler.psm1
@@ -18,7 +18,7 @@ function Invoke-ProfiledPipeline {
             $OperationCounter['StorageOperations'] = [long] 0
         }
 
-        $results = @()
+        $results = [System.Collections.Generic.List[object]]::new()
     }
 
     process {
@@ -26,14 +26,27 @@ function Invoke-ProfiledPipeline {
 
         foreach ($item in $transformed) {
-            # Array concatenation allocates a new buffer and writes every element.
-            $OperationCounter['StorageOperations'] =
-                [long] $OperationCounter['StorageOperations'] + $results.Count + 1
-            $results += $item
+            $countBeforeAdd = $results.Count
+            $capacityBeforeAdd = $results.Capacity
+
+            $results.Add($item)
+
+            # Add writes the new element. A capacity change also copies the
+            # elements that were already in the list into its grown buffer.
+            $storageOperations = [long] 1
+            if ($results.Capacity -ne $capacityBeforeAdd) {
+                $storageOperations += $countBeforeAdd
+            }
+            $OperationCounter['StorageOperations'] =
+                [long] $OperationCounter['StorageOperations'] + $storageOperations
         }
     }
 
     end {
-        $results
+        # Materializing the final array performs one write per result. PowerShell
+        # then enumerates it, retaining the usual zero/one/many pipeline shape.
+        $OperationCounter['StorageOperations'] =
+            [long] $OperationCounter['StorageOperations'] + $results.Count
+        $results.ToArray()
     }
 }
 
