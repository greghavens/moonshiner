diff --git a/lru.c b/lru.c
new file mode 100644
index 0000000..e8db769
--- /dev/null
+++ b/lru.c
@@ -0,0 +1,159 @@
+#include "lru.h"
+
+static size_t bucket_of(uint32_t key) {
+    return key % LRU_BUCKETS;
+}
+
+/* --- hash-chain surgery ----------------------------------------------- */
+
+static lru_entry *chain_find(const lru_cache *c, uint32_t key) {
+    for (lru_entry *e = c->buckets[bucket_of(key)]; e != NULL; e = e->hnext)
+        if (e->key == key)
+            return e;
+    return NULL;
+}
+
+static void chain_insert(lru_cache *c, lru_entry *e) {
+    size_t b = bucket_of(e->key);
+    e->hnext = c->buckets[b];
+    c->buckets[b] = e;
+}
+
+static void chain_remove(lru_cache *c, lru_entry *e) {
+    lru_entry **pp = &c->buckets[bucket_of(e->key)];
+    while (*pp != e)
+        pp = &(*pp)->hnext;
+    *pp = e->hnext;
+    e->hnext = NULL;
+}
+
+/* --- recency-list surgery ---------------------------------------------- */
+
+static void list_remove(lru_cache *c, lru_entry *e) {
+    if (e->prev != NULL)
+        e->prev->next = e->next;
+    else
+        c->mru = e->next;
+    if (e->next != NULL)
+        e->next->prev = e->prev;
+    else
+        c->lru = e->prev;
+    e->prev = NULL;
+    e->next = NULL;
+}
+
+static void list_push_mru(lru_cache *c, lru_entry *e) {
+    e->prev = NULL;
+    e->next = c->mru;
+    if (c->mru != NULL)
+        c->mru->prev = e;
+    c->mru = e;
+    if (c->lru == NULL)
+        c->lru = e;
+}
+
+static void promote(lru_cache *c, lru_entry *e) {
+    if (c->mru == e)
+        return;
+    list_remove(c, e);
+    list_push_mru(c, e);
+}
+
+/* --- public API --------------------------------------------------------- */
+
+int lru_init(lru_cache *c, lru_entry *slots, size_t cap) {
+    if (c == NULL || slots == NULL || cap == 0)
+        return -1;
+    c->slots = slots;
+    c->cap = cap;
+    c->len = 0;
+    c->mru = NULL;
+    c->lru = NULL;
+    c->hits = 0;
+    c->misses = 0;
+    c->evictions = 0;
+    for (size_t b = 0; b < LRU_BUCKETS; b++)
+        c->buckets[b] = NULL;
+    c->free_head = &slots[0];
+    for (size_t i = 0; i + 1 < cap; i++)
+        slots[i].hnext = &slots[i + 1];
+    slots[cap - 1].hnext = NULL;
+    return 0;
+}
+
+int lru_get(lru_cache *c, uint32_t key, uint32_t *value_out) {
+    if (c == NULL)
+        return 0;
+    lru_entry *e = chain_find(c, key);
+    if (e == NULL) {
+        c->misses++;
+        return 0;
+    }
+    if (value_out != NULL)
+        *value_out = e->value;
+    promote(c, e);
+    c->hits++;
+    return 1;
+}
+
+void lru_put(lru_cache *c, uint32_t key, uint32_t value) {
+    if (c == NULL)
+        return;
+    lru_entry *e = chain_find(c, key);
+    if (e != NULL) {
+        e->value = value;
+        promote(c, e);
+        return;
+    }
+
+    if (c->len == c->cap) {
+        /* recycle the coldest slot: off its chain, off the list */
+        lru_entry *victim = c->lru;
+        chain_remove(c, victim);
+        list_remove(c, victim);
+        victim->hnext = c->free_head;
+        c->free_head = victim;
+        c->len--;
+        c->evictions++;
+    }
+
+    e = c->free_head;
+    c->free_head = e->hnext;
+    e->key = key;
+    e->value = value;
+    e->hnext = NULL;
+    chain_insert(c, e);
+    list_push_mru(c, e);
+    c->len++;
+}
+
+int lru_contains(const lru_cache *c, uint32_t key) {
+    if (c == NULL)
+        return 0;
+    return chain_find(c, key) != NULL ? 1 : 0;
+}
+
+size_t lru_len(const lru_cache *c) {
+    return c == NULL ? 0 : c->len;
+}
+
+uint32_t lru_hits(const lru_cache *c) {
+    return c == NULL ? 0 : c->hits;
+}
+
+uint32_t lru_misses(const lru_cache *c) {
+    return c == NULL ? 0 : c->misses;
+}
+
+uint32_t lru_evictions(const lru_cache *c) {
+    return c == NULL ? 0 : c->evictions;
+}
+
+size_t lru_keys_mru(const lru_cache *c, uint32_t *out, size_t max) {
+    if (c == NULL || out == NULL)
+        return 0;
+    size_t n = 0;
+    for (const lru_entry *e = c->mru; e != NULL && n < max; e = e->next)
+        out[n++] = e->key;
+    return n;
+}
diff --git a/lru.h b/lru.h
new file mode 100644
index 0000000..f593fc1
--- /dev/null
+++ b/lru.h
@@ -0,0 +1,56 @@
+/* lru.h — intrusive LRU cache for directory entries, zero allocation.
+ *
+ * Every entry carries its own links: hnext threads the hash chain (and
+ * the freelist while the slot is unused), prev/next thread the global
+ * recency list. All storage is the caller's slot array; after warmup
+ * the cache runs forever on those cap slots.
+ */
+#ifndef LRU_H
+#define LRU_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+#define LRU_BUCKETS 32
+
+typedef struct lru_entry {
+    uint32_t key;
+    uint32_t value;
+    struct lru_entry *hnext;        /* hash-chain link */
+    struct lru_entry *prev, *next;  /* recency-list links */
+} lru_entry;
+
+typedef struct {
+    lru_entry *slots;       /* caller storage: cap entries */
+    size_t     cap;
+    size_t     len;
+    lru_entry *mru, *lru;   /* recency list ends */
+    lru_entry *free_head;   /* unused slots, chained via hnext */
+    lru_entry *buckets[LRU_BUCKETS];
+    uint32_t   hits, misses, evictions;
+} lru_cache;
+
+/* Thread all cap slots onto the freelist and empty the cache. 0 on
+ * success, -1 if slots is NULL or cap is 0. */
+int lru_init(lru_cache *c, lru_entry *slots, size_t cap);
+
+/* Hit: write the value through value_out (NULL just promotes), move
+ * the entry to MRU, count a hit, return 1. Miss: count one, return 0. */
+int lru_get(lru_cache *c, uint32_t key, uint32_t *value_out);
+
+/* Known key: update value and promote. New key: evict the LRU entry
+ * first when full (recycling its slot), then insert as MRU. */
+void lru_put(lru_cache *c, uint32_t key, uint32_t value);
+
+/* Presence check: no promotion, no counters. */
+int lru_contains(const lru_cache *c, uint32_t key);
+
+size_t   lru_len(const lru_cache *c);
+uint32_t lru_hits(const lru_cache *c);
+uint32_t lru_misses(const lru_cache *c);
+uint32_t lru_evictions(const lru_cache *c);
+
+/* Write up to max keys most-recent-first; returns how many. */
+size_t lru_keys_mru(const lru_cache *c, uint32_t *out, size_t max);
+
+#endif /* LRU_H */
