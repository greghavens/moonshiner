diff --git a/haulstats.ps1 b/haulstats.ps1
new file mode 100644
index 0000000..ceb9306
--- /dev/null
+++ b/haulstats.ps1
@@ -0,0 +1,65 @@
+# haulstats.ps1 — per-(Region,Carrier) shipment weight rollup.
+# Usage: pwsh -NoProfile -File haulstats.ps1 -Path <shipments.csv>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Path
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message, [int]$Code)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+    Fail "haulstats: file not found: $Path" 66
+}
+
+$header = '"Region","Carrier","Shipments","TotalKg","MinKg","MaxKg","AvgKg"'
+$rows = @(Import-Csv -LiteralPath $Path)
+if ($rows.Count -eq 0) {
+    Write-Output $header
+    exit 0
+}
+
+foreach ($col in @('Region', 'Carrier', 'WeightKg')) {
+    if (@($rows[0].PSObject.Properties.Name) -cnotcontains $col) {
+        Fail "haulstats: required column '$col' not found" 65
+    }
+}
+
+$inv = [System.Globalization.CultureInfo]::InvariantCulture
+$parsed = @(for ($i = 0; $i -lt $rows.Count; $i++) {
+    $row = $rows[$i]
+    $kg = 0.0
+    if (-not [double]::TryParse($row.WeightKg, [System.Globalization.NumberStyles]::Float, $inv, [ref]$kg)) {
+        Fail ("haulstats: bad WeightKg '{0}' at data row {1}" -f $row.WeightKg, ($i + 1)) 65
+    }
+    [pscustomobject]@{ Region = $row.Region; Carrier = $row.Carrier; Kg = $kg }
+})
+
+$groups = @($parsed | Group-Object -Property Region, Carrier -CaseSensitive)
+$byKey = [System.Collections.Generic.Dictionary[string, object]]::new([System.StringComparer]::Ordinal)
+foreach ($g in $groups) { $byKey[$g.Group[0].Region + [char]1 + $g.Group[0].Carrier] = $g }
+$keys = [string[]]@($byKey.Keys)
+[Array]::Sort($keys, [System.StringComparer]::Ordinal)
+
+$report = @(foreach ($k in $keys) {
+    $g = $byKey[$k]
+    $m = $g.Group | Measure-Object -Property Kg -Sum -Minimum -Maximum
+    [pscustomobject][ordered]@{
+        Region    = $g.Group[0].Region
+        Carrier   = $g.Group[0].Carrier
+        Shipments = [string]$m.Count
+        TotalKg   = [string]::Format($inv, '{0:0.00}', $m.Sum)
+        MinKg     = [string]::Format($inv, '{0:0.00}', $m.Minimum)
+        MaxKg     = [string]::Format($inv, '{0:0.00}', $m.Maximum)
+        AvgKg     = [string]::Format($inv, '{0:0.00}', [math]::Round($m.Sum / $m.Count, 2, [System.MidpointRounding]::AwayFromZero))
+    }
+})
+
+$report | ConvertTo-Csv | Write-Output
+exit 0
