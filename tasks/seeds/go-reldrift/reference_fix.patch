@@ -0,0 +1,106 @@
+// Package reldrift compares release manifests between environments and
+// reports which services drifted, ignoring the fields that always differ
+// between a rollout and the live cluster.
+package reldrift
+
+import (
+	"fmt"
+	"sort"
+	"time"
+
+	"github.com/google/go-cmp/cmp"
+	"github.com/google/go-cmp/cmp/cmpopts"
+)
+
+// Service is one deployable unit as recorded in a release manifest.
+type Service struct {
+	Name       string
+	Image      string
+	Replicas   int
+	CPU        float64
+	Ports      []int
+	Env        map[string]string
+	DeployedAt time.Time
+}
+
+// houseRules are the comparison options every drift check shares:
+// deploy timestamps are noise, CPU requests jitter through the scheduler,
+// port lists are unordered, and nil versus empty is not a difference.
+func houseRules() []cmp.Option {
+	return []cmp.Option{
+		cmpopts.IgnoreFields(Service{}, "DeployedAt"),
+		cmpopts.EquateApprox(0, 0.001),
+		cmpopts.SortSlices(func(a, b int) bool { return a < b }),
+		cmpopts.EquateEmpty(),
+	}
+}
+
+// SameService reports whether two services are equivalent under the house
+// comparison rules.
+func SameService(a, b Service) bool {
+	return cmp.Equal(a, b, houseRules()...)
+}
+
+// DiffService returns a human-readable diff of the drifted fields, or ""
+// when the services are equivalent under the house rules.
+func DiffService(a, b Service) string {
+	return cmp.Diff(a, b, houseRules()...)
+}
+
+// Report summarizes drift between two manifests. Added, Removed and Changed
+// hold service names sorted ascending; Details maps each changed service to
+// its diff text.
+type Report struct {
+	Added   []string
+	Removed []string
+	Changed []string
+	Details map[string]string
+}
+
+// BuildReport compares the before and after manifests keyed by service name.
+// A name appearing twice within a single manifest is an error.
+func BuildReport(before, after []Service) (Report, error) {
+	b, err := index(before)
+	if err != nil {
+		return Report{}, err
+	}
+	a, err := index(after)
+	if err != nil {
+		return Report{}, err
+	}
+
+	var rep Report
+	for name, sa := range a {
+		sb, ok := b[name]
+		switch {
+		case !ok:
+			rep.Added = append(rep.Added, name)
+		case !SameService(sb, sa):
+			rep.Changed = append(rep.Changed, name)
+			if rep.Details == nil {
+				rep.Details = make(map[string]string)
+			}
+			rep.Details[name] = DiffService(sb, sa)
+		}
+	}
+	for name := range b {
+		if _, ok := a[name]; !ok {
+			rep.Removed = append(rep.Removed, name)
+		}
+	}
+	sort.Strings(rep.Added)
+	sort.Strings(rep.Removed)
+	sort.Strings(rep.Changed)
+	return rep, nil
+}
+
+func index(list []Service) (map[string]Service, error) {
+	m := make(map[string]Service, len(list))
+	for _, s := range list {
+		if _, dup := m[s.Name]; dup {
+			return nil, fmt.Errorf("duplicate service %q", s.Name)
+		}
+		m[s.Name] = s
+	}
+	return m, nil
+}
