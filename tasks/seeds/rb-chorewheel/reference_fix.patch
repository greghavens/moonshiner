+# The co-op house chore wheel: fair weekly chore assignment with history
+# weighting, vacation deferrals, swaps, and a cat-able plain-text sheet.
+class ChoreWheel
+  NAME = /\A[a-z0-9-]+\z/
+  HEADER = "choresheet v1"
+
+  attr_reader :members, :chores
+
+  def initialize(members:, chores:)
+    raise ArgumentError, "no members" if members.empty?
+    raise ArgumentError, "no chores" if chores.empty?
+
+    (members + chores).each do |name|
+      raise ArgumentError, "invalid name: #{name.inspect}" unless name.is_a?(String) && name.match?(NAME)
+    end
+    check_unique!(members, "member")
+    check_unique!(chores, "chore")
+
+    @members = members.dup.freeze
+    @chores = chores.dup.freeze
+    @weeks = []      # one {chore => member} per planned week, chores order
+    @vacations = {}  # week number => [members]
+  end
+
+  def weeks_planned
+    @weeks.size
+  end
+
+  def assignments(week)
+    check_week!(week)
+    @weeks[week - 1].dup
+  end
+
+  # Total assignments per member across the recorded history (post-swap),
+  # every member listed, roster order.
+  def tally
+    counts = @members.to_h { |member| [member, 0] }
+    @weeks.each { |plan| plan.each_value { |member| counts[member] += 1 } }
+    counts
+  end
+
+  # Plans the next week and records it. Per chore, in chores order: fewest
+  # total assignments wins (counting chores already handed out this week),
+  # ties to whoever was assigned longest ago, then roster order. Nobody
+  # doubles up while an available member still has nothing this week.
+  def plan_week!
+    week = weeks_planned + 1
+    available = @members - (@vacations[week] || [])
+    plan = {}
+    unless available.empty?
+      @chores.each do |chore|
+        pool = available.reject { |member| plan.value?(member) }
+        pool = available if pool.empty?
+        plan[chore] = pick(pool, plan, week)
+      end
+    end
+    @weeks << plan
+    plan.dup
+  end
+
+  # Marks a future week as away for a member. Their totals don't move, so
+  # the fairness weighting automatically owes them a turn afterwards.
+  def vacation(member, week)
+    check_member!(member)
+    raise ArgumentError, "week #{week} already planned" if week <= weeks_planned
+
+    away = (@vacations[week] ||= [])
+    away << member unless away.include?(member)
+    self
+  end
+
+  # Exchanges two members' entire workloads for a planned week and returns
+  # the week's new plan. History (and future fairness) follows the swap.
+  def swap!(week, first, second)
+    check_week!(week)
+    check_member!(first)
+    check_member!(second)
+    raise ArgumentError, "cannot swap #{first} with themselves" if first == second
+
+    plan = @weeks[week - 1]
+    [first, second].each do |member|
+      unless plan.value?(member)
+        raise ArgumentError, "#{member} has no assignment in week #{week}"
+      end
+    end
+    swapped = plan.transform_values do |member|
+      if member == first then second
+      elsif member == second then first
+      else member
+      end
+    end
+    @weeks[week - 1] = swapped
+    swapped.dup
+  end
+
+  # Writes the chore sheet: header, roster, vacations (ascending week,
+  # roster order), then one line per planned week. Byte-stable.
+  def save(path)
+    lines = [HEADER,
+             "members #{@members.join(" ")}",
+             "chores #{@chores.join(" ")}"]
+    @vacations.keys.sort.each do |week|
+      @vacations[week].sort_by { |member| @members.index(member) }.each do |member|
+        lines << "vacation #{week} #{member}"
+      end
+    end
+    @weeks.each_with_index do |plan, index|
+      entries = plan.map { |chore, member| "#{chore}=#{member}" }
+      lines << ["week #{index + 1}", *entries].join(" ")
+    end
+    File.write(path, lines.join("\n") + "\n")
+    path
+  end
+
+  def self.load(path)
+    lines = File.readlines(path, chomp: true)
+    raise ArgumentError, "not a choresheet" unless lines.shift == HEADER
+
+    members = []
+    chores = []
+    vacations = []
+    weeks = []
+    lines.each do |line|
+      kind, rest = line.split(" ", 2)
+      case kind
+      when "members" then members = rest.split(" ")
+      when "chores" then chores = rest.split(" ")
+      when "vacation"
+        week, member = rest.split(" ")
+        vacations << [Integer(week), member]
+      when "week"
+        number, *entries = rest.split(" ")
+        weeks[Integer(number) - 1] = entries.to_h { |entry| entry.split("=", 2) }
+      else
+        raise ArgumentError, "not a choresheet"
+      end
+    end
+    wheel = new(members: members, chores: chores)
+    wheel.send(:restore, weeks.map { |plan| plan || {} }, vacations)
+    wheel
+  end
+
+  private
+
+  def restore(weeks, vacations)
+    @weeks = weeks
+    vacations.each do |week, member|
+      away = (@vacations[week] ||= [])
+      away << member unless away.include?(member)
+    end
+    self
+  end
+
+  def pick(pool, current_plan, week)
+    counts = tally
+    last = @members.to_h { |member| [member, 0] }
+    @weeks.each_with_index do |plan, index|
+      plan.each_value { |member| last[member] = index + 1 }
+    end
+    current_plan.each_value do |member|
+      counts[member] += 1
+      last[member] = week
+    end
+    pool.min_by { |member| [counts[member], last[member], @members.index(member)] }
+  end
+
+  def check_unique!(names, kind)
+    seen = {}
+    names.each do |name|
+      raise ArgumentError, "duplicate #{kind}: #{name}" if seen.key?(name)
+
+      seen[name] = true
+    end
+  end
+
+  def check_member!(member)
+    raise ArgumentError, "unknown member: #{member}" unless @members.include?(member)
+  end
+
+  def check_week!(week)
+    raise ArgumentError, "no week #{week}" unless week >= 1 && week <= weeks_planned
+  end
+end
