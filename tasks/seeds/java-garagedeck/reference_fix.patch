+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+
 /**
- * Issues tickets ("T-0001", "T-0002", ...) and tracks them by id: lookup,
- * markPaid, voidTicket, and the per-status listing the day report uses.
+ * Issues tickets ("T-0001", "T-0002", ...) and tracks them by id. Only an
+ * OPEN ticket may transition to PAID or VOID.
  */
 public class TicketDesk {
-    // TODO: issue / lookup / markPaid / voidTicket / byStatus.
+
+    private final Map<String, Ticket> tickets = new LinkedHashMap<>();
+    private int nextSerial = 1;
+
+    public Ticket issue(String plate, VehicleClass vehicleClass, String spaceId, long entryTick) {
+        String id = String.format(Locale.ROOT, "T-%04d", nextSerial++);
+        Ticket ticket = new Ticket(id, plate, vehicleClass, spaceId, entryTick);
+        tickets.put(id, ticket);
+        return ticket;
+    }
+
+    public Ticket lookup(String id) {
+        Ticket ticket = tickets.get(id);
+        if (ticket == null) {
+            throw new IllegalArgumentException("unknown ticket " + id);
+        }
+        return ticket;
+    }
+
+    private Ticket openTicket(String id) {
+        Ticket ticket = lookup(id);
+        if (ticket.status() != Ticket.Status.OPEN) {
+            throw new IllegalStateException("ticket " + id + " is not open");
+        }
+        return ticket;
+    }
+
+    public void markPaid(String id) {
+        openTicket(id).setStatus(Ticket.Status.PAID);
+    }
+
+    public void voidTicket(String id) {
+        openTicket(id).setStatus(Ticket.Status.VOID);
+    }
+
+    /** Tickets with the given status, sorted by ticket id ascending. */
+    public List<Ticket> byStatus(Ticket.Status status) {
+        List<Ticket> out = new ArrayList<>();
+        for (Ticket ticket : tickets.values()) {
+            if (ticket.status() == status) {
+                out.add(ticket);
+            }
+        }
+        out.sort((a, b) -> a.id().compareTo(b.id()));
+        return out;
+    }
 }
diff --git a/Validations.java b/Validations.java
index 2a06291..81f6d61 100644
--- a/Validations.java
+++ b/Validations.java
@@ -1,7 +1,60 @@
+import java.util.LinkedHashMap;
+import java.util.Map;
+
 /**
  * The merchant validation book: flat and percent discounts registered by
  * code and applied one at a time to a running amount (never below zero).
  */
 public class Validations {
-    // TODO: defineFlat / definePercent / defined / apply.
+
+    private static final class Rule {
+        final boolean percent;
+        final long value;
+
+        Rule(boolean percent, long value) {
+            this.percent = percent;
+            this.value = value;
+        }
+    }
+
+    private final Map<String, Rule> rules = new LinkedHashMap<>();
+
+    private void define(String code, Rule rule) {
+        if (rules.containsKey(code)) {
+            throw new IllegalArgumentException("validation " + code + " already defined");
+        }
+        rules.put(code, rule);
+    }
+
+    public void defineFlat(String code, long cents) {
+        if (cents < 0) {
+            throw new IllegalArgumentException("negative amount");
+        }
+        define(code, new Rule(false, cents));
+    }
+
+    public void definePercent(String code, int percent) {
+        if (percent < 0 || percent > 100) {
+            throw new IllegalArgumentException("percent must be 0..100");
+        }
+        define(code, new Rule(true, percent));
+    }
+
+    /** True when the code is in the book. */
+    public boolean defined(String code) {
+        return rules.containsKey(code);
+    }
+
+    /**
+     * The amount in cents after applying this one validation. Percent
+     * discounts round half-up in integer math; the result floors at zero.
+     */
+    public long apply(String code, long amountCents) {
+        Rule rule = rules.get(code);
+        if (rule == null) {
+            throw new IllegalArgumentException("unknown validation " + code);
+        }
+        long discount = rule.percent ? (amountCents * rule.value + 50) / 100 : rule.value;
+        return Math.max(0, amountCents - discount);
+    }
 }
