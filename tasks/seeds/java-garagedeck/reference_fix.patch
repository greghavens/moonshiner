+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
 /**
  * Front office for the whole deck: enter / stamp / exit / voidTicket on the
- * logical minute clock, plus the accessors the day report reads. Keeps the
- * Receipt record for every paid ticket.
+ * logical minute clock. Wires one SpaceInventory, one TicketDesk, and one
+ * Validations book, and files a Receipt for every paid ticket.
  */
 public class Garage {
-    // TODO: constructor with per-class space counts, the nested Receipt class,
-    // enter / stamp / exit / voidTicket, lookup / receiptFor / ticketsByStatus,
-    // freeSpaces / occupied / capacity, and validations().
+
+    /** Settlement record for one paid ticket. */
+    public static final class Receipt {
+        private final String ticketId;
+        private final long minutes;
+        private final long baseCents;
+        private final long dueCents;
+        private final List<String> appliedValidations;
+
+        Receipt(String ticketId, long minutes, long baseCents, long dueCents,
+                List<String> appliedValidations) {
+            this.ticketId = ticketId;
+            this.minutes = minutes;
+            this.baseCents = baseCents;
+            this.dueCents = dueCents;
+            this.appliedValidations = List.copyOf(appliedValidations);
+        }
+
+        public String ticketId() {
+            return ticketId;
+        }
+
+        public long minutes() {
+            return minutes;
+        }
+
+        public long baseCents() {
+            return baseCents;
+        }
+
+        public long dueCents() {
+            return dueCents;
+        }
+
+        public long discountCents() {
+            return baseCents - dueCents;
+        }
+
+        public List<String> appliedValidations() {
+            return appliedValidations;
+        }
+    }
+
+    private final SpaceInventory inventory;
+    private final TicketDesk desk = new TicketDesk();
+    private final Validations validations = new Validations();
+    private final Map<String, List<String>> stamps = new LinkedHashMap<>();
+    private final Map<String, Receipt> receipts = new LinkedHashMap<>();
+
+    public Garage(int motorcycle, int compact, int standard, int oversize) {
+        this.inventory = new SpaceInventory(motorcycle, compact, standard, oversize);
+    }
+
+    /** The garage's validation book; merchant codes are defined through it. */
+    public Validations validations() {
+        return validations;
+    }
+
+    /** Assigns a space and issues a ticket at the given tick. */
+    public Ticket enter(String plate, VehicleClass vehicleClass, long tick) {
+        String spaceId = inventory.assign(vehicleClass);
+        if (spaceId == null) {
+            throw new IllegalStateException("no space available for " + vehicleClass);
+        }
+        Ticket ticket = desk.issue(plate, vehicleClass, spaceId, tick);
+        stamps.put(ticket.id(), new ArrayList<>());
+        return ticket;
+    }
+
+    /** Records a validation stamp on an open ticket; order is preserved. */
+    public void stamp(String ticketId, String code) {
+        Ticket ticket = desk.lookup(ticketId);
+        if (ticket.status() != Ticket.Status.OPEN) {
+            throw new IllegalStateException("ticket " + ticketId + " is not open");
+        }
+        if (!validations.defined(code)) {
+            throw new IllegalArgumentException("unknown validation " + code);
+        }
+        List<String> applied = stamps.get(ticketId);
+        if (applied.contains(code)) {
+            throw new IllegalStateException(code + " already stamped on " + ticketId);
+        }
+        applied.add(code);
+    }
+
+    /** Settles an open ticket: charge, apply stamps in order, free the space. */
+    public Receipt exit(String ticketId, long tick) {
+        Ticket ticket = desk.lookup(ticketId);
+        if (ticket.status() != Ticket.Status.OPEN) {
+            throw new IllegalStateException("ticket " + ticketId + " is not open");
+        }
+        if (tick < ticket.entryTick()) {
+            throw new IllegalArgumentException("exit before entry");
+        }
+        long minutes = tick - ticket.entryTick();
+        long base = Pricing.charge(ticket.vehicleClass(), minutes);
+        long due = base;
+        List<String> applied = stamps.get(ticketId);
+        for (String code : applied) {
+            due = validations.apply(code, due);
+        }
+        desk.markPaid(ticketId);
+        inventory.release(ticket.spaceId());
+        Receipt receipt = new Receipt(ticketId, minutes, base, due, applied);
+        receipts.put(ticketId, receipt);
+        return receipt;
+    }
+
+    /** Voids an open ticket and releases its space; no charge, no receipt. */
+    public void voidTicket(String ticketId) {
+        Ticket ticket = desk.lookup(ticketId);
+        desk.voidTicket(ticketId);
+        inventory.release(ticket.spaceId());
+    }
+
+    public Ticket lookup(String ticketId) {
+        return desk.lookup(ticketId);
+    }
+
+    /** The filed receipt for a paid ticket. */
+    public Receipt receiptFor(String ticketId) {
+        Receipt receipt = receipts.get(ticketId);
+        if (receipt == null) {
+            throw new IllegalArgumentException("no receipt for " + ticketId);
+        }
+        return receipt;
+    }
+
+    public List<Ticket> ticketsByStatus(Ticket.Status status) {
+        return desk.byStatus(status);
+    }
+
+    public int freeSpaces(VehicleClass c) {
+        return inventory.free(c);
+    }
+
+    public int occupied(VehicleClass c) {
+        return inventory.total(c) - inventory.free(c);
+    }
+
+    public int capacity(VehicleClass c) {
+        return inventory.total(c);
+    }
 }
diff --git a/Pricing.java b/Pricing.java
index b342587..e5e6905 100644
--- a/Pricing.java
+++ b/Pricing.java
@@ -1,7 +1,69 @@
+import java.util.Locale;
+
 /**
- * Tariff math: first-hour / additional-hour tiers with a per-day cap, all in
- * integer cents, plus the money formatter used everywhere ("$12.50").
+ * The posted tariff: first-hour / additional-hour tiers with a per-day cap,
+ * in integer cents, plus the money formatter used everywhere.
  */
 public class Pricing {
-    // TODO: static charge(VehicleClass, long minutes) and static money(long cents).
+
+    private static final long MINUTES_PER_DAY = 1440;
+
+    private Pricing() {
+    }
+
+    private static long firstHour(VehicleClass c) {
+        return switch (c) {
+            case MOTORCYCLE -> 300;
+            case COMPACT -> 500;
+            case STANDARD -> 600;
+            case OVERSIZE -> 1000;
+        };
+    }
+
+    private static long additionalHour(VehicleClass c) {
+        return switch (c) {
+            case MOTORCYCLE -> 200;
+            case COMPACT -> 350;
+            case STANDARD -> 400;
+            case OVERSIZE -> 700;
+        };
+    }
+
+    private static long dailyMax(VehicleClass c) {
+        return switch (c) {
+            case MOTORCYCLE -> 1500;
+            case COMPACT -> 2500;
+            case STANDARD -> 3000;
+            case OVERSIZE -> 5000;
+        };
+    }
+
+    private static long tier(VehicleClass c, long startedHours) {
+        return firstHour(c) + (startedHours - 1) * additionalHour(c);
+    }
+
+    /** Charge in cents for a stay of the given length in minutes. */
+    public static long charge(VehicleClass vehicleClass, long minutes) {
+        if (minutes < 0) {
+            throw new IllegalArgumentException("negative duration");
+        }
+        long days = minutes / MINUTES_PER_DAY;
+        long rem = minutes % MINUTES_PER_DAY;
+        long remCharge;
+        if (days == 0) {
+            long hours = Math.max(1, (rem + 59) / 60);
+            remCharge = Math.min(tier(vehicleClass, hours), dailyMax(vehicleClass));
+        } else if (rem == 0) {
+            remCharge = 0;
+        } else {
+            long hours = (rem + 59) / 60;
+            remCharge = Math.min(tier(vehicleClass, hours), dailyMax(vehicleClass));
+        }
+        return days * dailyMax(vehicleClass) + remCharge;
+    }
+
+    /** Renders cents as "$12.50" (Locale.ROOT, no thousands separator). */
+    public static String money(long cents) {
+        return String.format(Locale.ROOT, "$%d.%02d", cents / 100, cents % 100);
+    }
 }
diff --git a/SpaceInventory.java b/SpaceInventory.java
index d37453f..4227526 100644
--- a/SpaceInventory.java
+++ b/SpaceInventory.java
@@ -1,12 +1,95 @@
+import java.util.EnumMap;
+import java.util.LinkedHashMap;
+import java.util.Locale;
+import java.util.Map;
+
 /**
  * Numbered parking spaces grouped by vehicle class.
  *
- * <p>Owns the space ids ("M-01", "C-01", ...), the assignment policy
- * (smallest fitting class, lowest number first), release, and the occupancy
- * counts the day report reads. See the operations brief for the exact
- * contract.
+ * <p>Space ids are {@code {code}-{number}} with the number 1-based and
+ * zero-padded to two digits (M-01, C-01, ...). Assignment walks the classes
+ * smallest to largest, skips classes the vehicle does not fit, and takes the
+ * lowest-numbered free space of the first fitting class that has one.
  */
 public class SpaceInventory {
-    // TODO: constructor taking per-class counts, plus
-    // assign / release / isOccupied / free / total.
+
+    private final Map<VehicleClass, Integer> capacity = new EnumMap<>(VehicleClass.class);
+    private final Map<String, Boolean> occupied = new LinkedHashMap<>();
+
+    public SpaceInventory(int motorcycle, int compact, int standard, int oversize) {
+        addRow(VehicleClass.MOTORCYCLE, motorcycle);
+        addRow(VehicleClass.COMPACT, compact);
+        addRow(VehicleClass.STANDARD, standard);
+        addRow(VehicleClass.OVERSIZE, oversize);
+    }
+
+    private void addRow(VehicleClass c, int count) {
+        if (count < 0) {
+            throw new IllegalArgumentException("negative space count");
+        }
+        capacity.put(c, count);
+        for (int i = 1; i <= count; i++) {
+            occupied.put(spaceId(c, i), false);
+        }
+    }
+
+    private static String spaceId(VehicleClass c, int number) {
+        return String.format(Locale.ROOT, "%s-%02d", c.code(), number);
+    }
+
+    /**
+     * Assigns the lowest-numbered free space of the smallest fitting class
+     * that has one; null when nothing fits.
+     */
+    public String assign(VehicleClass vehicle) {
+        for (VehicleClass c : VehicleClass.values()) {
+            if (!vehicle.fitsIn(c)) {
+                continue;
+            }
+            for (int i = 1; i <= capacity.get(c); i++) {
+                String id = spaceId(c, i);
+                if (!occupied.get(id)) {
+                    occupied.put(id, true);
+                    return id;
+                }
+            }
+        }
+        return null;
+    }
+
+    /** Frees an occupied space. */
+    public void release(String spaceId) {
+        Boolean taken = occupied.get(spaceId);
+        if (taken == null) {
+            throw new IllegalArgumentException("unknown space " + spaceId);
+        }
+        if (!taken) {
+            throw new IllegalStateException("space " + spaceId + " is not occupied");
+        }
+        occupied.put(spaceId, false);
+    }
+
+    public boolean isOccupied(String spaceId) {
+        Boolean taken = occupied.get(spaceId);
+        if (taken == null) {
+            throw new IllegalArgumentException("unknown space " + spaceId);
+        }
+        return taken;
+    }
+
+    /** Capacity of the class row. */
+    public int total(VehicleClass c) {
+        return capacity.get(c);
+    }
+
+    /** Currently-free spaces in the class row. */
+    public int free(VehicleClass c) {
+        int free = 0;
+        for (int i = 1; i <= capacity.get(c); i++) {
+            if (!occupied.get(spaceId(c, i))) {
+                free++;
+            }
+        }
+        return free;
+    }
 }
