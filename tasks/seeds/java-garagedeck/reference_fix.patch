+import java.util.List;
+
 /**
  * End-of-day reconciliation export: open/paid/voided tickets, occupancy per
  * class, and revenue totals in one fixed plaintext format.
  */
 public class DayReport {
-    // TODO: static render(Garage, long tick).
+
+    private DayReport() {
+    }
+
+    /** Renders the reconciliation report at the given tick, character-exact. */
+    public static String render(Garage garage, long tick) {
+        StringBuilder out = new StringBuilder();
+        out.append("== reconciliation @ tick ").append(tick).append(" ==\n");
+
+        List<Ticket> open = garage.ticketsByStatus(Ticket.Status.OPEN);
+        out.append("open tickets: ").append(open.size()).append('\n');
+        for (Ticket t : open) {
+            out.append("  ").append(t.id()).append(' ').append(t.plate()).append(' ')
+                    .append(t.vehicleClass()).append(' ').append(t.spaceId())
+                    .append(" in=").append(t.entryTick()).append('\n');
+        }
+
+        List<Ticket> paid = garage.ticketsByStatus(Ticket.Status.PAID);
+        out.append("paid tickets: ").append(paid.size()).append('\n');
+        long baseTotal = 0;
+        long dueTotal = 0;
+        for (Ticket t : paid) {
+            Garage.Receipt r = garage.receiptFor(t.id());
+            baseTotal += r.baseCents();
+            dueTotal += r.dueCents();
+            out.append("  ").append(t.id()).append(' ').append(t.plate()).append(' ')
+                    .append(t.vehicleClass())
+                    .append(" due ").append(Pricing.money(r.dueCents()))
+                    .append(" (base ").append(Pricing.money(r.baseCents()))
+                    .append(", validated ").append(Pricing.money(r.discountCents()))
+                    .append(")\n");
+        }
+
+        List<Ticket> voided = garage.ticketsByStatus(Ticket.Status.VOID);
+        out.append("voided tickets: ").append(voided.size()).append('\n');
+        for (Ticket t : voided) {
+            out.append("  ").append(t.id()).append(' ').append(t.plate()).append(' ')
+                    .append(t.vehicleClass()).append('\n');
+        }
+
+        out.append("occupancy:");
+        for (VehicleClass c : VehicleClass.values()) {
+            out.append(' ').append(c.code()).append(' ')
+                    .append(garage.occupied(c)).append('/').append(garage.capacity(c));
+        }
+        out.append('\n');
+
+        out.append("revenue: base ").append(Pricing.money(baseTotal))
+                .append(", validated ").append(Pricing.money(baseTotal - dueTotal))
+                .append(", due ").append(Pricing.money(dueTotal)).append('\n');
+        return out.toString();
+    }
 }
