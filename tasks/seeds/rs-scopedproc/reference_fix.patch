 //! rs-scopedproc: scoped-thread chunk processor over borrowed slices.
-//! Implementation pending — see tests/scopedproc.rs for the acceptance
-//! contract.
+//!
+//! Workers borrow the input directly via `std::thread::scope` — no `Arc`,
+//! no cloning, and map results may themselves borrow from the input. The
+//! merge is a left fold in chunk-index order on the calling thread, so the
+//! result never depends on which worker finished first.
+
+use std::thread;
+
+#[derive(Debug, PartialEq, Eq)]
+pub enum ChunkError {
+    /// `chunk_size` was zero.
+    ZeroChunkSize,
+    /// `workers` was zero.
+    ZeroWorkers,
+}
+
+/// Split `items` into contiguous `chunk_size` chunks (last one ragged), map
+/// each chunk on one of `min(workers, chunks)` scoped worker threads, and
+/// left-fold the results in chunk-index order.
+///
+/// Chunks are assigned round-robin: worker `w` owns chunks `w`, `w + n`,
+/// `w + 2n`, ... and walks them in ascending index order.
+///
+/// Returns `Ok(None)` for empty input (the map is never invoked). Argument
+/// validation runs first — `chunk_size` before `workers` — even when the
+/// input is empty.
+pub fn process_chunks<'a, T, R, M, G>(
+    items: &'a [T],
+    chunk_size: usize,
+    workers: usize,
+    map_fn: M,
+    mut merge_fn: G,
+) -> Result<Option<R>, ChunkError>
+where
+    T: Sync,
+    R: Send,
+    M: Fn(usize, &'a [T]) -> R + Sync,
+    G: FnMut(R, R) -> R,
+{
+    if chunk_size == 0 {
+        return Err(ChunkError::ZeroChunkSize);
+    }
+    if workers == 0 {
+        return Err(ChunkError::ZeroWorkers);
+    }
+    if items.is_empty() {
+        return Ok(None);
+    }
+
+    let chunks: Vec<&'a [T]> = items.chunks(chunk_size).collect();
+    let n_workers = workers.min(chunks.len());
+
+    // Slot per chunk; workers report (index, result) and the fold below
+    // consumes the slots in index order.
+    let mut results: Vec<Option<R>> = Vec::with_capacity(chunks.len());
+    results.resize_with(chunks.len(), || None);
+
+    thread::scope(|s| {
+        let map_fn = &map_fn;
+        let chunks = &chunks;
+        let handles: Vec<_> = (0..n_workers)
+            .map(|w| {
+                s.spawn(move || {
+                    let mut out = Vec::new();
+                    let mut idx = w;
+                    while idx < chunks.len() {
+                        out.push((idx, map_fn(idx, chunks[idx])));
+                        idx += n_workers;
+                    }
+                    out
+                })
+            })
+            .collect();
+        for handle in handles {
+            let partials = handle.join().expect("worker thread panicked");
+            for (idx, value) in partials {
+                results[idx] = Some(value);
+            }
+        }
+    });
+
+    let mut ordered = results
+        .into_iter()
+        .map(|slot| slot.expect("every chunk produces exactly one result"));
+    let mut acc = ordered.next().expect("input is non-empty");
+    for value in ordered {
+        acc = merge_fn(acc, value);
+    }
+    Ok(Some(acc))
+}
