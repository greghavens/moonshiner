@@ -0,0 +1,94 @@
+import { TOMBSTONE, isExpired, makeEntry } from './entries.ts';
+import type { Entry, Layer, Slot } from './entries.ts';
+
+type StoreOptions = { clock?: () => number };
+
+export class KVStore {
+  private base: Map<string, Entry>;
+  private layers: Layer[];
+  private clock: () => number;
+
+  constructor(opts: StoreOptions = {}) {
+    this.base = new Map();
+    this.layers = [];
+    this.clock = opts.clock ?? Date.now;
+  }
+
+  // Topmost slot for a key, walking open transaction levels down to the base.
+  // A tombstone or an expired entry masks everything beneath it.
+  private slot(key: string): Slot | undefined {
+    for (let i = this.layers.length - 1; i >= 0; i--) {
+      const s = this.layers[i].get(key);
+      if (s !== undefined) return s;
+    }
+    return this.base.get(key);
+  }
+
+  private liveEntry(key: string): Entry | undefined {
+    const s = this.slot(key);
+    if (s === undefined || s === TOMBSTONE) return undefined;
+    return isExpired(s, this.clock()) ? undefined : s;
+  }
+
+  set(key: string, value: unknown, opts: { ttlMs?: number } = {}): void {
+    const entry = makeEntry(value, this.clock(), opts.ttlMs);
+    const top = this.layers[this.layers.length - 1];
+    if (top) top.set(key, entry);
+    else this.base.set(key, entry);
+  }
+
+  get(key: string): unknown {
+    return this.liveEntry(key)?.value;
+  }
+
+  has(key: string): boolean {
+    return this.liveEntry(key) !== undefined;
+  }
+
+  delete(key: string): boolean {
+    const wasLive = this.liveEntry(key) !== undefined;
+    const top = this.layers[this.layers.length - 1];
+    if (top) {
+      if (wasLive) top.set(key, TOMBSTONE);
+    } else {
+      this.base.delete(key);
+    }
+    return wasLive;
+  }
+
+  keys(): string[] {
+    const seen = new Set<string>();
+    for (const key of this.base.keys()) seen.add(key);
+    for (const layer of this.layers) for (const key of layer.keys()) seen.add(key);
+    const out: string[] = [];
+    for (const key of seen) if (this.liveEntry(key) !== undefined) out.push(key);
+    return out.sort();
+  }
+
+  begin(): void {
+    this.layers.push(new Map());
+  }
+
+  commit(): void {
+    const top = this.layers.pop();
+    if (!top) throw new Error('no active transaction');
+    const below = this.layers[this.layers.length - 1];
+    for (const [key, s] of top) {
+      if (below) {
+        below.set(key, s);
+      } else if (s === TOMBSTONE) {
+        this.base.delete(key);
+      } else {
+        this.base.set(key, s);
+      }
+    }
+  }
+
+  rollback(): void {
+    if (!this.layers.pop()) throw new Error('no active transaction');
+  }
+
+  depth(): number {
+    return this.layers.length;
+  }
+}
