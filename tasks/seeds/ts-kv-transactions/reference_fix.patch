+// Internal entry/layer bookkeeping for KVStore. An Entry pins its absolute
+// expiry at write time; a Layer is one open transaction level where deleted
+// keys are recorded as tombstones so they mask lower layers.
+
+export type Entry = { value: unknown; expiresAt: number | null };
+
+export const TOMBSTONE: unique symbol = Symbol('tombstone');
+
+export type Slot = Entry | typeof TOMBSTONE;
+
+export type Layer = Map<string, Slot>;
+
+export function isExpired(entry: Entry, now: number): boolean {
+  return entry.expiresAt !== null && now >= entry.expiresAt;
+}
+
+export function makeEntry(value: unknown, now: number, ttlMs?: number): Entry {
+  if (ttlMs === undefined) return { value, expiresAt: null };
+  if (!(ttlMs > 0)) throw new RangeError(`ttlMs must be positive, got ${ttlMs}`);
+  return { value, expiresAt: now + ttlMs };
+}
