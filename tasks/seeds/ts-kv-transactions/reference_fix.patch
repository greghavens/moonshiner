+import type { KVStore } from './store.ts';
+
+type Query = {
+  prefix?: string;
+  where?: (value: unknown, key: string) => boolean;
+  limit?: number;
+};
+
+type Hit = { key: string; value: unknown };
+
+// Read-only query layer over the public KVStore surface: keys() already
+// excludes expired entries and reflects open-transaction state, so find()
+// inherits both properties for free.
+export function find(store: KVStore, q: Query = {}): Hit[] {
+  const out: Hit[] = [];
+  for (const key of store.keys()) {
+    if (q.prefix !== undefined && !key.startsWith(q.prefix)) continue;
+    const value = store.get(key);
+    if (q.where !== undefined && !q.where(value, key)) continue;
+    out.push({ key, value });
+    if (q.limit !== undefined && out.length >= q.limit) break;
+  }
+  return out;
+}
diff --git a/store.ts b/store.ts
