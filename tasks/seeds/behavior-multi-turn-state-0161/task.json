{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0161",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "calendar",
  "prompt": "Retrieve meeting CAL-6193 and confirm its name, current location, and status. Do not change it or contact anyone yet. If the tool omits a requested field, call it unknown instead of filling it in.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same meeting to Room Aspen. Do not change its scheduled date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Room Birch, not Room Aspen. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "calendar_get",
    "calendar_search",
    "calendar_update",
    "calendar_create",
    "calendar_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "CAL-6193",
        "name": "Accessibility working session",
        "location": "Room Juniper",
        "date": "2026-08-17",
        "status": "active"
      },
      {
        "id": "CAL-9193",
        "name": "Q4 budget check-in",
        "location": "Chicago Office",
        "date": "2026-09-22",
        "status": "pending"
      },
      {
        "id": "CAL-12193",
        "name": "Accessibility working session archive",
        "location": "Chicago Office",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_get",
            "arguments": {
              "id": "CAL-6193"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_update",
            "arguments": {
              "id": "CAL-6193",
              "location": "Room Aspen"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_update",
            "arguments": {
              "id": "CAL-6193",
              "location": "Room Birch"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its scheduled date or status."
      }
    ],
    "state_assertions": [
      "CAL-6193.location == Room Birch",
      "CAL-6193.location != Room Aspen",
      "CAL-6193.date == 2026-08-17",
      "CAL-9193.date == 2026-09-22",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "calendar_create",
      "calendar_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location.",
      "Label any requested field omitted by a tool result as unknown."
    ]
  },
  "training_tags": [
    "conversation:multi-turn",
    "if:correction",
    "if:grounded-response",
    "if:negative-constraint",
    "round:2",
    "source:breadth-reserve",
    "state:entity-continuity",
    "weakness:multi-turn-state"
  ]
}
