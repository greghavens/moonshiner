+"""Music-library ORM layer (SQLAlchemy 2.0 style)."""
+from __future__ import annotations
+
+from sqlalchemy import Engine, ForeignKey, String, create_engine, func, select
+from sqlalchemy.orm import (
+    DeclarativeBase,
+    Mapped,
+    Session,
+    mapped_column,
+    relationship,
+)
+
+
+class Base(DeclarativeBase):
+    pass
+
+
+class Artist(Base):
+    __tablename__ = "artists"
+
+    id: Mapped[int] = mapped_column(primary_key=True)
+    name: Mapped[str] = mapped_column(String(200), unique=True)
+
+    albums: Mapped[list[Album]] = relationship(
+        back_populates="artist", cascade="all, delete-orphan")
+
+
+class Album(Base):
+    __tablename__ = "albums"
+
+    id: Mapped[int] = mapped_column(primary_key=True)
+    title: Mapped[str] = mapped_column(String(200))
+    year: Mapped[int]
+    artist_id: Mapped[int] = mapped_column(ForeignKey("artists.id"))
+
+    artist: Mapped[Artist] = relationship(back_populates="albums")
+    tracks: Mapped[list[Track]] = relationship(
+        back_populates="album", cascade="all, delete-orphan",
+        order_by="Track.position")
+
+
+class Track(Base):
+    __tablename__ = "tracks"
+
+    id: Mapped[int] = mapped_column(primary_key=True)
+    title: Mapped[str] = mapped_column(String(200))
+    seconds: Mapped[int]
+    position: Mapped[int]
+    album_id: Mapped[int] = mapped_column(ForeignKey("albums.id"))
+
+    album: Mapped[Album] = relationship(back_populates="tracks")
+
+
+class Playlist(Base):
+    __tablename__ = "playlists"
+
+    id: Mapped[int] = mapped_column(primary_key=True)
+    name: Mapped[str] = mapped_column(String(200), unique=True)
+
+    entries: Mapped[list[PlaylistEntry]] = relationship(
+        back_populates="playlist", cascade="all, delete-orphan",
+        order_by="PlaylistEntry.position")
+
+
+class PlaylistEntry(Base):
+    __tablename__ = "playlist_entries"
+
+    playlist_id: Mapped[int] = mapped_column(
+        ForeignKey("playlists.id"), primary_key=True)
+    position: Mapped[int] = mapped_column(primary_key=True)
+    track_id: Mapped[int] = mapped_column(ForeignKey("tracks.id"))
+
+    playlist: Mapped[Playlist] = relationship(back_populates="entries")
+    track: Mapped[Track] = relationship()
+
+
+def make_engine() -> Engine:
+    """Engine over a private in-memory SQLite database."""
+    return create_engine("sqlite://")
+
+
+def init_db(engine: Engine) -> None:
+    """Create the full schema on the given engine."""
+    Base.metadata.create_all(engine)
+
+
+def add_album(session: Session, artist_name: str, title: str, year: int,
+              tracks: list[tuple[str, int]]) -> Album:
+    """Add an album (reusing the artist row by name) without committing.
+
+    The caller owns the transaction; we only flush so ids are assigned.
+    """
+    artist = session.scalars(
+        select(Artist).where(Artist.name == artist_name)).one_or_none()
+    if artist is None:
+        artist = Artist(name=artist_name)
+        session.add(artist)
+    album = Album(title=title, year=year, artist=artist)
+    for position, (track_title, seconds) in enumerate(tracks, start=1):
+        album.tracks.append(
+            Track(title=track_title, seconds=seconds, position=position))
+    session.add(album)
+    session.flush()
+    return album
+
+
+def album_runtimes(session: Session, artist_name: str) -> list[tuple[str, int]]:
+    """(album_title, total_seconds) per album of the artist, by album year."""
+    rows = session.execute(
+        select(Album.title, func.sum(Track.seconds))
+        .join(Track, Track.album_id == Album.id)
+        .join(Artist, Album.artist_id == Artist.id)
+        .where(Artist.name == artist_name)
+        .group_by(Album.id)
+        .order_by(Album.year)
+    ).all()
+    return [(title, int(total)) for title, total in rows]
+
+
+def tracks_longer_than(session: Session,
+                       min_seconds: int) -> list[tuple[str, str, str]]:
+    """(artist, album, track) for tracks strictly longer than min_seconds."""
+    rows = session.execute(
+        select(Artist.name, Album.title, Track.title)
+        .join(Album, Album.artist_id == Artist.id)
+        .join(Track, Track.album_id == Album.id)
+        .where(Track.seconds > min_seconds)
+        .order_by(Track.seconds.desc(), Track.title.asc())
+    ).all()
+    return [tuple(row) for row in rows]
+
+
+def playlist_titles(session: Session, playlist_name: str) -> list[str]:
+    """Track titles of the playlist in position order."""
+    rows = session.execute(
+        select(Track.title)
+        .join(PlaylistEntry, PlaylistEntry.track_id == Track.id)
+        .join(Playlist, PlaylistEntry.playlist_id == Playlist.id)
+        .where(Playlist.name == playlist_name)
+        .order_by(PlaylistEntry.position)
+    ).all()
+    return [title for (title,) in rows]
