--- /dev/null
+++ b/mmsolver.ps1
@@ -0,0 +1,70 @@
+# Mastermind solver: consistency filtering with a pinned 1122 opener and
+# lexicographic-first candidate selection.
+[CmdletBinding()]
+param([string]$Secret = '')
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if ($Secret -cnotmatch '^[1-6]{4}$') {
+    [Console]::Error.WriteLine('error: secret must be 4 digits 1-6')
+    exit 2
+}
+
+# All 1296 codes in lexicographic order, plus a per-code digit-count table so
+# scoring stays cheap inside the filter loop.
+$codes = [System.Collections.Generic.List[string]]::new()
+$countsByCode = [System.Collections.Generic.Dictionary[string, int[]]]::new()
+foreach ($a in 1..6) {
+    foreach ($b in 1..6) {
+        foreach ($c in 1..6) {
+            foreach ($d in 1..6) {
+                $code = "$a$b$c$d"
+                $codes.Add($code)
+                $counts = [int[]]::new(7)
+                $counts[$a]++; $counts[$b]++; $counts[$c]++; $counts[$d]++
+                $countsByCode[$code] = $counts
+            }
+        }
+    }
+}
+
+# Returns black*16 + white packed into one int (cheaper than an array per call).
+function Get-PackedScore {
+    param([string]$Guess, [string]$Code)
+    $black = 0
+    for ($i = 0; $i -lt 4; $i++) {
+        if ($Guess[$i] -ceq $Code[$i]) { $black++ }
+    }
+    $g = $countsByCode[$Guess]
+    $s = $countsByCode[$Code]
+    $total = 0
+    for ($d = 1; $d -le 6; $d++) {
+        $total += [Math]::Min($g[$d], $s[$d])
+    }
+    ($black * 16) + ($total - $black)
+}
+
+$cands = $codes
+$guess = '1122'
+$n = 0
+while ($true) {
+    $n++
+    $feedback = Get-PackedScore -Guess $guess -Code $Secret
+    $survivors = [System.Collections.Generic.List[string]]::new()
+    foreach ($c in $cands) {
+        if ((Get-PackedScore -Guess $guess -Code $c) -eq $feedback) {
+            $survivors.Add($c)
+        }
+    }
+    $cands = $survivors
+    $black = [int][Math]::Floor($feedback / 16)
+    $white = $feedback % 16
+    Write-Output ("GUESS {0} {1} black={2} white={3} candidates={4}" -f $n, $guess, $black, $white, $cands.Count)
+    if ($black -eq 4) {
+        $unit = if ($n -eq 1) { 'guess' } else { 'guesses' }
+        Write-Output ("CRACKED {0} in {1} {2}" -f $Secret, $n, $unit)
+        exit 0
+    }
+    $guess = $cands[0]
+}
