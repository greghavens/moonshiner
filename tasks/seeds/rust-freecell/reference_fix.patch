+//! FreeCell engine for the solitaire corner: text deals in, deterministic
+//! rule enforcement, and the supermove capacity law pinned exactly.
+
+const RANKS: &[u8] = b"A23456789TJQK";
+const SUITS: &[u8] = b"CDHS";
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+struct Card {
+    rank: u8, // 1..=13
+    suit: u8, // index into SUITS
+}
+
+impl Card {
+    fn parse(tok: &str) -> Option<Card> {
+        let b = tok.as_bytes();
+        if b.len() != 2 {
+            return None;
+        }
+        let rank = RANKS.iter().position(|&r| r == b[0])? as u8 + 1;
+        let suit = SUITS.iter().position(|&s| s == b[1])? as u8;
+        Some(Card { rank, suit })
+    }
+
+    fn name(&self) -> String {
+        format!(
+            "{}{}",
+            RANKS[self.rank as usize - 1] as char,
+            SUITS[self.suit as usize] as char
+        )
+    }
+
+    fn is_red(&self) -> bool {
+        SUITS[self.suit as usize] == b'D' || SUITS[self.suit as usize] == b'H'
+    }
+
+    /// Can `self` go on top of `below` in a cascade build?
+    fn stacks_on(&self, below: &Card) -> bool {
+        self.rank + 1 == below.rank && self.is_red() != below.is_red()
+    }
+}
+
+#[derive(Debug, Clone)]
+pub struct Game {
+    cascades: [Vec<Card>; 8],
+    free: [Option<Card>; 4],
+    home: [u8; 4], // top rank per suit, 0 = empty
+}
+
+fn parse_move(mv: &str) -> Option<(u8, u8)> {
+    let b = mv.as_bytes();
+    if b.len() != 2 {
+        return None;
+    }
+    let src_ok = (b'1'..=b'8').contains(&b[0]) || (b'a'..=b'd').contains(&b[0]);
+    let dst_ok = (b'1'..=b'8').contains(&b[1]) || (b'a'..=b'd').contains(&b[1]) || b[1] == b'h';
+    let both_free = (b'a'..=b'd').contains(&b[0]) && (b'a'..=b'd').contains(&b[1]);
+    if !src_ok || !dst_ok || b[0] == b[1] || both_free {
+        return None;
+    }
+    Some((b[0], b[1]))
+}
+
+impl Game {
+    pub fn load(deal: &str) -> Result<Game, String> {
+        let lines: Vec<&str> = deal
+            .lines()
+            .map(|l| l.trim_end())
+            .filter(|l| !l.is_empty())
+            .collect();
+        if lines.len() != 8 {
+            return Err(format!("expected 8 cascades, got {}", lines.len()));
+        }
+        let mut cascades: [Vec<Card>; 8] = Default::default();
+        let mut seen = [false; 52];
+        for (i, line) in lines.iter().enumerate() {
+            let want = if i < 4 { 7 } else { 6 };
+            let toks: Vec<&str> = line.split_whitespace().collect();
+            if toks.len() != want {
+                return Err(format!(
+                    "cascade {} must have {} cards, got {}",
+                    i + 1,
+                    want,
+                    toks.len()
+                ));
+            }
+            for tok in toks {
+                let card = Card::parse(tok).ok_or_else(|| format!("bad card: {tok}"))?;
+                let idx = (card.suit as usize) * 13 + card.rank as usize - 1;
+                if seen[idx] {
+                    return Err(format!("duplicate card: {}", card.name()));
+                }
+                seen[idx] = true;
+                cascades[i].push(card);
+            }
+        }
+        Ok(Game {
+            cascades,
+            free: [None; 4],
+            home: [0; 4],
+        })
+    }
+
+    pub fn render(&self) -> String {
+        let mut out = Vec::with_capacity(10);
+        let free = self
+            .free
+            .iter()
+            .map(|c| c.map_or(".".to_string(), |c| c.name()))
+            .collect::<Vec<_>>()
+            .join(" ");
+        out.push(format!("free: {free}"));
+        let home = (0..4)
+            .map(|s| {
+                let top = self.home[s];
+                let shown = if top == 0 {
+                    ".".to_string()
+                } else {
+                    (RANKS[top as usize - 1] as char).to_string()
+                };
+                format!("{}:{}", SUITS[s] as char, shown)
+            })
+            .collect::<Vec<_>>()
+            .join(" ");
+        out.push(format!("home: {home}"));
+        for (i, cascade) in self.cascades.iter().enumerate() {
+            let mut line = format!("{}:", i + 1);
+            for card in cascade {
+                line.push(' ');
+                line.push_str(&card.name());
+            }
+            out.push(line);
+        }
+        out.join("\n")
+    }
+
+    pub fn is_won(&self) -> bool {
+        self.home.iter().all(|&r| r == 13)
+    }
+
+    fn empty_free(&self) -> usize {
+        self.free.iter().filter(|c| c.is_none()).count()
+    }
+
+    fn empty_cascades(&self) -> usize {
+        self.cascades.iter().filter(|c| c.is_empty()).count()
+    }
+
+    /// The supermove capacity law: (empty free cells + 1) * 2^(empty
+    /// cascades); a move landing ON an empty cascade cannot count that
+    /// cascade toward the multiplier.
+    pub fn max_supermove(&self, to_empty: bool) -> usize {
+        let empties = if to_empty {
+            self.empty_cascades().saturating_sub(1)
+        } else {
+            self.empty_cascades()
+        };
+        (self.empty_free() + 1) << empties
+    }
+
+    /// Length of the maximal ordered run (descending, alternating colors) at
+    /// the top of a cascade.
+    fn run_len(&self, i: usize) -> usize {
+        let c = &self.cascades[i];
+        let mut n = usize::from(!c.is_empty());
+        while n < c.len() && c[c.len() - n].stacks_on(&c[c.len() - n - 1]) {
+            n += 1;
+        }
+        n
+    }
+
+    fn send_home(&mut self, card: Card) -> Result<(), String> {
+        if self.home[card.suit as usize] + 1 != card.rank {
+            return Err("does not fit".to_string());
+        }
+        self.home[card.suit as usize] = card.rank;
+        Ok(())
+    }
+
+    pub fn apply(&mut self, mv: &str) -> Result<(), String> {
+        let (src, dst) = parse_move(mv).ok_or_else(|| format!("bad move: {mv}"))?;
+        match (src, dst) {
+            (b'a'..=b'd', _) => {
+                let cell = (src - b'a') as usize;
+                let card = self.free[cell]
+                    .ok_or_else(|| format!("free cell {} is empty", src as char))?;
+                match dst {
+                    b'h' => self.send_home(card)?,
+                    _ => {
+                        let to = (dst - b'1') as usize;
+                        if let Some(top) = self.cascades[to].last() {
+                            if !card.stacks_on(top) {
+                                return Err("does not fit".to_string());
+                            }
+                        }
+                        self.cascades[to].push(card);
+                    }
+                }
+                self.free[cell] = None;
+                Ok(())
+            }
+            (b'1'..=b'8', b'a'..=b'd') => {
+                let from = (src - b'1') as usize;
+                let cell = (dst - b'a') as usize;
+                if self.free[cell].is_some() {
+                    return Err(format!("free cell {} is occupied", dst as char));
+                }
+                let card = self.cascades[from]
+                    .pop()
+                    .ok_or_else(|| "empty source".to_string())?;
+                self.free[cell] = Some(card);
+                Ok(())
+            }
+            (b'1'..=b'8', b'h') => {
+                let from = (src - b'1') as usize;
+                let card = *self.cascades[from]
+                    .last()
+                    .ok_or_else(|| "empty source".to_string())?;
+                self.send_home(card)?;
+                self.cascades[from].pop();
+                Ok(())
+            }
+            (b'1'..=b'8', b'1'..=b'8') => {
+                let from = (src - b'1') as usize;
+                let to = (dst - b'1') as usize;
+                if self.cascades[from].is_empty() {
+                    return Err("empty source".to_string());
+                }
+                let run = self.run_len(from);
+                let take = match self.cascades[to].last() {
+                    Some(top) => {
+                        let top = *top;
+                        let mut fit = None;
+                        for k in 1..=run {
+                            let card = self.cascades[from][self.cascades[from].len() - k];
+                            if card.stacks_on(&top) {
+                                fit = Some(k);
+                                break;
+                            }
+                        }
+                        let k = fit.ok_or_else(|| "does not fit".to_string())?;
+                        let cap = self.max_supermove(false);
+                        if k > cap {
+                            return Err(format!("supermove needs {k} cards, capacity is {cap}"));
+                        }
+                        k
+                    }
+                    None => run.min(self.max_supermove(true)),
+                };
+                let at = self.cascades[from].len() - take;
+                let moved: Vec<Card> = self.cascades[from].split_off(at);
+                self.cascades[to].extend(moved);
+                Ok(())
+            }
+            _ => unreachable!(),
+        }
+    }
+
+    pub fn apply_script(&mut self, moves: &str) -> Result<usize, String> {
+        let mut n = 0;
+        for mv in moves.split_whitespace() {
+            n += 1;
+            self.apply(mv)
+                .map_err(|e| format!("move {n} ({mv}): {e}"))?;
+        }
+        Ok(n)
+    }
+}
