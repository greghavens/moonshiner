 }
 
-export type Middleware = (ctx: Context, next: () => void) => void;
+export type Middleware = (ctx: Context, next: () => Promise<void>) => unknown;
+export type ErrorHandler = (
+  err: unknown,
+  ctx: Context,
+  next: (err?: unknown) => Promise<void>,
+) => unknown;
+
+interface Entry {
+  fn: Middleware | ErrorHandler;
+  isError: boolean;
+}
+
+/** Wraps an error that has already exhausted the handler chain so outer
+ *  frames rethrow it instead of feeding it to the handlers again. */
+class ExhaustedError extends Error {
+  original: unknown;
+
+  constructor(original: unknown) {
+    super('pipeline error with no remaining handler');
+    this.original = original;
+  }
+}
 
 export class Pipeline {
-  private stack: Middleware[] = [];
+  private stack: Entry[] = [];
 
-  use(middleware: Middleware): this {
-    this.stack.push(middleware);
+  use(middleware: Middleware | ErrorHandler): this {
+    this.stack.push({ fn: middleware, isError: middleware.length >= 3 });
     return this;
   }
 
-  run(ctx: Context): Context {
-    const dispatch = (index: number): void => {
-      if (index >= this.stack.length) return;
-      let called = false;
-      const next = (): void => {
-        if (called) throw new Error('next() called twice');
-        called = true;
-        dispatch(index + 1);
-      };
-      this.stack[index](ctx, next);
-    };
-    dispatch(0);
+  async run(ctx: Context): Promise<Context> {
+    try {
+      await this.dispatch(0, ctx);
+    } catch (err) {
+      try {
+        await this.handleError(err, ctx, 0);
+      } catch (unhandled) {
+        throw unhandled instanceof ExhaustedError ? unhandled.original : unhandled;
+      }
+    }
     return ctx;
   }
+
+  private async dispatch(start: number, ctx: Context): Promise<void> {
+    let index = start;
+    while (index < this.stack.length && this.stack[index].isError) index++;
+    if (index >= this.stack.length) return;
+
+    let called = false;
+    const next = (): Promise<void> => {
+      if (called) throw new Error('next() called twice');
+      called = true;
+      return this.dispatch(index + 1, ctx);
+    };
+    await (this.stack[index].fn as Middleware)(ctx, next);
+  }
+
+  private async handleError(err: unknown, ctx: Context, handlerIndex: number): Promise<void> {
+    if (err instanceof ExhaustedError) throw err;
+    const handlers = this.stack.filter((entry) => entry.isError);
+    if (handlerIndex >= handlers.length) throw new ExhaustedError(err);
+
+    let called = false;
+    const next = (forwarded?: unknown): Promise<void> => {
+      if (called) throw new Error('next() called twice');
+      called = true;
+      if (forwarded === undefined) return Promise.resolve(); // declared handled
+      return this.handleError(forwarded, ctx, handlerIndex + 1);
+    };
+    try {
+      await (handlers[handlerIndex].fn as ErrorHandler)(err, ctx, next);
+    } catch (thrown) {
+      await this.handleError(thrown, ctx, handlerIndex + 1);
+    }
+  }
 }
