+static int append_unknown(struct tlv_message *message,
+                          const uint8_t *record,
+                          size_t record_len)
+{
+    uint8_t *grown;
+
+    if (record_len > SIZE_MAX - message->unknown_fields_len) {
+        return TLV_ERR_NO_MEMORY;
+    }
+    grown = realloc(message->unknown_fields,
+                    message->unknown_fields_len + record_len);
+    if (grown == NULL) {
+        return TLV_ERR_NO_MEMORY;
+    }
+    memcpy(grown + message->unknown_fields_len, record, record_len);
+    message->unknown_fields = grown;
+    message->unknown_fields_len += record_len;
+    return TLV_OK;
+}
