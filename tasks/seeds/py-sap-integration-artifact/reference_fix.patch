@@ -0,0 +1,103 @@
+"""Design-time artifact operations: list versions, upload, deploy-and-wait."""
+
+import base64
+import urllib.parse
+
+from .versions import is_at_least, parse_version
+
+BUILD_TERMINAL = {"SUCCESS", "FAIL", "FAIL_ON_LICENSE_ERROR"}
+RUNTIME_FINAL = {"STARTED", "ERROR"}
+POLL_INTERVAL_SECONDS = 5
+
+
+class VersionConflictError(Exception):
+    pass
+
+
+class DeploymentError(Exception):
+    pass
+
+
+def list_versions(client, artifact_id):
+    """All design-time versions of one artifact, oldest to newest."""
+    query = urllib.parse.quote("Id eq '%s'" % artifact_id, safe="'")
+    doc = client.get_json(
+        "/IntegrationDesigntimeArtifacts?$format=json&$filter=" + query
+    )
+    rows = (doc.get("d") or {}).get("results") or []
+    return sorted(rows, key=lambda r: parse_version(r.get("Version", "0")))
+
+
+def upload_new_version(client, artifact_id, name, version, content):
+    """Update the draft and save it as `version`, unless the tenant already
+    holds that version or a newer one — then nothing is written at all."""
+    for row in list_versions(client, artifact_id):
+        if is_at_least(row.get("Version", "0"), version):
+            raise VersionConflictError(
+                "tenant already has %s version %s; refusing to overwrite with %s"
+                % (artifact_id, row.get("Version"), version)
+            )
+    encoded = base64.b64encode(content).decode("ascii")
+    client.put(
+        "/IntegrationDesigntimeArtifacts(Id='%s',Version='active')" % artifact_id,
+        {"Name": name, "ArtifactContent": encoded},
+    )
+    client.post(
+        "/IntegrationDesigntimeArtifactSaveAsVersion?Id='%s'&SaveAsVersion='%s'"
+        % (artifact_id, version)
+    )
+    return {"id": artifact_id, "version": version, "uploaded": True}
+
+
+def _poll(client, path, field, terminal, wait, max_polls, describe):
+    for _ in range(max_polls):
+        doc = client.get_json(path)
+        status = (doc.get("d") or {}).get(field)
+        if status in terminal:
+            return status
+        wait(POLL_INTERVAL_SECONDS)
+    raise DeploymentError("%s never reached a terminal status after %d polls" % (describe, max_polls))
+
+
+def deploy_and_wait(client, artifact_id, version, wait, max_polls=10):
+    """Trigger the documented deploy action and follow it to a final answer."""
+    _, _, payload = client.post(
+        "/DeployIntegrationDesigntimeArtifact?Id='%s'&Version='%s'"
+        % (artifact_id, version)
+    )
+    task_id = payload.decode("utf-8").strip()
+    build_status = _poll(
+        client,
+        "/BuildAndDeployStatus(TaskId='%s')?$format=json" % task_id,
+        "Status",
+        BUILD_TERMINAL,
+        wait,
+        max_polls,
+        "build task %s" % task_id,
+    )
+    if build_status != "SUCCESS":
+        raise DeploymentError(
+            "deployment of %s %s failed with build status %s (task %s)"
+            % (artifact_id, version, build_status, task_id)
+        )
+    runtime_status = _poll(
+        client,
+        "/IntegrationRuntimeArtifacts('%s')?$format=json" % artifact_id,
+        "Status",
+        RUNTIME_FINAL,
+        wait,
+        max_polls,
+        "runtime artifact %s" % artifact_id,
+    )
+    if runtime_status == "ERROR":
+        detail = client.get_text(
+            "/IntegrationRuntimeArtifacts('%s')/ErrorInformation/$value" % artifact_id
+        )
+        raise DeploymentError(
+            "runtime artifact %s is in ERROR: %s" % (artifact_id, detail)
+        )
+    return {
+        "task_id": task_id,
+        "build_status": build_status,
+        "runtime_status": runtime_status,
+    }
