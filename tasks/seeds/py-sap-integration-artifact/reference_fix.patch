index 0000000..5dd18cd
--- /dev/null
+++ b/cpideploy/client.py
@@ -0,0 +1,107 @@
+"""HTTP transport for the Cloud Integration OData API.
+
+Basic auth on every request; modifying calls carry the CSRF token and the
+session cookie obtained through the documented X-CSRF-Token: Fetch pre-flight.
+"""
+
+import base64
+import json
+import urllib.error
+import urllib.request
+
+_MODIFYING = ("POST", "PUT", "DELETE")
+
+
+class CpiApiError(Exception):
+    """OData error document from the tenant. Never contains credentials."""
+
+    def __init__(self, status, code, message_value, error_body):
+        super().__init__(
+            "SAP Cloud Integration API error %s (HTTP %d): %s" % (code, status, message_value)
+        )
+        self.status = status
+        self.code = code
+        self.message_value = message_value
+        self.error_body = error_body
+
+
+class CpiClient:
+    def __init__(self, base_url, user, password):
+        self.service_root = base_url.rstrip("/") + "/api/v1"
+        self._auth = "Basic " + base64.b64encode(
+            ("%s:%s" % (user, password)).encode()
+        ).decode()
+        self._csrf_token = None
+        self._cookie = None
+
+    # -- raw transport -----------------------------------------------------
+
+    def _send(self, method, url, headers, body=None):
+        req = urllib.request.Request(url, data=body, method=method)
+        req.add_header("Authorization", self._auth)
+        for k, v in headers.items():
+            req.add_header(k, v)
+        try:
+            resp = urllib.request.urlopen(req)
+            return resp.status, dict(resp.headers.items()), resp.read()
+        except urllib.error.HTTPError as e:
+            payload = e.read()
+            self._raise_odata_error(e.code, payload)
+            raise
+
+    def _raise_odata_error(self, status, payload):
+        try:
+            doc = json.loads(payload.decode("utf-8"))
+        except (UnicodeDecodeError, ValueError):
+            doc = None
+        if isinstance(doc, dict) and isinstance(doc.get("error"), dict):
+            err = doc["error"]
+            message = err.get("message") or {}
+            raise CpiApiError(status, err.get("code"), message.get("value", ""), err)
+        raise CpiApiError(status, "HTTP_%d" % status, "", {})
+
+    def _url(self, path):
+        return self.service_root + (path if path.startswith("/") else "/" + path)
+
+    # -- CSRF --------------------------------------------------------------
+
+    def _ensure_csrf(self):
+        if self._csrf_token is not None:
+            return
+        # Documented flow: a GET with X-CSRF-Token: Fetch answers with the
+        # token header and the session cookie for the modifying call.
+        status, headers, _ = self._send(
+            "GET", self.service_root + "/", {"X-CSRF-Token": "Fetch"}
+        )
+        lower = {k.lower(): v for k, v in headers.items()}
+        self._csrf_token = lower.get("x-csrf-token")
+        set_cookie = lower.get("set-cookie")
+        if set_cookie:
+            self._cookie = set_cookie.split(";", 1)[0]
+
+    # -- public verbs --------------------------------------------------------
+
+    def get_json(self, path):
+        _, _, payload = self._send("GET", self._url(path), {"Accept": "application/json"})
+        return json.loads(payload.decode("utf-8"))
+
+    def get_text(self, path):
+        _, _, payload = self._send("GET", self._url(path), {})
+        return payload.decode("utf-8")
+
+    def _modify(self, method, path, body):
+        self._ensure_csrf()
+        headers = {"Accept": "application/json", "X-CSRF-Token": self._csrf_token}
+        if self._cookie:
+            headers["Cookie"] = self._cookie
+        data = None
+        if body is not None:
+            data = json.dumps(body).encode("utf-8")
+            headers["Content-Type"] = "application/json"
+        return self._send(method, self._url(path), headers, data)
+
+    def post(self, path, body=None):
+        return self._modify("POST", path, body)
+
+    def put(self, path, body=None):
+        return self._modify("PUT", path, body)
