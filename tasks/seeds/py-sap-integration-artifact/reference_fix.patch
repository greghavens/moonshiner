index 0000000..d8e7d36
--- /dev/null
+++ b/cpideploy/versions.py
@@ -0,0 +1,17 @@
+"""Dotted-numeric artifact version handling ('1.10.0' is newer than '1.9.0')."""
+
+
+def parse_version(text):
+    parts = []
+    for seg in str(text).split("."):
+        parts.append(int(seg) if seg.isdigit() else 0)
+    return tuple(parts)
+
+
+def is_at_least(candidate, target):
+    """candidate >= target under numeric per-segment comparison."""
+    a, b = parse_version(candidate), parse_version(target)
+    length = max(len(a), len(b))
+    a += (0,) * (length - len(a))
+    b += (0,) * (length - len(b))
+    return a >= b
