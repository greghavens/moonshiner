+// Package flowschema loads workflow documents into typed structs,
+// normalizes them, and re-emits a single canonical form.
+package flowschema
+
+import (
+	"fmt"
+	"regexp"
+	"sort"
+	"strconv"
+	"strings"
+	"time"
+
+	"gopkg.in/yaml.v3"
+)
+
+// ---------------------------------------------------------------- types
+
+type Workflow struct {
+	Document Document    `yaml:"document"`
+	Timeout  *Timeout    `yaml:"timeout"`
+	Do       []TaskEntry `yaml:"do"`
+}
+
+type Document struct {
+	DSL       string
+	Namespace string
+	Name      string
+	Version   string
+}
+
+type Timeout struct {
+	After time.Duration
+}
+
+type TaskEntry struct {
+	Name string
+	Task Task
+}
+
+type Task struct {
+	Kind    string
+	If      string
+	Then    string
+	Timeout *Timeout
+	Call    *CallSpec
+	Set     map[string]string
+	Switch  []Case
+	For     *ForSpec
+	Wait    time.Duration
+}
+
+type CallSpec struct {
+	Fn   string
+	With map[string]string
+}
+
+type Case struct {
+	When string `yaml:"when"`
+	Then string `yaml:"then"`
+}
+
+type ForSpec struct {
+	Each string      `yaml:"each"`
+	In   string      `yaml:"in"`
+	At   string      `yaml:"at"`
+	Do   []TaskEntry `yaml:"do"`
+}
+
+// -------------------------------------------------------------- parsing
+
+func Parse(data []byte) (*Workflow, error) {
+	var wf Workflow
+	if err := yaml.Unmarshal(data, &wf); err != nil {
+		return nil, err
+	}
+	if wf.Document.DSL == "" {
+		return nil, fmt.Errorf(`document.dsl must be the string "1.0"`)
+	}
+	if len(wf.Do) == 0 {
+		return nil, fmt.Errorf("do must be a non-empty list")
+	}
+	fillDefaults(wf.Do)
+	return &wf, nil
+}
+
+func fillDefaults(entries []TaskEntry) {
+	for i := range entries {
+		task := &entries[i].Task
+		if task.Then == "" {
+			task.Then = "continue"
+		}
+		for j := range task.Switch {
+			if task.Switch[j].Then == "" {
+				task.Switch[j].Then = "continue"
+			}
+		}
+		if task.For != nil {
+			fillDefaults(task.For.Do)
+		}
+	}
+}
+
+func (d *Document) UnmarshalYAML(node *yaml.Node) error {
+	if node.Kind != yaml.MappingNode {
+		return fmt.Errorf("line %d: document must be a mapping", node.Line)
+	}
+	for i := 0; i+1 < len(node.Content); i += 2 {
+		key, val := node.Content[i], node.Content[i+1]
+		switch key.Value {
+		case "dsl":
+			if val.Tag != "!!str" || val.Value != "1.0" {
+				return fmt.Errorf(`line %d: document.dsl must be the string "1.0"`, val.Line)
+			}
+			d.DSL = val.Value
+		case "namespace":
+			d.Namespace = val.Value
+		case "name":
+			d.Name = val.Value
+		case "version":
+			d.Version = val.Value
+		default:
+			return fmt.Errorf("line %d: unknown document field %q", key.Line, key.Value)
+		}
+	}
+	if d.DSL == "" {
+		return fmt.Errorf(`line %d: document.dsl must be the string "1.0"`, node.Line)
+	}
+	return nil
+}
+
+func (t *Timeout) UnmarshalYAML(node *yaml.Node) error {
+	var after *yaml.Node
+	if node.Kind == yaml.MappingNode {
+		for i := 0; i+1 < len(node.Content); i += 2 {
+			if node.Content[i].Value == "after" {
+				after = node.Content[i+1]
+			}
+		}
+	}
+	if after == nil {
+		return fmt.Errorf(`line %d: timeout must be a mapping with an "after" key`, node.Line)
+	}
+	d, err := parseISODuration(after.Value, after.Line)
+	if err != nil {
+		return err
+	}
+	t.After = d
+	return nil
+}
+
+func (e *TaskEntry) UnmarshalYAML(node *yaml.Node) error {
+	if node.Kind != yaml.MappingNode || len(node.Content) != 2 {
+		return fmt.Errorf("line %d: task entry must be a mapping with exactly one key", node.Line)
+	}
+	e.Name = node.Content[0].Value
+	return e.Task.unmarshal(node.Content[1])
+}
+
+func (t *Task) unmarshal(node *yaml.Node) error {
+	if node.Kind != yaml.MappingNode {
+		return fmt.Errorf("line %d: task must be a mapping", node.Line)
+	}
+	var kinds []string
+	var withNode, withKey *yaml.Node
+	for i := 0; i+1 < len(node.Content); i += 2 {
+		key, val := node.Content[i], node.Content[i+1]
+		switch key.Value {
+		case "call":
+			kinds = append(kinds, "call")
+			t.Call = &CallSpec{Fn: val.Value}
+		case "set":
+			kinds = append(kinds, "set")
+			if err := val.Decode(&t.Set); err != nil {
+				return err
+			}
+		case "switch":
+			kinds = append(kinds, "switch")
+			if err := val.Decode(&t.Switch); err != nil {
+				return err
+			}
+		case "for":
+			kinds = append(kinds, "for")
+			t.For = &ForSpec{}
+			if err := val.Decode(t.For); err != nil {
+				return err
+			}
+		case "wait":
+			kinds = append(kinds, "wait")
+			d, err := parseISODuration(val.Value, val.Line)
+			if err != nil {
+				return err
+			}
+			t.Wait = d
+		case "with":
+			withNode, withKey = val, key
+		case "if":
+			t.If = val.Value
+		case "then":
+			t.Then = val.Value
+		case "timeout":
+			t.Timeout = &Timeout{}
+			if err := val.Decode(t.Timeout); err != nil {
+				return err
+			}
+		default:
+			return fmt.Errorf("line %d: unknown task field %q", key.Line, key.Value)
+		}
+	}
+	switch {
+	case len(kinds) == 0:
+		return fmt.Errorf("line %d: task must declare exactly one task type (found none)", node.Line)
+	case len(kinds) > 1:
+		sort.Strings(kinds)
+		return fmt.Errorf("line %d: task must declare exactly one task type (found %s)",
+			node.Line, strings.Join(kinds, ", "))
+	}
+	t.Kind = kinds[0]
+	if withNode != nil {
+		if t.Kind != "call" {
+			return fmt.Errorf(`line %d: "with" is only valid on call tasks`, withKey.Line)
+		}
+		if err := withNode.Decode(&t.Call.With); err != nil {
+			return err
+		}
+	}
+	return nil
+}
+
+// ------------------------------------------------------------- durations
+
+var isoDuration = regexp.MustCompile(`^PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?$`)
+
+func parseISODuration(s string, line int) (time.Duration, error) {
+	m := isoDuration.FindStringSubmatch(s)
+	bad := func() error {
+		return fmt.Errorf("line %d: invalid ISO-8601 duration %q", line, s)
+	}
+	if m == nil || (m[1] == "" && m[2] == "" && m[3] == "") {
+		return 0, bad()
+	}
+	var total time.Duration
+	units := []time.Duration{time.Hour, time.Minute, time.Second}
+	for i, unit := range units {
+		if m[i+1] == "" {
+			continue
+		}
+		n, err := strconv.Atoi(m[i+1])
+		if err != nil {
+			return 0, bad()
+		}
+		total += time.Duration(n) * unit
+	}
+	if total <= 0 {
+		return 0, bad()
+	}
+	return total, nil
+}
+
+func formatISODuration(d time.Duration) string {
+	var b strings.Builder
+	b.WriteString("PT")
+	h := d / time.Hour
+	d -= h * time.Hour
+	m := d / time.Minute
+	d -= m * time.Minute
+	s := d / time.Second
+	if h > 0 {
+		fmt.Fprintf(&b, "%dH", h)
+	}
+	if m > 0 {
+		fmt.Fprintf(&b, "%dM", m)
+	}
+	if s > 0 || (h == 0 && m == 0) {
+		fmt.Fprintf(&b, "%dS", s)
+	}
+	return b.String()
+}
+
+// --------------------------------------------------------------- dumping
+
+func Dump(wf *Workflow) string {
+	var b strings.Builder
+	b.WriteString("document:\n")
+	fmt.Fprintf(&b, "  dsl: %q\n", wf.Document.DSL)
+	fmt.Fprintf(&b, "  namespace: %s\n", wf.Document.Namespace)
+	fmt.Fprintf(&b, "  name: %s\n", wf.Document.Name)
+	if wf.Document.Version != "" {
+		fmt.Fprintf(&b, "  version: %s\n", wf.Document.Version)
+	}
+	if wf.Timeout != nil {
+		b.WriteString("timeout:\n")
+		fmt.Fprintf(&b, "  after: %s\n", formatISODuration(wf.Timeout.After))
+	}
+	b.WriteString("do:\n")
+	dumpDo(&b, wf.Do, 2)
+	return b.String()
+}
+
+// dumpDo writes a task list whose dashes sit at column indent.
+func dumpDo(b *strings.Builder, entries []TaskEntry, indent int) {
+	pad := strings.Repeat(" ", indent)
+	for i := range entries {
+		fmt.Fprintf(b, "%s- %s:\n", pad, entries[i].Name)
+		dumpTask(b, &entries[i].Task, indent+4)
+	}
+}
+
+func dumpTask(b *strings.Builder, t *Task, indent int) {
+	pad := strings.Repeat(" ", indent)
+	sub := pad + "  "
+	switch t.Kind {
+	case "call":
+		fmt.Fprintf(b, "%scall: %s\n", pad, t.Call.Fn)
+		if len(t.Call.With) > 0 {
+			fmt.Fprintf(b, "%swith:\n", pad)
+			dumpSortedMap(b, t.Call.With, sub)
+		}
+	case "set":
+		fmt.Fprintf(b, "%sset:\n", pad)
+		dumpSortedMap(b, t.Set, sub)
+	case "switch":
+		fmt.Fprintf(b, "%sswitch:\n", pad)
+		for _, c := range t.Switch {
+			if c.When != "" {
+				fmt.Fprintf(b, "%s- when: %s\n", sub, c.When)
+				fmt.Fprintf(b, "%s  then: %s\n", sub, c.Then)
+			} else {
+				fmt.Fprintf(b, "%s- then: %s\n", sub, c.Then)
+			}
+		}
+	case "for":
+		fmt.Fprintf(b, "%sfor:\n", pad)
+		fmt.Fprintf(b, "%seach: %s\n", sub, t.For.Each)
+		fmt.Fprintf(b, "%sin: %s\n", sub, t.For.In)
+		if t.For.At != "" {
+			fmt.Fprintf(b, "%sat: %s\n", sub, t.For.At)
+		}
+		fmt.Fprintf(b, "%sdo:\n", sub)
+		dumpDo(b, t.For.Do, indent+4)
+	case "wait":
+		fmt.Fprintf(b, "%swait: %s\n", pad, formatISODuration(t.Wait))
+	}
+	if t.If != "" {
+		fmt.Fprintf(b, "%sif: %s\n", pad, t.If)
+	}
+	if t.Timeout != nil {
+		fmt.Fprintf(b, "%stimeout:\n", pad)
+		fmt.Fprintf(b, "%safter: %s\n", sub, formatISODuration(t.Timeout.After))
+	}
+	fmt.Fprintf(b, "%sthen: %s\n", pad, t.Then)
+}
+
+func dumpSortedMap(b *strings.Builder, m map[string]string, pad string) {
+	keys := make([]string, 0, len(m))
+	for k := range m {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	for _, k := range keys {
+		fmt.Fprintf(b, "%s%s: %s\n", pad, k, m[k])
+	}
+}
