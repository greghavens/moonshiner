+// tttserver referees one game of tic-tac-toe between two TCP clients on a
+// loopback ephemeral port. It prints "PORT <n>" on stdout once listening,
+// speaks a line protocol (HELLO/JOIN/MOVE/BOARD/TURN/WIN/DRAW/ERR), and
+// exits 0 when the game ends — by win, draw, or forfeit on disconnect.
+package main
+
+import (
+	"bufio"
+	"fmt"
+	"net"
+	"os"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+)
+
+var marks = [2]byte{'X', 'O'}
+
+type server struct {
+	mu      sync.Mutex
+	ln      net.Listener
+	board   [9]byte
+	turn    int // index into conns: 0 moves as X, 1 as O
+	started bool
+	over    bool
+	conns   [2]net.Conn
+	joined  [2]bool
+}
+
+func main() {
+	ln, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		fmt.Fprintln(os.Stderr, err)
+		os.Exit(1)
+	}
+	fmt.Printf("PORT %d\n", ln.Addr().(*net.TCPAddr).Port)
+	s := &server{ln: ln}
+	for i := range s.board {
+		s.board[i] = '.'
+	}
+	s.acceptLoop()
+}
+
+func (s *server) acceptLoop() {
+	players := 0
+	for {
+		conn, err := s.ln.Accept()
+		if err != nil {
+			return
+		}
+		if players == 2 {
+			writeLine(conn, "ERR full")
+			conn.Close()
+			continue
+		}
+		slot := players
+		players++
+		s.mu.Lock()
+		s.conns[slot] = conn
+		s.mu.Unlock()
+		writeLine(conn, fmt.Sprintf("HELLO %c", marks[slot]))
+		go s.reader(slot, conn)
+	}
+}
+
+func writeLine(conn net.Conn, line string) {
+	conn.SetWriteDeadline(time.Now().Add(5 * time.Second))
+	fmt.Fprintf(conn, "%s\n", line)
+}
+
+func (s *server) reader(slot int, conn net.Conn) {
+	sc := bufio.NewScanner(conn)
+	for sc.Scan() {
+		s.handle(slot, strings.TrimRight(sc.Text(), "\r"))
+	}
+	s.forfeit(slot)
+}
+
+func validName(name string) bool {
+	if len(name) < 1 || len(name) > 16 {
+		return false
+	}
+	for _, r := range name {
+		switch {
+		case r >= 'a' && r <= 'z', r >= 'A' && r <= 'Z', r >= '0' && r <= '9', r == '_', r == '-':
+		default:
+			return false
+		}
+	}
+	return true
+}
+
+func (s *server) boardString() string {
+	return string(s.board[:])
+}
+
+// broadcast sends a line to both players, in slot order.
+func (s *server) broadcast(line string) {
+	for _, c := range s.conns {
+		if c != nil {
+			writeLine(c, line)
+		}
+	}
+}
+
+func (s *server) handle(slot int, line string) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	conn := s.conns[slot]
+	fields := strings.Fields(line)
+	if len(fields) == 0 {
+		writeLine(conn, "ERR bad-command")
+		return
+	}
+	switch fields[0] {
+	case "JOIN":
+		if s.joined[slot] {
+			writeLine(conn, "ERR already-joined")
+			return
+		}
+		if len(fields) != 2 || !validName(fields[1]) {
+			writeLine(conn, "ERR bad-name")
+			return
+		}
+		s.joined[slot] = true
+		if s.joined[0] && s.joined[1] {
+			s.started = true
+			s.broadcast("BOARD " + s.boardString())
+			s.broadcast("TURN X")
+		}
+	case "MOVE":
+		s.move(slot, fields[1:])
+	case "BOARD":
+		writeLine(conn, "BOARD "+s.boardString())
+	default:
+		writeLine(conn, "ERR bad-command")
+	}
+}
+
+func (s *server) move(slot int, args []string) {
+	conn := s.conns[slot]
+	switch {
+	case !s.started:
+		writeLine(conn, "ERR not-started")
+		return
+	case s.over:
+		writeLine(conn, "ERR game-over")
+		return
+	case s.turn != slot:
+		writeLine(conn, "ERR not-your-turn")
+		return
+	}
+	if len(args) != 1 {
+		writeLine(conn, "ERR bad-cell")
+		return
+	}
+	cell, err := strconv.Atoi(args[0])
+	if err != nil || cell < 0 || cell > 8 {
+		writeLine(conn, "ERR bad-cell")
+		return
+	}
+	if s.board[cell] != '.' {
+		writeLine(conn, "ERR occupied")
+		return
+	}
+	s.board[cell] = marks[slot]
+	s.broadcast("BOARD " + s.boardString())
+	switch {
+	case s.won(marks[slot]):
+		s.broadcast(fmt.Sprintf("WIN %c", marks[slot]))
+		s.finish()
+	case !strings.Contains(s.boardString(), "."):
+		s.broadcast("DRAW")
+		s.finish()
+	default:
+		s.turn = 1 - s.turn
+		s.broadcast(fmt.Sprintf("TURN %c", marks[s.turn]))
+	}
+}
+
+var winLines = [8][3]int{
+	{0, 1, 2}, {3, 4, 5}, {6, 7, 8},
+	{0, 3, 6}, {1, 4, 7}, {2, 5, 8},
+	{0, 4, 8}, {2, 4, 6},
+}
+
+func (s *server) won(mark byte) bool {
+	for _, l := range winLines {
+		if s.board[l[0]] == mark && s.board[l[1]] == mark && s.board[l[2]] == mark {
+			return true
+		}
+	}
+	return false
+}
+
+// finish closes everything and exits 0. Callers hold the mutex.
+func (s *server) finish() {
+	s.over = true
+	for _, c := range s.conns {
+		if c != nil {
+			c.Close()
+		}
+	}
+	s.ln.Close()
+	os.Exit(0)
+}
+
+// forfeit ends the game when a player's connection drops before the game is
+// decided: the remaining player wins.
+func (s *server) forfeit(slot int) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if s.over {
+		return
+	}
+	other := 1 - slot
+	if s.conns[other] != nil {
+		writeLine(s.conns[other], fmt.Sprintf("WIN %c forfeit", marks[other]))
+	}
+	s.finish()
+}
