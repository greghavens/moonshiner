--- a/bin/run_case.sh
+++ b/bin/run_case.sh
@@ -8,21 +8,65 @@
     exit 64
 fi
 
-child_pid=
+leader_pid=
+process_group=
+cleanup_started=0
 
-cleanup() {
-    local status=$?
+group_is_alive() {
+    [[ -n ${process_group:-} ]] && kill -0 -- "-$process_group" 2>&-
+}
+
+cleanup_group() {
+    local attempt
+
+    if (( cleanup_started )); then
+        return
+    fi
+    cleanup_started=1
+
+    if [[ -n ${process_group:-} ]]; then
+        kill -TERM -- "-$process_group" 2>&- || true
+        for (( attempt = 0; attempt < 20; attempt++ )); do
+            group_is_alive || break
+            sleep 0.01
+        done
+        if group_is_alive; then
+            kill -KILL -- "-$process_group" 2>&- || true
+        fi
+    fi
 
-    if [[ -n ${child_pid:-} ]]; then
-        kill "$child_pid" 2>/dev/null || true
-        wait "$child_pid" 2>/dev/null || true
+    if [[ -n ${leader_pid:-} ]]; then
+        wait "$leader_pid" 2>&- || true
     fi
+}
+
+finish() {
+    local status=$?
 
-    return "$status"
+    trap - EXIT HUP INT TERM
+    cleanup_group
+    exit "$status"
 }
 
-trap cleanup EXIT HUP INT TERM
+cancel() {
+    local status=$1
+
+    trap - EXIT HUP INT TERM
+    cleanup_group
+    exit "$status"
+}
 
-"$@" <&0 &
-child_pid=$!
-wait "$child_pid"
+trap finish EXIT
+trap 'cancel 129' HUP
+trap 'cancel 130' INT
+trap 'cancel 143' TERM
+
+# A non-interactive shell otherwise puts this background command in the
+# harness's process group. setsid makes the recorded PID the new group leader.
+setsid "$@" <&0 &
+leader_pid=$!
+process_group=$leader_pid
+
+wait "$leader_pid"
+status=$?
+exit "$status"
