@@ -0,0 +1,65 @@
+export type RelativeStyle = 'long' | 'short';
+
+export interface RelativeOptions {
+  now: Date | number;
+  style?: RelativeStyle;
+}
+
+interface Unit {
+  ms: number;
+  long: string;
+  short: string;
+}
+
+const SEC = 1000;
+const MIN = 60 * SEC;
+const HOUR = 60 * MIN;
+const DAY = 24 * HOUR;
+
+const JUST_NOW_WINDOW_MS = 10 * SEC;
+
+// Ordered largest-first; the first unit whose span fits the diff wins.
+const UNITS: Unit[] = [
+  { ms: 365 * DAY, long: 'year', short: 'y' },
+  { ms: 30 * DAY, long: 'month', short: 'mo' },
+  { ms: 7 * DAY, long: 'week', short: 'w' },
+  { ms: DAY, long: 'day', short: 'd' },
+  { ms: HOUR, long: 'hour', short: 'h' },
+  { ms: MIN, long: 'minute', short: 'm' },
+  { ms: SEC, long: 'second', short: 's' },
+];
+
+function toMillis(value: Date | number, label: string): number {
+  const ms = value instanceof Date ? value.getTime() : value;
+  if (typeof ms !== 'number' || Number.isNaN(ms)) {
+    throw new TypeError(`formatRelative: ${label} is not a valid date`);
+  }
+  return ms;
+}
+
+export function formatRelative(target: Date | number, options: RelativeOptions): string {
+  const targetMs = toMillis(target, 'target');
+  const nowMs = toMillis(options.now, 'now');
+  const style: RelativeStyle = options.style ?? 'long';
+
+  const diff = targetMs - nowMs;
+  const magnitude = Math.abs(diff);
+
+  if (magnitude <= JUST_NOW_WINDOW_MS) {
+    return style === 'short' ? 'now' : 'just now';
+  }
+
+  let unit = UNITS[UNITS.length - 1];
+  for (const candidate of UNITS) {
+    if (magnitude >= candidate.ms) {
+      unit = candidate;
+      break;
+    }
+  }
+
+  const count = Math.floor(magnitude / unit.ms);
+  const label =
+    style === 'short' ? `${count}${unit.short}` : `${count} ${unit.long}${count === 1 ? '' : 's'}`;
+
+  return diff < 0 ? `${label} ago` : `in ${label}`;
+}
