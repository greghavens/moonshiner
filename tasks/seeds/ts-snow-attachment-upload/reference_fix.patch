+// Errors surfaced by the attachment client. Exception text must never
+// contain credentials — only status/message/detail from ServiceNow's
+// {"error": {"message", "detail"}, "status": "failure"} envelope.
+
+export class SnowApiError extends Error {
+  readonly statusCode: number;
+  readonly detail: string;
+
+  constructor(statusCode: number, message: string, detail = '') {
+    super(message);
+    this.name = 'SnowApiError';
+    this.statusCode = statusCode;
+    this.detail = detail;
+  }
+}
+
+export class RateLimitError extends SnowApiError {
+  readonly retryAfter: number;
+
+  constructor(statusCode: number, message: string, detail: string, retryAfter: number) {
+    super(statusCode, message, detail);
+    this.name = 'RateLimitError';
+    this.retryAfter = retryAfter;
+  }
+}
+
+export class AttachmentVerificationError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'AttachmentVerificationError';
+  }
+}
