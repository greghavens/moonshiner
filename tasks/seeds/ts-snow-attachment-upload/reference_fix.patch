+// Manual multipart/form-data assembly for the Attachment API upload
+// operation. Built byte-wise so binary payloads (CRLFs, boundary-looking
+// runs) survive untouched.
+
+import { randomUUID } from 'node:crypto';
+
+export interface FilePart {
+  name: string;
+  filename: string;
+  contentType: string;
+  content: Uint8Array;
+}
+
+const CRLF = '\r\n';
+
+export function buildMultipart(
+  fields: Record<string, string>,
+  file: FilePart,
+): { body: Uint8Array; contentType: string } {
+  const boundary = `snow-upload-${randomUUID()}`;
+  const chunks: Uint8Array[] = [];
+  const push = (s: string) => chunks.push(Buffer.from(s, 'utf8'));
+
+  for (const [name, value] of Object.entries(fields)) {
+    push(`--${boundary}${CRLF}`);
+    push(`Content-Disposition: form-data; name="${name}"${CRLF}${CRLF}`);
+    push(`${value}${CRLF}`);
+  }
+  push(`--${boundary}${CRLF}`);
+  push(`Content-Disposition: form-data; name="${file.name}"; filename="${file.filename}"${CRLF}`);
+  push(`Content-Type: ${file.contentType}${CRLF}${CRLF}`);
+  chunks.push(file.content);
+  push(`${CRLF}--${boundary}--${CRLF}`);
+
+  return {
+    body: Buffer.concat(chunks),
+    contentType: `multipart/form-data; boundary=${boundary}`,
+  };
+}
