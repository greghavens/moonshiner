+#!/usr/bin/env python3
+"""Reference proof using the same executable workflow required by the task."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parent
+PHASE_WORKER = r'''
+import json
+import subprocess
+import sys
+
+commands = json.loads(sys.argv[1])
+processes = [
+    subprocess.Popen(
+        command,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    for command in commands
+]
+outputs = []
+for process in processes:
+    stdout, stderr = process.communicate(timeout=15)
+    if process.returncode != 0:
+        raise RuntimeError(stderr.strip() or "meeting operation failed")
+    outputs.append(json.loads(stdout))
+print(json.dumps(outputs))
+'''
+
+
+def parallel(commands: list[list[str]]) -> list[dict[str, object]]:
+    completed = subprocess.run(
+        [sys.executable, "-B", "-c", PHASE_WORKER, json.dumps(commands)],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=20,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "meeting phase failed")
+    payload = json.loads(completed.stdout)
+    if not isinstance(payload, list) or len(payload) != len(commands):
+        raise RuntimeError("meeting phase returned an invalid payload")
+    return payload
+
+
+def main() -> int:
+    requested = [
+        ("Vendor Accessibility Check-In", "Remote - Meet"),
+        ("Facilities Safety Debrief", "Boston Office"),
+    ]
+    searches = parallel([
+        ["./meetingctl", "search", "--name", name, "--location", location]
+        for name, location in requested
+    ])
+
+    identifiers: list[str] = []
+    for result in searches:
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        meeting_id = matches[0].get("id")
+        if not isinstance(meeting_id, str) or not meeting_id:
+            raise RuntimeError("reference branch returned no stable ID")
+        identifiers.append(meeting_id)
+
+    gets = parallel([
+        ["./meetingctl", "get", "--id", meeting_id]
+        for meeting_id in identifiers
+    ])
+    records = [result.get("record") for result in gets]
+    if any(not isinstance(record, dict) for record in records):
+        raise RuntimeError("full-record retrieval failed")
+    first, second = records
+    comparison = "same" if first["status"] == second["status"] else "different"
+    report = (
+        f"{first['name']} | {first['id']} | {first['status']}\n"
+        f"{second['name']} | {second['id']} | {second['status']}\n"
+        f"Status comparison: {comparison} "
+        f"({first['status']} vs {second['status']}).\n"
+        "No changes made.\n"
+    )
+    (ROOT / "meeting-status.md").write_text(report, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
