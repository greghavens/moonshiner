+"""contacts_api -- WSGI JSON REST resource for the admin API's contacts store.
+
+Stdlib only. `create_app()` returns an independent WSGI callable with its own
+in-memory store; dispatch goes through a data-driven routing table.
+"""
+import json
+import re
+from urllib.parse import parse_qs
+
+DEFAULT_LIMIT = 10
+MAX_LIMIT = 50
+FIELDS = ("name", "email", "phone")
+
+_REASONS = {
+    200: "OK",
+    201: "Created",
+    204: "No Content",
+    400: "Bad Request",
+    404: "Not Found",
+    405: "Method Not Allowed",
+}
+
+
+class _BadRequest(Exception):
+    def __init__(self, message):
+        super().__init__(message)
+        self.message = message
+
+
+def _validate(payload):
+    """Returns (clean record dict, errors dict) -- exactly one is non-empty."""
+    errors = {}
+    for field in sorted(set(payload) - set(FIELDS)):
+        errors[field] = "unknown field"
+    name = payload.get("name")
+    if not isinstance(name, str) or not name.strip():
+        errors["name"] = "required and must be a non-blank string"
+    email = payload.get("email")
+    if not isinstance(email, str) or "@" not in email:
+        errors["email"] = "required and must contain @"
+    phone = payload.get("phone")
+    if phone is not None and not isinstance(phone, str):
+        errors["phone"] = "must be a string when present"
+    if errors:
+        return None, errors
+    return {"name": name, "email": email, "phone": phone}, {}
+
+
+def _read_json_object(environ):
+    try:
+        length = int(environ.get("CONTENT_LENGTH") or 0)
+    except ValueError:
+        length = 0
+    raw = environ["wsgi.input"].read(length) if length > 0 else b""
+    if not raw:
+        raise _BadRequest("request body required")
+    try:
+        payload = json.loads(raw)
+    except ValueError:
+        raise _BadRequest("request body is not valid JSON")
+    if not isinstance(payload, dict):
+        raise _BadRequest("request body must be a JSON object")
+    return payload
+
+
+def _int_param(query, name, default, minimum, maximum=None):
+    values = query.get(name)
+    if values is None:
+        return default
+    raw = values[-1]
+    try:
+        value = int(raw)
+    except ValueError:
+        raise _BadRequest(f"{name} must be an integer, got {raw!r}")
+    if value < minimum or (maximum is not None and value > maximum):
+        bound = f"{minimum}..{maximum}" if maximum is not None else f">= {minimum}"
+        raise _BadRequest(f"{name} must be {bound}, got {value}")
+    return value
+
+
+def create_app():
+    records = {}
+    counter = {"next_id": 1}
+
+    def list_contacts(environ, match):
+        query = parse_qs(environ.get("QUERY_STRING", ""), keep_blank_values=True)
+        limit = _int_param(query, "limit", DEFAULT_LIMIT, 1, MAX_LIMIT)
+        offset = _int_param(query, "offset", 0, 0)
+        ordered = [records[cid] for cid in sorted(records)]
+        return 200, {
+            "items": ordered[offset:offset + limit],
+            "total": len(ordered),
+            "limit": limit,
+            "offset": offset,
+        }, []
+
+    def create_contact(environ, match):
+        payload = _read_json_object(environ)
+        record, errors = _validate(payload)
+        if errors:
+            return 400, {"errors": errors}, []
+        cid = counter["next_id"]
+        counter["next_id"] += 1
+        record["id"] = cid
+        records[cid] = record
+        return 201, record, [("Location", f"/contacts/{cid}")]
+
+    def get_contact(environ, match):
+        cid = int(match.group(1))
+        if cid not in records:
+            return 404, {"error": f"contact {cid} not found"}, []
+        return 200, records[cid], []
+
+    def put_contact(environ, match):
+        cid = int(match.group(1))
+        if cid not in records:
+            return 404, {"error": f"contact {cid} not found"}, []
+        payload = _read_json_object(environ)
+        record, errors = _validate(payload)
+        if errors:
+            return 400, {"errors": errors}, []
+        record["id"] = cid
+        records[cid] = record
+        return 200, record, []
+
+    def delete_contact(environ, match):
+        cid = int(match.group(1))
+        if cid not in records:
+            return 404, {"error": f"contact {cid} not found"}, []
+        del records[cid]
+        return 204, None, []
+
+    routes = [
+        ("GET", re.compile(r"^/contacts$"), list_contacts),
+        ("POST", re.compile(r"^/contacts$"), create_contact),
+        ("GET", re.compile(r"^/contacts/(\d+)$"), get_contact),
+        ("PUT", re.compile(r"^/contacts/(\d+)$"), put_contact),
+        ("DELETE", re.compile(r"^/contacts/(\d+)$"), delete_contact),
+    ]
+
+    def app(environ, start_response):
+        method = environ["REQUEST_METHOD"]
+        path = environ.get("PATH_INFO", "")
+        handler = match = None
+        allowed = set()
+        for route_method, pattern, route_handler in routes:
+            found = pattern.match(path)
+            if not found:
+                continue
+            allowed.add(route_method)
+            if route_method == method:
+                handler, match = route_handler, found
+        if handler is not None:
+            try:
+                status, body, extra_headers = handler(environ, match)
+            except _BadRequest as exc:
+                status, body, extra_headers = 400, {"error": exc.message}, []
+        elif allowed:
+            status = 405
+            body = {"error": f"{method} not allowed on {path}"}
+            extra_headers = [("Allow", ", ".join(sorted(allowed)))]
+        else:
+            status, body, extra_headers = 404, {"error": f"no route for {path}"}, []
+
+        headers = list(extra_headers)
+        if body is None:
+            payload = b""
+        else:
+            payload = json.dumps(body).encode("utf-8")
+            headers.append(("Content-Type", "application/json; charset=utf-8"))
+        headers.append(("Content-Length", str(len(payload))))
+        start_response(f"{status} {_REASONS[status]}", headers)
+        return [payload]
+
+    return app
