 }
+
+// cancelBody ties a per-attempt context's cancel func to the response
+// body so the context is released when the caller closes the body.
+type cancelBody struct {
+	io.ReadCloser
+	cancel context.CancelFunc
+}
+
+func (b *cancelBody) Close() error {
+	err := b.ReadCloser.Close()
+	b.cancel()
+	return err
+}
+
+// attempt performs one request, applying PerAttemptTimeout if set.
+func (c *Client) attempt(ctx context.Context, url string) (*http.Response, error) {
+	cancel := context.CancelFunc(func() {})
+	if c.PerAttemptTimeout > 0 {
+		ctx, cancel = context.WithTimeout(ctx, c.PerAttemptTimeout)
+	}
+	req, err := http.NewRequestWithContext(ctx, http.MethodGet, url, nil)
+	if err != nil {
+		cancel()
+		return nil, err
+	}
+	resp, err := c.HTTP.Do(req)
+	if err != nil {
+		cancel()
+		return nil, err
+	}
+	resp.Body = &cancelBody{ReadCloser: resp.Body, cancel: cancel}
+	return resp, nil
+}
+
+// retryDelay computes the wait after attempt i (0-based). A parseable
+// Retry-After on the response wins over the computed backoff; both
+// are clamped to MaxDelay.
+func (c *Client) retryDelay(i int, resp *http.Response) time.Duration {
+	if resp != nil {
+		if ra := strings.TrimSpace(resp.Header.Get("Retry-After")); ra != "" {
+			if secs, err := strconv.Atoi(ra); err == nil && secs >= 0 {
+				return c.clamp(time.Duration(secs) * time.Second)
+			}
+		}
+	}
+	if c.BaseDelay <= 0 {
+		return 0
+	}
+	d := c.BaseDelay
+	for k := 0; k < i; k++ {
+		d *= 2
+		if c.MaxDelay > 0 && d >= c.MaxDelay {
+			return c.MaxDelay
+		}
+	}
+	return c.clamp(d)
+}
+
+func (c *Client) clamp(d time.Duration) time.Duration {
+	if c.MaxDelay > 0 && d > c.MaxDelay {
+		return c.MaxDelay
+	}
+	return d
+}
+
+// sleep waits for d via the injected Sleep hook, or a real timer when
+// none is set.
+func (c *Client) sleep(ctx context.Context, d time.Duration) error {
+	if c.Sleep != nil {
+		return c.Sleep(ctx, d)
+	}
+	t := time.NewTimer(d)
+	defer t.Stop()
+	select {
+	case <-t.C:
+		return nil
+	case <-ctx.Done():
+		return ctx.Err()
+	}
+}
