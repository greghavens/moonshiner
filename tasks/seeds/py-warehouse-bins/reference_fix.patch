+"""Put-away planning and pick-path math. Pure functions, no IO."""
+
+
+class PackingError(Exception):
+    """A placement or pick that cannot be satisfied legally."""
+
+
+def aisle_position(bin_id):
+    aisle, _, pos = bin_id.partition("-")
+    return aisle, int(pos)
+
+
+def pick_path(bin_ids):
+    """Serpentine walk: aisles in letter order; odd aisles (A, C, ...) walk
+    positions ascending, even aisles (B, D, ...) descending."""
+    def key(bin_id):
+        aisle, pos = aisle_position(bin_id)
+        descending = (ord(aisle) - ord("A")) % 2 == 1
+        return (aisle, -pos if descending else pos)
+    return sorted(bin_ids, key=key)
+
+
+def _bin_contents_qty(contents):
+    return sum(contents.values())
+
+
+def _fits(bin_info, contents, skus, sku_id):
+    """How many units of sku_id this bin can still take (capacity only)."""
+    used_volume = sum(skus[s]["volume"] * q for s, q in contents.items())
+    used_weight = sum(skus[s]["weight"] * q for s, q in contents.items())
+    sku = skus[sku_id]
+    by_volume = (bin_info["volume"] - used_volume) // sku["volume"]
+    by_weight = (bin_info["max_weight"] - used_weight) // sku["weight"]
+    return max(0, min(by_volume, by_weight))
+
+
+def _eligible(bin_info, contents, skus, sku_id):
+    """Sharing rules: haz only in hazmat bins; haz and non-haz never mix."""
+    hazardous = skus[sku_id]["hazmat"]
+    if hazardous and not bin_info["hazmat"]:
+        return False
+    for held in contents:
+        if skus[held]["hazmat"] != hazardous:
+            return False
+    return True
+
+
+def plan_putaway(bins, stock, skus, sku_id, qty):
+    """[(bin_id, qty), ...] allocations, or raise PackingError.
+
+    bins: {bin_id: {volume, max_weight, hazmat}}
+    stock: {bin_id: {sku_id: qty}} current contents
+    Preference: bins already holding the SKU (ascending id), then the rest
+    ascending, hazmat bins last for non-haz SKUs. Greedy fill at each stop.
+    """
+    hazardous = skus[sku_id]["hazmat"]
+
+    def rank(bin_id):
+        contents = stock.get(bin_id, {})
+        holds = contents.get(sku_id, 0) > 0
+        last_resort = bins[bin_id]["hazmat"] and not hazardous
+        return (0 if holds else 1, 1 if last_resort else 0, bin_id)
+
+    remaining = qty
+    plan = []
+    for bin_id in sorted(bins, key=rank):
+        if remaining == 0:
+            break
+        contents = stock.get(bin_id, {})
+        if not _eligible(bins[bin_id], contents, skus, sku_id):
+            continue
+        take = min(remaining, _fits(bins[bin_id], contents, skus, sku_id))
+        if take > 0:
+            plan.append((bin_id, take))
+            remaining -= take
+    if remaining:
+        raise PackingError(
+            f"no legal space for {remaining} of {qty} unit(s) of {sku_id}")
+    return plan
+
+
+def plan_pick(stock, sku_id, qty):
+    """[(bin_id, qty), ...] in pick-path order, or raise PackingError."""
+    holding = [b for b, contents in stock.items() if contents.get(sku_id, 0) > 0]
+    remaining = qty
+    plan = []
+    for bin_id in pick_path(holding):
+        if remaining == 0:
+            break
+        take = min(remaining, stock[bin_id][sku_id])
+        plan.append((bin_id, take))
+        remaining -= take
+    if remaining:
+        raise PackingError(f"only {qty - remaining} unit(s) of {sku_id} on hand")
+    return plan
