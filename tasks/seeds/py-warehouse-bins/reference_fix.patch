+"""Warehouse operations tying registration, packing, and stock together."""
+import re
+
+import packing
+
+BIN_ID_RE = re.compile(r"^[A-Z]-\d{2}$")
+
+
+class WarehouseError(Exception):
+    pass
+
+
+def add_bin(state, bin_id, volume, max_weight, hazmat):
+    if not BIN_ID_RE.fullmatch(bin_id):
+        raise WarehouseError(
+            f"bad bin id {bin_id!r}: expected AISLE-POSITION like A-01")
+    if bin_id in state["bins"]:
+        raise WarehouseError(f"bin {bin_id} already exists")
+    if volume <= 0 or max_weight <= 0:
+        raise WarehouseError("bin volume and max weight must be positive")
+    state["bins"][bin_id] = {
+        "volume": volume, "max_weight": max_weight, "hazmat": hazmat}
+
+
+def add_sku(state, sku_id, volume, weight, hazmat, min_stock):
+    if sku_id in state["skus"]:
+        raise WarehouseError(f"sku {sku_id} already exists")
+    if volume <= 0 or weight <= 0:
+        raise WarehouseError("sku volume and weight must be positive")
+    if min_stock < 0:
+        raise WarehouseError("min-stock cannot be negative")
+    state["skus"][sku_id] = {
+        "volume": volume, "weight": weight, "hazmat": hazmat,
+        "min_stock": min_stock}
+
+
+def _require_sku(state, sku_id):
+    if sku_id not in state["skus"]:
+        raise WarehouseError(f"unknown sku {sku_id}")
+
+
+def _require_qty(qty):
+    if qty < 1:
+        raise WarehouseError("qty must be at least 1")
+
+
+def putaway(state, sku_id, qty):
+    _require_sku(state, sku_id)
+    _require_qty(qty)
+    try:
+        plan = packing.plan_putaway(
+            state["bins"], state["stock"], state["skus"], sku_id, qty)
+    except packing.PackingError as exc:
+        raise WarehouseError(str(exc)) from exc
+    for bin_id, take in plan:
+        contents = state["stock"].setdefault(bin_id, {})
+        contents[sku_id] = contents.get(sku_id, 0) + take
+    return plan
+
+
+def pick(state, sku_id, qty):
+    _require_sku(state, sku_id)
+    _require_qty(qty)
+    try:
+        plan = packing.plan_pick(state["stock"], sku_id, qty)
+    except packing.PackingError as exc:
+        raise WarehouseError(str(exc)) from exc
+    for bin_id, take in plan:
+        contents = state["stock"][bin_id]
+        contents[sku_id] -= take
+        if contents[sku_id] == 0:
+            del contents[sku_id]
+        if not contents:
+            del state["stock"][bin_id]
+    return plan
+
+
+def find(state, sku_id):
+    _require_sku(state, sku_id)
+    holdings = sorted(
+        (bin_id, contents[sku_id])
+        for bin_id, contents in state["stock"].items()
+        if contents.get(sku_id, 0) > 0)
+    total = sum(q for _, q in holdings)
+    return holdings, total
+
+
+def alerts(state):
+    low = []
+    for sku_id in sorted(state["skus"]):
+        want = state["skus"][sku_id]["min_stock"]
+        have = sum(c.get(sku_id, 0) for c in state["stock"].values())
+        if have < want:
+            low.append((sku_id, have, want))
+    return low
