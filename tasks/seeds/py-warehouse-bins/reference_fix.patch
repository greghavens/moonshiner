+"""Warehouse CLI. Usage: python3 cli.py --db PATH <command> ..."""
+import argparse
+import sys
+
+import store
+import warehouse
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="cli.py")
+    parser.add_argument("--db", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add-bin")
+    p.add_argument("bin_id")
+    p.add_argument("--volume", type=int, required=True)
+    p.add_argument("--max-weight", type=int, required=True)
+    p.add_argument("--hazmat", action="store_true")
+
+    p = sub.add_parser("add-sku")
+    p.add_argument("sku_id")
+    p.add_argument("--volume", type=int, required=True)
+    p.add_argument("--weight", type=int, required=True)
+    p.add_argument("--hazmat", action="store_true")
+    p.add_argument("--min-stock", type=int, default=0)
+
+    for name in ("putaway", "pick"):
+        p = sub.add_parser(name)
+        p.add_argument("sku_id")
+        p.add_argument("--qty", type=int, required=True)
+
+    p = sub.add_parser("find")
+    p.add_argument("sku_id")
+
+    sub.add_parser("alerts")
+    return parser
+
+
+def run(args, state):
+    """Execute one command; return (lines_to_print, db_changed)."""
+    if args.command == "add-bin":
+        warehouse.add_bin(state, args.bin_id, args.volume, args.max_weight,
+                          args.hazmat)
+        return [], True
+    if args.command == "add-sku":
+        warehouse.add_sku(state, args.sku_id, args.volume, args.weight,
+                          args.hazmat, args.min_stock)
+        return [], True
+    if args.command == "putaway":
+        plan = warehouse.putaway(state, args.sku_id, args.qty)
+        return [f"{bin_id}\t{qty}" for bin_id, qty in plan], True
+    if args.command == "pick":
+        plan = warehouse.pick(state, args.sku_id, args.qty)
+        return [f"{bin_id}\t{qty}" for bin_id, qty in plan], True
+    if args.command == "find":
+        holdings, total = warehouse.find(state, args.sku_id)
+        lines = [f"{bin_id}\t{qty}" for bin_id, qty in holdings]
+        return lines + [f"total={total}"], False
+    if args.command == "alerts":
+        return [f"{sku}\thave={have}\twant={want}"
+                for sku, have, want in warehouse.alerts(state)], False
+    raise AssertionError(args.command)
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    state = store.load(args.db)
+    try:
+        lines, changed = run(args, state)
+    except warehouse.WarehouseError as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+    if changed:
+        store.save(args.db, state)
+    for line in lines:
+        print(line)
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
