+"""JSON persistence. A missing db file is simply an empty warehouse."""
+import json
+import os
+
+
+def empty_state():
+    return {"bins": {}, "skus": {}, "stock": {}}
+
+
+def load(path):
+    if not os.path.exists(path):
+        return empty_state()
+    with open(path, encoding="utf-8") as fh:
+        return json.load(fh)
+
+
+def save(path, state):
+    tmp = path + ".tmp"
+    with open(tmp, "w", encoding="utf-8") as fh:
+        json.dump(state, fh, indent=2, sort_keys=True)
+        fh.write("\n")
+    os.replace(tmp, path)
