+++ b/fsmcore.py
@@ -0,0 +1,140 @@
+"""Table-driven finite state machine engine.
+
+A machine is declared as plain data: a states table (state name -> optional
+enter/exit hooks) and a flat, ordered list of transition rows
+(event, src, dst, optional guard, optional action). The engine validates the
+definition up front, dispatches events against the table in declaration
+order, and keeps an audit trail of every transition it fires.
+
+Pure decision core: no threads, no clocks, no I/O.
+"""
+
+_DEF_KEYS = {"initial", "states", "transitions"}
+_HOOK_KEYS = {"enter", "exit"}
+_ROW_REQUIRED = {"event", "src", "dst"}
+_ROW_KEYS = _ROW_REQUIRED | {"guard", "action"}
+
+
+class DefinitionError(ValueError):
+    """The machine definition itself is malformed."""
+
+
+class TransitionError(Exception):
+    """An event was sent that the current state does not accept."""
+
+    def __init__(self, state, event, allowed):
+        self.state = state
+        self.event = event
+        self.allowed = list(allowed)
+        shown = ", ".join(self.allowed) if self.allowed else "none"
+        super().__init__(
+            "event %r not allowed in state %r (allowed: %s)"
+            % (event, state, shown)
+        )
+
+
+def _validate(definition):
+    if not isinstance(definition, dict):
+        raise DefinitionError("definition must be a dict")
+    extra = set(definition) - _DEF_KEYS
+    if extra:
+        raise DefinitionError("unknown definition keys: %s" % sorted(extra))
+    missing = _DEF_KEYS - set(definition)
+    if missing:
+        raise DefinitionError("definition missing keys: %s" % sorted(missing))
+
+    states = definition["states"]
+    if not isinstance(states, dict) or not states:
+        raise DefinitionError("states must be a non-empty dict")
+    for name, hooks in states.items():
+        if not isinstance(hooks, dict):
+            raise DefinitionError("hooks for state %r must be a dict" % name)
+        bad = set(hooks) - _HOOK_KEYS
+        if bad:
+            raise DefinitionError(
+                "unknown hook keys for state %r: %s" % (name, sorted(bad)))
+
+    initial = definition["initial"]
+    if initial not in states:
+        raise DefinitionError("initial state %r is not declared" % initial)
+
+    rows = definition["transitions"]
+    if not isinstance(rows, list):
+        raise DefinitionError("transitions must be a list of rows")
+    for i, row in enumerate(rows):
+        if not isinstance(row, dict):
+            raise DefinitionError("transition row %d must be a dict" % i)
+        missing = _ROW_REQUIRED - set(row)
+        if missing:
+            raise DefinitionError(
+                "transition row %d missing keys: %s" % (i, sorted(missing)))
+        extra = set(row) - _ROW_KEYS
+        if extra:
+            raise DefinitionError(
+                "transition row %d has unknown keys: %s" % (i, sorted(extra)))
+        for endpoint in ("src", "dst"):
+            if row[endpoint] not in states:
+                raise DefinitionError(
+                    "transition row %d: %s state %r is not declared"
+                    % (i, endpoint, row[endpoint]))
+
+
+class Machine:
+    def __init__(self, definition, context=None):
+        _validate(definition)
+        self._states = {
+            name: dict(hooks) for name, hooks in definition["states"].items()
+        }
+        self._rows = [dict(row) for row in definition["transitions"]]
+        self._state = definition["initial"]
+        self._history = []
+        self.context = context
+
+    @property
+    def state(self):
+        return self._state
+
+    @property
+    def history(self):
+        return [dict(rec) for rec in self._history]
+
+    def allowed_events(self):
+        return sorted({row["event"] for row in self._rows
+                       if row["src"] == self._state})
+
+    def send(self, event, payload=None):
+        candidates = [row for row in self._rows
+                      if row["src"] == self._state and row["event"] == event]
+        if not candidates:
+            raise TransitionError(self._state, event, self.allowed_events())
+
+        chosen = None
+        for row in candidates:
+            step = {"event": event, "payload": payload,
+                    "src": row["src"], "dst": row["dst"]}
+            guard = row.get("guard")
+            if guard is None or guard(self.context, step):
+                chosen = (row, step)
+                break
+        if chosen is None:
+            raise TransitionError(self._state, event, self.allowed_events())
+
+        row, step = chosen
+        exit_hook = self._states[row["src"]].get("exit")
+        if exit_hook is not None:
+            exit_hook(self.context, step)
+        self._state = row["dst"]
+        action = row.get("action")
+        if action is not None:
+            action(self.context, step)
+        enter_hook = self._states[row["dst"]].get("enter")
+        if enter_hook is not None:
+            enter_hook(self.context, step)
+        self._history.append({
+            "seq": len(self._history) + 1,
+            "event": event,
+            "src": row["src"],
+            "dst": row["dst"],
+            "payload": payload,
+        })
+        return self._state
