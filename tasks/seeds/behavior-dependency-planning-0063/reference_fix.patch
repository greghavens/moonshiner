+#!/usr/bin/env python3
+"""Reference proof using the genuine lodging executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Foundry Hall Reception", "Pittsburgh"),
+    ("Glasshouse Dinner Reservation", "Cleveland"),
+)
+
+
+def phase_worker() -> int:
+    """Start every client before collecting any response for one phase."""
+    commands = json.loads(sys.stdin.read())
+    if not isinstance(commands, list) or not commands:
+        raise RuntimeError("reference phase has no commands")
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "lodging operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("lodging operation returned an invalid payload")
+        payloads.append(payload)
+    print(json.dumps(payloads))
+    return 0
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Use a fresh action parent for each dependency phase."""
+    completed = subprocess.run(
+        [sys.executable, "-B", str(Path(__file__).resolve()), "--phase-worker"],
+        cwd=ROOT,
+        input=json.dumps(commands),
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+        check=False,
+        timeout=30,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "reference phase failed")
+    payloads = json.loads(completed.stdout)
+    if not isinstance(payloads, list) or not all(
+        isinstance(payload, dict) for payload in payloads
+    ):
+        raise RuntimeError("reference phase returned invalid results")
+    return payloads
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./lodgectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        match = matches[0]
+        if not isinstance(match, dict):
+            continue
+        stable_id = match.get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./lodgectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    lines: list[str] = []
+    statuses: list[str | None] = []
+    for index, record in enumerate(retrieved):
+        requested_name, requested_location = TARGETS[index]
+        if record is None:
+            lines.append(
+                f"{requested_name} at {requested_location} [UNRESOLVED] is unresolved."
+            )
+            statuses.append(None)
+            continue
+        name = record.get("name")
+        location = record.get("location")
+        stable_id = record.get("id")
+        status = record.get("status")
+        if not all(isinstance(value, str) and value for value in (name, location, stable_id, status)):
+            raise RuntimeError("full record omitted a required value")
+        lines.append(
+            f"{name} at {location} [{stable_id}] has retrieved status {status}."
+        )
+        statuses.append(status)
+
+    if statuses[0] is None or statuses[1] is None:
+        lines.append("Status comparison: unknown.")
+    elif statuses[0] == statuses[1]:
+        lines.append(f"Status comparison: both are {statuses[0]}.")
+    else:
+        lines.append(
+            f"Status comparison: {statuses[0]} differs from {statuses[1]}."
+        )
+
+    (ROOT / "lodging-audit.txt").write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    if sys.argv[1:] == ["--phase-worker"]:
+        raise SystemExit(phase_worker())
+    raise SystemExit(main())
