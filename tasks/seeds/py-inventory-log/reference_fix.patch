+"""Derived stock snapshot: fold of the event log, kept beside it."""
+import json
+import os
+
+
+class SnapshotMissing(Exception):
+    """The snapshot is gone while a log exists — operator must rebuild."""
+
+
+def path_for(log_path):
+    return log_path + ".state"
+
+
+def fold(events):
+    """Fold events into {sku: qty}."""
+    totals = {}
+    for ev in events:
+        delta = ev["qty"] if ev["op"] == "in" else -ev["qty"]
+        totals[ev["sku"]] = totals.get(ev["sku"], 0) + delta
+    return totals
+
+
+def load(log_path):
+    """Load the snapshot. Fresh start (no log, no snapshot) is empty;
+    a log without its snapshot raises SnapshotMissing."""
+    state_path = path_for(log_path)
+    if not os.path.exists(state_path):
+        if os.path.exists(log_path):
+            raise SnapshotMissing(state_path)
+        return {}
+    with open(state_path, encoding="utf-8") as f:
+        return json.load(f)
+
+
+def save(log_path, totals):
+    with open(path_for(log_path), "w", encoding="utf-8") as f:
+        json.dump(totals, f, indent=1)
+        f.write("\n")
