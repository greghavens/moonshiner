+#!/usr/bin/env python3
+"""Inventory manager: append-only event log + derived stock snapshot."""
+import argparse
+import sys
+
+import eventlog
+import stockstate
+
+
+def positive_int(text):
+    try:
+        qty = int(text)
+    except ValueError:
+        raise argparse.ArgumentTypeError(f"quantity must be an integer: {text!r}")
+    if qty <= 0:
+        raise argparse.ArgumentTypeError(f"quantity must be positive: {qty}")
+    return qty
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="inventory.py")
+    parser.add_argument("--log", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    for op in ("in", "out"):
+        p = sub.add_parser(op)
+        p.add_argument("sku")
+        p.add_argument("qty", type=positive_int)
+
+    p_stock = sub.add_parser("stock")
+    p_stock.add_argument("sku", nargs="?")
+
+    p_hist = sub.add_parser("history")
+    p_hist.add_argument("sku")
+
+    sub.add_parser("rebuild")
+    return parser
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+
+    if args.command == "rebuild":
+        events = eventlog.read(args.log)
+        stockstate.save(args.log, stockstate.fold(events))
+        print(f"rebuilt {len(events)} events")
+        return 0
+
+    if args.command == "history":
+        for ev in eventlog.read(args.log):
+            if ev["sku"] == args.sku:
+                print(f"{ev['op']} {ev['qty']}")
+        return 0
+
+    try:
+        totals = stockstate.load(args.log)
+    except stockstate.SnapshotMissing as exc:
+        print(f"snapshot missing ({exc}); run rebuild first", file=sys.stderr)
+        return 1
+
+    if args.command == "stock":
+        if args.sku is not None:
+            print(totals.get(args.sku, 0))
+        else:
+            for sku in sorted(totals):
+                if totals[sku] > 0:
+                    print(f"{sku}: {totals[sku]}")
+        return 0
+
+    # in / out
+    delta = args.qty if args.command == "in" else -args.qty
+    current = totals.get(args.sku, 0)
+    if current + delta < 0:
+        print(f"cannot take {args.qty} of {args.sku}: only {current} on hand",
+              file=sys.stderr)
+        return 1
+    eventlog.append(args.log, args.command, args.sku, args.qty)
+    totals[args.sku] = current + delta
+    stockstate.save(args.log, totals)
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
