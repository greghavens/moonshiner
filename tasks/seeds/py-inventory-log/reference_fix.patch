+"""Append-only JSON-lines event log — the source of truth.
+
+Event schema (shared with other warehouse tools, do not extend):
+    {"op": "in"|"out", "sku": str, "qty": positive int}
+"""
+import json
+import os
+
+
+def append(path, op, sku, qty):
+    with open(path, "a", encoding="utf-8") as f:
+        f.write(json.dumps({"op": op, "sku": sku, "qty": qty}) + "\n")
+
+
+def read(path):
+    """All events in log order; a missing log is an empty history."""
+    if not os.path.exists(path):
+        return []
+    events = []
+    with open(path, encoding="utf-8") as f:
+        for line in f:
+            if line.strip():
+                events.append(json.loads(line))
+    return events
