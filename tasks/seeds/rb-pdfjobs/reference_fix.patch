@@ -58,4 +58,16 @@ class ExportJob
            @doc_id, @options[:page_size], @options[:orientation],
            @options[:copies], stamps, ccs, bundle)
   end
+
+  private
+
+  # DEFAULTS holds nested structures; every job needs its own copies so a
+  # job's edits can never reach the shared constant or a sibling job.
+  def deep_copy(value)
+    case value
+    when Hash  then value.to_h { |k, v| [k, deep_copy(v)] }
+    when Array then value.map { |v| deep_copy(v) }
+    else value
+    end
+  end
 end
