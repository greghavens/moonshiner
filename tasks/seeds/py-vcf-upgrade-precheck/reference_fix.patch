@@ -0,0 +1,32 @@
+"""Exception types for the SDDC Manager precheck client."""
+
+
+class VcfApiError(Exception):
+    """A non-2xx (or contract-violating) answer from SDDC Manager."""
+
+    def __init__(self, status_code, error_code=None, message=None,
+                 remediation=None, reference_token=None, nested=None):
+        self.status_code = status_code
+        self.error_code = error_code
+        self.message = message
+        self.remediation = remediation
+        self.reference_token = reference_token
+        self.nested = list(nested) if nested else []
+        text = f"SDDC Manager returned {status_code}"
+        if error_code:
+            text += f" ({error_code})"
+        if message:
+            text += f": {message}"
+        super().__init__(text)
+
+
+class InventoryNotReadyError(VcfApiError):
+    """409: the SDDC Manager inventory cache is not seeded yet."""
+
+
+class TaskTimeoutError(VcfApiError):
+    """The polled task never reached a terminal state within max_polls reads."""
+
+
+class SpecError(ValueError):
+    """A locally-refused resource descriptor; nothing was sent on the wire."""
