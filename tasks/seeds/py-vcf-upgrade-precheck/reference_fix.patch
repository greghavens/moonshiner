+++ b/vcf_precheck/precheck.py
@@ -0,0 +1,43 @@
+"""End-to-end upgrade precheck flow and error-report flattening."""
+
+
+def flatten_errors(task):
+    """Flatten a task's composite errors depth-first for the ops report.
+
+    Order: each task-level error followed by its nested errors, then every
+    subTask in list order with its errors flattened the same way. Reference
+    tokens and remediation text survive verbatim; absent fields become None.
+    """
+    flat = []
+
+    def walk(error, source):
+        flat.append({
+            "source": source,
+            "errorCode": error.get("errorCode"),
+            "message": error.get("message"),
+            "remediationMessage": error.get("remediationMessage"),
+            "referenceToken": error.get("referenceToken"),
+        })
+        for nested in error.get("nestedErrors") or []:
+            walk(nested, source)
+
+    for error in task.get("errors") or []:
+        walk(error, "task")
+    for sub_task in task.get("subTasks") or []:
+        for error in sub_task.get("errors") or []:
+            walk(error, sub_task.get("name"))
+    return flat
+
+
+def run_upgrade_precheck(client, domain_id, resources, target_version):
+    """Query check-sets, trigger the run, follow the task, fetch the result."""
+    query_result = client.query_check_sets(domain_id, resources)
+    accepted = client.start_precheck(query_result, target_version=target_version)
+    task = client.wait_for_task(accepted["id"])
+    assessment = client.get_assessment(accepted["id"])
+    return {
+        "run_id": accepted["id"],
+        "task": task,
+        "assessment": assessment,
+        "errors": flatten_errors(task),
+    }
