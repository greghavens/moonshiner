{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0162",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "travel",
  "prompt": "Check trip TRP-6206 and confirm its name, current location, and status. Do not change it or contact anyone yet. Do not send any notification or message about it.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same trip to Ottawa. Do not change its departure date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Québec City, not Ottawa. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "travel_get",
    "travel_search",
    "travel_update",
    "travel_create",
    "travel_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "TRP-6206",
        "name": "Montréal conference trip",
        "location": "Montréal",
        "date": "2026-08-18",
        "status": "active"
      },
      {
        "id": "TRP-9206",
        "name": "Santa Fe site visit",
        "location": "Santa Fe",
        "date": "2026-09-23",
        "status": "pending"
      },
      {
        "id": "TRP-12206",
        "name": "Montréal conference trip archive",
        "location": "Santa Fe",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "travel_get",
            "arguments": {
              "id": "TRP-6206"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "travel_update",
            "arguments": {
              "id": "TRP-6206",
              "location": "Ottawa"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "travel_update",
            "arguments": {
              "id": "TRP-6206",
              "location": "Québec City"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its departure date or status."
      }
    ],
    "state_assertions": [
      "TRP-6206.location == Québec City",
      "TRP-6206.location != Ottawa",
      "TRP-6206.date == 2026-08-18",
      "TRP-9206.date == 2026-09-23",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "travel_create",
      "travel_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location."
    ]
  },
