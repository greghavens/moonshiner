+// Package mw is the platform's blessed middleware kit.
+package mw
+
+import (
+	"context"
+	"crypto/rand"
+	"encoding/hex"
+	"net/http"
+)
+
+// Middleware wraps an http.Handler with extra behavior.
+type Middleware func(http.Handler) http.Handler
+
+// Chain composes middlewares so that the first argument is outermost: it
+// sees the request first and the response last. Chain() is the identity,
+// and the result is itself a Middleware so chains can be nested.
+func Chain(mws ...Middleware) Middleware {
+	return func(next http.Handler) http.Handler {
+		h := next
+		for i := len(mws) - 1; i >= 0; i-- {
+			h = mws[i](h)
+		}
+		return h
+	}
+}
+
+type ctxKey int
+
+const requestIDKey ctxKey = 0
+
+// RequestID tags every request with an id: an incoming X-Request-ID header
+// is honored, otherwise a fresh unique one is generated. The id is set on
+// the response header and stored in the request context.
+func RequestID(next http.Handler) http.Handler {
+	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		id := r.Header.Get("X-Request-ID")
+		if id == "" {
+			id = newID()
+		}
+		w.Header().Set("X-Request-ID", id)
+		ctx := context.WithValue(r.Context(), requestIDKey, id)
+		next.ServeHTTP(w, r.WithContext(ctx))
+	})
+}
+
+func newID() string {
+	var b [16]byte
+	if _, err := rand.Read(b[:]); err != nil {
+		panic(err) // crypto/rand never fails on supported platforms
+	}
+	return hex.EncodeToString(b[:])
+}
+
+// RequestIDFrom returns the request id stored by RequestID, or "" when the
+// middleware never ran.
+func RequestIDFrom(ctx context.Context) string {
+	id, _ := ctx.Value(requestIDKey).(string)
+	return id
+}
+
+// RequireHeader gates a handler: the named header must equal want or the
+// request is rejected with a 401 and the downstream handler never runs.
+func RequireHeader(name, want string) Middleware {
+	return func(next http.Handler) http.Handler {
+		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			if r.Header.Get(name) != want {
+				http.Error(w, "unauthorized", http.StatusUnauthorized)
+				return
+			}
+			next.ServeHTTP(w, r)
+		})
+	}
+}
+
+// Recover turns downstream panics into plain 500s without echoing the
+// panic value to the client. http.ErrAbortHandler is re-panicked because
+// net/http depends on it.
+func Recover(next http.Handler) http.Handler {
+	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		defer func() {
+			if v := recover(); v != nil {
+				if v == http.ErrAbortHandler {
+					panic(v)
+				}
+				http.Error(w, "internal server error", http.StatusInternalServerError)
+			}
+		}()
+		next.ServeHTTP(w, r)
+	})
+}
+
+// CaptureStatus reports, once per request after the downstream handler
+// returns, the status actually sent and the total body bytes written.
+func CaptureStatus(onDone func(status int, bytes int64)) Middleware {
+	return func(next http.Handler) http.Handler {
+		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+			cw := &captureWriter{ResponseWriter: w}
+			defer func() {
+				onDone(cw.reportStatus(), cw.bytes)
+			}()
+			next.ServeHTTP(cw, r)
+		})
+	}
+}
+
+type captureWriter struct {
+	http.ResponseWriter
+	status int
+	bytes  int64
+}
+
+func (c *captureWriter) WriteHeader(status int) {
+	if c.status == 0 {
+		c.status = status
+	}
+	c.ResponseWriter.WriteHeader(status)
+}
+
+func (c *captureWriter) Write(p []byte) (int, error) {
+	if c.status == 0 {
+		c.status = http.StatusOK // implicit 200 on first write
+	}
+	n, err := c.ResponseWriter.Write(p)
+	c.bytes += int64(n)
+	return n, err
+}
+
+func (c *captureWriter) Flush() {
+	if f, ok := c.ResponseWriter.(http.Flusher); ok {
+		f.Flush()
+	}
+}
+
+func (c *captureWriter) reportStatus() int {
+	if c.status == 0 {
+		return http.StatusOK // handler wrote nothing at all
+	}
+	return c.status
+}
