index 0000000..e4345d7
--- /dev/null
+++ b/texttable.py
@@ -0,0 +1,85 @@
+"""Plain-text table renderer with alignment and word wrapping."""
+
+_ALIGNERS = {
+    "l": lambda text, width: text.ljust(width),
+    "r": lambda text, width: text.rjust(width),
+    "c": lambda text, width: text.center(width),
+}
+
+
+def _cell_text(value):
+    if value is None:
+        return ""
+    return str(value)
+
+
+def _wrap(text, width):
+    """Greedy word wrap; hard-break words longer than width."""
+    if len(text) <= width:
+        return [text]
+    lines = []
+    current = ""
+    for word in text.split(" "):
+        while len(word) > width:
+            if current:
+                lines.append(current)
+                current = ""
+            lines.append(word[:width])
+            word = word[width:]
+        if not word:
+            continue
+        candidate = f"{current} {word}" if current else word
+        if len(candidate) <= width:
+            current = candidate
+        else:
+            lines.append(current)
+            current = word
+    if current:
+        lines.append(current)
+    return lines or [""]
+
+
+def format_table(rows, headers, *, align=None, max_col_width=None):
+    ncols = len(headers)
+    if align is None:
+        align = ["l"] * ncols
+    if len(align) != ncols:
+        raise ValueError(f"align has {len(align)} entries for {ncols} columns")
+    for code in align:
+        if code not in _ALIGNERS:
+            raise ValueError(f"unknown align code: {code!r}")
+
+    # Normalize cells to lists of wrapped lines.
+    grid = []
+    for row in rows:
+        if len(row) > ncols:
+            raise ValueError(f"row has {len(row)} cells but only {ncols} columns")
+        cells = [_cell_text(v) for v in row] + [""] * (ncols - len(row))
+        if max_col_width is not None:
+            cells = [_wrap(c, max_col_width) for c in cells]
+        else:
+            cells = [[c] for c in cells]
+        grid.append(cells)
+
+    widths = [len(h) for h in headers]
+    for cells in grid:
+        for i, lines in enumerate(cells):
+            widths[i] = max(widths[i], max(len(line) for line in lines))
+
+    out = []
+
+    def emit(line_cells):
+        parts = [_ALIGNERS[align[i]](text, widths[i])
+                 for i, text in enumerate(line_cells)]
+        while parts and not parts[-1].strip():
+            parts.pop()
+        out.append(" | ".join(parts).rstrip())
+
+    emit(list(headers))
+    out.append("-+-".join("-" * w for w in widths))
+    for cells in grid:
+        height = max(len(lines) for lines in cells)
+        for lineno in range(height):
+            emit([lines[lineno] if lineno < len(lines) else ""
+                  for lines in cells])
+    return "\n".join(out)
