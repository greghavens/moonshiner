diff --git a/tsvjoin.sh b/tsvjoin.sh
new file mode 100644
index 0000000..96832bf
--- /dev/null
+++ b/tsvjoin.sh
@@ -0,0 +1,106 @@
+#!/usr/bin/env bash
+# tsvjoin.sh — left-join two headered TSV files on a named key column.
+#
+# usage: tsvjoin.sh [--key NAME] <left.tsv> <right.tsv>
+#
+# Output: joined header (left columns, then right columns minus the key),
+# then the body: every left row, right fields filled with '-' when unmatched,
+# rows ascending by key in C byte order.
+set -u
+LC_ALL=C
+export LC_ALL
+
+TAB=$(printf '\t')
+
+usage() {
+  echo 'usage: tsvjoin.sh [--key NAME] <left.tsv> <right.tsv>' >&2
+  exit 64
+}
+
+key=''
+args=()
+while [ "$#" -gt 0 ]; do
+  case $1 in
+    --key)
+      [ "$#" -ge 2 ] || usage
+      key=$2
+      shift 2
+      ;;
+    --*)
+      usage
+      ;;
+    *)
+      args+=( "$1" )
+      shift
+      ;;
+  esac
+done
+[ "${#args[@]}" -eq 2 ] || usage
+left=${args[0]}
+right=${args[1]}
+
+for f in "$left" "$right"; do
+  if [ ! -f "$f" ] || [ ! -r "$f" ]; then
+    echo "tsvjoin.sh: cannot read: $f" >&2
+    exit 66
+  fi
+done
+for f in "$left" "$right"; do
+  if [ ! -s "$f" ]; then
+    echo "tsvjoin.sh: empty file: $f" >&2
+    exit 65
+  fi
+done
+
+IFS= read -r lhead < "$left"
+IFS= read -r rhead < "$right"
+IFS=$TAB read -r -a lcols <<< "$lhead"
+IFS=$TAB read -r -a rcols <<< "$rhead"
+
+[ -n "$key" ] || key=${lcols[0]}
+
+lk=0
+for i in "${!lcols[@]}"; do
+  if [ "${lcols[$i]}" = "$key" ]; then
+    lk=$((i + 1))
+    break
+  fi
+done
+if [ "$lk" -eq 0 ]; then
+  echo "tsvjoin.sh: no such column: $key in $left" >&2
+  exit 65
+fi
+
+rk=0
+for i in "${!rcols[@]}"; do
+  if [ "${rcols[$i]}" = "$key" ]; then
+    rk=$((i + 1))
+    break
+  fi
+done
+if [ "$rk" -eq 0 ]; then
+  echo "tsvjoin.sh: no such column: $key in $right" >&2
+  exit 65
+fi
+
+# Joined header: left columns, then right columns minus the key column.
+header=$lhead
+for i in "${!rcols[@]}"; do
+  [ $((i + 1)) -eq "$rk" ] && continue
+  header=$header$TAB${rcols[$i]}
+done
+printf '%s\n' "$header"
+
+# Explicit output field list so unpaired left rows get '-' fills.
+olist=''
+for ((i = 1; i <= ${#lcols[@]}; i++)); do
+  olist=$olist${olist:+,}1.$i
+done
+for ((j = 1; j <= ${#rcols[@]}; j++)); do
+  [ "$j" -eq "$rk" ] && continue
+  olist=$olist,2.$j
+done
+
+join -t "$TAB" -1 "$lk" -2 "$rk" -a 1 -e '-' -o "$olist" \
+  <(tail -n +2 "$left" | sort -t "$TAB" -k"$lk,$lk") \
+  <(tail -n +2 "$right" | sort -t "$TAB" -k"$rk,$rk")
