+package jobflow
+
+import "fmt"
+
+// validateGraph checks that every dependency exists and that the dependency
+// graph is acyclic. Called once, at the top of Run.
+func validateGraph(specs []JobSpec, index map[JobID]int) error {
+	for _, spec := range specs {
+		for _, dep := range spec.Deps {
+			if _, known := index[dep]; !known {
+				return fmt.Errorf("jobflow: job %q depends on unknown job %q", spec.ID, dep)
+			}
+		}
+	}
+
+	const (
+		unvisited = iota
+		visiting
+		done
+	)
+	colors := make(map[JobID]int, len(specs))
+	var visit func(id JobID) error
+	visit = func(id JobID) error {
+		switch colors[id] {
+		case visiting:
+			return fmt.Errorf("jobflow: dependency cycle through job %q", id)
+		case done:
+			return nil
+		}
+		colors[id] = visiting
+		for _, dep := range specs[index[id]].Deps {
+			if err := visit(dep); err != nil {
+				return err
+			}
+		}
+		colors[id] = done
+		return nil
+	}
+	for _, spec := range specs {
+		if err := visit(spec.ID); err != nil {
+			return err
+		}
+	}
+	return nil
+}
diff --git a/jobflow.go b/jobflow.go
