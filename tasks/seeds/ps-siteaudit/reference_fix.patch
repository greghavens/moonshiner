diff --git a/siteaudit.ps1 b/siteaudit.ps1
index b4b2f14..a8bee65 100644
--- a/siteaudit.ps1
+++ b/siteaudit.ps1
@@ -2,6 +2,7 @@
 #
 #   pwsh -NoProfile -File siteaudit.ps1 -Root <dir> -Now <iso8601-utc>
 #                                       [-MaxBytes <n>] [-MaxAgeDays <n>]
+#                                       [-Rules <file>] [-MinSeverity <level>]
 #
 # The reference instant always arrives as -Now; this tool never reads the
 # wall clock, so audits are reproducible after the fact.
@@ -12,17 +13,30 @@
 #                days before -Now
 #   badname   -- leaf name contains a space or an uppercase ASCII letter
 #
-# Output: one '<check> <relative-path>' line per finding, all lines sorted
-# ordinal; paths are relative to -Root with '/' separators. Exit 65 when
-# there is at least one finding, 0 when the tree is clean.
+# Default severities: oversize=error, stale=warn, badname=info.
 #
-# Errors (stdout stays empty): bad -Now -> exit 64, missing root -> 66.
+# -Rules file: one directive per line, '#' comments and blanks ignored:
+#   exclude <pattern>            drop every finding on a matching path
+#   severity <level> <pattern>   override the level on matching paths
+# Patterns match the relative path case-sensitively (wildcards allowed).
+# An exclude always beats a severity override; among severity lines the
+# LAST matching one wins.
+#
+# Output: without -Rules/-MinSeverity, the classic '<check> <rel>' lines;
+# with either flag, '<level> <check> <rel>'. All lines sorted ordinal.
+# -MinSeverity (info|warn|error, default info) drops findings below the
+# given level. Exit 65 when at least one finding is reported, 0 otherwise.
+#
+# Errors (stdout stays empty): bad -Now / bad -MinSeverity / bad rule
+# line -> exit 64, missing root or rules file -> 66.
 
 param(
     [Parameter(Mandatory)][string]$Root,
     [Parameter(Mandatory)][string]$Now,
     [int]$MaxBytes = 4096,
-    [int]$MaxAgeDays = 90
+    [int]$MaxAgeDays = 90,
+    [string]$Rules,
+    [string]$MinSeverity = 'info'
 )
 
 Set-StrictMode -Version Latest
@@ -34,6 +48,11 @@ function Fail {
     exit $Code
 }
 
+$levelRank = [System.Collections.Generic.Dictionary[string, int]]::new([System.StringComparer]::Ordinal)
+$levelRank['info'] = 0
+$levelRank['warn'] = 1
+$levelRank['error'] = 2
+
 $nowUtc = [datetime]::MinValue
 $styles = [System.Globalization.DateTimeStyles]::AssumeUniversal -bor
           [System.Globalization.DateTimeStyles]::AdjustToUniversal
@@ -42,27 +61,81 @@ if (-not [datetime]::TryParse($Now, [System.Globalization.CultureInfo]::Invarian
     Fail "bad -Now value: $Now" 64
 }
 
+if (-not $levelRank.ContainsKey($MinSeverity)) {
+    Fail "bad -MinSeverity value: $MinSeverity" 64
+}
+
 if (-not (Test-Path -LiteralPath $Root -PathType Container)) {
     Fail "root not found: $Root" 66
 }
 $prefix = (Get-Item -LiteralPath $Root).FullName
 
+# The level column appears as soon as the caller opts into either of the
+# new knobs; bare invocations keep the classic format.
+$severityMode = $PSBoundParameters.ContainsKey('Rules') -or
+                $PSBoundParameters.ContainsKey('MinSeverity')
+
+$excludes = @()
+$overrides = @()
+if ($PSBoundParameters.ContainsKey('Rules')) {
+    if (-not (Test-Path -LiteralPath $Rules -PathType Leaf)) {
+        Fail "rules file not found: $Rules" 66
+    }
+    $leaf = Split-Path -Leaf $Rules
+    $lineNo = 0
+    foreach ($raw in [System.IO.File]::ReadAllLines($Rules)) {
+        $lineNo++
+        $text = $raw.Trim()
+        if ($text -ceq '' -or $text.StartsWith('#')) { continue }
+        $head = $text -split ' ', 2
+        if ($head[0] -ceq 'exclude' -and $head.Count -eq 2 -and $head[1].Trim() -cne '') {
+            $excludes += $head[1].Trim()
+            continue
+        }
+        if ($head[0] -ceq 'severity' -and $head.Count -eq 2) {
+            $rest = $head[1].Trim() -split ' ', 2
+            if ($rest.Count -eq 2 -and $levelRank.ContainsKey($rest[0]) -and $rest[1].Trim() -cne '') {
+                $overrides += [pscustomobject]@{ Level = $rest[0]; Pattern = $rest[1].Trim() }
+                continue
+            }
+        }
+        Fail "${leaf}: bad rule line $lineNo" 64
+    }
+}
+
+$defaultLevel = @{ oversize = 'error'; stale = 'warn'; badname = 'info' }
+
 $maxAge = [timespan]::FromDays($MaxAgeDays)
-$lines = @()
+$findings = @()
 foreach ($f in @(Get-ChildItem -LiteralPath $prefix -Recurse -File -Force)) {
     $rel = $f.FullName.Substring($prefix.Length).TrimStart('/', '\') -replace '\\', '/'
-    if ($f.Length -gt $MaxBytes) {
-        $lines += "oversize $rel"
-    }
-    if (($nowUtc - $f.LastWriteTimeUtc) -gt $maxAge) {
-        $lines += "stale $rel"
+    $checks = @()
+    if ($f.Length -gt $MaxBytes) { $checks += 'oversize' }
+    if (($nowUtc - $f.LastWriteTimeUtc) -gt $maxAge) { $checks += 'stale' }
+    if ($f.Name.Contains(' ') -or ($f.Name -cmatch '[A-Z]')) { $checks += 'badname' }
+    if ($checks.Count -eq 0) { continue }
+
+    $excluded = $false
+    foreach ($pattern in $excludes) {
+        if ($rel -clike $pattern) { $excluded = $true; break }
     }
-    if ($f.Name.Contains(' ') -or ($f.Name -cmatch '[A-Z]')) {
-        $lines += "badname $rel"
+    if ($excluded) { continue }
+
+    foreach ($check in $checks) {
+        $level = $defaultLevel[$check]
+        foreach ($rule in $overrides) {
+            if ($rel -clike $rule.Pattern) { $level = $rule.Level }
+        }
+        if ($levelRank[$level] -lt $levelRank[$MinSeverity]) { continue }
+        if ($severityMode) {
+            $findings += "$level $check $rel"
+        } else {
+            $findings += "$check $rel"
+        }
     }
 }
 
-[Array]::Sort($lines, [System.StringComparer]::Ordinal)
-foreach ($line in $lines) { Write-Output $line }
-if ($lines.Count -gt 0) { exit 65 }
+[Array]::Sort($findings, [System.StringComparer]::Ordinal)
+foreach ($line in $findings) { Write-Output $line }
+if ($findings.Count -gt 0) { exit 65 }
 exit 0
