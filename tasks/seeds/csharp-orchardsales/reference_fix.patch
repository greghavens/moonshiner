+namespace OrchardSales;
+
+public sealed record VarietyTotal(string Variety, int Crates, decimal Revenue);
+
+public sealed record GrowerSummary(string GrowerId, decimal Revenue, int Deliveries, int DistinctVarieties);
+
+public sealed record DailyTotal(DateOnly Day, decimal Revenue, string TopVariety);
+
+public sealed record PriceSpread(decimal Min, decimal Max, decimal WeightedAverage);
+
+public static class CoopReport
+{
+    private static decimal LineRevenue(CrateLine line) => line.Crates * line.PricePerCrate;
+
+    private static decimal TicketRevenue(Delivery d) => d.Lines.Sum(LineRevenue);
+
+    public static IReadOnlyList<VarietyTotal> VarietyTotals(IEnumerable<Delivery> deliveries) =>
+        deliveries
+            .SelectMany(d => d.Lines)
+            .GroupBy(l => l.Variety, StringComparer.Ordinal)
+            .Select(g => new VarietyTotal(g.Key, g.Sum(l => l.Crates), g.Sum(LineRevenue)))
+            .OrderByDescending(v => v.Revenue)
+            .ThenBy(v => v.Variety, StringComparer.Ordinal)
+            .ToList();
+
+    public static IReadOnlyList<GrowerSummary> GrowerLeaderboard(IEnumerable<Delivery> deliveries, int top)
+    {
+        if (top < 0)
+            throw new ArgumentOutOfRangeException(nameof(top));
+        return deliveries
+            .GroupBy(d => d.GrowerId, StringComparer.Ordinal)
+            .Select(g => new GrowerSummary(
+                g.Key,
+                g.Sum(TicketRevenue),
+                g.Count(),
+                g.SelectMany(d => d.Lines).Select(l => l.Variety).Distinct(StringComparer.Ordinal).Count()))
+            .OrderByDescending(s => s.Revenue)
+            .ThenBy(s => s.GrowerId, StringComparer.Ordinal)
+            .Take(top)
+            .ToList();
+    }
+
+    public static IReadOnlyList<DailyTotal> DailyTotals(IEnumerable<Delivery> deliveries) =>
+        deliveries
+            .GroupBy(d => d.Day)
+            .OrderBy(g => g.Key)
+            .Select(g => new DailyTotal(
+                g.Key,
+                g.Sum(TicketRevenue),
+                g.SelectMany(d => d.Lines)
+                 .GroupBy(l => l.Variety, StringComparer.Ordinal)
+                 .Select(v => (Variety: v.Key, Crates: v.Sum(l => l.Crates)))
+                 .OrderByDescending(v => v.Crates)
+                 .ThenBy(v => v.Variety, StringComparer.Ordinal)
+                 .Select(v => v.Variety)
+                 .FirstOrDefault() ?? ""))
+            .ToList();
+
+    public static PriceSpread SpreadFor(IEnumerable<Delivery> deliveries, string variety)
+    {
+        var lines = deliveries
+            .SelectMany(d => d.Lines)
+            .Where(l => string.Equals(l.Variety, variety, StringComparison.Ordinal))
+            .ToList();
+        if (lines.Count == 0)
+            throw new InvalidOperationException($"no crates of variety '{variety}'");
+        var crates = lines.Sum(l => l.Crates);
+        var revenue = lines.Sum(LineRevenue);
+        return new PriceSpread(
+            lines.Min(l => l.PricePerCrate),
+            lines.Max(l => l.PricePerCrate),
+            Math.Round(revenue / crates, 2, MidpointRounding.AwayFromZero));
+    }
+}
