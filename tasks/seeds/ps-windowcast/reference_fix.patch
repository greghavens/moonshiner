diff --git a/announce.ps1 b/announce.ps1
new file mode 100644
index 0000000..9b8a5e2
--- /dev/null
+++ b/announce.ps1
@@ -0,0 +1,108 @@
+# announce.ps1 — format a maintenance-window card for the ops channel.
+# Runs non-interactively everywhere (CI, chat-bridge): binding failures
+# are left to the engine on purpose; only body-level checks use 64/65.
+[CmdletBinding(DefaultParameterSetName = 'Run')]
+param(
+    [Parameter(ParameterSetName = 'Help')]
+    [switch]$Help,
+
+    [Parameter(Mandatory, ParameterSetName = 'Run')]
+    [ValidatePattern('^[a-z][a-z0-9-]{1,31}$')]
+    [string]$Service,
+
+    [Parameter(Mandatory, ParameterSetName = 'Run')]
+    [ValidatePattern('^\d{4}-\d{2}-\d{2}$')]
+    [string]$Date,
+
+    [Parameter(ParameterSetName = 'Run')]
+    [string]$Start = '22:00',
+
+    [Parameter(ParameterSetName = 'Run')]
+    [int]$Minutes = 30,
+
+    [Parameter(ParameterSetName = 'Run')]
+    [ValidateSet('low', 'normal', 'urgent')]
+    [string]$Impact = 'normal',
+
+    [Parameter(ParameterSetName = 'Run')]
+    [string]$NotesFile
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+$usage = @'
+usage: announce.ps1 -Service <name> -Date <yyyy-MM-dd> [options]
+
+options:
+  -Service <name>     lowercase service id (letters, digits, dashes)
+  -Date <yyyy-MM-dd>  date of the window
+  -Start <HH:mm>      24-hour start time (default 22:00)
+  -Minutes <n>        window length in minutes, 1..480 (default 30)
+  -Impact <level>     one of: low, normal, urgent (default normal)
+  -NotesFile <path>   append each non-empty line of this file to the card
+  -Help               print this help and exit 0
+
+exit codes: 0 ok, 64 usage error, 65 data error (binding errors exit 1)
+'@
+
+if ($PSCmdlet.ParameterSetName -eq 'Help') {
+    Write-Output $usage
+    exit 0
+}
+
+function Exit-Usage {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    [Console]::Error.WriteLine($usage)
+    exit 64
+}
+
+function Exit-Data {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit 65
+}
+
+if ($Start -notmatch '^([01][0-9]|2[0-3]):[0-5][0-9]$') {
+    Exit-Usage "announce: invalid start time: $Start"
+}
+if ($Minutes -lt 1 -or $Minutes -gt 480) {
+    Exit-Usage "announce: minutes out of range: $Minutes"
+}
+
+$noteLines = @()
+if ($PSBoundParameters.ContainsKey('NotesFile')) {
+    if (-not (Test-Path -LiteralPath $NotesFile -PathType Leaf)) {
+        Exit-Data "announce: notes file not found: $NotesFile"
+    }
+    foreach ($line in [System.IO.File]::ReadAllLines($NotesFile)) {
+        $trimmed = $line.TrimEnd()
+        if ($trimmed.Length -gt 0) {
+            $noteLines += $trimmed
+        }
+    }
+    if ($noteLines.Count -eq 0) {
+        Exit-Data "announce: notes file is empty: $NotesFile"
+    }
+}
+
+$startHour = [int]$Start.Substring(0, 2)
+$startMinute = [int]$Start.Substring(3, 2)
+$endTotal = $startHour * 60 + $startMinute + $Minutes
+$daySuffix = ''
+if ($endTotal -ge 1440) {
+    $endTotal -= 1440
+    $daySuffix = '+1d'
+}
+$end = '{0:D2}:{1:D2}' -f [int][math]::Floor($endTotal / 60), ($endTotal % 60)
+
+$card = @(
+    "service: $Service"
+    "window: $Date $Start-$end$daySuffix"
+    "impact: $Impact"
+    "minutes: $Minutes"
+)
+$card += @($noteLines | ForEach-Object { "note: $_" })
+Write-Output ($card -join "`n")
+exit 0
