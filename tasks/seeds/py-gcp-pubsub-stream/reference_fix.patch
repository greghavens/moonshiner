diff --git a/pubstream/lease.py b/pubstream/lease.py
new file mode 100644
index 0000000..38c2013
--- /dev/null
+++ b/pubstream/lease.py
@@ -0,0 +1,28 @@
+"""Explicit lease extension for messages whose processing outlives the
+acknowledgment deadline."""
+
+# The service caps modifyAckDeadline at 600 seconds. Below 10 seconds the
+# library docs advise against extending (network latency), and 0 makes the
+# message immediately redeliverable — a nack in effect — so the whole
+# sub-10 range is rejected as an extension value.
+_MIN_EXTENSION = 10
+_MAX_EXTENSION = 600
+
+
+class LeaseHandle:
+    """Lets a handler push out its message's ack deadline while it works."""
+
+    def __init__(self, message):
+        self._message = message
+        self.extensions = []
+
+    def extend(self, seconds):
+        if isinstance(seconds, bool) or not isinstance(seconds, int):
+            raise ValueError("lease extension must be an integer number of seconds")
+        if not _MIN_EXTENSION <= seconds <= _MAX_EXTENSION:
+            raise ValueError(
+                f"lease extension must be between {_MIN_EXTENSION} and "
+                f"{_MAX_EXTENSION} seconds"
+            )
+        self._message.modify_ack_deadline(seconds)
+        self.extensions.append(seconds)
