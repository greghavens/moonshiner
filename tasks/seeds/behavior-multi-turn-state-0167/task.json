      },
      {
        "id": "ITM-9271",
        "name": "Nitrile work gloves",
        "location": "Supply Cage A",
        "date": "2026-09-10",
        "status": "pending"
      },
      {
        "id": "ITM-12271",
        "name": "Letter-size printer paper archive",
        "location": "Supply Cage A",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
