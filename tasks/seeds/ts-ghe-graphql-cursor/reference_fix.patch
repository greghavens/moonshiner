+// Minimal GitHub GraphQL transport: POST /graphql with bearer auth,
+// separate variables, and typed HTTP/GraphQL errors that never leak the
+// token.
+
+export interface GraphQLErrorEntry {
+  message: string;
+  type?: string;
+  path?: Array<string | number>;
+}
+
+export interface RateHeaders {
+  limit: number | null;
+  remaining: number | null;
+  used: number | null;
+  reset: number | null;
+  resource: string | null;
+}
+
+export interface ExecuteResult {
+  data: any;
+  errors?: GraphQLErrorEntry[];
+  rateHeaders: RateHeaders;
+}
+
+export class GraphQLHttpError extends Error {
+  readonly status: number;
+
+  constructor(status: number, apiMessage: string) {
+    super(`github graphql http ${status}: ${apiMessage}`);
+    this.name = "GraphQLHttpError";
+    this.status = status;
+  }
+}
+
+export class GraphQLQueryError extends Error {
+  readonly errors: GraphQLErrorEntry[];
+
+  constructor(errors: GraphQLErrorEntry[]) {
+    super(`github graphql query failed: ${errors.map((e) => e.message).join("; ")}`);
+    this.name = "GraphQLQueryError";
+    this.errors = errors;
+  }
+}
+
+export interface ClientOptions {
+  baseUrl: string;
+  token: string;
+}
+
+function num(headers: Headers, name: string): number | null {
+  const raw = headers.get(name);
+  if (raw === null || raw === "") return null;
+  const n = Number(raw);
+  return Number.isNaN(n) ? null : n;
+}
+
+export class GraphQLClient {
+  readonly #endpoint: string;
+  readonly #token: string;
+
+  constructor(opts: ClientOptions) {
+    this.#endpoint = opts.baseUrl.replace(/\/+$/, "") + "/graphql";
+    this.#token = opts.token;
+  }
+
+  async execute(query: string, variables: Record<string, unknown>): Promise<ExecuteResult> {
+    const res = await fetch(this.#endpoint, {
+      method: "POST",
+      headers: {
+        authorization: `bearer ${this.#token}`,
+        "content-type": "application/json",
+        "user-agent": "compliance-repo-inventory/1.0",
+      },
+      body: JSON.stringify({ query, variables }),
+    });
+
+    const rateHeaders: RateHeaders = {
+      limit: num(res.headers, "x-ratelimit-limit"),
+      remaining: num(res.headers, "x-ratelimit-remaining"),
+      used: num(res.headers, "x-ratelimit-used"),
+      reset: num(res.headers, "x-ratelimit-reset"),
+      resource: res.headers.get("x-ratelimit-resource"),
+    };
+
+    const raw = await res.text();
+    if (!res.ok) {
+      let apiMessage = res.statusText || `status ${res.status}`;
+      try {
+        const parsed = JSON.parse(raw);
+        if (parsed && typeof parsed.message === "string") apiMessage = parsed.message;
+      } catch {
+        // non-JSON error body (e.g. a bare gateway page): keep the status text
+      }
+      throw new GraphQLHttpError(res.status, apiMessage);
+    }
+
+    const envelope = JSON.parse(raw);
+    return { data: envelope.data, errors: envelope.errors, rateHeaders };
+  }
+}
