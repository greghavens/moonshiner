+// Repository inventory: parameterized query, pageInfo cursor traversal,
+// partial-error tolerance, single bounded retry, and node-id deduplication.
+
+import {
+  GraphQLClient,
+  GraphQLHttpError,
+  GraphQLQueryError,
+  type ExecuteResult,
+  type GraphQLErrorEntry,
+  type RateHeaders,
+} from "./client.ts";
+
+const MAX_PAGE_SIZE = 100; // documented cap for first/last
+const RETRYABLE = new Set([502, 503]);
+
+const REPOSITORIES_QUERY = `
+query OrgRepositories($login: String!, $first: Int!, $after: String) {
+  organization(login: $login) {
+    repositories(first: $first, after: $after) {
+      totalCount
+      pageInfo {
+        hasNextPage
+        endCursor
+      }
+      nodes {
+        id
+        name
+        nameWithOwner
+        isArchived
+        visibility
+        pushedAt
+      }
+    }
+  }
+  rateLimit {
+    limit
+    cost
+    remaining
+    used
+    resetAt
+  }
+}`;
+
+export interface Repository {
+  id: string;
+  name: string;
+  nameWithOwner: string;
+  isArchived: boolean;
+  visibility: string;
+  pushedAt: string | null;
+}
+
+export interface RateLimitInfo {
+  limit: number;
+  cost: number;
+  remaining: number;
+  used: number;
+  resetAt: string;
+}
+
+export interface InventoryReport {
+  repositories: Repository[];
+  totalCount: number;
+  pagesFetched: number;
+  duplicatesDropped: number;
+  warnings: GraphQLErrorEntry[];
+  rateLimit: RateLimitInfo;
+  rateHeaders: RateHeaders;
+}
+
+export interface InventoryOptions {
+  pageSize?: number;
+}
+
+async function fetchPage(
+  client: GraphQLClient,
+  variables: Record<string, unknown>,
+): Promise<ExecuteResult> {
+  try {
+    return await client.execute(REPOSITORIES_QUERY, variables);
+  } catch (err) {
+    if (err instanceof GraphQLHttpError && RETRYABLE.has(err.status)) {
+      return await client.execute(REPOSITORIES_QUERY, variables);
+    }
+    throw err;
+  }
+}
+
+export async function collectRepositories(
+  client: GraphQLClient,
+  login: string,
+  opts: InventoryOptions = {},
+): Promise<InventoryReport> {
+  const first = Math.max(1, Math.min(opts.pageSize ?? MAX_PAGE_SIZE, MAX_PAGE_SIZE));
+
+  const seen = new Set<string>();
+  const repositories: Repository[] = [];
+  const warnings: GraphQLErrorEntry[] = [];
+  let duplicatesDropped = 0;
+  let totalCount = 0;
+  let pagesFetched = 0;
+  let rateLimit: RateLimitInfo | undefined;
+  let rateHeaders: RateHeaders | undefined;
+  let after: string | null = null;
+
+  for (;;) {
+    const res = await fetchPage(client, { login, first, after });
+    const connection = res.data?.organization?.repositories;
+    if (!connection) {
+      throw new GraphQLQueryError(
+        res.errors ?? [{ message: "no data and no errors in response" }],
+      );
+    }
+    if (res.errors?.length) {
+      warnings.push(...res.errors);
+    }
+
+    pagesFetched += 1;
+    totalCount = connection.totalCount;
+    if (res.data.rateLimit) rateLimit = res.data.rateLimit;
+    rateHeaders = res.rateHeaders;
+
+    for (const node of connection.nodes as Array<Repository | null>) {
+      if (node === null) continue; // partial-error hole
+      if (seen.has(node.id)) {
+        duplicatesDropped += 1;
+        continue;
+      }
+      seen.add(node.id);
+      repositories.push(node);
+    }
+
+    if (!connection.pageInfo.hasNextPage) break;
+    after = connection.pageInfo.endCursor;
+  }
+
+  return {
+    repositories,
+    totalCount,
+    pagesFetched,
+    duplicatesDropped,
+    warnings,
+    rateLimit: rateLimit!,
+    rateHeaders: rateHeaders!,
+  };
+}
