+// Connect Four engine plus a fixed-depth negamax bot with fully pinned
+// behavior: plain negamax (no pruning), depth-weighted win scores, a
+// center-column heuristic at the leaves, and lowest-column tie-breaking.
+
+export type Piece = 'X' | 'O';
+export type Winner = Piece | 'draw' | null;
+
+export const ROWS = 6;
+export const COLS = 7;
+
+export interface Game {
+  readonly board: ReadonlyArray<ReadonlyArray<string>>; // row 0 = top, '.' empty
+  readonly turn: Piece;
+  readonly winner: Winner;
+}
+
+export function newGame(): Game {
+  return {
+    board: Array.from({ length: ROWS }, () => Array(COLS).fill('.')),
+    turn: 'X',
+    winner: null,
+  };
+}
+
+const DIRS: Array<[number, number]> = [[0, 1], [1, 0], [1, 1], [1, -1]];
+
+function runLength(board: ReadonlyArray<ReadonlyArray<string>>, r: number, c: number, dr: number, dc: number): number {
+  const piece = board[r][c];
+  let n = 1;
+  for (const sign of [1, -1]) {
+    let rr = r + dr * sign;
+    let cc = c + dc * sign;
+    while (rr >= 0 && rr < ROWS && cc >= 0 && cc < COLS && board[rr][cc] === piece) {
+      n++;
+      rr += dr * sign;
+      cc += dc * sign;
+    }
+  }
+  return n;
+}
+
+function wonThrough(board: ReadonlyArray<ReadonlyArray<string>>, r: number, c: number): boolean {
+  return DIRS.some(([dr, dc]) => runLength(board, r, c, dr, dc) >= 4);
+}
+
+export function legalMoves(game: Game): number[] {
+  if (game.winner !== null) return [];
+  const out: number[] = [];
+  for (let c = 0; c < COLS; c++) {
+    if (game.board[0][c] === '.') out.push(c);
+  }
+  return out;
+}
+
+export function drop(game: Game, col: number): Game {
+  if (!Number.isInteger(col) || col < 0 || col >= COLS) {
+    throw new RangeError(`column out of range: ${col}`);
+  }
+  if (game.winner !== null) throw new Error('game is over');
+  if (game.board[0][col] !== '.') throw new Error(`column ${col} is full`);
+  const board = game.board.map((row) => row.slice());
+  let r = ROWS - 1;
+  while (board[r][col] !== '.') r--;
+  board[r][col] = game.turn;
+  let winner: Winner = null;
+  if (wonThrough(board, r, col)) {
+    winner = game.turn;
+  } else if (board[0].every((cell) => cell !== '.')) {
+    winner = 'draw';
+  }
+  return { board, turn: game.turn === 'X' ? 'O' : 'X', winner };
+}
+
+// Fixture positions load from a 6-line board drawing. The side to move is
+// derived from the piece counts (X always moves first); a finished position
+// gets its winner detected by a full scan.
+export function parseBoard(text: string): Game {
+  const lines = text.split('\n').filter((l) => l !== '');
+  if (lines.length !== ROWS || lines.some((l) => l.length !== COLS)) {
+    throw new Error('board must be 6 lines of 7 cells');
+  }
+  const board = lines.map((l) => [...l]);
+  let x = 0;
+  let o = 0;
+  for (const row of board) {
+    for (const cell of row) {
+      if (cell === 'X') x++;
+      else if (cell === 'O') o++;
+      else if (cell !== '.') throw new Error(`bad cell: ${cell}`);
+    }
+  }
+  if (o > x || x - o > 1) throw new Error('impossible piece counts');
+  for (let c = 0; c < COLS; c++) {
+    for (let r = 1; r < ROWS; r++) {
+      if (board[r][c] === '.' && board[r - 1][c] !== '.') {
+        throw new Error(`floating piece in column ${c}`);
+      }
+    }
+  }
+  let winner: Winner = null;
+  for (let r = 0; r < ROWS; r++) {
+    for (let c = 0; c < COLS; c++) {
+      if (board[r][c] !== '.' && wonThrough(board, r, c)) {
+        const w = board[r][c] as Piece;
+        if (winner !== null && winner !== w) throw new Error('both sides have four in a row');
+        winner = w;
+      }
+    }
+  }
+  if (winner === null && board[0].every((cell) => cell !== '.')) winner = 'draw';
+  return { board, turn: x === o ? 'X' : 'O', winner };
+}
+
+export function render(game: Game): string {
+  return game.board.map((row) => row.join('')).join('\n');
+}
+
+// Leaf heuristic, from the perspective of the side to move: own discs in the
+// center column minus the opponent's discs there.
+function heuristic(game: Game): number {
+  let mine = 0;
+  let theirs = 0;
+  for (let r = 0; r < ROWS; r++) {
+    const cell = game.board[r][3];
+    if (cell === game.turn) mine++;
+    else if (cell !== '.') theirs++;
+  }
+  return mine - theirs;
+}
+
+// Negamax value of the position for the side to move. A lost position is
+// worth -(10000 - ply) so faster wins score higher than slower ones.
+function value(game: Game, depth: number, ply: number): number {
+  if (game.winner === 'draw') return 0;
+  if (game.winner !== null) return -(10000 - ply);
+  if (depth === 0) return heuristic(game);
+  let best = -Infinity;
+  for (const col of legalMoves(game)) {
+    const v = -value(drop(game, col), depth - 1, ply + 1);
+    if (v > best) best = v;
+  }
+  return best;
+}
+
+// Best column for the side to move, searching exactly `depth` plies. Ties
+// break to the LOWEST column index (candidates are scanned ascending and
+// only a strictly better value replaces the champion).
+export function bestMove(game: Game, depth: number): number {
+  if (!Number.isInteger(depth) || depth < 1) throw new RangeError(`bad depth: ${depth}`);
+  if (game.winner !== null) throw new Error('game is over');
+  let bestCol = -1;
+  let best = -Infinity;
+  for (const col of legalMoves(game)) {
+    const v = -value(drop(game, col), depth - 1, 1);
+    if (v > best) {
+      best = v;
+      bestCol = col;
+    }
+  }
+  return bestCol;
+}
+
+// Bot-vs-bot: both sides use bestMove at the same depth until the game ends.
+export function selfPlay(depth: number): { moves: number[]; game: Game } {
+  let game = newGame();
+  const moves: number[] = [];
+  while (game.winner === null) {
+    const col = bestMove(game, depth);
+    moves.push(col);
+    game = drop(game, col);
+  }
+  return { moves, game };
+}
