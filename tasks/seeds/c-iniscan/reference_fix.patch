diff --git a/ini.c b/ini.c
new file mode 100644
index 0000000..781b6a1
--- /dev/null
+++ b/ini.c
@@ -0,0 +1,234 @@
+#include "ini.h"
+
+#include <string.h>
+
+/* --- arena -------------------------------------------------------------- */
+
+void ini_arena_init(ini_arena *a, void *storage, size_t cap) {
+    a->base = storage;
+    a->cap = cap;
+    a->used = 0;
+}
+
+/* Copy [s, s+len) into the arena, NUL-terminated. NULL when full. */
+static char *arena_copy(ini_arena *a, const char *s, size_t len) {
+    if (a->used + len + 1 > a->cap)
+        return NULL;
+    char *dst = a->base + a->used;
+    memcpy(dst, s, len);
+    dst[len] = '\0';
+    a->used += len + 1;
+    return dst;
+}
+
+/* Append one byte to an in-progress arena string. 0 ok, -1 full. */
+static int arena_push(ini_arena *a, char ch) {
+    if (a->used + 1 > a->cap)
+        return -1;
+    a->base[a->used++] = ch;
+    return 0;
+}
+
+/* --- line helpers -------------------------------------------------------- */
+
+static int is_blank(char ch) {
+    return ch == ' ' || ch == '\t';
+}
+
+static size_t skip_blanks(const char *ln, size_t i, size_t len) {
+    while (i < len && is_blank(ln[i]))
+        i++;
+    return i;
+}
+
+static size_t trim_back(const char *ln, size_t i, size_t end) {
+    while (end > i && is_blank(ln[end - 1]))
+        end--;
+    return end;
+}
+
+static void set_err(size_t *err_line, size_t *err_col, size_t line,
+                    size_t col) {
+    if (err_line != NULL)
+        *err_line = line;
+    if (err_col != NULL)
+        *err_col = col;
+}
+
+/* --- parser ---------------------------------------------------------------
+ * One call per line; columns are 1-based byte positions in the line
+ * (the trailing \r, if any, is already stripped by the caller).
+ */
+
+typedef struct {
+    ini_arena *a;
+    ini_pair *pairs;
+    size_t max_pairs;
+    size_t npairs;
+    const char *section; /* current section name, arena or "" */
+} scan_state;
+
+static long parse_line(scan_state *st, const char *ln, size_t len,
+                       size_t lineno, size_t *err_line, size_t *err_col) {
+    size_t i = skip_blanks(ln, 0, len);
+    if (i == len || ln[i] == ';' || ln[i] == '#')
+        return INI_OK; /* blank or comment */
+
+    if (ln[i] == '[') {
+        const char *rb = memchr(ln + i, ']', len - i);
+        if (rb == NULL) {
+            set_err(err_line, err_col, lineno, i + 1);
+            return INI_ESECTION;
+        }
+        size_t close = (size_t)(rb - ln);
+        size_t ns = skip_blanks(ln, i + 1, close);
+        size_t ne = trim_back(ln, ns, close);
+        if (ns == ne) {
+            set_err(err_line, err_col, lineno, i + 1);
+            return INI_ESECTION;
+        }
+        size_t rest = skip_blanks(ln, close + 1, len);
+        if (rest < len) {
+            set_err(err_line, err_col, lineno, rest + 1);
+            return INI_ESECTION;
+        }
+        char *name = arena_copy(st->a, ln + ns, ne - ns);
+        if (name == NULL) {
+            set_err(err_line, err_col, lineno, 0);
+            return INI_ENOMEM;
+        }
+        st->section = name;
+        return INI_OK;
+    }
+
+    /* key = value */
+    const char *eqp = memchr(ln + i, '=', len - i);
+    if (eqp == NULL) {
+        set_err(err_line, err_col, lineno, i + 1);
+        return INI_EKEY;
+    }
+    size_t eq = (size_t)(eqp - ln);
+    size_t ke = trim_back(ln, i, eq);
+    if (i == ke) {
+        set_err(err_line, err_col, lineno, eq + 1);
+        return INI_EKEY;
+    }
+
+    if (st->npairs == st->max_pairs) {
+        set_err(err_line, err_col, lineno, 0);
+        return INI_ENOMEM;
+    }
+
+    char *key = arena_copy(st->a, ln + i, ke - i);
+    if (key == NULL) {
+        set_err(err_line, err_col, lineno, 0);
+        return INI_ENOMEM;
+    }
+
+    size_t vs = skip_blanks(ln, eq + 1, len);
+    size_t ve = trim_back(ln, vs, len);
+    const char *value;
+
+    if (vs < ve && ln[vs] == '"') {
+        /* quoted value: decode escapes straight into the arena */
+        size_t mark = st->a->used;
+        size_t p = vs + 1;
+        for (;;) {
+            if (p >= len) { /* never closed */
+                st->a->used = mark;
+                set_err(err_line, err_col, lineno, vs + 1);
+                return INI_EQUOTE;
+            }
+            char ch = ln[p];
+            if (ch == '"')
+                break;
+            if (ch == '\\') {
+                if (p + 1 >= len) {
+                    st->a->used = mark;
+                    set_err(err_line, err_col, lineno, p + 1);
+                    return INI_EQUOTE;
+                }
+                char esc = ln[p + 1];
+                if (esc == '"')
+                    ch = '"';
+                else if (esc == '\\')
+                    ch = '\\';
+                else if (esc == 'n')
+                    ch = '\n';
+                else if (esc == 't')
+                    ch = '\t';
+                else {
+                    st->a->used = mark;
+                    set_err(err_line, err_col, lineno, p + 1);
+                    return INI_EQUOTE;
+                }
+                p += 2;
+            } else {
+                p++;
+            }
+            if (arena_push(st->a, ch) != 0) {
+                st->a->used = mark;
+                set_err(err_line, err_col, lineno, 0);
+                return INI_ENOMEM;
+            }
+        }
+        size_t rest = skip_blanks(ln, p + 1, len);
+        if (rest < len) {
+            st->a->used = mark;
+            set_err(err_line, err_col, lineno, rest + 1);
+            return INI_ETRAIL;
+        }
+        if (arena_push(st->a, '\0') != 0) {
+            st->a->used = mark;
+            set_err(err_line, err_col, lineno, 0);
+            return INI_ENOMEM;
+        }
+        value = st->a->base + mark;
+    } else {
+        char *v = arena_copy(st->a, ln + vs, ve - vs);
+        if (v == NULL) {
+            set_err(err_line, err_col, lineno, 0);
+            return INI_ENOMEM;
+        }
+        value = v;
+    }
+
+    ini_pair *pr = &st->pairs[st->npairs++];
+    pr->section = st->section;
+    pr->key = key;
+    pr->value = value;
+    pr->line = lineno;
+    return INI_OK;
+}
+
+long ini_parse(const char *text, ini_arena *a,
+               ini_pair *pairs, size_t max_pairs,
+               size_t *err_line, size_t *err_col) {
+    if (text == NULL || a == NULL || pairs == NULL || max_pairs == 0)
+        return INI_EARG;
+
+    scan_state st;
+    st.a = a;
+    st.pairs = pairs;
+    st.max_pairs = max_pairs;
+    st.npairs = 0;
+    st.section = "";
+
+    const char *p = text;
+    size_t lineno = 0;
+    while (*p != '\0') {
+        lineno++;
+        const char *nl = strchr(p, '\n');
+        size_t len = nl != NULL ? (size_t)(nl - p) : strlen(p);
+        const char *next = nl != NULL ? nl + 1 : p + len;
+        if (len > 0 && p[len - 1] == '\r')
+            len--; /* CRLF input */
+        long rc = parse_line(&st, p, len, lineno, err_line, err_col);
+        if (rc != INI_OK)
+            return rc;
+        p = next;
+    }
+
+    set_err(err_line, err_col, 0, 0);
+    return (long)st.npairs;
+}
diff --git a/ini.h b/ini.h
new file mode 100644
index 0000000..ab6fdb5
--- /dev/null
+++ b/ini.h
@@ -0,0 +1,47 @@
+/* ini.h — single-pass INI scanner, all memory supplied by the caller.
+ *
+ * ini_parse walks the text once, copies every section/key/value string
+ * into the caller's arena, and appends one ini_pair per key/value line.
+ * It returns the pair count (>= 0) or a negative INI_* code; parse
+ * errors report a 1-based line and column through err_line/err_col.
+ */
+#ifndef INI_H
+#define INI_H
+
+#include <stddef.h>
+
+typedef struct {
+    char *base;   /* caller-provided storage */
+    size_t cap;   /* total bytes available */
+    size_t used;  /* bytes handed out so far */
+} ini_arena;
+
+typedef struct {
+    const char *section;  /* "" for pairs before the first [section] */
+    const char *key;
+    const char *value;
+    size_t line;          /* 1-based line the pair appeared on */
+} ini_pair;
+
+enum {
+    INI_OK       = 0,
+    INI_EARG     = -1,   /* bad call arguments */
+    INI_ESECTION = -2,   /* malformed [section] header */
+    INI_EKEY     = -3,   /* missing '=' or empty key */
+    INI_EQUOTE   = -4,   /* unterminated quote or unknown escape */
+    INI_ETRAIL   = -5,   /* text after a closing quote */
+    INI_ENOMEM   = -6    /* arena or pair table exhausted */
+};
+
+/* Record the storage block and reset the bump pointer. */
+void ini_arena_init(ini_arena *a, void *storage, size_t cap);
+
+/* Scan text; fill pairs (up to max_pairs) from the arena. On success
+ * returns the count and zeroes the err slots; on a parse error
+ * returns a negative code and sets them to the error position. Either
+ * pointer may be NULL. */
+long ini_parse(const char *text, ini_arena *a,
+               ini_pair *pairs, size_t max_pairs,
+               size_t *err_line, size_t *err_col);
+
+#endif /* INI_H */
