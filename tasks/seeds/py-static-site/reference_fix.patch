+#!/usr/bin/env python3
+"""Static site generator: flat dir of .md sources -> HTML pages + index.
+
+Validation is all-or-nothing: any bad source aborts before a single file
+is written.
+"""
+import argparse
+import os
+import sys
+
+import frontmatter
+import htmlout
+import mdlite
+
+
+def collect(srcdir):
+    """Render every publishable source in memory. Raises SourceError."""
+    rendered = {}
+    pages = []
+    for name in sorted(os.listdir(srcdir)):
+        if not name.endswith(".md"):
+            continue
+        with open(os.path.join(srcdir, name), encoding="utf-8") as f:
+            meta, body_lines = frontmatter.parse(name, f.read())
+        if meta["draft"]:
+            continue
+        html_name = name[:-3] + ".html"
+        rendered[html_name] = htmlout.page_html(meta["title"], mdlite.render(body_lines))
+        pages.append((html_name, meta["title"], meta["date"]))
+    rendered["index.html"] = htmlout.index_html(pages)
+    return rendered
+
+
+def main(argv=None):
+    parser = argparse.ArgumentParser(prog="sitegen.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+    p_build = sub.add_parser("build")
+    p_build.add_argument("srcdir")
+    p_build.add_argument("outdir")
+    args = parser.parse_args(argv)
+
+    try:
+        rendered = collect(args.srcdir)
+    except frontmatter.SourceError as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+    htmlout.write_site(args.outdir, rendered)
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
