+"""Front-matter parsing and validation for markdown sources."""
+from datetime import date
+
+
+class SourceError(Exception):
+    """A source file that cannot be published (message names the file)."""
+
+
+def parse(name, text):
+    """Split '---' front matter from body. Returns (meta, body_lines).
+
+    Raises SourceError when title/date are missing or the date is malformed.
+    """
+    lines = text.splitlines()
+    if not lines or lines[0].strip() != "---":
+        raise SourceError(f"{name}: missing front matter")
+    meta = {}
+    body_start = None
+    for i, line in enumerate(lines[1:], start=1):
+        if line.strip() == "---":
+            body_start = i + 1
+            break
+        key, sep, value = line.partition(":")
+        if sep:
+            meta[key.strip()] = value.strip()
+    if body_start is None:
+        raise SourceError(f"{name}: unterminated front matter")
+    if "title" not in meta or not meta["title"]:
+        raise SourceError(f"{name}: front matter is missing 'title'")
+    if "date" not in meta or not meta["date"]:
+        raise SourceError(f"{name}: front matter is missing 'date'")
+    try:
+        date.fromisoformat(meta["date"])
+    except ValueError:
+        raise SourceError(f"{name}: bad date {meta['date']!r} (want YYYY-MM-DD)")
+    meta["draft"] = meta.get("draft", "").lower() == "true"
+    return meta, lines[body_start:]
