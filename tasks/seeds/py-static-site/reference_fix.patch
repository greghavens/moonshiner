+"""Page/index assembly and the all-or-nothing site writer."""
+import os
+
+from mdlite import escape
+
+
+def page_html(title, blocks):
+    body = "\n".join(blocks)
+    return (f"<html>\n<head><title>{escape(title)}</title></head>\n"
+            f"<body>\n{body}\n</body>\n</html>\n")
+
+
+def index_html(pages):
+    """pages: list of (href, title, date) already rendered. Newest first,
+    ties by title A-Z (stable two-pass sort)."""
+    ordered = sorted(sorted(pages, key=lambda p: p[1]),
+                     key=lambda p: p[2], reverse=True)
+    items = "".join(f'<li><a href="{href}">{escape(title)}</a></li>'
+                    for href, title, _ in ordered)
+    return ("<html>\n<head><title>Index</title></head>\n"
+            f"<body>\n<ul>{items}</ul>\n</body>\n</html>\n")
+
+
+def write_site(outdir, rendered):
+    """rendered: {filename: html}. Written only after every page rendered."""
+    os.makedirs(outdir, exist_ok=True)
+    for name in sorted(rendered):
+        with open(os.path.join(outdir, name), "w", encoding="utf-8") as f:
+            f.write(rendered[name])
