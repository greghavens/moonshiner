diff --git a/syncjob.py b/syncjob.py
index 4e08d1a..b97299b 100644
--- a/syncjob.py
+++ b/syncjob.py
@@ -35,17 +35,23 @@ class CatalogSync:
         since = self._state.get("cursor", 0.0)
         params = {"since": since, "limit": self._page_size}
         upserted = 0
+        newest_seen = since
         while True:
             page = self._fetch(params)
             for rec in page["records"]:
                 self._store[rec["id"]] = rec
                 upserted += 1
+                if rec["updated_at"] > newest_seen:
+                    newest_seen = rec["updated_at"]
             token = page.get("next")
             if not token:
                 break
             params = {"since": since, "limit": self._page_size, "token": token}
         finished = self._clock()
-        self._state["cursor"] = finished
+        # The next run must start from the newest change we actually
+        # received -- anything edited after that (including mid-run edits
+        # this run's snapshot never showed us) still sorts after it.
+        self._state["cursor"] = newest_seen
         self._state["last_run_at"] = finished
         self._state["runs"] = self._state.get("runs", 0) + 1
         return upserted
