+"""Human-friendly duration and byte-size parsing/formatting.
+
+Durations: components like "1h30m" with units w/d/h/m/s/ms (lowercase),
+largest-to-smallest, no repeats, decimals allowed per component, one
+optional leading '-'.  Byte sizes: decimal (KB=1000) and binary
+(KiB=1024) ladders, case-insensitive, result rounded half-up to whole
+bytes.  Malformed input is always ValueError.
+"""
+
+import math
+import re
+
+_DUR_UNITS = [("w", 604800), ("d", 86400), ("h", 3600),
+              ("m", 60), ("s", 1), ("ms", 0.001)]
+_DUR_ORDER = {name: i for i, (name, _) in enumerate(_DUR_UNITS)}
+_DUR_COMPONENT = re.compile(r"(\d+(?:\.\d+)?)(ms|w|d|h|m|s)")
+
+_SIZE_UNITS = {"b": 1}
+for _i, _p in enumerate(["k", "m", "g", "t"], start=1):
+    _SIZE_UNITS[_p + "b"] = 1000 ** _i
+    _SIZE_UNITS[_p + "ib"] = 1024 ** _i
+
+_SIZE_RE = re.compile(r"(\d+(?:\.\d+)?)\s*([a-z]*)$")
+
+
+def parse_duration(s):
+    if not isinstance(s, str):
+        raise ValueError("duration must be a string: %r" % (s,))
+    text = s.strip()
+    sign = 1
+    if text.startswith("-"):
+        sign = -1
+        text = text[1:]
+    if not text:
+        raise ValueError("empty duration: %r" % (s,))
+    total = 0.0
+    last = -1
+    pos = 0
+    seen_any = False
+    while pos < len(text):
+        if text[pos] == " ":
+            pos += 1
+            continue
+        m = _DUR_COMPONENT.match(text, pos)
+        if not m:
+            raise ValueError("bad duration component in %r at %r"
+                             % (s, text[pos:]))
+        value, unit = float(m.group(1)), m.group(2)
+        order = _DUR_ORDER[unit]
+        if order <= last:
+            raise ValueError("units out of order or repeated in %r" % (s,))
+        last = order
+        total += value * dict(_DUR_UNITS)[unit]
+        seen_any = True
+        pos = m.end()
+    if not seen_any:
+        raise ValueError("no components in duration %r" % (s,))
+    return sign * total
+
+
+def format_duration(secs):
+    if not isinstance(secs, (int, float)) or isinstance(secs, bool):
+        raise ValueError("duration must be a number: %r" % (secs,))
+    sign = "-" if secs < 0 else ""
+    ms_total = int(math.floor(abs(secs) * 1000 + 0.5))
+    if ms_total == 0:
+        return "0s"
+    parts = []
+    for name, span in _DUR_UNITS:
+        span_ms = int(round(span * 1000))
+        count, ms_total = divmod(ms_total, span_ms)
+        if count:
+            parts.append("%d%s" % (count, name))
+    return sign + "".join(parts)
+
+
+def parse_size(s):
+    if not isinstance(s, str):
+        raise ValueError("size must be a string: %r" % (s,))
+    text = s.strip().lower()
+    if not text:
+        raise ValueError("empty size")
+    m = _SIZE_RE.match(text)
+    if not m:
+        raise ValueError("bad size: %r" % (s,))
+    number, unit = m.group(1), m.group(2)
+    if unit and unit not in _SIZE_UNITS:
+        raise ValueError("unknown unit %r in %r" % (unit, s))
+    factor = _SIZE_UNITS[unit] if unit else 1
+    raw = float(number) * factor
+    return int(math.floor(raw + 0.5))
+
+
+def format_size(n, binary=True):
+    if not isinstance(n, int) or isinstance(n, bool):
+        raise ValueError("size must be an int: %r" % (n,))
+    if n < 0:
+        raise ValueError("size must be non-negative: %r" % (n,))
+    base = 1024 if binary else 1000
+    names = ["B"] + [p + ("iB" if binary else "B") for p in "KMGT"]
+    value = float(n)
+    idx = 0
+    while value >= base and idx < len(names) - 1:
+        value /= base
+        idx += 1
+    if idx == 0:
+        return "%dB" % n
+    rendered = "%.2f" % value
+    rendered = rendered.rstrip("0").rstrip(".")
+    return rendered + names[idx]
