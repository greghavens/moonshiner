+# matchbook.ps1 — shared matching helpers for the change-window triage tool.
+# Everything in here is case-sensitive by policy; dot-source to use.
+
+function Get-NoteFields {
+    param([Parameter(Mandatory)][string]$Line)
+    $pattern = '^(?<date>\d{4}-\d{2}-\d{2}) (?<service>[a-z][a-z0-9-]*) ' +
+        '(?<action>restart|reload|patch) window=(?<start>\d{2}:\d{2})-(?<end>\d{2}:\d{2})$'
+    if ($Line -cmatch $pattern) {
+        return [pscustomobject]@{
+            Date        = $Matches['date']
+            Service     = $Matches['service']
+            Action      = $Matches['action']
+            WindowStart = $Matches['start']
+            WindowEnd   = $Matches['end']
+        }
+    }
+    return $null
+}
+
+function Get-ChangeRefs {
+    param([Parameter(Mandatory)][string]$Text)
+    $refs = foreach ($m in [regex]::Matches($Text, 'CHG-(?<num>\d+)')) {
+        [pscustomobject]@{
+            Ref    = $m.Value
+            Number = [int]$m.Groups['num'].Value
+            Index  = $m.Index
+        }
+    }
+    return @($refs)
+}
+
+function Hide-OwnerAddresses {
+    param([Parameter(Mandatory)][string]$Text)
+    $pattern = '(?<user>[A-Za-z][A-Za-z0-9._-]*)@(?<host>[A-Za-z0-9.-]+)'
+    return $Text -creplace $pattern, {
+        $_.Groups['user'].Value.Substring(0, 1) + '***@' + $_.Groups['host'].Value
+    }
+}
+
+function Test-FieldMatch {
+    param(
+        [Parameter(Mandatory)][string]$Value,
+        [Parameter(Mandatory)][string]$Pattern,
+        [Parameter(Mandatory)][ValidateSet('Exact', 'Anywhere')][string]$Mode
+    )
+    if ($Mode -eq 'Exact') {
+        return [regex]::IsMatch($Value, '^(?:' + $Pattern + ')$')
+    }
+    return [regex]::IsMatch($Value, $Pattern)
+}
