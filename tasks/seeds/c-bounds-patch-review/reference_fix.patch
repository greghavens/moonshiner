diff --git a/src/bounded_slice.c b/src/bounded_slice.c
--- a/src/bounded_slice.c
+++ b/src/bounded_slice.c
@@ -8,6 +8,8 @@ int bounded_slice_copy(char *destination,
                        ptrdiff_t source_offset,
