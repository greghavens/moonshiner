+// RenderWidth renders like Render but with the given bar width. Bar
+// lengths are rounded half up to the nearest column, and any bucket
+// with a nonzero count renders at least one column so it stays visible.
+func (h *Histogram) RenderWidth(w int) (string, error) {
+	if w < 1 {
+		return "", fmt.Errorf("histogram: bar width %d < 1", w)
+	}
+	return h.render(w, true), nil
