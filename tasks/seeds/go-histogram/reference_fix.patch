+// NewLog returns a histogram with n logarithmic buckets: bucket i
+// covers [lo*base^i, lo*base^(i+1)). lo must be positive, base greater
+// than 1, and n at least 1. Out-of-range samples are clamped exactly
+// like the linear constructor's.
+func NewLog(lo float64, n int, base float64) (*Histogram, error) {
+	if n < 1 {
+		return nil, fmt.Errorf("histogram: bucket count %d < 1", n)
+	}
+	if lo <= 0 {
+		return nil, fmt.Errorf("histogram: log scale needs lo > 0, got %g", lo)
+	}
+	if base <= 1 {
+		return nil, fmt.Errorf("histogram: log scale needs base > 1, got %g", base)
+	}
+	bounds := make([]float64, n+1)
+	bounds[0] = lo
+	for i := 1; i <= n; i++ {
+		bounds[i] = bounds[i-1] * base
+	}
+	return &Histogram{bounds: bounds, counts: make([]int, n)}, nil
+}
