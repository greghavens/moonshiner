@@ -0,0 +1,139 @@
+using System.Text.Json;
+
+namespace DbxServing;
+
+/// <summary>
+/// Creates or updates a serving endpoint and follows its readiness and
+/// config-update states through bounded, injected-wait polling.
+/// </summary>
+public sealed class EndpointDeployer
+{
+    private static readonly HashSet<string> FailedDeployments =
+        new() { "DEPLOYMENT_FAILED", "DEPLOYMENT_ABORTED" };
+
+    private readonly ServingClient _client;
+    private readonly Func<TimeSpan, CancellationToken, Task> _wait;
+    private readonly int _maxPolls;
+    private readonly TimeSpan _pollInterval;
+
+    public EndpointDeployer(ServingClient client, Func<TimeSpan, CancellationToken, Task> wait,
+        int maxPolls, TimeSpan pollInterval)
+    {
+        _client = client;
+        _wait = wait;
+        _maxPolls = maxPolls;
+        _pollInterval = pollInterval;
+    }
+
+    public async Task<DeployResult> DeployAsync(EndpointSpec spec, CancellationToken ct)
+    {
+        ct.ThrowIfCancellationRequested();
+        var existing = await _client.GetEndpointAsync(spec.Name, ct);
+        bool created;
+        JsonDocument current;
+        if (existing is null)
+        {
+            current = await _client.CreateAsync(spec, ct);
+            created = true;
+        }
+        else
+        {
+            existing.Dispose();
+            current = await _client.UpdateConfigAsync(spec, ct);
+            created = false;
+        }
+
+        var polls = 0;
+        while (true)
+        {
+            var (ready, configUpdate) = States(current);
+            if (IsTerminal(ready, configUpdate))
+                break;
+            if (polls == _maxPolls)
+            {
+                current.Dispose();
+                throw new PollTimeoutException(ready, configUpdate);
+            }
+            await _wait(_pollInterval, ct);
+            ct.ThrowIfCancellationRequested();
+            current.Dispose();
+            current = await _client.GetEndpointAsync(spec.Name, ct)
+                ?? throw new DbxApiException(404, "RESOURCE_DOES_NOT_EXIST",
+                    $"endpoint {spec.Name} disappeared while polling");
+            polls++;
+        }
+
+        var result = BuildResult(current, created);
+        current.Dispose();
+        return result;
+    }
+
+    private static bool IsTerminal(string ready, string configUpdate) =>
+        (ready == "READY" && configUpdate == "NOT_UPDATING")
+        || configUpdate == "UPDATE_FAILED"
+        || configUpdate == "UPDATE_CANCELED";
+
+    private static (string Ready, string ConfigUpdate) States(JsonDocument doc)
+    {
+        var state = doc.RootElement.GetProperty("state");
+        return (state.GetProperty("ready").GetString() ?? "",
+                state.GetProperty("config_update").GetString() ?? "");
+    }
+
+    private static DeployResult BuildResult(JsonDocument doc, bool created)
+    {
+        var root = doc.RootElement;
+        var (ready, configUpdate) = States(doc);
+        string? endpointUrl = root.TryGetProperty("endpoint_url", out var url) ? url.GetString() : null;
+
+        // The active config carries the live entities; while deploying they
+        // only exist under pending_config.
+        JsonElement source = default;
+        var hasSource = root.TryGetProperty("config", out source)
+            || root.TryGetProperty("pending_config", out source);
+
+        var entities = new List<EntityStatus>();
+        var routes = new List<RouteStatus>();
+        if (hasSource)
+        {
+            if (source.TryGetProperty("served_entities", out var served))
+                foreach (var entity in served.EnumerateArray())
+                    entities.Add(DecodeEntity(entity));
+            if (source.TryGetProperty("traffic_config", out var traffic)
+                && traffic.TryGetProperty("routes", out var routeArray))
+                foreach (var route in routeArray.EnumerateArray())
+                    routes.Add(new RouteStatus(
+                        route.GetProperty("served_model_name").GetString() ?? "",
+                        route.GetProperty("traffic_percentage").GetInt32()));
+        }
+
+        var errors = new Dictionary<string, string>();
+        foreach (var configKey in new[] { "config", "pending_config" })
+        {
+            if (!root.TryGetProperty(configKey, out var cfg)
+                || !cfg.TryGetProperty("served_entities", out var served))
+                continue;
+            foreach (var entity in served.EnumerateArray())
+            {
+                var status = DecodeEntity(entity);
+                if (FailedDeployments.Contains(status.Deployment))
+                    errors[status.Name] = status.Message;
+            }
+        }
+
+        return new DeployResult(created, ready, configUpdate, endpointUrl, entities, routes, errors);
+    }
+
+    private static EntityStatus DecodeEntity(JsonElement entity)
+    {
+        var name = entity.GetProperty("name").GetString() ?? "";
+        var deployment = "";
+        var message = "";
+        if (entity.TryGetProperty("state", out var state))
+        {
+            deployment = state.TryGetProperty("deployment", out var d) ? d.GetString() ?? "" : "";
+            message = state.TryGetProperty("deployment_state_message", out var m) ? m.GetString() ?? "" : "";
+        }
+        return new EntityStatus(name, deployment, message);
+    }
+}
