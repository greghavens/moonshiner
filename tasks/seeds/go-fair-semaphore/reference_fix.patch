+// Package semaphore provides a weighted semaphore with strict FIFO
+// fairness: waiters are served in arrival order and nobody — including
+// TryAcquire — may barge past the head of the queue.
+package semaphore
+
+import (
+	"container/list"
+	"context"
+	"fmt"
+	"sync"
+)
+
+type waiter struct {
+	n     int64
+	ready chan struct{} // closed when the tokens have been granted
+}
+
+// Semaphore is a FIFO-fair counting semaphore. All methods are safe for
+// concurrent use.
+type Semaphore struct {
+	mu       sync.Mutex
+	capacity int64
+	held     int64
+	queue    *list.List // of *waiter, front = oldest
+}
+
+// New builds a semaphore with the given token capacity.
+func New(capacity int64) (*Semaphore, error) {
+	if capacity < 1 {
+		return nil, fmt.Errorf("semaphore: capacity must be at least 1, got %d", capacity)
+	}
+	return &Semaphore{capacity: capacity, queue: list.New()}, nil
+}
+
+// Acquire blocks until n tokens are granted or ctx is done. Requests
+// join a FIFO queue; a request larger than the total capacity fails
+// immediately since it can never be satisfied.
+func (s *Semaphore) Acquire(ctx context.Context, n int64) error {
+	if n < 1 {
+		return fmt.Errorf("semaphore: acquire weight must be at least 1, got %d", n)
+	}
+	if n > s.capacity {
+		return fmt.Errorf("semaphore: acquire weight %d exceeds capacity %d", n, s.capacity)
+	}
+	if err := ctx.Err(); err != nil {
+		return err
+	}
+
+	s.mu.Lock()
+	if s.queue.Len() == 0 && s.capacity-s.held >= n {
+		s.held += n
+		s.mu.Unlock()
+		return nil
+	}
+	w := &waiter{n: n, ready: make(chan struct{})}
+	elem := s.queue.PushBack(w)
+	s.mu.Unlock()
+
+	select {
+	case <-w.ready:
+		return nil
+	case <-ctx.Done():
+		s.mu.Lock()
+		select {
+		case <-w.ready:
+			// Granted and canceled raced; we lost the race. Give the
+			// tokens back and let the queue move on.
+			s.held -= w.n
+			s.notify()
+		default:
+			s.queue.Remove(elem)
+			// Removing a stalled head may unblock the next waiter.
+			s.notify()
+		}
+		s.mu.Unlock()
+		return ctx.Err()
+	}
+}
+
+// TryAcquire takes n tokens without blocking. It fails when not enough
+// tokens are free or when any waiter is queued (no barging).
+func (s *Semaphore) TryAcquire(n int64) bool {
+	if n < 1 || n > s.capacity {
+		return false
+	}
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if s.queue.Len() > 0 || s.capacity-s.held < n {
+		return false
+	}
+	s.held += n
+	return true
+}
+
+// Release returns n tokens and serves queued waiters in FIFO order.
+// Releasing more tokens than are held panics: it means the caller's
+// bookkeeping is broken.
+func (s *Semaphore) Release(n int64) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	s.held -= n
+	if s.held < 0 {
+		panic("semaphore: released more tokens than were held")
+	}
+	s.notify()
+}
+
+// notify grants tokens to consecutive waiters from the front of the
+// queue while they fit. It stops at the first waiter that does not:
+// strict FIFO means nobody behind the head is considered. Callers hold
+// s.mu.
+func (s *Semaphore) notify() {
+	for {
+		front := s.queue.Front()
+		if front == nil {
+			return
+		}
+		w := front.Value.(*waiter)
+		if s.capacity-s.held < w.n {
+			return
+		}
+		s.held += w.n
+		s.queue.Remove(front)
+		close(w.ready)
+	}
+}
+
+// Waiters reports how many goroutines are queued in Acquire.
+func (s *Semaphore) Waiters() int {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	return s.queue.Len()
+}
