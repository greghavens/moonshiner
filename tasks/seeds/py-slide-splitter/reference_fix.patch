+def _extract_notes(lines):
+    """Split a slide's lines into (body_lines, notes).
+
+    The first line that starts with ``Note:`` opens the notes block, which
+    runs to the end of the slide; the prefix is dropped and the block is
+    stripped of surrounding whitespace.  Slides without a marker get ''.
+    """
+    for i, line in enumerate(lines):
+        if line.startswith(NOTE_PREFIX):
+            block = [line[len(NOTE_PREFIX):]] + lines[i + 1:]
+            return lines[:i], "\n".join(block).strip()
+    return lines, ""
+
