+def _extract_fragments(lines):
+    """Strip fragment markers from body lines and number them per slide.
+
+    Returns (cleaned_lines, fragments) where fragments is a list of
+    (n, text) tuples numbered from 1; text is the cleaned line without its
+    surrounding indentation.
+    """
+    cleaned, fragments = [], []
+    for line in lines:
+        bare = line.rstrip()
+        if bare.endswith(FRAGMENT_MARK):
+            bare = bare[:-len(FRAGMENT_MARK)].rstrip()
+            fragments.append((len(fragments) + 1, bare.strip()))
+            cleaned.append(bare)
+        else:
+            cleaned.append(line)
+    return cleaned, fragments
