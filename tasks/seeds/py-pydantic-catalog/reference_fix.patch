+"""Validation models for the product-feed import boundary."""
+import re
+from datetime import datetime
+
+from pydantic import (
+    BaseModel,
+    ConfigDict,
+    Field,
+    ValidationError,
+    field_validator,
+    model_validator,
+)
+
+_SLUG_RE = re.compile(r"^[a-z0-9-]+$")
+
+
+class Variant(BaseModel):
+    """One sellable variant of a product."""
+
+    model_config = ConfigDict(extra="forbid")
+
+    sku: str = Field(pattern=r"^[A-Z]{2,4}-\d{3,}$")
+    price_cents: int = Field(gt=0)
+    label: str
+
+
+class Product(BaseModel):
+    """A catalog product as the feeds are allowed to describe it."""
+
+    model_config = ConfigDict(extra="forbid")
+
+    slug: str
+    name: str
+    tags: list[str] = Field(default_factory=list)
+    variants: list[Variant] = Field(min_length=1)
+    created_at: datetime
+
+    @field_validator("slug")
+    @classmethod
+    def _slug_shape(cls, value: str) -> str:
+        if not _SLUG_RE.fullmatch(value):
+            raise ValueError(
+                "slug must contain only lowercase letters, digits and hyphens")
+        return value
+
+    @field_validator("name")
+    @classmethod
+    def _name_not_blank(cls, value: str) -> str:
+        value = value.strip()
+        if not value:
+            raise ValueError("name must not be blank")
+        return value
+
+    @field_validator("tags")
+    @classmethod
+    def _normalize_tags(cls, value: list[str]) -> list[str]:
+        return sorted({tag.strip().lower() for tag in value})
+
+    @model_validator(mode="after")
+    def _unique_variant_skus(self) -> "Product":
+        seen: set[str] = set()
+        for variant in self.variants:
+            if variant.sku in seen:
+                raise ValueError(f"duplicate variant sku: {variant.sku}")
+            seen.add(variant.sku)
+        return self
+
+
+class Catalog(BaseModel):
+    """A full feed: a list of products with unique slugs."""
+
+    model_config = ConfigDict(extra="forbid")
+
+    products: list[Product] = Field(default_factory=list)
+
+    @model_validator(mode="after")
+    def _unique_slugs(self) -> "Catalog":
+        seen: set[str] = set()
+        for product in self.products:
+            if product.slug in seen:
+                raise ValueError(f"duplicate product slug: {product.slug}")
+            seen.add(product.slug)
+        return self
+
+
+def summarize_errors(err: ValidationError) -> list[str]:
+    """Flatten a ValidationError into sorted '<dotted.path>: <message>' lines."""
+    lines = []
+    for error in err.errors():
+        path = ".".join(str(part) for part in error["loc"])
+        lines.append(f"{path}: {error['msg']}")
+    return sorted(lines)
