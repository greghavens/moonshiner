+"""Okta API transport for the HR-driven user/group sync.
+
+OAuth-for-Okta service-app auth (private_key_jwt with a delegated signer),
+rate-limit-aware requests, Link-header pagination, and a halt-don't-guess
+user sync on top.
+"""
diff --git a/oktasync/auth.py b/oktasync/auth.py
new file mode 100644
index 0000000..d4c9046
--- /dev/null
+++ b/oktasync/auth.py
@@ -0,0 +1,76 @@
+"""OAuth 2.0 for Okta: client-credentials tokens for a service app.
+
+Per the official guide, service apps hitting okta.* scopes must authenticate
+with private_key_jwt: a form-encoded POST to /oauth2/v1/token carrying a
+signed assertion instead of an Authorization header. The private key lives
+in a KMS, so signing is delegated to an injected callable that maps the JWT
+signing input to raw signature bytes.
+"""
+
+import base64
+import json
+import urllib.parse
+import urllib.request
+
+ASSERTION_TYPE = "urn:ietf:params:oauth:client-assertion-type:jwt-bearer"
+ASSERTION_LIFETIME = 300  # seconds; the docs cap assertion exp at one hour
+REFRESH_SKEW = 60  # refresh this many seconds before the token expires
+
+
+def _b64url(raw):
+    return base64.urlsafe_b64encode(raw).rstrip(b"=").decode("ascii")
+
+
+class ClientCredentialsTokenSource:
+    def __init__(self, org_url, client_id, scopes, signer, clock):
+        self._token_url = org_url.rstrip("/") + "/oauth2/v1/token"
+        self._client_id = client_id
+        self._scopes = list(scopes)
+        self._signer = signer
+        self._clock = clock
+        self._access_token = None
+        self._refresh_at = 0.0
+
+    def _assertion(self):
+        header = {"alg": "RS256", "typ": "JWT"}
+        claims = {
+            "iss": self._client_id,
+            "sub": self._client_id,
+            "aud": self._token_url,
+            "exp": int(self._clock.now()) + ASSERTION_LIFETIME,
+        }
+        head = _b64url(json.dumps(header, separators=(",", ":")).encode("utf-8"))
+        body = _b64url(json.dumps(claims, separators=(",", ":")).encode("utf-8"))
+        signing_input = (head + "." + body).encode("ascii")
+        return head + "." + body + "." + _b64url(self._signer(signing_input))
+
+    def token(self):
+        if self._access_token is not None and self._clock.now() < self._refresh_at:
+            return self._access_token
+
+        form = urllib.parse.urlencode({
+            "grant_type": "client_credentials",
+            "scope": " ".join(self._scopes),
+            "client_assertion_type": ASSERTION_TYPE,
+            "client_assertion": self._assertion(),
+        }).encode("ascii")
+        request = urllib.request.Request(
+            self._token_url,
+            data=form,
+            method="POST",
+            headers={
+                "Content-Type": "application/x-www-form-urlencoded",
+                "Accept": "application/json",
+            },
+        )
+        issued_at = self._clock.now()
+        with urllib.request.urlopen(request) as response:
+            payload = json.loads(response.read().decode("utf-8"))
+        self._access_token = payload["access_token"]
+        self._refresh_at = issued_at + float(payload["expires_in"]) - REFRESH_SKEW
+        return self._access_token
+
+    def invalidate(self):
+        """Drops the cached token (e.g. after a 401 E0000011)."""
+        self._access_token = None
+        self._refresh_at = 0.0
