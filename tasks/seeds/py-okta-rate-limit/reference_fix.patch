@@ -0,0 +1,33 @@
+"""User sync on top of the Okta transport.
+
+Lists the org's users (full pagination), matches desired profiles by
+profile.login, and creates only what's missing — as STAGED users, so nobody
+gets an activation email at 2am (create defaults to activate=true otherwise).
+A rate-limited create halts the run with resume info instead of retrying:
+creates aren't idempotent, and the operator resumes after the window.
+"""
+
+from .transport import RateLimitError
+
+LIST_USERS = "/api/v1/users?limit=200"
+CREATE_STAGED = "/api/v1/users?activate=false"
+
+
+def sync_users(transport, desired_profiles):
+    existing_logins = {
+        user["profile"]["login"] for user in transport.paginate(LIST_USERS)
+    }
+
+    report = {"created": [], "existing": [], "halted": None}
+    for profile in desired_profiles:
+        login = profile["login"]
+        if login in existing_logins:
+            report["existing"].append(login)
+            continue
+        try:
+            transport.create(CREATE_STAGED, {"profile": profile})
+        except RateLimitError as err:
+            report["halted"] = {"login": login, "reset_epoch": err.reset_epoch}
+            break
+        report["created"].append(login)
+    return report
diff --git a/oktasync/transport.py b/oktasync/transport.py
