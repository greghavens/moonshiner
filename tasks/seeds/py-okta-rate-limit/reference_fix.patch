index 0000000..4b2096b
--- /dev/null
+++ b/oktasync/transport.py
@@ -0,0 +1,140 @@
+"""Rate-limit-aware HTTP transport for the Okta management API.
+
+Okta stamps X-Rate-Limit-Limit / -Remaining / -Reset (UTC epoch seconds) on
+every response. On 429 the correct move for an idempotent GET is to wait
+until the advertised reset — computed against the response's own Date header
+so client clock skew can't hurt — and retry the identical URL. A 429 on a
+create is surfaced immediately: user creation is not idempotent and retrying
+blind is how duplicate accounts happen.
+"""
+
+import json
+import urllib.error
+import urllib.request
+from dataclasses import dataclass
+from email.utils import parsedate_to_datetime
+
+INVALID_TOKEN_CODE = "E0000011"
+MAX_RATE_RETRIES = 2
+
+
+@dataclass(frozen=True)
+class RateLimitInfo:
+    limit: int
+    remaining: int
+    reset_epoch: int
+
+
+class RateLimitError(Exception):
+    def __init__(self, message, reset_epoch):
+        super().__init__(message)
+        self.reset_epoch = reset_epoch
+
+
+class OktaAuthError(Exception):
+    pass
+
+
+def _next_link(link_header):
+    if not link_header:
+        return None
+    for segment in link_header.split(","):
+        open_ = segment.find("<")
+        close = segment.find(">")
+        if open_ < 0 or close < open_:
+            continue
+        if 'rel="next"' in segment[close + 1:].lower():
+            return segment[open_ + 1:close]
+    return None
+
+
+class OktaTransport:
+    def __init__(self, org_url, token_source, clock, wait):
+        self._base = org_url.rstrip("/")
+        self._source = token_source
+        self._clock = clock
+        self._wait = wait
+        self.rate_limit = None
+
+    def get_json(self, path_or_url):
+        data, _ = self._request("GET", path_or_url, retry_rate_limited=True)
+        return data
+
+    def create(self, path, body):
+        data, _ = self._request("POST", path, body=body, retry_rate_limited=False)
+        return data
+
+    def paginate(self, path):
+        """Yields items across every page, following Link rel="next" URLs
+        verbatim — the server owns the cursor and query format."""
+        url = path
+        while url is not None:
+            data, headers = self._request("GET", url, retry_rate_limited=True)
+            yield from data
+            url = _next_link(headers.get("Link"))
+
+    # ------------------------------------------------------------ internals
+
+    def _request(self, method, path_or_url, body=None, retry_rate_limited=False):
+        url = path_or_url if path_or_url.startswith("http") else self._base + path_or_url
+        auth_retried = False
+        rate_retries = 0
+        while True:
+            status, headers, payload = self._send(method, url, body)
+            self._record_rate_limit(headers)
+
+            if status == 401 and payload.get("errorCode") == INVALID_TOKEN_CODE:
+                if auth_retried:
+                    raise OktaAuthError(
+                        "Okta rejected the access token twice ({}): {}".format(
+                            payload.get("errorCode"), payload.get("errorSummary")))
+                self._source.invalidate()
+                auth_retried = True
+                continue
+
+            if status == 429:
+                reset = int(headers.get("X-Rate-Limit-Reset", "0"))
+                message = "Okta rate limit exceeded ({}): {} — window resets at epoch {}".format(
+                    payload.get("errorCode"), payload.get("errorSummary"), reset)
+                if not retry_rate_limited or rate_retries >= MAX_RATE_RETRIES:
+                    raise RateLimitError(message, reset)
+                rate_retries += 1
+                self._wait(self._delay_until_reset(headers, reset))
+                continue
+
+            return payload, headers
+
+    def _send(self, method, url, body):
+        data = None
+        headers = {"Accept": "application/json"}
+        if body is not None:
+            data = json.dumps(body).encode("utf-8")
+            headers["Content-Type"] = "application/json"
+        headers["Authorization"] = "Bearer " + self._source.token()
+        request = urllib.request.Request(url, data=data, method=method, headers=headers)
+        try:
+            with urllib.request.urlopen(request) as response:
+                return response.status, response.headers, self._decode(response.read())
+        except urllib.error.HTTPError as err:
+            return err.code, err.headers, self._decode(err.read())
+
+    @staticmethod
+    def _decode(raw):
+        if not raw:
+            return {}
+        return json.loads(raw.decode("utf-8"))
+
+    def _record_rate_limit(self, headers):
+        limit = headers.get("X-Rate-Limit-Limit")
+        remaining = headers.get("X-Rate-Limit-Remaining")
+        reset = headers.get("X-Rate-Limit-Reset")
+        if limit is not None and remaining is not None and reset is not None:
+            self.rate_limit = RateLimitInfo(int(limit), int(remaining), int(reset))
+
+    @staticmethod
+    def _delay_until_reset(headers, reset):
+        """Seconds until the advertised reset, anchored on the server's own
+        Date header (never the local clock)."""
+        date_header = headers.get("Date")
+        server_now = parsedate_to_datetime(date_header).timestamp()
+        return max(int(reset - server_now), 1)
