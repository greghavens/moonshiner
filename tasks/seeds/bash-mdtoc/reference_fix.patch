diff --git a/mdtoc.sh b/mdtoc.sh
new file mode 100644
index 0000000..ffb6ef6
--- /dev/null
+++ b/mdtoc.sh
@@ -0,0 +1,69 @@
+#!/usr/bin/env bash
+# mdtoc.sh — regenerate the table of contents of a markdown file, in place,
+# between the exact marker lines "<!-- toc -->" and "<!-- tocstop -->".
+#
+# usage: mdtoc.sh <file.md>
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo 'usage: mdtoc.sh <file.md>' >&2
+  exit 64
+}
+
+[ "$#" -eq 1 ] || usage
+file=$1
+
+if [ ! -f "$file" ] || [ ! -r "$file" ]; then
+  echo "mdtoc.sh: cannot read: $file" >&2
+  exit 66
+fi
+
+tmp=$file.tmp.$$
+
+if awk '
+  { line[NR] = $0 }
+
+  $0 == "<!-- toc -->" && !t1 { t1 = NR }
+  $0 == "<!-- tocstop -->" && t1 && !t2 && NR > t1 { t2 = NR }
+
+  /^```/ { fence = !fence; next }
+  fence  { next }
+
+  /^#/ {
+    match($0, /^#+/)
+    lvl = RLENGTH
+    if (lvl <= 4 && substr($0, lvl + 1, 1) == " ") {
+      text = substr($0, lvl + 1)
+      gsub(/^ +/, "", text)
+      gsub(/ +$/, "", text)
+      n++
+      hlvl[n] = lvl
+      htext[n] = text
+    }
+  }
+
+  END {
+    if (!t1 || !t2) exit 65
+    for (i = 1; i < t1; i++) print line[i]
+    print line[t1]
+    for (i = 1; i <= n; i++) {
+      slug = tolower(htext[i])          # ASCII lowercase (C locale)
+      gsub(/ /, "-", slug)              # every space becomes a dash
+      gsub(/[^a-z0-9_-]/, "", slug)     # drop everything else, byte-wise
+      k = seen[slug]++
+      if (k > 0) slug = slug "-" k
+      indent = ""
+      for (j = 1; j < hlvl[i]; j++) indent = indent "  "
+      printf "%s- [%s](#%s)\n", indent, htext[i], slug
+    }
+    for (i = t2; i <= NR; i++) print line[i]
+  }
+' "$file" > "$tmp"; then
+  mv "$tmp" "$file"
+else
+  rm -f "$tmp"
+  echo "mdtoc.sh: no toc markers in $file" >&2
+  exit 65
+fi
