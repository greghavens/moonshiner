@@ -0,0 +1,80 @@
+package idxplan
+
+import (
+	"errors"
+	"sort"
+)
+
+// Query is a single-field predicate: either an equality or a half-open
+// range (lo <= value < hi in byte order, nil = unbounded).
+type Query struct {
+	Field string
+	Eq    *string
+	Lo    *string
+	Hi    *string
+}
+
+// Eq builds an equality query.
+func Eq(field, value string) Query {
+	return Query{Field: field, Eq: &value}
+}
+
+// Range builds a range query over lo <= value < hi.
+func Range(field string, lo, hi *string) Query {
+	return Query{Field: field, Lo: lo, Hi: hi}
+}
+
+// Plan is the pinned explain output: exactly what Search will execute.
+type Plan struct {
+	Kind  string  // "hash" | "ordered" | "scan"
+	Index string  // chosen index name, "" for a scan
+	Field string
+	Eq    *string
+	Lo    *string
+	Hi    *string
+}
+
+// Explain picks the access path for q without executing it.
+//
+// Rules: Eq prefers hash over ordered over scan; Range can only use an
+// ordered index, else scan. Among eligible indexes of the winning kind the
+// lexicographically smallest name wins, so plans are stable.
+func (h *Heap) Explain(q Query) (Plan, error) {
+	if q.Field == "" {
+		return Plan{}, errors.New("query has no field")
+	}
+	plan := Plan{Field: q.Field, Eq: q.Eq, Lo: q.Lo, Hi: q.Hi}
+	if q.Eq != nil {
+		if name := h.bestIndex(q.Field, "hash"); name != "" {
+			plan.Kind, plan.Index = "hash", name
+			return plan, nil
+		}
+		if name := h.bestIndex(q.Field, "ordered"); name != "" {
+			plan.Kind, plan.Index = "ordered", name
+			return plan, nil
+		}
+	} else {
+		if name := h.bestIndex(q.Field, "ordered"); name != "" {
+			plan.Kind, plan.Index = "ordered", name
+			return plan, nil
+		}
+	}
+	plan.Kind = "scan"
+	return plan, nil
+}
+
+// bestIndex returns the lexicographically smallest index name of the given
+// kind covering field, or "".
+func (h *Heap) bestIndex(field, kind string) string {
+	var names []string
+	for name, idx := range h.indexes {
+		if idx.fieldName() == field && idx.kind() == kind {
+			names = append(names, name)
+		}
+	}
+	if len(names) == 0 {
+		return ""
+	}
+	sort.Strings(names)
+	return names[0]
+}
