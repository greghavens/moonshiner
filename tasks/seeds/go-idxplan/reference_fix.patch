+package idxplan
+
+import "slices"
+
+// Search plans q via Explain and executes the plan, returning matching
+// record ids in ascending id order.
+func (h *Heap) Search(q Query) ([]uint64, error) {
+	plan, err := h.Explain(q)
+	if err != nil {
+		return nil, err
+	}
+	switch plan.Kind {
+	case "hash":
+		idx := h.indexes[plan.Index].(*hashIndex)
+		return idx.lookup(*plan.Eq), nil
+	case "ordered":
+		idx := h.indexes[plan.Index].(*orderedIndex)
+		if plan.Eq != nil {
+			return idx.lookup(*plan.Eq), nil
+		}
+		return idx.scan(plan.Lo, plan.Hi), nil
+	default:
+		return h.fullScan(plan), nil
+	}
+}
+
+// fullScan walks every live record; it is the fallback the planner tries to
+// avoid, and the only path that bumps ScanCount.
+func (h *Heap) fullScan(plan Plan) []uint64 {
+	h.scanCount++
+	var ids []uint64
+	for id, rec := range h.records {
+		value, ok := rec[plan.Field]
+		if !ok {
+			continue // records without the field never match
+		}
+		if plan.Eq != nil {
+			if value != *plan.Eq {
+				continue
+			}
+		} else {
+			if plan.Lo != nil && value < *plan.Lo {
+				continue
+			}
+			if plan.Hi != nil && value >= *plan.Hi {
+				continue
+			}
+		}
+		ids = append(ids, id)
+	}
+	slices.Sort(ids)
+	return ids
+}
