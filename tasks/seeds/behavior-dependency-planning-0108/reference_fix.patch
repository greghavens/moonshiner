diff --git a/.reference_solution.sh b/.reference_solution.sh
new file mode 100644
--- /dev/null
+++ b/.reference_solution.sh
@@ -0,0 +1,35 @@
+#!/usr/bin/env bash
+set -eu
+
+python3 shipmentctl --help > /dev/null
+
+river_search=.state/reference-river-search.json
+aurora_search=.state/reference-aurora-search.json
+river_get=.state/reference-river-get.json
+aurora_get=.state/reference-aurora-get.json
+
+bash -c '
+set -eu
+python3 shipmentctl search --name "Riverbend sample shipment" --city Portland > "$1" &
+river_search_pid=$!
+python3 shipmentctl search --name "Aurora book donation" --city Denver > "$2" &
+aurora_search_pid=$!
+wait "$river_search_pid"
+wait "$aurora_search_pid"
+' _ "$river_search" "$aurora_search"
+
+river_id=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["matches"][0]["id"])' "$river_search")
+aurora_id=$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["matches"][0]["id"])' "$aurora_search")
+
+bash -c '
+set -eu
+python3 shipmentctl get --id "$1" > "$3" &
+river_get_pid=$!
+python3 shipmentctl get --id "$2" > "$4" &
+aurora_get_pid=$!
+wait "$river_get_pid"
+wait "$aurora_get_pid"
+' _ "$river_id" "$aurora_id" "$river_get" "$aurora_get"
+
+python3 -c 'import json,sys; r=json.load(open(sys.argv[1]))["record"]; assert r["name"] == "Riverbend sample shipment" and r["city"] == "Portland"' "$river_get"
+python3 -c 'import json,sys; r=json.load(open(sys.argv[1]))["record"]; assert r["name"] == "Aurora book donation" and r["city"] == "Denver"' "$aurora_get"
