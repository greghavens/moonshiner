diff --git a/maintlog.sh b/maintlog.sh
new file mode 100644
index 0000000..66d810a
--- /dev/null
+++ b/maintlog.sh
@@ -0,0 +1,154 @@
+#!/usr/bin/env bash
+# maintlog.sh — tiny per-directory host-maintenance log.
+#
+# Entries live in ./.maintlog, one per line, tab-separated:
+#   <seq>\t<host>\t<tag>\t<message>
+# Exit codes: 0 ok, 64 usage error, 65 data error.
+set -u
+
+LOG=.maintlog
+TAB=$'\t'
+
+usage() {
+  cat <<'EOF'
+usage: maintlog.sh <command> [options]
+
+commands:
+  init                                  create an empty log in this directory
+  add -H <host> -m <text> [-t <tag>]    append a maintenance entry
+  report [-H <host>] [-n <count>]       print entries, oldest first
+
+long options: --host=<v>  --message=<v>  --tag=<v>  --limit=<v>  --help
+exit codes:   0 ok, 64 usage error, 65 data error
+EOF
+}
+
+usage_error() { # <message> -> stderr message + usage block, exit 64
+  printf 'maintlog: %s\n' "$1" >&2
+  usage >&2
+  exit 64
+}
+
+data_error() { # <message> -> stderr one-liner, exit 65
+  printf 'maintlog: %s\n' "$1" >&2
+  exit 65
+}
+
+require_log() {
+  [ -f "$LOG" ] || data_error "not initialized (run 'maintlog.sh init' first)"
+}
+
+# Rewrite the supported --long=value spellings to short options so a single
+# getopts loop handles everything. Values must not start with "--" (documented
+# limitation; use the short spelling for those).
+expand_long() { # <args...> -> global ARGS array
+  ARGS=()
+  local a
+  for a in "$@"; do
+    case $a in
+      --help)      ARGS+=(-h) ;;
+      --host=*)    ARGS+=(-H "${a#--host=}") ;;
+      --message=*) ARGS+=(-m "${a#--message=}") ;;
+      --tag=*)     ARGS+=(-t "${a#--tag=}") ;;
+      --limit=*)   ARGS+=(-n "${a#--limit=}") ;;
+      --*)         usage_error "unknown option: $a" ;;
+      *)           ARGS+=("$a") ;;
+    esac
+  done
+}
+
+count_entries() { # -> global SEQ = number of lines already in the log
+  SEQ=0
+  local _line
+  while IFS= read -r _line; do
+    SEQ=$((SEQ + 1))
+  done < "$LOG"
+}
+
+cmd_init() {
+  [ -e "$LOG" ] && data_error "already initialized"
+  : > "$LOG"
+  printf 'initialized %s\n' "$LOG"
+}
+
+cmd_add() {
+  require_log
+  expand_long "$@"
+  set -- "${ARGS[@]}"
+  local host='' msg='' tag='-' opt
+  OPTIND=1
+  while getopts ':H:m:t:h' opt; do
+    case $opt in
+      H) host=$OPTARG ;;
+      m) msg=$OPTARG ;;
+      t) tag=$OPTARG ;;
+      h) usage; exit 0 ;;
+      :) usage_error "option -$OPTARG requires a value" ;;
+      *) usage_error "unknown option: -$OPTARG" ;;
+    esac
+  done
+  shift $((OPTIND - 1))
+  [ $# -gt 0 ] && usage_error "add: unexpected argument: $1"
+  { [ -n "$host" ] && [ -n "$msg" ]; } || usage_error "add: -H and -m are required"
+  case "$host$tag$msg" in
+    *"$TAB"*) data_error "fields may not contain tabs" ;;
+  esac
+  count_entries
+  local seq=$((SEQ + 1))
+  printf '%s\t%s\t%s\t%s\n' "$seq" "$host" "$tag" "$msg" >> "$LOG"
+  printf 'added #%s\n' "$seq"
+}
+
+cmd_report() {
+  require_log
+  expand_long "$@"
+  set -- "${ARGS[@]}"
+  local host='' count='' opt
+  OPTIND=1
+  while getopts ':H:n:h' opt; do
+    case $opt in
+      H) host=$OPTARG ;;
+      n) count=$OPTARG ;;
+      h) usage; exit 0 ;;
+      :) usage_error "option -$OPTARG requires a value" ;;
+      *) usage_error "unknown option: -$OPTARG" ;;
+    esac
+  done
+  shift $((OPTIND - 1))
+  [ $# -gt 0 ] && usage_error "report: unexpected argument: $1"
+  if [ -n "$count" ]; then
+    case $count in
+      *[!0-9]*) usage_error "invalid count: $count" ;;
+    esac
+    [ "$count" -ge 1 ] || usage_error "invalid count: $count"
+  fi
+
+  local -a rows=()
+  local line rest f_host
+  while IFS= read -r line; do
+    rest=${line#*"$TAB"}
+    f_host=${rest%%"$TAB"*}
+    if [ -z "$host" ] || [ "$f_host" = "$host" ]; then
+      rows+=("$line")
+    fi
+  done < "$LOG"
+
+  local n=${#rows[@]} start=0 i
+  if [ -n "$count" ] && [ "$count" -lt "$n" ]; then
+    start=$((n - count))
+  fi
+  for ((i = start; i < n; i++)); do
+    printf '#%s\n' "${rows[i]}"
+  done
+}
+
+[ $# -eq 0 ] && usage_error "missing command"
+cmd=$1
+shift
+case $cmd in
+  -h|--help) usage ;;
+  init)      cmd_init ;;
+  add)       cmd_add "$@" ;;
+  report)    cmd_report "$@" ;;
+  *)         usage_error "unknown command: $cmd" ;;
+esac
