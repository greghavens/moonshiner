+// Optimistic-update store: local mutations apply immediately as pending ops,
+// the confirmed state only changes when the server confirms or rejects them.
+// Purely synchronous — the transport layer drives confirm/reject from outside.
+
+export type Op = { id: string; key: string; value: unknown };
+
+export interface Policy {
+  name: string;
+  resolve(local: unknown, server: unknown, op: Op): unknown;
+}
+
+export type ConflictHandler = (local: unknown, server: unknown, op: Op) => void;
+
+export const serverWins: Policy = {
+  name: 'server-wins',
+  resolve: (_local, server) => server,
+};
+
+export const clientWins: Policy = {
+  name: 'client-wins',
+  resolve: (local) => local,
+};
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (Array.isArray(a) && Array.isArray(b)) {
+    return a.length === b.length && a.every((item, i) => deepEqual(item, b[i]));
+  }
+  if (
+    typeof a === 'object' && typeof b === 'object' &&
+    a !== null && b !== null && !Array.isArray(a) && !Array.isArray(b)
+  ) {
+    const ka = Object.keys(a as Record<string, unknown>);
+    const kb = Object.keys(b as Record<string, unknown>);
+    if (ka.length !== kb.length) return false;
+    return ka.every((k) =>
+      Object.prototype.hasOwnProperty.call(b, k) &&
+      deepEqual((a as Record<string, unknown>)[k], (b as Record<string, unknown>)[k]));
+  }
+  return false;
+}
+
+export class OptimisticStore {
+  private base: Record<string, unknown>;
+  private queue: Op[] = [];
+  private nextId = 1;
+  private policy: Policy;
+  private onConflict?: ConflictHandler;
+
+  constructor(
+    base: Record<string, unknown> = {},
+    opts: { policy?: Policy; onConflict?: ConflictHandler } = {},
+  ) {
+    this.base = { ...base };
+    this.policy = opts.policy ?? serverWins;
+    this.onConflict = opts.onConflict;
+  }
+
+  apply(key: string, value: unknown): string {
+    const tail = this.queue[this.queue.length - 1];
+    if (tail && tail.key === key) {
+      tail.value = value; // coalesce into the tail op
+      return tail.id;
+    }
+    const op: Op = { id: `op-${this.nextId++}`, key, value };
+    this.queue.push(op);
+    return op.id;
+  }
+
+  state(): Record<string, unknown> {
+    const snapshot = { ...this.base };
+    for (const op of this.queue) snapshot[op.key] = op.value;
+    return snapshot;
+  }
+
+  confirmed(): Record<string, unknown> {
+    return { ...this.base };
+  }
+
+  pending(): Op[] {
+    return this.queue.map((op) => ({ ...op }));
+  }
+
+  confirm(opId: string, serverValue: unknown): void {
+    const op = this.takeHead(opId);
+    if (deepEqual(serverValue, op.value)) {
+      this.base[op.key] = op.value;
+      return;
+    }
+    this.onConflict?.(op.value, serverValue, { ...op });
+    this.base[op.key] = this.policy.resolve(op.value, serverValue, { ...op });
+  }
+
+  reject(opId: string, serverValue?: unknown): void {
+    const op = this.takeHead(opId);
+    this.onConflict?.(op.value, serverValue, { ...op });
+    if (serverValue !== undefined) {
+      this.base[op.key] = serverValue;
+    }
+  }
+
+  private takeHead(opId: string): Op {
+    const index = this.queue.findIndex((op) => op.id === opId);
+    if (index === -1) throw new Error(`unknown op "${opId}"`);
+    if (index !== 0) throw new Error(`op "${opId}" is not at the head of the queue`);
+    return this.queue.shift() as Op;
+  }
+}
