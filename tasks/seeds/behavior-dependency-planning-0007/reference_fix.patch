+#!/usr/bin/env python3
+"""Produce the two-branch stockroom audit through the inventory CLI."""
+
+from __future__ import annotations
+
+from concurrent.futures import ThreadPoolExecutor
+import json
+from pathlib import Path
+import subprocess
+from typing import Any
+
+
+INVENTORY = Path(__file__).resolve().parent / "bin" / "inventory"
+QUERIES = (
+    ("Reinforced Packing Tape", "Warehouse C"),
+    ("Recycled Printer Paper", "Warehouse D"),
+)
+
+
+def invoke(*arguments: str) -> dict[str, Any]:
+    completed = subprocess.run(
+        [str(INVENTORY), *arguments],
+        stdin=subprocess.DEVNULL,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+        check=True,
+    )
+    return json.loads(completed.stdout)
+
+
+def search(query: tuple[str, str]) -> dict[str, Any]:
+    name, location = query
+    return invoke("search", "--name", name, "--location", location)
+
+
+def get(stable_id: str) -> dict[str, Any]:
+    return invoke("get", "--id", stable_id)
+
+
+def main() -> None:
+    with ThreadPoolExecutor(max_workers=2) as executor:
+        search_futures = [executor.submit(search, query) for query in QUERIES]
+        search_results = [future.result() for future in search_futures]
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(search_results):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        stable_id = matches[0].get("stable_id")
+        if isinstance(stable_id, str):
+            resolved.append((index, stable_id))
+
+    retrieved: dict[int, dict[str, Any]] = {}
+    with ThreadPoolExecutor(max_workers=max(1, len(resolved))) as executor:
+        get_futures = {
+            index: executor.submit(get, stable_id) for index, stable_id in resolved
+        }
+        for index, future in get_futures.items():
+            result = future.result()
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    records = [retrieved[index] for index in range(len(QUERIES)) if index in retrieved]
+    for record in records:
+        print(
+            f'Name: {record["name"]} | Stable ID: {record["stable_id"]} | '
+            f'Location: {record["location"]} | Date: {record["date"]} | '
+            f'Status: {record["status"]}'
+        )
+
+    if len(records) < 2:
+        print("Status comparison: Unavailable because fewer than two records resolved.")
+    elif records[0]["status"] == records[1]["status"]:
+        print(f'Status comparison: Both records have status "{records[0]["status"]}".')
+    else:
+        print(
+            f'Status comparison: "{records[0]["name"]}" is '
+            f'"{records[0]["status"]}", while "{records[1]["name"]}" is '
+            f'"{records[1]["status"]}".'
+        )
+
+
+if __name__ == "__main__":
+    main()
