+export interface Duration {
+  years: number;
+  months: number;
+  days: number;
+  hours: number;
+  minutes: number;
+  seconds: number;
+}
+
+export type DurationLike = Partial<Duration>;
+
+const FIELDS: (keyof Duration)[] = ['years', 'months', 'days', 'hours', 'minutes', 'seconds'];
+
+function complete(d: DurationLike): Duration {
+  return {
+    years: d.years ?? 0,
+    months: d.months ?? 0,
+    days: d.days ?? 0,
+    hours: d.hours ?? 0,
+    minutes: d.minutes ?? 0,
+    seconds: d.seconds ?? 0,
+  };
+}
+
+const DATE_DESIGNATORS: Record<string, keyof Duration> = {
+  Y: 'years',
+  M: 'months',
+  W: 'days', // weeks, handled specially
+  D: 'days',
+};
+const TIME_DESIGNATORS: Record<string, keyof Duration> = {
+  H: 'hours',
+  M: 'minutes',
+  S: 'seconds',
+};
+const DATE_ORDER = 'YMWD';
+const TIME_ORDER = 'HMS';
+
+export function parseDuration(text: string): Duration {
+  let s = text.trim();
+  let sign = 1;
+  if (s.startsWith('-')) {
+    sign = -1;
+    s = s.slice(1);
+  } else if (s.startsWith('+')) {
+    s = s.slice(1);
+  }
+  if (!s.startsWith('P')) {
+    throw new Error(`invalid duration "${text}": must start with 'P'`);
+  }
+
+  const body = s.slice(1);
+  const result = complete({});
+  let inTime = false;
+  let lastOrder = -1;
+  let componentCount = 0;
+  let sawWeeks = false;
+
+  let i = 0;
+  while (i < body.length) {
+    const ch = body[i];
+    if (ch === 'T') {
+      if (inTime) throw new Error(`invalid duration "${text}": duplicate 'T'`);
+      inTime = true;
+      lastOrder = -1;
+      i++;
+      continue;
+    }
+
+    const numMatch = /^(\d+)(\.\d+)?/.exec(body.slice(i));
+    if (numMatch === null) {
+      throw new Error(`invalid duration "${text}": unexpected character '${ch}'`);
+    }
+    if (numMatch[2] !== undefined) {
+      throw new Error(
+        `invalid duration "${text}": fractional values are not supported, components must be integers`,
+      );
+    }
+    i += numMatch[0].length;
+    const designator = body[i];
+    if (designator === undefined) {
+      throw new Error(`invalid duration "${text}": number ${numMatch[1]} has no designator`);
+    }
+    i++;
+
+    const value = Number(numMatch[1]);
+    if (inTime) {
+      if (TIME_DESIGNATORS[designator] === undefined) {
+        if (DATE_ORDER.includes(designator)) {
+          throw new Error(
+            `invalid duration "${text}": '${designator}' is a date component and cannot appear after 'T'`,
+          );
+        }
+        throw new Error(`invalid duration "${text}": unexpected character '${designator}'`);
+      }
+      const order = TIME_ORDER.indexOf(designator);
+      if (order <= lastOrder) {
+        throw new Error(`invalid duration "${text}": components out of order at '${designator}'`);
+      }
+      lastOrder = order;
+      result[TIME_DESIGNATORS[designator]] = value;
+    } else {
+      if (DATE_DESIGNATORS[designator] === undefined) {
+        if (TIME_ORDER.includes(designator)) {
+          throw new Error(
+            `invalid duration "${text}": '${designator}' is a time component and must appear after 'T'`,
+          );
+        }
+        throw new Error(`invalid duration "${text}": unexpected character '${designator}'`);
+      }
+      const order = DATE_ORDER.indexOf(designator);
+      if (order <= lastOrder) {
+        throw new Error(`invalid duration "${text}": components out of order at '${designator}'`);
+      }
+      lastOrder = order;
+      if (designator === 'W') {
+        sawWeeks = true;
+        result.days += value * 7;
+      } else {
+        result[DATE_DESIGNATORS[designator]] = value;
+      }
+    }
+    componentCount++;
+  }
+
+  if (componentCount === 0) {
+    throw new Error(`invalid duration "${text}": it has no components`);
+  }
+  if (sawWeeks && componentCount > 1) {
+    throw new Error(`invalid duration "${text}": weeks cannot be combined with other components`);
+  }
+
+  if (sign < 0) {
+    for (const f of FIELDS) result[f] = result[f] === 0 ? 0 : -result[f];
+  }
+  return result;
+}
+
+export function formatDuration(input: DurationLike): string {
+  const d = complete(input);
+  let hasPositive = false;
+  let hasNegative = false;
+  for (const f of FIELDS) {
+    if (d[f] > 0) hasPositive = true;
+    if (d[f] < 0) hasNegative = true;
+  }
+  if (hasPositive && hasNegative) {
+    throw new Error('cannot format a mixed-sign duration as ISO-8601');
+  }
+  const sign = hasNegative ? '-' : '';
+
+  const date: string[] = [];
+  if (d.years !== 0) date.push(`${Math.abs(d.years)}Y`);
+  if (d.months !== 0) date.push(`${Math.abs(d.months)}M`);
+  if (d.days !== 0) date.push(`${Math.abs(d.days)}D`);
+  const time: string[] = [];
+  if (d.hours !== 0) time.push(`${Math.abs(d.hours)}H`);
+  if (d.minutes !== 0) time.push(`${Math.abs(d.minutes)}M`);
+  if (d.seconds !== 0) time.push(`${Math.abs(d.seconds)}S`);
+
+  if (date.length === 0 && time.length === 0) return 'PT0S';
+  let out = sign + 'P' + date.join('');
+  if (time.length > 0) out += 'T' + time.join('');
+  return out;
+}
+
+function totalMonths(d: Duration): number {
+  return d.years * 12 + d.months;
+}
+
+function totalSeconds(d: Duration): number {
+  return ((d.days * 24 + d.hours) * 60 + d.minutes) * 60 + d.seconds;
+}
+
+export function normalizeDuration(input: DurationLike): Duration {
+  const d = complete(input);
+  const months = totalMonths(d);
+  const seconds = totalSeconds(d);
+
+  const years = Math.trunc(months / 12);
+  const monthsRem = months % 12;
+
+  const days = Math.trunc(seconds / 86400);
+  let rem = seconds % 86400;
+  const hours = Math.trunc(rem / 3600);
+  rem = rem % 3600;
+  const minutes = Math.trunc(rem / 60);
+  const secondsRem = rem % 60;
+
+  // Avoid -0 sneaking into results.
+  const clean = (n: number) => (n === 0 ? 0 : n);
+  return {
+    years: clean(years),
+    months: clean(monthsRem),
+    days: clean(days),
+    hours: clean(hours),
+    minutes: clean(minutes),
+    seconds: clean(secondsRem),
+  };
+}
+
+export function addDurations(a: DurationLike, b: DurationLike): Duration {
+  const da = complete(a);
+  const db = complete(b);
+  const sum: Duration = complete({});
+  for (const f of FIELDS) sum[f] = da[f] + db[f];
+  return normalizeDuration(sum);
+}
+
+export function subtractDurations(a: DurationLike, b: DurationLike): Duration {
+  const da = complete(a);
+  const db = complete(b);
+  const diff: Duration = complete({});
+  for (const f of FIELDS) diff[f] = da[f] - db[f];
+  return normalizeDuration(diff);
+}
+
+export function compareDurations(a: DurationLike, b: DurationLike): -1 | 0 | 1 | null {
+  const da = complete(a);
+  const db = complete(b);
+  const monthsDelta = totalMonths(da) - totalMonths(db);
+  const secondsDelta = totalSeconds(da) - totalSeconds(db);
+
+  if (monthsDelta === 0 && secondsDelta === 0) return 0;
+  if (monthsDelta >= 0 && secondsDelta >= 0) return 1;
+  if (monthsDelta <= 0 && secondsDelta <= 0) return -1;
+  return null;
+}
