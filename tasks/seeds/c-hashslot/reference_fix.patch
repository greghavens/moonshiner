diff --git a/hs.c b/hs.c
new file mode 100644
index 0000000..e70af71
--- /dev/null
+++ b/hs.c
@@ -0,0 +1,184 @@
+#include "hs.h"
+
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+
+/* A slot is empty (key == NULL), a tombstone (key == TOMB), or live. */
+static char hs_tomb_marker;
+#define TOMB (&hs_tomb_marker)
+
+typedef struct {
+    char *key;
+    void *val;
+} hs_slot;
+
+struct hs_map {
+    hs_slot *slots;
+    size_t cap;  /* power of two */
+    size_t live; /* live entries */
+    size_t used; /* live + tombstones */
+};
+
+static uint32_t fnv1a(const char *s) {
+    uint32_t h = 2166136261u;
+    for (; *s != '\0'; s++) {
+        h ^= (unsigned char)*s;
+        h *= 16777619u;
+    }
+    return h;
+}
+
+hs_map *hs_new(void) {
+    hs_map *m = malloc(sizeof *m);
+    if (m == NULL)
+        return NULL;
+    m->cap = 16;
+    m->live = 0;
+    m->used = 0;
+    m->slots = calloc(m->cap, sizeof *m->slots);
+    if (m->slots == NULL) {
+        free(m);
+        return NULL;
+    }
+    return m;
+}
+
+void hs_free(hs_map *m) {
+    if (m == NULL)
+        return;
+    for (size_t i = 0; i < m->cap; i++) {
+        char *k = m->slots[i].key;
+        if (k != NULL && k != TOMB)
+            free(k);
+    }
+    free(m->slots);
+    free(m);
+}
+
+/* Probe for key. Returns the slot index that ended the probe: either
+ * the live slot holding the key (*found = 1) or the empty slot where
+ * the probe stopped (*found = 0). *first_tomb is the first tombstone
+ * passed, or SIZE_MAX. */
+static size_t probe(const hs_map *m, const char *key, int *found,
+                    size_t *first_tomb) {
+    size_t mask = m->cap - 1;
+    size_t idx = fnv1a(key) & mask;
+    *first_tomb = SIZE_MAX;
+    for (;;) {
+        const hs_slot *e = &m->slots[idx];
+        if (e->key == NULL) {
+            *found = 0;
+            return idx;
+        }
+        if (e->key == TOMB) {
+            if (*first_tomb == SIZE_MAX)
+                *first_tomb = idx;
+        } else if (strcmp(e->key, key) == 0) {
+            *found = 1;
+            return idx;
+        }
+        idx = (idx + 1) & mask;
+    }
+}
+
+/* Double the table; re-insert live entries in old slot order; drop
+ * tombstones. 0 ok, -1 on allocation failure (old table kept). */
+static int rehash(hs_map *m) {
+    size_t ncap = m->cap * 2;
+    hs_slot *nslots = calloc(ncap, sizeof *nslots);
+    if (nslots == NULL)
+        return -1;
+    size_t mask = ncap - 1;
+    for (size_t i = 0; i < m->cap; i++) {
+        char *k = m->slots[i].key;
+        if (k == NULL || k == TOMB)
+            continue;
+        size_t idx = fnv1a(k) & mask;
+        while (nslots[idx].key != NULL)
+            idx = (idx + 1) & mask;
+        nslots[idx] = m->slots[i];
+    }
+    free(m->slots);
+    m->slots = nslots;
+    m->cap = ncap;
+    m->used = m->live;
+    return 0;
+}
+
+static char *copy_key(const char *key) {
+    size_t n = strlen(key) + 1;
+    char *c = malloc(n);
+    if (c != NULL)
+        memcpy(c, key, n);
+    return c;
+}
+
+int hs_put(hs_map *m, const char *key, void *val) {
+    int found;
+    size_t first_tomb;
+    size_t idx = probe(m, key, &found, &first_tomb);
+    if (found) {
+        m->slots[idx].val = val; /* keep the existing key copy */
+        return 0;
+    }
+    if ((m->used + 1) * 10 > m->cap * 7) {
+        if (rehash(m) != 0)
+            return -1;
+        idx = probe(m, key, &found, &first_tomb); /* fresh, no tombstones */
+    }
+    char *k = copy_key(key);
+    if (k == NULL)
+        return -1;
+    if (first_tomb != SIZE_MAX) {
+        m->slots[first_tomb].key = k;
+        m->slots[first_tomb].val = val;
+        /* a tombstone flipped back to live: used is unchanged */
+    } else {
+        m->slots[idx].key = k;
+        m->slots[idx].val = val;
+        m->used++;
+    }
+    m->live++;
+    return 0;
+}
+
+void *hs_get(const hs_map *m, const char *key) {
+    int found;
+    size_t first_tomb;
+    size_t idx = probe(m, key, &found, &first_tomb);
+    return found ? m->slots[idx].val : NULL;
+}
+
+int hs_del(hs_map *m, const char *key) {
+    int found;
+    size_t first_tomb;
+    size_t idx = probe(m, key, &found, &first_tomb);
+    if (!found)
+        return -1;
+    free(m->slots[idx].key);
+    m->slots[idx].key = TOMB;
+    m->slots[idx].val = NULL;
+    m->live--;
+    return 0;
+}
+
+size_t hs_len(const hs_map *m) {
+    return m->live;
+}
+
+size_t hs_cap(const hs_map *m) {
+    return m->cap;
+}
+
+int hs_next(const hs_map *m, size_t *it, const char **key, void **val) {
+    while (*it < m->cap) {
+        const hs_slot *e = &m->slots[(*it)++];
+        if (e->key != NULL && e->key != TOMB) {
+            *key = e->key;
+            *val = e->val;
+            return 1;
+        }
+    }
+    return 0;
+}
diff --git a/hs.h b/hs.h
new file mode 100644
index 0000000..a59accc
--- /dev/null
+++ b/hs.h
@@ -0,0 +1,38 @@
+/* hs.h — open-addressing string-key map with a pinned, reproducible
+ * layout (FNV-1a, linear probing, tombstones, 7/10 load rule). */
+#ifndef HS_H
+#define HS_H
+
+#include <stddef.h>
+
+typedef struct hs_map hs_map;
+
+/* Fresh map with capacity 16. NULL on allocation failure. */
+hs_map *hs_new(void);
+
+/* Free all key copies, the table, and the map itself. */
+void hs_free(hs_map *m);
+
+/* Insert or update. The key is copied (the map owns its copies); the
+ * value pointer is stored as-is and stays caller-owned.
+ * 0 on success, -1 on allocation failure. */
+int hs_put(hs_map *m, const char *key, void *val);
+
+/* Stored value, or NULL if the key is absent. */
+void *hs_get(const hs_map *m, const char *key);
+
+/* Remove a key (leaves a tombstone slot). 0 removed, -1 absent. */
+int hs_del(hs_map *m, const char *key);
+
+size_t hs_len(const hs_map *m); /* live entries */
+size_t hs_cap(const hs_map *m); /* slot count */
+
+/* Cursor iteration in ascending slot order:
+ *     size_t it = 0;
+ *     while (hs_next(m, &it, &key, &val)) ...
+ * Returns 1 with *key and *val set for each live entry, 0 when done.
+ * *key points at the map's own copy: don't free it or hold it across
+ * a mutation. Don't modify the map mid-iteration. */
+int hs_next(const hs_map *m, size_t *it, const char **key, void **val);
+
+#endif /* HS_H */
