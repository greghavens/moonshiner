+"""Quoting linter for YAML string values.
+
+Answers one question for the config formatter: if this string value were
+written unquoted, what would the loader turn it into? All verdicts come
+from PyYAML's own safe loader, so they track the parser we actually ship
+(including its deliberate deviations from the YAML 1.1 spec sheet).
+"""
+import datetime
+
+import yaml
+
+
+def plain_parse(scalar):
+    """Value PyYAML's safe loader produces for the bare scalar text."""
+    return yaml.safe_load(scalar)
+
+
+def classify(scalar):
+    """What the scalar becomes when loaded unquoted; 'str' means safe."""
+    try:
+        value = yaml.safe_load(scalar)
+    except Exception:
+        # Not only YAMLError: a date-shaped scalar with an impossible
+        # month escapes the loader as a plain ValueError.
+        return "invalid"
+    if isinstance(value, bool):
+        return "bool"
+    if isinstance(value, int):
+        return "int"
+    if isinstance(value, float):
+        return "float"
+    if value is None:
+        return "null"
+    if isinstance(value, (datetime.date, datetime.datetime)):
+        return "timestamp"
+    if isinstance(value, str):
+        return "str" if value == scalar else "reparsed"
+    return "other"
+
+
+def needs_quotes(scalar):
+    """True unless the scalar survives unquoted as the identical string."""
+    return classify(scalar) != "str"
+
+
+def audit(mapping):
+    """Findings for every value that must stay quoted, sorted by key."""
+    findings = []
+    for key in sorted(mapping):
+        value = mapping[key]
+        becomes = classify(value)
+        if becomes != "str":
+            findings.append({"key": key, "value": value, "becomes": becomes})
+    return findings
