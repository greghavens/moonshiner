diff --git a/probefeed.ps1 b/probefeed.ps1
index 6b941c9..8788625 100644
--- a/probefeed.ps1
+++ b/probefeed.ps1
@@ -1,6 +1,7 @@
 # probefeed.ps1 -- fold synthetic-probe result drops into the ledger.
 #
 #   pwsh -NoProfile -File probefeed.ps1 -Spool <dir> -Out <ledger.ndjson>
+#                                       [-Checkpoint <state.json>]
 #
 # The probe runners drop one small JSON file per result into the spool:
 #
@@ -19,10 +20,18 @@
 #
 # stdout is one summary line:  processed <p>, skipped <s>, ok=<a>, fail=<b>
 # Exit 0 on any completed run; 66 when the spool directory is missing.
+#
+# With -Checkpoint, the run is incremental: the state file records every
+# spool file already handled (processed OR skipped-as-malformed), those
+# are not touched again, the summary gains ', seen=<n>' for them, and the
+# state file is rewritten afterwards. A missing state file means a first
+# run; an unreadable one is reported ('probefeed: checkpoint unreadable,
+# rebuilding'), treated as empty, and rebuilt from this run.
 
 param(
     [Parameter(Mandatory)][string]$Spool,
-    [Parameter(Mandatory)][string]$Out
+    [Parameter(Mandatory)][string]$Out,
+    [string]$Checkpoint
 )
 
 Set-StrictMode -Version Latest
@@ -54,6 +63,27 @@ if (-not (Test-Path -LiteralPath $Spool -PathType Container)) {
     Fail "spool not found: $Spool" 66
 }
 
+$useCheckpoint = $PSBoundParameters.ContainsKey('Checkpoint')
+$done = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+if ($useCheckpoint -and (Test-Path -LiteralPath $Checkpoint -PathType Leaf)) {
+    $loaded = $false
+    try {
+        $state = ConvertFrom-Json -InputObject ([System.IO.File]::ReadAllText($Checkpoint))
+        if ($null -ne $state -and
+            @($state.PSObject.Properties.Name) -ccontains 'done' -and
+            $state.done -is [array]) {
+            foreach ($n in $state.done) { [void]$done.Add([string]$n) }
+            $loaded = $true
+        }
+    } catch {
+        $loaded = $false
+    }
+    if (-not $loaded) {
+        $done.Clear()
+        [Console]::Error.WriteLine('probefeed: checkpoint unreadable, rebuilding')
+    }
+}
+
 $names = @()
 foreach ($f in @(Get-ChildItem -LiteralPath $Spool -File)) {
     if ($f.Name -clike '*.json') { $names += $f.Name }
@@ -64,8 +94,13 @@ $processed = 0
 $skipped = 0
 $okCount = 0
 $failCount = 0
+$seen = 0
 
 foreach ($name in $names) {
+    if ($useCheckpoint -and $done.Contains($name)) {
+        $seen++
+        continue
+    }
     $raw = [System.IO.File]::ReadAllText((Join-Path $Spool $name))
     $rec = $null
     try {
@@ -76,6 +111,7 @@ foreach ($name in $names) {
     if (-not (Test-ProbeRecord $rec)) {
         [Console]::Error.WriteLine("probefeed: skipped ${name}: malformed")
         $skipped++
+        [void]$done.Add($name)
         continue
     }
     $entry = [ordered]@{
@@ -88,8 +124,17 @@ foreach ($name in $names) {
     $line = ($entry | ConvertTo-Json -Compress) + "`n"
     [System.IO.File]::AppendAllText($Out, $line)
     $processed++
+    [void]$done.Add($name)
     if ($rec.status -ceq 'ok') { $okCount++ } else { $failCount++ }
 }
 
-Write-Output "processed $processed, skipped $skipped, ok=$okCount, fail=$failCount"
+if ($useCheckpoint) {
+    $handled = @($done)
+    [Array]::Sort($handled, [System.StringComparer]::Ordinal)
+    $state = [pscustomobject]@{ done = $handled }
+    [System.IO.File]::WriteAllText($Checkpoint, ($state | ConvertTo-Json) + "`n")
+    Write-Output "processed $processed, skipped $skipped, ok=$okCount, fail=$failCount, seen=$seen"
+} else {
+    Write-Output "processed $processed, skipped $skipped, ok=$okCount, fail=$failCount"
+}
 exit 0
