+/**
+ * Server-Sent-Events consumer at the text line protocol level.
+ * No npm dependencies; node 26 with type stripping (no enums/namespaces).
+ */
+
+export class SseEvent {
+  type: string;
+  data: string;
+  id: string | null;
+
+  constructor(type: string, data: string, id: string | null) {
+    this.type = type;
+    this.data = data;
+    this.id = id;
+  }
+}
+
+type Transport = (lastEventId: string | null) => AsyncGenerator<string>;
+
+export class SseFeed {
+  retryMs: number = 3000;
+  private _transport: Transport;
+
+  constructor(transport: Transport) {
+    this._transport = transport;
+  }
+
+  async *events(): AsyncGenerator<SseEvent> {
+    let lastEventId: string | null = null;
+
+    // Reconnect loop: the outer loop runs once per connection
+    while (true) {
+      // Per-event buffer state
+      let eventType = 'message';
+      let dataLines: string[] = [];
+      let currentId: string | null = lastEventId;
+
+      // Line buffer: accumulates text until we have a complete line
+      let lineBuf = '';
+
+      const gen = this._transport(lastEventId);
+
+      for await (const chunk of gen) {
+        lineBuf += chunk;
+
+        // Extract complete lines (delimited by \n)
+        let nlPos: number;
+        while ((nlPos = lineBuf.indexOf('\n')) !== -1) {
+          const line = lineBuf.slice(0, nlPos);
+          lineBuf = lineBuf.slice(nlPos + 1);
+
+          // Empty line: dispatch event if data buffer is non-empty
+          if (line === '') {
+            if (dataLines.length > 0) {
+              const ev = new SseEvent(eventType, dataLines.join('\n'), currentId);
+              lastEventId = currentId;
+              // Reset buffer
+              eventType = 'message';
+              dataLines = [];
+              yield ev;
+            } else {
+              // No data — reset event fields but keep id
+              eventType = 'message';
+            }
+            continue;
+          }
+
+          // Comment line
+          if (line.startsWith(':')) continue;
+
+          // Parse field: everything before the first colon is the field name
+          const colonIdx = line.indexOf(':');
+          let fieldName: string;
+          let value: string;
+          if (colonIdx === -1) {
+            fieldName = line;
+            value = '';
+          } else {
+            fieldName = line.slice(0, colonIdx);
+            value = line.slice(colonIdx + 1);
+            // Strip exactly one leading space
+            if (value.startsWith(' ')) value = value.slice(1);
+          }
+
+          switch (fieldName) {
+            case 'event':
+              eventType = value;
+              break;
+            case 'data':
+              dataLines.push(value);
+              break;
+            case 'id':
+              currentId = value;
+              break;
+            case 'retry': {
+              const ms = parseInt(value, 10);
+              if (!isNaN(ms)) this.retryMs = ms;
+              break;
+            }
+            default:
+              // Unknown field: ignore
+          }
+        }
+      }
+
+      // Transport closed — reconnect on next loop iteration
+      // (no sleep; caller can handle scheduling)
+    }
+  }
+}
