+namespace ReplicaRead;
+
+public sealed record ReplicaAnswer(string Replica, string Value);
+
+public sealed class FanoutReader
+{
+    private readonly IReadOnlyList<IReplica> _replicas;
+
+    public FanoutReader(IReadOnlyList<IReplica> replicas)
+    {
+        if (replicas is null || replicas.Count == 0)
+            throw new ArgumentException("at least one replica is required", nameof(replicas));
+        _replicas = replicas;
+    }
+
+    public async Task<IReadOnlyList<string>> ReadAllAsync(string key, CancellationToken ct = default)
+    {
+        var tasks = new Task<string>[_replicas.Count];
+        for (var i = 0; i < _replicas.Count; i++)
+            tasks[i] = _replicas[i].ReadAsync(key, ct);
+        return await Task.WhenAll(tasks).ConfigureAwait(false);
+    }
+
+    public async Task<ReplicaAnswer> ReadFastestAsync(string key, CancellationToken ct = default)
+    {
+        using var linked = CancellationTokenSource.CreateLinkedTokenSource(ct);
+        var pending = new Dictionary<Task<string>, IReplica>(_replicas.Count);
+        foreach (var replica in _replicas)
+            pending[replica.ReadAsync(key, linked.Token)] = replica;
+
+        while (pending.Count > 0)
+        {
+            var done = await Task.WhenAny(pending.Keys).ConfigureAwait(false);
+            var replica = pending[done];
+            pending.Remove(done);
+
+            if (done.IsCompletedSuccessfully)
+            {
+                // stragglers must observe cancellation before the caller
+                // observes the answer
+                linked.Cancel();
+                return new ReplicaAnswer(replica.Name, done.Result);
+            }
+
+            // canceled replicas mean the caller gave up — surface that;
+            // faulted replicas are simply not answers, keep waiting
+            if (done.IsCanceled)
+                ct.ThrowIfCancellationRequested();
+        }
+
+        throw new InvalidOperationException(
+            $"all {_replicas.Count} replicas failed for key '{key}'");
+    }
+}
