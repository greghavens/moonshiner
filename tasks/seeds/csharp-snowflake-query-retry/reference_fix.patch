+namespace SnowflakeSql;
+
+/// <summary>
+/// The retry or poll budget ran out without a terminal answer. Carries the
+/// attempt count and the last HTTP status observed; never any credentials.
+/// </summary>
+public sealed class SnowflakeTransportException : Exception
+{
+    public int Attempts { get; }
+    public int LastStatusCode { get; }
+
+    public SnowflakeTransportException(string message, int attempts, int lastStatusCode)
+        : base($"{message} (attempts {attempts}, last HTTP status {lastStatusCode})")
+    {
+        Attempts = attempts;
+        LastStatusCode = lastStatusCode;
+    }
+}
