+namespace SnowflakeSql;
+
+/// <summary>
+/// Retry/polling policy for <see cref="SnowflakeStatementExecutor"/>.
+/// Defaults mirror docs/contract.json.
+/// </summary>
+public sealed record RetryOptions
+{
+    /// <summary>Total submit attempts, the first one included.</summary>
+    public int MaxAttempts { get; init; } = 4;
+
+    /// <summary>Fallback backoff when no Retry-After header is present.</summary>
+    public IReadOnlyList<int> BackoffSeconds { get; init; } = new[] { 1, 2, 4 };
+
+    public int PollIntervalSeconds { get; init; } = 1;
+
+    public int MaxPolls { get; init; } = 10;
+}
