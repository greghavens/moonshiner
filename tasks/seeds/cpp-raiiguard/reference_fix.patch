+#include "guard.hpp"
+
+#include <utility>
+
+/* --- FileGuard ------------------------------------------------------- */
+
+FileGuard::FileGuard() noexcept = default;
+
+FileGuard::FileGuard(ActionLog &log, std::string path)
+    : log_(&log), path_(std::move(path)) {
+    log_->push_back("open " + path_);
+}
+
+FileGuard::~FileGuard() {
+    release();
+}
+
+FileGuard::FileGuard(FileGuard &&other) noexcept
+    : log_(other.log_), path_(std::move(other.path_)) {
+    other.log_ = nullptr;
+    other.path_.clear();
+}
+
+FileGuard &FileGuard::operator=(FileGuard &&other) noexcept {
+    if (this == &other)
+        return *this;
+    release();
+    log_ = other.log_;
+    path_ = std::move(other.path_);
+    other.log_ = nullptr;
+    other.path_.clear();
+    return *this;
+}
+
+bool FileGuard::active() const noexcept {
+    return log_ != nullptr;
+}
+
+const std::string &FileGuard::path() const noexcept {
+    return path_;
+}
+
+void FileGuard::release() {
+    if (log_ == nullptr)
+        return;
+    log_->push_back("close " + path_);
+    log_ = nullptr;
+    path_.clear();
+}
+
+/* --- LockGuard ------------------------------------------------------- */
+
+LockGuard::LockGuard() noexcept = default;
+
+LockGuard::LockGuard(ActionLog &log, std::string name)
+    : log_(&log), name_(std::move(name)) {
+    log_->push_back("lock " + name_);
+}
+
+LockGuard::~LockGuard() {
+    release();
+}
+
+LockGuard::LockGuard(LockGuard &&other) noexcept
+    : log_(other.log_), name_(std::move(other.name_)) {
+    other.log_ = nullptr;
+    other.name_.clear();
+}
+
+LockGuard &LockGuard::operator=(LockGuard &&other) noexcept {
+    if (this == &other)
+        return *this;
+    release();
+    log_ = other.log_;
+    name_ = std::move(other.name_);
+    other.log_ = nullptr;
+    other.name_.clear();
+    return *this;
+}
+
+bool LockGuard::active() const noexcept {
+    return log_ != nullptr;
+}
+
+const std::string &LockGuard::name() const noexcept {
+    return name_;
+}
+
+void LockGuard::release() {
+    if (log_ == nullptr)
+        return;
+    log_->push_back("unlock " + name_);
+    log_ = nullptr;
+    name_.clear();
+}
+
+/* --- StationSession -------------------------------------------------- */
+
+StationSession::StationSession(ActionLog &log, const std::string &station,
+                               const std::string &file)
+    : lock_(log, station), file_(log, file) {}
+
+bool StationSession::active() const noexcept {
+    return lock_.active();
+}
+
+const std::string &StationSession::station() const noexcept {
+    return lock_.name();
+}
+
+const std::string &StationSession::file() const noexcept {
+    return file_.path();
+}
+
+void StationSession::release() {
+    file_.release();
+    lock_.release();
+}
