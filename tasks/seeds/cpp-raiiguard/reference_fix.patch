--- /dev/null
+++ b/guard.hpp
@@ -0,0 +1,70 @@
+#pragma once
+
+#include <string>
+#include <vector>
+
+using ActionLog = std::vector<std::string>;
+
+/* RAII wrappers over the bench action journal: acquiring a resource appends
+ * one journal line, releasing it appends the matching line, and ownership
+ * moves without ever journaling twice. */
+
+class FileGuard {
+public:
+    FileGuard() noexcept;
+    FileGuard(ActionLog &log, std::string path);
+    ~FileGuard();
+    FileGuard(FileGuard &&other) noexcept;
+    FileGuard &operator=(FileGuard &&other) noexcept;
+    FileGuard(const FileGuard &) = delete;
+    FileGuard &operator=(const FileGuard &) = delete;
+
+    bool active() const noexcept;
+    const std::string &path() const noexcept;
+    void release();
+
+private:
+    ActionLog *log_ = nullptr;
+    std::string path_;
+};
+
+class LockGuard {
+public:
+    LockGuard() noexcept;
+    LockGuard(ActionLog &log, std::string name);
+    ~LockGuard();
+    LockGuard(LockGuard &&other) noexcept;
+    LockGuard &operator=(LockGuard &&other) noexcept;
+    LockGuard(const LockGuard &) = delete;
+    LockGuard &operator=(const LockGuard &) = delete;
+
+    bool active() const noexcept;
+    const std::string &name() const noexcept;
+    void release();
+
+private:
+    ActionLog *log_ = nullptr;
+    std::string name_;
+};
+
+class StationSession {
+public:
+    StationSession(ActionLog &log, const std::string &station,
+                   const std::string &file);
+    StationSession(StationSession &&) noexcept = default;
+    StationSession &operator=(StationSession &&) noexcept = default;
+    StationSession(const StationSession &) = delete;
+    StationSession &operator=(const StationSession &) = delete;
+    ~StationSession() = default;
+
+    bool active() const noexcept;
+    const std::string &station() const noexcept;
+    const std::string &file() const noexcept;
+    void release();
+
+private:
+    /* The lock is declared first so member destruction (reverse order)
+     * closes the file before the station lock lets go. */
+    LockGuard lock_;
+    FileGuard file_;
+};
