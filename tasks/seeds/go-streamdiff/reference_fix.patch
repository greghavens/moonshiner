+// Package reconcile diffs two key-sorted sequences in a single merge
+// walk, emitting added/removed/changed events in batches. It is designed
+// for reconciling huge exports (catalog dumps, index snapshots) without
+// materializing either side into a map.
+package reconcile
+
+import (
+	"errors"
+	"fmt"
+)
+
+// Sentinel errors for broken input sequences.
+var (
+	ErrUnsorted     = errors.New("reconcile: sequence is not sorted ascending")
+	ErrDuplicateKey = errors.New("reconcile: duplicate key in sequence")
+)
+
+// Pair is one key/value element of an input sequence.
+type Pair struct {
+	Key, Value string
+}
+
+// Op classifies a Change.
+type Op int
+
+// The three kinds of difference between the sequences.
+const (
+	OpAdded Op = iota
+	OpRemoved
+	OpChanged
+)
+
+// Change describes one difference. Old is empty for OpAdded; New is
+// empty for OpRemoved.
+type Change struct {
+	Op       Op
+	Key      string
+	Old, New string
+}
+
+// cursor walks one sequence, validating strict ascending key order as
+// elements are consumed.
+type cursor struct {
+	name  string
+	seq   []Pair
+	i     int
+	prev  string
+	moved bool
+}
+
+func (c *cursor) done() bool { return c.i >= len(c.seq) }
+
+func (c *cursor) head() (Pair, error) {
+	p := c.seq[c.i]
+	if c.moved {
+		if p.Key == c.prev {
+			return Pair{}, fmt.Errorf("%w: %q in %s", ErrDuplicateKey, p.Key, c.name)
+		}
+		if p.Key < c.prev {
+			return Pair{}, fmt.Errorf("%w: %q after %q in %s", ErrUnsorted, p.Key, c.prev, c.name)
+		}
+	}
+	return p, nil
+}
+
+func (c *cursor) advance() {
+	c.prev = c.seq[c.i].Key
+	c.moved = true
+	c.i++
+}
+
+// batcher accumulates changes and flushes complete batches.
+type batcher struct {
+	size    int
+	pending []Change
+	flush   func([]Change) error
+}
+
+func (b *batcher) add(ch Change) error {
+	b.pending = append(b.pending, ch)
+	if len(b.pending) < b.size {
+		return nil
+	}
+	return b.emit()
+}
+
+// emit hands the pending changes to flush as a fresh slice; the callee
+// may retain it.
+func (b *batcher) emit() error {
+	if len(b.pending) == 0 {
+		return nil
+	}
+	batch := b.pending
+	b.pending = nil
+	return b.flush(batch)
+}
+
+// Reconcile walks before and after (each strictly ascending by Key) in a
+// single pass and delivers differences to flush in batches of batchSize,
+// with a smaller final batch for the remainder. Validation is performed
+// as the walk progresses: batches completed before a sequence error are
+// already flushed when the error is returned.
+func Reconcile(before, after []Pair, batchSize int, flush func([]Change) error) error {
+	if batchSize < 1 {
+		return fmt.Errorf("reconcile: batch size must be >= 1, got %d", batchSize)
+	}
+	b := &cursor{name: "before", seq: before}
+	a := &cursor{name: "after", seq: after}
+	out := &batcher{size: batchSize, flush: flush}
+
+	for !b.done() || !a.done() {
+		switch {
+		case b.done():
+			p, err := a.head()
+			if err != nil {
+				return err
+			}
+			if err := out.add(Change{Op: OpAdded, Key: p.Key, New: p.Value}); err != nil {
+				return err
+			}
+			a.advance()
+		case a.done():
+			p, err := b.head()
+			if err != nil {
+				return err
+			}
+			if err := out.add(Change{Op: OpRemoved, Key: p.Key, Old: p.Value}); err != nil {
+				return err
+			}
+			b.advance()
+		default:
+			pb, err := b.head()
+			if err != nil {
+				return err
+			}
+			pa, err := a.head()
+			if err != nil {
+				return err
+			}
+			switch {
+			case pb.Key < pa.Key:
+				if err := out.add(Change{Op: OpRemoved, Key: pb.Key, Old: pb.Value}); err != nil {
+					return err
+				}
+				b.advance()
+			case pb.Key > pa.Key:
+				if err := out.add(Change{Op: OpAdded, Key: pa.Key, New: pa.Value}); err != nil {
+					return err
+				}
+				a.advance()
+			default:
+				if pb.Value != pa.Value {
+					if err := out.add(Change{Op: OpChanged, Key: pb.Key, Old: pb.Value, New: pa.Value}); err != nil {
+						return err
+					}
+				}
+				b.advance()
+				a.advance()
+			}
+		}
+	}
+	return out.emit()
+}
