+# pipetally.ps1 — streaming dedupe and tally for object feeds.
+# Dot-source this file to get Select-UniqueRecord.
+
+function Select-UniqueRecord {
+    [CmdletBinding()]
+    param(
+        [Parameter(ValueFromPipeline)]
+        [object[]]$InputObject,
+
+        [string]$Key = 'Id',
+
+        [switch]$Summary
+    )
+
+    begin {
+        $order = [System.Collections.Generic.List[string]]::new()
+        $counts = [System.Collections.Generic.Dictionary[string, int]]::new()
+    }
+    process {
+        foreach ($record in $InputObject) {
+            if ($null -eq $record) { continue }
+            $prop = $record.PSObject.Properties[$Key]
+            if ($null -eq $prop) {
+                throw "pipetally: record is missing key property '$Key'"
+            }
+            $k = [string]$prop.Value
+            if ($counts.ContainsKey($k)) {
+                $counts[$k] = $counts[$k] + 1
+                continue
+            }
+            $counts[$k] = 1
+            $order.Add($k)
+            if (-not $Summary) { $record }
+        }
+    }
+    end {
+        if ($Summary) {
+            foreach ($k in $order) {
+                [pscustomobject][ordered]@{ Key = $k; Count = $counts[$k] }
+            }
+        }
+    }
+}
