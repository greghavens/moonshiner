+//! rs-rcweaktree: the outline editor's section tree.
+//!
+//! Ownership law: children are held strongly (`Rc`), parents weakly
+//! (`Weak`) — so a tree is freed the moment its root's last strong handle
+//! drops, and no structural operation can create a reference cycle.
+
+use std::cell::RefCell;
+use std::rc::{Rc, Weak};
+
+#[derive(Debug, PartialEq, Eq)]
+pub enum TreeError {
+    /// The child already has a live parent.
+    AlreadyAttached,
+    /// The operation would make a node its own ancestor.
+    WouldCycle,
+}
+
+pub struct Node {
+    label: String,
+    parent: RefCell<Weak<Node>>,
+    children: RefCell<Vec<Rc<Node>>>,
+}
+
+impl Node {
+    pub fn new(label: &str) -> Rc<Node> {
+        Rc::new(Node {
+            label: label.to_string(),
+            parent: RefCell::new(Weak::new()),
+            children: RefCell::new(Vec::new()),
+        })
+    }
+
+    pub fn label(&self) -> &str {
+        &self.label
+    }
+
+    /// The parent, if it is still alive. A dropped parent reads as no parent.
+    pub fn parent(&self) -> Option<Rc<Node>> {
+        self.parent.borrow().upgrade()
+    }
+
+    /// Snapshot of the child list, insertion order.
+    pub fn children(&self) -> Vec<Rc<Node>> {
+        self.children.borrow().clone()
+    }
+
+    /// Labels from self up to and including the root, following live
+    /// weak links only.
+    pub fn path_to_root(&self) -> Vec<String> {
+        let mut out = vec![self.label.clone()];
+        let mut cur = self.parent();
+        while let Some(node) = cur {
+            out.push(node.label.clone());
+            cur = node.parent();
+        }
+        out
+    }
+
+    /// True if `candidate` is `node` itself or one of `node`'s ancestors.
+    fn in_ancestor_chain(node: &Rc<Node>, candidate: &Rc<Node>) -> bool {
+        let mut cur = Some(Rc::clone(node));
+        while let Some(n) = cur {
+            if Rc::ptr_eq(&n, candidate) {
+                return true;
+            }
+            cur = n.parent();
+        }
+        false
+    }
+
+    /// Append `child` under `parent`. The child must be a root, and the
+    /// parent must not live inside the child's subtree.
+    pub fn attach(parent: &Rc<Node>, child: &Rc<Node>) -> Result<(), TreeError> {
+        // Cycle first: it wins even when the child is also attached elsewhere.
+        if Self::in_ancestor_chain(parent, child) {
+            return Err(TreeError::WouldCycle);
+        }
+        if child.parent().is_some() {
+            return Err(TreeError::AlreadyAttached);
+        }
+        parent.children.borrow_mut().push(Rc::clone(child));
+        *child.parent.borrow_mut() = Rc::downgrade(parent);
+        Ok(())
+    }
+
+    /// Unhook this node from its parent. Returns false (touching nothing)
+    /// for roots and for nodes whose parent has already been dropped.
+    pub fn detach(&self) -> bool {
+        let parent = self.parent();
+        match parent {
+            Some(p) => {
+                let me = self as *const Node;
+                p.children.borrow_mut().retain(|c| Rc::as_ptr(c) != me);
+                *self.parent.borrow_mut() = Weak::new();
+                true
+            }
+            None => false,
+        }
+    }
+
+    /// Move `node` (with its whole subtree) under `new_parent`, appending it
+    /// to the back of the child list. Reparenting under the node itself or
+    /// any of its descendants is refused with `WouldCycle` and changes
+    /// nothing.
+    pub fn reparent(node: &Rc<Node>, new_parent: &Rc<Node>) -> Result<(), TreeError> {
+        if Self::in_ancestor_chain(new_parent, node) {
+            return Err(TreeError::WouldCycle);
+        }
+        node.detach();
+        new_parent.children.borrow_mut().push(Rc::clone(node));
+        *node.parent.borrow_mut() = Rc::downgrade(new_parent);
+        Ok(())
+    }
+
+    /// Depth-first, self before children, children in insertion order.
+    pub fn preorder(root: &Rc<Node>) -> Vec<Rc<Node>> {
+        let mut out = vec![Rc::clone(root)];
+        for child in root.children.borrow().iter() {
+            out.extend(Self::preorder(child));
+        }
+        out
+    }
+
+    /// First preorder match by label, searching only `root`'s subtree.
+    pub fn find(root: &Rc<Node>, label: &str) -> Option<Rc<Node>> {
+        if root.label == label {
+            return Some(Rc::clone(root));
+        }
+        for child in root.children.borrow().iter() {
+            if let Some(hit) = Self::find(child, label) {
+                return Some(hit);
+            }
+        }
+        None
+    }
+}
