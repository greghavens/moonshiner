+++ b/dt_entities/errors.py
@@ -0,0 +1,31 @@
+"""Errors raised by the dt_entities package."""
+
+
+class DtApiError(Exception):
+    """A Dynatrace API error envelope ({"error": {...}})."""
+
+    def __init__(self, status, code=None, message="", violations=None):
+        self.status = status
+        self.code = code
+        self.message = message
+        self.violations = list(violations or [])
+        detail = "Dynatrace API error %s: %s" % (status, message)
+        if self.violations:
+            detail += " (%s)" % "; ".join(
+                "%s: %s" % (v.get("location", "?"), v.get("message", ""))
+                for v in self.violations
+            )
+        super().__init__(detail)
+
+
+class EntityDriftError(Exception):
+    """The finished scan disagrees with the first page's totalCount."""
+
+    def __init__(self, collected, total_count, entities):
+        self.collected = collected
+        self.total_count = total_count
+        self.entities = entities
+        super().__init__(
+            "entity scan drifted: collected %d unique entities but the first "
+            "page reported totalCount=%d" % (collected, total_count)
+        )
diff --git a/dt_entities/export.py b/dt_entities/export.py
