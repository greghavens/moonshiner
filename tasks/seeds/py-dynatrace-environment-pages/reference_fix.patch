--- /dev/null
+++ b/dt_entities/client.py
@@ -0,0 +1,78 @@
+"""Low-level Environment API v2 client (stdlib urllib only)."""
+
+import json
+import urllib.error
+import urllib.parse
+import urllib.request
+
+from .errors import DtApiError
+from .selector import validate_selector
+
+ENTITIES_PATH = "/api/v2/entities"
+
+
+class EntitiesClient:
+    """GET /api/v2/entities with Api-Token auth.
+
+    The token travels only in the Authorization header; the api-token
+    query parameter alternative would end up in logs.
+    """
+
+    def __init__(self, base_url, token, timeout=30):
+        self._base_url = base_url.rstrip("/")
+        self._token = token
+        self._timeout = timeout
+
+    def fetch_page(self, entity_selector=None, next_page_key=None, fields=None,
+                   time_from=None, time_to=None, page_size=None, sort=None):
+        if (entity_selector is None) == (next_page_key is None):
+            raise ValueError(
+                "exactly one of entity_selector / next_page_key is required"
+            )
+        if next_page_key is not None:
+            # Subsequent pages: the cursor must be the only parameter.
+            params = [("nextPageKey", next_page_key)]
+        else:
+            validate_selector(entity_selector)
+            params = [("entitySelector", entity_selector)]
+            if page_size is not None:
+                params.append(("pageSize", str(page_size)))
+            if time_from is not None:
+                params.append(("from", time_from))
+            if time_to is not None:
+                params.append(("to", time_to))
+            if fields:
+                for field in fields:
+                    if not field.startswith("+"):
+                        raise ValueError(
+                            "fields entries must be '+'-prefixed properties: %r"
+                            % (field,)
+                        )
+                params.append(("fields", ",".join(fields)))
+            if sort is not None:
+                params.append(("sort", sort))
+        url = "%s%s?%s" % (
+            self._base_url, ENTITIES_PATH, urllib.parse.urlencode(params)
+        )
+        request = urllib.request.Request(
+            url, headers={"Authorization": "Api-Token %s" % self._token}
+        )
+        try:
+            with urllib.request.urlopen(request, timeout=self._timeout) as resp:
+                return json.loads(resp.read().decode("utf-8"))
+        except urllib.error.HTTPError as exc:
+            raise self._api_error(exc) from None
+
+    @staticmethod
+    def _api_error(exc):
+        try:
+            envelope = json.loads(exc.read().decode("utf-8"))
+            error = envelope.get("error") or {}
+        except (ValueError, AttributeError):
+            error = {}
+        return DtApiError(
+            status=exc.code,
+            code=error.get("code"),
+            message=error.get("message", ""),
+            violations=error.get("constraintViolations") or [],
+        )
