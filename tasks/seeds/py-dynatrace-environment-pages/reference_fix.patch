+++ b/dt_entities/export.py
@@ -0,0 +1,67 @@
+"""Paged entity export with deterministic normalization."""
+
+from .errors import EntityDriftError
+
+
+def normalize_entity(raw):
+    tags = []
+    for tag in raw.get("tags") or []:
+        context = tag.get("context", "")
+        key = tag.get("key", "")
+        if tag.get("value") is not None:
+            tags.append("%s:%s=%s" % (context, key, tag["value"]))
+        else:
+            tags.append("%s:%s" % (context, key))
+    zones = sorted(z.get("name", "") for z in raw.get("managementZones") or [])
+    return {
+        "entityId": raw["entityId"],
+        "displayName": raw.get("displayName", ""),
+        "type": raw.get("type", ""),
+        "firstSeenTms": raw.get("firstSeenTms"),
+        "lastSeenTms": raw.get("lastSeenTms"),
+        "tags": sorted(tags),
+        "managementZones": zones,
+    }
+
+
+def export_entities(client, entity_selector, page_size=50, time_from="now-3d",
+                    time_to=None, fields=None, sort=None):
+    """Walk every page of /api/v2/entities and normalize the result.
+
+    pageSize and from are always sent explicitly so a scan does not
+    silently change shape when server defaults move.
+    """
+    page = client.fetch_page(
+        entity_selector=entity_selector,
+        page_size=page_size,
+        time_from=time_from,
+        time_to=time_to,
+        fields=fields,
+        sort=sort,
+    )
+    total_count = page.get("totalCount", 0)
+    pages = 1
+    collected = []
+    seen = set()
+    while True:
+        for raw in page.get("entities") or []:
+            if raw["entityId"] in seen:
+                continue  # page-boundary churn: keep the first occurrence
+            seen.add(raw["entityId"])
+            collected.append(raw)
+        next_key = page.get("nextPageKey")
+        if not next_key:
+            break
+        page = client.fetch_page(next_page_key=next_key)
+        pages += 1
+    normalized = sorted(
+        (normalize_entity(raw) for raw in collected),
+        key=lambda e: e["entityId"],
+    )
+    if len(normalized) != total_count:
+        raise EntityDriftError(
+            collected=len(normalized),
+            total_count=total_count,
+            entities=normalized,
+        )
+    return {"totalCount": total_count, "pages": pages, "entities": normalized}
diff --git a/dt_entities/selector.py b/dt_entities/selector.py
new file mode 100644
index 0000000..c1b3608
--- /dev/null
+++ b/dt_entities/selector.py
@@ -0,0 +1,43 @@
+"""Entity selector building and validation.
+
+The Environment API v2 entity selector must contain exactly one type(...)
+criterion, criteria join with commas (AND), and the whole selector is
+limited to 2,000 characters.
+"""
+
+import re
+
+MAX_SELECTOR_CHARS = 2000
+_TYPE_RE = re.compile(r'(?<![\w.])type\(')
+_HEALTH_STATES = ("HEALTHY", "UNHEALTHY")
+
+
+def validate_selector(selector):
+    if not isinstance(selector, str) or not selector.strip():
+        raise ValueError("entitySelector must be a non-empty string")
+    if len(selector) > MAX_SELECTOR_CHARS:
+        raise ValueError(
+            "entitySelector exceeds the documented %d character limit"
+            % MAX_SELECTOR_CHARS
+        )
+    types = _TYPE_RE.findall(selector)
+    if not types:
+        raise ValueError("entitySelector must contain a type(...) criterion")
+    if len(types) > 1:
+        raise ValueError("only one entity type may be selected per query")
+    return selector
+
+
+def build_selector(entity_type, tags=(), health_state=None):
+    if not entity_type or not str(entity_type).strip():
+        raise ValueError("entity_type is required")
+    parts = ['type("%s")' % entity_type]
+    for tag in tags:
+        parts.append('tag("%s")' % tag)
+    if health_state is not None:
+        if health_state not in _HEALTH_STATES:
+            raise ValueError(
+                "healthState must be one of %s" % (_HEALTH_STATES,)
+            )
+        parts.append('healthState("%s")' % health_state)
+    return validate_selector(",".join(parts))
