diff --git a/binrec.py b/binrec.py
new file mode 100644
index 0000000..03a4c98
--- /dev/null
+++ b/binrec.py
@@ -0,0 +1,163 @@
+"""Fixed-size binary record codec with manual byte handling (no struct).
+
+Layout: declaration order; uints big-endian; strN = N bytes, UTF-8 +
+NUL padding; consecutive flag fields share bytes LSB-first.
+"""
+
+
+class SchemaError(ValueError):
+    pass
+
+
+class PackError(ValueError):
+    pass
+
+
+class UnpackError(ValueError):
+    pass
+
+
+_UINT_SIZES = {"uint8": 1, "uint16": 2, "uint32": 4}
+
+
+class _Field:
+    def __init__(self, name, kind, size):
+        self.name = name
+        self.kind = kind      # "uint" | "str" | "flags"
+        self.size = size      # byte width (uint/str) or flag count (flags)
+        self.names = None     # flag field names, for kind == "flags"
+
+
+def _parse_fields(fields):
+    if not fields:
+        raise SchemaError("a schema needs at least one field")
+    seen = set()
+    parsed = []          # list of _Field, flags grouped into runs
+    flag_run = None
+    for entry in fields:
+        try:
+            name, kind = entry
+        except (TypeError, ValueError):
+            raise SchemaError(f"malformed field entry: {entry!r}") from None
+        if not isinstance(name, str) or not name:
+            raise SchemaError(f"field name must be a non-empty string: {name!r}")
+        if name in seen:
+            raise SchemaError(f"duplicate field name: {name!r}")
+        seen.add(name)
+        if kind == "flag":
+            if flag_run is None:
+                flag_run = _Field(None, "flags", 0)
+                flag_run.names = []
+                parsed.append(flag_run)
+            flag_run.names.append(name)
+            flag_run.size += 1
+            continue
+        flag_run = None
+        if kind in _UINT_SIZES:
+            parsed.append(_Field(name, "uint", _UINT_SIZES[kind]))
+        elif isinstance(kind, str) and kind.startswith("str"):
+            suffix = kind[3:]
+            if not suffix.isdigit() or int(suffix) < 1:
+                raise SchemaError(f"bad string type {kind!r} for field {name!r}")
+            parsed.append(_Field(name, "str", int(suffix)))
+        else:
+            raise SchemaError(f"unknown field type {kind!r} for field {name!r}")
+    return parsed
+
+
+class Schema:
+    def __init__(self, fields):
+        self._fields = _parse_fields(fields)
+        self.size = sum(
+            (f.size + 7) // 8 if f.kind == "flags" else f.size
+            for f in self._fields
+        )
+
+    # -- packing ----------------------------------------------------------
+    def pack(self, record):
+        expected = set()
+        for f in self._fields:
+            expected.update(f.names if f.kind == "flags" else [f.name])
+        missing = expected - set(record)
+        if missing:
+            raise PackError(f"missing field(s): {', '.join(sorted(missing))}")
+        extra = set(record) - expected
+        if extra:
+            raise PackError(f"unexpected field(s): {', '.join(sorted(extra))}")
+
+        out = bytearray()
+        for f in self._fields:
+            if f.kind == "uint":
+                out += self._pack_uint(f, record[f.name])
+            elif f.kind == "str":
+                out += self._pack_str(f, record[f.name])
+            else:
+                out += self._pack_flags(f, record)
+        return bytes(out)
+
+    @staticmethod
+    def _pack_uint(f, value):
+        if isinstance(value, bool) or not isinstance(value, int):
+            raise PackError(f"field {f.name!r} needs an int, got {value!r}")
+        limit = 1 << (8 * f.size)
+        if not 0 <= value < limit:
+            raise PackError(f"field {f.name!r} out of range: {value}")
+        return value.to_bytes(f.size, "big")
+
+    @staticmethod
+    def _pack_str(f, value):
+        if not isinstance(value, str):
+            raise PackError(f"field {f.name!r} needs a str, got {value!r}")
+        if "\x00" in value:
+            raise PackError(f"field {f.name!r} must not contain NUL")
+        raw = value.encode("utf-8")
+        if len(raw) > f.size:
+            raise PackError(
+                f"field {f.name!r} is {len(raw)} bytes encoded, max {f.size}")
+        return raw + b"\x00" * (f.size - len(raw))
+
+    @staticmethod
+    def _pack_flags(f, record):
+        nbytes = (f.size + 7) // 8
+        buf = bytearray(nbytes)
+        for i, name in enumerate(f.names):
+            value = record[name]
+            if not isinstance(value, bool):
+                raise PackError(f"field {name!r} needs a bool, got {value!r}")
+            if value:
+                buf[i // 8] |= 1 << (i % 8)
+        return bytes(buf)
+
+    # -- unpacking ----------------------------------------------------------
+    def unpack(self, data):
+        if not isinstance(data, (bytes, bytearray)):
+            raise UnpackError(f"expected bytes, got {type(data).__name__}")
+        if len(data) != self.size:
+            raise UnpackError(
+                f"record must be exactly {self.size} bytes, got {len(data)}")
+        record = {}
+        offset = 0
+        for f in self._fields:
+            if f.kind == "uint":
+                record[f.name] = int.from_bytes(data[offset:offset + f.size], "big")
+                offset += f.size
+            elif f.kind == "str":
+                chunk = data[offset:offset + f.size].rstrip(b"\x00")
+                try:
+                    record[f.name] = chunk.decode("utf-8")
+                except UnicodeDecodeError:
+                    raise UnpackError(
+                        f"field {f.name!r} is not valid UTF-8") from None
+                offset += f.size
+            else:
+                nbytes = (f.size + 7) // 8
+                chunk = data[offset:offset + nbytes]
+                value = int.from_bytes(chunk, "little")
+                if value >> f.size:
+                    raise UnpackError(
+                        f"corrupt record: stray bits in flag byte(s) at "
+                        f"offset {offset}")
+                for i, name in enumerate(f.names):
+                    record[name] = bool(value >> i & 1)
+                offset += nbytes
+        return record
