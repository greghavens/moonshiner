diff --git a/src/serial_writer.c b/src/serial_writer.c
--- a/src/serial_writer.c
+++ b/src/serial_writer.c
@@ -2,12 +2,53 @@
 
 #include <errno.h>
 
+static int cancelled(const serial_transport_t *transport)
+{
+    if (transport->is_cancelled != NULL &&
+        transport->is_cancelled(transport->context)) {
+        errno = ECANCELED;
+        return 1;
+    }
+    return 0;
+}
+
+static int remaining_timeout(const serial_transport_t *transport,
+                             uint64_t started_at,
+                             uint32_t timeout_ms,
+                             uint32_t *remaining_ms)
+{
+    uint64_t now;
+    uint64_t elapsed;
+
+    if (timeout_ms == SERIAL_TIMEOUT_INFINITE) {
+        *remaining_ms = SERIAL_TIMEOUT_INFINITE;
+        return 0;
+    }
+
+    now = transport->now_ms(transport->context);
+    if (now < started_at) {
+        errno = EIO;
+        return -1;
+    }
+
+    elapsed = now - started_at;
+    if (elapsed >= timeout_ms) {
+        errno = ETIMEDOUT;
+        return -1;
+    }
+
+    *remaining_ms = timeout_ms - (uint32_t)elapsed;
+    return 0;
+}
+
 int serial_write_all(const serial_transport_t *transport,
                      const uint8_t *data,
                      size_t length,
                      uint32_t timeout_ms)
 {
-    ssize_t written;
+    uint64_t started_at = 0U;
+    size_t offset = 0U;
+    int first_attempt = 1;
 
