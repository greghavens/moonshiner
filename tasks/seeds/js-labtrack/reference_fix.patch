diff --git a/labtrack.mjs b/labtrack.mjs
new file mode 100644
index 0000000..f41e902
--- /dev/null
+++ b/labtrack.mjs
@@ -0,0 +1,113 @@
+// labtrack — CLI for tracking lab samples through intake and testing.
+import fs from "node:fs";
+import path from "node:path";
+import { Argument, Command, InvalidArgumentError, Option } from "commander";
+
+const KINDS = ["water", "soil", "air"];
+const STATUSES = ["received", "testing", "complete"];
+
+function parseDilution(value) {
+  const n = Number.parseFloat(value);
+  if (!Number.isFinite(n) || n <= 0) {
+    throw new InvalidArgumentError("dilution must be a positive number");
+  }
+  return n;
+}
+
+function loadState(file) {
+  if (!fs.existsSync(file)) return {};
+  return JSON.parse(fs.readFileSync(file, "utf8"));
+}
+
+function saveState(file, state) {
+  fs.writeFileSync(file, JSON.stringify(state, null, 2) + "\n");
+}
+
+function fail(message, code) {
+  process.stderr.write(message + "\n");
+  process.exit(code);
+}
+
+const program = new Command();
+
+program
+  .name("labtrack")
+  .description("track lab samples through intake and testing")
+  .option("-f, --file <path>", "state file", "samples.json")
+  .exitOverride();
+
+program
+  .command("register")
+  .description("register a new sample")
+  .argument("<sampleId>", "sample identifier")
+  .addOption(new Option("-k, --kind <kind>", "sample kind")
+    .choices(KINDS).makeOptionMandatory())
+  .option("-d, --dilution <ratio>", "dilution ratio", parseDilution, 1)
+  .option("-t, --tag <tags...>", "free-form tags")
+  .action((sampleId, opts) => {
+    const file = path.resolve(program.opts().file);
+    const state = loadState(file);
+    if (Object.hasOwn(state, sampleId)) {
+      fail(`error: sample ${sampleId} already registered`, 3);
+    }
+    state[sampleId] = {
+      kind: opts.kind,
+      dilution: opts.dilution,
+      tags: opts.tag ?? [],
+      status: "received",
+    };
+    saveState(file, state);
+    process.stdout.write(
+      `registered ${sampleId} kind=${opts.kind} dilution=${opts.dilution}\n`);
+  });
+
+program
+  .command("list")
+  .description("list registered samples")
+  .addOption(new Option("-k, --kind <kind>", "filter by kind").choices(KINDS))
+  .option("--json", "emit JSON")
+  .action((opts) => {
+    const file = path.resolve(program.opts().file);
+    const state = loadState(file);
+    const rows = Object.keys(state).sort()
+      .map((id) => ({ id, ...state[id] }))
+      .filter((row) => !opts.kind || row.kind === opts.kind);
+    if (opts.json) {
+      process.stdout.write(JSON.stringify(rows, null, 2) + "\n");
+      return;
+    }
+    for (const row of rows) {
+      const tags = row.tags.length ? row.tags.join(",") : "-";
+      process.stdout.write(
+        `${row.id}\t${row.kind}\tdilution=${row.dilution}\t` +
+        `status=${row.status}\ttags=${tags}\n`);
+    }
+  });
+
+program
+  .command("status")
+  .description("update a sample's status")
+  .argument("<sampleId>", "sample identifier")
+  .addArgument(new Argument("<newStatus>", "new status").choices(STATUSES))
+  .action((sampleId, newStatus) => {
+    const file = path.resolve(program.opts().file);
+    const state = loadState(file);
+    if (!Object.hasOwn(state, sampleId)) {
+      fail(`error: no such sample: ${sampleId}`, 4);
+    }
+    state[sampleId].status = newStatus;
+    saveState(file, state);
+    process.stdout.write(`${sampleId} -> ${newStatus}\n`);
+  });
+
+try {
+  await program.parseAsync(process.argv);
+} catch (err) {
+  // commander throws because of exitOverride(): keep help/version at 0 and
+  // map genuine usage problems onto the bench scripts' exit-code contract.
+  if (err.code === "commander.helpDisplayed" || err.code === "commander.help" ||
+      err.code === "commander.version") {
+    process.exit(0);
+  }
+  process.exit(2);
+}
