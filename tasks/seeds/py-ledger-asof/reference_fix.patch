diff --git a/ledger.py b/ledger.py
index 4cfc91a..1262f49 100644
--- a/ledger.py
+++ b/ledger.py
@@ -74,3 +74,18 @@ class Ledger:
             raise KeyError(account)
         mine = [e for e in self._entries if e.account == account]
         return sorted(mine, key=lambda e: (e.date, e.seq))
+
+    def balance_asof(self, account, on):
+        """Balance counting entries dated on-or-before `on` (YYYY-MM-DD)."""
+        cutoff = _parse_date(on)
+        if account not in self._accounts:
+            raise KeyError(account)
+        return sum(e.amount for e in self._entries
+                   if e.account == account and e.date <= cutoff)
+
+    def balances_asof(self, on):
+        """As-of balance for every open account (0 when nothing posted yet)."""
+        cutoff = _parse_date(on)  # validate once, even for empty ledgers
+        return {name: sum(e.amount for e in self._entries
+                          if e.account == name and e.date <= cutoff)
+                for name in self._accounts}
