+#!/usr/bin/env python3
+"""Reference proof using the genuine executable and returned stable IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+PHASE_WORKER = r'''
+import json
+import subprocess
+import sys
+
+commands = json.loads(sys.argv[1])
+processes = [
+    subprocess.Popen(
+        command,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    for command in commands
+]
+outputs = []
+for process in processes:
+    stdout, stderr = process.communicate(timeout=12)
+    if process.returncode != 0:
+        raise RuntimeError(stderr.strip() or "fleet operation failed")
+    outputs.append(json.loads(stdout))
+print(json.dumps(outputs))
+'''
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    completed = subprocess.run(
+        [sys.executable, "-B", "-c", PHASE_WORKER, json.dumps(commands)],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=20,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "fleet phase failed")
+    payload = json.loads(completed.stdout)
+    if not isinstance(payload, list) or len(payload) != len(commands):
+        raise RuntimeError("fleet phase returned an invalid payload")
+    return payload
+
+
+def main() -> int:
+    requested = [
+        ("Shuttle 30", "Depot D"),
+        ("Cargo Van 12", "Depot A"),
+    ]
+    searches = run_phase(
+        [
+            ["./fleetctl", "search", "--name", name, "--location", location]
+            for name, location in requested
+        ]
+    )
+
+    stable_ids: list[str] = []
+    for search in searches:
+        matches = search.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        stable_id = matches[0].get("id")
+        if not isinstance(stable_id, str) or not stable_id:
+            raise RuntimeError("reference search returned no stable ID")
+        stable_ids.append(stable_id)
+
+    gets = run_phase(
+        [["./fleetctl", "get", "--id", stable_id] for stable_id in stable_ids]
+    )
+    records: list[dict[str, Any]] = []
+    for result in gets:
+        record = result.get("record")
+        if not isinstance(record, dict):
+            raise RuntimeError("reference get returned no full record")
+        records.append(record)
+
+    first, second = records
+    if first["status"] == second["status"]:
+        comparison = f"The statuses match: {first['status']}."
+    else:
+        comparison = (
+            f"The statuses differ: {first['status']} versus {second['status']}."
+        )
+    brief = (
+        f"{first['name']} at {first['location']} has stable ID {first['id']} "
+        f"and status {first['status']}.\n"
+        f"{second['name']} at {second['location']} has stable ID {second['id']} "
+        f"and status {second['status']}.\n"
+        f"{comparison}\n"
+    )
+    (ROOT / "dispatch-brief.txt").write_text(brief, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
