+"""Deterministic dependency resolution (topological order + parallel stages)."""
+import heapq
+
+
+class CycleError(ValueError):
+    """A dependency loop. `cycle` holds the loop, smallest member first."""
+
+    def __init__(self, cycle):
+        self.cycle = cycle
+        loop = " -> ".join(cycle + [cycle[0]])
+        super().__init__(f"dependency cycle: {loop}")
+
+
+def _normalize(graph):
+    """Deduplicated dep sets, with implicit leaf nodes filled in."""
+    deps = {}
+    for node, node_deps in graph.items():
+        deps.setdefault(node, set()).update(node_deps)
+    for node_deps in list(deps.values()):
+        for dep in node_deps:
+            deps.setdefault(dep, set())
+    return deps
+
+
+def _raise_cycle(deps, leftover):
+    """Every leftover node has a leftover dep, so a walk must loop."""
+    walk = []
+    seen = {}
+    node = min(leftover)
+    while node not in seen:
+        seen[node] = len(walk)
+        walk.append(node)
+        node = min(d for d in deps[node] if d in leftover)
+    loop = walk[seen[node]:]
+    smallest = loop.index(min(loop))
+    raise CycleError(loop[smallest:] + loop[:smallest])
+
+
+def resolve(graph):
+    """Flat install order: every dependency precedes its dependents.
+
+    Simultaneously-ready nodes are emitted lexicographically, regardless
+    of dict insertion order.
+    """
+    deps = _normalize(graph)
+    dependents = {node: [] for node in deps}
+    indegree = {}
+    for node, node_deps in deps.items():
+        indegree[node] = len(node_deps)
+        for dep in node_deps:
+            dependents[dep].append(node)
+    ready = [node for node, count in indegree.items() if count == 0]
+    heapq.heapify(ready)
+    order = []
+    while ready:
+        node = heapq.heappop(ready)
+        order.append(node)
+        for dependent in dependents[node]:
+            indegree[dependent] -= 1
+            if indegree[dependent] == 0:
+                heapq.heappush(ready, dependent)
+    if len(order) < len(deps):
+        _raise_cycle(deps, {n for n in deps if indegree[n] > 0})
+    return order
+
+
+def stages(graph):
+    """Parallel waves: wave k needs only nodes from waves < k. Waves sorted."""
+    deps = _normalize(graph)
+    placed = set()
+    waves = []
+    remaining = set(deps)
+    while remaining:
+        wave = sorted(n for n in remaining if deps[n] <= placed)
+        if not wave:
+            _raise_cycle(deps, remaining)
+        waves.append(wave)
+        placed.update(wave)
+        remaining.difference_update(wave)
+    return waves
