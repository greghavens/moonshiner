+"""A tiny text-adventure engine: the world is data, loaded from a JSON file."""
+import json
+import sys
+
+
+class Game:
+    def __init__(self, world):
+        rooms = world.get("rooms")
+        if not isinstance(rooms, dict) or not rooms:
+            raise ValueError("world needs a rooms table")
+        for rid, room in rooms.items():
+            for field in ("name", "desc"):
+                if not isinstance(room.get(field), str):
+                    raise ValueError(f"room {rid!r} missing {field}")
+            for direction, dest in room.get("exits", {}).items():
+                if dest not in rooms:
+                    raise ValueError(
+                        f"room {rid!r} exit {direction!r} leads nowhere: {dest!r}")
+            for direction in room.get("locked", {}):
+                if direction not in room.get("exits", {}):
+                    raise ValueError(
+                        f"room {rid!r} locks {direction!r} but has no such exit")
+        if world.get("start") not in rooms:
+            raise ValueError("bad start room")
+        victory = world.get("victory", {})
+        if victory.get("room") not in rooms or not victory.get("item"):
+            raise ValueError("bad victory condition")
+        self.rooms = {rid: {"name": r["name"], "desc": r["desc"],
+                            "exits": dict(r.get("exits", {})),
+                            "items": list(r.get("items", [])),
+                            "locked": dict(r.get("locked", {}))}
+                      for rid, r in rooms.items()}
+        self.location = world["start"]
+        self.victory = victory
+        self.inventory = []
+        self.won = False
+
+    def _room(self):
+        return self.rooms[self.location]
+
+    def look(self):
+        room = self._room()
+        lines = [room["name"], room["desc"]]
+        if room["items"]:
+            lines.append("items: " + ", ".join(room["items"]))
+        doors = []
+        for direction in sorted(room["exits"]):
+            locked = " (locked)" if direction in room["locked"] else ""
+            doors.append(direction + locked)
+        if doors:
+            lines.append("exits: " + ", ".join(doors))
+        return "\n".join(lines)
+
+    def execute(self, command):
+        """Apply one command, return the response text (may be multi-line)."""
+        parts = command.split()
+        verb, arg = (parts[0], " ".join(parts[1:])) if parts else ("", "")
+        room = self._room()
+        if verb == "look" and not arg:
+            reply = self.look()
+        elif verb == "inventory" and not arg:
+            reply = ("You carry: " + ", ".join(self.inventory)
+                     if self.inventory else "You carry nothing.")
+        elif verb == "go":
+            if arg not in room["exits"]:
+                reply = "You can't go that way."
+            elif arg in room["locked"]:
+                reply = f"The {arg} door is locked."
+            else:
+                self.location = room["exits"][arg]
+                reply = self.look()
+        elif verb == "take":
+            if arg in room["items"]:
+                room["items"].remove(arg)
+                self.inventory.append(arg)
+                reply = f"You take the {arg}."
+            else:
+                reply = f"There is no {arg} here."
+        elif verb == "drop":
+            if arg in self.inventory:
+                self.inventory.remove(arg)
+                room["items"].append(arg)
+                reply = f"You drop the {arg}."
+            else:
+                reply = f"You don't have the {arg}."
+        elif verb == "unlock":
+            if arg not in room["exits"]:
+                reply = f"There is no door to the {arg}."
+            elif arg not in room["locked"]:
+                reply = f"The {arg} door isn't locked."
+            elif room["locked"][arg] in self.inventory:
+                del room["locked"][arg]
+                reply = f"You unlock the {arg} door."
+            else:
+                reply = "You don't have the key for that."
+        elif verb == "use":
+            if arg not in self.inventory:
+                reply = f"You don't have the {arg}."
+            else:
+                for direction in sorted(room["locked"]):
+                    if room["locked"][direction] == arg:
+                        del room["locked"][direction]
+                        reply = f"You use the {arg}. The {direction} door unlocks."
+                        break
+                else:
+                    reply = "Nothing happens."
+        else:
+            reply = "I don't understand."
+        if (not self.won and self.location == self.victory["room"]
+                and self.victory["item"] in self.inventory):
+            self.won = True
+            reply += "\nYou win!"
+        return reply
+
+
+def load(path):
+    with open(path, encoding="utf-8") as fh:
+        return Game(json.load(fh))
+
+
+def main(argv=None):
+    argv = sys.argv if argv is None else argv
+    if len(argv) != 2:
+        print("usage: adventure.py WORLD.json", file=sys.stderr)
+        return 2
+    game = load(argv[1])
+    print(game.look())
+    for raw in sys.stdin:
+        command = raw.strip()
+        print(f"> {command}")
+        print(game.execute(command))
+        if game.won:
+            return 0
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
