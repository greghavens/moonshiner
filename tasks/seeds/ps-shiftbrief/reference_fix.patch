+# briefkit.ps1 — shift-brief renderer for kiosk collector logs.
+# Dot-source this file to get Build-ShiftBrief.
+Set-StrictMode -Version Latest
+
+function Build-ShiftBrief {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][string]$Path
+    )
+    if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+        throw "briefkit: log not found: $Path"
+    }
+
+    $out = [System.Collections.Generic.List[string]]::new()
+    $out.Add('shift brief')
+
+    # level names are case-sensitive as logged; default hashtables fold case,
+    # so counts live in an ordinal dictionary
+    $levelCounts = [System.Collections.Generic.Dictionary[string, int]]::new([System.StringComparer]::Ordinal)
+
+    $entries = 0
+    $skipped = 0
+    foreach ($line in [System.IO.File]::ReadAllLines($Path)) {
+        if ($line.Trim().Length -eq 0) { continue }
+        $fields = $line.Split(' ')
+        $ok = ($fields.Length -eq 5)
+        if ($ok) {
+            foreach ($f in $fields) { if ($f.Length -eq 0) { $ok = $false } }
+        }
+        if (-not $ok) {
+            $skipped++
+            continue
+        }
+        $site, $unit, $level, $ms, $note = $fields
+        $entries++
+        $out.Add(('{0:D7} {1} {2}/{3} {4}ms {5}' -f $entries, $level.PadRight(5), $site, $unit, $ms, $note))
+        if ($levelCounts.ContainsKey($level)) { $levelCounts[$level]++ } else { $levelCounts[$level] = 1 }
+    }
+
+    $out.Add("entries: $entries")
+    $out.Add("skipped: $skipped")
+    $names = [string[]]$levelCounts.Keys
+    [Array]::Sort($names, [System.StringComparer]::Ordinal)
+    foreach ($name in $names) {
+        $out.Add(('level {0}: {1}' -f $name, $levelCounts[$name]))
+    }
+
+    return ($out -join "`n") + "`n"
+}
