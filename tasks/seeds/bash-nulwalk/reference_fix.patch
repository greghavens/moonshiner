+#!/usr/bin/env bash
+# sweepplan.sh — plan a tidy-up of a drop directory: print an action manifest,
+# touch nothing.
+#
+# One line per regular file:  <ACTION>\t<path>
+# Classification (first match wins, case-sensitive on the file name):
+#   *.log *.tmp -> SWEEP;  *.bak *~ -> ARCHIVE;  everything else -> KEEP
+#
+# NUL-safe end to end (find -print0 | sort -z | read -d ''), so names with
+# spaces, newlines, dashes, globs, and UTF-8 come through intact. Embedded
+# newlines are rendered as the two characters "\n" to keep the manifest
+# one record per line.
+set -u
+
+if [ $# -ne 1 ]; then
+  echo 'usage: sweepplan.sh <dir>' >&2
+  exit 64
+fi
+dir=$1
+if [ ! -d "$dir" ]; then
+  printf 'sweepplan.sh: not a directory: %s\n' "$dir" >&2
+  exit 66
+fi
+
+while IFS= read -r -d '' path; do
+  name=${path##*/}
+  case $name in
+    *.log|*.tmp) action=SWEEP ;;
+    *.bak|*~)    action=ARCHIVE ;;
+    *)           action=KEEP ;;
+  esac
+  printf '%s\t%s\n' "$action" "${path//$'\n'/\\n}"
+done < <(find "$dir" -type f -print0 | LC_ALL=C sort -z)
