diff --git a/notes.py b/notes.py
index edff9bb..74dbf36 100644
--- a/notes.py
+++ b/notes.py
@@ -62,3 +62,101 @@ class NoteStore:
 
     def _by_id(self):
         return [self._notes[k] for k in sorted(self._notes)]
+
+    def search(self, query):
+        """Boolean tag search: AND / OR / NOT with parentheses.
+
+        Precedence: NOT > AND > OR. Operator words are case-insensitive;
+        every other token is a tag term. Returns notes sorted by id.
+        Malformed queries raise ValueError.
+        """
+        tokens = _tokenize(query)
+        parser = _Parser(tokens, self)
+        matched = parser.parse()
+        return [self._notes[i] for i in sorted(matched)]
+
+    def _ids_with_tag(self, tag):
+        return {n.id for n in self._notes.values() if tag in n.tags}
+
+    def _all_ids(self):
+        return set(self._notes)
+
+
+_TOKEN_RE = None
+
+
+def _tokenize(query):
+    import re
+    global _TOKEN_RE
+    if _TOKEN_RE is None:
+        _TOKEN_RE = re.compile(r"\s*(\(|\)|[A-Za-z0-9_-]+)")
+    if query is None or not query.strip():
+        raise ValueError("empty query")
+    tokens, pos = [], 0
+    while pos < len(query):
+        m = _TOKEN_RE.match(query, pos)
+        if not m:
+            if query[pos:].strip() == "":
+                break
+            raise ValueError("bad character in query at %r" % query[pos:])
+        tokens.append(m.group(1))
+        pos = m.end()
+    return tokens
+
+
+class _Parser:
+    """Recursive descent over: or ::= and (OR and)* ; and ::= not (AND not)* ;
+    not ::= NOT not | term | '(' or ')'"""
+
+    def __init__(self, tokens, store):
+        self._tokens = tokens
+        self._pos = 0
+        self._store = store
+
+    def parse(self):
+        result = self._or()
+        if self._peek() is not None:
+            raise ValueError("unexpected token: %r" % self._peek())
+        return result
+
+    def _peek(self):
+        return self._tokens[self._pos] if self._pos < len(self._tokens) else None
+
+    def _take(self):
+        tok = self._peek()
+        self._pos += 1
+        return tok
+
+    def _or(self):
+        result = self._and()
+        while self._peek() is not None and self._peek().upper() == "OR":
+            self._take()
+            result = result | self._and()
+        return result
+
+    def _and(self):
+        result = self._not()
+        while self._peek() is not None and self._peek().upper() == "AND":
+            self._take()
+            result = result & self._not()
+        return result
+
+    def _not(self):
+        tok = self._peek()
+        if tok is not None and tok.upper() == "NOT":
+            self._take()
+            return self._store._all_ids() - self._not()
+        return self._atom()
+
+    def _atom(self):
+        tok = self._take()
+        if tok is None:
+            raise ValueError("query ended where a tag was expected")
+        if tok == "(":
+            inner = self._or()
+            if self._take() != ")":
+                raise ValueError("missing closing parenthesis")
+            return inner
+        if tok == ")" or tok.upper() in ("AND", "OR", "NOT"):
+            raise ValueError("misplaced %r in query" % tok)
+        return self._store._ids_with_tag(tok.lower())
