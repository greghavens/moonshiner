+export interface FlightCacheOptions {
+  /** Milliseconds a stored value stays fresh. Omit to cache forever. */
+  ttlMs?: number;
+  /** Injectable clock (ms). Defaults to Date.now. */
+  now?: () => number;
+}
+
+type Entry<V> =
+  | { kind: 'flight'; promise: Promise<V> }
+  | { kind: 'value'; value: V; storedAt: number };
+
+export class FlightCache<V> {
+  private entries = new Map<string, Entry<V>>();
+  private ttlMs: number | undefined;
+  private now: () => number;
+
+  constructor(opts: FlightCacheOptions = {}) {
+    this.ttlMs = opts.ttlMs;
+    this.now = opts.now ?? Date.now;
+  }
+
+  get(key: string, loader: () => Promise<V>): Promise<V> {
+    const existing = this.entries.get(key);
+    if (existing) {
+      if (existing.kind === 'flight') return existing.promise;
+      if (this.ttlMs === undefined || this.now() - existing.storedAt < this.ttlMs) {
+        return Promise.resolve(existing.value);
+      }
+      this.entries.delete(key); // stale
+    }
+
+    const promise = Promise.resolve()
+      .then(loader)
+      .then(
+        (value) => {
+          // Only store if this flight is still the current entry — an
+          // invalidate() or clear() during the load supersedes the result.
+          if (this.entries.get(key) === entry) {
+            this.entries.set(key, { kind: 'value', value, storedAt: this.now() });
+          }
+          return value;
+        },
+        (error: unknown) => {
+          if (this.entries.get(key) === entry) {
+            this.entries.delete(key); // errors are never cached
+          }
+          throw error;
+        },
+      );
+    const entry: Entry<V> = { kind: 'flight', promise };
+    this.entries.set(key, entry);
+    return promise;
+  }
+
+  invalidate(key: string): void {
+    this.entries.delete(key);
+  }
+
+  clear(): void {
+    this.entries.clear();
+  }
+}
