+package taskrunner
+
+// findCycle returns the names on some dependency cycle, or nil.
+// Iterative three-color DFS over the dep edges.
+func findCycle(deps map[string][]string, tasks map[string]Task) []string {
+	const (
+		white = 0
+		gray  = 1
+		black = 2
+	)
+	color := make(map[string]int, len(tasks))
+	var stack []string
+
+	var visit func(string) []string
+	visit = func(n string) []string {
+		color[n] = gray
+		stack = append(stack, n)
+		for _, d := range deps[n] {
+			switch color[d] {
+			case gray:
+				// slice the current stack from d to n
+				for i, s := range stack {
+					if s == d {
+						return append(append([]string(nil), stack[i:]...), d)
+					}
+				}
+				return []string{d, n, d}
+			case white:
+				if cyc := visit(d); cyc != nil {
+					return cyc
+				}
+			}
+		}
+		stack = stack[:len(stack)-1]
+		color[n] = black
+		return nil
+	}
+
+	for name := range tasks {
+		if color[name] == white {
+			if cyc := visit(name); cyc != nil {
+				return cyc
+			}
+		}
+	}
+	return nil
+}
+
+// closure returns every task reachable from target via dep edges,
+// including target itself.
+func (r *Runner) closure(target string) map[string]bool {
+	seen := map[string]bool{target: true}
+	queue := []string{target}
+	for len(queue) > 0 {
+		n := queue[0]
+		queue = queue[1:]
+		for _, d := range r.deps[n] {
+			if !seen[d] {
+				seen[d] = true
+				queue = append(queue, d)
+			}
+		}
+	}
+	return seen
+}
