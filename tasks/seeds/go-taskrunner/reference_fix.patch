--- /dev/null
+++ b/taskrunner.go
@@ -0,0 +1,66 @@
+// Package taskrunner runs named tasks in dependency order, executing
+// independent tasks concurrently — a tiny library-shaped `make`.
+package taskrunner
+
+import (
+	"context"
+	"fmt"
+)
+
+// Task is one unit of work in the graph.
+type Task struct {
+	Name   string
+	Deps   []string
+	Action func(context.Context) error
+}
+
+// Status is the terminal state of a task after a Run.
+type Status string
+
+const (
+	StatusOK      Status = "ok"
+	StatusFailed  Status = "failed"
+	StatusSkipped Status = "skipped"
+)
+
+// Runner holds a validated task graph. It is immutable after NewRunner and
+// safe to reuse across Runs.
+type Runner struct {
+	tasks  map[string]Task
+	deps   map[string][]string // task -> its deps
+	rdeps  map[string][]string // task -> tasks that depend on it
+}
+
+// NewRunner validates the task list and builds the dependency graph.
+func NewRunner(tasks []Task) (*Runner, error) {
+	r := &Runner{
+		tasks: make(map[string]Task, len(tasks)),
+		deps:  make(map[string][]string, len(tasks)),
+		rdeps: make(map[string][]string, len(tasks)),
+	}
+	for _, t := range tasks {
+		if t.Name == "" {
+			return nil, fmt.Errorf("taskrunner: task with empty name")
+		}
+		if t.Action == nil {
+			return nil, fmt.Errorf("taskrunner: task %q has a nil action", t.Name)
+		}
+		if _, dup := r.tasks[t.Name]; dup {
+			return nil, fmt.Errorf("taskrunner: duplicate task name %q", t.Name)
+		}
+		r.tasks[t.Name] = t
+	}
+	for _, t := range tasks {
+		for _, d := range t.Deps {
+			if _, ok := r.tasks[d]; !ok {
+				return nil, fmt.Errorf("taskrunner: task %q depends on unknown task %q", t.Name, d)
+			}
+			r.deps[t.Name] = append(r.deps[t.Name], d)
+			r.rdeps[d] = append(r.rdeps[d], t.Name)
+		}
+	}
+	if cyc := findCycle(r.deps, r.tasks); cyc != nil {
+		return nil, fmt.Errorf("taskrunner: dependency cycle: %v", cyc)
+	}
+	return r, nil
+}
