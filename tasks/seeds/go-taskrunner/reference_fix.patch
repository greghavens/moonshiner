@@ -0,0 +1,110 @@
+package taskrunner
+
+import (
+	"context"
+	"fmt"
+)
+
+// internal per-run task state
+const (
+	statePending = iota
+	stateRunning
+	stateDone // terminal: recorded in statuses
+)
+
+// Run executes target and its transitive dependencies. Independent ready
+// tasks run concurrently. See package docs for failure/cancel semantics.
+func (r *Runner) Run(ctx context.Context, target string) (*Report, error) {
+	if _, ok := r.tasks[target]; !ok {
+		return nil, fmt.Errorf("taskrunner: unknown target %q", target)
+	}
+	inClosure := r.closure(target)
+
+	state := make(map[string]int, len(inClosure))
+	statuses := make(map[string]Status, len(inClosure))
+	waiting := make(map[string]int, len(inClosure)) // unfinished deps per task
+	for name := range inClosure {
+		state[name] = statePending
+		waiting[name] = len(r.deps[name])
+	}
+
+	type doneMsg struct {
+		name string
+		err  error
+	}
+	done := make(chan doneMsg)
+	running := 0
+	var firstErr error
+
+	launch := func(name string) {
+		state[name] = stateRunning
+		running++
+		action := r.tasks[name].Action
+		go func() {
+			done <- doneMsg{name, action(ctx)}
+		}()
+	}
+
+	// skip marks name and all its (pending) transitive dependents skipped.
+	var skip func(string)
+	skip = func(name string) {
+		if state[name] != statePending {
+			return
+		}
+		state[name] = stateDone
+		statuses[name] = StatusSkipped
+		for _, up := range r.rdeps[name] {
+			if inClosure[up] {
+				skip(up)
+			}
+		}
+	}
+
+	launchReady := func() {
+		if ctx.Err() != nil {
+			return // stop scheduling new work once canceled
+		}
+		for name := range inClosure {
+			if state[name] == statePending && waiting[name] == 0 {
+				launch(name)
+			}
+		}
+	}
+
+	launchReady()
+	for running > 0 {
+		msg := <-done
+		running--
+		state[msg.name] = stateDone
+		if msg.err != nil {
+			statuses[msg.name] = StatusFailed
+			if firstErr == nil {
+				firstErr = fmt.Errorf("taskrunner: task %q failed: %w", msg.name, msg.err)
+			}
+			for _, up := range r.rdeps[msg.name] {
+				if inClosure[up] {
+					skip(up)
+				}
+			}
+		} else {
+			statuses[msg.name] = StatusOK
+			for _, up := range r.rdeps[msg.name] {
+				if inClosure[up] {
+					waiting[up]--
+				}
+			}
+		}
+		launchReady()
+	}
+
+	// Anything still pending was starved by cancellation.
+	for name := range inClosure {
+		if state[name] == statePending {
+			statuses[name] = StatusSkipped
+		}
+	}
+	if firstErr == nil && ctx.Err() != nil {
+		firstErr = fmt.Errorf("taskrunner: run canceled: %w", ctx.Err())
+	}
+	return &Report{Statuses: statuses}, firstErr
+}
