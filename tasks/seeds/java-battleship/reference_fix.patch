+import java.util.ArrayList;
+import java.util.HashMap;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** One player's 10x10 harbour grid: fleet placement, shots and renders. */
+public final class Board {
+
+    private static final int SIZE = 10;
+    private static final Map<String, Integer> FLEET = new LinkedHashMap<>();
+    static {
+        FLEET.put("carrier", 5);
+        FLEET.put("battleship", 4);
+        FLEET.put("cruiser", 3);
+        FLEET.put("submarine", 3);
+        FLEET.put("destroyer", 2);
+    }
+
+    private final String[][] ship = new String[SIZE][SIZE]; // ship name or null
+    private final boolean[][] shot = new boolean[SIZE][SIZE];
+    private final Map<String, Integer> afloat = new HashMap<>(); // cells left per ship
+
+    private Board() {}
+
+    /** Parses a five-line fleet layout: "<class> <coord> <H|V>" per ship. */
+    public static Board parse(String layout) {
+        Board b = new Board();
+        List<int[]> placed = new ArrayList<>();
+        for (String raw : layout.split("\n", -1)) {
+            String line = raw.trim();
+            if (line.isEmpty()) continue;
+            String[] tok = line.split("\\s+");
+            if (tok.length != 3) throw new IllegalArgumentException("bad placement: " + line);
+            String name = tok[0];
+            Integer len = FLEET.get(name);
+            if (len == null) throw new IllegalArgumentException("unknown ship class: " + name);
+            if (b.afloat.containsKey(name)) {
+                throw new IllegalArgumentException("duplicate ship: " + name);
+            }
+            int[] rc = coord(tok[1]);
+            int dr, dc;
+            if (tok[2].equals("H")) { dr = 0; dc = 1; }
+            else if (tok[2].equals("V")) { dr = 1; dc = 0; }
+            else throw new IllegalArgumentException("bad direction: " + tok[2]);
+            for (int i = 0; i < len; i++) {
+                int r = rc[0] + i * dr, c = rc[1] + i * dc;
+                if (r >= SIZE || c >= SIZE) {
+                    throw new IllegalArgumentException(name + " runs off the board");
+                }
+                if (b.ship[r][c] != null) {
+                    throw new IllegalArgumentException(name + " overlaps " + b.ship[r][c]);
+                }
+                b.ship[r][c] = name;
+                placed.add(new int[]{r, c});
+            }
+            b.afloat.put(name, len);
+        }
+        if (b.afloat.size() != FLEET.size()) {
+            throw new IllegalArgumentException("fleet must place all " + FLEET.size() + " ships");
+        }
+        // no-touch rule: every neighbour (including diagonals) of a ship cell is
+        // either water or the same ship
+        for (int[] rc : placed) {
+            String me = b.ship[rc[0]][rc[1]];
+            for (int dr = -1; dr <= 1; dr++) {
+                for (int dc = -1; dc <= 1; dc++) {
+                    int r = rc[0] + dr, c = rc[1] + dc;
+                    if (r < 0 || r >= SIZE || c < 0 || c >= SIZE) continue;
+                    if (b.ship[r][c] != null && !b.ship[r][c].equals(me)) {
+                        throw new IllegalArgumentException(me + " touches " + b.ship[r][c]);
+                    }
+                }
+            }
+        }
+        return b;
+    }
+
+    private static int[] coord(String s) {
+        String t = s.trim().toUpperCase();
+        if (t.length() < 2 || t.length() > 3 || t.charAt(0) < 'A' || t.charAt(0) > 'J') {
+            throw new IllegalArgumentException("bad coordinate: " + s);
+        }
+        String num = t.substring(1);
+        int col;
+        try {
+            col = Integer.parseInt(num);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("bad coordinate: " + s);
+        }
+        if (col < 1 || col > 10 || num.startsWith("0")) {
+            throw new IllegalArgumentException("bad coordinate: " + s);
+        }
+        return new int[]{t.charAt(0) - 'A', col - 1};
+    }
+
+    /** Resolves one shot: "miss", "hit" or "sunk <ship>". */
+    public String shoot(String coordText) {
+        if (allSunk()) throw new IllegalStateException("the fleet is already destroyed");
+        int[] rc = coord(coordText);
+        if (shot[rc[0]][rc[1]]) {
+            throw new IllegalArgumentException("already shot: " + coordText.toUpperCase());
+        }
+        shot[rc[0]][rc[1]] = true;
+        String name = ship[rc[0]][rc[1]];
+        if (name == null) return "miss";
+        int left = afloat.get(name) - 1;
+        afloat.put(name, left);
+        return left == 0 ? "sunk " + name : "hit";
+    }
+
+    public boolean allSunk() {
+        for (int n : afloat.values()) if (n > 0) return false;
+        return true;
+    }
+
+    /** Defender's view: '#' intact ship, 'X' hit ship, 'o' splashed water, '.' sea. */
+    public String renderOwn() {
+        return render(true);
+    }
+
+    /** Attacker's view of this board: only 'X' hits and 'o' misses. */
+    public String renderTracking() {
+        return render(false);
+    }
+
+    private String render(boolean showShips) {
+        StringBuilder sb = new StringBuilder();
+        for (int r = 0; r < SIZE; r++) {
+            if (r > 0) sb.append('\n');
+            sb.append((char) ('A' + r)).append(' ');
+            for (int c = 0; c < SIZE; c++) {
+                boolean s = ship[r][c] != null;
+                if (shot[r][c]) sb.append(s ? 'X' : 'o');
+                else if (s && showShips) sb.append('#');
+                else sb.append('.');
+            }
+        }
+        return sb.toString();
+    }
+}
diff --git a/Match.java b/Match.java
