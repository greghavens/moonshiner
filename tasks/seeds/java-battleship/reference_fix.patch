+import java.util.List;
+
+/** Referees a duel between two scripted shot lists, A shooting first. */
+public final class Match {
+
+    private Match() {}
+
+    public static String run(String layoutA, String layoutB,
+                             List<String> shotsA, List<String> shotsB) {
+        Board boardA = Board.parse(layoutA);
+        Board boardB = Board.parse(layoutB);
+        StringBuilder sb = new StringBuilder();
+        int ia = 0, ib = 0;
+        for (int n = 1; ; n++) {
+            boolean aTurn = n % 2 == 1;
+            List<String> script = aTurn ? shotsA : shotsB;
+            int idx = aTurn ? ia++ : ib++;
+            if (idx >= script.size()) {
+                throw new IllegalStateException("shot script for " + (aTurn ? "A" : "B")
+                        + " ran out before a decision");
+            }
+            String coord = script.get(idx).toUpperCase();
+            Board target = aTurn ? boardB : boardA;
+            String result = target.shoot(coord);
+            sb.append(n).append(' ').append(aTurn ? 'A' : 'B').append(' ')
+              .append(coord).append(": ").append(result).append('\n');
+            if (target.allSunk()) {
+                sb.append("winner ").append(aTurn ? 'A' : 'B').append(" on shot ").append(n).append('\n');
+                return sb.toString();
+            }
+        }
+    }
+}
