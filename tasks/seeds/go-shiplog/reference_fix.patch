+package shiplog
+
+import (
+	"encoding/json"
+	"math"
+	"net"
+	"net/http"
+	"strconv"
+	"sync"
+	"time"
+)
+
+// RateLimitConfig configures the per-client token-bucket middleware.
+type RateLimitConfig struct {
+	Rate  float64 // tokens refilled per second
+	Burst int     // bucket capacity; buckets start full
+
+	// Now supplies the clock; nil means time.Now. Everything is driven
+	// through it so tests and staging can run on a fake clock.
+	Now func() time.Time
+
+	// KeyFunc derives the client key; nil keys by the host part of
+	// RemoteAddr (the same IP on different source ports is one client).
+	KeyFunc func(*http.Request) string
+
+	// Bypass lists client keys (post-KeyFunc values) that are never
+	// limited and never consume tokens.
+	Bypass []string
+}
+
+type bucket struct {
+	tokens float64
+	last   time.Time
+}
+
+// RateLimit wraps next with a per-client token bucket: requests with no
+// token available are answered 429 with a Retry-After header and never
+// reach next.
+func RateLimit(next http.Handler, cfg RateLimitConfig) http.Handler {
+	now := cfg.Now
+	if now == nil {
+		now = time.Now
+	}
+	key := cfg.KeyFunc
+	if key == nil {
+		key = clientIP
+	}
+	bypass := make(map[string]struct{}, len(cfg.Bypass))
+	for _, k := range cfg.Bypass {
+		bypass[k] = struct{}{}
+	}
+
+	var mu sync.Mutex
+	buckets := make(map[string]*bucket)
+
+	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		k := key(r)
+		if _, free := bypass[k]; free {
+			next.ServeHTTP(w, r)
+			return
+		}
+
+		mu.Lock()
+		b, ok := buckets[k]
+		t := now()
+		if !ok {
+			b = &bucket{tokens: float64(cfg.Burst), last: t}
+			buckets[k] = b
+		} else {
+			b.tokens = math.Min(float64(cfg.Burst), b.tokens+cfg.Rate*t.Sub(b.last).Seconds())
+			b.last = t
+		}
+		if b.tokens >= 1 {
+			b.tokens--
+			mu.Unlock()
+			next.ServeHTTP(w, r)
+			return
+		}
+		// Whole seconds until a full token exists, rounded up, never 0.
+		retry := int(math.Ceil((1 - b.tokens) / cfg.Rate))
+		mu.Unlock()
+		if retry < 1 {
+			retry = 1
+		}
+
+		w.Header().Set("Retry-After", strconv.Itoa(retry))
+		w.Header().Set("Content-Type", "application/json")
+		w.WriteHeader(http.StatusTooManyRequests)
+		json.NewEncoder(w).Encode(map[string]string{"error": "rate limit exceeded"})
+	})
+}
+
+// clientIP is the default key: the host part of RemoteAddr, or the whole
+// RemoteAddr when it has no port to split off.
+func clientIP(r *http.Request) string {
+	host, _, err := net.SplitHostPort(r.RemoteAddr)
+	if err != nil {
+		return r.RemoteAddr
+	}
+	return host
+}
