@@ -0,0 +1,38 @@
+# Enumerable dataset over raw hive-inspection lines. Lines are parsed on
+# demand, one row per yield — never at construction.
+class InspectionLog
+  include Enumerable
+
+  def initialize(lines)
+    @lines = lines
+  end
+
+  def each
+    return to_enum(:each) unless block_given?
+    @lines.each_with_index do |raw, index|
+      yield parse(raw, index + 1)
+    end
+    self
+  end
+
+  # Lazy pipeline over parsed rows: nothing is parsed until the chain is
+  # forced, and only as many rows as the terminal actually needs.
+  def scan
+    to_enum(:each).lazy
+  end
+
+  private
+
+  def parse(raw, lineno)
+    fields = raw.split("|", -1)
+    bad!(lineno, raw) unless fields.length == 5
+    hive, date, frames, queen_flag, note = fields
+    bad!(lineno, raw) unless frames.match?(/\A\d+\z/)
+    bad!(lineno, raw) unless queen_flag == "Q" || queen_flag == "-"
+    { hive: hive, date: date, frames: Integer(frames, 10), queen: queen_flag == "Q", note: note }
+  end
+
+  def bad!(lineno, raw)
+    raise ArgumentError, "bad inspection line #{lineno}: #{raw}"
+  end
+end
