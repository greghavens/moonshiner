+"""Event-sourcing rebuilder: seq-ordered replay, snapshots, upcasting."""
+
+import copy
+
+
+class Replayer:
+    def __init__(self, initial):
+        self._initial = initial
+        self._handlers = {}       # type -> (version, fn)
+        self._upcasters = {}      # (type, from_version) -> fn
+
+    def on(self, etype, version, fn):
+        if etype in self._handlers:
+            raise ValueError("handler already registered for %r" % (etype,))
+        self._handlers[etype] = (version, fn)
+
+    def upcast(self, etype, from_version, fn):
+        key = (etype, from_version)
+        if key in self._upcasters:
+            raise ValueError("upcaster already registered for %r v%d"
+                             % (etype, from_version))
+        self._upcasters[key] = fn
+
+    def _lift(self, etype, version, data):
+        """Bring event data up to the handler's version via upcasters."""
+        target, _ = self._handlers[etype]
+        if version > target:
+            raise ValueError("event %r v%d is newer than handler v%d"
+                             % (etype, version, target))
+        data = copy.deepcopy(data)
+        while version < target:
+            fn = self._upcasters.get((etype, version))
+            if fn is None:
+                raise ValueError("no upcaster for %r v%d -> v%d"
+                                 % (etype, version, version + 1))
+            data = fn(data)
+            version += 1
+        return data
+
+    def rebuild(self, events, snapshot=None, strict=True):
+        if snapshot is not None:
+            state = copy.deepcopy(snapshot["state"])
+            floor = snapshot["seq"]
+        else:
+            state = self._initial()
+            floor = None
+        ordered = sorted(events, key=lambda e: e["seq"])
+        seen = set()
+        for event in ordered:
+            seq = event["seq"]
+            if seq in seen:
+                raise ValueError("duplicate seq %r" % (seq,))
+            seen.add(seq)
+        for event in ordered:
+            if floor is not None and event["seq"] <= floor:
+                continue
+            etype = event["type"]
+            if etype not in self._handlers:
+                if strict:
+                    raise KeyError("no handler for event type %r" % (etype,))
+                continue
+            data = self._lift(etype, event["v"], event["data"])
+            _, fn = self._handlers[etype]
+            state = fn(state, data)
+        return state
