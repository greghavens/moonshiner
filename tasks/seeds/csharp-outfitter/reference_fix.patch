+namespace Outfitter;
+
+/// <summary>The console's only source of time — injected so tests script it.</summary>
+public interface IClock
+{
+    DateTimeOffset UtcNow { get; }
+}
+
+/// <summary>Production adapter: the one place wall-clock time enters the app.</summary>
+internal sealed class SystemClock : IClock
+{
+    public DateTimeOffset UtcNow => TimeProvider.System.GetUtcNow();
+}
