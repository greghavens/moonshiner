+    private string PlaceHold(string[] parts)
+    {
+        if (parts.Length != 4)
+            return "error: usage: hold <sku> <qty> <minutes>";
+        if (!TryQty(parts[2], out var qty))
+            return "error: quantity must be a positive integer";
+        if (!TryQty(parts[3], out var minutes))
+            return "error: minutes must be a positive integer";
+        var sku = parts[1];
+        if (!_stock.Knows(sku))
+            return $"error: unknown sku '{sku}'";
+        if (Available(sku) < qty)
+            return ShortageError(sku);
+
+        var now = _clock.UtcNow;
+        var hold = new Hold($"H{_nextHoldId++}", sku, qty, now.AddMinutes(minutes));
+        _holds.Add(hold);
+        _audit.Add($"{Stamp(now)} hold {hold.Id} {sku} {qty} until {Stamp(hold.Expiry)}");
+        return $"ok: hold {hold.Id} holds {qty} of {sku} until {Stamp(hold.Expiry)}";
+    }
+
+    private string Release(string[] parts)
+    {
+        if (parts.Length != 2)
+            return "error: usage: release <hold-id>";
+        var hold = _holds.FirstOrDefault(h => string.Equals(h.Id, parts[1], StringComparison.Ordinal));
+        if (hold is null)
+            return $"error: unknown hold '{parts[1]}'";
+        _holds.Remove(hold);
+        _audit.Add($"{Stamp(_clock.UtcNow)} release {hold.Id}");
+        return $"ok: hold {hold.Id} released";
     }
 
+    private string ListHolds() =>
+        _holds.Count == 0
+            ? "(none)"
+            : string.Join('\n', _holds.Select(h => $"{h.Id} {h.Sku} x{h.Qty} until {Stamp(h.Expiry)}"));
+
+    private string Audit() => _audit.Count == 0 ? "(none)" : string.Join('\n', _audit);
+
     private string Stock()
     {
         var rows = _stock.Snapshot();
         return rows.Count == 0
             ? "(empty)"
-            : string.Join('\n', rows.Select(r => $"{r.Sku} {r.Qty}"));
+            : string.Join('\n', rows.Select(r => $"{r.Sku} {Available(r.Sku)}{HoldSuffix(r.Sku)}"));
+    }
+
+    private void SweepExpired()
+    {
+        var now = _clock.UtcNow;
+        foreach (var hold in _holds.Where(h => h.Expiry <= now).ToList())
+        {
+            _holds.Remove(hold);
+            _audit.Add($"{Stamp(now)} expire {hold.Id}");
+        }
     }
 
+    private int Held(string sku) =>
+        _holds.Where(h => string.Equals(h.Sku, sku, StringComparison.Ordinal)).Sum(h => h.Qty);
+
+    private int Available(string sku) => _stock.OnHand(sku) - Held(sku);
+
+    private string HoldSuffix(string sku)
+    {
+        var held = Held(sku);
+        return held > 0 ? $" ({held} on hold)" : "";
+    }
+
+    private string ShortageError(string sku) =>
+        $"error: only {Available(sku)} of {sku} available{HoldSuffix(sku)}";
+
+    private static string Stamp(DateTimeOffset at) =>
+        at.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", CultureInfo.InvariantCulture);
+
     private static bool TryQty(string raw, out int qty) =>
         int.TryParse(raw, NumberStyles.None, CultureInfo.InvariantCulture, out qty) && qty > 0;
