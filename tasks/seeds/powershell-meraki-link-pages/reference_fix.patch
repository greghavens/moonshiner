diff --git a/Inventory.ps1 b/Inventory.ps1
new file mode 100644
index 0000000..b739ef9
--- /dev/null
+++ b/Inventory.ps1
@@ -0,0 +1,63 @@
+# Deterministic organization inventory export: networks + devices with
+# ordinal sorting and pinned key order so downstream diffs stay quiet.
+
+Set-StrictMode -Version Latest
+
+function Get-MerakiInventory {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)]$Context,
+        [Parameter(Mandatory)][string]$OrganizationId,
+        [int]$PerPage
+    )
+    $pagedArgs = @{ Context = $Context }
+    if ($PSBoundParameters.ContainsKey('PerPage')) { $pagedArgs['PerPage'] = $PerPage }
+    $networks = Get-MerakiPaged @pagedArgs -Path ('/organizations/{0}/networks' -f $OrganizationId)
+    $devices = Get-MerakiPaged @pagedArgs -Path ('/organizations/{0}/devices' -f $OrganizationId)
+    return [pscustomobject]@{
+        OrganizationId = $OrganizationId
+        Networks       = @($networks)
+        Devices        = @($devices)
+    }
+}
+
+function Sort-OrdinalBy {
+    param([object[]]$Items, [string]$Property)
+    $sorted = @($Items)
+    [Array]::Sort($sorted, [System.Comparison[object]] {
+            param($a, $b)
+            [string]::CompareOrdinal([string]$a.$Property, [string]$b.$Property)
+        })
+    return ,$sorted
+}
+
+function ConvertTo-MerakiInventoryJson {
+    [CmdletBinding()]
+    param([Parameter(Mandatory)]$Inventory)
+    $networks = foreach ($network in (Sort-OrdinalBy -Items @($Inventory.Networks) -Property 'id')) {
+        $productTypes = [string[]]@(@($network.productTypes) | ForEach-Object { [string]$_ })
+        [Array]::Sort($productTypes, [System.Comparison[string]] {
+                param($a, $b) [string]::CompareOrdinal($a, $b)
+            })
+        [ordered]@{
+            id           = [string]$network.id
+            name         = [string]$network.name
+            productTypes = $productTypes
+        }
+    }
+    $devices = foreach ($device in (Sort-OrdinalBy -Items @($Inventory.Devices) -Property 'serial')) {
+        [ordered]@{
+            serial      = [string]$device.serial
+            name        = [string]$device.name
+            model       = [string]$device.model
+            networkId   = [string]$device.networkId
+            productType = [string]$device.productType
+        }
+    }
+    $document = [ordered]@{
+        organizationId = [string]$Inventory.OrganizationId
+        networks       = @($networks)
+        devices        = @($devices)
+    }
+    return ($document | ConvertTo-Json -Depth 8 -Compress)
+}
