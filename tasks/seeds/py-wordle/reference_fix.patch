+"""A Wordle-style daily word game with fixture word lists and a hard mode."""
+import sys
+
+
+def load_words(path):
+    with open(path, encoding="utf-8") as fh:
+        return [w.strip().lower() for w in fh if w.strip()]
+
+
+def score_guess(guess, answer):
+    """Per-letter feedback: G green, Y yellow, - miss.
+
+    Greens are decided first and consume their answer letters; the leftover
+    letters then satisfy yellows strictly left to right.
+    """
+    if len(guess) != len(answer):
+        raise ValueError("guess/answer length mismatch")
+    marks = [""] * len(guess)
+    remaining = {}
+    for i, (g, a) in enumerate(zip(guess, answer)):
+        if g == a:
+            marks[i] = "G"
+        else:
+            remaining[a] = remaining.get(a, 0) + 1
+    for i, g in enumerate(guess):
+        if marks[i]:
+            continue
+        if remaining.get(g, 0) > 0:
+            remaining[g] -= 1
+            marks[i] = "Y"
+        else:
+            marks[i] = "-"
+    return "".join(marks)
+
+
+def hard_mode_error(prev_guess, prev_feedback, guess):
+    """None if `guess` honours the previous feedback, else the refusal message.
+
+    Green positions must be replayed in place (checked left to right); then
+    every letter marked G or Y must appear at least that many times (letters
+    checked in alphabetical order).
+    """
+    for i, mark in enumerate(prev_feedback):
+        if mark == "G" and guess[i] != prev_guess[i]:
+            return f"hard mode: letter {i + 1} must be {prev_guess[i].upper()}"
+    required = {}
+    for mark, letter in zip(prev_feedback, prev_guess):
+        if mark in "GY":
+            required[letter] = required.get(letter, 0) + 1
+    for letter in sorted(required):
+        if guess.count(letter) < required[letter]:
+            return f"hard mode: not enough {letter.upper()}"
+    return None
+
+
+def main(argv=None):
+    argv = sys.argv if argv is None else argv
+    args = [a for a in argv[1:] if a != "--hard"]
+    hard = "--hard" in argv[1:]
+    if len(args) != 3:
+        print("usage: wordle.py ANSWERS ALLOWED GAME [--hard]", file=sys.stderr)
+        return 2
+    answers = load_words(args[0])
+    valid = set(answers) | set(load_words(args[1]))
+    game = int(args[2])
+    if not 1 <= game <= len(answers):
+        print(f"no game {game}", file=sys.stderr)
+        return 2
+    answer = answers[game - 1]
+    prev = None
+    used = 0
+    for raw in sys.stdin:
+        guess = raw.strip().lower()
+        if len(guess) != 5 or not guess.isalpha() or guess not in valid:
+            print("not a valid word")
+            continue
+        if hard and prev is not None:
+            err = hard_mode_error(prev[0], prev[1], guess)
+            if err:
+                print(err)
+                continue
+        feedback = score_guess(guess, answer)
+        print(feedback)
+        used += 1
+        prev = (guess, feedback)
+        if guess == answer:
+            print(f"solved in {used}")
+            return 0
+        if used == 6:
+            print(f"out of guesses: {answer}")
+            return 0
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
