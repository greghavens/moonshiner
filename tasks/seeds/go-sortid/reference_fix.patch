+package sortid
+
+import (
+	"fmt"
+	"strconv"
+	"sync"
+	"time"
+)
+
+// Sortable issues 16-character lowercase-hex IDs that sort
+// lexicographically in creation order: 12 hex digits of Unix
+// millisecond timestamp followed by 4 hex digits of a per-millisecond
+// sequence. Safe for concurrent use.
+type Sortable struct {
+	mu   sync.Mutex
+	now  func() time.Time
+	last int64 // last millisecond stamped into an ID
+	seq  int64 // next sequence within last (once an ID exists there)
+	used bool
+}
+
+// NewSortable returns a Sortable that reads the wall clock through now.
+func NewSortable(now func() time.Time) *Sortable {
+	return &Sortable{now: now}
+}
+
+// Next returns the next ID. Calls within one millisecond increment the
+// sequence; a sequence overflow rolls into the following millisecond;
+// a clock that steps backwards never produces an ID that sorts before
+// an already-issued one.
+func (s *Sortable) Next() string {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	ms := s.now().UnixMilli()
+	switch {
+	case !s.used || ms > s.last:
+		s.last, s.seq, s.used = ms, 0, true
+	default: // same millisecond, or the clock went backwards
+		s.seq++
+		if s.seq > 0xffff {
+			s.last++
+			s.seq = 0
+		}
+	}
+	return fmt.Sprintf("%012x%04x", s.last, s.seq)
+}
+
+// ParsedID is the decoded form of a sortable ID.
+type ParsedID struct {
+	Time time.Time // embedded timestamp, UTC, millisecond precision
+	Seq  uint16    // per-millisecond sequence number
+}
+
+// Parse decodes a sortable ID. It rejects anything that is not exactly
+// 16 lowercase hexadecimal digits.
+func Parse(id string) (ParsedID, error) {
+	if len(id) != 16 {
+		return ParsedID{}, fmt.Errorf("sortid: invalid id %q: want 16 characters, got %d", id, len(id))
+	}
+	for i := 0; i < len(id); i++ {
+		c := id[i]
+		if (c < '0' || c > '9') && (c < 'a' || c > 'f') {
+			return ParsedID{}, fmt.Errorf("sortid: invalid id %q: character %q is not lowercase hex", id, c)
+		}
+	}
+	ms, err := strconv.ParseInt(id[:12], 16, 64)
+	if err != nil {
+		return ParsedID{}, fmt.Errorf("sortid: invalid id %q: %v", id, err)
+	}
+	seq, err := strconv.ParseUint(id[12:], 16, 16)
+	if err != nil {
+		return ParsedID{}, fmt.Errorf("sortid: invalid id %q: %v", id, err)
+	}
+	return ParsedID{Time: time.UnixMilli(ms).UTC(), Seq: uint16(seq)}, nil
+}
