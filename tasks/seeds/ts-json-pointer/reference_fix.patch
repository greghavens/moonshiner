+++ b/pointer.ts
@@ -0,0 +1,162 @@
+export interface PatchOp {
+  op: 'add' | 'remove' | 'replace' | 'test';
+  path: string;
+  value?: unknown;
+}
+
+// -- pointer parsing ----------------------------------------------------------
+
+function parse(pointer: string): string[] {
+  if (pointer === '') return [];
+  if (!pointer.startsWith('/')) {
+    throw new Error(`malformed JSON pointer: ${JSON.stringify(pointer)}`);
+  }
+  return pointer
+    .split('/')
+    .slice(1)
+    .map((token) => token.replace(/~1/g, '/').replace(/~0/g, '~'));
+}
+
+function arrayIndex(token: string, length: number, allowEnd: boolean): number {
+  if (!/^(0|[1-9][0-9]*)$/.test(token)) {
+    throw new Error(`invalid array index ${JSON.stringify(token)}`);
+  }
+  const index = Number(token);
+  if (index > length || (!allowEnd && index === length)) {
+    throw new Error(`array index ${index} out of range (length ${length})`);
+  }
+  return index;
+}
+
+function step(node: unknown, token: string, pointer: string): unknown {
+  if (Array.isArray(node)) {
+    return node[arrayIndex(token, node.length, false)];
+  }
+  if (typeof node === 'object' && node !== null) {
+    const obj = node as Record<string, unknown>;
+    if (!Object.prototype.hasOwnProperty.call(obj, token)) {
+      throw new Error(`pointer ${JSON.stringify(pointer)} not found: no member ${JSON.stringify(token)}`);
+    }
+    return obj[token];
+  }
+  throw new Error(`pointer ${JSON.stringify(pointer)} descends into a non-container value`);
+}
+
+export function get(doc: unknown, pointer: string): unknown {
+  let node = doc;
+  for (const token of parse(pointer)) {
+    node = step(node, token, pointer);
+  }
+  return node;
+}
+
+export function has(doc: unknown, pointer: string): boolean {
+  const tokens = parse(pointer); // malformed pointers still throw
+  let node = doc;
+  try {
+    for (const token of tokens) node = step(node, token, pointer);
+  } catch {
+    return false;
+  }
+  return true;
+}
+
+// -- deep equality (for the test op) -------------------------------------------
+
+function deepEqual(a: unknown, b: unknown): boolean {
+  if (a === b) return true;
+  if (Array.isArray(a) || Array.isArray(b)) {
+    if (!Array.isArray(a) || !Array.isArray(b) || a.length !== b.length) return false;
+    return a.every((item, i) => deepEqual(item, b[i]));
+  }
+  if (typeof a === 'object' && a !== null && typeof b === 'object' && b !== null) {
+    const ka = Object.keys(a as object);
+    const kb = Object.keys(b as object);
+    if (ka.length !== kb.length) return false;
+    return ka.every(
+      (k) =>
+        Object.prototype.hasOwnProperty.call(b, k) &&
+        deepEqual((a as Record<string, unknown>)[k], (b as Record<string, unknown>)[k]),
+    );
+  }
+  return false;
+}
+
+// -- patch --------------------------------------------------------------------
+
+function clone<T>(value: T): T {
+  return value === undefined ? value : (JSON.parse(JSON.stringify(value)) as T);
+}
+
+/** Resolve to the parent container of a pointer's target. */
+function parentOf(root: unknown, tokens: string[], pointer: string): unknown {
+  let node = root;
+  for (const token of tokens.slice(0, -1)) {
+    node = step(node, token, pointer);
+  }
+  return node;
+}
+
+export function applyPatch(doc: unknown, ops: PatchOp[]): unknown {
+  // Work on a private copy: the input must survive untouched even when an
+  // op halfway through the sequence fails.
+  let root = clone(doc);
+
+  for (const op of ops) {
+    const tokens = parse(op.path);
+
+    if (op.op === 'test') {
+      if (!deepEqual(get(root, op.path), op.value)) {
+        throw new Error(`test failed at ${JSON.stringify(op.path)}`);
+      }
+      continue;
+    }
+
+    if (op.op === 'add') {
+      if (tokens.length === 0) {
+        root = clone(op.value);
+        continue;
+      }
+      const parent = parentOf(root, tokens, op.path);
+      const last = tokens[tokens.length - 1];
+      if (Array.isArray(parent)) {
+        const index = last === '-' ? parent.length : arrayIndex(last, parent.length, true);
+        parent.splice(index, 0, clone(op.value));
+      } else if (typeof parent === 'object' && parent !== null) {
+        (parent as Record<string, unknown>)[last] = clone(op.value);
+      } else {
+        throw new Error(`cannot add into a non-container at ${JSON.stringify(op.path)}`);
+      }
+      continue;
+    }
+
+    if (op.op === 'remove' || op.op === 'replace') {
+      if (tokens.length === 0) {
+        if (op.op === 'remove') throw new Error('cannot remove the whole document');
+        root = clone(op.value);
+        continue;
+      }
+      const parent = parentOf(root, tokens, op.path);
+      const last = tokens[tokens.length - 1];
+      if (Array.isArray(parent)) {
+        const index = arrayIndex(last, parent.length, false);
+        if (op.op === 'remove') parent.splice(index, 1);
+        else parent[index] = clone(op.value);
+      } else if (typeof parent === 'object' && parent !== null) {
+        const obj = parent as Record<string, unknown>;
+        if (!Object.prototype.hasOwnProperty.call(obj, last)) {
+          throw new Error(`${op.op} target ${JSON.stringify(op.path)} does not exist`);
+        }
+        if (op.op === 'remove') delete obj[last];
+        else obj[last] = clone(op.value);
+      } else {
+        throw new Error(`${op.op} target ${JSON.stringify(op.path)} does not exist`);
+      }
+      continue;
+    }
+
+    throw new Error(`unknown patch op ${JSON.stringify((op as PatchOp).op)}`);
+  }
+
+  return root;
+}
