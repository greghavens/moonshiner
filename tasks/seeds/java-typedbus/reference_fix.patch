+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.function.Consumer;
+
+/**
+ * Typed, re-entrancy-safe event dispatcher for hub automations.
+ *
+ * Listeners register under a Class token and receive every published event
+ * that token is assignable from. Dispatch order is priority-descending with
+ * registration order breaking ties. Each publish runs against a snapshot,
+ * so handlers may subscribe, cancel, and publish freely mid-dispatch with
+ * pinned semantics (see the acceptance tests).
+ */
+public final class HubBus {
+
+    private static final class Sub<E> implements Subscription {
+        final Class<E> type;
+        final int priority;
+        final long seq;
+        final Consumer<? super E> handler;
+        final boolean once;
+        boolean active = true;
+
+        Sub(Class<E> type, int priority, long seq, Consumer<? super E> handler, boolean once) {
+            this.type = type;
+            this.priority = priority;
+            this.seq = seq;
+            this.handler = handler;
+            this.once = once;
+        }
+
+        @Override
+        public boolean cancel() {
+            if (!active) {
+                return false;
+            }
+            active = false;
+            return true;
+        }
+
+        @Override
+        public boolean active() {
+            return active;
+        }
+
+        void invoke(Object event) {
+            handler.accept(type.cast(event));
+        }
+    }
+
+    private final List<Sub<?>> subs = new ArrayList<>();
+    private long nextSeq = 0;
+
+    public <E> Subscription subscribe(Class<E> type, int priority, Consumer<? super E> handler) {
+        return register(type, priority, handler, false);
+    }
+
+    public <E> Subscription subscribeOnce(Class<E> type, int priority, Consumer<? super E> handler) {
+        return register(type, priority, handler, true);
+    }
+
+    private <E> Subscription register(Class<E> type, int priority,
+                                      Consumer<? super E> handler, boolean once) {
+        if (type == null) {
+            throw new IllegalArgumentException("type must not be null");
+        }
+        if (handler == null) {
+            throw new IllegalArgumentException("handler must not be null");
+        }
+        Sub<E> sub = new Sub<>(type, priority, nextSeq++, handler, once);
+        subs.add(sub);
+        return sub;
+    }
+
+    /**
+     * Dispatches {@code event} to every active subscription whose token is
+     * assignable from it, in priority-then-registration order, against a
+     * snapshot taken now. Returns how many handlers this call invoked.
+     */
+    public int publish(Object event) {
+        if (event == null) {
+            throw new IllegalArgumentException("event must not be null");
+        }
+        List<Sub<?>> snapshot = new ArrayList<>();
+        for (Sub<?> sub : subs) {
+            if (sub.active && sub.type.isInstance(event)) {
+                snapshot.add(sub);
+            }
+        }
+        snapshot.sort(Comparator.<Sub<?>>comparingInt(s -> s.priority).reversed()
+                .thenComparingLong(s -> s.seq));
+        int invoked = 0;
+        for (Sub<?> sub : snapshot) {
+            if (!sub.active) {
+                continue; // cancelled by an earlier handler in this dispatch
+            }
+            if (sub.once) {
+                sub.active = false; // consumed before the handler runs
+            }
+            invoked++;
+            sub.invoke(event); // exceptions propagate as-is
+        }
+        subs.removeIf(s -> !s.active);
+        return invoked;
+    }
+
+    /** Active subscriptions registered with exactly this token. */
+    public int listenerCount(Class<?> type) {
+        if (type == null) {
+            throw new IllegalArgumentException("type must not be null");
+        }
+        int n = 0;
+        for (Sub<?> sub : subs) {
+            if (sub.active && sub.type.equals(type)) {
+                n++;
+            }
+        }
+        return n;
+    }
+}
