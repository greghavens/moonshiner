+//! Interval set for the resumable-download range tracker.
+//!
+//! Stores half-open `[start, end)` intervals over `u64`, normalized at all
+//! times: sorted ascending, non-overlapping, non-adjacent (touching spans are
+//! merged), never empty. `insert` merges, `remove` trims and splits, and the
+//! query side answers point membership, whole-range coverage, and the gaps
+//! inside a window.
+
+/// A normalized set of half-open `[start, end)` intervals over `u64`.
+#[derive(Debug, Clone, Default, PartialEq, Eq)]
+pub struct IntervalSet {
+    /// Sorted, disjoint, non-adjacent, non-empty spans.
+    spans: Vec<(u64, u64)>,
+}
+
+impl IntervalSet {
+    /// An empty set.
+    pub fn new() -> IntervalSet {
+        IntervalSet::default()
+    }
+
+    /// Number of normalized spans.
+    pub fn len(&self) -> usize {
+        self.spans.len()
+    }
+
+    /// True when nothing is covered.
+    pub fn is_empty(&self) -> bool {
+        self.spans.is_empty()
+    }
+
+    /// Sum of span lengths.
+    pub fn total(&self) -> u64 {
+        self.spans.iter().map(|&(s, e)| e - s).sum()
+    }
+
+    /// The normalized spans, sorted ascending.
+    pub fn iter(&self) -> impl Iterator<Item = (u64, u64)> + '_ {
+        self.spans.iter().copied()
+    }
+
+    /// Add `[start, end)`, merging with every span it overlaps or touches.
+    /// Degenerate ranges (`start >= end`) are no-ops.
+    pub fn insert(&mut self, start: u64, end: u64) {
+        if start >= end {
+            return;
+        }
+        // First span that could merge: the first whose end reaches `start`
+        // (end == start is adjacency, which also merges).
+        let lo = self.spans.partition_point(|&(_, e)| e < start);
+        let mut new_start = start;
+        let mut new_end = end;
+        let mut hi = lo;
+        while hi < self.spans.len() && self.spans[hi].0 <= end {
+            new_start = new_start.min(self.spans[hi].0);
+            new_end = new_end.max(self.spans[hi].1);
+            hi += 1;
+        }
+        self.spans.splice(lo..hi, [(new_start, new_end)]);
+    }
+
+    /// Subtract `[start, end)`: trims overlapping edges, deletes swallowed
+    /// spans, splits a span when the range is strictly inside it.
+    /// Degenerate ranges are no-ops.
+    pub fn remove(&mut self, start: u64, end: u64) {
+        if start >= end {
+            return;
+        }
+        let mut result = Vec::with_capacity(self.spans.len() + 1);
+        for &(s, e) in &self.spans {
+            if e <= start || s >= end {
+                result.push((s, e));
+                continue;
+            }
+            if s < start {
+                result.push((s, start));
+            }
+            if e > end {
+                result.push((end, e));
+            }
+        }
+        self.spans = result;
+    }
+
+    /// Is `point` covered? Starts are inclusive, ends exclusive.
+    pub fn contains(&self, point: u64) -> bool {
+        let idx = self.spans.partition_point(|&(_, e)| e <= point);
+        matches!(self.spans.get(idx), Some(&(s, _)) if s <= point)
+    }
+
+    /// Is the whole of `[start, end)` covered? Empty queries are vacuously
+    /// true. Because the set is normalized, a covered range always lies
+    /// within a single span.
+    pub fn covers(&self, start: u64, end: u64) -> bool {
+        if start >= end {
+            return true;
+        }
+        let idx = self.spans.partition_point(|&(_, e)| e < end);
+        matches!(self.spans.get(idx), Some(&(s, e)) if s <= start && end <= e)
+    }
+
+    /// The uncovered sub-ranges of the window `[start, end)`, clipped to it,
+    /// sorted ascending. The whole window when nothing is covered; empty for
+    /// an empty window.
+    pub fn gaps(&self, start: u64, end: u64) -> Vec<(u64, u64)> {
+        let mut out = Vec::new();
+        if start >= end {
+            return out;
+        }
+        let mut cursor = start;
+        for &(s, e) in &self.spans {
+            if e <= start {
+                continue;
+            }
+            if s >= end {
+                break;
+            }
+            let clipped_start = s.max(start);
+            if cursor < clipped_start {
+                out.push((cursor, clipped_start));
+            }
+            cursor = cursor.max(e.min(end));
+            if cursor >= end {
+                break;
+            }
+        }
+        if cursor < end {
+            out.push((cursor, end));
+        }
+        out
+    }
+}
