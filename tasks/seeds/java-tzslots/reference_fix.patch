index 0000000..81c27de
--- /dev/null
+++ b/Participant.java
@@ -0,0 +1,27 @@
+import java.time.ZoneId;
+import java.util.List;
+
+/** One attendee: their zone, daily working window, and local busy blocks. */
+public record Participant(String name, ZoneId zone, TimeRange workday, List<TimeRange> busy) {
+
+    public Participant {
+        if (name == null) {
+            throw new IllegalArgumentException("name must not be null");
+        }
+        if (zone == null) {
+            throw new IllegalArgumentException("zone must not be null");
+        }
+        if (workday == null) {
+            throw new IllegalArgumentException("workday must not be null");
+        }
+        if (busy == null) {
+            throw new IllegalArgumentException("busy must not be null");
+        }
+        for (TimeRange range : busy) {
+            if (range == null) {
+                throw new IllegalArgumentException("busy must not contain null");
+            }
+        }
+        busy = List.copyOf(busy);
+    }
+}
