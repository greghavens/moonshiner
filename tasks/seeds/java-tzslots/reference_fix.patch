+++ b/MeetingSlots.java
@@ -0,0 +1,148 @@
+import java.time.Duration;
+import java.time.Instant;
+import java.time.LocalDate;
+import java.time.ZoneId;
+import java.time.ZonedDateTime;
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+
+/**
+ * Cross-timezone meeting-slot intersector. All interval arithmetic happens
+ * in instants; zones matter only when resolving each participant's local
+ * wall-clock times (ZonedDateTime.of gap/overlap rules) and when rendering
+ * the result in the display zone.
+ */
+public final class MeetingSlots {
+
+    private MeetingSlots() {
+    }
+
+    /** Inclusive-start, exclusive-end instant interval. */
+    private record Span(Instant start, Instant end) {
+    }
+
+    public static List<Slot> find(List<Participant> people, LocalDate date,
+                                  Duration minLength, ZoneId displayZone) {
+        if (people == null || people.isEmpty()) {
+            throw new IllegalArgumentException("people must not be empty");
+        }
+        for (Participant person : people) {
+            // (List.of() lists throw NPE on contains(null) — scan by hand.)
+            if (person == null) {
+                throw new IllegalArgumentException("people must not contain null");
+            }
+        }
+        if (date == null) {
+            throw new IllegalArgumentException("date must not be null");
+        }
+        if (minLength == null || minLength.isZero() || minLength.isNegative()) {
+            throw new IllegalArgumentException("minLength must be positive");
+        }
+        if (displayZone == null) {
+            throw new IllegalArgumentException("displayZone must not be null");
+        }
+
+        List<Span> common = null;
+        for (Participant person : people) {
+            List<Span> free = availability(person, date);
+            common = common == null ? free : intersect(common, free);
+        }
+
+        List<Slot> slots = new ArrayList<>();
+        for (Span span : common) {
+            if (Duration.between(span.start(), span.end()).compareTo(minLength) >= 0) {
+                slots.add(new Slot(ZonedDateTime.ofInstant(span.start(), displayZone),
+                        ZonedDateTime.ofInstant(span.end(), displayZone)));
+            }
+        }
+        slots.sort(Comparator.comparing(s -> s.start().toInstant()));
+        return List.copyOf(slots);
+    }
+
+    /** The participant's free instant-intervals on their own calendar date. */
+    private static List<Span> availability(Participant person, LocalDate date) {
+        Instant windowStart = resolve(date, person.workday().start(), person.zone());
+        Instant windowEnd = resolve(date, person.workday().end(), person.zone());
+        if (!windowStart.isBefore(windowEnd)) {
+            return List.of(); // whole window swallowed by a gap — nothing available
+        }
+
+        List<Span> busy = new ArrayList<>();
+        for (TimeRange range : person.busy()) {
+            Instant start = resolve(date, range.start(), person.zone());
+            Instant end = resolve(date, range.end(), person.zone());
+            if (start.isBefore(windowStart)) {
+                start = windowStart;
+            }
+            if (end.isAfter(windowEnd)) {
+                end = windowEnd;
+            }
+            if (start.isBefore(end)) {
+                busy.add(new Span(start, end)); // inverted/empty spans (gap-swallowed) drop out
+            }
+        }
+        busy.sort(Comparator.comparing(Span::start));
+
+        List<Span> merged = new ArrayList<>();
+        for (Span span : busy) {
+            Span last = merged.isEmpty() ? null : merged.get(merged.size() - 1);
+            if (last != null && !span.start().isAfter(last.end())) {
+                merged.set(merged.size() - 1,
+                        new Span(last.start(), max(last.end(), span.end())));
+            } else {
+                merged.add(span);
+            }
+        }
+
+        List<Span> free = new ArrayList<>();
+        Instant cursor = windowStart;
+        for (Span span : merged) {
+            if (cursor.isBefore(span.start())) {
+                free.add(new Span(cursor, span.start()));
+            }
+            cursor = max(cursor, span.end());
+        }
+        if (cursor.isBefore(windowEnd)) {
+            free.add(new Span(cursor, windowEnd));
+        }
+        return free;
+    }
+
+    /**
+     * Local wall time on `date` in `zone` as an instant, with the JDK's
+     * resolution rules: gap times slide forward, ambiguous times take the
+     * earlier offset.
+     */
+    private static Instant resolve(LocalDate date, java.time.LocalTime time, ZoneId zone) {
+        return ZonedDateTime.of(date, time, zone).toInstant();
+    }
+
+    /** Intersection of two ascending disjoint interval lists. */
+    private static List<Span> intersect(List<Span> a, List<Span> b) {
+        List<Span> out = new ArrayList<>();
+        int i = 0;
+        int j = 0;
+        while (i < a.size() && j < b.size()) {
+            Instant start = max(a.get(i).start(), b.get(j).start());
+            Instant end = min(a.get(i).end(), b.get(j).end());
+            if (start.isBefore(end)) {
+                out.add(new Span(start, end));
+            }
+            if (a.get(i).end().isBefore(b.get(j).end())) {
+                i++;
+            } else {
+                j++;
+            }
+        }
+        return out;
+    }
+
+    private static Instant max(Instant x, Instant y) {
+        return x.isAfter(y) ? x : y;
+    }
+
+    private static Instant min(Instant x, Instant y) {
+        return x.isBefore(y) ? x : y;
+    }
+}
diff --git a/Participant.java b/Participant.java
