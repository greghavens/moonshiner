+// Package ttlmap is a concurrency-safe map whose entries expire after a
+// per-entry TTL. There is no background janitor: expired entries are
+// deleted lazily on read and in bulk by an explicit Sweep.
+package ttlmap
+
+import (
+	"errors"
+	"sort"
+	"sync"
+	"time"
+)
+
+// Clock supplies the current time; injected so tests never sleep.
+type Clock interface {
+	Now() time.Time
+}
+
+type entry struct {
+	value   any
+	expires time.Time // zero => never expires
+}
+
+// expired reports whether the entry is dead at instant now.
+// The deadline itself counts as expired.
+func (e entry) expired(now time.Time) bool {
+	return !e.expires.IsZero() && !now.Before(e.expires)
+}
+
+// Map stores values with per-entry TTLs. Safe for concurrent use.
+type Map struct {
+	mu      sync.Mutex
+	clock   Clock
+	entries map[string]entry
+}
+
+// New builds an empty map using the given clock.
+func New(clock Clock) (*Map, error) {
+	if clock == nil {
+		return nil, errors.New("ttlmap: clock must not be nil")
+	}
+	return &Map{clock: clock, entries: make(map[string]entry)}, nil
+}
+
+// Set stores value under key, expiring at Now()+ttl. A ttl <= 0 pins the
+// entry forever. Overwrites replace the value and restart the TTL.
+func (m *Map) Set(key string, value any, ttl time.Duration) {
+	e := entry{value: value}
+	if ttl > 0 {
+		e.expires = m.clock.Now().Add(ttl)
+	}
+	m.mu.Lock()
+	m.entries[key] = e
+	m.mu.Unlock()
+}
+
+// Get returns the live value for key. Reading an expired entry deletes
+// it (read-expiry) and reports a miss.
+func (m *Map) Get(key string) (any, bool) {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	e, ok := m.entries[key]
+	if !ok {
+		return nil, false
+	}
+	if e.expired(m.clock.Now()) {
+		delete(m.entries, key)
+		return nil, false
+	}
+	return e.value, true
+}
+
+// Sweep deletes every expired entry and returns how many were removed.
+func (m *Map) Sweep() int {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	now := m.clock.Now()
+	removed := 0
+	for k, e := range m.entries {
+		if e.expired(now) {
+			delete(m.entries, k)
+			removed++
+		}
+	}
+	return removed
+}
+
+// Len counts live entries; expired-but-unswept corpses are excluded.
+func (m *Map) Len() int {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	now := m.clock.Now()
+	n := 0
+	for _, e := range m.entries {
+		if !e.expired(now) {
+			n++
+		}
+	}
+	return n
+}
+
+// Keys returns the sorted keys of live entries.
+func (m *Map) Keys() []string {
+	m.mu.Lock()
+	now := m.clock.Now()
+	keys := make([]string, 0, len(m.entries))
+	for k, e := range m.entries {
+		if !e.expired(now) {
+			keys = append(keys, k)
+		}
+	}
+	m.mu.Unlock()
+	sort.Strings(keys)
+	return keys
+}
+
+// Delete removes key and reports whether it was present and still live.
+func (m *Map) Delete(key string) bool {
+	m.mu.Lock()
+	defer m.mu.Unlock()
+	e, ok := m.entries[key]
+	if !ok {
+		return false
+	}
+	delete(m.entries, key)
+	return !e.expired(m.clock.Now())
+}
