+# strkit.ps1 — shared string helpers for the ops summary printers.
+# Dot-source this file; no regex operators, .NET string methods and -f only.
+
+function Format-TrimText {
+    param(
+        [Parameter(Mandatory)][AllowEmptyString()][string]$Text,
+        [string]$Chars
+    )
+    if ($PSBoundParameters.ContainsKey('Chars') -and $Chars.Length -gt 0) {
+        return $Text.Trim($Chars.ToCharArray())
+    }
+    return $Text.Trim()
+}
+
+function Format-PadText {
+    param(
+        [Parameter(Mandatory)][AllowEmptyString()][string]$Text,
+        [Parameter(Mandatory)][int]$Width,
+        [Parameter(Mandatory)][ValidateSet('left', 'right', 'center')][string]$Align,
+        [string]$PadChar = ' '
+    )
+    if ($Width -lt 0) { throw 'strkit: Width must be non-negative' }
+    if ($PadChar.Length -ne 1) { throw 'strkit: PadChar must be exactly one character' }
+    if ($Text.Length -ge $Width) { return $Text }
+    $pad = $PadChar[0]
+    switch ($Align) {
+        'left' { return $Text.PadRight($Width, $pad) }
+        'right' { return $Text.PadLeft($Width, $pad) }
+        'center' {
+            $extra = $Width - $Text.Length
+            $left = [int][math]::Floor($extra / 2)
+            return $Text.PadLeft($Text.Length + $left, $pad).PadRight($Width, $pad)
+        }
+    }
+}
+
+function Format-ClipText {
+    param(
+        [Parameter(Mandatory)][AllowEmptyString()][string]$Text,
+        [Parameter(Mandatory)][int]$Width,
+        [string]$Marker = '...'
+    )
+    if ($Width -lt 1) { throw 'strkit: Width must be at least 1' }
+    if ($Text.Length -le $Width) { return $Text }
+    if ($Width -le $Marker.Length) { return $Marker.Substring(0, $Width) }
+    return $Text.Substring(0, $Width - $Marker.Length) + $Marker
+}
+
+function ConvertTo-UpperText {
+    param([Parameter(Mandatory)][AllowEmptyString()][string]$Text)
+    return $Text.ToUpperInvariant()
+}
+
+function ConvertTo-LowerText {
+    param([Parameter(Mandatory)][AllowEmptyString()][string]$Text)
+    return $Text.ToLowerInvariant()
+}
+
+function ConvertTo-TitleText {
+    param([Parameter(Mandatory)][AllowEmptyString()][string]$Text)
+    $info = [System.Globalization.CultureInfo]::InvariantCulture.TextInfo
+    return $info.ToTitleCase($Text.ToLowerInvariant())
+}
+
+function Format-StatLine {
+    param(
+        [Parameter(Mandatory)][string]$Label,
+        [Parameter(Mandatory)][double]$Value
+    )
+    return '{0,-20} {1,12:N2}' -f $Label, $Value
+}
+
+function Format-CountLine {
+    param(
+        [Parameter(Mandatory)][string]$Label,
+        [Parameter(Mandatory)][long]$Count
+    )
+    return '{0}: {1:N0}' -f $Label, $Count
+}
