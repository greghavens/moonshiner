+export interface RetryContext {
+  attempt: number;
+  signal: AbortSignal;
+}
+
+export type DelayFn = (ms: number, signal: AbortSignal) => Promise<void>;
+
+export interface RetryOptions {
+  /** Total number of tries (including the first). */
+  attempts: number;
+  baseDelayMs: number;
+  factor?: number;
+  maxDelayMs?: number;
+  signal?: AbortSignal;
+  attemptTimeoutMs?: number;
+  delay?: DelayFn;
+}
+
+/** setTimeout-based wait that cancels its timer when the signal aborts. */
+export const defaultDelay: DelayFn = (ms, signal) =>
+  new Promise<void>((resolve, reject) => {
+    if (signal?.aborted) {
+      reject(signal.reason);
+      return;
+    }
+    const onAbort = () => {
+      clearTimeout(id);
+      reject(signal.reason);
+    };
+    const id = setTimeout(() => {
+      signal?.removeEventListener('abort', onAbort);
+      resolve();
+    }, ms);
+    signal?.addEventListener('abort', onAbort, { once: true });
+  });
+
+function timeoutError(attempt: number, ms: number): Error {
+  const err = new Error(`attempt ${attempt} timed out after ${ms}ms`);
+  err.name = 'TimeoutError';
+  return err;
+}
+
+export function retry<T>(fn: (ctx: RetryContext) => Promise<T>, opts: RetryOptions): Promise<T> {
+  if (!Number.isInteger(opts.attempts) || opts.attempts < 1) {
+    throw new TypeError(`attempts must be a positive integer, got ${opts.attempts}`);
+  }
+  return runRetry(fn, opts);
+}
+
+type Outcome<T> =
+  | { kind: 'ok'; value: T }
+  | { kind: 'err'; error: unknown }
+  | { kind: 'timeout' }
+  | { kind: 'aborted'; reason: unknown };
+
+async function runRetry<T>(fn: (ctx: RetryContext) => Promise<T>, opts: RetryOptions): Promise<T> {
+  const {
+    attempts,
+    baseDelayMs,
+    factor = 2,
+    maxDelayMs = Infinity,
+    signal: outer,
+    attemptTimeoutMs,
+    delay = defaultDelay,
+  } = opts;
+
+  let lastError: unknown;
+
+  for (let attempt = 1; attempt <= attempts; attempt++) {
+    if (outer?.aborted) throw outer.reason;
+
+    const attemptCtl = new AbortController();
+    const timerCtl = new AbortController();
+    const onOuterAbort = () => {
+      attemptCtl.abort(outer!.reason);
+      timerCtl.abort(outer!.reason);
+    };
+    outer?.addEventListener('abort', onOuterAbort, { once: true });
+
+    const attemptP = Promise.resolve().then(() => fn({ attempt, signal: attemptCtl.signal }));
+    const racers: Array<Promise<Outcome<T>>> = [
+      attemptP.then(
+        (value) => ({ kind: 'ok' as const, value }),
+        (error: unknown) => ({ kind: 'err' as const, error }),
+      ),
+    ];
+    if (outer) {
+      racers.push(
+        new Promise<Outcome<T>>((resolve) => {
+          outer.addEventListener('abort', () => resolve({ kind: 'aborted', reason: outer.reason }), {
+            once: true,
+          });
+        }),
+      );
+    }
+    if (attemptTimeoutMs !== undefined) {
+      racers.push(
+        delay(attemptTimeoutMs, timerCtl.signal).then(
+          () => ({ kind: 'timeout' as const }),
+          // Timer was cancelled because the attempt settled first: never wins.
+          () => new Promise<never>(() => {}),
+        ),
+      );
+    }
+
+    const outcome = await Promise.race(racers);
+    outer?.removeEventListener('abort', onOuterAbort);
+    timerCtl.abort(new Error('attempt settled'));
+    attemptP.catch(() => {}); // a losing attempt may still reject later
+
+    if (outcome.kind === 'ok') return outcome.value;
+    if (outcome.kind === 'aborted') {
+      attemptCtl.abort(outcome.reason);
+      throw outcome.reason;
+    }
+    if (outcome.kind === 'timeout') {
+      const err = timeoutError(attempt, attemptTimeoutMs!);
+      attemptCtl.abort(err);
+      lastError = err;
+    } else {
+      lastError = outcome.error;
+    }
+
+    if (outer?.aborted) throw outer.reason;
+
+    if (attempt < attempts) {
+      const backoff = Math.min(baseDelayMs * factor ** (attempt - 1), maxDelayMs);
+      await delay(backoff, outer ?? new AbortController().signal);
+    }
+  }
+
+  throw lastError;
+}
