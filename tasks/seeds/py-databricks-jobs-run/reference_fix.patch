@@ -0,0 +1,55 @@
+"""One-time run orchestration: submit idempotently, poll, collect, cancel."""
+
+import uuid
+from dataclasses import dataclass, field
+
+
+@dataclass
+class RunReport:
+    run_id: int
+    life_cycle_state: str
+    result_state: str
+    termination: dict
+    canceled: bool = False
+    task_outputs: dict = field(default_factory=dict)
+    task_errors: dict = field(default_factory=dict)
+
+
+class OneTimeRunner:
+    def __init__(self, client, poll_interval=5):
+        self.client = client
+        self.poll_interval = poll_interval
+
+    def run(self, tasks, run_name=None, idempotency_token=None, cancel=None):
+        token = idempotency_token or uuid.uuid4().hex
+        run_id = self.client.submit_run(tasks, run_name=run_name,
+                                        idempotency_token=token)
+        cancel_sent = False
+        run = self.client.get_run(run_id)
+        while run["status"]["state"] != "TERMINATED":
+            if cancel is not None and not cancel_sent and cancel():
+                self.client.cancel_run(run_id)
+                cancel_sent = True
+            self.client._sleep(self.poll_interval)
+            run = self.client.get_run(run_id)
+
+        termination = run["status"].get("termination_details", {})
+        result_state = run.get("state", {}).get("result_state", "")
+        report = RunReport(
+            run_id=run_id,
+            life_cycle_state=run["status"]["state"],
+            result_state=result_state,
+            termination=termination,
+            canceled=result_state == "CANCELED",
+        )
+        if not report.canceled:
+            for task in run.get("tasks", []):
+                output = self.client.get_run_output(task["run_id"])
+                if "error" in output:
+                    report.task_errors[task["task_key"]] = {
+                        "error": output.get("error"),
+                        "error_trace": output.get("error_trace"),
+                    }
+                else:
+                    report.task_outputs[task["task_key"]] = output
+        return report
