+// Package logfmt encodes and decodes key=value log lines with quoting,
+// escaping, and typed values (string, int64, float64, bool,
+// time.Duration). Field order is preserved in both directions and decode
+// errors carry exact byte offsets.
+package logfmt
+
+import (
+	"fmt"
+	"strconv"
+	"strings"
+	"time"
+)
+
+// Field is one key/value pair in a logfmt line.
+type Field struct {
+	Key   string
+	Value any
+}
+
+// SyntaxError reports malformed input to Decode. Pos is the 0-based byte
+// offset of the offending character.
+type SyntaxError struct {
+	Pos int
+	Msg string
+}
+
+func (e *SyntaxError) Error() string {
+	return fmt.Sprintf("logfmt: %s at offset %d", e.Msg, e.Pos)
+}
+
+func syntaxErr(pos int, msg string) error {
+	return &SyntaxError{Pos: pos, Msg: msg}
+}
+
+// validKey reports whether key can be encoded: non-empty and free of
+// spaces, '=', '"', '\' and control characters.
+func validKey(key string) bool {
+	if key == "" {
+		return false
+	}
+	for _, r := range key {
+		if r == ' ' || r == '=' || r == '"' || r == '\\' || r < 0x20 || r == 0x7f {
+			return false
+		}
+	}
+	return true
+}
+
+// needsQuotes reports whether a string value must be quoted.
+func needsQuotes(s string) bool {
+	if s == "" {
+		return true
+	}
+	for _, r := range s {
+		if r == ' ' || r == '=' || r == '"' || r == '\\' || r < 0x20 || r == 0x7f {
+			return true
+		}
+	}
+	return false
+}
+
+// quote renders s inside double quotes with the dialect's four escapes.
+func quote(s string) string {
+	var b strings.Builder
+	b.WriteByte('"')
+	for _, r := range s {
+		switch r {
+		case '\\':
+			b.WriteString(`\\`)
+		case '"':
+			b.WriteString(`\"`)
+		case '\n':
+			b.WriteString(`\n`)
+		case '\t':
+			b.WriteString(`\t`)
+		default:
+			b.WriteRune(r)
+		}
+	}
+	b.WriteByte('"')
+	return b.String()
+}
+
+// Encode renders fields as one logfmt line, preserving key order.
+func Encode(fields []Field) (string, error) {
+	parts := make([]string, 0, len(fields))
+	for _, f := range fields {
+		if !validKey(f.Key) {
+			return "", fmt.Errorf("logfmt: invalid key %q", f.Key)
+		}
+		var rendered string
+		switch v := f.Value.(type) {
+		case string:
+			if needsQuotes(v) {
+				rendered = quote(v)
+			} else {
+				rendered = v
+			}
+		case int:
+			rendered = strconv.FormatInt(int64(v), 10)
+		case int64:
+			rendered = strconv.FormatInt(v, 10)
+		case float64:
+			rendered = strconv.FormatFloat(v, 'g', -1, 64)
+		case bool:
+			rendered = strconv.FormatBool(v)
+		case time.Duration:
+			rendered = v.String()
+		default:
+			return "", fmt.Errorf("logfmt: unsupported value type %T for key %q", f.Value, f.Key)
+		}
+		parts = append(parts, f.Key+"="+rendered)
+	}
+	return strings.Join(parts, " "), nil
+}
+
+// inferValue types a bare (unquoted) value: bool, then int64, then
+// float64, then time.Duration, falling back to string.
+func inferValue(s string) any {
+	switch s {
+	case "true":
+		return true
+	case "false":
+		return false
+	}
+	if n, err := strconv.ParseInt(s, 10, 64); err == nil {
+		return n
+	}
+	if f, err := strconv.ParseFloat(s, 64); err == nil {
+		return f
+	}
+	if d, err := time.ParseDuration(s); err == nil {
+		return d
+	}
+	return s
+}
+
+// Decode parses one logfmt line into fields, preserving order and
+// duplicate keys. Malformed input yields a *SyntaxError.
+func Decode(line string) ([]Field, error) {
+	var fields []Field
+	i := 0
+	n := len(line)
+	for {
+		for i < n && line[i] == ' ' {
+			i++
+		}
+		if i >= n {
+			return fields, nil
+		}
+
+		// Key: up to '=' or space.
+		keyStart := i
+		for i < n && line[i] != '=' && line[i] != ' ' {
+			i++
+		}
+		key := line[keyStart:i]
+
+		if i >= n || line[i] == ' ' {
+			// Bare key: a boolean flag.
+			fields = append(fields, Field{Key: key, Value: true})
+			continue
+		}
+
+		// line[i] is '='.
+		if key == "" {
+			return nil, syntaxErr(i, "empty key")
+		}
+		i++ // consume '='
+
+		if i < n && line[i] == '"' {
+			openQuote := i
+			i++
+			var b strings.Builder
+			closed := false
+			for i < n {
+				c := line[i]
+				if c == '"' {
+					closed = true
+					i++
+					break
+				}
+				if c == '\\' {
+					if i+1 >= n {
+						return nil, syntaxErr(i, "dangling escape")
+					}
+					switch line[i+1] {
+					case '\\':
+						b.WriteByte('\\')
+					case '"':
+						b.WriteByte('"')
+					case 'n':
+						b.WriteByte('\n')
+					case 't':
+						b.WriteByte('\t')
+					default:
+						return nil, syntaxErr(i, fmt.Sprintf("unknown escape \\%c", line[i+1]))
+					}
+					i += 2
+					continue
+				}
+				b.WriteByte(c)
+				i++
+			}
+			if !closed {
+				return nil, syntaxErr(openQuote, "unterminated quoted value")
+			}
+			if i < n && line[i] != ' ' {
+				return nil, syntaxErr(i, "unexpected character after closing quote")
+			}
+			fields = append(fields, Field{Key: key, Value: b.String()})
+			continue
+		}
+
+		// Bare value: up to the next space; quotes are not allowed inside.
+		valStart := i
+		for i < n && line[i] != ' ' {
+			if line[i] == '"' {
+				return nil, syntaxErr(i, "quote inside unquoted value")
+			}
+			i++
+		}
+		fields = append(fields, Field{Key: key, Value: inferValue(line[valStart:i])})
+	}
+}
