+"""Feature-usage metering transforms: retry dedupe, sessionization, funnels.
+
+Pure functions over lists of event dicts. An event carries ``user``, ``name``,
+``ts`` (epoch seconds) and optionally ``key`` — the client SDK's idempotency
+key, reused by retried uploads. Inputs are never mutated.
+"""
+
+
+def dedupe(events):
+    """Drop retried events: keep the first occurrence of each idempotency key.
+
+    First is by input order (uploads can arrive out of timestamp order), and
+    keys are global across users. Keyless events always pass through.
+    """
+    seen = set()
+    out = []
+    for event in events:
+        key = event.get("key")
+        if key is not None:
+            if key in seen:
+                continue
+            seen.add(key)
+        out.append(event)
+    return out
+
+
+def _by_user_sorted(events):
+    """Group events per user, each group stable-sorted by timestamp."""
+    grouped = {}
+    for event in events:
+        grouped.setdefault(event["user"], []).append(event)
+    for user in grouped:
+        grouped[user] = sorted(grouped[user], key=lambda e: e["ts"])
+    return grouped
+
+
+def sessionize(events, gap):
+    """Split each user's activity into sessions on inactivity gaps.
+
+    A new session starts when the delta between consecutive events exceeds
+    ``gap`` seconds; a delta of exactly ``gap`` stays in the same session.
+    """
+    if gap <= 0:
+        raise ValueError("gap must be > 0")
+    sessions = []
+    for user, stream in _by_user_sorted(events).items():
+        current = [stream[0]]
+        for event in stream[1:]:
+            if event["ts"] - current[-1]["ts"] > gap:
+                sessions.append(_session(user, current))
+                current = [event]
+            else:
+                current.append(event)
+        sessions.append(_session(user, current))
+    sessions.sort(key=lambda s: (s["user"], s["start"]))
+    return sessions
+
+
+def _session(user, batch):
+    start, end = batch[0]["ts"], batch[-1]["ts"]
+    return {
+        "user": user,
+        "start": start,
+        "end": end,
+        "duration": end - start,
+        "events": list(batch),
+    }
+
+
+def funnel(events, steps):
+    """Ordered funnel with first-touch anchoring.
+
+    Per user, the anchor is the first occurrence of steps[0]; every following
+    step must occur strictly after the previously matched event (by position
+    in the stable timestamp ordering). Users are counted at every step they
+    reached.
+    """
+    if not steps:
+        raise ValueError("steps must be a non-empty list")
+    reached = [set() for _ in steps]
+    for user, stream in _by_user_sorted(events).items():
+        pos = -1
+        for depth, step in enumerate(steps):
+            found = None
+            for i in range(pos + 1, len(stream)):
+                if stream[i]["name"] == step:
+                    found = i
+                    break
+            if found is None:
+                break
+            pos = found
+            reached[depth].add(user)
+    return [
+        {"step": step, "count": len(users), "users": sorted(users)}
+        for step, users in zip(steps, reached)
+    ]
+
+
+def usage_report(events, gap, steps):
+    """The glued pipeline: dedupe first, then sessions and funnel on the result."""
+    deduped = dedupe(events)
+    sessions = sessionize(deduped, gap)
+    by_user = {}
+    for session in sessions:
+        by_user[session["user"]] = by_user.get(session["user"], 0) + 1
+    return {
+        "event_count": len(deduped),
+        "user_count": len({e["user"] for e in deduped}),
+        "session_count": len(sessions),
+        "sessions_by_user": by_user,
+        "funnel": funnel(deduped, steps),
+    }
