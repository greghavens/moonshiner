index 0000000..1ed2d7c
--- /dev/null
+++ b/textgrid.ps1
@@ -0,0 +1,78 @@
+# textgrid.ps1 — hand-rendered fixed-width tables for the capacity reviews.
+# The stock rendering cmdlets are banned near pinned output; this renderer
+# is deterministic by construction.
+
+function Format-TextGrid {
+    param(
+        [Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Rows,
+        [int]$MaxWidth = 0
+    )
+    if ($PSBoundParameters.ContainsKey('MaxWidth') -and $MaxWidth -lt 4) {
+        throw 'textgrid: MaxWidth must be at least 4'
+    }
+    if ($null -eq $Rows -or $Rows.Count -eq 0) {
+        throw 'textgrid: no rows'
+    }
+
+    $numericTypes = @([byte], [sbyte], [int16], [uint16], [int], [uint32],
+        [long], [uint64], [single], [double], [decimal])
+
+    function Render-Cell {
+        param($Value)
+        if ($null -eq $Value) { return '' }
+        if ($Value -is [string]) { return $Value }
+        foreach ($t in $numericTypes) {
+            if ($Value -is $t) {
+                return [System.Convert]::ToString($Value, [System.Globalization.CultureInfo]::InvariantCulture)
+            }
+        }
+        return [string]$Value
+    }
+
+    function Clip-Cell {
+        param([string]$Text)
+        if ($MaxWidth -ge 4 -and $Text.Length -gt $MaxWidth) {
+            return $Text.Substring(0, $MaxWidth - 3) + '...'
+        }
+        return $Text
+    }
+
+    $first = $Rows[0]
+    $columns = @(foreach ($prop in $first.PSObject.Properties) {
+        $isNumeric = $false
+        foreach ($t in $numericTypes) {
+            if ($prop.Value -is $t) { $isNumeric = $true; break }
+        }
+        @{ Name = $prop.Name; Header = Clip-Cell $prop.Name; Right = $isNumeric }
+    })
+
+    $table = @(foreach ($row in $Rows) {
+        , @(foreach ($col in $columns) { Clip-Cell (Render-Cell $row.($col.Name)) })
+    })
+
+    foreach ($col in $columns) { $col.Width = $col.Header.Length }
+    foreach ($cells in $table) {
+        for ($c = 0; $c -lt $cells.Count; $c++) {
+            if ($cells[$c].Length -gt $columns[$c].Width) {
+                $columns[$c].Width = $cells[$c].Length
+            }
+        }
+    }
+
+    function Render-Line {
+        param([string[]]$Cells)
+        $parts = for ($c = 0; $c -lt $Cells.Count; $c++) {
+            if ($columns[$c].Right) { $Cells[$c].PadLeft($columns[$c].Width) }
+            else { $Cells[$c].PadRight($columns[$c].Width) }
+        }
+        return ($parts -join '  ').TrimEnd()
+    }
+
+    $lines = [System.Collections.Generic.List[string]]::new()
+    $lines.Add((Render-Line @($columns | ForEach-Object { $_.Header })))
+    $lines.Add((Render-Line @($columns | ForEach-Object { '-' * $_.Width })))
+    foreach ($cells in $table) {
+        $lines.Add((Render-Line $cells))
+    }
+    return $lines -join "`n"
+}
