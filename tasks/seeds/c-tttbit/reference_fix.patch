diff --git a/tttbit.c b/tttbit.c
new file mode 100644
index 0000000..7057e55
--- /dev/null
+++ b/tttbit.c
@@ -0,0 +1,106 @@
+#include "tttbit.h"
+
+#define FULL 0x1FFu
+#define NCODES 19683 /* 3^9 */
+
+static const uint16_t lines[8] = {
+    0x007, 0x038, 0x1C0, /* rows */
+    0x049, 0x092, 0x124, /* columns */
+    0x111, 0x054         /* diagonals */
+};
+
+uint16_t ttt_line(int i) {
+    if (i < 0 || i > 7) return 0;
+    return lines[i];
+}
+
+int ttt_has_win(uint16_t m) {
+    for (int i = 0; i < 8; i++)
+        if ((m & lines[i]) == lines[i]) return 1;
+    return 0;
+}
+
+uint16_t ttt_moves(uint16_t x, uint16_t o) {
+    if (ttt_has_win(x) || ttt_has_win(o)) return 0;
+    return (uint16_t)(~(x | o) & FULL);
+}
+
+/* ternary board code: cell i contributes 0 empty / 1 X / 2 O times 3^i */
+static int code_of(uint16_t x, uint16_t o) {
+    int code = 0, pow = 1;
+    for (int i = 0; i < 9; i++) {
+        if (x & (1u << i)) code += pow;
+        else if (o & (1u << i)) code += 2 * pow;
+        pow *= 3;
+    }
+    return code;
+}
+
+/* memo per (code, side to move): 0 = unknown, else value + 2 (1..3) */
+static int8_t memo[2][NCODES];
+
+int ttt_value(uint16_t x, uint16_t o, int xturn) {
+    if (ttt_has_win(x)) return 1;
+    if (ttt_has_win(o)) return -1;
+    if ((x | o) == FULL) return 0;
+
+    int turn = xturn ? 1 : 0;
+    int code = code_of(x, o);
+    if (memo[turn][code]) return memo[turn][code] - 2;
+
+    int best = xturn ? -2 : 2;
+    for (int i = 0; i < 9; i++) {
+        uint16_t b = (uint16_t)(1u << i);
+        if ((x | o) & b) continue;
+        int v = xturn ? ttt_value((uint16_t)(x | b), o, 0)
+                      : ttt_value(x, (uint16_t)(o | b), 1);
+        if (xturn ? (v > best) : (v < best)) best = v;
+    }
+    memo[turn][code] = (int8_t)(best + 2);
+    return best;
+}
+
+int ttt_best(uint16_t x, uint16_t o, int xturn) {
+    if (ttt_moves(x, o) == 0) return -1;
+    int bestmove = -1, best = xturn ? -2 : 2;
+    for (int i = 0; i < 9; i++) {
+        uint16_t b = (uint16_t)(1u << i);
+        if ((x | o) & b) continue;
+        int v = xturn ? ttt_value((uint16_t)(x | b), o, 0)
+                      : ttt_value(x, (uint16_t)(o | b), 1);
+        if (xturn ? (v > best) : (v < best)) {
+            best = v;
+            bestmove = i;
+        }
+    }
+    return bestmove;
+}
+
+static uint8_t seen[NCODES];
+static long n_seen, n_xw, n_ow, n_dr;
+
+static void explore(uint16_t x, uint16_t o, int xturn) {
+    int code = code_of(x, o);
+    if (seen[code]) return;
+    seen[code] = 1;
+    n_seen++;
+    if (ttt_has_win(x)) { n_xw++; return; }
+    if (ttt_has_win(o)) { n_ow++; return; }
+    if ((x | o) == FULL) { n_dr++; return; }
+    for (int i = 0; i < 9; i++) {
+        uint16_t b = (uint16_t)(1u << i);
+        if ((x | o) & b) continue;
+        if (xturn) explore((uint16_t)(x | b), o, 0);
+        else explore(x, (uint16_t)(o | b), 1);
+    }
+}
+
+long ttt_reachable(long *xwins, long *owins, long *draws) {
+    for (int i = 0; i < NCODES; i++) seen[i] = 0;
+    n_seen = n_xw = n_ow = n_dr = 0;
+    explore(0, 0, 1);
+    if (xwins) *xwins = n_xw;
+    if (owins) *owins = n_ow;
+    if (draws) *draws = n_dr;
+    return n_seen;
+}
diff --git a/tttbit.h b/tttbit.h
new file mode 100644
index 0000000..2ebea8b
--- /dev/null
+++ b/tttbit.h
@@ -0,0 +1,13 @@
+#ifndef TTTBIT_H
+#define TTTBIT_H
+
+#include <stdint.h>
+
+uint16_t ttt_line(int i);
+int      ttt_has_win(uint16_t m);
+uint16_t ttt_moves(uint16_t x, uint16_t o);
+int      ttt_value(uint16_t x, uint16_t o, int xturn);
+int      ttt_best(uint16_t x, uint16_t o, int xturn);
+long     ttt_reachable(long *xwins, long *owins, long *draws);
+
+#endif /* TTTBIT_H */
