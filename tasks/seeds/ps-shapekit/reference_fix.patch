+# shapekit.ps1 — shape raw kiosk telemetry records for the signage dashboard.
+# Dot-source this file; everything here must be StrictMode-clean.
+
+function ConvertTo-KioskCard {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)]$Record
+    )
+    $names = @($Record.PSObject.Properties.Name)
+    foreach ($required in @('hostName', 'siteCode', 'uptimeMinutes', 'errorCount')) {
+        if ($names -cnotcontains $required) {
+            throw "shapekit: record is missing required property '$required'"
+        }
+    }
+    $minutes = [int]$Record.uptimeMinutes
+    $days = [math]::Floor($minutes / 1440)
+    $hours = [math]::Floor(($minutes % 1440) / 60)
+    $errors = [int]$Record.errorCount
+    $health = if ($errors -eq 0) { 'ok' } elseif ($errors -le 5) { 'watch' } else { 'fault' }
+    $noteProp = $Record.PSObject.Properties['note']
+    $note = if (($null -eq $noteProp) -or ($null -eq $noteProp.Value)) { '(none)' } else { [string]$noteProp.Value }
+    return [pscustomobject][ordered]@{
+        Kiosk  = [string]$Record.hostName
+        Site   = [string]$Record.siteCode
+        Uptime = '{0}d{1}h' -f $days, $hours
+        Health = $health
+        Note   = $note
+    }
+}
+
+function Select-CardField {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)]$Card,
+        [Parameter(Mandatory)][string[]]$Name
+    )
+    $bag = [ordered]@{}
+    foreach ($n in $Name) {
+        $prop = $Card.PSObject.Properties[$n]
+        if ($null -eq $prop) {
+            throw "shapekit: unknown field '$n'"
+        }
+        $bag[$n] = $prop.Value
+    }
+    return [pscustomobject]$bag
+}
+
+function Measure-FieldCoverage {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][AllowEmptyCollection()][AllowNull()][object[]]$Records,
+        [Parameter(Mandatory)][string]$Name
+    )
+    $present = 0
+    $missing = 0
+    foreach ($record in $Records) {
+        if ($null -eq $record) { continue }
+        if ($null -ne $record.PSObject.Properties[$Name]) { $present++ } else { $missing++ }
+    }
+    return [pscustomobject][ordered]@{ Field = $Name; Present = $present; Missing = $missing }
+}
