 // state machine: a transition table plus business guards, with an
 // append-only history of every transition the order takes.
 //
+// Beyond the happy path the machine carries the compensation flows agreed
+// with finance: cancelling before or after payment, returns after delivery,
+// and refunds that must balance captured money before an order may close.
+//
 // Money amounts are integer cents. The package is a pure decision core:
 // no payment gateway calls, no clocks, no storage — callers own all of that.
 package order
@@ -20,6 +24,9 @@ const (
 	StatePaid      State = "paid"
 	StateShipped   State = "shipped"
 	StateDelivered State = "delivered"
+	StateCancelled State = "cancelled"
+	StateReturned  State = "returned"
+	StateClosed    State = "closed"
 )
 
 // Event is a lifecycle transition trigger.
@@ -30,15 +37,29 @@ const (
 	EventPay     Event = "pay"
 	EventShip    Event = "ship"
 	EventDeliver Event = "deliver"
+	EventCancel  Event = "cancel"
+	EventReturn  Event = "return"
+	EventRefund  Event = "refund"
+)
+
+// Role identifies who is asking for a gated transition.
+type Role string
+
+const (
+	RoleCustomer Role = "customer"
+	RoleAgent    Role = "agent"
 )
 
 // transitions is the machine: which event is legal in which state, and
 // where it goes.
 var transitions = map[State]map[Event]State{
-	StateCart:    {EventPlace: StatePlaced},
-	StatePlaced:  {EventPay: StatePaid},
-	StatePaid:    {EventShip: StateShipped},
-	StateShipped: {EventDeliver: StateDelivered},
+	StateCart:      {EventPlace: StatePlaced},
+	StatePlaced:    {EventPay: StatePaid, EventCancel: StateClosed},
+	StatePaid:      {EventShip: StateShipped, EventCancel: StateCancelled},
+	StateShipped:   {EventDeliver: StateDelivered},
+	StateDelivered: {EventReturn: StateReturned},
+	StateCancelled: {EventRefund: StateClosed},
+	StateReturned:  {EventRefund: StateClosed},
 }
 
 // TransitionError reports an event that is not legal in the current state.
@@ -62,12 +83,31 @@ func (e *GuardError) Error() string {
 	return fmt.Sprintf("guard refused %q: %s", e.Event, e.Reason)
 }
 
+// PermissionError reports a role that may not trigger a gated transition.
+type PermissionError struct {
+	Role  Role
+	Event Event
+}
+
+func (e *PermissionError) Error() string {
+	return fmt.Sprintf("role %q may not trigger %q", e.Role, e.Event)
+}
+
+// InvariantError reports a history that violates the audit rules.
+type InvariantError struct {
+	Reason string
