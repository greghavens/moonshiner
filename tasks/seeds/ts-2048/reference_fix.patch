+// 2048 engine with fully pinned determinism: merge law is exact (one merge
+// per tile per move, traversal from the edge you push toward), and spawns
+// come from a 31-bit LCG so every game replays identically from its seed.
+
+export type Dir = 'left' | 'right' | 'up' | 'down';
+
+export interface Game {
+  readonly board: ReadonlyArray<ReadonlyArray<number>>; // 4x4, 0 = empty
+  readonly score: number;
+  readonly state: number; // current LCG state
+  readonly won: boolean;  // sticky once a 2048 tile exists
+}
+
+const M = 2147483648; // 2^31
+
+// state' = (state * 1103515245 + 12345) mod 2^31 — the product overflows
+// double precision, so do the multiply exactly.
+export function lcg(state: number): number {
+  return Number((BigInt(state) * 1103515245n + 12345n) % BigInt(M));
+}
+
+// Slide one 4-cell line toward index 0: compact, then merge equal adjacent
+// pairs starting at the near edge; a tile born from a merge never merges
+// again in the same move. Returns the new line and the points gained.
+export function slide(line: ReadonlyArray<number>): { line: number[]; gained: number } {
+  const tiles = line.filter((v) => v !== 0);
+  const out: number[] = [];
+  let gained = 0;
+  for (let i = 0; i < tiles.length; i++) {
+    if (i + 1 < tiles.length && tiles[i] === tiles[i + 1]) {
+      out.push(tiles[i] * 2);
+      gained += tiles[i] * 2;
+      i++;
+    } else {
+      out.push(tiles[i]);
+    }
+  }
+  while (out.length < line.length) out.push(0);
+  return { line: out, gained };
+}
+
+function boardsEqual(a: ReadonlyArray<ReadonlyArray<number>>, b: number[][]): boolean {
+  for (let r = 0; r < 4; r++) {
+    for (let c = 0; c < 4; c++) {
+      if (a[r][c] !== b[r][c]) return false;
+    }
+  }
+  return true;
+}
+
+// Spawn one tile: free cells are enumerated row-major; one LCG draw picks
+// the position (draw % freeCount), a second draw picks the value (4 when
+// draw % 10 === 0, else 2). Mutates board, returns the advanced state.
+function spawn(board: number[][], state: number): number {
+  const free: Array<[number, number]> = [];
+  for (let r = 0; r < 4; r++) {
+    for (let c = 0; c < 4; c++) {
+      if (board[r][c] === 0) free.push([r, c]);
+    }
+  }
+  let s = lcg(state);
+  const [r, c] = free[s % free.length];
+  s = lcg(s);
+  board[r][c] = s % 10 === 0 ? 4 : 2;
+  return s;
+}
+
+export function newGame(seed: number): Game {
+  const board: number[][] = Array.from({ length: 4 }, () => [0, 0, 0, 0]);
+  let state = ((seed % M) + M) % M;
+  state = spawn(board, state);
+  state = spawn(board, state);
+  return { board, score: 0, state, won: hasWon(board) };
+}
+
+function hasWon(board: number[][] | ReadonlyArray<ReadonlyArray<number>>): boolean {
+  return board.some((row) => row.some((v) => v >= 2048));
+}
+
+export function move(game: Game, dir: Dir): Game {
+  const next: number[][] = Array.from({ length: 4 }, () => [0, 0, 0, 0]);
+  let gained = 0;
+
+  const put = (line: number[], set: (i: number, v: number) => void) => {
+    const res = slide(line);
+    gained += res.gained;
+    res.line.forEach((v, i) => set(i, v));
+  };
+
+  if (dir === 'left') {
+    for (let r = 0; r < 4; r++) {
+      put([...game.board[r]], (i, v) => { next[r][i] = v; });
+    }
+  } else if (dir === 'right') {
+    for (let r = 0; r < 4; r++) {
+      put([...game.board[r]].reverse(), (i, v) => { next[r][3 - i] = v; });
+    }
+  } else if (dir === 'up') {
+    for (let c = 0; c < 4; c++) {
+      put([0, 1, 2, 3].map((r) => game.board[r][c]), (i, v) => { next[i][c] = v; });
+    }
+  } else if (dir === 'down') {
+    for (let c = 0; c < 4; c++) {
+      put([3, 2, 1, 0].map((r) => game.board[r][c]), (i, v) => { next[3 - i][c] = v; });
+    }
+  } else {
+    throw new Error(`bad direction: ${dir}`);
+  }
+
+  if (boardsEqual(game.board, next)) return game;
+  const state = spawn(next, game.state);
+  return {
+    board: next,
+    score: game.score + gained,
+    state,
+    won: game.won || hasWon(next),
+  };
+}
+
+export function gameOver(game: Game): boolean {
+  for (let r = 0; r < 4; r++) {
+    for (let c = 0; c < 4; c++) {
+      const v = game.board[r][c];
+      if (v === 0) return false;
+      if (c + 1 < 4 && game.board[r][c + 1] === v) return false;
+      if (r + 1 < 4 && game.board[r + 1][c] === v) return false;
+    }
+  }
+  return true;
+}
+
+const LETTER: Record<string, Dir> = { L: 'left', R: 'right', U: 'up', D: 'down' };
+
+// Replay a move script like 'LLUR'. Impossible moves are no-ops (the board
+// keeps its state); unknown letters throw.
+export function play(seed: number, moves: string): Game {
+  let g = newGame(seed);
+  for (const ch of moves) {
+    const dir = LETTER[ch];
+    if (!dir) throw new Error(`bad move letter: ${ch}`);
+    g = move(g, dir);
+  }
+  return g;
+}
+
+// Each cell right-aligned to width 4 ('.' for empty), cells joined with '|',
+// rows joined with '\n', no trailing newline.
+export function render(game: Game): string {
+  return game.board
+    .map((row) => row.map((v) => String(v === 0 ? '.' : v).padStart(4)).join('|'))
+    .join('\n');
+}
