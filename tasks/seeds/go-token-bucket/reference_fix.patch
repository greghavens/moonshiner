+// Package ratelimit provides a token-bucket rate limiter with an
+// injectable clock so callers can test without real sleeps.
+package ratelimit
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"sync"
+	"time"
+)
+
+// Clock abstracts time for the bucket. Production code passes a wrapper
+// around the time package; tests pass a fake.
+type Clock interface {
+	Now() time.Time
+	After(d time.Duration) <-chan time.Time
+}
+
+// Bucket is a token bucket: it holds up to capacity tokens and
+// regenerates one token every refill interval. Safe for concurrent use.
+type Bucket struct {
+	mu       sync.Mutex
+	capacity int
+	refill   time.Duration
+	clock    Clock
+
+	tokens int
+	// last marks the instant the current refill interval started.
+	// While the bucket is full it tracks "now" so idle time banks nothing.
+	last time.Time
+}
+
+// New builds a full bucket that regenerates one token per refill interval.
+func New(capacity int, refill time.Duration, clock Clock) (*Bucket, error) {
+	if capacity <= 0 {
+		return nil, fmt.Errorf("ratelimit: capacity must be positive, got %d", capacity)
+	}
+	if refill <= 0 {
+		return nil, fmt.Errorf("ratelimit: refill interval must be positive, got %v", refill)
+	}
+	if clock == nil {
+		return nil, errors.New("ratelimit: clock must not be nil")
+	}
+	return &Bucket{
+		capacity: capacity,
+		refill:   refill,
+		clock:    clock,
+		tokens:   capacity,
+		last:     clock.Now(),
+	}, nil
+}
+
+// accrue credits whole tokens earned since last. Callers hold b.mu.
+// Partial progress toward the next token is preserved by advancing last
+// by whole intervals only, never snapping it to now while below capacity.
+func (b *Bucket) accrue() {
+	now := b.clock.Now()
+	if b.tokens >= b.capacity {
+		b.last = now
+		return
+	}
+	earned := int(now.Sub(b.last) / b.refill)
+	if earned <= 0 {
+		return
+	}
+	if b.tokens+earned >= b.capacity {
+		b.tokens = b.capacity
+		b.last = now
+		return
+	}
+	b.tokens += earned
+	b.last = b.last.Add(time.Duration(earned) * b.refill)
+}
+
+// Allow takes one token if available.
+func (b *Bucket) Allow() bool { return b.AllowN(1) }
+
+// AllowN takes n tokens if all are available; otherwise it takes nothing.
+// n <= 0 succeeds trivially. n > capacity can never be satisfied and
+// always fails without consuming anything.
+func (b *Bucket) AllowN(n int) bool {
+	if n <= 0 {
+		return true
+	}
+	b.mu.Lock()
+	defer b.mu.Unlock()
+	if n > b.capacity {
+		return false
+	}
+	b.accrue()
+	if b.tokens < n {
+		return false
+	}
+	b.tokens -= n
+	return true
+}
+
+// Wait blocks until one token is available and consumes it. If a token is
+// already available it returns immediately without consulting the clock's
+// After. Otherwise it computes the time remaining until the next token
+// accrues and performs a single sleep of exactly that duration. If ctx is
+// canceled while waiting, the ctx error is returned and no token is taken.
+func (b *Bucket) Wait(ctx context.Context) error {
+	for {
+		b.mu.Lock()
+		b.accrue()
+		if b.tokens > 0 {
+			b.tokens--
+			b.mu.Unlock()
+			return nil
+		}
+		// Time until the current interval completes and yields a token.
+		remaining := b.refill - b.clock.Now().Sub(b.last)
+		b.mu.Unlock()
+
+		select {
+		case <-ctx.Done():
+			return ctx.Err()
+		case <-b.clock.After(remaining):
+			// Re-check: the token should have accrued; if a concurrent
+			// caller grabbed it we compute a fresh sleep.
+		}
+	}
+}
