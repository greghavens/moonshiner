+#!/usr/bin/env python3
+"""Produce the reference reconciliation through genuine two-stage execution."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import subprocess
+import sys
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+CLIENT = ROOT / "bin" / "course-records"
+TARGETS = (
+    ("Applied Microeconomics Seminar", "Downtown Campus"),
+    ("Modern Cities History Lab", "North Campus"),
+)
+
+
+def run_parallel(commands: list[list[str]]) -> list[dict[str, Any]]:
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdin=subprocess.DEVNULL,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    results: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate()
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "course-record command failed")
+        result = json.loads(stdout)
+        if not isinstance(result, dict):
+            raise RuntimeError("course-record command returned a non-object")
+        results.append(result)
+    return results
+
+
+def stage_search() -> int:
+    commands = [
+        [
+            str(CLIENT),
+            "search",
+            "--name",
+            name,
+            "--location",
+            location,
+        ]
+        for name, location in TARGETS
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def stage_get(stable_ids: list[str]) -> int:
+    commands = [
+        [str(CLIENT), "get", "--id", stable_id] for stable_id in stable_ids
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def unique_stable_id(result: dict[str, Any]) -> str | None:
+    matches = result.get("matches")
+    if not isinstance(matches, list):
+        return None
+    stable_ids = {
+        match.get("stable_id")
+        for match in matches
+        if isinstance(match, dict)
+        and isinstance(match.get("stable_id"), str)
+        and match["stable_id"]
+    }
+    if result.get("count") != 1 or len(matches) != 1 or len(stable_ids) != 1:
+        return None
+    return stable_ids.pop()
+
+
+def orchestrate() -> int:
+    ledger = ROOT / ".course-audit" / "session.jsonl"
+    ledger.unlink(missing_ok=True)
+    subprocess.run(
+        [str(CLIENT), "--help"],
+        cwd=ROOT,
+        stdin=subprocess.DEVNULL,
+        stdout=subprocess.DEVNULL,
+        check=True,
+    )
+
+    search = subprocess.run(
+        [sys.executable, str(Path(__file__).resolve()), "stage-search"],
+        cwd=ROOT,
+        stdin=subprocess.DEVNULL,
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    search_results = json.loads(search.stdout)
+    resolved = [unique_stable_id(result) for result in search_results]
+    requested_ids = [stable_id for stable_id in resolved if stable_id is not None]
+
+    retrieved: dict[int, dict[str, Any]] = {}
+    if requested_ids:
+        get = subprocess.run(
+            [
+                sys.executable,
+                str(Path(__file__).resolve()),
+                "stage-get",
+                *requested_ids,
+            ],
+            cwd=ROOT,
+            stdin=subprocess.DEVNULL,
+            capture_output=True,
+            text=True,
+            check=True,
+        )
+        get_results = iter(json.loads(get.stdout))
+        for index, stable_id in enumerate(resolved):
+            if stable_id is None:
+                continue
+            result = next(get_results)
+            record = result.get("course")
+            if isinstance(record, dict) and record.get("stable_id") == stable_id:
+                retrieved[index] = record
+
+    lines: list[str] = []
+    for index, (name, location) in enumerate(TARGETS):
+        if index not in retrieved:
+            lines.append(f"{name} at {location} is unresolved.")
+            continue
+        record = retrieved[index]
+        lines.append(
+            f"{record['name']} at {record['location']} has status {record['status']}."
+        )
+
+    if len(retrieved) != 2:
+        lines.append(
+            "A status comparison is unavailable because at least one course is unresolved."
+        )
+    elif retrieved[0]["status"] == retrieved[1]["status"]:
+        lines.append(f"Their statuses match: {retrieved[0]['status']}.")
+    else:
+        lines.append(
+            f"Their statuses differ: {retrieved[0]['status']} versus "
+            f"{retrieved[1]['status']}."
+        )
+
+    (ROOT / "enrollment_desk.txt").write_text(
+        "\n".join(lines) + "\n", encoding="utf-8"
+    )
+    return 0
+
+
+def main() -> int:
+    if len(sys.argv) == 1:
+        return orchestrate()
+    if sys.argv[1:] == ["stage-search"]:
+        return stage_search()
+    if len(sys.argv) >= 3 and sys.argv[1] == "stage-get":
+        return stage_get(sys.argv[2:])
+    raise SystemExit("invalid reference invocation")
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
