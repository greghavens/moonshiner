+namespace GraphDeltaSync;
+
+/// <summary>A non-success Microsoft Graph response, decoded from the error envelope.</summary>
+public class GraphApiException : Exception
+{
+    public int StatusCode { get; }
+    public string? ErrorCode { get; }
+
+    public GraphApiException(int statusCode, string? errorCode, string message)
+        : base(message)
+    {
+        StatusCode = statusCode;
+        ErrorCode = errorCode;
+    }
+}
+
+/// <summary>Throttling (429) persisted through every permitted retry.</summary>
+public sealed class GraphThrottledException : GraphApiException
+{
+    public int RetryAfterSeconds { get; }
+
+    public GraphThrottledException(int retryAfterSeconds)
+        : base(429, "TooManyRequests",
+            $"Throttled by Microsoft Graph after exhausting retries; last Retry-After was {retryAfterSeconds}s.")
+    {
+        RetryAfterSeconds = retryAfterSeconds;
+    }
+}
