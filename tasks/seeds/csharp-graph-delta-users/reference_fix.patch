+namespace GraphDeltaSync;
+
+/// <summary>
+/// Holds the synchronized user set and the deltaLink that produced it.
+/// Both advance together, atomically, when a round completes; an aborted
+/// round must leave the store exactly as it was.
+/// </summary>
+public sealed class UserDirectoryStore
+{
+    private Dictionary<string, UserRecord> _users = new(StringComparer.Ordinal);
+
+    public IReadOnlyDictionary<string, UserRecord> Users => _users;
+
+    public string? DeltaLink { get; private set; }
+
+    internal void Commit(Dictionary<string, UserRecord> users, string deltaLink)
+    {
+        _users = users;
+        DeltaLink = deltaLink;
+    }
+}
