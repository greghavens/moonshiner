index 0000000..a4f1542
--- /dev/null
+++ b/RecordLayout.java
@@ -0,0 +1,142 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * A typed column layout parsed from the one-line config DSL:
+ * comma-separated entries of the form {@code name:start:len:type}.
+ *
+ * Types: text, int, dec(K), date(PATTERN), code(RAW=LABEL|RAW=LABEL|...).
+ */
+public final class RecordLayout {
+
+    /** One parsed column. kind is the base type token; arg its parenthesized argument. */
+    record Col(String name, int start, int len, String kind, String arg, Map<String, String> codes) {}
+
+    private final List<Col> cols;
+
+    private RecordLayout(List<Col> cols) {
+        this.cols = List.copyOf(cols);
+    }
+
+    public static RecordLayout parse(String spec) {
+        List<Col> cols = new ArrayList<>();
+        List<String> seen = new ArrayList<>();
+        if (spec != null) {
+            for (String rawEntry : spec.split(",", -1)) {
+                String entry = rawEntry.trim();
+                if (entry.isEmpty()) {
+                    continue;
+                }
+                cols.add(parseEntry(entry, seen));
+            }
+        }
+        if (cols.isEmpty()) {
+            throw new IllegalArgumentException("empty layout");
+        }
+        return new RecordLayout(cols);
+    }
+
+    private static Col parseEntry(String entry, List<String> seen) {
+        String[] parts = entry.split(":", -1);
+        if (parts.length != 4) {
+            throw new IllegalArgumentException(
+                    "bad column spec '" + entry + "' (want name:start:len:type)");
+        }
+        String name = parts[0].trim();
+        if (name.isEmpty()) {
+            throw new IllegalArgumentException(
+                    "bad column spec '" + entry + "' (want name:start:len:type)");
+        }
+        if (seen.contains(name)) {
+            throw new IllegalArgumentException("duplicate column '" + name + "'");
+        }
+        int start = spanInt(parts[1].trim(), name);
+        int len = spanInt(parts[2].trim(), name);
+        if (start < 0 || len < 1) {
+            throw new IllegalArgumentException("bad span in column '" + name + "'");
+        }
+        String type = parts[3].trim();
+        String base = type;
+        String arg = null;
+        int open = type.indexOf('(');
+        if (open >= 0 && type.endsWith(")")) {
+            base = type.substring(0, open);
+            arg = type.substring(open + 1, type.length() - 1);
+        }
+        Map<String, String> codes = null;
+        switch (base) {
+            case "text":
+            case "int":
+                if (arg != null) {
+                    throw new IllegalArgumentException(
+                            "unknown type '" + type + "' in column '" + name + "'");
+                }
+                break;
+            case "dec":
+                if (arg == null || !arg.trim().matches("\\d+")) {
+                    throw new IllegalArgumentException(
+                            "unknown type '" + type + "' in column '" + name + "'");
+                }
+                arg = arg.trim();
+                break;
+            case "date":
+                if (arg == null || arg.isEmpty()) {
+                    throw new IllegalArgumentException(
+                            "unknown type '" + type + "' in column '" + name + "'");
+                }
+                break;
+            case "code":
+                if (arg == null || arg.isEmpty()) {
+                    throw new IllegalArgumentException(
+                            "unknown type '" + type + "' in column '" + name + "'");
+                }
+                codes = new LinkedHashMap<>();
+                for (String pair : arg.split("\\|")) {
+                    int eq = pair.indexOf('=');
+                    if (eq < 0) {
+                        throw new IllegalArgumentException(
+                                "unknown type '" + type + "' in column '" + name + "'");
+                    }
+                    codes.put(pair.substring(0, eq).trim(), pair.substring(eq + 1).trim());
+                }
+                break;
+            default:
+                throw new IllegalArgumentException(
+                        "unknown type '" + type + "' in column '" + name + "'");
+        }
+        seen.add(name);
+        return new Col(name, start, len, base, arg, codes);
+    }
+
+    private static int spanInt(String token, String name) {
+        try {
+            return Integer.parseInt(token);
+        } catch (NumberFormatException e) {
+            throw new IllegalArgumentException("bad span in column '" + name + "'");
+        }
+    }
+
+    /** Column names in spec order. */
+    public List<String> names() {
+        List<String> out = new ArrayList<>(cols.size());
+        for (Col c : cols) {
+            out.add(c.name());
+        }
+        return out;
+    }
+
+    /** Rightmost end of any column: the minimum line length for a full record. */
+    public int width() {
+        int w = 0;
+        for (Col c : cols) {
+            w = Math.max(w, c.start() + c.len());
+        }
+        return w;
+    }
+
+    List<Col> cols() {
+        return cols;
+    }
+}
