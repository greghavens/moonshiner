@@ -0,0 +1,31 @@
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Outcome of one typed read: every fully-clean row, plus every problem the
+ * file had. The reader never gives up early, so one result describes the
+ * whole file.
+ */
+public final class ReadResult {
+    private final List<Map<String, Object>> rows;
+    private final List<RowError> errors;
+
+    ReadResult(List<Map<String, Object>> rows, List<RowError> errors) {
+        this.rows = List.copyOf(rows);
+        this.errors = List.copyOf(errors);
+    }
+
+    /** Typed values for each row that had no errors, in file order. */
+    public List<Map<String, Object>> rows() {
+        return rows;
+    }
+
+    /** Every collected problem, ordered by line then column-spec position. */
+    public List<RowError> errors() {
+        return errors;
+    }
+
+    public boolean clean() {
+        return errors.isEmpty();
+    }
+}
