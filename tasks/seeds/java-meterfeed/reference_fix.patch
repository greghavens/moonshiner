+import java.math.BigDecimal;
+import java.time.LocalDate;
+import java.time.format.DateTimeFormatter;
+import java.time.format.DateTimeParseException;
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+import java.util.Objects;
+
+/**
+ * Typed fixed-width reader driven by a RecordLayout. Framing matches the
+ * legacy FixedWidthReader ('\n' separated, trailing '\r' tolerated, blank
+ * lines skipped), but conversion problems are collected per cell instead of
+ * aborting the import.
+ */
+public final class LayoutReader {
+    private final RecordLayout layout;
+    private final Map<String, DateTimeFormatter> dateFormats = new LinkedHashMap<>();
+
+    public LayoutReader(RecordLayout layout) {
+        this.layout = Objects.requireNonNull(layout, "layout");
+        for (RecordLayout.Col c : layout.cols()) {
+            if (c.kind().equals("date")) {
+                dateFormats.put(c.name(), DateTimeFormatter.ofPattern(c.arg(), Locale.ROOT));
+            }
+        }
+    }
+
+    public ReadResult read(String content) {
+        List<Map<String, Object>> rows = new ArrayList<>();
+        List<RowError> errors = new ArrayList<>();
+        if (content != null && !content.isEmpty()) {
+            String[] lines = content.split("\n", -1);
+            for (int i = 0; i < lines.length; i++) {
+                String line = lines[i];
+                if (line.endsWith("\r")) {
+                    line = line.substring(0, line.length() - 1);
+                }
+                if (line.isEmpty()) {
+                    continue;
+                }
+                readRecord(line, i + 1, rows, errors);
+            }
+        }
+        return new ReadResult(rows, errors);
+    }
+
+    private void readRecord(String line, int lineNo, List<Map<String, Object>> rows,
+                            List<RowError> errors) {
+        Map<String, Object> row = new LinkedHashMap<>();
+        int errorsBefore = errors.size();
+        for (RecordLayout.Col c : layout.cols()) {
+            if (c.start() + c.len() > line.length()) {
+                errors.add(new RowError(lineNo, c.name(),
+                        "past end of line (" + line.length() + " chars)"));
+                continue;
+            }
+            String cell = line.substring(c.start(), c.start() + c.len()).trim();
+            try {
+                row.put(c.name(), convert(c, cell));
+            } catch (BadCell e) {
+                errors.add(new RowError(lineNo, c.name(), e.getMessage()));
+            }
+        }
+        if (errors.size() == errorsBefore) {
+            rows.add(row);
+        }
+    }
+
+    private Object convert(RecordLayout.Col c, String cell) {
+        switch (c.kind()) {
+            case "text":
+                return cell;
+            case "int":
+                try {
+                    return Long.parseLong(cell);
+                } catch (NumberFormatException e) {
+                    throw new BadCell("not an integer: '" + cell + "'");
+                }
+            case "dec":
+                if (!cell.matches("[+-]?\\d+")) {
+                    throw new BadCell("not a number: '" + cell + "'");
+                }
+                return new BigDecimal(cell).movePointLeft(Integer.parseInt(c.arg()));
+            case "date":
+                try {
+                    return LocalDate.parse(cell, dateFormats.get(c.name()));
+                } catch (DateTimeParseException e) {
+                    throw new BadCell("bad date: '" + cell + "'");
+                }
+            case "code":
+                String label = c.codes().get(cell);
+                if (label == null) {
+                    throw new BadCell("unknown code: '" + cell + "'");
+                }
+                return label;
+            default:
+                throw new IllegalStateException("unreachable type " + c.kind());
+        }
+    }
+
+    private static final class BadCell extends RuntimeException {
+        BadCell(String message) {
+            super(message);
+        }
+    }
+}
