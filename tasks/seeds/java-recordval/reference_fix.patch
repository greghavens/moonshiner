diff --git a/Geofence.java b/Geofence.java
new file mode 100644
index 0000000..e599c21
--- /dev/null
+++ b/Geofence.java
@@ -0,0 +1,42 @@
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * The cylindrical airspace volume a drone permit applies to.
+ * Immutable; the compact constructor accumulates ALL violations before
+ * throwing, so callers get the full picture at once.
+ */
+public record Geofence(double centerLat, double centerLon, int radiusM, int maxAltitudeM) {
+
+    public Geofence {
+        List<String> violations = new ArrayList<>();
+        // NaN fails these comparisons, which is exactly what we want: a
+        // garbage GPS fix must trip the range message, so the checks are
+        // written as "inside the range" and negated.
+        if (!(centerLat >= -90.0 && centerLat <= 90.0)) {
+            violations.add("centerLat must be between -90.0 and 90.0");
+        }
+        if (!(centerLon >= -180.0 && centerLon <= 180.0)) {
+            violations.add("centerLon must be between -180.0 and 180.0");
+        }
+        if (radiusM < 50 || radiusM > 5000) {
+            violations.add("radiusM must be between 50 and 5000");
+        }
+        if (maxAltitudeM < 10 || maxAltitudeM > 120) {
+            violations.add("maxAltitudeM must be between 10 and 120");
+        }
+        if (!violations.isEmpty()) {
+            throw new ValidationErrors("Geofence", violations);
+        }
+    }
+
+    /** New instance with the radius replaced; runs full validation again. */
+    public Geofence withRadiusM(int radiusM) {
+        return new Geofence(centerLat, centerLon, radiusM, maxAltitudeM);
+    }
+
+    /** New instance with the altitude ceiling replaced; runs full validation again. */
+    public Geofence withMaxAltitudeM(int maxAltitudeM) {
+        return new Geofence(centerLat, centerLon, radiusM, maxAltitudeM);
+    }
+}
diff --git a/PermitRequest.java b/PermitRequest.java
new file mode 100644
index 0000000..87bb78d
--- /dev/null
+++ b/PermitRequest.java
@@ -0,0 +1,89 @@
+import java.time.LocalDate;
+import java.util.ArrayList;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Set;
+import java.util.regex.Pattern;
+
+/**
+ * One drone flight-permit request as submitted to the aviation authority.
+ * Immutable record; the compact constructor collects every violation (in
+ * component declaration order) and throws a single ValidationErrors.
+ */
+public record PermitRequest(String permitId, String pilotLicense, Geofence zone,
+                            LocalDate flightDate, List<String> waivers) {
+
+    private static final Pattern PERMIT_ID = Pattern.compile("DFP-\\d{5}");
+    private static final Pattern LICENSE = Pattern.compile("[A-Z]{2}\\d{4}");
+    private static final Pattern KEBAB = Pattern.compile("[a-z0-9]+(?:-[a-z0-9]+)*");
+
+    public PermitRequest {
+        List<String> violations = new ArrayList<>();
+
+        if (permitId == null) {
+            violations.add("permitId must not be null");
+        } else if (!PERMIT_ID.matcher(permitId).matches()) {
+            violations.add("permitId must match DFP-NNNNN");
+        }
+
+        if (pilotLicense == null) {
+            violations.add("pilotLicense must not be null");
+        } else if (!LICENSE.matcher(pilotLicense).matches()) {
+            violations.add("pilotLicense must match LLNNNN");
+        }
+
+        if (zone == null) {
+            violations.add("zone must not be null");
+        }
+
+        if (flightDate == null) {
+            violations.add("flightDate must not be null");
+        }
+
+        if (waivers == null) {
+            violations.add("waivers must not be null");
+        } else {
+            Set<String> seen = new HashSet<>();
+            boolean duplicates = false;
+            for (int i = 0; i < waivers.size(); i++) {
+                String w = waivers.get(i);
+                if (w == null) {
+                    violations.add("waivers[" + i + "] must not be null");
+                } else {
+                    if (!KEBAB.matcher(w).matches()) {
+                        violations.add("waivers[" + i + "] must be lowercase kebab-case");
+                    }
+                    if (!seen.add(w)) {
+                        duplicates = true;
+                    }
+                }
+            }
+            if (duplicates) {
+                violations.add("waivers must not contain duplicates");
+            }
+        }
+
+        if (!violations.isEmpty()) {
+            throw new ValidationErrors("PermitRequest", violations);
+        }
+
+        // Valid: freeze our own copy so later caller-side mutation can't leak in.
+        waivers = List.copyOf(waivers);
+    }
+
+    public PermitRequest withPilotLicense(String pilotLicense) {
+        return new PermitRequest(permitId, pilotLicense, zone, flightDate, waivers);
+    }
+
+    public PermitRequest withZone(Geofence zone) {
+        return new PermitRequest(permitId, pilotLicense, zone, flightDate, waivers);
+    }
+
+    public PermitRequest withFlightDate(LocalDate flightDate) {
+        return new PermitRequest(permitId, pilotLicense, zone, flightDate, waivers);
+    }
+
+    public PermitRequest withWaivers(List<String> waivers) {
+        return new PermitRequest(permitId, pilotLicense, zone, flightDate, waivers);
+    }
+}
diff --git a/ValidationErrors.java b/ValidationErrors.java
new file mode 100644
index 0000000..6316430
--- /dev/null
+++ b/ValidationErrors.java
@@ -0,0 +1,20 @@
+import java.util.List;
+
+/**
+ * Carries every validation failure found for one domain object, so callers
+ * see the whole problem in a single round trip instead of one field at a time.
+ */
+public class ValidationErrors extends IllegalArgumentException {
+
+    private final List<String> violations;
+
+    public ValidationErrors(String subject, List<String> violations) {
+        super(subject + ": " + String.join("; ", violations));
+        this.violations = List.copyOf(violations);
+    }
+
+    /** All violation messages, in the order they were detected. Unmodifiable. */
+    public List<String> violations() {
+        return violations;
+    }
+}
