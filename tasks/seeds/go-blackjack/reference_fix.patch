+// Package blackjack is a deterministic dealer engine: rounds are dealt from
+// a fixture shoe and the player's decisions come from a scripted token
+// stream, producing an exact round-by-round transcript.
+package blackjack
+
+import (
+	"fmt"
+	"strings"
+)
+
+const (
+	baseBet       = 10
+	startBankroll = 100
+)
+
+// stripComments removes '#' comments (to end of line) and returns the
+// remaining whitespace-separated tokens.
+func stripComments(s string) []string {
+	var b strings.Builder
+	for _, line := range strings.Split(s, "\n") {
+		if i := strings.IndexByte(line, '#'); i >= 0 {
+			line = line[:i]
+		}
+		b.WriteString(line)
+		b.WriteByte('\n')
+	}
+	return strings.Fields(b.String())
+}
+
+func validCard(c string) bool {
+	if len(c) != 2 {
+		return false
+	}
+	return strings.IndexByte("A23456789TJQK", c[0]) >= 0 &&
+		strings.IndexByte("HDCS", c[1]) >= 0
+}
+
+// ParseShoe reads a shoe file: whitespace-separated cards like "AS TH 9D",
+// with '#' starting a comment that runs to end of line. The shoe may span
+// several decks, so repeats are fine.
+func ParseShoe(s string) ([]string, error) {
+	cards := stripComments(s)
+	for _, c := range cards {
+		if !validCard(c) {
+			return nil, fmt.Errorf("blackjack: bad card %q in shoe", c)
+		}
+	}
+	return cards, nil
+}
+
+func cardValue(c string) int {
+	switch c[0] {
+	case 'A':
+		return 1
+	case 'T', 'J', 'Q', 'K':
+		return 10
+	default:
+		return int(c[0] - '0')
+	}
+}
+
+// HandValue returns the best blackjack total of a hand and whether it is
+// soft (an ace currently counted as 11). Invalid cards are an error.
+func HandValue(cards []string) (int, bool, error) {
+	total, aces := 0, 0
+	for _, c := range cards {
+		if !validCard(c) {
+			return 0, false, fmt.Errorf("blackjack: bad card %q", c)
+		}
+		total += cardValue(c)
+		if c[0] == 'A' {
+			aces++
+		}
+	}
+	if aces > 0 && total+10 <= 21 {
+		return total + 10, true, nil
+	}
+	return total, false, nil
+}
+
+type hand struct {
+	cards     []string
+	bet       int
+	fromSplit bool
+	splitAces bool
+	stood     bool
+}
+
+func (h *hand) value() (int, bool) {
+	t, s, _ := HandValue(h.cards)
+	return t, s
+}
+
+func valueString(cards []string) string {
+	t, soft, _ := HandValue(cards)
+	switch {
+	case t > 21:
+		return fmt.Sprintf("%d bust", t)
+	case soft:
+		return fmt.Sprintf("soft %d", t)
+	default:
+		return fmt.Sprintf("%d", t)
+	}
+}
+
+type game struct {
+	shoe   []string
+	script []string
+	out    strings.Builder
+	bank   int
+}
+
+func (g *game) draw() (string, error) {
+	if len(g.shoe) == 0 {
+		return "", fmt.Errorf("blackjack: shoe exhausted")
+	}
+	c := g.shoe[0]
+	g.shoe = g.shoe[1:]
+	return c, nil
+}
+
+func (g *game) action(round int) (string, error) {
+	if len(g.script) == 0 {
+		return "", fmt.Errorf("blackjack: round %d: script exhausted", round)
+	}
+	a := g.script[0]
+	g.script = g.script[1:]
+	return a, nil
+}
+
+func (g *game) line(format string, args ...any) {
+	fmt.Fprintf(&g.out, format+"\n", args...)
+}
+
+// playHand consumes actions for one player hand until it stands, doubles,
+// busts, or reaches 21.
+func (g *game) playHand(round int, h *hand, allowSplit bool) (*hand, error) {
+	for {
+		t, _ := h.value()
+		if t >= 21 || h.stood {
+			return nil, nil
+		}
+		if h.splitAces {
+			// Split aces take exactly one card and stand.
+			return nil, nil
+		}
+		a, err := g.action(round)
+		if err != nil {
+			return nil, err
+		}
+		switch a {
+		case "hit":
+			c, err := g.draw()
+			if err != nil {
+				return nil, err
+			}
+			h.cards = append(h.cards, c)
+			g.line("hit: %s (%s)", c, valueString(h.cards))
+		case "stand":
+			g.line("stand: (%s)", valueString(h.cards))
+			h.stood = true
+			return nil, nil
+		case "double":
+			if len(h.cards) != 2 {
+				return nil, fmt.Errorf("blackjack: round %d: double on a %d-card hand", round, len(h.cards))
+			}
+			c, err := g.draw()
+			if err != nil {
+				return nil, err
+			}
+			h.bet *= 2
+			h.cards = append(h.cards, c)
+			h.stood = true
+			g.line("double: %s (%s)", c, valueString(h.cards))
+			return nil, nil
+		case "split":
+			if !allowSplit || h.fromSplit {
+				return nil, fmt.Errorf("blackjack: round %d: hand cannot be split again", round)
+			}
+			if len(h.cards) != 2 || cardValue(h.cards[0]) != cardValue(h.cards[1]) {
+				return nil, fmt.Errorf("blackjack: round %d: split needs two equal-value cards", round)
+			}
+			aces := h.cards[0][0] == 'A'
+			second := &hand{cards: []string{h.cards[1]}, bet: baseBet, fromSplit: true, splitAces: aces}
+			h.cards = h.cards[:1]
+			h.fromSplit = true
+			h.splitAces = aces
+			g.line("split: %s | %s", h.cards[0], second.cards[0])
+			c1, err := g.draw()
+			if err != nil {
+				return nil, err
+			}
+			h.cards = append(h.cards, c1)
+			c2, err := g.draw()
+			if err != nil {
+				return nil, err
+			}
+			second.cards = append(second.cards, c2)
+			g.line("hand 1: %s %s (%s)", h.cards[0], h.cards[1], valueString(h.cards))
+			return second, nil
+		default:
+			return nil, fmt.Errorf("blackjack: round %d: unknown action %q", round, a)
+		}
+	}
+}
+
+func resultWord(net int) string {
+	switch {
+	case net > 0:
+		return "win"
+	case net < 0:
+		return "lose"
+	default:
+		return "push"
+	}
+}
+
+func sign(n int) string {
+	if n >= 0 {
+		return fmt.Sprintf("+%d", n)
+	}
+	return fmt.Sprintf("%d", n)
+}
+
+func (g *game) playRound(round int) error {
+	g.line("== round %d ==", round)
+	var cards [4]string
+	for i := range cards {
+		c, err := g.draw()
+		if err != nil {
+			return err
+		}
+		cards[i] = c
+	}
+	player := &hand{cards: []string{cards[0], cards[2]}, bet: baseBet}
+	dealer := []string{cards[1], cards[3]}
+
+	pt, _ := player.value()
+	playerBJ := pt == 21
+	if playerBJ {
+		g.line("player: %s %s (blackjack)", player.cards[0], player.cards[1])
+	} else {
+		g.line("player: %s %s (%s)", player.cards[0], player.cards[1], valueString(player.cards))
+	}
+	g.line("dealer: %s ??", dealer[0])
+
+	dt, _, _ := HandValue(dealer)
+	dealerBJ := dt == 21
+
+	dealerValue := func() string {
+		if dealerBJ {
+			return "blackjack"
+		}
+		return valueString(dealer)
+	}
+	reveal := func() {
+		g.line("dealer: %s %s (%s)", dealer[0], dealer[1], dealerValue())
+	}
+
+	if playerBJ || dealerBJ {
+		reveal()
+		var net int
+		switch {
+		case playerBJ && dealerBJ:
+			net = 0
+			g.line("result: push +0")
+		case playerBJ:
+			net = baseBet * 3 / 2
+			g.line("result: blackjack %s", sign(net))
+		default:
+			net = -baseBet
+			g.line("result: dealer blackjack %s", sign(net))
+		}
+		g.bank += net
+		g.line("bankroll: %d", g.bank)
+		return nil
+	}
+
+	hands := []*hand{player}
+	for i := 0; i < len(hands); i++ {
+		for {
+			extra, err := g.playHand(round, hands[i], i == 0 && len(hands) == 1)
+			if err != nil {
+				return err
+			}
+			if extra == nil {
+				break
+			}
+			hands = append(hands, extra)
+		}
+		if len(hands) == 2 && i == 0 {
+			g.line("hand 2: %s %s (%s)", hands[1].cards[0], hands[1].cards[1], valueString(hands[1].cards))
+		}
+	}
+
+	allBust := true
+	for _, h := range hands {
+		if t, _ := h.value(); t <= 21 {
+			allBust = false
+		}
+	}
+
+	reveal()
+	if !allBust {
+		for {
+			t, _, _ := HandValue(dealer)
+			if t >= 17 {
+				break
+			}
+			c, err := g.draw()
+			if err != nil {
+				return err
+			}
+			dealer = append(dealer, c)
+			g.line("dealer hit: %s (%s)", c, valueString(dealer))
+		}
+	}
+	dt, _, _ = HandValue(dealer)
+
+	net := 0
+	for i, h := range hands {
+		t, _ := h.value()
+		var hn int
+		switch {
+		case t > 21:
+			hn = -h.bet
+		case dt > 21 || t > dt:
+			hn = h.bet
+		case t < dt:
+			hn = -h.bet
+		}
+		net += hn
+		if len(hands) == 1 {
+			g.line("result: %s %s", resultWord(hn), sign(hn))
+		} else {
+			g.line("result hand %d: %s %s", i+1, resultWord(hn), sign(hn))
+		}
+	}
+	g.bank += net
+	g.line("bankroll: %d", g.bank)
+	return nil
+}
+
+// Run plays the requested number of rounds, drawing cards from the shoe and
+// player decisions from the script, and returns the full transcript. Any
+// rule violation, malformed input, or script/shoe mismatch is an error.
+func Run(shoe, script string, rounds int) (string, error) {
+	if rounds < 1 {
+		return "", fmt.Errorf("blackjack: rounds must be >= 1, got %d", rounds)
+	}
+	cards, err := ParseShoe(shoe)
+	if err != nil {
+		return "", err
+	}
+	g := &game{shoe: cards, script: stripComments(script), bank: startBankroll}
+	for r := 1; r <= rounds; r++ {
+		if err := g.playRound(r); err != nil {
+			return "", err
+		}
+	}
+	if len(g.script) > 0 {
+		return "", fmt.Errorf("blackjack: %d unused script action(s)", len(g.script))
+	}
+	return g.out.String(), nil
+}
