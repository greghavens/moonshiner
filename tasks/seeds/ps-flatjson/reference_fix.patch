diff --git a/flatjson.ps1 b/flatjson.ps1
new file mode 100644
index 0000000..05f201c
--- /dev/null
+++ b/flatjson.ps1
@@ -0,0 +1,127 @@
+# flatjson.ps1 — flatten nested JSON records to dotted-column CSV, and back.
+# Usage: pwsh -NoProfile -File flatjson.ps1 -Mode flatten|expand -Path <file>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][ValidateSet('flatten', 'expand')][string]$Mode,
+    [Parameter(Mandatory)][string]$Path
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message, [int]$Code)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+    Fail "flatjson: file not found: $Path" 66
+}
+
+$inv = [System.Globalization.CultureInfo]::InvariantCulture
+
+function Add-FlatCells {
+    param($Record, [string]$Prefix, $Cells)
+    foreach ($prop in $Record.PSObject.Properties) {
+        $leafPath = if ($Prefix -eq '') { $prop.Name } else { $Prefix + '.' + $prop.Name }
+        $value = $prop.Value
+        if ($null -eq $value) {
+            $Cells[$leafPath] = ''
+            continue
+        }
+        if ($value -is [System.Management.Automation.PSCustomObject]) {
+            if ($leafPath.Split('.').Count -ge 3) {
+                Fail "flatjson: nesting too deep at '$leafPath'" 65
+            }
+            Add-FlatCells -Record $value -Prefix $leafPath -Cells $Cells
+            continue
+        }
+        if ($value -is [bool]) {
+            $Cells[$leafPath] = if ($value) { 'true' } else { 'false' }
+            continue
+        }
+        if (($value -is [long]) -or ($value -is [int])) {
+            $Cells[$leafPath] = $value.ToString($inv)
+            continue
+        }
+        if ($value -is [string]) {
+            if (($value -eq '') -or ($value -ceq 'true') -or ($value -ceq 'false') -or ($value -match '^-?[0-9]+$')) {
+                Fail "flatjson: string value at '$leafPath' would not round-trip" 65
+            }
+            $Cells[$leafPath] = $value
+            continue
+        }
+        Fail "flatjson: unsupported value at '$leafPath'" 65
+    }
+}
+
+if ($Mode -eq 'flatten') {
+    $records = @(Get-Content -LiteralPath $Path -Raw | ConvertFrom-Json)
+    $rowCells = @(foreach ($record in $records) {
+        $cells = [System.Collections.Generic.Dictionary[string, string]]::new([System.StringComparer]::Ordinal)
+        Add-FlatCells -Record $record -Prefix '' -Cells $cells
+        , $cells
+    })
+    if ($rowCells.Count -eq 0) { exit 0 }
+    $colSet = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+    foreach ($cells in $rowCells) {
+        foreach ($name in $cells.Keys) { $null = $colSet.Add($name) }
+    }
+    $columns = [string[]]@($colSet)
+    [Array]::Sort($columns, [System.StringComparer]::Ordinal)
+    $shaped = @(foreach ($cells in $rowCells) {
+        $bag = [ordered]@{}
+        foreach ($col in $columns) {
+            $bag[$col] = if ($cells.ContainsKey($col)) { $cells[$col] } else { '' }
+        }
+        [pscustomobject]$bag
+    })
+    $shaped | ConvertTo-Csv | Write-Output
+    exit 0
+}
+
+# expand
+$rows = @(Import-Csv -LiteralPath $Path)
+if ($rows.Count -eq 0) {
+    Write-Output (ConvertTo-Json @())
+    exit 0
+}
+$headers = @($rows[0].PSObject.Properties.Name)
+foreach ($h in $headers) {
+    $segments = $h.Split('.')
+    if ($segments.Count -gt 3) {
+        Fail "flatjson: nesting too deep at '$h'" 65
+    }
+    for ($i = 1; $i -lt $segments.Count; $i++) {
+        $prefix = $segments[0..($i - 1)] -join '.'
+        if ($headers -ccontains $prefix) {
+            Fail "flatjson: column '$h' conflicts with column '$prefix'" 65
+        }
+    }
+}
+
+function Convert-Cell {
+    param([string]$Text)
+    if ($Text -eq '') { return $null }
+    if ($Text -ceq 'true') { return $true }
+    if ($Text -ceq 'false') { return $false }
+    if ($Text -match '^-?[0-9]+$') { return [long]::Parse($Text, $inv) }
+    return $Text
+}
+
+$expanded = @(foreach ($row in $rows) {
+    $root = [ordered]@{}
+    foreach ($h in $headers) {
+        $segments = $h.Split('.')
+        $node = $root
+        for ($i = 0; $i -lt $segments.Count - 1; $i++) {
+            if (-not $node.Contains($segments[$i])) { $node[$segments[$i]] = [ordered]@{} }
+            $node = $node[$segments[$i]]
+        }
+        $node[$segments[-1]] = Convert-Cell ([string]$row.$h)
+    }
+    $root
+})
+Write-Output (ConvertTo-Json $expanded -Depth 8)
+exit 0
