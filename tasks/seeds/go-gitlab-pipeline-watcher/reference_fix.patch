@@ -0,0 +1,59 @@
+// Package glpipe launches and watches GitLab CI pipelines through the
+// documented REST v4 surface (docs/contract.json pins the wire contract).
+package glpipe
+
+import "fmt"
+
+// Variable is one pipeline variable for POST /projects/:id/pipeline.
+// variable_type defaults to env_var server-side, so it is omitted when unset.
+type Variable struct {
+	Key          string `json:"key"`
+	Value        string `json:"value"`
+	VariableType string `json:"variable_type,omitempty"`
+}
+
+// Pipeline mirrors the documented pipeline resource fields we consume.
+type Pipeline struct {
+	ID        int    `json:"id"`
+	IID       int    `json:"iid"`
+	ProjectID int    `json:"project_id"`
+	Status    string `json:"status"`
+	Source    string `json:"source"`
+	Ref       string `json:"ref"`
+	SHA       string `json:"sha"`
+	WebURL    string `json:"web_url"`
+}
+
+// Job mirrors the documented job resource fields we consume.
+type Job struct {
+	ID           int    `json:"id"`
+	Name         string `json:"name"`
+	Stage        string `json:"stage"`
+	Status       string `json:"status"`
+	Ref          string `json:"ref"`
+	AllowFailure bool   `json:"allow_failure"`
+	WebURL       string `json:"web_url"`
+}
+
+// Report is the structured outcome of a watch run. It is returned even on
+// cancellation or poll-budget exhaustion, carrying whatever was observed.
+type Report struct {
+	PipelineID      int
+	Status          string
+	Completed       bool
+	Polls           int
+	Throttled       int
+	Jobs            []Job
+	FailedTraces    map[int]string
+	CancelRequested bool
+}
+
+// APIError is a non-2xx GitLab response. It never contains the token.
+type APIError struct {
+	Status  int
+	Message string
+}
+
+func (e *APIError) Error() string {
+	return fmt.Sprintf("gitlab answered %d: %s", e.Status, e.Message)
+}
