+package glpipe
+
+import (
+	"context"
+	"fmt"
+	"time"
+)
+
+// terminalStatuses per the documented pipeline status enumeration. Note
+// that "canceling", "waiting_for_resource", "waiting_for_callback" and
+// friends are in-flight states — only these four end a watch.
+var terminalStatuses = map[string]bool{
+	"success":  true,
+	"failed":   true,
+	"canceled": true,
+	"skipped":  true,
+}
+
+// Watcher launches a pipeline and follows it to a terminal state.
+type Watcher struct {
+	Client   *Client
+	Pace     func(attempt int) // runs between consecutive status polls
+	PerPage  int
+	MaxPolls int
+}
+
+// Run creates the pipeline, polls it to a terminal status, then collects
+// its jobs and the traces of failed jobs. On context cancellation it fires
+// a best-effort server-side cancel and returns the partial report together
+// with the context error.
+func (w *Watcher) Run(ctx context.Context, projectID int, ref string, vars []Variable) (*Report, error) {
+	report := &Report{FailedTraces: map[int]string{}}
+	defer func() { report.Throttled = w.Client.ThrottleCount() }()
+
+	created, err := w.Client.CreatePipeline(ctx, projectID, ref, vars)
+	if err != nil {
+		return report, err
+	}
+	report.PipelineID = created.ID
+
+	for attempt := 1; ; attempt++ {
+		if ctx.Err() != nil {
+			w.requestCancel(projectID, report)
+			return report, ctx.Err()
+		}
+		current, err := w.Client.GetPipeline(ctx, projectID, created.ID)
+		if err != nil {
+			return report, err
+		}
+		report.Polls++
+		report.Status = current.Status
+		if terminalStatuses[current.Status] {
+			report.Completed = true
+			break
+		}
+		if report.Polls >= w.MaxPolls {
+			return report, fmt.Errorf(
+				"pipeline %d still %q after %d polls", created.ID, current.Status, report.Polls,
+			)
+		}
+		w.Pace(attempt)
+	}
+
+	jobs, err := w.Client.ListPipelineJobs(ctx, projectID, created.ID, w.PerPage)
+	if err != nil {
+		return report, err
+	}
+	report.Jobs = jobs
+	for _, j := range jobs {
+		if j.Status != "failed" {
+			continue
+		}
+		trace, err := w.Client.JobTrace(ctx, projectID, j.ID)
+		if err != nil {
+			return report, err
+		}
+		report.FailedTraces[j.ID] = trace
+	}
+	return report, nil
+}
+
+// requestCancel best-effort cancels the pipeline server-side after the
+// caller's context died; it runs on its own short-lived context.
+func (w *Watcher) requestCancel(projectID int, report *Report) {
+	if report.PipelineID == 0 {
+		return
+	}
+	ctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
+	defer cancel()
+	if err := w.Client.CancelPipeline(ctx, projectID, report.PipelineID); err == nil {
+		report.CancelRequested = true
+	}
+}
