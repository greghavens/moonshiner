@@ -0,0 +1,209 @@
+package glpipe
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strconv"
+	"strings"
+	"time"
+)
+
+const maxRateLimitRetries = 3
+
+// Client speaks the GitLab REST v4 API. All waiting goes through the
+// injected sleep function; the package never calls time.Sleep.
+type Client struct {
+	baseURL   string
+	token     string
+	hc        *http.Client
+	sleep     func(time.Duration)
+	throttled int
+}
+
+func NewClient(baseURL, token string, hc *http.Client, sleep func(time.Duration)) *Client {
+	if hc == nil {
+		hc = http.DefaultClient
+	}
+	return &Client{
+		baseURL: strings.TrimRight(baseURL, "/"),
+		token:   token,
+		hc:      hc,
+		sleep:   sleep,
+	}
+}
+
+// ThrottleCount reports how many 429 waits have been honored so far.
+func (c *Client) ThrottleCount() int { return c.throttled }
+
+// do issues one authenticated request, transparently honoring documented
+// rate limiting: on 429 it waits exactly Retry-After seconds via the
+// injected sleep and retries, giving up after maxRateLimitRetries waits.
+func (c *Client) do(ctx context.Context, method, path string, body any) (*http.Response, error) {
+	var payload []byte
+	if body != nil {
+		var err error
+		if payload, err = json.Marshal(body); err != nil {
+			return nil, err
+		}
+	}
+	for attempt := 0; ; attempt++ {
+		req, err := http.NewRequestWithContext(ctx, method, c.baseURL+path, bytes.NewReader(payload))
+		if err != nil {
+			return nil, err
+		}
+		req.Header.Set("PRIVATE-TOKEN", c.token)
+		req.Header.Set("Accept", "application/json")
+		if body != nil {
+			req.Header.Set("Content-Type", "application/json")
+		}
+		resp, err := c.hc.Do(req)
+		if err != nil {
+			return nil, err
+		}
+		if resp.StatusCode != http.StatusTooManyRequests {
+			return resp, nil
+		}
+		_, _ = io.Copy(io.Discard, resp.Body)
+		_ = resp.Body.Close()
+		if attempt >= maxRateLimitRetries {
+			return nil, &APIError{
+				Status:  429,
+				Message: fmt.Sprintf("still rate limited after %d retries", attempt),
+			}
+		}
+		c.throttled++
+		c.sleep(retryAfter(resp.Header))
+	}
+}
+
+// retryAfter reads the documented Retry-After header (seconds).
+func retryAfter(h http.Header) time.Duration {
+	if s := h.Get("Retry-After"); s != "" {
+		if n, err := strconv.Atoi(strings.TrimSpace(s)); err == nil && n >= 0 {
+			return time.Duration(n) * time.Second
+		}
+	}
+	return time.Second
+}
+
+func (c *Client) apiError(resp *http.Response) error {
+	data, _ := io.ReadAll(io.LimitReader(resp.Body, 64<<10))
+	message := strings.TrimSpace(string(data))
+	var doc struct {
+		Message any    `json:"message"`
+		Error   string `json:"error"`
+	}
+	if json.Unmarshal(data, &doc) == nil {
+		switch m := doc.Message.(type) {
+		case string:
+			message = m
+		case nil:
+			if doc.Error != "" {
+				message = doc.Error
+			}
+		default:
+			if enc, err := json.Marshal(m); err == nil {
+				message = string(enc)
+			}
+		}
+	}
+	return &APIError{Status: resp.StatusCode, Message: message}
+}
+
+func (c *Client) getJSON(ctx context.Context, path string, out any) (http.Header, error) {
+	resp, err := c.do(ctx, http.MethodGet, path, nil)
+	if err != nil {
+		return nil, err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		return nil, c.apiError(resp)
+	}
+	return resp.Header, json.NewDecoder(resp.Body).Decode(out)
+}
+
+// CreatePipeline is POST /projects/:id/pipeline with ref and variables.
+func (c *Client) CreatePipeline(ctx context.Context, projectID int, ref string, vars []Variable) (*Pipeline, error) {
+	body := map[string]any{"ref": ref}
+	if len(vars) > 0 {
+		body["variables"] = vars
+	}
+	resp, err := c.do(ctx, http.MethodPost, fmt.Sprintf("/api/v4/projects/%d/pipeline", projectID), body)
+	if err != nil {
+		return nil, err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusCreated {
+		return nil, c.apiError(resp)
+	}
+	var p Pipeline
+	if err := json.NewDecoder(resp.Body).Decode(&p); err != nil {
+		return nil, err
+	}
+	return &p, nil
+}
+
+// GetPipeline is GET /projects/:id/pipelines/:pipeline_id.
+func (c *Client) GetPipeline(ctx context.Context, projectID, pipelineID int) (*Pipeline, error) {
+	var p Pipeline
+	path := fmt.Sprintf("/api/v4/projects/%d/pipelines/%d", projectID, pipelineID)
+	if _, err := c.getJSON(ctx, path, &p); err != nil {
+		return nil, err
+	}
+	return &p, nil
+}
+
+// ListPipelineJobs pages GET /projects/:id/pipelines/:pipeline_id/jobs by
+// following the documented x-next-page header until it comes back empty.
+func (c *Client) ListPipelineJobs(ctx context.Context, projectID, pipelineID, perPage int) ([]Job, error) {
+	var all []Job
+	page := "1"
+	for page != "" {
+		var batch []Job
+		path := fmt.Sprintf(
+			"/api/v4/projects/%d/pipelines/%d/jobs?per_page=%d&page=%s",
+			projectID, pipelineID, perPage, page,
+		)
+		hdr, err := c.getJSON(ctx, path, &batch)
+		if err != nil {
+			return all, err
+		}
+		all = append(all, batch...)
+		page = strings.TrimSpace(hdr.Get("x-next-page"))
+	}
+	return all, nil
+}
+
+// JobTrace is GET /projects/:id/jobs/:job_id/trace, served as plain text.
+func (c *Client) JobTrace(ctx context.Context, projectID, jobID int) (string, error) {
+	resp, err := c.do(ctx, http.MethodGet, fmt.Sprintf("/api/v4/projects/%d/jobs/%d/trace", projectID, jobID), nil)
+	if err != nil {
+		return "", err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		return "", c.apiError(resp)
+	}
+	data, err := io.ReadAll(resp.Body)
+	return string(data), err
+}
+
+// CancelPipeline is POST /projects/:id/pipelines/:pipeline_id/cancel; the
+// docs promise 200 regardless of the pipeline's state.
+func (c *Client) CancelPipeline(ctx context.Context, projectID, pipelineID int) error {
+	path := fmt.Sprintf("/api/v4/projects/%d/pipelines/%d/cancel", projectID, pipelineID)
+	resp, err := c.do(ctx, http.MethodPost, path, nil)
+	if err != nil {
+		return err
+	}
+	defer resp.Body.Close()
+	if resp.StatusCode != http.StatusOK {
+		return c.apiError(resp)
+	}
+	_, _ = io.Copy(io.Discard, resp.Body)
+	return nil
+}
