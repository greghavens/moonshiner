{
  "product": "GitLab REST API v4 — CI/CD pipelines and jobs",
  "base_path": "/api/v4",
  "auth": {
    "header": "PRIVATE-TOKEN",
    "note": "required on every API request, including the cancel POST; never emitted in error text"
  },
  "operations": {
    "create_pipeline": {
      "request": {
        "method": "POST",
        "path": "/api/v4/projects/{id}/pipeline",
        "note": "singular 'pipeline'",
        "body": {
          "ref": "required branch or tag",
          "variables": "array of {key, value, variable_type?}; variable_type is one of env_var|file and MUST be omitted when unset (server defaults to env_var)"
        }
      },
      "success": { "status": 201, "body": "pipeline: id, iid, project_id, status, source, ref, sha, web_url" }
    },
    "get_pipeline": {
      "request": { "method": "GET", "path": "/api/v4/projects/{id}/pipelines/{pipeline_id}" },
      "status_enum": [
        "created", "waiting_for_resource", "preparing", "waiting_for_callback",
        "pending", "running", "success", "failed", "canceling", "canceled",
        "skipped", "manual", "scheduled"
      ],
      "terminal_for_watching": ["success", "failed", "canceled", "skipped"],
      "note": "canceling is NOT terminal; keep polling until canceled"
    },
    "list_pipeline_jobs": {
      "request": {
        "method": "GET",
        "path": "/api/v4/projects/{id}/pipelines/{pipeline_id}/jobs",
        "query": { "per_page": "page size", "page": "offset pagination; follow x-next-page until empty" }
      },
      "success": {
        "status": 200,
        "pagination_headers": ["x-page", "x-per-page", "x-total-pages", "x-next-page"],
        "body": "JSON array of jobs: id, name, stage, status, ref, allow_failure, web_url"
      }
    },
    "job_trace": {
      "request": { "method": "GET", "path": "/api/v4/projects/{id}/jobs/{job_id}/trace" },
      "success": { "status": 200, "content_type": "text/plain", "body": "raw log text" },
      "not_found": { "status": 404, "body": { "message": "404 Not Found" } }
    },
    "cancel_pipeline": {
      "request": { "method": "POST", "path": "/api/v4/projects/{id}/pipelines/{pipeline_id}/cancel" },
      "success": { "status": 200, "note": "returns 200 regardless of the pipeline's state" }
    },
    "rate_limiting": {
      "status": 429,
      "body": "plain text: Retry later",
      "headers": {
        "RateLimit-Limit": "per-minute quota",
        "RateLimit-Remaining": "remaining quota in the window",
        "RateLimit-Reset": "Unix time the quota resets",
        "Retry-After": "remaining duration in SECONDS until the quota resets"
      },
      "client_rule": "wait exactly Retry-After seconds through the injected sleep, then retry; retries are bounded"
    }
  },
  "mock_fixture": {
    "project_id": 4711,
    "pipeline_id": 88123,
    "failed_job_id": 9002,
    "jobs_pages": 2,
    "retry_after_seconds": 30
  }
}
