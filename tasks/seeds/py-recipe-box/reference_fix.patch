index 0000000..e62e32f
--- /dev/null
+++ b/recipes.py
@@ -0,0 +1,45 @@
+"""Recipe validation and scaling."""
+import units
+
+
+class RecipeError(ValueError):
+    pass
+
+
+def validate(raw):
+    """Validate a raw recipe dict; returns a normalized copy or raises RecipeError."""
+    if not isinstance(raw, dict):
+        raise RecipeError("recipe must be a JSON object")
+    name = raw.get("name")
+    if not isinstance(name, str) or not name.strip():
+        raise RecipeError("recipe needs a non-empty name")
+    servings = raw.get("servings")
+    if not isinstance(servings, int) or isinstance(servings, bool) or servings <= 0:
+        raise RecipeError(f"{name}: servings must be a positive integer")
+    ingredients = raw.get("ingredients")
+    if not isinstance(ingredients, list) or not ingredients:
+        raise RecipeError(f"{name}: needs a non-empty ingredients list")
+    normalized = []
+    for ing in ingredients:
+        if not isinstance(ing, dict):
+            raise RecipeError(f"{name}: ingredient entries must be objects")
+        item = ing.get("item")
+        if not isinstance(item, str) or not item.strip():
+            raise RecipeError(f"{name}: ingredient needs an item name")
+        qty = ing.get("qty")
+        if not isinstance(qty, (int, float)) or isinstance(qty, bool) or qty <= 0:
+            raise RecipeError(f"{name}: {item}: qty must be a positive number")
+        unit = ing.get("unit", "")
+        try:
+            units.to_base(qty, unit)
+        except ValueError as e:
+            raise RecipeError(f"{name}: {item}: {e}") from None
+        normalized.append({"item": item, "qty": qty, "unit": unit or ""})
+    return {"name": name, "servings": servings, "ingredients": normalized}
+
+
+def scaled_ingredients(recipe, servings):
+    """Ingredients scaled to `servings`, as (item, qty, unit) in recipe order."""
+    factor = servings / recipe["servings"]
+    return [(ing["item"], ing["qty"] * factor, ing["unit"])
+            for ing in recipe["ingredients"]]
