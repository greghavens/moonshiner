@@ -0,0 +1,18 @@
+"""Shopping list merging. Pure functions, no IO."""
+import units
+
+
+def merge(entries):
+    """Merge (item, qty, unit) entries into a shopping list.
+
+    Quantities for the same item are summed in base units, but only within
+    the same dimension: butter-in-grams and butter-in-tbsp stay separate rows.
+    Returns [(item, formatted_qty)] sorted by item, then base unit.
+    """
+    totals = {}
+    for item, qty, unit in entries:
+        base_qty, base_unit = units.to_base(qty, unit)
+        key = (item, base_unit)
+        totals[key] = totals.get(key, 0) + base_qty
+    return [(item, units.format_qty(total, base_unit))
+            for (item, base_unit), total in sorted(totals.items())]
