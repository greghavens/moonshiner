+"""Unit conversion and display formatting. Pure functions, no IO."""
+
+# base units: volume -> tsp, weight -> g, counts -> ''
+_TO_BASE = {
+    "tsp": (1, "tsp"),
+    "tbsp": (3, "tsp"),
+    "cup": (48, "tsp"),
+    "g": (1, "g"),
+    "kg": (1000, "g"),
+    "": (1, ""),
+}
+
+# display ladder per base unit: (threshold, factor, name), biggest first
+_DISPLAY = {
+    "tsp": [(48, 48, "cup"), (3, 3, "tbsp"), (0, 1, "tsp")],
+    "g": [(1000, 1000, "kg"), (0, 1, "g")],
+    "": [(0, 1, "")],
+}
+
+
+def to_base(qty, unit):
+    """Convert a recipe quantity to (base_qty, base_unit).
+
+    Raises ValueError for units we don't know about.
+    """
+    if unit is None:
+        unit = ""
+    try:
+        factor, base = _TO_BASE[unit]
+    except KeyError:
+        raise ValueError(f"unknown unit: {unit!r}") from None
+    return qty * factor, base
+
+
+def _render_number(value):
+    value = round(value, 2)
+    if value == int(value):
+        return str(int(value))
+    return f"{value:g}"
+
+
+def format_qty(base_qty, base_unit):
+    """Human display: biggest sensible unit, <= 2 decimals, no trailing zeros."""
+    try:
+        ladder = _DISPLAY[base_unit]
+    except KeyError:
+        raise ValueError(f"unknown base unit: {base_unit!r}") from None
+    for threshold, factor, name in ladder:
+        if base_qty >= threshold:
+            number = _render_number(base_qty / factor)
+            return f"{number} {name}" if name else number
+    number = _render_number(base_qty)  # negative/zero quantities: smallest unit
+    name = ladder[-1][2]
+    return f"{number} {name}" if name else number
