@@ -0,0 +1,114 @@
+"""Recipe box CLI: add / list / show / shop."""
+import argparse
+import json
+import sys
+
+import recipes
+import shopping
+import store
+import units
+
+
+def cmd_add(args):
+    try:
+        with open(args.recipe_file, "r", encoding="utf-8") as f:
+            raw = json.load(f)
+    except (OSError, json.JSONDecodeError) as e:
+        print(f"error: cannot read recipe file: {e}", file=sys.stderr)
+        return 1
+    try:
+        recipe = recipes.validate(raw)
+    except recipes.RecipeError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    state = store.load(args.db)
+    if recipe["name"] in state["recipes"]:
+        print(f"error: recipe {recipe['name']!r} already in the box", file=sys.stderr)
+        return 1
+    state["recipes"][recipe["name"]] = {
+        "servings": recipe["servings"], "ingredients": recipe["ingredients"]}
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_list(args):
+    state = store.load(args.db)
+    for name in sorted(state["recipes"]):
+        print(f"{name} (serves {state['recipes'][name]['servings']})")
+    return 0
+
+
+def _get_recipe(state, name):
+    recipe = state["recipes"].get(name)
+    if recipe is None:
+        print(f"error: no recipe named {name!r}", file=sys.stderr)
+    return recipe
+
+
+def cmd_show(args):
+    if args.servings <= 0:
+        print("error: --servings must be a positive integer", file=sys.stderr)
+        return 1
+    state = store.load(args.db)
+    recipe = _get_recipe(state, args.name)
+    if recipe is None:
+        return 1
+    for item, qty, unit in recipes.scaled_ingredients(recipe, args.servings):
+        print(f"{item}\t{units.format_qty(*units.to_base(qty, unit))}")
+    return 0
+
+
+def cmd_shop(args):
+    state = store.load(args.db)
+    entries = []
+    for spec in args.specs:
+        name, _, servings = spec.partition("=")
+        recipe = _get_recipe(state, name)
+        if recipe is None:
+            return 1
+        if servings:
+            try:
+                n = int(servings)
+            except ValueError:
+                n = 0
+            if n <= 0:
+                print(f"error: bad servings in {spec!r}", file=sys.stderr)
+                return 1
+        else:
+            n = recipe["servings"]
+        entries.extend(recipes.scaled_ingredients(recipe, n))
+    for item, formatted in shopping.merge(entries):
+        print(f"{item}\t{formatted}")
+    return 0
+
+
+def build_parser():
+    ap = argparse.ArgumentParser(prog="recipebox")
+    ap.add_argument("--db", required=True)
+    sub = ap.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add")
+    p.add_argument("recipe_file")
+    p.set_defaults(func=cmd_add)
+
+    p = sub.add_parser("list")
+    p.set_defaults(func=cmd_list)
+
+    p = sub.add_parser("show")
+    p.add_argument("name")
+    p.add_argument("--servings", required=True, type=int)
+    p.set_defaults(func=cmd_show)
+
+    p = sub.add_parser("shop")
+    p.add_argument("specs", nargs="+", metavar="NAME[=SERVINGS]")
+    p.set_defaults(func=cmd_shop)
+    return ap
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
