+++ b/cli.py
@@ -0,0 +1,100 @@
+"""Survey engine CLI. Usage: python3 cli.py --db PATH <command> ..."""
+import argparse
+import json
+import sys
+
+import results
+import store
+import survey
+
+
+class CliError(Exception):
+    pass
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="cli.py")
+    parser.add_argument("--db", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("define")
+    p.add_argument("definition_file")
+
+    p = sub.add_parser("submit")
+    p.add_argument("--id", dest="respondent", required=True)
+    p.add_argument("pairs", nargs="+")
+
+    sub.add_parser("tally")
+    sub.add_parser("export")
+    return parser
+
+
+def load_db(path):
+    if not store.exists(path):
+        raise CliError(f"no survey db at {path}; run define first")
+    return store.load(path)
+
+
+def parse_pairs(pairs):
+    answers = {}
+    for pair in pairs:
+        if "=" not in pair:
+            raise CliError(f"expected QID=VALUE, got {pair!r}")
+        qid, _, value = pair.partition("=")
+        if qid in answers:
+            raise CliError(f"{qid}: given more than once")
+        answers[qid] = value
+    return answers
+
+
+def cmd_define(args):
+    if store.exists(args.db):
+        raise CliError(f"db {args.db} already exists; refusing to redefine")
+    try:
+        with open(args.definition_file, encoding="utf-8") as fh:
+            definition = json.load(fh)
+    except (OSError, json.JSONDecodeError) as exc:
+        raise CliError(f"cannot read definition: {exc}") from exc
+    survey.check_definition(definition)
+    store.save(args.db, store.new_state(definition))
+
+
+def cmd_submit(args):
+    state = load_db(args.db)
+    answers = parse_pairs(args.pairs)
+    if any(r["respondent"] == args.respondent for r in state["responses"]):
+        raise CliError(f"respondent {args.respondent} already submitted")
+    problems = survey.validate(state["definition"], answers)
+    if problems:
+        raise CliError("; ".join(problems))
+    state["responses"].append({"respondent": args.respondent, "answers": answers})
+    store.save(args.db, state)
+
+
+def run(args):
+    if args.command == "define":
+        cmd_define(args)
+    elif args.command == "submit":
+        cmd_submit(args)
+    elif args.command == "tally":
+        state = load_db(args.db)
+        lines = results.tally_lines(state["definition"], state["responses"])
+        if lines:
+            print("\n".join(lines))
+    elif args.command == "export":
+        state = load_db(args.db)
+        sys.stdout.write(results.export_csv(state["definition"], state["responses"]))
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    try:
+        run(args)
+    except (CliError, survey.DefinitionError) as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
