@@ -0,0 +1,52 @@
+"""Aggregation and CSV export over collected responses."""
+import csv
+import io
+
+import survey
+
+
+def tally_lines(defn, responses):
+    """TSV lines: one per (choice question, option), definition order.
+
+    The denominator for a question is how many respondents were shown it.
+    """
+    lines = []
+    shown_counts = {q["id"]: 0 for q in defn["questions"]}
+    counts = {}
+    for resp in responses:
+        for qid in survey.visible_questions(defn, resp["answers"]):
+            shown_counts[qid] += 1
+    for q in defn["questions"]:
+        if q["type"] != "choice":
+            continue
+        qid = q["id"]
+        for option in q["options"]:
+            counts[(qid, option)] = 0
+    for resp in responses:
+        for qid, value in resp["answers"].items():
+            if (qid, value) in counts:
+                counts[(qid, value)] += 1
+    for q in defn["questions"]:
+        if q["type"] != "choice":
+            continue
+        qid = q["id"]
+        shown = shown_counts[qid]
+        for option in q["options"]:
+            n = counts[(qid, option)]
+            pct = (100.0 * n / shown) if shown else 0.0
+            lines.append(f"{qid}\t{option}\t{n}\t{pct:.1f}%")
+    return lines
+
+
+def export_csv(defn, responses):
+    """Responses as CSV text: respondent + one column per question."""
+    qids = [q["id"] for q in defn["questions"]]
+    buf = io.StringIO()
+    writer = csv.writer(buf, lineterminator="\n")
+    writer.writerow(["respondent"] + qids)
+    for resp in responses:
+        answers = resp["answers"]
+        writer.writerow([resp["respondent"]] +
+                        [str(answers[qid]) if qid in answers else ""
+                         for qid in qids])
+    return buf.getvalue()
