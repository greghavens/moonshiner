index 0000000..9b5498c
--- /dev/null
+++ b/survey.py
@@ -0,0 +1,91 @@
+"""Branching and validation logic. Pure functions over plain dicts, no IO."""
+
+TYPES = ("choice", "number", "text")
+
+
+class DefinitionError(Exception):
+    """The survey definition itself is broken."""
+
+
+def check_definition(defn):
+    """Raise DefinitionError if the definition is unusable."""
+    questions = defn.get("questions")
+    if not isinstance(questions, list) or not questions:
+        raise DefinitionError("definition needs a non-empty questions list")
+    seen = set()
+    for q in questions:
+        qid = q.get("id")
+        if not qid:
+            raise DefinitionError("every question needs an id")
+        if qid in seen:
+            raise DefinitionError(f"duplicate question id: {qid}")
+        qtype = q.get("type")
+        if qtype not in TYPES:
+            raise DefinitionError(f"question {qid}: unknown type {qtype!r}")
+        if qtype == "choice" and not q.get("options"):
+            raise DefinitionError(f"question {qid}: choice needs options")
+        for ref in q.get("show_if", {}):
+            if ref not in seen:
+                raise DefinitionError(
+                    f"question {qid}: show_if refers to {ref!r}, "
+                    "which is not an earlier question")
+        seen.add(qid)
+
+
+def _questions(defn):
+    return defn["questions"]
+
+
+def visible_questions(defn, answers):
+    """Ids of questions shown for the given answers, in definition order.
+
+    A question with show_if is visible only if the referenced question is
+    itself visible and answered with exactly the required value (chaining).
+    """
+    visible = []
+    for q in _questions(defn):
+        cond = q.get("show_if", {})
+        if all(ref in visible and answers.get(ref) == want
+               for ref, want in cond.items()):
+            visible.append(q["id"])
+    return visible
+
+
+def _check_value(q, value):
+    """Problem string for a single answer, or None if it's fine."""
+    qid = q["id"]
+    if q["type"] == "choice":
+        if value not in q["options"]:
+            return f"{qid}: {value!r} is not one of the options"
+    elif q["type"] == "number":
+        try:
+            number = int(str(value))
+        except ValueError:
+            return f"{qid}: {value!r} is not an integer"
+        if "min" in q and number < q["min"]:
+            return f"{qid}: {number} is below the minimum {q['min']}"
+        if "max" in q and number > q["max"]:
+            return f"{qid}: {number} is above the maximum {q['max']}"
+    return None
+
+
+def validate(defn, answers):
+    """List of problem strings for one response; empty means valid."""
+    problems = []
+    by_id = {q["id"]: q for q in _questions(defn)}
+    for qid in answers:
+        if qid not in by_id:
+            problems.append(f"{qid}: unknown question")
+    visible = set(visible_questions(defn, answers))
+    for q in _questions(defn):
+        qid = q["id"]
+        if qid in visible:
+            if qid in answers:
+                problem = _check_value(q, answers[qid])
+                if problem:
+                    problems.append(problem)
+            elif q.get("required", True):
+                problems.append(f"{qid}: required question not answered")
+        elif qid in answers:
+            problems.append(f"{qid}: answered but not shown for this response")
+    return problems
