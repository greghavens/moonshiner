+"""Offline DFA algebra for the validator table pipeline.
+
+Machines are complete DFAs declared as plain dicts (see validate for the
+exact shape). The module transforms and compares machines-as-data:
+
+- validate(dfa)        shape / completeness checks
+- accepts(dfa, word)   run a word
+- trim(dfa)            drop unreachable states
+- minimize(dfa)        partition refinement + canonical BFS renumbering
+- equivalent(a, b)     product-construction check with a witness word
+
+Pure functions; inputs are never mutated.
+"""
+
+from collections import deque
+
+_DFA_KEYS = {"states", "alphabet", "delta", "initial", "accepting"}
+
+
+class DFAError(ValueError):
+    """The machine dict is malformed, or a word uses unknown symbols."""
+
+
+def validate(dfa):
+    if not isinstance(dfa, dict):
+        raise DFAError("DFA must be a dict")
+    extra = set(dfa) - _DFA_KEYS
+    if extra:
+        raise DFAError("unknown DFA keys: %s" % sorted(extra))
+    missing = _DFA_KEYS - set(dfa)
+    if missing:
+        raise DFAError("missing DFA keys: %s" % sorted(missing))
+
+    states = dfa["states"]
+    if not isinstance(states, list) or not states:
+        raise DFAError("states must be a non-empty list")
+    state_set = set(states)
+    if len(state_set) != len(states):
+        raise DFAError("duplicate state names")
+
+    alphabet = dfa["alphabet"]
+    if not isinstance(alphabet, list) or not alphabet:
+        raise DFAError("alphabet must be a non-empty list")
+    for sym in alphabet:
+        if not isinstance(sym, str) or len(sym) != 1:
+            raise DFAError("symbol %r is not a single-character string" % (sym,))
+    symbol_set = set(alphabet)
+    if len(symbol_set) != len(alphabet):
+        raise DFAError("duplicate symbols in alphabet")
+
+    delta = dfa["delta"]
+    if not isinstance(delta, dict):
+        raise DFAError("delta must be a dict")
+    if set(delta) != state_set:
+        raise DFAError("delta rows must cover exactly the declared states")
+    for state, row in delta.items():
+        if not isinstance(row, dict) or set(row) != symbol_set:
+            raise DFAError(
+                "delta row for state %r must map exactly the alphabet" % (state,))
+        for sym, target in row.items():
+            if target not in state_set:
+                raise DFAError(
+                    "delta[%r][%r] targets undeclared state %r"
+                    % (state, sym, target))
+
+    if dfa["initial"] not in state_set:
+        raise DFAError("initial state %r is not declared" % (dfa["initial"],))
+    for acc in dfa["accepting"]:
+        if acc not in state_set:
+            raise DFAError("accepting state %r is not declared" % (acc,))
+
+
+def accepts(dfa, word):
+    validate(dfa)
+    symbol_set = set(dfa["alphabet"])
+    current = dfa["initial"]
+    for ch in word:
+        if ch not in symbol_set:
+            raise DFAError("symbol %r is not in the alphabet" % ch)
+        current = dfa["delta"][current][ch]
+    return current in set(dfa["accepting"])
+
+
+def _reachable(dfa):
+    delta = dfa["delta"]
+    seen = {dfa["initial"]}
+    stack = [dfa["initial"]]
+    while stack:
+        state = stack.pop()
+        for sym in dfa["alphabet"]:
+            target = delta[state][sym]
+            if target not in seen:
+                seen.add(target)
+                stack.append(target)
+    return seen
+
+
+def trim(dfa):
+    validate(dfa)
+    keep = _reachable(dfa)
+    return {
+        "states": [s for s in dfa["states"] if s in keep],
+        "alphabet": list(dfa["alphabet"]),
+        "delta": {s: dict(dfa["delta"][s]) for s in dfa["states"] if s in keep},
+        "initial": dfa["initial"],
+        "accepting": [s for s in dfa["accepting"] if s in keep],
+    }
+
+
+def minimize(dfa):
+    validate(dfa)
+    machine = trim(dfa)
+    states = machine["states"]
+    alphabet = sorted(machine["alphabet"])
+    delta = machine["delta"]
+    accepting = set(machine["accepting"])
+
+    # Partition refinement: start from the accepting / non-accepting split,
+    # then split blocks until no symbol distinguishes two states in a block.
+    block_of = {s: (s in accepting) for s in states}
+    while True:
+        signatures = {}
+        for s in states:
+            sig = (block_of[s],
+                   tuple(block_of[delta[s][sym]] for sym in alphabet))
+            signatures.setdefault(sig, []).append(s)
+        if len(signatures) == len(set(block_of.values())):
+            break  # refinement never merges, so equal counts = stable
+        block_of = {}
+        for sig, members in signatures.items():
+            for member in members:
+                block_of[member] = sig
+
+    # Canonical renumbering: BFS over blocks from the initial block, trying
+    # symbols in sorted order; blocks get integers in discovery order.
+    number = {block_of[machine["initial"]]: 0}
+    representative = {0: machine["initial"]}
+    queue = deque([machine["initial"]])
+    while queue:
+        state = queue.popleft()
+        for sym in alphabet:
+            target = delta[state][sym]
+            block = block_of[target]
+            if block not in number:
+                number[block] = len(number)
+                representative[number[block]] = target
+                queue.append(target)
+
+    n = len(number)
+    out_delta = {}
+    out_accepting = []
+    for idx in range(n):
+        rep = representative[idx]
+        out_delta[idx] = {
+            sym: number[block_of[delta[rep][sym]]] for sym in alphabet
+        }
+        if rep in accepting:
+            out_accepting.append(idx)
+    return {
+        "states": list(range(n)),
+        "alphabet": alphabet,
+        "delta": out_delta,
+        "initial": 0,
+        "accepting": out_accepting,
+    }
+
+
+def equivalent(a, b):
+    validate(a)
+    validate(b)
+    if set(a["alphabet"]) != set(b["alphabet"]):
+        raise DFAError("alphabets differ; the machines are not comparable")
+    alphabet = sorted(a["alphabet"])
+    accept_a = set(a["accepting"])
+    accept_b = set(b["accepting"])
+
+    start = (a["initial"], b["initial"])
+    seen = {start}
+    queue = deque([(start, "")])
+    while queue:
+        (sa, sb), word = queue.popleft()
+        if (sa in accept_a) != (sb in accept_b):
+            return (False, word)
+        for sym in alphabet:
+            pair = (a["delta"][sa][sym], b["delta"][sb][sym])
+            if pair not in seen:
+                seen.add(pair)
+                queue.append((pair, word + sym))
+    return (True, None)
