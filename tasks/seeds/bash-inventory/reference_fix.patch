diff --git a/inv.sh b/inv.sh
new file mode 100644
index 0000000..7364c32
--- /dev/null
+++ b/inv.sh
@@ -0,0 +1,84 @@
+#!/usr/bin/env bash
+# inv.sh — summarize an asset check-in feed.
+#
+# Feed: one scan per line, "<asset>\t<location>" (exactly one tab, both sides
+# non-empty, fields used verbatim). Lines starting with "#" and blank lines
+# are skipped; anything else malformed is warned about and skipped.
+# Counting is pure bash (associative arrays); sort(1) under LC_ALL=C is the
+# only external tool, for the section ordering.
+set -u
+
+TAB=$'\t'
+
+if [ $# -ne 1 ]; then
+  printf 'usage: inv.sh <feed-file>\n' >&2
+  exit 64
+fi
+feed=$1
+if [ ! -f "$feed" ] || [ ! -r "$feed" ]; then
+  printf 'inv.sh: cannot read: %s\n' "$feed" >&2
+  exit 66
+fi
+
+declare -A pair_count=() loc_scans=() loc_distinct=() name_seen=()
+scans=0
+lineno=0
+
+while IFS= read -r line; do
+  lineno=$((lineno + 1))
+  [ -z "$line" ] && continue
+  case $line in '#'*) continue ;; esac
+
+  tabs=${line//[!"$TAB"]/}
+  if [ "${#tabs}" -ne 1 ]; then
+    printf 'inv.sh: line %d: malformed, skipped\n' "$lineno" >&2
+    continue
+  fi
+  asset=${line%%"$TAB"*}
+  loc=${line#*"$TAB"}
+  if [ -z "$asset" ] || [ -z "$loc" ]; then
+    printf 'inv.sh: line %d: malformed, skipped\n' "$lineno" >&2
+    continue
+  fi
+
+  scans=$((scans + 1))
+  key="$asset$TAB$loc"
+  if [ -z "${pair_count[$key]:-}" ]; then
+    pair_count[$key]=1
+    loc_distinct[$loc]=$(( ${loc_distinct[$loc]:-0} + 1 ))
+  else
+    pair_count[$key]=$(( ${pair_count[$key]} + 1 ))
+  fi
+  loc_scans[$loc]=$(( ${loc_scans[$loc]:-0} + 1 ))
+  name_seen[$asset]=1
+done < "$feed"
+
+print_sorted() { # print the given rows one per line in C byte order
+  [ $# -eq 0 ] && return 0
+  printf '%s\n' "$@" | LC_ALL=C sort
+}
+
+rows=()
+for loc in "${!loc_scans[@]}"; do
+  rows+=("$loc$TAB${loc_distinct[$loc]}$TAB${loc_scans[$loc]}")
+done
+printf 'BY-LOCATION\n'
+print_sorted "${rows[@]}"
+
+reps=()
+repeated=0
+for key in "${!pair_count[@]}"; do
+  count=${pair_count[$key]}
+  if [ "$count" -ge 2 ]; then
+    reps+=("$key$TAB$count")
+    repeated=$((repeated + 1))
+  fi
+done
+printf 'REPEATED\n'
+print_sorted "${reps[@]}"
+
+printf 'TOTALS\n'
+printf 'locations\t%d\n' "${#loc_scans[@]}"
+printf 'assets\t%d\n' "${#name_seen[@]}"
+printf 'scans\t%d\n' "$scans"
+printf 'repeated\t%d\n' "$repeated"
