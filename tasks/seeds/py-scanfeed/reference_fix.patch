+def dedupe(records, duped=None):
+    """Lazily drop repeats of the last kept scan of each package.
+
+    A repeat is a record whose (event, depot) equals the last record
+    this stage let through for the same package — the double-fire
+    signature of the hand scanners. Skips go to ``duped(record)``.
+    """
+    last_seen = {}
+    for record in records:
+        key = (record["event"], record["depot"])
+        if last_seen.get(record["package"]) == key:
+            if duped is not None:
+                duped(record)
+            continue
+        last_seen[record["package"]] = key
+        yield record
+
+
+def summarize(records):
+    """Consume a record stream into the events/packages/delivered summary."""
+    events = {}
+    packages = set()
+    delivered = set()
+    for record in records:
+        events[record["event"]] = events.get(record["event"], 0) + 1
+        packages.add(record["package"])
+        if record["event"] == "DELIVER":
+            delivered.add(record["package"])
+    return {
+        "events": events,
+        "packages": len(packages),
+        "delivered": sorted(delivered),
+    }
+
+
+def run(lines, bad=None):
+    """Full pipeline: parse, drop QA, dedupe, summarize.
+
+    Returns the shift-summary dict with the discard counters included.
+    ``bad`` is still forwarded per malformed line when given.
+    """
+    counts = {"bad": 0, "dups": 0, "qa": 0}
+
+    def on_bad(lineno, line, reason):
+        counts["bad"] += 1
+        if bad is not None:
+            bad(lineno, line, reason)
+
+    def on_qa(_record):
+        counts["qa"] += 1
+
+    def on_dup(_record):
+        counts["dups"] += 1
+
+    survivors = dedupe(drop_qa(iter_records(lines, bad=on_bad),
+                               dropped=on_qa), duped=on_dup)
+    summary = summarize(survivors)
+    summary["bad_lines"] = counts["bad"]
+    summary["duplicates"] = counts["dups"]
+    summary["qa_dropped"] = counts["qa"]
+    return summary
