+//! Tetris-lite engine for the kiosk: fixture piece feed (no RNG), explicit
+//! gravity ticks, the classic four-state rotation tables, and pinned
+//! line-clear scoring. Every frame is reproducible from the command script.
+
+pub const WIDTH: usize = 10;
+pub const HEIGHT: usize = 20;
+pub const SCORES: [u32; 5] = [0, 100, 300, 500, 800];
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum Status {
+    Playing,
+    Complete,
+    ToppedOut,
+}
+
+const PIECES: &[u8] = b"IOTSZJL";
+
+// (row, col) offsets inside the piece box for states 0 (spawn), 1 (one CW
+// turn), 2 and 3. The box origin never rotates; only the offsets change.
+const CELLS: [[[(i32, i32); 4]; 4]; 7] = [
+    // I
+    [
+        [(1, 0), (1, 1), (1, 2), (1, 3)],
+        [(0, 2), (1, 2), (2, 2), (3, 2)],
+        [(2, 0), (2, 1), (2, 2), (2, 3)],
+        [(0, 1), (1, 1), (2, 1), (3, 1)],
+    ],
+    // O
+    [
+        [(0, 1), (0, 2), (1, 1), (1, 2)],
+        [(0, 1), (0, 2), (1, 1), (1, 2)],
+        [(0, 1), (0, 2), (1, 1), (1, 2)],
+        [(0, 1), (0, 2), (1, 1), (1, 2)],
+    ],
+    // T
+    [
+        [(0, 1), (1, 0), (1, 1), (1, 2)],
+        [(0, 1), (1, 1), (1, 2), (2, 1)],
+        [(1, 0), (1, 1), (1, 2), (2, 1)],
+        [(0, 1), (1, 0), (1, 1), (2, 1)],
+    ],
+    // S
+    [
+        [(0, 1), (0, 2), (1, 0), (1, 1)],
+        [(0, 1), (1, 1), (1, 2), (2, 2)],
+        [(1, 1), (1, 2), (2, 0), (2, 1)],
+        [(0, 0), (1, 0), (1, 1), (2, 1)],
+    ],
+    // Z
+    [
+        [(0, 0), (0, 1), (1, 1), (1, 2)],
+        [(0, 2), (1, 1), (1, 2), (2, 1)],
+        [(1, 0), (1, 1), (2, 1), (2, 2)],
+        [(0, 1), (1, 0), (1, 1), (2, 0)],
+    ],
+    // J
+    [
+        [(0, 0), (1, 0), (1, 1), (1, 2)],
+        [(0, 1), (0, 2), (1, 1), (2, 1)],
+        [(1, 0), (1, 1), (1, 2), (2, 2)],
+        [(0, 1), (1, 1), (2, 0), (2, 1)],
+    ],
+    // L
+    [
+        [(0, 2), (1, 0), (1, 1), (1, 2)],
+        [(0, 1), (1, 1), (2, 1), (2, 2)],
+        [(1, 0), (1, 1), (1, 2), (2, 0)],
+        [(0, 0), (0, 1), (1, 1), (2, 1)],
+    ],
+];
+
+#[derive(Debug, Clone, Copy)]
+struct Active {
+    kind: usize,
+    state: usize,
+    row: i32,
+    col: i32,
+}
+
+#[derive(Debug, Clone)]
+pub struct Game {
+    board: [[bool; WIDTH]; HEIGHT],
+    feed: Vec<usize>, // remaining pieces, next at the END
+    active: Option<Active>,
+    score: u32,
+    lines: u32,
+    status: Status,
+}
+
+impl Game {
+    pub fn new(feed: &str) -> Result<Game, String> {
+        if feed.is_empty() {
+            return Err("empty feed".to_string());
+        }
+        let mut kinds = Vec::with_capacity(feed.len());
+        for ch in feed.bytes() {
+            let kind = PIECES
+                .iter()
+                .position(|&p| p == ch)
+                .ok_or_else(|| format!("bad piece: {}", ch as char))?;
+            kinds.push(kind);
+        }
+        kinds.reverse();
+        let mut game = Game {
+            board: [[false; WIDTH]; HEIGHT],
+            feed: kinds,
+            active: None,
+            score: 0,
+            lines: 0,
+            status: Status::Playing,
+        };
+        game.spawn();
+        Ok(game)
+    }
+
+    fn fits(&self, kind: usize, state: usize, row: i32, col: i32) -> bool {
+        CELLS[kind][state].iter().all(|&(dr, dc)| {
+            let (r, c) = (row + dr, col + dc);
+            r >= 0
+                && c >= 0
+                && (r as usize) < HEIGHT
+                && (c as usize) < WIDTH
+                && !self.board[r as usize][c as usize]
+        })
+    }
+
+    fn spawn(&mut self) {
+        match self.feed.pop() {
+            None => self.status = Status::Complete,
+            Some(kind) => {
+                if self.fits(kind, 0, 0, 3) {
+                    self.active = Some(Active {
+                        kind,
+                        state: 0,
+                        row: 0,
+                        col: 3,
+                    });
+                } else {
+                    self.status = Status::ToppedOut;
+                }
+            }
+        }
+    }
+
+    fn lock(&mut self) {
+        let a = self.active.take().expect("lock with no active piece");
+        for &(dr, dc) in &CELLS[a.kind][a.state] {
+            self.board[(a.row + dr) as usize][(a.col + dc) as usize] = true;
+        }
+        let mut kept: Vec<[bool; WIDTH]> = self
+            .board
+            .iter()
+            .copied()
+            .filter(|row| !row.iter().all(|&c| c))
+            .collect();
+        let cleared = HEIGHT - kept.len();
+        while kept.len() < HEIGHT {
+            kept.insert(0, [false; WIDTH]);
+        }
+        for (i, row) in kept.into_iter().enumerate() {
+            self.board[i] = row;
+        }
+        self.score += SCORES[cleared];
+        self.lines += cleared as u32;
+        self.spawn();
+    }
+
+    pub fn step(&mut self, cmd: char) -> Result<(), String> {
+        if self.status != Status::Playing {
+            return Err("game over".to_string());
+        }
+        let a = self.active.expect("playing without an active piece");
+        match cmd {
+            'L' | 'R' => {
+                let col = if cmd == 'L' { a.col - 1 } else { a.col + 1 };
+                if self.fits(a.kind, a.state, a.row, col) {
+                    self.active.as_mut().unwrap().col = col;
+                }
+            }
+            'C' | 'A' => {
+                let state = if cmd == 'C' {
+                    (a.state + 1) % 4
+                } else {
+                    (a.state + 3) % 4
+                };
+                if self.fits(a.kind, state, a.row, a.col) {
+                    self.active.as_mut().unwrap().state = state;
+                }
+            }
+            'D' => {
+                if self.fits(a.kind, a.state, a.row + 1, a.col) {
+                    self.active.as_mut().unwrap().row += 1;
+                } else {
+                    self.lock();
+                }
+            }
+            'H' => {
+                let mut row = a.row;
+                while self.fits(a.kind, a.state, row + 1, a.col) {
+                    row += 1;
+                }
+                self.active.as_mut().unwrap().row = row;
+                self.lock();
+            }
+            other => return Err(format!("bad command: {other}")),
+        }
+        Ok(())
+    }
+
+    pub fn run(&mut self, script: &str) -> Result<usize, String> {
+        let mut n = 0;
+        for cmd in script.chars().filter(|c| !c.is_whitespace()) {
+            n += 1;
+            self.step(cmd).map_err(|e| format!("step {n} ({cmd}): {e}"))?;
+        }
+        Ok(n)
+    }
+
+    pub fn render(&self) -> String {
+        let mut grid = [[b'.'; WIDTH]; HEIGHT];
+        for (r, row) in self.board.iter().enumerate() {
+            for (c, &filled) in row.iter().enumerate() {
+                if filled {
+                    grid[r][c] = b'#';
+                }
+            }
+        }
+        if let Some(a) = self.active {
+            for &(dr, dc) in &CELLS[a.kind][a.state] {
+                grid[(a.row + dr) as usize][(a.col + dc) as usize] = b'@';
+            }
+        }
+        grid.iter()
+            .map(|row| String::from_utf8(row.to_vec()).unwrap())
+            .collect::<Vec<_>>()
+            .join("\n")
+    }
+
+    pub fn score(&self) -> u32 {
+        self.score
+    }
+
+    pub fn lines(&self) -> u32 {
+        self.lines
+    }
+
+    pub fn status(&self) -> Status {
+        self.status
+    }
+
+    pub fn is_over(&self) -> bool {
+        self.status != Status::Playing
+    }
+}
