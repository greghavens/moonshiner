index 0000000..ef71bc4
--- /dev/null
+++ b/state.go
@@ -0,0 +1,62 @@
+package migrunner
+
+import (
+	"encoding/json"
+	"errors"
+	"fmt"
+	"os"
+	"path/filepath"
+)
+
+// stateFile is the on-disk applied-history record. It is versioned so more
+// fields (checksums, timestamps) can be added without breaking old files.
+type stateFile struct {
+	Version int      `json:"version"`
+	Applied []string `json:"applied"`
+}
+
+// loadState reads the applied history from path. A missing file is a fresh
+// install and yields an empty history.
+func loadState(path string) ([]string, error) {
+	raw, err := os.ReadFile(path)
+	if errors.Is(err, os.ErrNotExist) {
+		return nil, nil
+	}
+	if err != nil {
+		return nil, fmt.Errorf("migrunner: read state %s: %w", path, err)
+	}
+	var sf stateFile
+	if err := json.Unmarshal(raw, &sf); err != nil {
+		return nil, fmt.Errorf("migrunner: parse state %s: %w", path, err)
+	}
+	return sf.Applied, nil
+}
+
+// saveState writes the applied history atomically: temp file, then rename,
+// so a crash mid-write can never leave a truncated state file.
+func saveState(path string, applied []string) error {
+	raw, err := json.MarshalIndent(stateFile{Version: 1, Applied: applied}, "", "  ")
+	if err != nil {
+		return fmt.Errorf("migrunner: encode state: %w", err)
+	}
+	dir := filepath.Dir(path)
+	tmp, err := os.CreateTemp(dir, ".migrunner-state-*")
+	if err != nil {
+		return fmt.Errorf("migrunner: create temp state: %w", err)
+	}
+	tmpPath := tmp.Name()
+	if _, err := tmp.Write(append(raw, '\n')); err != nil {
+		tmp.Close()
+		os.Remove(tmpPath)
+		return fmt.Errorf("migrunner: write state: %w", err)
+	}
+	if err := tmp.Close(); err != nil {
+		os.Remove(tmpPath)
+		return fmt.Errorf("migrunner: close state: %w", err)
+	}
+	if err := os.Rename(tmpPath, path); err != nil {
+		os.Remove(tmpPath)
+		return fmt.Errorf("migrunner: swap state: %w", err)
+	}
+	return nil
+}
