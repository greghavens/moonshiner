diff --git a/mazeuf.c b/mazeuf.c
new file mode 100644
index 0000000..40321a9
--- /dev/null
+++ b/mazeuf.c
@@ -0,0 +1,162 @@
+#include "mazeuf.h"
+
+#include <string.h>
+
+int uf_init(uf *u, int n) {
+    if (!u || n < 1 || n > 256) return -1;
+    u->n = n;
+    for (int i = 0; i < n; i++) {
+        u->parent[i] = (int16_t)i;
+        u->size[i] = 1;
+    }
+    return 0;
+}
+
+int uf_find(uf *u, int x) {
+    if (!u || x < 0 || x >= u->n) return -1;
+    int root = x;
+    while (u->parent[root] != root) root = u->parent[root];
+    while (u->parent[x] != root) {
+        int next = u->parent[x];
+        u->parent[x] = (int16_t)root;
+        x = next;
+    }
+    return root;
+}
+
+int uf_union(uf *u, int a, int b) {
+    int ra = uf_find(u, a), rb = uf_find(u, b);
+    if (ra < 0 || rb < 0) return -1;
+    if (ra == rb) return 0;
+    if (u->size[ra] < u->size[rb]) {
+        int t = ra;
+        ra = rb;
+        rb = t;
+    }
+    u->parent[rb] = (int16_t)ra;
+    u->size[ra] = (int16_t)(u->size[ra] + u->size[rb]);
+    return 1;
+}
+
+typedef struct {
+    uint8_t r, c;
+    char dir; /* 'E' or 'S' */
+} wall;
+
+static uint32_t lcg_next(uint32_t *state) {
+    *state = (*state * 1103515245u + 12345u) & 0x7FFFFFFFu;
+    return *state >> 16;
+}
+
+int maze_generate(maze *m, int w, int h, uint32_t seed) {
+    if (!m || w < 2 || w > MAZE_MAX || h < 2 || h > MAZE_MAX) return -1;
+    m->w = w;
+    m->h = h;
+    memset(m->open_e, 0, sizeof m->open_e);
+    memset(m->open_s, 0, sizeof m->open_s);
+
+    wall walls[2 * MAZE_MAX * MAZE_MAX];
+    int nwalls = 0;
+    for (int r = 0; r < h; r++) {
+        for (int c = 0; c < w; c++) {
+            if (c + 1 < w) {
+                walls[nwalls].r = (uint8_t)r;
+                walls[nwalls].c = (uint8_t)c;
+                walls[nwalls].dir = 'E';
+                nwalls++;
+            }
+            if (r + 1 < h) {
+                walls[nwalls].r = (uint8_t)r;
+                walls[nwalls].c = (uint8_t)c;
+                walls[nwalls].dir = 'S';
+                nwalls++;
+            }
+        }
+    }
+
+    uint32_t state = seed;
+    for (int i = nwalls - 1; i >= 1; i--) {
+        int j = (int)(lcg_next(&state) % (uint32_t)(i + 1));
+        wall t = walls[i];
+        walls[i] = walls[j];
+        walls[j] = t;
+    }
+
+    uf sets;
+    uf_init(&sets, w * h);
+    for (int i = 0; i < nwalls; i++) {
+        int a = walls[i].r * w + walls[i].c;
+        int b = (walls[i].dir == 'E') ? a + 1 : a + w;
+        if (uf_union(&sets, a, b) == 1) {
+            if (walls[i].dir == 'E') m->open_e[walls[i].r][walls[i].c] = 1;
+            else m->open_s[walls[i].r][walls[i].c] = 1;
+        }
+    }
+    return 0;
+}
+
+int maze_render(const maze *m, char *buf, size_t cap) {
+    if (!m || !buf) return -1;
+    int rows = 2 * m->h + 1, cols = 2 * m->w + 1;
+    size_t need = (size_t)rows * (size_t)(cols + 1) + 1;
+    if (cap < need) return -1;
+    char *p = buf;
+    for (int rr = 0; rr < rows; rr++) {
+        for (int cc = 0; cc < cols; cc++) {
+            char ch = '#';
+            if (rr % 2 == 1 && cc % 2 == 1) {
+                ch = ' ';
+            } else if (rr % 2 == 1 && cc % 2 == 0) {
+                int c = cc / 2;
+                if (c >= 1 && c <= m->w - 1 && m->open_e[rr / 2][c - 1])
+                    ch = ' ';
+            } else if (rr % 2 == 0 && cc % 2 == 1) {
+                int r = rr / 2;
+                if (r >= 1 && r <= m->h - 1 && m->open_s[r - 1][cc / 2])
+                    ch = ' ';
+            }
+            *p++ = ch;
+        }
+        *p++ = '\n';
+    }
+    *p = '\0';
+    return (int)(need - 1);
+}
+
+static int passage_open(const maze *m, int r, int c, char d) {
+    switch (d) {
+    case 'E': return c + 1 < m->w && m->open_e[r][c];
+    case 'W': return c - 1 >= 0 && m->open_e[r][c - 1];
+    case 'S': return r + 1 < m->h && m->open_s[r][c];
+    case 'N': return r - 1 >= 0 && m->open_s[r - 1][c];
+    }
+    return 0;
+}
+
+int maze_solve(const maze *m, char *dirs, size_t cap) {
+    static const char cw[] = {'N', 'E', 'S', 'W'};
+    if (!m || !dirs) return -1;
+    int r = 0, c = 0, facing = 1; /* index into cw[]: start facing east */
+    size_t len = 0;
+    while (r != m->h - 1 || c != m->w - 1) {
+        /* right, straight, left, back — relative to the current facing */
+        static const int offs[] = {1, 0, 3, 2};
+        for (int i = 0; i < 4; i++) {
+            int d = (facing + offs[i]) % 4;
+            if (passage_open(m, r, c, cw[d])) {
+                facing = d;
+                break;
+            }
+        }
+        switch (cw[facing]) {
+        case 'N': r--; break;
+        case 'E': c++; break;
+        case 'S': r++; break;
+        case 'W': c--; break;
+        }
+        if (len + 1 >= cap) return -1;
+        dirs[len++] = cw[facing];
+    }
+    dirs[len] = '\0';
+    return (int)len;
+}
diff --git a/mazeuf.h b/mazeuf.h
new file mode 100644
index 0000000..4b97695
--- /dev/null
+++ b/mazeuf.h
@@ -0,0 +1,24 @@
+#ifndef MAZEUF_H
+#define MAZEUF_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+typedef struct { int16_t parent[256]; int16_t size[256]; int n; } uf;
+
+int uf_init(uf *u, int n);
+int uf_find(uf *u, int x);
+int uf_union(uf *u, int a, int b);
+
+#define MAZE_MAX 16
+typedef struct {
+    int w, h;
+    uint8_t open_e[MAZE_MAX][MAZE_MAX]; /* open_e[r][c]: passage (r,c)->(r,c+1) */
+    uint8_t open_s[MAZE_MAX][MAZE_MAX]; /* open_s[r][c]: passage (r,c)->(r+1,c) */
+} maze;
+
+int maze_generate(maze *m, int w, int h, uint32_t seed);
+int maze_render(const maze *m, char *buf, size_t cap);
+int maze_solve(const maze *m, char *dirs, size_t cap);
+
+#endif /* MAZEUF_H */
