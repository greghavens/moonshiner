+package shortener
+
+import (
+	"crypto/rand"
+	"fmt"
+	"regexp"
+)
+
+const codeAlphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-"
+
+var codePattern = regexp.MustCompile(`^[A-Za-z0-9_-]{1,32}$`)
+
+// validCode reports whether a client-supplied vanity code is acceptable.
+func validCode(code string) bool {
+	return codePattern.MatchString(code)
+}
+
+// randomCode returns an 8-character code from the link alphabet.
+// 64^8 possibilities; uniqueness is still enforced by the store.
+func randomCode() (string, error) {
+	var buf [8]byte
+	if _, err := rand.Read(buf[:]); err != nil {
+		return "", fmt.Errorf("generate code: %w", err)
+	}
+	for i, b := range buf {
+		buf[i] = codeAlphabet[int(b)%len(codeAlphabet)]
+	}
+	return string(buf[:]), nil
+}
