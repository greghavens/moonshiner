index 0000000..4be58bf
--- /dev/null
+++ b/ewma_alarm.py
@@ -0,0 +1,70 @@
+"""EWMA-smoothed alarm with hysteresis and warmup suppression."""
+
+import math
+
+
+def _require_number(x, what):
+    if isinstance(x, bool) or not isinstance(x, (int, float)):
+        raise ValueError("%s must be a number: %r" % (what, x))
+    if not math.isfinite(x):
+        raise ValueError("%s must be finite: %r" % (what, x))
+    return float(x)
+
+
+class AlarmMonitor:
+    def __init__(self, alpha, high, low, warmup=0):
+        alpha = _require_number(alpha, "alpha")
+        if not 0 < alpha <= 1:
+            raise ValueError("alpha must be in (0, 1]: %r" % (alpha,))
+        high = _require_number(high, "high")
+        low = _require_number(low, "low")
+        if not low < high:
+            raise ValueError("low (%r) must be below high (%r)" % (low, high))
+        if not isinstance(warmup, int) or isinstance(warmup, bool) \
+                or warmup < 0:
+            raise ValueError("warmup must be a non-negative int: %r"
+                             % (warmup,))
+        self._alpha = alpha
+        self._high = high
+        self._low = low
+        self._warmup = warmup
+        self.reset()
+
+    def reset(self):
+        self._ewma = None
+        self._samples = 0
+        self._state = "ok"
+        self._events = []
+
+    @property
+    def state(self):
+        return self._state
+
+    @property
+    def value(self):
+        return self._ewma
+
+    @property
+    def samples(self):
+        return self._samples
+
+    @property
+    def events(self):
+        return list(self._events)
+
+    def observe(self, value):
+        value = _require_number(value, "sample")
+        if self._ewma is None:
+            self._ewma = value
+        else:
+            self._ewma = self._alpha * value + (1 - self._alpha) * self._ewma
+        index = self._samples
+        self._samples += 1
+        if index >= self._warmup:
+            if self._state == "ok" and self._ewma >= self._high:
+                self._state = "alarm"
+                self._events.append((index, "raised"))
+            elif self._state == "alarm" and self._ewma <= self._low:
+                self._state = "ok"
+                self._events.append((index, "cleared"))
+        return self._state
