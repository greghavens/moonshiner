+//! In-house iterator adapters (itertools replacement, stdlib only).
+//!
+//! Three adapters implemented as real [`Iterator`] structs with a strict
+//! laziness contract:
+//!
+//! 1. construction pulls nothing from the source;
+//! 2. lookahead is bounded and buffered — an element pulled to find a
+//!    boundary is handed back later, never re-pulled;
+//! 3. once the source returns `None` it is never polled again (sources are
+//!    not guaranteed to be fused);
+//! 4. `intersperse` clones the separator exactly once per emission and never
+//!    clones items; `chunk_by` / `dedup_by_key` need no `Clone` at all.
+
+/// Extension trait providing the adapters on every iterator.
+pub trait IterAdapters: Iterator + Sized {
+    /// Group consecutive elements. The predicate is called with
+    /// `(&previous_element, &candidate)` — the immediately preceding element,
+    /// like `slice::chunk_by` — and the candidate joins the current group
+    /// while the predicate returns `true`.
+    fn chunk_by<F>(self, same_group: F) -> ChunkBy<Self, F>
+    where
+        F: FnMut(&Self::Item, &Self::Item) -> bool,
+    {
+        ChunkBy {
+            iter: self,
+            same_group,
+            lookahead: None,
+            done: false,
+        }
+    }
+
+    /// Skip elements whose key equals the key of the last yielded element.
+    /// Consecutive runs collapse to their first element; non-adjacent
+    /// repeats survive. Only the key is stored, so items move through.
+    fn dedup_by_key<K, F>(self, key: F) -> DedupByKey<Self, K, F>
+    where
+        K: PartialEq,
+        F: FnMut(&Self::Item) -> K,
+    {
+        DedupByKey {
+            iter: self,
+            key,
+            last_key: None,
+            done: false,
+        }
+    }
+
+    /// Yield `separator` between adjacent elements — never leading or
+    /// trailing. The separator is cloned once per emission.
+    fn intersperse(self, separator: Self::Item) -> Intersperse<Self>
+    where
+        Self::Item: Clone,
+    {
+        Intersperse {
+            iter: self,
+            separator,
+            lookahead: None,
+            started: false,
+            done: false,
+        }
+    }
+}
+
+impl<I: Iterator> IterAdapters for I {}
+
+/// Iterator over `Vec` groups of consecutive elements accepted by a
+/// predicate. See [`IterAdapters::chunk_by`].
+pub struct ChunkBy<I: Iterator, F> {
+    iter: I,
+    same_group: F,
+    /// First element of the next group, pulled while finding the boundary.
+    lookahead: Option<I::Item>,
+    done: bool,
+}
+
+impl<I, F> Iterator for ChunkBy<I, F>
+where
+    I: Iterator,
+    F: FnMut(&I::Item, &I::Item) -> bool,
+{
+    type Item = Vec<I::Item>;
+
+    fn next(&mut self) -> Option<Vec<I::Item>> {
+        let first = match self.lookahead.take() {
+            Some(buffered) => buffered,
+            None => {
+                if self.done {
+                    return None;
+                }
+                match self.iter.next() {
+                    Some(item) => item,
+                    None => {
+                        self.done = true;
+                        return None;
+                    }
+                }
+            }
+        };
+        let mut group = vec![first];
+        loop {
+            match self.iter.next() {
+                None => {
+                    self.done = true;
+                    break;
+                }
+                Some(item) => {
+                    if (self.same_group)(group.last().unwrap(), &item) {
+                        group.push(item);
+                    } else {
+                        self.lookahead = Some(item);
+                        break;
+                    }
+                }
+            }
+        }
+        Some(group)
+    }
+}
+
+/// Iterator skipping consecutive elements with equal keys. See
+/// [`IterAdapters::dedup_by_key`].
+pub struct DedupByKey<I: Iterator, K, F> {
+    iter: I,
+    key: F,
+    last_key: Option<K>,
+    done: bool,
+}
+
+impl<I, K, F> Iterator for DedupByKey<I, K, F>
+where
+    I: Iterator,
+    K: PartialEq,
+    F: FnMut(&I::Item) -> K,
+{
+    type Item = I::Item;
+
+    fn next(&mut self) -> Option<I::Item> {
+        if self.done {
+            return None;
+        }
+        loop {
+            match self.iter.next() {
+                None => {
+                    self.done = true;
+                    return None;
+                }
+                Some(item) => {
+                    let k = (self.key)(&item);
+                    if self.last_key.as_ref() != Some(&k) {
+                        self.last_key = Some(k);
+                        return Some(item);
+                    }
+                }
+            }
+        }
+    }
+}
+
+/// Iterator yielding a separator between adjacent elements. See
+/// [`IterAdapters::intersperse`].
+pub struct Intersperse<I: Iterator> {
+    iter: I,
+    separator: I::Item,
+    /// Successor buffered while deciding whether a separator is due.
+    lookahead: Option<I::Item>,
+    started: bool,
+    done: bool,
+}
+
+impl<I> Iterator for Intersperse<I>
+where
+    I: Iterator,
+    I::Item: Clone,
+{
+    type Item = I::Item;
+
+    fn next(&mut self) -> Option<I::Item> {
+        if !self.started {
+            self.started = true;
+            return match self.iter.next() {
+                Some(item) => Some(item),
+                None => {
+                    self.done = true;
+                    None
+                }
+            };
+        }
+        if let Some(buffered) = self.lookahead.take() {
+            return Some(buffered);
+        }
+        if self.done {
+            return None;
+        }
+        match self.iter.next() {
+            None => {
+                self.done = true;
+                None
+            }
+            Some(item) => {
+                self.lookahead = Some(item);
+                Some(self.separator.clone())
+            }
+        }
+    }
+}
