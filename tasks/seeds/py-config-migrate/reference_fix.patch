@@ -0,0 +1,34 @@
+"""Registration of stepwise migrations and per-version validators."""
+
+_MIGRATIONS = {}   # from_version -> callable(config) -> config at from_version+1
+_VALIDATORS = {}   # version -> callable(config) -> list of problems (or None)
+
+
+def migration(from_version):
+    """Decorator: register the step migrating from_version -> from_version+1."""
+    def decorator(func):
+        if from_version in _MIGRATIONS:
+            raise ValueError(f"migration for v{from_version} already registered")
+        _MIGRATIONS[from_version] = func
+        return func
+    return decorator
+
+
+def validator(version):
+    """Decorator: register the validator for one config version."""
+    def decorator(func):
+        if version in _VALIDATORS:
+            raise ValueError(f"validator for v{version} already registered")
+        _VALIDATORS[version] = func
+        return func
+    return decorator
+
+
+def migration_for(from_version):
+    if from_version not in _MIGRATIONS:
+        raise LookupError(f"no migration registered from v{from_version}")
+    return _MIGRATIONS[from_version]
+
+
+def validator_for(version):
+    return _VALIDATORS.get(version)
