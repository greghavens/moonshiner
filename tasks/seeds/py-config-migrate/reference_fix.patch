+"""Migration engine: walk a config through registered steps, validating."""
+import copy
+
+from confmig import registry
+
+LATEST = 4
+
+
+class DowngradeError(Exception):
+    """Asked to migrate a config to an older version."""
+
+
+class ValidationError(Exception):
+    """A config failed its version's validator."""
+
+
+def _version_of(config):
+    version = config.get("version") if isinstance(config, dict) else None
+    if not isinstance(version, int) or isinstance(version, bool) or version < 1:
+        raise ValueError(f"config version must be an integer >= 1, got {version!r}")
+    return version
+
+
+def _validate(config, version):
+    check = registry.validator_for(version)
+    if check is None:
+        return
+    problems = check(config) or []
+    if problems:
+        raise ValidationError(f"invalid v{version} config: " + "; ".join(problems))
+
+
+def upgrade(config, target=None):
+    """Return config migrated to target (default LATEST). Pure function."""
+    if target is None:
+        target = LATEST
+    current = _version_of(config)
+    if target < current:
+        raise DowngradeError(f"refusing downgrade from v{current} to v{target}")
+    working = copy.deepcopy(config)
+    _validate(working, current)
+    while current < target:
+        step = registry.migration_for(current)
+        working = step(working)
+        current += 1
+        working["version"] = current
+        _validate(working, current)
+    return working
