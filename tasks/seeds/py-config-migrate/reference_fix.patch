+"""The actual migration steps and validators for the app config."""
+from confmig.registry import migration, validator
+
+LOG_LEVELS = ("debug", "info")
+
+
+def _problems(config, checks):
+    return [message for ok, message in checks if not ok]
+
+
+def _split_server(value):
+    host, _, port = value.rpartition(":")
+    return host, port
+
+
+# ---- validators -----------------------------------------------------------
+
+@validator(1)
+def check_v1(config):
+    server = config.get("server")
+    server_ok = isinstance(server, str) and ":" in server
+    if server_ok:
+        host, port = _split_server(server)
+        server_ok = bool(host) and port.isdigit()
+    return _problems(config, [
+        (server_ok, "server must be a host:port string with an integer port"),
+        (isinstance(config.get("debug"), bool), "debug must be a bool"),
+        (isinstance(config.get("log_file"), str) and config.get("log_file"),
+         "log_file must be a non-empty string"),
+    ])
+
+
+@validator(2)
+def check_v2(config):
+    port = config.get("port")
+    return _problems(config, [
+        (isinstance(config.get("host"), str) and config.get("host"),
+         "host must be a non-empty string"),
+        (isinstance(port, int) and not isinstance(port, bool)
+         and 1 <= port <= 65535, "port must be an int in 1..65535"),
+        (isinstance(config.get("debug"), bool), "debug must be a bool"),
+        (isinstance(config.get("log_file"), str) and config.get("log_file"),
+         "log_file must be a non-empty string"),
+    ])
+
+
+@validator(3)
+def check_v3(config):
+    return _problems(config, [
+        (isinstance(config.get("host"), str) and config.get("host"),
+         "host must be a non-empty string"),
+        (isinstance(config.get("port"), int), "port must be an int"),
+        (config.get("log_level") in LOG_LEVELS,
+         "log_level must be 'debug' or 'info'"),
+        (isinstance(config.get("log_file"), str) and config.get("log_file"),
+         "log_file must be a non-empty string"),
+    ])
+
+
+@validator(4)
+def check_v4(config):
+    logging = config.get("logging")
+    logging_ok = (isinstance(logging, dict)
+                  and logging.get("level") in LOG_LEVELS
+                  and isinstance(logging.get("file"), str))
+    return _problems(config, [
+        (isinstance(config.get("host"), str) and config.get("host"),
+         "host must be a non-empty string"),
+        (isinstance(config.get("port"), int), "port must be an int"),
+        (logging_ok, "logging must be {'level': ..., 'file': ...}"),
+    ])
+
+
+# ---- migrations -----------------------------------------------------------
+
+@migration(1)
+def v1_to_v2(config):
+    host, port = _split_server(config.pop("server"))
+    config["host"] = host
+    config["port"] = int(port)
+    return config
+
+
+@migration(2)
+def v2_to_v3(config):
+    config["log_level"] = "debug" if config.pop("debug") else "info"
+    return config
+
+
+@migration(3)
+def v3_to_v4(config):
+    config["logging"] = {"level": config.pop("log_level"),
+                         "file": config.pop("log_file")}
+    return config
