+#!/usr/bin/env python3
+"""Config migration CLI.
+
+    python3 confmigrate.py upgrade app.json [--to N]
+    python3 confmigrate.py version app.json
+"""
+import argparse
+import json
+import sys
+
+from confmig import engine
+
+RUNTIME_ERROR = 1
+
+
+def load(path):
+    """Return (config, original_bytes)."""
+    with open(path, "rb") as f:
+        raw = f.read()
+    return json.loads(raw.decode("utf-8")), raw
+
+
+def cmd_upgrade(path, target):
+    config, raw = load(path)
+    migrated = engine.upgrade(config, target)
+    old = config.get("version")
+    new = migrated["version"]
+    if new == old:
+        print(f"already at v{new}")
+        return 0
+    # backup first, with the original bytes untouched by any reformatting
+    with open(path + ".bak", "wb") as f:
+        f.write(raw)
+    with open(path, "w") as f:
+        json.dump(migrated, f, indent=2)
+        f.write("\n")
+    print(f"migrated {path}: v{old} -> v{new}")
+    return 0
+
+
+def cmd_version(path):
+    config, _ = load(path)
+    version = config.get("version")
+    if not isinstance(version, int) or isinstance(version, bool):
+        raise ValueError(f"config has no integer version: {version!r}")
+    print(f"v{version}")
+    return 0
+
+
+def main():
+    parser = argparse.ArgumentParser(prog="confmigrate.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_upgrade = sub.add_parser("upgrade")
+    p_upgrade.add_argument("file")
+    p_upgrade.add_argument("--to", type=int, default=None)
+
+    p_version = sub.add_parser("version")
+    p_version.add_argument("file")
+
+    args = parser.parse_args()
+    try:
+        if args.command == "upgrade":
+            return cmd_upgrade(args.file, args.to)
+        return cmd_version(args.file)
+    except (engine.DowngradeError, engine.ValidationError, LookupError,
+            ValueError, OSError) as e:
+        print(f"error: {e}", file=sys.stderr)
+        return RUNTIME_ERROR
+
+
+if __name__ == "__main__":
+    sys.exit(main())
