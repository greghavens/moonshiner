+//! Aho-Corasick-style automaton: all patterns are compiled into one trie
+//! with failure links, then flattened into a dense goto table so scanning is
+//! a single table lookup per input byte, independent of the pattern count.
+
+use crate::Match;
+
+const NONE: u32 = u32::MAX;
+
+pub(crate) struct Automaton {
+    /// Byte -> dense class id; class 0 is "byte absent from every pattern",
+    /// which can only ever lead back to the root.
+    classes: [u16; 256],
+    nclasses: usize,
+    /// Flattened goto table: `next[state * nclasses + class]`.
+    next: Vec<u32>,
+    /// Pattern ids ending at each state, own hits plus every hit inherited
+    /// along the failure chain (dictionary suffixes).
+    out: Vec<Vec<u32>>,
+    pat_len: Vec<usize>,
+}
+
+impl Automaton {
+    pub(crate) fn build(patterns: &[String]) -> Automaton {
+        let mut classes = [0u16; 256];
+        let mut nclasses = 1usize; // class 0 reserved for "not in any pattern"
+        for p in patterns {
+            for &b in p.as_bytes() {
+                if classes[b as usize] == 0 {
+                    classes[b as usize] = nclasses as u16;
+                    nclasses += 1;
+                }
+            }
+        }
+
+        // Trie construction over class ids.
+        let mut rows: Vec<Vec<u32>> = vec![vec![NONE; nclasses]];
+        let mut out: Vec<Vec<u32>> = vec![Vec::new()];
+        for (pid, p) in patterns.iter().enumerate() {
+            let mut state = 0usize;
+            for &b in p.as_bytes() {
+                let class = classes[b as usize] as usize;
+                if rows[state][class] == NONE {
+                    rows.push(vec![NONE; nclasses]);
+                    out.push(Vec::new());
+                    rows[state][class] = (rows.len() - 1) as u32;
+                }
+                state = rows[state][class] as usize;
+            }
+            out[state].push(pid as u32);
+        }
+
+        // Breadth-first pass: compute failure links, fold each state's
+        // failure outputs into its own output list, and complete the goto
+        // table so every (state, class) has a target.
+        let mut fail = vec![0u32; rows.len()];
+        let mut queue = std::collections::VecDeque::new();
+        for class in 0..nclasses {
+            match rows[0][class] {
+                NONE => rows[0][class] = 0,
+                s => {
+                    fail[s as usize] = 0;
+                    queue.push_back(s as usize);
+                }
+            }
+        }
+        while let Some(u) = queue.pop_front() {
+            let f = fail[u] as usize;
+            let inherited = out[f].clone();
+            out[u].extend(inherited);
+            for class in 0..nclasses {
+                let v = rows[u][class];
+                if v == NONE {
+                    rows[u][class] = rows[f][class];
+                } else {
+                    fail[v as usize] = rows[f][class];
+                    queue.push_back(v as usize);
+                }
+            }
+        }
+
+        let mut next = Vec::with_capacity(rows.len() * nclasses);
+        for row in &rows {
+            next.extend_from_slice(row);
+        }
+        Automaton {
+            classes,
+            nclasses,
+            next,
+            out,
+            pat_len: patterns.iter().map(|p| p.len()).collect(),
+        }
+    }
+
+    pub(crate) fn find_all(&self, hay: &[u8]) -> Vec<Match> {
+        let mut matches = Vec::new();
+        let mut state = 0usize;
+        for (i, &b) in hay.iter().enumerate() {
+            let class = self.classes[b as usize] as usize;
+            state = self.next[state * self.nclasses + class] as usize;
+            let hits = &self.out[state];
+            if !hits.is_empty() {
+                for &pid in hits {
+                    matches.push(Match {
+                        start: i + 1 - self.pat_len[pid as usize],
+                        pattern: pid as usize,
+                    });
+                }
+            }
+        }
+        // Hits are produced in end-position order; the contract is
+        // (start, pattern id).
+        matches.sort_unstable();
+        matches
+    }
+}
