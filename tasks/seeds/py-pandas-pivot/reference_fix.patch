+"""Monthly usage rollup for the metering export."""
+import pandas as pd
+
+COLUMNS = ["date", "team", "resource", "hours", "rate", "cost"]
+
+
+def load_usage(path):
+    """Read the metering CSV with strict dtypes and a derived cost column."""
+    df = pd.read_csv(
+        path,
+        dtype={"team": "category", "resource": "category",
+               "hours": "int64", "rate": "float64"},
+        parse_dates=["date"],
+    )
+    df["cost"] = (df["hours"] * df["rate"]).astype("float64")
+    return df[COLUMNS]
+
+
+def team_totals(df):
+    """One row per team: total hours, total cost, and entry count."""
+    totals = (
+        df.groupby("team", observed=True)
+          .agg(hours=("hours", "sum"), cost=("cost", "sum"),
+               entries=("hours", "size"))
+          .reset_index()
+    )
+    totals["team"] = totals["team"].astype(str)
+    return totals.sort_values("team").reset_index(drop=True)
+
+
+def monthly_matrix(df):
+    """Month-by-resource cost matrix with zero-filled gaps."""
+    frame = df.assign(month=df["date"].dt.strftime("%Y-%m"))
+    matrix = frame.pivot_table(
+        index="month", columns="resource", values="cost",
+        aggfunc="sum", fill_value=0.0, observed=True,
+    )
+    matrix = matrix.astype("float64")
+    matrix.columns = [str(c) for c in matrix.columns]
+    matrix = matrix.reindex(sorted(matrix.columns), axis=1)
+    matrix.columns.name = None
+    return matrix.sort_index()
+
+
+def write_report(matrix, path):
+    """Write the matrix as a stable CSV: two decimals, LF line endings."""
+    matrix.to_csv(path, float_format="%.2f", lineterminator="\n")
