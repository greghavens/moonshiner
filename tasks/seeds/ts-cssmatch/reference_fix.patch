+// cssmatch.ts — selector engine for the template-lint object trees.
+//
+// Supported subset: type / .class / #id / compounds, [attr] and [attr=value],
+// :first-child and :nth-child(N), descendant and child combinators. Anything
+// else throws at parse time so rules can validate their selectors up front.
+
+export type DomNode = { tag: string; attrs: Record<string, string>; children: DomNode[] };
+
+type Simple =
+  | { kind: 'type'; name: string }
+  | { kind: 'class'; name: string }
+  | { kind: 'id'; name: string }
+  | { kind: 'attr'; name: string; value: string | null }
+  | { kind: 'first-child' }
+  | { kind: 'nth-child'; index: number };
+
+// combinator relates this compound to the one on its LEFT (' ' for the first)
+type Compound = { combinator: ' ' | '>'; parts: Simple[] };
+
+export type ParsedSelector = { compounds: Compound[] };
+
+const IDENT_CHAR = /[A-Za-z0-9_-]/;
+
+export function parseSelector(source: string): ParsedSelector {
+  const src = source;
+  const n = src.length;
+  let i = 0;
+
+  function fail(detail: string): never {
+    throw new Error(`unsupported selector ${JSON.stringify(source)}: ${detail}`);
+  }
+
+  function skipWs(): boolean {
+    const start = i;
+    while (i < n && /\s/.test(src[i])) i++;
+    return i > start;
+  }
+
+  function ident(what: string): string {
+    const start = i;
+    while (i < n && IDENT_CHAR.test(src[i])) i++;
+    if (i === start) fail(`expected ${what}`);
+    return src.slice(start, i);
+  }
+
+  function parsePseudo(): Simple {
+    const name = ident('a pseudo-class name');
+    if (name === 'first-child') return { kind: 'first-child' };
+    if (name !== 'nth-child') fail(`pseudo-class ":${name}" is not supported`);
+    if (src[i] !== '(') fail("expected '(' after :nth-child");
+    i++;
+    const start = i;
+    while (i < n && src[i] !== ')') i++;
+    if (i >= n) fail("expected ')'");
+    const arg = src.slice(start, i);
+    i++;
+    if (!/^[0-9]+$/.test(arg) || Number(arg) < 1) {
+      fail(`:nth-child argument must be a positive integer, got "${arg}"`);
+    }
+    return { kind: 'nth-child', index: Number(arg) };
+  }
+
+  function parseAttr(): Simple {
+    const name = ident('an attribute name');
+    let value: string | null = null;
+    if (src[i] === '=') {
+      i++;
+      if (src[i] === '"') {
+        i++;
+        const start = i;
+        while (i < n && src[i] !== '"') i++;
+        if (i >= n) fail('unclosed quoted attribute value');
+        value = src.slice(start, i);
+        i++;
+      } else {
+        value = ident('an attribute value');
+      }
+    }
+    if (src[i] !== ']') fail("expected ']'");
+    i++;
+    return { kind: 'attr', name, value };
+  }
+
+  function parseCompound(): Simple[] {
+    const parts: Simple[] = [];
+    if (i < n && IDENT_CHAR.test(src[i])) parts.push({ kind: 'type', name: ident('a tag name') });
+    for (;;) {
+      const c = src[i];
+      if (c === '.') {
+        i++;
+        parts.push({ kind: 'class', name: ident('a class name') });
+      } else if (c === '#') {
+        i++;
+        parts.push({ kind: 'id', name: ident('an id') });
+      } else if (c === '[') {
+        i++;
+        parts.push(parseAttr());
+      } else if (c === ':') {
+        i++;
+        parts.push(parsePseudo());
+      } else {
+        break;
+      }
+    }
+    if (parts.length === 0) fail(`unexpected character ${JSON.stringify(src[i])}`);
+    return parts;
+  }
+
+  skipWs();
+  if (i >= n) fail('empty selector');
+  const compounds: Compound[] = [{ combinator: ' ', parts: parseCompound() }];
+  for (;;) {
+    const hadWs = skipWs();
+    if (i >= n) break;
+    let combinator: ' ' | '>' = ' ';
+    if (src[i] === '>') {
+      i++;
+      combinator = '>';
+      skipWs();
+      if (i >= n) fail('selector ends with a combinator');
+    } else if (!hadWs) {
+      fail(`unexpected character ${JSON.stringify(src[i])}`);
+    }
+    compounds.push({ combinator, parts: parseCompound() });
+  }
+  return { compounds };
+}
+
+function classTokens(node: DomNode): string[] {
+  const cls = node.attrs['class'];
+  return cls === undefined ? [] : cls.split(/\s+/);
+}
+
+function matchesSimple(part: Simple, node: DomNode, parent: DomNode | null): boolean {
+  switch (part.kind) {
+    case 'type':
+      return node.tag === part.name;
+    case 'class':
+      return classTokens(node).includes(part.name);
+    case 'id':
+      return node.attrs['id'] === part.name;
+    case 'attr': {
+      const value = node.attrs[part.name];
+      if (value === undefined) return false;
+      return part.value === null || value === part.value;
+    }
+    case 'first-child':
+      return parent !== null && parent.children[0] === node;
+    case 'nth-child':
+      return parent !== null && parent.children[part.index - 1] === node;
+  }
+}
+
+// Does compound `ci` match path[pi]? path holds root..candidate, so ancestor
+// positions are simply lower indexes; descendant steps backtrack over them.
+function matchesAt(compounds: Compound[], ci: number, path: DomNode[], pi: number): boolean {
+  const node = path[pi];
+  const parent = pi > 0 ? path[pi - 1] : null;
+  if (!compounds[ci].parts.every((part) => matchesSimple(part, node, parent))) return false;
+  if (ci === 0) return true;
+  if (compounds[ci].combinator === '>') {
+    return pi > 0 && matchesAt(compounds, ci - 1, path, pi - 1);
+  }
+  for (let k = pi - 1; k >= 0; k--) {
+    if (matchesAt(compounds, ci - 1, path, k)) return true;
+  }
+  return false;
+}
+
+export function select(root: DomNode, selector: string): DomNode[] {
+  const { compounds } = parseSelector(selector);
+  const last = compounds.length - 1;
+  const out: DomNode[] = [];
+  const path: DomNode[] = [];
+
+  function visit(node: DomNode): void {
+    path.push(node);
+    if (matchesAt(compounds, last, path, path.length - 1)) out.push(node);
+    for (const child of node.children) visit(child);
+    path.pop();
+  }
+
+  visit(root);
+  return out;
+}
