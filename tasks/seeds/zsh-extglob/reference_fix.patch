diff --git a/sift.zsh b/sift.zsh
new file mode 100644
index 0000000..c6d098d
--- /dev/null
+++ b/sift.zsh
@@ -0,0 +1,59 @@
+#!/usr/bin/env zsh
+# sift.zsh — answer "which files match this pattern" with zsh's own globbing.
+#
+#   zsh sift.zsh [-c] <pattern> [dir]
+#
+# The pattern is a zsh extended glob, taken literally from argv and applied
+# with the ${~var} globbing flag — never eval. Plain files only, hidden files
+# stay hidden, results in byte order relative to DIR (default: .).
+emulate -R zsh
+setopt no_unset extended_glob
+
+# byte order is part of the contract, whatever locale the caller runs in
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  print -u2 -- 'usage: sift.zsh [-c] <pattern> [dir]'
+  exit 64
+}
+
+typeset -i count_only=0
+if (( $# > 0 )) && [[ $1 == -c ]]; then
+  count_only=1
+  shift
+fi
+(( $# >= 1 && $# <= 2 )) || usage
+pat=$1
+[[ -n $pat ]] || usage
+dir=${2:-.}
+if [[ ! -d $dir ]]; then
+  print -u2 -- "sift.zsh: not a directory: $dir"
+  exit 66
+fi
+
+cd -- "$dir" || exit 66
+
+typeset -a matches
+typeset -i broken=0
+{
+  matches=( ${~pat}(N.on) )
+} always {
+  if (( TRY_BLOCK_ERROR )); then
+    broken=1
+    TRY_BLOCK_ERROR=0
+  fi
+} 2>/dev/null
+
+if (( broken )); then
+  print -u2 -r -- "sift.zsh: bad pattern: $pat"
+  exit 2
+fi
+
+if (( count_only )); then
+  print -r -- "${#matches}"
+elif (( ${#matches} > 0 )); then
+  print -rl -- "${matches[@]}"
+fi
+(( ${#matches} > 0 )) && exit 0
+exit 1
