{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0066",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "commerce",
  "prompt": "Find the order “Volunteer T-shirt Order” at Denver Hub and report its stable ID, current date, location, and status. Do not make any changes yet. Write every date as YYYY-MM-DD and do not add details the tools did not return.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same order to Aurora Hub and set its date to 2026-10-20. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-24. Keep it at Aurora Hub; do not revert any other field."
    }
  ],
  "available_tools": [
    "commerce_search",
    "commerce_get",
    "commerce_list",
    "commerce_update",
    "commerce_cancel",
    "commerce_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "com-166",
        "name": "Volunteer T-shirt Order",
        "location": "Denver Hub",
        "date": "2026-08-17",
        "status": "active"
      },
      {
        "id": "com-566",
        "name": "Name Badge Order",
        "location": "Aurora Hub",
        "date": "2026-09-06",
        "status": "active"
      },
      {
        "id": "com-866",
        "name": "Volunteer T-shirt Order",
        "location": "Archive Store",
        "date": "2026-09-06",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "commerce_search",
            "arguments": {
              "query": "Volunteer T-shirt Order",
              "location": "Denver Hub"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "commerce_update",
            "arguments": {
              "id": "com-166",
              "date": "2026-10-20",
              "location": "Aurora Hub"
            }
          }
        ],
        "purpose": "Apply the requested date and location together to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "commerce_update",
            "arguments": {
              "id": "com-166",
              "date": "2026-11-24"
            }
          }
        ],
        "purpose": "Correct only the date while retaining the location set by the preceding update."
      }
    ],
    "state_assertions": [
      "com-166.date == 2026-11-24",
      "com-166.location == Aurora Hub",
      "com-166.status == active",
      "com-566.date == 2026-09-06",
      "com-866.date == 2026-09-06",
