diff --git a/stockrep.zsh b/stockrep.zsh
new file mode 100644
index 0000000..f65f386
--- /dev/null
+++ b/stockrep.zsh
@@ -0,0 +1,117 @@
+#!/usr/bin/env zsh
+# stockrep.zsh -- ledger report over a typeset -A store, zsh builtins only.
+# usage: stockrep.zsh <ledger> [first PATTERN | count PATTERN]
+emulate -R zsh
+setopt extended_glob
+LC_ALL=C
+
+TAB=$'\t'
+
+usage() {
+  print -ru2 -- 'usage: stockrep.zsh <ledger> [first PATTERN | count PATTERN]'
+}
+
+die_usage() { # die_usage <message>
+  print -ru2 -- "stockrep.zsh: $1"
+  usage
+  exit 64
+}
+
+if (( $# == 0 )); then
+  usage
+  exit 64
+fi
+
+ledger=$1
+shift
+if [[ ! -f $ledger || ! -r $ledger ]]; then
+  print -ru2 -- "stockrep.zsh: cannot read: $ledger"
+  exit 66
+fi
+
+mode=report
+pattern=''
+if (( $# > 0 )); then
+  mode=$1
+  shift
+  case $mode in
+    first|count) ;;
+    *) die_usage "unknown mode: $mode" ;;
+  esac
+  (( $# == 1 )) || die_usage 'wrong number of arguments'
+  pattern=$1
+fi
+
+# ---- parse the ledger into the associative store ----------------------------
+
+typeset -A qty
+typeset -a bad
+typeset line key
+
+while IFS= read -r line || [[ -n $line ]]; do
+  [[ -z $line || $line == '#'* ]] && continue
+  if [[ $line == (#b)([^.=[:space:]]##.[^=[:space:]]##)=(<->) ]]; then
+    key=$match[1]
+    (( qty[$key] += match[2] ))
+  else
+    bad+=( "$line" )
+  fi
+done < "$ledger"
+
+# ---- modes -------------------------------------------------------------------
+
+case $mode in
+  first)
+    key=${qty[(i)$pattern]}
+    if [[ -z $key ]]; then
+      print -ru2 -- "stockrep.zsh: no item matches: $pattern"
+      exit 1
+    fi
+    print -r -- "${key}${TAB}${qty[$key]}"
+    exit 0
+    ;;
+  count)
+    typeset -a hits
+    hits=( "${(@k)qty[(I)$pattern]}" )
+    print -r -- ${#hits}
+    for key in "${(@o)hits}"; do
+      print -r -- "${key}${TAB}${qty[$key]}"
+    done
+    exit 0
+    ;;
+esac
+
+# ---- full report ---------------------------------------------------------------
+
+typeset -A catkinds catunits
+typeset cat
+typeset -i units=0
+
+for key in "${(@k)qty}"; do
+  cat=${key%%.*}
+  (( catkinds[$cat] += 1 ))
+  (( catunits[$cat] += qty[$key] ))
+  (( units += qty[$key] ))
+done
+
+print -r -- CATEGORIES
+for cat in "${(@ko)catkinds}"; do
+  print -r -- "${cat}${TAB}${catkinds[$cat]}${TAB}${catunits[$cat]}"
+done
+
+print -r -- ITEMS
+for key in "${(@ko)qty}"; do
+  print -r -- "${key}${TAB}${qty[$key]}"
+done
+
+print -r -- MALFORMED
+for line in "${(@o)bad}"; do
+  print -r -- "$line"
+done
+
+print -r -- TOTALS
+print -r -- "categories${TAB}${#catkinds}"
+print -r -- "items${TAB}${#qty}"
+print -r -- "units${TAB}${units}"
+print -r -- "malformed${TAB}${#bad}"
+exit 0
