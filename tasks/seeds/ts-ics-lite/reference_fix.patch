+export interface CalendarEvent {
+  summary: string;
+  dtstart: string;
+  dtend: string;
+  description?: string;
+}
+
+const CRLF = '\r\n';
+const MAX_LINE = 75;
+
+function escapeText(value: string): string {
+  return value
+    .replace(/\\/g, '\\\\')
+    .replace(/;/g, '\\;')
+    .replace(/,/g, '\\,')
+    .replace(/\r\n|\r|\n/g, '\\n');
+}
+
+function unescapeText(value: string): string {
+  let out = '';
+  for (let i = 0; i < value.length; i++) {
+    const ch = value[i];
+    if (ch === '\\' && i + 1 < value.length) {
+      const next = value[i + 1];
+      out += next === 'n' || next === 'N' ? '\n' : next;
+      i++;
+    } else {
+      out += ch;
+    }
+  }
+  return out;
+}
+
+function foldLine(line: string): string[] {
+  if (line.length <= MAX_LINE) return [line];
+  const parts = [line.slice(0, MAX_LINE)];
+  let i = MAX_LINE;
+  while (i < line.length) {
+    parts.push(' ' + line.slice(i, i + MAX_LINE - 1));
+    i += MAX_LINE - 1;
+  }
+  return parts;
+}
+
+export function formatCalendar(events: CalendarEvent[]): string {
+  const lines: string[] = ['BEGIN:VCALENDAR', 'VERSION:2.0'];
+  for (const event of events) {
+    lines.push('BEGIN:VEVENT');
+    lines.push(...foldLine('SUMMARY:' + escapeText(event.summary)));
+    lines.push(...foldLine('DTSTART:' + event.dtstart));
+    lines.push(...foldLine('DTEND:' + event.dtend));
+    if (event.description !== undefined) {
+      lines.push(...foldLine('DESCRIPTION:' + escapeText(event.description)));
+    }
+    lines.push('END:VEVENT');
+  }
+  lines.push('END:VCALENDAR');
+  return lines.join(CRLF) + CRLF;
+}
+
+function unfold(text: string): string[] {
+  const raw = text.split(/\r\n|\r|\n/);
+  const lines: string[] = [];
+  for (const line of raw) {
+    if ((line.startsWith(' ') || line.startsWith('\t')) && lines.length > 0) {
+      lines[lines.length - 1] += line.slice(1);
+    } else if (line !== '') {
+      lines.push(line);
+    }
+  }
+  return lines;
+}
+
+export function parseCalendar(text: string): CalendarEvent[] {
+  const lines = unfold(text);
+  if (lines.length === 0 || lines[0] !== 'BEGIN:VCALENDAR') {
+    throw new Error('invalid calendar: input must start with BEGIN:VCALENDAR');
+  }
+
+  const events: CalendarEvent[] = [];
+  let current: Partial<Record<'summary' | 'dtstart' | 'dtend' | 'description', string>> | null = null;
+  let closed = false;
+
+  for (const line of lines.slice(1)) {
+    if (line === 'BEGIN:VEVENT') {
+      if (current !== null) {
+        throw new Error('invalid calendar: BEGIN:VEVENT before previous END:VEVENT');
+      }
+      current = {};
+      continue;
+    }
+    if (line === 'END:VEVENT') {
+      if (current === null) {
+        throw new Error('invalid calendar: END:VEVENT without a matching BEGIN:VEVENT');
+      }
+      if (current.summary === undefined) {
+        throw new Error('invalid event: missing required SUMMARY property');
+      }
+      if (current.dtstart === undefined) {
+        throw new Error('invalid event: missing required DTSTART property');
+      }
+      if (current.dtend === undefined) {
+        throw new Error('invalid event: missing required DTEND property');
+      }
+      const event: CalendarEvent = {
+        summary: current.summary,
+        dtstart: current.dtstart,
+        dtend: current.dtend,
+      };
+      if (current.description !== undefined) event.description = current.description;
+      events.push(event);
+      current = null;
+      continue;
+    }
+    if (line === 'END:VCALENDAR') {
+      if (current !== null) {
+        throw new Error('invalid calendar: BEGIN:VEVENT without a matching END:VEVENT');
+      }
+      closed = true;
+      break;
+    }
+    if (current === null) continue; // calendar-level properties like VERSION
+
+    const colon = line.indexOf(':');
+    if (colon < 0) {
+      throw new Error(`invalid content line (missing colon): "${line}"`);
+    }
+    const name = line.slice(0, colon).split(';')[0].toUpperCase();
+    const value = line.slice(colon + 1);
+    switch (name) {
+      case 'SUMMARY':
+        current.summary = unescapeText(value);
+        break;
+      case 'DTSTART':
+        current.dtstart = value;
+        break;
+      case 'DTEND':
+        current.dtend = value;
+        break;
+      case 'DESCRIPTION':
+        current.description = unescapeText(value);
+        break;
+      default:
+        break; // tolerated: properties we don't model
+    }
+  }
+
+  if (!closed) {
+    throw new Error('invalid calendar: missing END:VCALENDAR');
+  }
+  return events;
+}
