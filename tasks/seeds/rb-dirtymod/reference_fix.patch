+# Base class for dirty-tracked records: subclasses declare their columns
+# with `attributes :a, :b` and get accessors plus change tracking.
+class DirtyModel
+  def self.attributes(*names)
+    @attribute_names = names.map(&:to_sym).freeze
+    @attribute_names.each do |name|
+      define_method(name) { @values[name] }
+      define_method(:"#{name}=") { |value| @values[name] = value }
+    end
+  end
+
+  def self.attribute_names
+    @attribute_names || [].freeze
+  end
+
+  def initialize(attrs = {})
+    declared = self.class.attribute_names
+    attrs.each_key do |key|
+      unless declared.include?(key.to_sym)
+        raise ArgumentError, "unknown attribute #{key.to_sym.inspect}"
+      end
+    end
+    @originals = {}
+    declared.each { |name| @originals[name] = attrs.fetch(name, nil) }
+    @values = @originals.dup
+  end
+
+  def changed?
+    self.class.attribute_names.any? { |name| @values[name] != @originals[name] }
+  end
+
+  def changes
+    self.class.attribute_names.each_with_object({}) do |name, out|
+      next if @values[name] == @originals[name]
+      out[name] = [@originals[name], @values[name]]
+    end
+  end
+
+  def rollback!
+    @values = @originals.dup
+    self
+  end
+end
