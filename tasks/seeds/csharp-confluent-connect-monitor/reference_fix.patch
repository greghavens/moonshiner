+namespace ConnectMonitor;
+
+/// <summary>One task from a connector status; Trace is set for FAILED tasks.</summary>
+public sealed record ConnectTaskStatus(int Id, string State, string WorkerId, string? Trace);
+
+/// <summary>A connector's status subresource, flattened.</summary>
+public sealed record ConnectorStatus(
+    string Name, string State, string WorkerId, string Type,
+    IReadOnlyList<ConnectTaskStatus> Tasks);
+
+/// <summary>Result of a restart request: 202 carries the echoed status.</summary>
+public sealed record RestartOutcome(
+    int HttpStatus, string? ConnectorState, IReadOnlyList<ConnectTaskStatus> Tasks);
+
+/// <summary>One flattened task state line of the remediation report.</summary>
+public sealed record TaskLine(string Connector, int TaskId, string State, string WorkerId);
+
+/// <summary>One remediation attempt and how it ended.</summary>
+public sealed record RemediationAction(string Connector, string Action, int Attempts, string Result);
+
+/// <summary>The deterministic sweep report.</summary>
+public sealed record RemediationReport(
+    IReadOnlyList<TaskLine> Tasks,
+    IReadOnlyList<RemediationAction> Actions,
+    IReadOnlyList<string> Healthy);
+
+/// <summary>A Connect REST failure: the HTTP status plus the envelope message.</summary>
+public sealed class ConnectApiException : Exception
+{
+    public int HttpStatus { get; }
+
+    public ConnectApiException(int httpStatus, string message) : base(message)
+    {
+        HttpStatus = httpStatus;
+    }
+}
