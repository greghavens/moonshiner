+namespace ConnectMonitor;
+
+/// <summary>
+/// One sweep: flatten every task state, restart exactly the connectors that
+/// are FAILED or own a FAILED task, retry rebalance conflicts through the
+/// injected backoff, and keep going past vanished connectors. Output is
+/// deterministic for identical cluster state.
+/// </summary>
+public sealed class RemediationMonitor
+{
+    private readonly ConnectClient _client;
+    private readonly int _maxConflictRetries;
+    private readonly Func<int, CancellationToken, Task> _conflictBackoff;
+
+    public RemediationMonitor(ConnectClient client, int maxConflictRetries,
+        Func<int, CancellationToken, Task> conflictBackoff)
+    {
+        _client = client;
+        _maxConflictRetries = maxConflictRetries;
+        _conflictBackoff = conflictBackoff;
+    }
+
+    public async Task<RemediationReport> RunAsync(CancellationToken ct)
+    {
+        var fleet = await _client.ListConnectorsAsync(ct);
+        var tasks = new List<TaskLine>();
+        var actions = new List<RemediationAction>();
+        var healthy = new List<string>();
+
+        foreach (var connector in fleet)
+        {
+            foreach (var task in connector.Tasks)
+            {
+                tasks.Add(new TaskLine(connector.Name, task.Id, task.State, task.WorkerId));
+            }
+        }
+
+        foreach (var connector in fleet)
+        {
+            bool failed = connector.State == "FAILED"
+                || connector.Tasks.Any(t => t.State == "FAILED");
+            if (!failed)
+            {
+                healthy.Add(connector.Name);
+                continue;
+            }
+            var (attempts, result) = await RestartWithConflictRetryAsync(connector.Name, ct);
+            actions.Add(new RemediationAction(
+                connector.Name, "RESTART_FAILED_TASKS", attempts, result));
+        }
+
+        return new RemediationReport(tasks, actions, healthy);
+    }
+
+    private async Task<(int Attempts, string Result)> RestartWithConflictRetryAsync(
+        string name, CancellationToken ct)
+    {
+        int attempts = 0;
+        while (true)
+        {
+            attempts++;
+            try
+            {
+                var outcome = await _client.RestartFailedAsync(name, ct);
+                return (attempts, outcome.HttpStatus == 204 ? "NO_CONTENT" : "ACCEPTED");
+            }
+            catch (ConnectApiException ex) when (ex.HttpStatus == 409)
+            {
+                if (attempts > _maxConflictRetries)
+                {
+                    return (attempts, "REBALANCE_DEFERRED");
+                }
+                await _conflictBackoff(attempts, ct);
+            }
+            catch (ConnectApiException ex) when (ex.HttpStatus == 404)
+            {
+                return (attempts, "NOT_FOUND");
+            }
+        }
+    }
+}
