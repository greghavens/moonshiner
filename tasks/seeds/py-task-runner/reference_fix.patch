+#!/usr/bin/env python3
+"""make-style task runner: JSON taskfile, topological execution,
+mtime-based up-to-date skipping, dry-run mode."""
+import argparse
+import sys
+
+import executor
+import taskfile
+import taskgraph
+
+
+def main(argv=None):
+    parser = argparse.ArgumentParser(prog="runner.py")
+    parser.add_argument("--file", required=True)
+    parser.add_argument("--dry-run", action="store_true")
+    parser.add_argument("target")
+    args = parser.parse_args(argv)
+
+    try:
+        tasks, base = taskfile.load(args.file)
+    except taskfile.TaskfileError as exc:
+        print(exc, file=sys.stderr)
+        return 2
+
+    try:
+        needed = taskgraph.closure(tasks, args.target)
+        schedule = taskgraph.order(tasks, needed)
+    except taskgraph.GraphError as exc:
+        print(exc, file=sys.stderr)
+        return 1
+
+    for name in schedule:
+        task = tasks[name]
+        if executor.up_to_date(task, base):
+            print(f"skip {name} (up to date)")
+            continue
+        if args.dry_run:
+            print(f"would run {name}")
+            continue
+        print(f"run {name}", flush=True)
+        code = executor.run(task, base)
+        if code != 0:
+            print(f"task {name} failed (exit {code})", file=sys.stderr)
+            return 1
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
