+"""Dependency closure and deterministic topological ordering."""
+
+
+class GraphError(Exception):
+    """Undefined task/dep or dependency cycle."""
+
+
+def closure(tasks, target):
+    """Transitive dep closure of target. Detects undefined names and cycles."""
+    if target not in tasks:
+        raise GraphError(f"no such task: {target}")
+    needed = set()
+    in_stack = set()
+
+    def visit(name):
+        if name in in_stack:
+            raise GraphError(f"dependency cycle involving {name!r}")
+        if name in needed:
+            return
+        in_stack.add(name)
+        for dep in tasks[name]["deps"]:
+            if dep not in tasks:
+                raise GraphError(f"task {name!r} depends on undefined task {dep!r}")
+            visit(dep)
+        in_stack.remove(name)
+        needed.add(name)
+
+    visit(target)
+    return needed
+
+
+def order(tasks, needed):
+    """Topological order over `needed`; among simultaneously-ready tasks,
+    alphabetical — the schedule is fully deterministic."""
+    done = set()
+    schedule = []
+    while len(done) < len(needed):
+        ready = sorted(n for n in needed - done
+                       if all(d in done for d in tasks[n]["deps"]))
+        if not ready:  # closure() already rejects cycles; belt and braces
+            raise GraphError("dependency cycle")
+        schedule.append(ready[0])
+        done.add(ready[0])
+    return schedule
