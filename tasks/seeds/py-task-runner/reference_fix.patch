+"""Taskfile loading. Paths inside the file resolve against its directory."""
+import json
+import os
+
+
+class TaskfileError(Exception):
+    """Unreadable or unparseable taskfile (usage-level failure, exit 2)."""
+
+
+def load(path):
+    """Return (tasks, base_dir)."""
+    try:
+        with open(path, encoding="utf-8") as f:
+            data = json.load(f)
+    except (OSError, json.JSONDecodeError) as exc:
+        raise TaskfileError(f"cannot load taskfile {path}: {exc}")
+    tasks = data.get("tasks")
+    if not isinstance(tasks, dict):
+        raise TaskfileError(f"taskfile {path} has no 'tasks' object")
+    normalized = {}
+    for name, spec in tasks.items():
+        normalized[name] = {
+            "cmd": spec.get("cmd", []),
+            "deps": spec.get("deps", []),
+            "inputs": spec.get("inputs", []),
+            "outputs": spec.get("outputs", []),
+        }
+    return normalized, os.path.dirname(os.path.abspath(path))
