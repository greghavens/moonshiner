+"""Up-to-date checks (pure mtime, make-style) and command execution."""
+import os
+import subprocess
+
+
+def up_to_date(task, base):
+    """True iff the task declares outputs, every output and input exists,
+    and the oldest output is at least as new as the newest input."""
+    outputs = [os.path.join(base, p) for p in task["outputs"]]
+    inputs = [os.path.join(base, p) for p in task["inputs"]]
+    if not outputs:
+        return False
+    if not all(os.path.exists(p) for p in outputs + inputs):
+        return False
+    if not inputs:
+        return True
+    oldest_out = min(os.path.getmtime(p) for p in outputs)
+    newest_in = max(os.path.getmtime(p) for p in inputs)
+    return oldest_out >= newest_in
+
+
+def run(task, base):
+    """Execute the task's argv (no shell) with cwd = taskfile dir."""
+    return subprocess.run(task["cmd"], cwd=base).returncode
