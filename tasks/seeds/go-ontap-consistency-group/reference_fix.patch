index 0000000..4e48cf8
--- /dev/null
+++ b/types.go
@@ -0,0 +1,51 @@
+package cgrecon
+
+import "fmt"
+
+// APIError is a non-2xx ONTAP REST response carrying the documented error object.
+type APIError struct {
+	Status  int
+	Code    string
+	Message string
+	Target  string
+}
+
+func (e *APIError) Error() string {
+	return fmt.Sprintf("ontap api error %d (code %s): %s", e.Status, e.Code, e.Message)
+}
+
+// JobError is an asynchronous job that reached the failure state.
+type JobError struct {
+	UUID    string
+	Code    string
+	Message string
+}
+
+func (e *JobError) Error() string {
+	return fmt.Sprintf("ontap job %s failed (code %s): %s", e.UUID, e.Code, e.Message)
+}
+
+// VolumeSpec names a member volume of the consistency group.
+type VolumeSpec struct {
+	Name string
+}
+
+// Spec is the desired state of one consistency group.
+type Spec struct {
+	SVM       string
+	Name      string
+	Volumes   []VolumeSpec
+	QoSPolicy string // empty means the QoS policy is unmanaged
+}
+
+// Report describes how a reconcile converged.
+type Report struct {
+	UUID     string
+	Created  bool
+	Updated  bool
+	NoChange bool
+	Restarts int
+	JobPolls int
+	// Final is the last full instance document, unknown fields preserved.
+	Final map[string]any
+}
