@@ -0,0 +1,51 @@
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Identity/capability probe: uses the ONTAP 9.19.1+ whoami endpoint and
+ * degrades to the cluster version resource on clusters that predate it.
+ */
+public final class IdentityProbe {
+
+    public static final String WHOAMI_QUERY = "/api/security/login/whoami?fields=username,roles,privileges";
+
+    private final OntapRestClient client;
+
+    public IdentityProbe(OntapRestClient client) {
+        this.client = client;
+    }
+
+    public IdentityReport probe() throws Exception {
+        OntapRestClient.Response response = client.get(WHOAMI_QUERY);
+        if (response.status == 200) {
+            return parseWhoami(response.body);
+        }
+        if (response.status == 403) {
+            OntapApiException decoded = OntapRestClient.apiError(response);
+            throw new OntapPermissionException(decoded.status, decoded.code, decoded.apiMessage);
+        }
+        if (response.status == 404) {
+            // Endpoint absent: pre-9.19.1 cluster. Capability fallback, not an error.
+            ClusterIdentity cluster = ClusterProbe.probe(client);
+            return IdentityReport.fromFallback(client.username(), cluster);
+        }
+        throw OntapRestClient.apiError(response);
+    }
+
+    private static IdentityReport parseWhoami(String body) {
+        Map<String, Object> doc = Json.object(Json.parse(body));
+        List<String> roles = new ArrayList<>();
+        for (Object role : Json.array(doc.getOrDefault("roles", List.of()))) {
+            roles.add((String) role);
+        }
+        List<IdentityReport.Privilege> privileges = new ArrayList<>();
+        for (Object entry : Json.array(doc.getOrDefault("privileges", List.of()))) {
+            Map<String, Object> privilege = Json.object(entry);
+            privileges.add(new IdentityReport.Privilege(
+                    (String) privilege.get("path"),
+                    (String) privilege.get("access")));
+        }
+        return IdentityReport.fromWhoami((String) doc.get("username"), roles, privileges);
+    }
+}
diff --git a/IdentityReport.java b/IdentityReport.java
new file mode 100644
index 0000000..1c888f4
--- /dev/null
+++ b/IdentityReport.java
@@ -0,0 +1,48 @@
+import java.util.List;
+
+/** Result of the identity/capability probe (whoami or version fallback). */
+public final class IdentityReport {
+
+    public static final class Privilege {
+        public final String path;
+        public final String access;
+
+        public Privilege(String path, String access) {
+            this.path = path;
+            this.access = access;
+        }
+    }
+
+    public final boolean whoamiSupported;
+    public final String username;
+    public final List<String> roles;
+    public final List<Privilege> privileges;
+    public final String clusterName;
+    public final String versionFull;
+    public final Integer generation;
+    public final Integer major;
+    public final Integer minor;
+
+    private IdentityReport(boolean whoamiSupported, String username, List<String> roles,
+                           List<Privilege> privileges, String clusterName, String versionFull,
+                           Integer generation, Integer major, Integer minor) {
+        this.whoamiSupported = whoamiSupported;
+        this.username = username;
+        this.roles = roles;
+        this.privileges = privileges;
+        this.clusterName = clusterName;
+        this.versionFull = versionFull;
+        this.generation = generation;
+        this.major = major;
+        this.minor = minor;
+    }
+
+    static IdentityReport fromWhoami(String username, List<String> roles, List<Privilege> privileges) {
+        return new IdentityReport(true, username, roles, privileges, null, null, null, null, null);
+    }
+
+    static IdentityReport fromFallback(String loginUsername, ClusterIdentity cluster) {
+        return new IdentityReport(false, loginUsername, List.of(), List.of(),
+                cluster.name, cluster.versionFull, cluster.generation, cluster.major, cluster.minor);
+    }
+}
