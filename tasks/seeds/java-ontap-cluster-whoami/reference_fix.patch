+/** The authenticated account lacks permission — distinct from an unsupported endpoint. */
+public class OntapPermissionException extends OntapApiException {
+    public OntapPermissionException(int status, String code, String apiMessage) {
+        super(status, code, apiMessage);
+    }
+}
