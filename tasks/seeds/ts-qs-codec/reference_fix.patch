+export type QSLeaf = string | number | boolean;
+export type QSValue = QSLeaf | QSValue[] | { [key: string]: QSValue };
+
+export function encode(obj: Record<string, QSValue>): string {
+  const pairs: string[] = [];
+
+  const walk = (keyPath: string, value: QSValue): void => {
+    if (Array.isArray(value)) {
+      for (const item of value) walk(`${keyPath}[]`, item);
+    } else if (value !== null && typeof value === 'object') {
+      for (const [k, v] of Object.entries(value)) {
+        walk(`${keyPath}[${encodeURIComponent(k)}]`, v);
+      }
+    } else {
+      pairs.push(`${keyPath}=${encodeURIComponent(String(value))}`);
+    }
+  };
+
+  for (const [k, v] of Object.entries(obj)) {
+    walk(encodeURIComponent(k), v);
+  }
+  return pairs.join('&');
+}
+
+export function decode(input: string): Record<string, unknown> {
+  let s = input;
+  if (s.startsWith('?')) s = s.slice(1);
+  const out: Record<string, unknown> = {};
+  if (s === '') return out;
+
+  for (const part of s.split('&')) {
+    if (part === '') continue;
+    const eq = part.indexOf('=');
+    const rawKey = eq === -1 ? part : part.slice(0, eq);
+    const rawVal = eq === -1 ? '' : part.slice(eq + 1);
+    const value = decodeURIComponent(rawVal.replace(/\+/g, ' '));
+    assign(out, parseKey(rawKey), value);
+  }
+  return out;
+}
+
+/** 'user[first%20name][]' -> ['user', 'first name', ''] ('' marks an array push). */
+function parseKey(rawKey: string): string[] {
+  const open = rawKey.indexOf('[');
+  if (open === -1) return [decodeURIComponent(rawKey)];
+  const segments = [decodeURIComponent(rawKey.slice(0, open))];
+  const bracketRe = /\[([^\]]*)\]/g;
+  bracketRe.lastIndex = open;
+  let m: RegExpExecArray | null;
+  while ((m = bracketRe.exec(rawKey)) !== null) {
+    segments.push(m[1] === '' ? '' : decodeURIComponent(m[1]));
+  }
+  return segments;
+}
+
+function assign(obj: Record<string, unknown>, segs: string[], value: string): void {
+  const [head, ...rest] = segs;
+
+  if (rest.length === 0) {
+    const existing = obj[head];
+    if (existing === undefined) obj[head] = value;
+    else if (Array.isArray(existing)) existing.push(value);
+    else obj[head] = [existing, value];
+    return;
+  }
+
+  if (rest[0] === '') {
+    if (!Array.isArray(obj[head])) obj[head] = [];
+    (obj[head] as unknown[]).push(value);
+    return;
+  }
+
+  const current = obj[head];
+  if (current === null || typeof current !== 'object' || Array.isArray(current)) {
+    obj[head] = {};
+  }
+  assign(obj[head] as Record<string, unknown>, rest, value);
+}
