+// Uplink connection lifecycle state machine.
+//
+// Pure and synchronous: the host feeds events in (app calls and transport
+// notifications) and acts on the Effect[] returned by each event method.
+// The machine owns the rules — which events each state accepts, the retry
+// backoff schedule, and the pending-op queue — and nothing else. No sockets,
+// no timers, no clocks.
+
+export type ConnState =
+  | 'idle'
+  | 'connecting'
+  | 'connected'
+  | 'reconnecting'
+  | 'draining'
+  | 'closed';
+
+export type Effect =
+  | { kind: 'dial'; attempt: number }
+  | { kind: 'send'; ops: string[] }
+  | { kind: 'wait'; delayMs: number }
+  | { kind: 'discard'; ops: string[] };
+
+export type Options = {
+  backoff: number[];
+  maxAttempts: number;
+  maxQueue: number;
+};
+
+const LEGAL: Record<ConnState, string[]> = {
+  idle: ['close', 'connect'],
+  connecting: ['close', 'down', 'enqueue', 'up'],
+  connected: ['close', 'down', 'drain', 'enqueue'],
+  reconnecting: ['close', 'enqueue', 'timer'],
+  draining: ['close', 'down'],
+  closed: [],
+};
+
+export class IllegalEventError extends Error {
+  state: ConnState;
+  event: string;
+  legal: string[];
+
+  constructor(state: ConnState, event: string) {
+    const legal = LEGAL[state];
+    const shown = legal.length ? legal.join(', ') : 'none';
+    super(`event "${event}" is not legal in state "${state}" (legal: ${shown})`);
+    this.name = 'IllegalEventError';
+    this.state = state;
+    this.event = event;
+    this.legal = [...legal];
+  }
+}
+
+export class QueueFullError extends Error {
+  limit: number;
+
+  constructor(limit: number) {
+    super(`pending-op queue is full (limit ${limit})`);
+    this.name = 'QueueFullError';
+    this.limit = limit;
+  }
+}
+
+export class ConnectionMachine {
+  #state: ConnState = 'idle';
+  #queue: string[] = [];
+  #failures = 0;
+  #backoff: number[];
+  #maxAttempts: number;
+  #maxQueue: number;
+
+  constructor(opts: Options) {
+    if (!Array.isArray(opts.backoff) || opts.backoff.length === 0) {
+      throw new RangeError('backoff must be a non-empty array of delays');
+    }
+    for (const delay of opts.backoff) {
+      if (typeof delay !== 'number' || !Number.isFinite(delay) || delay <= 0) {
+        throw new RangeError(`backoff delay ${delay} must be a positive number`);
+      }
+    }
+    if (!Number.isInteger(opts.maxAttempts) || opts.maxAttempts < 1) {
+      throw new RangeError('maxAttempts must be an integer >= 1');
+    }
+    if (!Number.isInteger(opts.maxQueue) || opts.maxQueue < 1) {
+      throw new RangeError('maxQueue must be an integer >= 1');
+    }
+    this.#backoff = [...opts.backoff];
+    this.#maxAttempts = opts.maxAttempts;
+    this.#maxQueue = opts.maxQueue;
+  }
+
+  get state(): ConnState {
+    return this.#state;
+  }
+
+  pending(): string[] {
+    return [...this.#queue];
+  }
+
+  #require(event: string): void {
+    if (!LEGAL[this.#state].includes(event)) {
+      throw new IllegalEventError(this.#state, event);
+    }
+  }
+
+  #drainQueue(): string[] {
+    const ops = this.#queue;
+    this.#queue = [];
+    return ops;
+  }
+
+  connect(): Effect[] {
+    this.#require('connect');
+    this.#state = 'connecting';
+    return [{ kind: 'dial', attempt: this.#failures + 1 }];
+  }
+
+  enqueue(op: string): Effect[] {
+    this.#require('enqueue');
+    if (this.#state === 'connected') {
+      return [{ kind: 'send', ops: [op] }];
+    }
+    if (this.#queue.length >= this.#maxQueue) {
+      throw new QueueFullError(this.#maxQueue);
+    }
+    this.#queue.push(op);
+    return [];
+  }
+
+  up(): Effect[] {
+    this.#require('up');
+    this.#state = 'connected';
+    this.#failures = 0;
+    if (this.#queue.length === 0) return [];
+    return [{ kind: 'send', ops: this.#drainQueue() }];
+  }
+
+  down(_reason: string): Effect[] {
+    this.#require('down');
+    if (this.#state === 'draining') {
+      this.#state = 'closed';
+      return [];
+    }
+    if (this.#state === 'connected') {
+      // The established link dropped: fresh failure run, first delay.
+      this.#failures = 0;
+      this.#state = 'reconnecting';
+      return [{ kind: 'wait', delayMs: this.#backoff[0] }];
+    }
+    // A dial failed while connecting.
+    this.#failures += 1;
+    if (this.#failures >= this.#maxAttempts) {
+      this.#state = 'closed';
+      const ops = this.#drainQueue();
+      return ops.length ? [{ kind: 'discard', ops }] : [];
+    }
+    this.#state = 'reconnecting';
+    const idx = Math.min(this.#failures - 1, this.#backoff.length - 1);
+    return [{ kind: 'wait', delayMs: this.#backoff[idx] }];
+  }
+
+  timer(): Effect[] {
+    this.#require('timer');
+    this.#state = 'connecting';
+    return [{ kind: 'dial', attempt: this.#failures + 1 }];
+  }
+
+  drain(): Effect[] {
+    this.#require('drain');
+    this.#state = 'draining';
+    return [];
+  }
+
+  close(): Effect[] {
+    this.#require('close');
+    this.#state = 'closed';
+    const ops = this.#drainQueue();
+    return ops.length ? [{ kind: 'discard', ops }] : [];
+  }
+}
