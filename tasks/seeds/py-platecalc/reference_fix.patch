+"""Photovoltaic panel math for the 96-cell tester dumps.
+
+Readings stay integer (int64) end to end; summary values are converted to
+plain python ints because they feed json.dumps in the fleet dashboard.
+"""
+import numpy as np
+
+ROWS = 8
+COLS = 12
+
+
+def parse_panel(text):
+    """Parse a tester dump: 8 rows x 12 integer readings, '#' comments allowed."""
+    rows = []
+    for line in text.splitlines():
+        stripped = line.strip()
+        if not stripped or stripped.startswith("#"):
+            continue
+        tokens = stripped.split()
+        if len(tokens) != COLS:
+            raise ValueError(
+                f"expected {COLS} readings per row, got {len(tokens)}: {stripped!r}")
+        try:
+            rows.append([int(tok) for tok in tokens])
+        except ValueError:
+            raise ValueError(f"non-integer reading in row: {stripped!r}") from None
+    if len(rows) != ROWS:
+        raise ValueError(f"expected {ROWS} data rows, got {len(rows)}")
+    return np.array(rows, dtype=np.int64)
+
+
+def baseline_correct(panel, dark_col):
+    """Subtract each row's dark reference from the row, clamped at zero."""
+    grid = np.asarray(panel, dtype=np.int64)
+    if grid.ndim != 2:
+        raise ValueError(f"panel must be 2-D, got {grid.ndim}-D")
+    if not 0 <= dark_col < grid.shape[1]:
+        raise ValueError(
+            f"dark column {dark_col} outside 0..{grid.shape[1] - 1}")
+    darks = grid[:, dark_col][:, None]
+    return np.maximum(grid - darks, 0).astype(np.int64)
+
+
+def _cell_name(row, col):
+    return f"{chr(ord('A') + row)}{col + 1}"
+
+
+def panel_summary(panel):
+    """Total, peak, and peak cell name (first peak in row-major order)."""
+    grid = np.asarray(panel, dtype=np.int64)
+    flat_peak = int(np.argmax(grid))
+    row, col = divmod(flat_peak, grid.shape[1])
+    return {
+        "total": int(grid.sum()),
+        "peak": int(grid[row, col]),
+        "peak_cell": _cell_name(row, col),
+    }
+
+
+def flagged(panel, threshold):
+    """Cell names strictly above threshold, row-major order."""
+    grid = np.asarray(panel, dtype=np.int64)
+    return [_cell_name(r, c) for r, c in np.argwhere(grid > threshold)]
