diff --git a/expandkit.zsh b/expandkit.zsh
new file mode 100644
index 0000000..8e6ead6
--- /dev/null
+++ b/expandkit.zsh
@@ -0,0 +1,74 @@
+# expandkit.zsh — string/array/assoc chores as pure zsh parameter expansion.
+#
+# Sourceable; defines functions only. No external commands anywhere — these
+# helpers run in hooks where PATH is empty. Calling convention: the first
+# argument is always the NAME of an existing destination variable; internal
+# locals are __-prefixed so caller names like `out` or `result` stay usable.
+# Every function localizes its options with `emulate -L zsh` so callers
+# running under sh_word_split / ksh_arrays / glob_subst get identical results.
+
+ek_split() { # ek_split DEST SEP STRING -- split on a literal separator
+  emulate -L zsh
+  local __sep=$2 __s=$3
+  local -a __out
+  [[ -n $__s ]] && __out=( "${(@ps:$__sep:)__s}" )
+  set -A "$1" "${(@)__out}"
+}
+
+ek_join() { # ek_join DEST SEP ARRAYNAME -- join elements with the separator
+  emulate -L zsh
+  local __sep=$2
+  local -a __src=( "${(@P)3}" )
+  : ${(P)1::=${(pj:$__sep:)__src}}
+}
+
+ek_upper() { # ek_upper DEST STRING
+  emulate -L zsh
+  : ${(P)1::=${(U)2}}
+}
+
+ek_lower() { # ek_lower DEST STRING
+  emulate -L zsh
+  : ${(P)1::=${(L)2}}
+}
+
+ek_sorted() { # ek_sorted DEST ARRAYNAME -- ascending byte-order copy
+  emulate -L zsh
+  local -a __src=( "${(@P)2}" )
+  set -A "$1" "${(@o)__src}"
+}
+
+ek_rsorted() { # ek_rsorted DEST ARRAYNAME -- descending byte-order copy
+  emulate -L zsh
+  local -a __src=( "${(@P)2}" )
+  set -A "$1" "${(@O)__src}"
+}
+
+ek_uniq() { # ek_uniq DEST ARRAYNAME -- first occurrence of each element
+  emulate -L zsh
+  local -a __src=( "${(@P)2}" )
+  set -A "$1" "${(@u)__src}"
+}
+
+ek_keys() { # ek_keys DEST MAPNAME -- keys, ascending byte order
+  emulate -L zsh
+  local -a __k=( "${(@kP)2}" )
+  set -A "$1" "${(@o)__k}"
+}
+
+ek_rkeys() { # ek_rkeys DEST MAPNAME -- keys, descending byte order
+  emulate -L zsh
+  local -a __k=( "${(@kP)2}" )
+  set -A "$1" "${(@O)__k}"
+}
+
+ek_vals() { # ek_vals DEST MAPNAME -- values in ascending-key order
+  emulate -L zsh
+  local -A __m=( "${(@kvP)2}" )
+  local -a __keys=( "${(@ok)__m}" ) __out
+  local __key
+  for __key in "${(@)__keys}"; do
+    __out+=( "${__m[$__key]}" )
+  done
+  set -A "$1" "${(@)__out}"
+}
