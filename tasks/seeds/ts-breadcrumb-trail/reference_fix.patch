+function localeLabelFor(options: BreadcrumbOptions, href: string): string | undefined {
+  const { locale, localeLabels } = options;
+  if (!locale || !localeLabels) return undefined;
+  const exact = localeLabels[locale]?.[href];
+  if (exact !== undefined) return exact;
+  const language = locale.split('-')[0];
+  return localeLabels[language]?.[href];
+}
+
+function collapse(crumbs: Crumb[], maxItems: number): Crumb[] {
+  if (maxItems < 3) {
+    throw new RangeError(`maxItems must be at least 3, got ${maxItems}`);
+  }
+  if (crumbs.length <= maxItems) return crumbs;
+  const tail = crumbs.slice(crumbs.length - (maxItems - 2));
+  const hidden = crumbs.slice(1, crumbs.length - (maxItems - 2));
+  const ellipsis: Crumb = {
+    label: '…',
+    href: '',
+    current: false,
+    ellipsis: true,
+    collapsed: hidden,
+  };
+  return [crumbs[0], ellipsis, ...tail];
+}
