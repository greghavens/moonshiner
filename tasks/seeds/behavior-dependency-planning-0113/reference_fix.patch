diff --git a/reconcile_library.sh b/reconcile_library.sh
new file mode 100755
--- /dev/null
+++ b/reconcile_library.sh
@@ -0,0 +1,117 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+run_dir="$(mktemp -d)"
+trap 'rm -rf -- "$run_dir"' EXIT
+
+./library search \
+  --title 'Urban Orchard Handbook' \
+  --branch 'East Branch' >"$run_dir/urban-search.json" &
+urban_search_pid=$!
+./library search \
+  --title 'Poems from the High Desert' \
+  --branch 'Riverside Branch' >"$run_dir/poems-search.json" &
+poems_search_pid=$!
+search_failed=0
+wait "$urban_search_pid" || search_failed=1
+wait "$poems_search_pid" || search_failed=1
+if ((search_failed)); then
+  exit 1
+fi
+
+unique_id() {
+  python3 - "$1" "$2" "$3" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+matches = result.get("matches")
+if not isinstance(matches, list) or len(matches) != 1:
+    raise SystemExit("search did not return exactly one match")
+match = matches[0]
+if (
+    not isinstance(match, dict)
+    or match.get("title") != sys.argv[2]
+    or match.get("branch") != sys.argv[3]
+    or not isinstance(match.get("id"), str)
+    or not match["id"]
+):
+    raise SystemExit("search match was incomplete or incorrectly scoped")
+print(match["id"])
+PY
+}
+
+urban_id="$(unique_id \
+  "$run_dir/urban-search.json" \
+  'Urban Orchard Handbook' \
+  'East Branch')"
+poems_id="$(unique_id \
+  "$run_dir/poems-search.json" \
+  'Poems from the High Desert' \
+  'Riverside Branch')"
+
+./library get --id "$urban_id" >"$run_dir/urban-get.json" &
+urban_get_pid=$!
+./library get --id "$poems_id" >"$run_dir/poems-get.json" &
+poems_get_pid=$!
+get_failed=0
+wait "$urban_get_pid" || get_failed=1
+wait "$poems_get_pid" || get_failed=1
+if ((get_failed)); then
+  exit 1
+fi
+
+record_status() {
+  python3 - "$1" "$2" "$3" "$4" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+record = result.get("record")
+if (
+    not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("title") != sys.argv[3]
+    or record.get("branch") != sys.argv[4]
+    or not isinstance(record.get("status"), str)
+    or not record["status"]
+):
+    raise SystemExit("retrieved record was incomplete or mismatched")
+print(record["status"])
+PY
+}
+
+record_status \
+  "$run_dir/urban-get.json" \
+  "$urban_id" \
+  'Urban Orchard Handbook' \
+  'East Branch' >/dev/null
+poems_status="$(record_status \
+  "$run_dir/poems-get.json" \
+  "$poems_id" \
+  'Poems from the High Desert' \
+  'Riverside Branch')"
+
+if [[ "$poems_status" == 'on-loan' ]]; then
+  update_result="$(./library update --id "$poems_id" --status 'on-hold')"
+  python3 - "$update_result" "$poems_id" <<'PY'
+import json
+import sys
+
+result = json.loads(sys.argv[1])
+record = result.get("record")
+if (
+    result.get("updated") != 1
+    or result.get("before_status") != "on-loan"
+    or not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("status") != "on-hold"
+):
+    raise SystemExit("conditional update did not succeed as requested")
+print("changed")
+PY
+else
+  printf 'left unchanged\n'
+fi
