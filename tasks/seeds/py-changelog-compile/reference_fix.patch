+"""Changelog compiler CLI: bump / render / release over a changeset directory."""
+import argparse
+import os
+import sys
+
+import compiler
+import semver
+
+TITLE = "# Changelog"
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="cli.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+    for name in ("bump", "render", "release"):
+        p = sub.add_parser(name)
+        p.add_argument("directory")
+        p.add_argument("--version", required=True)
+        if name == "release":
+            p.add_argument("--changelog", required=True)
+    return parser
+
+
+def prepend_release(changelog_path, section):
+    if os.path.exists(changelog_path):
+        with open(changelog_path, encoding="utf-8") as fh:
+            text = fh.read()
+    else:
+        text = TITLE + "\n"
+    head, _, tail = text.partition(TITLE + "\n")
+    if head:  # no recognizable title line at the top
+        raise compiler.CompileError(
+            f"{changelog_path} does not start with {TITLE!r}")
+    tail = tail.lstrip("\n")
+    body = section if not tail else section + "\n" + tail
+    with open(changelog_path, "w", encoding="utf-8") as fh:
+        fh.write(TITLE + "\n\n" + body)
+
+
+def run(args):
+    semver.parse(args.version)  # reject bad versions before any work
+    parsed = compiler.load_entries(args.directory)
+
+    if args.command == "bump":
+        print(compiler.suggest_version(args.version, parsed))
+        return
+    if args.command == "render":
+        sys.stdout.write(compiler.render_section(args.version, parsed))
+        return
+
+    # release
+    if not parsed:
+        raise compiler.CompileError("nothing to release: no changesets")
+    new_version = compiler.suggest_version(args.version, parsed)
+    if new_version == args.version:
+        raise compiler.CompileError(
+            "nothing to release: no changeset moves the version")
+    section = compiler.render_section(args.version, parsed)
+    prepend_release(args.changelog, section)
+    for path in compiler.changeset_paths(args.directory):
+        os.remove(path)
+    print(new_version)
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    try:
+        run(args)
+    except (compiler.CompileError, ValueError) as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
