+"""Semver math. Pure functions, no IO."""
+import re
+
+_VERSION_RE = re.compile(r"^(\d+)\.(\d+)\.(\d+)$")
+
+
+def parse(version):
+    """'1.4.2' -> (1, 4, 2); strict X.Y.Z, ValueError otherwise."""
+    match = _VERSION_RE.match(version or "")
+    if not match:
+        raise ValueError(f"not a semver version: {version!r}")
+    return tuple(int(part) for part in match.groups())
+
+
+def suggest(current, has_breaking, has_feature, has_fix):
+    """Next version given what the pending changesets contain.
+
+    breaking > feature > fix/perf; anything else leaves the version alone.
+    Pre-1.0: breaking bumps minor, features bump patch.
+    """
+    major, minor, patch = parse(current)
+    if major == 0:
+        if has_breaking:
+            return f"0.{minor + 1}.0"
+        if has_feature or has_fix:
+            return f"0.{minor}.{patch + 1}"
+        return current
+    if has_breaking:
+        return f"{major + 1}.0.0"
+    if has_feature:
+        return f"{major}.{minor + 1}.0"
+    if has_fix:
+        return f"{major}.{minor}.{patch + 1}"
+    return current
