+"""Reading changeset directories and rendering release markdown."""
+import os
+
+import entries
+import semver
+
+SECTIONS = [
+    ("Breaking Changes", lambda e: e["breaking"]),
+    ("Features", lambda e: not e["breaking"] and e["type"] == "feat"),
+    ("Fixes", lambda e: not e["breaking"] and e["type"] == "fix"),
+    ("Performance", lambda e: not e["breaking"] and e["type"] == "perf"),
+    ("Maintenance", lambda e: not e["breaking"] and
+        e["type"] in ("docs", "refactor", "chore")),
+]
+
+
+class CompileError(Exception):
+    pass
+
+
+def changeset_paths(directory):
+    """The .txt changesets directly in directory, sorted by filename."""
+    try:
+        names = sorted(os.listdir(directory))
+    except OSError as exc:
+        raise CompileError(f"cannot read {directory}: {exc}") from exc
+    return [os.path.join(directory, n) for n in names
+            if n.endswith(".txt") and os.path.isfile(os.path.join(directory, n))]
+
+
+def load_entries(directory):
+    """Parse every changeset; one bad file fails the lot, named."""
+    parsed = []
+    for path in changeset_paths(directory):
+        with open(path, encoding="utf-8") as fh:
+            text = fh.read()
+        try:
+            parsed.append(entries.parse_entry(text))
+        except ValueError as exc:
+            raise CompileError(
+                f"{os.path.basename(path)}: {exc}") from exc
+    return parsed
+
+
+def suggest_version(current, parsed):
+    return semver.suggest(
+        current,
+        any(e["breaking"] for e in parsed),
+        any(not e["breaking"] and e["type"] == "feat" for e in parsed),
+        any(not e["breaking"] and e["type"] in ("fix", "perf") for e in parsed),
+    )
+
+
+def _bullet(entry):
+    if entry["scope"]:
+        return f"- **{entry['scope']}**: {entry['subject']}"
+    return f"- {entry['subject']}"
+
+
+def render_section(current, parsed):
+    """The `## VERSION` markdown block for the pending changesets."""
+    version = suggest_version(current, parsed)
+    blocks = [f"## {version}"]
+    for title, wanted in SECTIONS:
+        group = sorted((e for e in parsed if wanted(e)),
+                       key=lambda e: (e["scope"] or "", e["subject"]))
+        if group:
+            blocks.append(f"### {title}\n\n" +
+                          "\n".join(_bullet(e) for e in group))
+    return "\n\n".join(blocks) + "\n"
