+"""Changeset parsing. Pure functions, no IO."""
+import re
+
+TYPES = ("feat", "fix", "perf", "docs", "refactor", "chore")
+
+_HEADER_RE = re.compile(
+    r"^(?P<type>[a-z]+)(?:\((?P<scope>[^()]+)\))?(?P<bang>!)?:(?P<subject>.+)$")
+_BREAKING_FOOTER_RE = re.compile(r"^BREAKING CHANGE:", re.MULTILINE)
+
+
+def parse_entry(text):
+    """Parse one changeset. Returns {type, scope, subject, breaking}.
+
+    Raises ValueError when the header isn't conventional-commit-shaped.
+    """
+    lines = text.splitlines()
+    if not lines:
+        raise ValueError("empty changeset")
+    match = _HEADER_RE.match(lines[0])
+    if not match:
+        raise ValueError(f"malformed header: {lines[0]!r}")
+    if match.group("type") not in TYPES:
+        raise ValueError(f"unknown type: {match.group('type')!r}")
+    subject = match.group("subject").strip()
+    if not subject:
+        raise ValueError("empty subject")
+    breaking = bool(match.group("bang")) or \
+        _BREAKING_FOOTER_RE.search(text) is not None
+    return {
+        "type": match.group("type"),
+        "scope": match.group("scope"),
+        "subject": subject,
+        "breaking": breaking,
+    }
