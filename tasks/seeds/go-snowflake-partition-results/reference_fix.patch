new file mode 100644
index 0000000..87ed91a
--- /dev/null
+++ b/client.go
@@ -0,0 +1,131 @@
+// Package sfresults reads partitioned query results from the Snowflake SQL
+// API v2 (/api/v2/statements), preserving values exactly as string-encoded
+// by the server.
+package sfresults
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"net/url"
+)
+
+const statementsPath = "/api/v2/statements"
+
+// Config wires the client. NewRequestID supplies the requestId query value
+// for submissions; HTTPClient defaults to http.DefaultClient.
+type Config struct {
+	BaseURL      string
+	Token        string
+	TokenType    string
+	UserAgent    string
+	HTTPClient   *http.Client
+	NewRequestID func() string
+}
+
+// Statement is one SQL statement plus its execution context. Zero-valued
+// optional fields stay out of the request body.
+type Statement struct {
+	SQL       string
+	Timeout   int
+	Database  string
+	Schema    string
+	Warehouse string
+	Role      string
+}
+
+type Client struct {
+	cfg Config
+}
+
+func NewClient(cfg Config) *Client {
+	if cfg.HTTPClient == nil {
+		cfg.HTTPClient = http.DefaultClient
+	}
+	return &Client{cfg: cfg}
+}
+
+func (c *Client) submitURL() string {
+	q := url.Values{"requestId": {c.cfg.NewRequestID()}}
+	return c.cfg.BaseURL + statementsPath + "?" + q.Encode()
+}
+
+func (c *Client) partitionURL(handle string, partition int) string {
+	q := url.Values{"partition": {fmt.Sprint(partition)}}
+	return c.cfg.BaseURL + statementsPath + "/" + url.PathEscape(handle) + "?" + q.Encode()
+}
+
+func (st Statement) body() ([]byte, error) {
+	body := map[string]any{"statement": st.SQL}
+	if st.Timeout != 0 {
+		body["timeout"] = st.Timeout
+	}
+	if st.Database != "" {
+		body["database"] = st.Database
+	}
+	if st.Schema != "" {
+		body["schema"] = st.Schema
+	}
+	if st.Warehouse != "" {
+		body["warehouse"] = st.Warehouse
+	}
+	if st.Role != "" {
+		body["role"] = st.Role
+	}
+	return json.Marshal(body)
+}
+
+// roundTrip performs one request with the documented header set and returns
+// the status plus raw body.
+func (c *Client) roundTrip(ctx context.Context, method, rawURL string, payload []byte) (int, []byte, error) {
+	var reader io.Reader
+	if payload != nil {
+		reader = bytes.NewReader(payload)
+	}
+	req, err := http.NewRequestWithContext(ctx, method, rawURL, reader)
+	if err != nil {
+		return 0, nil, err
+	}
+	req.Header.Set("Authorization", "Bearer "+c.cfg.Token)
+	req.Header.Set("X-Snowflake-Authorization-Token-Type", c.cfg.TokenType)
+	req.Header.Set("Accept", "application/json")
+	req.Header.Set("User-Agent", c.cfg.UserAgent)
+	if payload != nil {
+		req.Header.Set("Content-Type", "application/json")
+	}
+	resp, err := c.cfg.HTTPClient.Do(req)
+	if err != nil {
+		return 0, nil, fmt.Errorf("sql api %s request failed: %w", method, err)
+	}
+	defer resp.Body.Close()
+	raw, err := io.ReadAll(resp.Body)
+	if err != nil {
+		return 0, nil, fmt.Errorf("sql api response read failed: %w", err)
+	}
+	return resp.StatusCode, raw, nil
+}
+
+// apiError decodes an error body into an APIError, tolerating bodies that
+// carry only a message.
+func apiError(status int, raw []byte) *APIError {
+	var body struct {
+		Code            string `json:"code"`
+		SQLState        string `json:"sqlState"`
+		Message         string `json:"message"`
+		StatementHandle string `json:"statementHandle"`
+	}
+	_ = json.Unmarshal(raw, &body)
+	if body.Message == "" {
+		body.Message = "no error message in response body"
+	}
+	return &APIError{
+		Status:          status,
+		Code:            body.Code,
+		SQLState:        body.SQLState,
+		Message:         body.Message,
+		StatementHandle: body.StatementHandle,
+	}
+}
