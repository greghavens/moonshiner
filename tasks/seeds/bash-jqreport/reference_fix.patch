+#!/usr/bin/env bash
+# report.sh — TSV reports over the orders export; jq does the heavy lifting.
+#
+# usage: report.sh <skus|regions> <file.json>
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo 'usage: report.sh <skus|regions> <file.json>' >&2
+  exit 64
+}
+
+[ "$#" -eq 2 ] || usage
+mode=$1
+file=$2
+case $mode in
+  skus | regions) ;;
+  *) usage ;;
+esac
+
+if [ ! -f "$file" ] || [ ! -r "$file" ]; then
+  echo "report.sh: cannot read: $file" >&2
+  exit 66
+fi
+
+# Parse probe: keep jq's own error text off the terminal.
+if ! jq empty "$file" > /dev/null 2>&1; then
+  echo "report.sh: invalid JSON: $file" >&2
+  exit 65
+fi
+
+skus_prog='
+  [ (.orders // [])[] as $o
+    | ($o.items // [])[]
+    | { oid: $o.id,
+        sku,
+        qty,
+        rev: (.qty * .unit_price - (.discount // 0)) } ]
+  | group_by(.sku)
+  | ( ["sku", "units", "revenue", "orders"],
+      ( .[]
+        | [ .[0].sku,
+            ([.[].qty] | add),
+            ([.[].rev] | add),
+            ([.[].oid] | unique | length) ] ) )
+  | @tsv
+'
+
+regions_prog='
+  (.orders // [])
+  | group_by(.region // "")
+  | ( ["region", "orders", "units", "revenue"],
+      ( .[]
+        | [ (.[0].region // ""),
+            length,
+            ([.[] | (.items // [])[] | .qty] | add // 0),
+            ([.[] | (.items // [])[]
+                  | .qty * .unit_price - (.discount // 0)] | add // 0) ] ) )
+  | @tsv
+'
+
+case $mode in
+  skus) jq -r "$skus_prog" "$file" ;;
+  regions) jq -r "$regions_prog" "$file" ;;
+esac
