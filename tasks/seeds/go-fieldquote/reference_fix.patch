+// Package fieldquote implements the site controller's quoting rules for
+// free-text fields in facility event ledger lines.
+package fieldquote
+
+import (
+	"errors"
+	"fmt"
+	"strings"
+	"unicode"
+	"unicode/utf8"
+)
+
+var (
+	ErrNotQuoted         = errors.New("fieldquote: value is not a quoted field")
+	ErrTrailingBackslash = errors.New("fieldquote: backslash at end of input")
+	ErrUnknownEscape     = errors.New("fieldquote: unknown escape sequence")
+	ErrBadHex            = errors.New("fieldquote: bad hex escape")
+	ErrBadRune           = errors.New("fieldquote: escape is not a valid code point")
+	ErrBareControl       = errors.New("fieldquote: unescaped control character")
+)
+
+// Printable reports whether Quote passes r through verbatim: printable
+// ASCII, or any rune above 0x7F that unicode.IsPrint accepts.
+func Printable(r rune) bool {
+	if r >= 0x20 && r <= 0x7e {
+		return true
+	}
+	if r > 0x7f {
+		return unicode.IsPrint(r)
+	}
+	return false
+}
+
+// Quote renders s as one double-quoted, single-line field per the
+// controller vendor's rules (uppercase hex, no named escapes beyond
+// \n, \t and \r).
+func Quote(s string) string {
+	var b strings.Builder
+	b.WriteByte('"')
+	for i := 0; i < len(s); {
+		r, size := utf8.DecodeRuneInString(s[i:])
+		if r == utf8.RuneError && size == 1 {
+			fmt.Fprintf(&b, `\x%02X`, s[i])
+			i++
+			continue
+		}
+		i += size
+		switch r {
+		case '"':
+			b.WriteString(`\"`)
+		case '\\':
+			b.WriteString(`\\`)
+		case '\n':
+			b.WriteString(`\n`)
+		case '\t':
+			b.WriteString(`\t`)
+		case '\r':
+			b.WriteString(`\r`)
+		default:
+			switch {
+			case Printable(r):
+				b.WriteRune(r)
+			case r < 0x80:
+				fmt.Fprintf(&b, `\x%02X`, r)
+			case r <= 0xFFFF:
+				fmt.Fprintf(&b, `\u%04X`, r)
+			default:
+				fmt.Fprintf(&b, `\U%08X`, r)
+			}
+		}
+	}
+	b.WriteByte('"')
+	return b.String()
+}
+
+// hexField reads exactly n hex digits of q starting at i.
+func hexField(q string, i, n int) (int, int, error) {
+	v := 0
+	for k := 0; k < n; k++ {
+		if i >= len(q) {
+			return 0, i, ErrBadHex
+		}
+		d := int(q[i])
+		switch {
+		case q[i] >= '0' && q[i] <= '9':
+			d -= '0'
+		case q[i] >= 'a' && q[i] <= 'f':
+			d -= 'a' - 10
+		case q[i] >= 'A' && q[i] <= 'F':
+			d -= 'A' - 10
+		default:
+			return 0, i, ErrBadHex
+		}
+		v = v<<4 | d
+		i++
+	}
+	return v, i, nil
+}
+
+// Unquote is the strict inverse of Quote for the reading side.
+func Unquote(q string) (string, error) {
+	if len(q) < 2 || q[0] != '"' {
+		return "", ErrNotQuoted
+	}
+	var b strings.Builder
+	i := 1
+	for i < len(q) {
+		if q[i] == '"' {
+			if i != len(q)-1 {
+				return "", ErrNotQuoted
+			}
+			return b.String(), nil
+		}
+		if q[i] != '\\' {
+			r, size := utf8.DecodeRuneInString(q[i:])
+			if r < 0x20 {
+				return "", ErrBareControl
+			}
+			b.WriteString(q[i : i+size])
+			i += size
+			continue
+		}
+		i++
+		if i >= len(q) {
+			return "", ErrTrailingBackslash
+		}
+		switch q[i] {
+		case '"':
+			b.WriteByte('"')
+			i++
+		case '\\':
+			b.WriteByte('\\')
+			i++
+		case 'n':
+			b.WriteByte('\n')
+			i++
+		case 't':
+			b.WriteByte('\t')
+			i++
+		case 'r':
+			b.WriteByte('\r')
+			i++
+		case 'x':
+			v, ni, err := hexField(q, i+1, 2)
+			if err != nil {
+				return "", err
+			}
+			b.WriteByte(byte(v))
+			i = ni
+		case 'u':
+			v, ni, err := hexField(q, i+1, 4)
+			if err != nil {
+				return "", err
+			}
+			if v >= 0xD800 && v <= 0xDFFF {
+				return "", ErrBadRune
+			}
+			b.WriteRune(rune(v))
+			i = ni
+		case 'U':
+			v, ni, err := hexField(q, i+1, 8)
+			if err != nil {
+				return "", err
+			}
+			if v > 0x10FFFF || (v >= 0xD800 && v <= 0xDFFF) {
+				return "", ErrBadRune
+			}
+			b.WriteRune(rune(v))
+			i = ni
+		default:
+			return "", ErrUnknownEscape
+		}
+	}
+	return "", ErrNotQuoted
+}
