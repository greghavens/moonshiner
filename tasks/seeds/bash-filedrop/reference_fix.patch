diff --git a/runjobs.sh b/runjobs.sh
index 8b120bd..8a429f5 100644
--- a/runjobs.sh
+++ b/runjobs.sh
@@ -28,19 +28,34 @@ if [ ! -d "$src" ]; then
 fi
 mkdir -p "$out"
 
+run_job() { # run_job <redirect-mode> <target> <argv...>
+  local mode=$1 target=$2
+  shift 2
+  case $mode in
+    none)     "$@" 2>/dev/null ;;
+    truncate) "$@" 2>/dev/null > "$target" ;;
+    append)   "$@" 2>/dev/null >> "$target" ;;
+  esac
+}
+
 ok=0
 failed=0
 while IFS=$'\t' read -r action name flags; do
   [ -n "$action" ] || continue
+  # the flags column is a short whitespace-separated option list
+  read -r -a flagv <<< "$flags"
   case $action in
     copy)
-      cmd="cp $flags -- '$src/$name' '$out/$name'"
+      cmd=(cp "${flagv[@]}" -- "$src/$name" "$out/$name")
+      mode=none target=''
       ;;
     pack)
-      cmd="gzip $flags -n -c -- '$src/$name' > '$out/$name.gz'"
+      cmd=(gzip "${flagv[@]}" -n -c -- "$src/$name")
+      mode=truncate target="$out/$name.gz"
       ;;
     note)
-      cmd="printf '%s\n' 'filed: $name' >> '$out/filing.log'"
+      cmd=(printf 'filed: %s\n' "$name")
+      mode=append target="$out/filing.log"
       ;;
     *)
       echo "runjobs: unknown action: $action" >&2
@@ -48,7 +63,7 @@ while IFS=$'\t' read -r action name flags; do
       continue
       ;;
   esac
-  if eval "$cmd" 2>/dev/null; then
+  if run_job "$mode" "$target" "${cmd[@]}"; then
     ok=$((ok + 1))
   else
     echo "runjobs: job failed: $action $name" >&2
