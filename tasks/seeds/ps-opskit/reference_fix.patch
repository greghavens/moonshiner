diff --git a/OpsKit/Private/Get-OpsSettingNames.ps1 b/OpsKit/Private/Get-OpsSettingNames.ps1
new file mode 100644
index 0000000..358d6af
--- /dev/null
+++ b/OpsKit/Private/Get-OpsSettingNames.ps1
@@ -0,0 +1,7 @@
+function Get-OpsSettingNames {
+    # Property names of a settings bag, ordinal-sorted.
+    param($Settings)
+
+    $names = @($Settings.PSObject.Properties | ForEach-Object { $_.Name })
+    return , (Get-OpsSortedNames -Names $names)
+}
diff --git a/OpsKit/Private/Get-OpsSortedNames.ps1 b/OpsKit/Private/Get-OpsSortedNames.ps1
new file mode 100644
index 0000000..4af50ba
--- /dev/null
+++ b/OpsKit/Private/Get-OpsSortedNames.ps1
@@ -0,0 +1,9 @@
+function Get-OpsSortedNames {
+    # Ordinal-sorted copy of a name list; every pinned ordering in the module
+    # goes through here so nothing falls back to a linguistic sort.
+    param([string[]]$Names)
+
+    $sorted = @($Names)
+    [Array]::Sort($sorted, [System.StringComparer]::Ordinal)
+    return , $sorted
+}
diff --git a/OpsKit/Private/Read-OpsHostFile.ps1 b/OpsKit/Private/Read-OpsHostFile.ps1
new file mode 100644
index 0000000..ba2b149
--- /dev/null
+++ b/OpsKit/Private/Read-OpsHostFile.ps1
@@ -0,0 +1,21 @@
+function Read-OpsHostFile {
+    # Parse one per-host state file; the caller supplies the bare file name
+    # used in error messages.
+    param([string]$Path, [string]$Name)
+
+    try {
+        $data = Get-Content -LiteralPath $Path -Raw | ConvertFrom-Json
+    } catch {
+        throw "OpsKit: invalid inventory file '$Name'"
+    }
+    if ($null -eq $data -or $data -isnot [pscustomobject]) {
+        throw "OpsKit: invalid inventory file '$Name'"
+    }
+    $members = @($data.PSObject.Properties | ForEach-Object { $_.Name })
+    foreach ($required in 'host', 'role', 'settings') {
+        if ($members -cnotcontains $required) {
+            throw "OpsKit: invalid inventory file '$Name'"
+        }
+    }
+    return $data
+}
diff --git a/OpsKit/Public/Compare-OpsState.ps1 b/OpsKit/Public/Compare-OpsState.ps1
new file mode 100644
index 0000000..2a12a92
--- /dev/null
+++ b/OpsKit/Public/Compare-OpsState.ps1
@@ -0,0 +1,78 @@
+function Compare-OpsState {
+    [CmdletBinding()]
+    param(
+        [Parameter(ValueFromPipeline)]
+        [object[]]$Inventory,
+
+        [Parameter(Mandatory)]
+        [string]$Desired
+    )
+
+    begin {
+        $hosts = [System.Collections.Generic.List[object]]::new()
+        $desiredData = Get-Content -LiteralPath $Desired -Raw | ConvertFrom-Json
+        $roleNames = @($desiredData.roles.PSObject.Properties | ForEach-Object { $_.Name })
+    }
+
+    process {
+        if ($null -ne $Inventory) {
+            foreach ($item in $Inventory) { $hosts.Add($item) }
+        }
+    }
+
+    end {
+        $byHost = [System.Collections.Generic.Dictionary[string, object]]::new([System.StringComparer]::Ordinal)
+        foreach ($h in $hosts) { $byHost[[string]$h.Host] = $h }
+
+        foreach ($hostName in (Get-OpsSortedNames -Names @($byHost.Keys))) {
+            $h = $byHost[$hostName]
+            $role = [string]$h.Role
+            if ($roleNames -cnotcontains $role) {
+                throw "OpsKit: no desired state for role '$role'"
+            }
+            $want = $desiredData.roles.$role.settings
+            $wantNames = Get-OpsSettingNames -Settings $want
+            $haveNames = Get-OpsSettingNames -Settings $h.Settings
+
+            $union = [System.Collections.Generic.List[string]]::new()
+            foreach ($n in $wantNames) { $union.Add($n) }
+            foreach ($n in $haveNames) {
+                if ($wantNames -cnotcontains $n) { $union.Add($n) }
+            }
+
+            foreach ($setting in (Get-OpsSortedNames -Names @($union))) {
+                $inWant = $wantNames -ccontains $setting
+                $inHave = $haveNames -ccontains $setting
+                if ($inWant -and $inHave) {
+                    $expected = [string]$want.$setting
+                    $actual = [string]$h.Settings.$setting
+                    if ($expected -cne $actual) {
+                        [pscustomobject]@{
+                            Host     = $hostName
+                            Setting  = $setting
+                            Kind     = 'value'
+                            Expected = $expected
+                            Actual   = $actual
+                        }
+                    }
+                } elseif ($inWant) {
+                    [pscustomobject]@{
+                        Host     = $hostName
+                        Setting  = $setting
+                        Kind     = 'missing'
+                        Expected = [string]$want.$setting
+                        Actual   = $null
+                    }
+                } else {
+                    [pscustomobject]@{
+                        Host     = $hostName
+                        Setting  = $setting
+                        Kind     = 'extra'
+                        Expected = $null
+                        Actual   = [string]$h.Settings.$setting
+                    }
+                }
+            }
+        }
+    }
+}
diff --git a/OpsKit/Public/Import-OpsInventory.ps1 b/OpsKit/Public/Import-OpsInventory.ps1
new file mode 100644
index 0000000..1aa4e09
--- /dev/null
+++ b/OpsKit/Public/Import-OpsInventory.ps1
@@ -0,0 +1,29 @@
+function Import-OpsInventory {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)]
+        [string]$Path
+    )
+
+    $names = @(Get-ChildItem -LiteralPath $Path -File -Filter '*.json' |
+        ForEach-Object { $_.Name })
+    $names = Get-OpsSortedNames -Names $names
+
+    $byHost = [System.Collections.Generic.Dictionary[string, object]]::new([System.StringComparer]::Ordinal)
+    foreach ($name in $names) {
+        $data = Read-OpsHostFile -Path (Join-Path $Path $name) -Name $name
+        $hostName = [string]$data.host
+        if ($byHost.ContainsKey($hostName)) {
+            throw "OpsKit: duplicate host '$hostName'"
+        }
+        $byHost[$hostName] = [pscustomobject]@{
+            Host     = $hostName
+            Role     = [string]$data.role
+            Settings = $data.settings
+        }
+    }
+
+    foreach ($hostName in (Get-OpsSortedNames -Names @($byHost.Keys))) {
+        $byHost[$hostName]
+    }
+}
diff --git a/OpsKit/Public/Invoke-OpsPlan.ps1 b/OpsKit/Public/Invoke-OpsPlan.ps1
new file mode 100644
index 0000000..0870674
--- /dev/null
+++ b/OpsKit/Public/Invoke-OpsPlan.ps1
@@ -0,0 +1,45 @@
+function Invoke-OpsPlan {
+    [CmdletBinding(SupportsShouldProcess)]
+    param(
+        [Parameter(Mandatory)]
+        [object[]]$Plan,
+
+        [Parameter(Mandatory)]
+        [string]$Root
+    )
+
+    foreach ($step in $Plan) {
+        $file = Join-Path $Root "$($step.Host).json"
+        if (-not (Test-Path -LiteralPath $file -PathType Leaf)) {
+            throw "OpsKit: no state file for host '$($step.Host)'"
+        }
+    }
+
+    foreach ($step in $Plan) {
+        $target = "$($step.Host).$($step.Setting)"
+        if (-not $PSCmdlet.ShouldProcess($target, $step.Action)) {
+            continue
+        }
+        $file = Join-Path $Root "$($step.Host).json"
+        $data = Get-Content -LiteralPath $file -Raw | ConvertFrom-Json
+        $existing = @($data.settings.PSObject.Properties | ForEach-Object { $_.Name })
+        if ($step.Action -ceq 'set') {
+            if ($existing -ccontains $step.Setting) {
+                $data.settings.($step.Setting) = $step.Value
+            } else {
+                $data.settings | Add-Member -NotePropertyName $step.Setting -NotePropertyValue $step.Value
+            }
+        } else {
+            $data.settings.PSObject.Properties.Remove($step.Setting)
+        }
+        $json = $data | ConvertTo-Json -Depth 8
+        [System.IO.File]::WriteAllText($file, $json + "`n")
+        [pscustomobject]@{
+            Order   = $step.Order
+            Host    = $step.Host
+            Action  = $step.Action
+            Setting = $step.Setting
+            Status  = 'applied'
+        }
+    }
+}
diff --git a/OpsKit/Public/New-OpsPlan.ps1 b/OpsKit/Public/New-OpsPlan.ps1
new file mode 100644
index 0000000..73b20f6
--- /dev/null
+++ b/OpsKit/Public/New-OpsPlan.ps1
@@ -0,0 +1,47 @@
+function New-OpsPlan {
+    [CmdletBinding()]
+    param(
+        [Parameter(ValueFromPipeline)]
+        [object[]]$Drift
+    )
+
+    begin {
+        $records = [System.Collections.Generic.List[object]]::new()
+    }
+
+    process {
+        if ($null -ne $Drift) {
+            foreach ($item in $Drift) { $records.Add($item) }
+        }
+    }
+
+    end {
+        $sets = [System.Collections.Generic.List[object]]::new()
+        $clears = [System.Collections.Generic.List[object]]::new()
+        foreach ($d in $records) {
+            if ($d.Kind -ceq 'extra') { $clears.Add($d) } else { $sets.Add($d) }
+        }
+
+        $order = 0
+        foreach ($group in @($sets, $clears)) {
+            $keys = @($group | ForEach-Object { "$($_.Host)|$($_.Setting)" })
+            $keys = Get-OpsSortedNames -Names $keys
+            foreach ($key in $keys) {
+                foreach ($d in $group) {
+                    if ("$($d.Host)|$($d.Setting)" -ceq $key) {
+                        $order++
+                        $value = if ($d.Kind -ceq 'extra') { $null } else { $d.Expected }
+                        $action = if ($d.Kind -ceq 'extra') { 'clear' } else { 'set' }
+                        [pscustomobject]@{
+                            Order   = $order
+                            Host    = $d.Host
+                            Action  = $action
+                            Setting = $d.Setting
+                            Value   = $value
+                        }
+                    }
+                }
+            }
+        }
+    }
+}
