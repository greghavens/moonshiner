+export interface MemoizeOptions<A> {
+  /** Derive the cache key from the argument (default: the argument itself). */
+  key?: (arg: A) => unknown;
+}
+
+export interface MemoizedAsync<A, R> {
+  (arg: A): Promise<R>;
+  delete(arg: A): boolean;
+  clear(): void;
+}
+
+interface Entry<R> {
+  promise: Promise<R>;
+}
+
+function isObjectKey(key: unknown): key is object {
+  return (typeof key === 'object' && key !== null) || typeof key === 'function';
+}
+
+export function memoizeAsync<A, R>(
+  fn: (arg: A) => Promise<R>,
+  opts: MemoizeOptions<A> = {},
+): MemoizedAsync<A, R> {
+  const keyOf = opts.key ?? ((arg: A) => arg as unknown);
+  let primitives = new Map<unknown, Entry<R>>();
+  // Object keys live in a WeakMap so entries die with the objects.
+  let objects = new WeakMap<object, Entry<R>>();
+
+  const lookup = (key: unknown): Entry<R> | undefined =>
+    isObjectKey(key) ? objects.get(key) : primitives.get(key);
+
+  const store = (key: unknown, entry: Entry<R>): void => {
+    if (isObjectKey(key)) objects.set(key, entry);
+    else primitives.set(key, entry);
+  };
+
+  const evict = (key: unknown): boolean =>
+    isObjectKey(key) ? objects.delete(key) : primitives.delete(key);
+
+  const memoized = (arg: A): Promise<R> => {
+    const key = keyOf(arg);
+    const existing = lookup(key);
+    if (existing) return existing.promise;
+
+    const entry: Entry<R> = { promise: undefined as unknown as Promise<R> };
+    entry.promise = Promise.resolve()
+      .then(() => fn(arg))
+      .catch((error: unknown) => {
+        // Errors are never cached — but only evict if this flight is still
+        // the current entry (a clear()/delete() may have replaced it).
+        if (lookup(key) === entry) evict(key);
+        throw error;
+      });
+    store(key, entry);
+    return entry.promise;
+  };
+
+  memoized.delete = (arg: A): boolean => evict(keyOf(arg));
+
+  memoized.clear = (): void => {
+    primitives = new Map();
+    objects = new WeakMap();
+  };
+
+  return memoized;
+}
