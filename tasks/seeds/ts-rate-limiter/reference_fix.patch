@@ -0,0 +1,112 @@
+export interface TimerHost {
+  now(): number;
+  setTimeout(fn: () => void, ms: number): unknown;
+  clearTimeout(id: unknown): void;
+}
+
+export interface LimiterOptions {
+  limit: number;
+  windowMs: number;
+  timers?: TimerHost;
+}
+
+const realTimers: TimerHost = {
+  now: () => Date.now(),
+  setTimeout: (fn, ms) => setTimeout(fn, ms),
+  clearTimeout: (id) => clearTimeout(id as Parameters<typeof clearTimeout>[0]),
+};
+
+interface Waiter {
+  resolve: () => void;
+  detach: (() => void) | null;
+}
+
+export class SlidingWindowLimiter {
+  private limit: number;
+  private windowMs: number;
+  private timers: TimerHost;
+  /** Grant timestamps, ascending; each occupies a slot until t + windowMs. */
+  private stamps: number[] = [];
+  private queue: Waiter[] = [];
+  private wakeTimer: unknown = null;
+
+  constructor(opts: LimiterOptions) {
+    const { limit, windowMs, timers = realTimers } = opts;
+    if (!Number.isInteger(limit) || limit < 1) {
+      throw new TypeError(`limit must be a positive integer, got ${limit}`);
+    }
+    if (!Number.isFinite(windowMs) || windowMs <= 0) {
+      throw new TypeError(`windowMs must be positive, got ${windowMs}`);
+    }
+    this.limit = limit;
+    this.windowMs = windowMs;
+    this.timers = timers;
+  }
+
+  get pending(): number {
+    return this.queue.length;
+  }
+
+  acquire(signal?: AbortSignal): Promise<void> {
+    if (signal?.aborted) return Promise.reject(signal.reason);
+    const now = this.timers.now();
+    this.prune(now);
+    if (this.stamps.length < this.limit && this.queue.length === 0) {
+      this.stamps.push(now);
+      return Promise.resolve();
+    }
+    return new Promise<void>((resolve, reject) => {
+      const waiter: Waiter = { resolve, detach: null };
+      if (signal) {
+        const onAbort = () => {
+          const i = this.queue.indexOf(waiter);
+          if (i !== -1) this.queue.splice(i, 1);
+          reject(signal.reason);
+        };
+        signal.addEventListener('abort', onAbort, { once: true });
+        waiter.detach = () => signal.removeEventListener('abort', onAbort);
+      }
+      this.queue.push(waiter);
+      this.scheduleWake();
+    });
+  }
+
+  tryAcquire(): boolean {
+    const now = this.timers.now();
+    this.prune(now);
+    if (this.stamps.length < this.limit && this.queue.length === 0) {
+      this.stamps.push(now);
+      return true;
+    }
+    return false;
+  }
+
+  /** Drop grants that have aged out of the sliding window. */
+  private prune(now: number): void {
+    while (this.stamps.length > 0 && now - this.stamps[0] >= this.windowMs) {
+      this.stamps.shift();
+    }
+  }
+
+  private scheduleWake(): void {
+    if (this.wakeTimer !== null || this.queue.length === 0 || this.stamps.length === 0) return;
+    const now = this.timers.now();
+    const wait = Math.max(0, this.stamps[0] + this.windowMs - now);
+    this.wakeTimer = this.timers.setTimeout(() => {
+      this.wakeTimer = null;
+      this.drainQueue();
+    }, wait);
+  }
+
+  private drainQueue(): void {
+    const now = this.timers.now();
+    this.prune(now);
+    while (this.queue.length > 0 && this.stamps.length < this.limit) {
+      const waiter = this.queue.shift()!;
+      waiter.detach?.();
+      this.stamps.push(now); // stamped at grant time
+      waiter.resolve();
+    }
+    this.scheduleWake();
+  }
+}
