+/**
+ * One schema reference as the registry expects it: the name used inside the
+ * referencing schema, the subject the referenced schema lives under, and the
+ * referenced version.
+ */
+public final class SchemaReference {
+    public final String name;
+    public final String subject;
+    public final int version;
+
+    public SchemaReference(String name, String subject, int version) {
+        this.name = name;
+        this.subject = subject;
+        this.version = version;
+    }
+}
diff --git a/SchemaRegistryClient.java b/SchemaRegistryClient.java
new file mode 100644
index 0000000..81efc16
--- /dev/null
+++ b/SchemaRegistryClient.java
@@ -0,0 +1,165 @@
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.Base64;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.function.IntConsumer;
+
+/**
+ * Thin client for the Schema Registry REST API using the versioned
+ * application/vnd.schemaregistry.v1+json media type. Every call retries
+ * documented 429 responses through the injected sleeper (Retry-After
+ * seconds, default 1 when the header is absent), at most 3 retries after
+ * the initial attempt. See docs/contract.json.
+ */
+public final class SchemaRegistryClient {
+
+    static final String MEDIA = "application/vnd.schemaregistry.v1+json";
+    private static final int MAX_RETRIES = 3;
+
+    private final String baseUrl;
+    private final String auth;
+    private final IntConsumer sleeper;
+    private final HttpClient http;
+
+    public SchemaRegistryClient(String baseUrl, String username, String password,
+            IntConsumer sleeper) {
+        this.baseUrl = baseUrl.endsWith("/")
+                ? baseUrl.substring(0, baseUrl.length() - 1) : baseUrl;
+        this.auth = "Basic " + Base64.getEncoder().encodeToString(
+                (username + ":" + password).getBytes(StandardCharsets.UTF_8));
+        this.sleeper = sleeper;
+        this.http = HttpClient.newBuilder()
+                .followRedirects(HttpClient.Redirect.NEVER)
+                .build();
+    }
+
+    public RegisteredSchema register(String subject, String schemaType,
+            String schema, List<SchemaReference> references)
+            throws SchemaRegistryException {
+        Map<String, Object> body = schemaBody(schemaType, schema, references);
+        Map<String, Object> response =
+                post("/subjects/" + subject + "/versions", body);
+        return new RegisteredSchema(intField(response, "id"));
+    }
+
+    /** Returns null when the schema (or the whole subject) is not registered. */
+    public LookupResult lookup(String subject, String schemaType, String schema,
+            List<SchemaReference> references) throws SchemaRegistryException {
+        Map<String, Object> body = schemaBody(schemaType, schema, references);
+        try {
+            Map<String, Object> response = post("/subjects/" + subject, body);
+            return new LookupResult((String) response.get("subject"),
+                    intField(response, "id"), intField(response, "version"),
+                    (String) response.get("schema"));
+        } catch (SchemaRegistryException e) {
+            if (e.errorCode == 40401 || e.errorCode == 40403) {
+                return null;
+            }
+            throw e;
+        }
+    }
+
+    public CompatibilityResult checkCompatibility(String subject, String version,
+            String schemaType, String schema, List<SchemaReference> references)
+            throws SchemaRegistryException {
+        Map<String, Object> body = schemaBody(schemaType, schema, references);
+        Map<String, Object> response = post("/compatibility/subjects/" + subject
+                + "/versions/" + version + "?verbose=true", body);
+        List<String> messages = new ArrayList<>();
+        Object raw = response.get("messages");
+        if (raw instanceof List<?> list) {
+            for (Object m : list) {
+                messages.add(String.valueOf(m));
+            }
+        }
+        return new CompatibilityResult(
+                Boolean.TRUE.equals(response.get("is_compatible")), messages);
+    }
+
+    private static Map<String, Object> schemaBody(String schemaType,
+            String schema, List<SchemaReference> references) {
+        Map<String, Object> body = new LinkedHashMap<>();
+        body.put("schema", schema);
+        if (schemaType != null && !"AVRO".equals(schemaType)) {
+            body.put("schemaType", schemaType);
+        }
+        if (references != null && !references.isEmpty()) {
+            List<Object> refs = new ArrayList<>();
+            for (SchemaReference r : references) {
+                Map<String, Object> ref = new LinkedHashMap<>();
+                ref.put("name", r.name);
+                ref.put("subject", r.subject);
+                ref.put("version", r.version);
+                refs.add(ref);
+            }
+            body.put("references", refs);
+        }
+        return body;
+    }
+
+    private static int intField(Map<String, Object> map, String key) {
+        return ((Number) map.get(key)).intValue();
+    }
+
+    @SuppressWarnings("unchecked")
+    private Map<String, Object> post(String path, Map<String, Object> body)
+            throws SchemaRegistryException {
+        HttpRequest request = HttpRequest.newBuilder(URI.create(baseUrl + path))
+                .header("Content-Type", MEDIA)
+                .header("Accept", MEDIA)
+                .header("Authorization", auth)
+                .POST(HttpRequest.BodyPublishers.ofString(Json.write(body)))
+                .build();
+        for (int attempt = 0; ; attempt++) {
+            HttpResponse<String> response;
+            try {
+                response = http.send(request,
+                        HttpResponse.BodyHandlers.ofString());
+            } catch (Exception e) {
+                throw new SchemaRegistryException(0, 0,
+                        "transport failure: " + e.getMessage());
+            }
+            if (response.statusCode() == 429 && attempt < MAX_RETRIES) {
+                sleeper.accept(retryAfterSeconds(response));
+                continue;
+            }
+            if (response.statusCode() / 100 == 2) {
+                return (Map<String, Object>) Json.parse(response.body());
+            }
+            throw envelopeError(response);
+        }
+    }
+
+    private static int retryAfterSeconds(HttpResponse<String> response) {
+        return response.headers().firstValue("Retry-After")
+                .map(Integer::parseInt).orElse(1);
+    }
+
+    private static SchemaRegistryException envelopeError(
+            HttpResponse<String> response) {
+        int code = 0;
+        String message = response.body();
+        try {
+            Object parsed = Json.parse(response.body());
+            if (parsed instanceof Map<?, ?> map) {
+                Object rawCode = map.get("error_code");
+                if (rawCode instanceof Number n) {
+                    code = n.intValue();
+                }
+                Object rawMessage = map.get("message");
+                if (rawMessage != null) {
+                    message = String.valueOf(rawMessage);
+                }
+            }
+        } catch (RuntimeException ignored) {
+            // keep the raw body as the message
+        }
+        return new SchemaRegistryException(response.statusCode(), code, message);
+    }
+}
diff --git a/SchemaRegistryException.java b/SchemaRegistryException.java
new file mode 100644
index 0000000..1951e14
--- /dev/null
+++ b/SchemaRegistryException.java
@@ -0,0 +1,11 @@
+/** A Schema Registry error envelope ({"error_code": ..., "message": ...}). */
+public class SchemaRegistryException extends Exception {
+    public final int httpStatus;
+    public final int errorCode;
+
+    public SchemaRegistryException(int httpStatus, int errorCode, String message) {
+        super("HTTP " + httpStatus + " / " + errorCode + ": " + message);
+        this.httpStatus = httpStatus;
+        this.errorCode = errorCode;
+    }
+}
