diff --git a/ReleaseGate.java b/ReleaseGate.java
new file mode 100644
index 0000000..85ca5f2
--- /dev/null
+++ b/ReleaseGate.java
@@ -0,0 +1,50 @@
+import java.util.List;
+
+/**
+ * Release-gate promotion flow, in order: identical schema already under the
+ * subject -> ALREADY_REGISTERED; incompatible with latest -> INCOMPATIBLE
+ * (never registered); otherwise register and resolve the assigned version.
+ * A brand-new subject (40401 on the compatibility check) is a first
+ * registration, not an error.
+ */
+public final class ReleaseGate {
+
+    private final SchemaRegistryClient client;
+
+    public ReleaseGate(SchemaRegistryClient client) {
+        this.client = client;
+    }
+
+    public PromotionResult promote(String subject, String schemaType,
+            String schema, List<SchemaReference> references)
+            throws SchemaRegistryException {
+        LookupResult existing =
+                client.lookup(subject, schemaType, schema, references);
+        if (existing != null) {
+            return new PromotionResult("ALREADY_REGISTERED", existing.id,
+                    existing.version, List.of());
+        }
+
+        CompatibilityResult compat = null;
+        try {
+            compat = client.checkCompatibility(subject, "latest", schemaType,
+                    schema, references);
+        } catch (SchemaRegistryException e) {
+            if (e.errorCode != 40401) {
+                throw e;
+            }
+            // Subject does not exist yet: nothing to be incompatible with.
+        }
+        if (compat != null && !compat.isCompatible) {
+            return new PromotionResult("INCOMPATIBLE", -1, -1, compat.messages);
+        }
+
+        RegisteredSchema registered =
+                client.register(subject, schemaType, schema, references);
+        LookupResult resolved =
+                client.lookup(subject, schemaType, schema, references);
+        int version = resolved != null ? resolved.version : -1;
+        return new PromotionResult("REGISTERED", registered.id, version,
+                List.of());
+    }
+}
