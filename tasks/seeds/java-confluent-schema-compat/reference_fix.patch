+import java.util.List;
+
+/**
+ * What the release gate decided: REGISTERED, ALREADY_REGISTERED, or
+ * INCOMPATIBLE (id/version -1, messages carrying the verbose reasons).
+ */
+public final class PromotionResult {
+    public final String outcome;
+    public final int id;
+    public final int version;
+    public final List<String> messages;
+
+    public PromotionResult(String outcome, int id, int version, List<String> messages) {
+        this.outcome = outcome;
+        this.id = id;
+        this.version = version;
+        this.messages = List.copyOf(messages);
+    }
+}
