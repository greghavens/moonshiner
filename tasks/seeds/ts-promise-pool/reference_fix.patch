+export type Settled<T> =
+  | { status: 'fulfilled'; value: T }
+  | { status: 'rejected'; reason: unknown };
+
+function checkLimit(limit: number): void {
+  if (!Number.isInteger(limit) || limit < 1) {
+    throw new TypeError(`limit must be a positive integer, got ${limit}`);
+  }
+}
+
+async function pump<T>(
+  tasks: Array<() => Promise<T>>,
+  limit: number,
+  onResult: (index: number, outcome: Settled<T>) => boolean,
+): Promise<void> {
+  let next = 0;
+  let stopped = false;
+
+  async function worker(): Promise<void> {
+    while (!stopped && next < tasks.length) {
+      const index = next++;
+      let outcome: Settled<T>;
+      try {
+        outcome = { status: 'fulfilled', value: await tasks[index]() };
+      } catch (reason) {
+        outcome = { status: 'rejected', reason };
+      }
+      if (!onResult(index, outcome)) {
+        stopped = true;
+        return;
+      }
+    }
+  }
+
+  const workers: Array<Promise<void>> = [];
+  for (let i = 0; i < Math.min(limit, tasks.length); i++) {
+    workers.push(worker());
+  }
+  await Promise.all(workers);
+}
+
+export function runPool<T>(
+  tasks: Array<() => Promise<T>>,
+  limit: number,
+): Promise<T[]> {
+  checkLimit(limit);
+  return new Promise<T[]>((resolve, reject) => {
+    const results = new Array<T>(tasks.length);
+    let failed = false;
+    pump<T>(tasks, limit, (index, outcome) => {
+      if (outcome.status === 'rejected') {
+        failed = true;
+        reject(outcome.reason);
+        return false;
+      }
+      results[index] = outcome.value;
+      return true;
+    }).then(() => {
+      if (!failed) resolve(results);
+    }, reject);
+  });
+}
+
+export function runPoolSettled<T>(
+  tasks: Array<() => Promise<T>>,
+  limit: number,
+): Promise<Array<Settled<T>>> {
+  checkLimit(limit);
+  const results = new Array<Settled<T>>(tasks.length);
+  return pump<T>(tasks, limit, (index, outcome) => {
+    results[index] = outcome;
+    return true;
+  }).then(() => results);
+}
