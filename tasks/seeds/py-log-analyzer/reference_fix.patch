+#!/usr/bin/env python3
+"""Access-log report CLI: summaries and top-N breakdowns with filters."""
+import argparse
+import sys
+
+import logparse
+import logstats
+
+BY_FIELD = {"path": "path", "ip": "ip"}
+
+
+def add_filter_args(parser):
+    parser.add_argument("logfile")
+    parser.add_argument("--status", type=int, default=None)
+    parser.add_argument("--method", default=None)
+    parser.add_argument("--path-prefix", dest="path_prefix", default=None)
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="logreport.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_sum = sub.add_parser("summary")
+    add_filter_args(p_sum)
+
+    p_top = sub.add_parser("top")
+    add_filter_args(p_top)
+    p_top.add_argument("--by", choices=sorted(BY_FIELD), required=True)
+    p_top.add_argument("-n", type=int, default=10)
+    return parser
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    try:
+        entries, malformed = logparse.parse_file(args.logfile)
+    except OSError as exc:
+        print(f"cannot read log file: {exc}", file=sys.stderr)
+        return 2
+
+    entries = logstats.apply_filters(entries, status=args.status,
+                                     method=args.method,
+                                     path_prefix=args.path_prefix)
+
+    if args.command == "summary":
+        stats = logstats.summarize(entries)
+        print(f"requests: {stats['requests']}")
+        print(f"bytes: {stats['bytes']}")
+        print(f"malformed: {malformed}")
+        for status in sorted(stats["by_status"]):
+            print(f"status {status}: {stats['by_status'][status]}")
+        return 0
+
+    for value, count in logstats.top(entries, BY_FIELD[args.by], args.n):
+        print(f"{count} {value}")
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
