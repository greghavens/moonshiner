+"""Common-log-format line parsing."""
+import re
+
+LINE_RE = re.compile(
+    r'^(?P<ip>\S+) \S+ \S+ \[(?P<time>[^\]]+)\] '
+    r'"(?P<method>\S+) (?P<target>\S+) [^"]*" '
+    r'(?P<status>\d{3}) (?P<size>\d+|-)$'
+)
+
+
+def parse_line(line):
+    """Parse one access-log line -> dict, or None if malformed."""
+    m = LINE_RE.match(line.rstrip("\n"))
+    if not m:
+        return None
+    size = m.group("size")
+    return {
+        "ip": m.group("ip"),
+        "method": m.group("method"),
+        "path": m.group("target").split("?", 1)[0],
+        "status": int(m.group("status")),
+        "bytes": 0 if size == "-" else int(size),
+    }
+
+
+def parse_file(path):
+    """Return (entries, malformed_count)."""
+    entries, malformed = [], 0
+    with open(path, encoding="utf-8", errors="replace") as f:
+        for line in f:
+            if not line.strip():
+                continue
+            entry = parse_line(line)
+            if entry is None:
+                malformed += 1
+            else:
+                entries.append(entry)
+    return entries, malformed
