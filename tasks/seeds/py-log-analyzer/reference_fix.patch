--- /dev/null
+++ b/logstats.py
@@ -0,0 +1,27 @@
+"""Filtering and aggregation over parsed log entries."""
+from collections import Counter
+
+
+def apply_filters(entries, status=None, method=None, path_prefix=None):
+    out = entries
+    if status is not None:
+        out = [e for e in out if e["status"] == status]
+    if method is not None:
+        out = [e for e in out if e["method"] == method]
+    if path_prefix is not None:
+        out = [e for e in out if e["path"].startswith(path_prefix)]
+    return out
+
+
+def summarize(entries):
+    return {
+        "requests": len(entries),
+        "bytes": sum(e["bytes"] for e in entries),
+        "by_status": Counter(e["status"] for e in entries),
+    }
+
+
+def top(entries, field, n):
+    counts = Counter(e[field] for e in entries)
+    ranked = sorted(counts.items(), key=lambda kv: (-kv[1], kv[0]))
+    return ranked[:n]
