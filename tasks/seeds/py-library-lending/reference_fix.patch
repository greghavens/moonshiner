+"""JSON persistence. This module owns the db format; nobody else opens the file.
+
+Format:
+{
+  "books":   {isbn: {"title": str, "copies": int,
+                     "loans": {member: due_date}, "holds": [member, ...]}},
+  "members": {name: {"fines_cents": int}}
+}
+"""
+import json
+import os
+
+
+def empty():
+    return {"books": {}, "members": {}}
+
+
+def load(path):
+    if not os.path.exists(path):
+        return empty()
+    with open(path, encoding="utf-8") as f:
+        return json.load(f)
+
+
+def save(path, state):
+    tmp = path + ".tmp"
+    with open(tmp, "w", encoding="utf-8") as f:
+        json.dump(state, f, indent=2, sort_keys=True)
+    os.replace(tmp, path)
