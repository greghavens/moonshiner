+"""Library lending CLI: add-book / checkout / return / hold / status / member / pay."""
+import argparse
+import sys
+
+import lending
+import store
+
+
+def err(msg):
+    print(f"error: {msg}", file=sys.stderr)
+    return 1
+
+
+def cmd_add_book(args):
+    if args.copies < 1:
+        return err("copies must be at least 1")
+    state = store.load(args.db)
+    if args.isbn in state["books"]:
+        return err(f"book {args.isbn} is already in the catalog")
+    state["books"][args.isbn] = {
+        "title": args.title, "copies": args.copies, "loans": {}, "holds": [],
+    }
+    store.save(args.db, state)
+    return 0
+
+
+def _get_book(state, isbn):
+    book = state["books"].get(isbn)
+    if book is None:
+        raise KeyError(isbn)
+    return book
+
+
+def _fines(state, member):
+    return state["members"].get(member, {}).get("fines_cents", 0)
+
+
+def cmd_checkout(args):
+    state = store.load(args.db)
+    try:
+        book = _get_book(state, args.isbn)
+    except KeyError:
+        return err(f"unknown book {args.isbn}")
+    try:
+        lending.parse_date(args.date)
+    except ValueError:
+        return err(f"bad date {args.date!r}, expected YYYY-MM-DD")
+    if args.member in book["loans"]:
+        return err(f"{args.member} already has {args.isbn} checked out")
+    owed = _fines(state, args.member)
+    if owed >= lending.BLOCK_THRESHOLD_CENTS:
+        return err(f"{args.member} owes {lending.format_cents(owed)}; "
+                   "checkout is suspended until fines drop below "
+                   f"{lending.format_cents(lending.BLOCK_THRESHOLD_CENTS)}")
+    available = book["copies"] - len(book["loans"])
+    if available <= 0:
+        return err(f"no copies of {args.isbn} available; place a hold")
+    if book["holds"]:
+        if book["holds"][0] != args.member:
+            return err(f"{args.isbn} is reserved for {book['holds'][0]}")
+        book["holds"].pop(0)
+    due = lending.due_date(args.date)
+    book["loans"][args.member] = due
+    store.save(args.db, state)
+    print(f"due {due}")
+    return 0
+
+
+def cmd_return(args):
+    state = store.load(args.db)
+    try:
+        book = _get_book(state, args.isbn)
+    except KeyError:
+        return err(f"unknown book {args.isbn}")
+    try:
+        lending.parse_date(args.date)
+    except ValueError:
+        return err(f"bad date {args.date!r}, expected YYYY-MM-DD")
+    due = book["loans"].get(args.member)
+    if due is None:
+        return err(f"{args.member} does not have {args.isbn} checked out")
+    fee = lending.late_fee_cents(due, args.date)
+    del book["loans"][args.member]
+    if fee:
+        member = state["members"].setdefault(args.member, {"fines_cents": 0})
+        member["fines_cents"] += fee
+    store.save(args.db, state)
+    print(f"fine {lending.format_cents(fee)}")
+    return 0
+
+
+def cmd_hold(args):
+    state = store.load(args.db)
+    try:
+        book = _get_book(state, args.isbn)
+    except KeyError:
+        return err(f"unknown book {args.isbn}")
+    if args.member in book["loans"]:
+        return err(f"{args.member} already has {args.isbn} checked out")
+    if args.member in book["holds"]:
+        return err(f"{args.member} is already in the queue for {args.isbn}")
+    if book["copies"] - len(book["loans"]) > 0:
+        return err(f"copies of {args.isbn} are available; check one out instead")
+    book["holds"].append(args.member)
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_status(args):
+    state = store.load(args.db)
+    try:
+        book = _get_book(state, args.isbn)
+    except KeyError:
+        return err(f"unknown book {args.isbn}")
+    available = book["copies"] - len(book["loans"])
+    print(f"{book['title']}\tavailable={available}/{book['copies']}"
+          f"\tholds={len(book['holds'])}")
+    return 0
+
+
+def cmd_member(args):
+    state = store.load(args.db)
+    for isbn in sorted(state["books"]):
+        due = state["books"][isbn]["loans"].get(args.name)
+        if due is not None:
+            print(f"{isbn}\tdue={due}")
+    print(f"fines={lending.format_cents(_fines(state, args.name))}")
+    return 0
+
+
+def cmd_pay(args):
+    try:
+        amount = lending.parse_amount_cents(args.amount)
+    except ValueError:
+        return err(f"bad amount {args.amount!r}")
+    if amount <= 0:
+        return err("payment must be more than $0.00")
+    state = store.load(args.db)
+    owed = _fines(state, args.name)
+    if amount > owed:
+        return err(f"{args.name} only owes {lending.format_cents(owed)}")
+    state["members"][args.name]["fines_cents"] = owed - amount
+    store.save(args.db, state)
+    return 0
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="cli.py", description="library lending")
+    parser.add_argument("--db", required=True, help="path to the JSON database")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add-book")
+    p.add_argument("isbn")
+    p.add_argument("--title", required=True)
+    p.add_argument("--copies", type=int, required=True)
+    p.set_defaults(func=cmd_add_book)
+
+    for name, func in (("checkout", cmd_checkout), ("return", cmd_return)):
+        p = sub.add_parser(name)
+        p.add_argument("isbn")
+        p.add_argument("--member", required=True)
+        p.add_argument("--date", required=True)
+        p.set_defaults(func=func)
+
+    p = sub.add_parser("hold")
+    p.add_argument("isbn")
+    p.add_argument("--member", required=True)
+    p.set_defaults(func=cmd_hold)
+
+    p = sub.add_parser("status")
+    p.add_argument("isbn")
+    p.set_defaults(func=cmd_status)
+
+    p = sub.add_parser("member")
+    p.add_argument("name")
+    p.set_defaults(func=cmd_member)
+
+    p = sub.add_parser("pay")
+    p.add_argument("name")
+    p.add_argument("--amount", required=True)
+    p.set_defaults(func=cmd_pay)
+
+    return parser
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
