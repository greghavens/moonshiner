+"""Pure loan and fine math. No file IO here: the kiosk imports this module."""
+from datetime import date, timedelta
+
+LOAN_DAYS = 14
+FINE_CENTS_PER_DAY = 25
+BLOCK_THRESHOLD_CENTS = 500  # $5.00 and up suspends checkout privileges
+
+
+def parse_date(s):
+    """Strict YYYY-MM-DD. Raises ValueError on anything else."""
+    return date.fromisoformat(s)
+
+
+def due_date(checkout_date):
+    """Loans run LOAN_DAYS days from the checkout date."""
+    return (parse_date(checkout_date) + timedelta(days=LOAN_DAYS)).isoformat()
+
+
+def late_fee_cents(due, returned):
+    """Fine owed for a return: FINE_CENTS_PER_DAY per full day late, 0 otherwise."""
+    days_late = (parse_date(returned) - parse_date(due)).days
+    return max(days_late, 0) * FINE_CENTS_PER_DAY
+
+
+def format_cents(cents):
+    """Integer cents -> '$X.XX'. Money never touches a float."""
+    return f"${cents // 100}.{cents % 100:02d}"
+
+
+def parse_amount_cents(s):
+    """Dollar string like '1.00', '0.75' or '3' -> integer cents.
+
+    Raises ValueError for negatives, extra dots, or non-digits.
+    """
+    parts = s.split(".")
+    if len(parts) == 1:
+        dollars, cents = parts[0], "0"
+    elif len(parts) == 2:
+        dollars, cents = parts
+    else:
+        raise ValueError(f"bad amount: {s!r}")
+    if not dollars.isdigit() or not cents.isdigit() or len(cents) > 2:
+        raise ValueError(f"bad amount: {s!r}")
+    return int(dollars) * 100 + int(cents.ljust(2, "0"))
