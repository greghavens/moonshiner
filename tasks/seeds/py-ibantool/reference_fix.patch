+"""IBAN validation, formatting and check-digit computation.
+
+Country registry is data-driven: length is the full IBAN length (CCkk
+prefix included), structure is a list of (count, kind) pieces over the
+BBAN, kind being 'n' (digits), 'a' (letters) or 'c' (letters or digits).
+"""
+import string
+
+
+class IBANError(ValueError):
+    """Raised for any IBAN that fails validation."""
+
+
+# (full length, BBAN structure)
+COUNTRIES = {
+    "AT": (20, [(16, "n")]),
+    "BE": (16, [(12, "n")]),
+    "CH": (21, [(5, "n"), (12, "c")]),
+    "DE": (22, [(18, "n")]),
+    "ES": (24, [(20, "n")]),
+    "FR": (27, [(10, "n"), (11, "c"), (2, "n")]),
+    "GB": (22, [(4, "a"), (14, "n")]),
+    "IT": (27, [(1, "a"), (10, "n"), (12, "c")]),
+    "NL": (18, [(4, "a"), (10, "n")]),
+    "PL": (28, [(24, "n")]),
+}
+
+_KIND_SETS = {
+    "n": set(string.digits),
+    "a": set(string.ascii_uppercase),
+    "c": set(string.digits + string.ascii_uppercase),
+}
+_ALNUM = _KIND_SETS["c"]
+
+
+def _clean(s):
+    """Strip separators, uppercase, and refuse anything non-alphanumeric."""
+    out = []
+    for ch in s.upper():
+        if ch in (" ", "-"):
+            continue
+        if ch not in _ALNUM:
+            raise IBANError(f"invalid character {ch!r} in IBAN")
+        out.append(ch)
+    return "".join(out)
+
+
+def _check_structure(country, bban):
+    pos = 0
+    for count, kind in COUNTRIES[country][1]:
+        allowed = _KIND_SETS[kind]
+        for ch in bban[pos:pos + count]:
+            if ch not in allowed:
+                raise IBANError(
+                    f"BBAN does not match the {country} structure "
+                    f"(bad character {ch!r} at position {pos + 4})")
+        pos += count
+
+
+def _mod97(s):
+    total = 0
+    for ch in s:
+        v = int(ch, 36)
+        total = (total * (10 if v < 10 else 100) + v) % 97
+    return total
+
+
+def validate(s):
+    """Return the canonical electronic form of s, or raise IBANError."""
+    iban = _clean(s)
+    if len(iban) < 4:
+        raise IBANError(f"IBAN {iban!r} is too short")
+    country = iban[:2]
+    if not country.isalpha():
+        raise IBANError(f"IBAN must start with a two-letter country code, got {country!r}")
+    if country not in COUNTRIES:
+        raise IBANError(f"unsupported country code {country}")
+    if not iban[2:4].isdigit():
+        raise IBANError(f"check digits must be numeric, got {iban[2:4]!r}")
+    expected_len = COUNTRIES[country][0]
+    if len(iban) != expected_len:
+        raise IBANError(
+            f"wrong length for {country}: expected {expected_len} characters, got {len(iban)}")
+    _check_structure(country, iban[4:])
+    if _mod97(iban[4:] + iban[:4]) != 1:
+        raise IBANError(f"checksum failure: IBAN {iban} fails the mod-97 check")
+    return iban
+
+
+def is_valid(s):
+    """True when s is a valid supported IBAN; never raises."""
+    try:
+        validate(s)
+        return True
+    except IBANError:
+        return False
+
+
+def format_electronic(s):
+    """Canonical compact form: uppercase, no separators."""
+    return validate(s)
+
+
+def format_paper(s):
+    """Paper form: groups of four separated by single spaces."""
+    iban = validate(s)
+    return " ".join(iban[i:i + 4] for i in range(0, len(iban), 4))
+
+
+def bban(s):
+    """The country-specific part after the CCkk prefix."""
+    return validate(s)[4:]
+
+
+def with_check_digits(country, bban):
+    """Build a full IBAN for country + BBAN with computed check digits."""
+    country = _clean(country)
+    bban = _clean(bban)
+    if len(country) != 2 or not country.isalpha() or country not in COUNTRIES:
+        raise IBANError(f"unsupported country code {country}")
+    expected_len = COUNTRIES[country][0]
+    if len(bban) != expected_len - 4:
+        raise IBANError(
+            f"wrong BBAN length for {country}: expected {expected_len - 4} characters, "
+            f"got {len(bban)}")
+    _check_structure(country, bban)
+    check = 98 - _mod97(bban + country + "00")
+    return f"{country}{check:02d}{bban}"
+
+
+def validate_batch(items):
+    """Validate each item; per-item result dicts, order preserved."""
+    results = []
+    for item in items:
+        try:
+            results.append({"input": item, "ok": True, "iban": validate(item)})
+        except IBANError as e:
+            results.append({"input": item, "ok": False, "error": str(e)})
+    return results
