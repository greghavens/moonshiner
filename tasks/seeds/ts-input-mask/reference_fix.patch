+export interface MaskResult {
+  masked: string;
+  complete: boolean;
+  cursor: number;
+}
+
+type SlotKind = 'digit' | 'letter' | 'alnum';
+
+type Token =
+  | { type: 'literal'; ch: string }
+  | { type: 'slot'; kind: SlotKind };
+
+const SLOT_KINDS: Record<string, SlotKind> = {
+  '#': 'digit',
+  '9': 'digit',
+  A: 'letter',
+  '*': 'alnum',
+};
+
+function tokenize(mask: string): Token[] {
+  const tokens: Token[] = [];
+  for (let i = 0; i < mask.length; i++) {
+    const ch = mask[i];
+    if (ch === '\\' && i + 1 < mask.length) {
+      tokens.push({ type: 'literal', ch: mask[i + 1] });
+      i++;
+    } else if (SLOT_KINDS[ch] !== undefined) {
+      tokens.push({ type: 'slot', kind: SLOT_KINDS[ch] });
+    } else {
+      tokens.push({ type: 'literal', ch });
+    }
+  }
+  return tokens;
+}
+
+const isDigit = (ch: string) => ch >= '0' && ch <= '9';
+const isLetter = (ch: string) => ch.toLowerCase() !== ch.toUpperCase();
+
+function fits(kind: SlotKind, ch: string): boolean {
+  if (kind === 'digit') return isDigit(ch);
+  if (kind === 'letter') return isLetter(ch);
+  return isDigit(ch) || isLetter(ch);
+}
+
+function fill(kind: SlotKind, ch: string): string {
+  return kind === 'letter' ? ch.toUpperCase() : ch;
+}
+
+export function applyMask(raw: string, mask: string, cursor?: number): MaskResult {
+  const tokens = tokenize(mask);
+  const totalSlots = tokens.filter((t) => t.type === 'slot').length;
+  const cursorIn = cursor ?? raw.length;
+
+  let out = '';
+  let pending = ''; // literals reached but not yet committed to output
+  let ti = 0;
+  let filled = 0;
+  let cursorOut = 0;
+
+  for (let r = 0; r < raw.length; r++) {
+    const ch = raw[r];
+    while (ti < tokens.length) {
+      const t = tokens[ti];
+      if (t.type === 'literal') {
+        pending += t.ch;
+        ti++;
+        if (ch === t.ch) break; // raw char is this literal: swallow it
+        continue;
+      }
+      if (fits(t.kind, ch)) {
+        out += pending + fill(t.kind, ch);
+        pending = '';
+        ti++;
+        filled++;
+      }
+      break; // slot handled the char (or rejected it)
+    }
+    if (r < cursorIn) cursorOut = out.length;
+  }
+
+  return { masked: out, complete: filled === totalSlots, cursor: cursorOut };
+}
+
+export function unmask(masked: string, mask: string): string {
+  const tokens = tokenize(mask);
+  let out = '';
+  let mi = 0;
+
+  for (const t of tokens) {
+    if (mi >= masked.length) break;
+    const ch = masked[mi];
+    if (t.type === 'literal') {
+      if (ch !== t.ch) {
+        throw new Error(`unmask: expected literal '${t.ch}' at index ${mi}, got '${ch}'`);
+      }
+    } else {
+      if (!fits(t.kind, ch)) {
+        throw new Error(`unmask: invalid character '${ch}' for ${t.kind} slot at index ${mi}`);
+      }
+      out += ch;
+    }
+    mi++;
+  }
+
+  if (mi < masked.length) {
+    throw new Error(`unmask: text continues past the end of the mask at index ${mi}`);
+  }
+  return out;
+}
