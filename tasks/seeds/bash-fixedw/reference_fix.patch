diff --git a/table.sh b/table.sh
new file mode 100644
index 0000000..810d2f5
--- /dev/null
+++ b/table.sh
@@ -0,0 +1,133 @@
+#!/usr/bin/env bash
+# table.sh — render a simple no-quoting CSV as an aligned fixed-width table.
+#
+# Usage: table.sh <file.csv> [maxwidth]
+# The dialect is deliberately dumb: a comma is always a separator (no quoting,
+# no escaping), the first line is the header, ASCII with LF endings.
+# Exit codes: 0 ok, 64 usage error, 65 data error, 66 unreadable input.
+set -u
+
+usage_error() {
+  printf '%s\n' "$1" >&2
+  exit 64
+}
+
+[ $# -ge 1 ] || usage_error 'usage: table.sh <file.csv> [maxwidth]'
+file=$1
+maxw=${2-16}
+
+case $maxw in
+  ''|*[!0-9]*) usage_error 'table.sh: maxwidth must be an integer >= 5' ;;
+esac
+[ "$maxw" -ge 5 ] || usage_error 'table.sh: maxwidth must be an integer >= 5'
+
+if [ ! -f "$file" ] || [ ! -r "$file" ]; then
+  printf 'table.sh: cannot read: %s\n' "$file" >&2
+  exit 66
+fi
+
+mapfile -t lines < "$file"
+if [ "${#lines[@]}" -eq 0 ]; then
+  printf 'table.sh: empty input\n' >&2
+  exit 65
+fi
+
+split_row() { # split_row <line> -> CELLS array (N commas = N+1 fields)
+  CELLS=()
+  local rest=$1
+  while [[ $rest == *,* ]]; do
+    CELLS+=("${rest%%,*}")
+    rest=${rest#*,}
+  done
+  CELLS+=("$rest")
+}
+
+# ---- pass 1: validate field counts, measure widths, detect numeric columns --
+
+split_row "${lines[0]}"
+ncols=${#CELLS[@]}
+widths=()
+numeric=()
+for ((i = 0; i < ncols; i++)); do
+  widths[i]=${#CELLS[i]}
+  numeric[i]=1
+done
+
+nrows=${#lines[@]}
+for ((r = 1; r < nrows; r++)); do
+  split_row "${lines[r]}"
+  if [ "${#CELLS[@]}" -ne "$ncols" ]; then
+    printf 'table.sh: line %d: expected %d fields, got %d\n' \
+      "$((r + 1))" "$ncols" "${#CELLS[@]}" >&2
+    exit 65
+  fi
+  for ((i = 0; i < ncols; i++)); do
+    cell=${CELLS[i]}
+    if [ "${#cell}" -gt "${widths[i]}" ]; then
+      widths[i]=${#cell}
+    fi
+    [[ $cell =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || numeric[i]=0
+  done
+done
+
+# a column with no data rows is text
+if [ "$nrows" -eq 1 ]; then
+  for ((i = 0; i < ncols; i++)); do
+    numeric[i]=0
+  done
+fi
+
+for ((i = 0; i < ncols; i++)); do
+  if [ "${widths[i]}" -gt "$maxw" ]; then
+    widths[i]=$maxw
+  fi
+done
+
+# ---- pass 2: render ----------------------------------------------------------
+
+render_cell() { # render_cell <value> <width> <numeric> -> RENDERED
+  local v=$1 w=$2 num=$3 keep
+  if [ "${#v}" -gt "$w" ]; then
+    keep=$((w - 3))
+    v="${v:0:keep}..."
+  fi
+  if [ "$num" -eq 1 ]; then
+    printf -v RENDERED '%*s' "$w" "$v"
+  else
+    printf -v RENDERED '%-*s' "$w" "$v"
+  fi
+}
+
+emit_row() { # uses CELLS/widths/numeric; prints one right-stripped line
+  local out='' i
+  for ((i = 0; i < ncols; i++)); do
+    render_cell "${CELLS[i]}" "${widths[i]}" "${numeric[i]}"
+    if [ "$i" -gt 0 ]; then
+      out+=' | '
+    fi
+    out+=$RENDERED
+  done
+  while [[ $out == *' ' ]]; do
+    out=${out%' '}
+  done
+  printf '%s\n' "$out"
+}
+
+split_row "${lines[0]}"
+emit_row
+
+sep=''
+for ((i = 0; i < ncols; i++)); do
+  printf -v dashes '%*s' "${widths[i]}" ''
+  dashes=${dashes// /-}
+  if [ "$i" -gt 0 ]; then
+    sep+='-+-'
+  fi
+  sep+=$dashes
+done
+printf '%s\n' "$sep"
+
+for ((r = 1; r < nrows; r++)); do
+  split_row "${lines[r]}"
+  emit_row
+done
