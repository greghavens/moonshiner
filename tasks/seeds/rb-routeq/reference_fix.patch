index 0000000..c210e14
--- /dev/null
+++ b/route_query.rb
@@ -0,0 +1,64 @@
+# Chainable, lazy, immutable query object over an array of route hashes.
+class RouteQuery
+  def initialize(rows, filters: [], orders: [])
+    @rows = rows
+    @filters = filters
+    @orders = orders
+  end
+
+  def where(conditions = nil, &block)
+    if conditions && block
+      raise ArgumentError, "where takes a filter hash or a block, not both"
+    end
+    if conditions.nil? && block.nil?
+      raise ArgumentError, "where needs a filter hash or a block"
+    end
+    filter = block || ->(row) { conditions.all? { |key, want| row.key?(key) && row[key] == want } }
+    chain(filters: @filters + [filter])
+  end
+
+  def order(key, direction = :asc)
+    unless %i[asc desc].include?(direction)
+      raise ArgumentError, "direction must be :asc or :desc, got #{direction.inspect}"
+    end
+    chain(orders: @orders + [[key, direction]])
+  end
+
+  def to_a
+    evaluate
+  end
+
+  def count
+    evaluate.length
+  end
+
+  def pluck(*keys)
+    rows = evaluate
+    keys.length == 1 ? rows.map { |r| r[keys.first] } : rows.map { |r| keys.map { |k| r[k] } }
+  end
+
+  private
+
+  def chain(filters: @filters, orders: @orders)
+    RouteQuery.new(@rows, filters: filters, orders: orders)
+  end
+
+  def evaluate
+    rows = @rows.select { |row| @filters.all? { |f| f.call(row) } }
+    return rows if @orders.empty?
+    # Stable multi-key sort: pair each row with its index so ties keep
+    # the order they had coming in.
+    rows.each_with_index.sort do |(a, ai), (b, bi)|
+      verdict = 0
+      @orders.each do |key, direction|
+        cmp = a[key] <=> b[key]
+        cmp = -cmp if direction == :desc
+        if cmp != 0
+          verdict = cmp
+          break
+        end
+      end
+      verdict.zero? ? ai <=> bi : verdict
+    end.map(&:first)
+  end
+end
