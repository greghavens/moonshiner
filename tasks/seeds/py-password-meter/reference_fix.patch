+
+
+# --------------------------------------------------------------- entropy
+
+POOL_SIZES = {"lower": 26, "upper": 26, "digit": 10, "symbol": 32}
+
+KEYBOARD_ROWS = ["qwertyuiop", "asdfghjkl", "zxcvbnm"]
+
+PATTERN_ORDER = ["sequence", "repeat", "keyboard", "year"]
+
+PENALTY_BITS = 10
+
+PATTERN_ADVICE = {
+    "sequence": "avoid sequences like 'abcd' or '1234'",
+    "repeat": "avoid repeating the same character",
+    "keyboard": "avoid keyboard runs like 'qwerty'",
+    "year": "don't end the password with a year",
+}
+
+
+def entropy_bits(password):
+    """Search-space size in bits: length * log2(pool of classes present)."""
+    if not password:
+        return 0.0
+    pool = sum(POOL_SIZES[c] for c in char_classes(password))
+    return round(len(password) * math.log2(pool), 1)
+
+
+def _has_sequence(low):
+    """4+ consecutive ascending or descending chars, alphabetic or numeric."""
+    for i in range(len(low) - 3):
+        window = low[i:i + 4]
+        if not (window.isalpha() or window.isdigit()):
+            continue
+        steps = {ord(b) - ord(a) for a, b in zip(window, window[1:])}
+        if steps == {1} or steps == {-1}:
+            return True
+    return False
+
+
+def _has_repeat(low):
+    """The same character three or more times in a row."""
+    return any(low[i] == low[i + 1] == low[i + 2] for i in range(len(low) - 2))
+
+
+def _has_keyboard_run(low):
+    """4+ characters straight off one keyboard row, forward or reversed."""
+    for i in range(len(low) - 3):
+        window = low[i:i + 4]
+        for row in KEYBOARD_ROWS:
+            if window in row or window in row[::-1]:
+                return True
+    return False
+
+
+def _has_year_suffix(password):
+    """Ends with a plausible year: 19xx or 20xx."""
+    tail = password[-4:]
+    return len(tail) == 4 and tail.isdigit() and tail[:2] in ("19", "20")
+
+
+def find_patterns(password):
+    """Names of the cracker shortcuts found, in canonical order."""
+    low = password.lower()
+    found = {
+        "sequence": _has_sequence(low),
+        "repeat": _has_repeat(low),
+        "keyboard": _has_keyboard_run(low),
+        "year": _has_year_suffix(password),
+    }
+    return [name for name in PATTERN_ORDER if found[name]]
+
+
+def effective_bits(password):
+    """Entropy after docking PENALTY_BITS per pattern type, floored at 0."""
+    raw = entropy_bits(password) - PENALTY_BITS * len(find_patterns(password))
+    return round(max(0.0, raw), 1)
+
+
+def entropy_score(password):
+    """Map effective bits onto the meter's 0-4 scale."""
+    bits = effective_bits(password)
+    for grade, ceiling in enumerate((28, 36, 60, 128)):
+        if bits < ceiling:
+            return grade
+    return 4
+
+
+def suggest(password):
+    """Actionable fixes, most fundamental first, empty when nothing applies."""
+    tips = []
+    if len(password) < 12:
+        tips.append("use at least 12 characters")
+    classes = char_classes(password)
+    for cls, tip in (("upper", "add uppercase letters"),
+                     ("lower", "add lowercase letters"),
+                     ("digit", "add digits"),
+                     ("symbol", "add symbols")):
+        if cls not in classes:
+            tips.append(tip)
+    for name in find_patterns(password):
+        tips.append(PATTERN_ADVICE[name])
+    return tips
+
+
+def evaluate(password):
+    """The full report the /password-check endpoint returns."""
+    grade = entropy_score(password)
+    return {
+        "bits": effective_bits(password),
+        "score": grade,
+        "verdict": VERDICTS[grade],
+        "patterns": find_patterns(password),
+        "suggestions": suggest(password),
+    }
