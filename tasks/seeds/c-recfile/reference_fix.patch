diff --git a/recfile.c b/recfile.c
new file mode 100644
index 0000000..9b06ac1
--- /dev/null
+++ b/recfile.c
@@ -0,0 +1,111 @@
+#include "recfile.h"
+
+#include <string.h>
+
+#define RF_HDR 8u /* bytes before the first record */
+#define RF_REC 11u
+#define RF_CRC 2u /* trailer */
+
+/* --- byte helpers ----------------------------------------------------- */
+
+static void put_u16(uint8_t *p, uint16_t v) {
+    p[0] = (uint8_t)(v & 0xFF);
+    p[1] = (uint8_t)(v >> 8);
+}
+
+static void put_u32(uint8_t *p, uint32_t v) {
+    p[0] = (uint8_t)(v & 0xFF);
+    p[1] = (uint8_t)((v >> 8) & 0xFF);
+    p[2] = (uint8_t)((v >> 16) & 0xFF);
+    p[3] = (uint8_t)(v >> 24);
+}
+
+static uint16_t get_u16(const uint8_t *p) {
+    return (uint16_t)(p[0] | ((uint16_t)p[1] << 8));
+}
+
+static uint32_t get_u32(const uint8_t *p) {
+    return (uint32_t)p[0] | ((uint32_t)p[1] << 8) | ((uint32_t)p[2] << 16) |
+           ((uint32_t)p[3] << 24);
+}
+
+/* --- public API -------------------------------------------------------- */
+
+size_t rf_size(size_t n) {
+    return RF_HDR + RF_REC * n + RF_CRC;
+}
+
+uint16_t rf_crc16(const void *data, size_t len) {
+    const uint8_t *p = data;
+    uint16_t crc = 0xFFFF;
+    for (size_t i = 0; i < len; i++) {
+        crc ^= (uint16_t)((uint16_t)p[i] << 8);
+        for (int b = 0; b < 8; b++) {
+            if (crc & 0x8000u)
+                crc = (uint16_t)((uint16_t)(crc << 1) ^ 0x1021u);
+            else
+                crc = (uint16_t)(crc << 1);
+        }
+    }
+    return crc;
+}
+
+long rf_encode(const rf_reading *recs, size_t n, void *out, size_t cap) {
+    if (out == NULL || (recs == NULL && n > 0))
+        return RF_EARG;
+    if (n > RF_MAX_RECORDS || cap < rf_size(n))
+        return RF_EARG;
+
+    uint8_t *p = out;
+    p[0] = 'S';
+    p[1] = 'R';
+    p[2] = '1';
+    p[3] = '\0';
+    p[4] = 1;
+    p[5] = 0;
+    put_u16(p + 6, (uint16_t)n);
+
+    uint8_t *r = p + RF_HDR;
+    for (size_t i = 0; i < n; i++) {
+        put_u16(r, recs[i].sensor);
+        put_u32(r + 2, recs[i].at);
+        put_u32(r + 6, (uint32_t)recs[i].value);
+        r[10] = recs[i].flags;
+        r += RF_REC;
+    }
+
+    size_t body = rf_size(n) - 2;
+    put_u16(p + body, rf_crc16(p, body));
+    return (long)rf_size(n);
+}
+
+long rf_decode(const void *buf, size_t len, rf_reading *out, size_t max) {
+    if (buf == NULL)
+        return RF_EARG;
+    if (len < rf_size(0))
+        return RF_ETRUNC;
+
+    const uint8_t *p = buf;
+    if (p[0] != 'S' || p[1] != 'R' || p[2] != '1' || p[3] != '\0')
+        return RF_EMAGIC;
+    if (p[4] != 1)
+        return RF_EVERSION;
+
+    size_t count = get_u16(p + 6);
+    if (len != rf_size(count))
+        return RF_ETRUNC;
+    if (rf_crc16(p, len - 2) != get_u16(p + len - 2))
+        return RF_ECRC;
+    if (count > max || (out == NULL && count > 0))
+        return RF_EARG;
+
+    const uint8_t *r = p + RF_HDR;
+    for (size_t i = 0; i < count; i++) {
+        out[i].sensor = get_u16(r);
+        out[i].at = get_u32(r + 2);
+        out[i].value = (int32_t)get_u32(r + 6);
+        out[i].flags = r[10];
+        r += RF_REC;
+    }
+    return (long)count;
+}
diff --git a/recfile.h b/recfile.h
new file mode 100644
index 0000000..76272e1
--- /dev/null
+++ b/recfile.h
@@ -0,0 +1,52 @@
+/* recfile.h — capture-blob codec for batched sensor readings.
+ *
+ * Wire format (little-endian, independent of host):
+ *
+ *   offset 0..3   magic 'S' 'R' '1' '\0'
+ *   offset 4      version (1)
+ *   offset 5      reserved, written 0, ignored on read
+ *   offset 6..7   record count, u16 LE
+ *   ...           count records, 11 bytes each:
+ *                 u16 LE sensor | u32 LE at | i32 LE value | u8 flags
+ *   last 2 bytes  CRC-16/CCITT-FALSE over everything before them, LE
+ */
+#ifndef RECFILE_H
+#define RECFILE_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+typedef struct {
+    uint16_t sensor;   /* channel id */
+    uint32_t at;       /* seconds since gateway boot */
+    int32_t  value;    /* reading in centi-units, may be negative */
+    uint8_t  flags;    /* bit0 = calibrated, rest reserved */
+} rf_reading;
+
+enum {
+    RF_OK       = 0,
+    RF_EARG     = -1,   /* bad pointers/capacities/counts */
+    RF_ETRUNC   = -2,   /* buffer length does not fit the format */
+    RF_EMAGIC   = -3,
+    RF_EVERSION = -4,
+    RF_ECRC     = -5
+};
+
+#define RF_MAX_RECORDS 4096
+
+/* Encoded byte length of a blob holding n records: 10 + 11*n. */
+size_t rf_size(size_t n);
+
+/* CRC-16/CCITT-FALSE: poly 0x1021, init 0xFFFF, no reflection, no
+ * final xor, MSB first. len 0 returns 0xFFFF. */
+uint16_t rf_crc16(const void *data, size_t len);
+
+/* Write the full blob (header, records, CRC) into out. Returns bytes
+ * written, or RF_EARG. Nothing is written on error. */
+long rf_encode(const rf_reading *recs, size_t n, void *out, size_t cap);
+
+/* Strictly validate buf and unpack its records into out. Returns the
+ * record count, or a negative RF_* code. */
+long rf_decode(const void *buf, size_t len, rf_reading *out, size_t max);
+
+#endif /* RECFILE_H */
