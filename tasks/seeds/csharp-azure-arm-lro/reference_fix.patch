@@ -0,0 +1,25 @@
+using System.Text.Json;
+
+namespace ArmLro;
+
+public sealed class ArmError
+{
+    public string Code { get; init; } = "";
+    public string Message { get; init; } = "";
+}
+
+public sealed class ArmOperationResult
+{
+    public bool Succeeded { get; init; }
+    public string Status { get; init; } = "";
+    public JsonElement? Resource { get; init; }
+    public ArmError? Error { get; init; }
+}
+
+public sealed class ArmLroClientOptions
+{
+    public int MaxPolls { get; set; } = 20;
+    public TimeSpan DefaultPollDelay { get; set; } = TimeSpan.FromSeconds(5);
+    public Func<TimeSpan, CancellationToken, Task> Delay { get; set; } =
+        (wait, ct) => Task.Delay(wait, ct);
+}
