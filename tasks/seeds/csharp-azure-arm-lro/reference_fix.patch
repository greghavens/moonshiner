@@ -0,0 +1,93 @@
+using System.Text.Json;
+
+namespace ArmLro;
+
+/// <summary>
+/// Acquires and caches app-only bearer tokens via the OAuth 2.0 client-credentials
+/// flow (POST {tenant}/oauth2/v2.0/token, application/x-www-form-urlencoded).
+/// </summary>
+public sealed class EntraTokenProvider
+{
+    private readonly HttpClient _http;
+    private readonly Uri _tokenEndpoint;
+    private readonly string _clientId;
+    private readonly string _clientSecret;
+    private readonly string _scope;
+    private readonly Func<DateTimeOffset> _now;
+    private readonly SemaphoreSlim _gate = new(1, 1);
+
+    private string? _cachedToken;
+    private DateTimeOffset _expiresAt = DateTimeOffset.MinValue;
+
+    public EntraTokenProvider(
+        HttpClient http,
+        Uri tokenEndpoint,
+        string clientId,
+        string clientSecret,
+        string scope,
+        Func<DateTimeOffset> now)
+    {
+        _http = http;
+        _tokenEndpoint = tokenEndpoint;
+        _clientId = clientId;
+        _clientSecret = clientSecret;
+        _scope = scope;
+        _now = now;
+    }
+
+    public async Task<string> GetTokenAsync(CancellationToken ct = default)
+    {
+        await _gate.WaitAsync(ct);
+        try
+        {
+            if (_cachedToken is not null && _now() < _expiresAt)
+            {
+                return _cachedToken;
+            }
+
+            using var content = new FormUrlEncodedContent(new Dictionary<string, string>
+            {
+                ["grant_type"] = "client_credentials",
+                ["client_id"] = _clientId,
+                ["client_secret"] = _clientSecret,
+                ["scope"] = _scope,
+            });
+            using var response = await _http.PostAsync(_tokenEndpoint, content, ct);
+            var body = await response.Content.ReadAsStringAsync(ct);
+
+            if (!response.IsSuccessStatusCode)
+            {
+                // Surface only the OAuth error code: error_description may echo request
+                // parameters and must never travel with the secret into logs.
+                var code = "unknown_error";
+                try
+                {
+                    using var doc = JsonDocument.Parse(body);
+                    if (doc.RootElement.TryGetProperty("error", out var errorProp))
+                    {
+                        code = errorProp.GetString() ?? code;
+                    }
+                }
+                catch (JsonException)
+                {
+                }
+                throw new ArmAuthException(
+                    $"token request failed with status {(int)response.StatusCode}: {code}");
+            }
+
+            using var okDoc = JsonDocument.Parse(body);
+            var root = okDoc.RootElement;
+            var token = root.GetProperty("access_token").GetString()
+                ?? throw new ArmAuthException("token response had no access_token");
+            var expiresIn = root.GetProperty("expires_in").GetInt32();
+
+            _cachedToken = token;
+            _expiresAt = _now().AddSeconds(expiresIn);
+            return token;
+        }
+        finally
+        {
+            _gate.Release();
+        }
+    }
+}
diff --git a/Exceptions.cs b/Exceptions.cs
new file mode 100644
index 0000000..fd0b71c
--- /dev/null
+++ b/Exceptions.cs
@@ -0,0 +1,30 @@
+using System.Net;
+
+namespace ArmLro;
+
+/// <summary>Token acquisition against the Microsoft Entra endpoint failed.</summary>
+public sealed class ArmAuthException : Exception
+{
+    public ArmAuthException(string message) : base(message) { }
+}
+
+/// <summary>The service violated the documented async-operation protocol,
+/// or the poll budget ran out before a terminal state.</summary>
+public sealed class ArmProtocolException : Exception
+{
+    public ArmProtocolException(string message) : base(message) { }
+}
+
+/// <summary>ARM rejected a request outright (non-LRO error response).</summary>
+public sealed class ArmRequestException : Exception
+{
+    public HttpStatusCode StatusCode { get; }
+    public ArmError? Error { get; }
+
+    public ArmRequestException(HttpStatusCode statusCode, ArmError? error)
+        : base($"ARM request failed with {(int)statusCode}: {error?.Code ?? "no error body"}")
+    {
+        StatusCode = statusCode;
+        Error = error;
+    }
+}
