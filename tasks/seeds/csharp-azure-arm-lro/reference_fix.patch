+using System.Net;
+using System.Net.Http.Headers;
+using System.Text;
+using System.Text.Json;
+
+namespace ArmLro;
+
+/// <summary>
+/// Drives an ARM create-or-update through the documented asynchronous-operation
+/// protocol: monitor-header precedence Azure-AsyncOperation, then
+/// Operation-Location, then Location; Retry-After between polls; terminal states
+/// Succeeded/Failed/Canceled (case-insensitive).
+/// </summary>
+public sealed class ArmLroClient
+{
+    private static readonly string[] MonitorHeaderPrecedence =
+    {
+        "Azure-AsyncOperation",
+        "Operation-Location",
+        "Location",
+    };
+
+    private readonly HttpClient _http;
+    private readonly EntraTokenProvider _tokens;
+    private readonly ArmLroClientOptions _options;
+
+    public ArmLroClient(HttpClient http, EntraTokenProvider tokens, ArmLroClientOptions options)
+    {
+        _http = http;
+        _tokens = tokens;
+        _options = options;
+    }
+
+    public async Task<ArmOperationResult> CreateOrUpdateAsync(
+        string resourcePath, string apiVersion, string requestBodyJson, CancellationToken ct = default)
+    {
+        var resourceUri = BuildResourceUri(resourcePath, apiVersion);
+        using var request = new HttpRequestMessage(HttpMethod.Put, resourceUri)
+        {
+            Content = new StringContent(requestBodyJson, Encoding.UTF8, "application/json"),
+        };
+        request.Headers.Authorization = await BearerAsync(ct);
+        using var response = await _http.SendAsync(request, ct);
+        var body = await response.Content.ReadAsStringAsync(ct);
+
+        if (response.StatusCode is HttpStatusCode.OK)
+        {
+            return CompletedResult(body);
+        }
+
+        if (response.StatusCode is HttpStatusCode.Created or HttpStatusCode.Accepted)
+        {
+            var (monitorHeader, monitorUrl) = FindMonitor(response);
+            if (monitorUrl is null)
+            {
+                if (response.StatusCode == HttpStatusCode.Created)
+                {
+                    // 201 with no monitor header: the operation completed synchronously.
+                    return CompletedResult(body);
+                }
+                throw new ArmProtocolException(
+                    "202 Accepted carried no Azure-AsyncOperation, Operation-Location, or Location header");
+            }
+            return await PollAsync(monitorHeader!, monitorUrl, resourceUri, RetryAfter(response), ct);
+        }
+
+        throw new ArmRequestException(response.StatusCode, ParseArmError(body));
+    }
+
+    private async Task<ArmOperationResult> PollAsync(
+        string monitorHeader, Uri monitorUrl, Uri resourceUri, TimeSpan? initialWait, CancellationToken ct)
+    {
+        var locationStyle = string.Equals(monitorHeader, "Location", StringComparison.OrdinalIgnoreCase);
+        var wait = initialWait ?? _options.DefaultPollDelay;
+
+        for (var poll = 0; poll < _options.MaxPolls; poll++)
+        {
+            await _options.Delay(wait, ct);
+
+            using var request = new HttpRequestMessage(HttpMethod.Get, monitorUrl);
+            request.Headers.Authorization = await BearerAsync(ct);
+            using var response = await _http.SendAsync(request, ct);
+            var body = await response.Content.ReadAsStringAsync(ct);
+            wait = RetryAfter(response) ?? _options.DefaultPollDelay;
+
+            if (locationStyle)
+            {
+                // A Location monitor answers 202 while running and 200 with the final body when done.
+                if (response.StatusCode == HttpStatusCode.Accepted)
+                {
+                    continue;
+                }
+                if (response.StatusCode == HttpStatusCode.OK)
+                {
+                    return CompletedResult(body);
+                }
+                throw new ArmRequestException(response.StatusCode, ParseArmError(body));
+            }
+
+            // Azure-AsyncOperation / Operation-Location monitors answer 200 with a status document.
+            if (!response.IsSuccessStatusCode)
+            {
+                throw new ArmRequestException(response.StatusCode, ParseArmError(body));
+            }
+            var (status, error) = ParseStatusDocument(body);
+            if (Terminal(status, "Succeeded"))
+            {
+                using var finalRequest = new HttpRequestMessage(HttpMethod.Get, resourceUri);
+                finalRequest.Headers.Authorization = await BearerAsync(ct);
+                using var finalResponse = await _http.SendAsync(finalRequest, ct);
+                var finalBody = await finalResponse.Content.ReadAsStringAsync(ct);
+                if (!finalResponse.IsSuccessStatusCode)
+                {
+                    throw new ArmRequestException(finalResponse.StatusCode, ParseArmError(finalBody));
+                }
+                return new ArmOperationResult
+                {
+                    Succeeded = true,
+                    Status = status,
+                    Resource = ParseJson(finalBody),
+                };
+            }
+            if (Terminal(status, "Failed") || Terminal(status, "Canceled"))
+            {
+                return new ArmOperationResult
+                {
+                    Succeeded = false,
+                    Status = status,
+                    Error = error,
+                };
+            }
+        }
+
+        throw new ArmProtocolException(
+            $"operation did not reach a terminal state within {_options.MaxPolls} polls");
+    }
+
+    private Uri BuildResourceUri(string resourcePath, string apiVersion)
+    {
+        var baseAddress = _http.BaseAddress
+            ?? throw new ArmProtocolException("HttpClient.BaseAddress must be set to the ARM endpoint");
+        return new Uri(baseAddress, $"{resourcePath}?api-version={Uri.EscapeDataString(apiVersion)}");
+    }
+
+    private async Task<AuthenticationHeaderValue> BearerAsync(CancellationToken ct)
+        => new("Bearer", await _tokens.GetTokenAsync(ct));
+
+    private (string? Header, Uri? Url) FindMonitor(HttpResponseMessage response)
+    {
+        foreach (var header in MonitorHeaderPrecedence)
+        {
+            if (response.Headers.TryGetValues(header, out var values))
+            {
+                var raw = values.FirstOrDefault();
+                if (string.IsNullOrEmpty(raw))
+                {
+                    continue;
+                }
+                var url = new Uri(raw, UriKind.Absolute);
+                RequireArmHost(header, url);
+                return (header, url);
+            }
+        }
+        return (null, null);
+    }
+
+    private void RequireArmHost(string header, Uri monitorUrl)
+    {
+        var expectedHost = _http.BaseAddress?.Host;
+        if (!string.Equals(monitorUrl.Host, expectedHost, StringComparison.OrdinalIgnoreCase))
+        {
+            throw new ArmProtocolException(
+                $"{header} monitor points at untrusted host {monitorUrl.Host}; refusing to send credentials off {expectedHost}");
+        }
+    }
+
+    private static TimeSpan? RetryAfter(HttpResponseMessage response)
+    {
+        var delta = response.Headers.RetryAfter?.Delta;
+        return delta is null ? null : delta.Value;
+    }
+
+    private static ArmOperationResult CompletedResult(string body)
+        => new()
+        {
+            Succeeded = true,
+            Status = "Succeeded",
+            Resource = ParseJson(body),
+        };
+
+    private static (string Status, ArmError? Error) ParseStatusDocument(string body)
+    {
+        JsonDocument doc;
+        try
+        {
+            doc = JsonDocument.Parse(body);
+        }
+        catch (JsonException)
+        {
+            throw new ArmProtocolException("status monitor returned a non-JSON body");
+        }
+        using (doc)
+        {
+            if (!doc.RootElement.TryGetProperty("status", out var statusProp)
+                || statusProp.ValueKind != JsonValueKind.String)
+            {
+                throw new ArmProtocolException("status monitor body is missing the required status property");
+            }
+            ArmError? error = null;
+            if (doc.RootElement.TryGetProperty("error", out var errorProp)
+                && errorProp.ValueKind == JsonValueKind.Object)
+            {
+                error = ReadError(errorProp);
+            }
+            return (statusProp.GetString()!, error);
+        }
+    }
+
+    private static ArmError? ParseArmError(string body)
+    {
+        try
+        {
+            using var doc = JsonDocument.Parse(body);
+            if (doc.RootElement.TryGetProperty("error", out var errorProp)
+                && errorProp.ValueKind == JsonValueKind.Object)
+            {
+                return ReadError(errorProp);
+            }
+        }
+        catch (JsonException)
+        {
+        }
+        return null;
+    }
+
+    private static ArmError ReadError(JsonElement errorProp)
+        => new()
+        {
+            Code = errorProp.TryGetProperty("code", out var code) ? code.GetString() ?? "" : "",
+            Message = errorProp.TryGetProperty("message", out var message) ? message.GetString() ?? "" : "",
+        };
+
+    private static JsonElement? ParseJson(string body)
+    {
+        if (string.IsNullOrWhiteSpace(body))
+        {
+            return null;
+        }
+        using var doc = JsonDocument.Parse(body);
+        return doc.RootElement.Clone();
+    }
+
+    private static bool Terminal(string status, string expected)
+        => string.Equals(status, expected, StringComparison.OrdinalIgnoreCase);
+}
