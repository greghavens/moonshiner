diff --git a/lcgdeal.s b/lcgdeal.s
new file mode 100644
index 0000000..2746882
--- /dev/null
+++ b/lcgdeal.s
@@ -0,0 +1,64 @@
+# Pinned 31-bit LCG (state' = state*1103515245 + 12345 mod 2^31) and the
+# Fisher-Yates deck deal built on it. System V AMD64, 32-bit arithmetic.
+	.text
+
+	.globl	lcg_next
+	.type	lcg_next, @function
+# uint32_t lcg_next(uint32_t *state)   rdi=state
+lcg_next:
+	movl	(%rdi), %eax
+	imull	$1103515245, %eax, %eax
+	addl	$12345, %eax
+	andl	$0x7fffffff, %eax
+	movl	%eax, (%rdi)
+	ret
+	.size	lcg_next, .-lcg_next
+
+	.globl	lcg_rand
+	.type	lcg_rand, @function
+# uint32_t lcg_rand(uint32_t *state, uint32_t bound)   rdi=state, esi=bound
+lcg_rand:
+	movl	(%rdi), %eax
+	imull	$1103515245, %eax, %eax
+	addl	$12345, %eax
+	andl	$0x7fffffff, %eax
+	movl	%eax, (%rdi)
+	shrl	$16, %eax
+	xorl	%edx, %edx
+	divl	%esi
+	movl	%edx, %eax
+	ret
+	.size	lcg_rand, .-lcg_rand
+
+	.globl	lcg_deal
+	.type	lcg_deal, @function
+# void lcg_deal(uint32_t seed, unsigned char *deck)   edi=seed, rsi=deck
+lcg_deal:
+	xorl	%ecx, %ecx		# deck[i] = i for i in 0..51
+.Linit:
+	movb	%cl, (%rsi,%rcx)
+	incl	%ecx
+	cmpl	$52, %ecx
+	jl	.Linit
+	andl	$0x7fffffff, %edi	# state = seed mod 2^31
+	movl	$51, %ecx		# i counts 51 down to 1
+.Lshuffle:
+	imull	$1103515245, %edi, %edi	# one draw of the pinned LCG
+	addl	$12345, %edi
+	andl	$0x7fffffff, %edi
+	movl	%edi, %eax
+	shrl	$16, %eax
+	xorl	%edx, %edx
+	leal	1(%rcx), %r8d
+	divl	%r8d			# j = (state >> 16) % (i+1) in edx
+	movl	%edx, %r9d
+	movzbl	(%rsi,%rcx), %eax	# swap deck[i], deck[j]
+	movzbl	(%rsi,%r9), %edx
+	movb	%dl, (%rsi,%rcx)
+	movb	%al, (%rsi,%r9)
+	decq	%rcx
+	jg	.Lshuffle
+	ret
+	.size	lcg_deal, .-lcg_deal
+
+	.section .note.GNU-stack,"",@progbits
