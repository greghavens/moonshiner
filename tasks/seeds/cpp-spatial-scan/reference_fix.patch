+constexpr std::size_t kSmallScanLimit = 32;
+
+double measure_pair(
+    std::span<const Point> points,
+    std::size_t first,
+    std::size_t second,
+    ScanStats* stats) {
+    if (stats != nullptr) {
+        ++stats->distance_comparisons;
+    }
+    return std::hypot(
+        points[first].x - points[second].x,
+        points[first].y - points[second].y);
+}
+
+std::vector<Proximity> quadratic_scan(
+    std::span<const Point> points,
+    double max_distance,
+    ScanStats* stats) {
+    std::vector<Proximity> matches;
+    for (std::size_t first = 0; first < points.size(); ++first) {
+        for (std::size_t second = first + 1; second < points.size(); ++second) {
+            const double distance = measure_pair(points, first, second, stats);
+            if (distance <= max_distance) {
+                matches.push_back(Proximity{first, second, distance});
+            }
+        }
+    }
+    return matches;
+}
+
