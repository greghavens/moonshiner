+
+/** All case-insensitive occurrences of all terms, merged (overlapping or
+ *  exactly adjacent ranges collapse) and sorted by position. */
+export function findMatches(text: string, terms: string[]): MatchRange[] {
+  const haystack = text.toLowerCase();
+  const raw: MatchRange[] = [];
+  for (const term of new Set(terms)) {
+    if (term === '') continue;
+    const needle = term.toLowerCase();
+    let from = 0;
+    while (true) {
+      const index = haystack.indexOf(needle, from);
+      if (index === -1) break;
+      raw.push({ start: index, end: index + needle.length });
+      from = index + 1;
+    }
+  }
+  raw.sort((a, b) => a.start - b.start || a.end - b.end);
+
+  const merged: MatchRange[] = [];
+  for (const range of raw) {
+    const last = merged[merged.length - 1];
+    if (last && range.start <= last.end) {
+      last.end = Math.max(last.end, range.end);
+    } else {
+      merged.push({ ...range });
+    }
+  }
+  return merged;
+}
