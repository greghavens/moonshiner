diff --git a/yahtzee.sh b/yahtzee.sh
new file mode 100644
index 0000000..8088819
--- /dev/null
+++ b/yahtzee.sh
@@ -0,0 +1,213 @@
+#!/usr/bin/env bash
+# yahtzee.sh — Yahtzee scoring engine and scripted game runner.
+set -u
+
+UPPER=(ones twos threes fours fives sixes)
+LOWER=(three_of_a_kind four_of_a_kind full_house small_straight large_straight yahtzee chance)
+
+usage() {
+  printf 'usage: yahtzee.sh score <category> <d1> <d2> <d3> <d4> <d5> | play <rolls-file> <script-file>\n' >&2
+  exit 2
+}
+
+die() { printf '%s\n' "$1" >&2; exit 2; }
+
+known_cat() {
+  case $1 in
+    ones|twos|threes|fours|fives|sixes|three_of_a_kind|four_of_a_kind|\
+    full_house|small_straight|large_straight|yahtzee|chance) return 0 ;;
+  esac
+  return 1
+}
+
+# score_cat <joker:0|1> <cat> <d1..d5>  -> prints the score
+score_cat() {
+  local joker=$1 cat=$2
+  shift 2
+  local d c=(0 0 0 0 0 0 0) sum=0 maxc=0 distinct=0 f
+  for d in "$@"; do
+    c[d]=$((c[d] + 1))
+    sum=$((sum + d))
+  done
+  for f in 1 2 3 4 5 6; do
+    (( c[f] > maxc )) && maxc=${c[f]}
+    (( c[f] > 0 )) && distinct=$((distinct + 1))
+  done
+  case $cat in
+    ones)   echo $(( 1 * c[1] )) ;;
+    twos)   echo $(( 2 * c[2] )) ;;
+    threes) echo $(( 3 * c[3] )) ;;
+    fours)  echo $(( 4 * c[4] )) ;;
+    fives)  echo $(( 5 * c[5] )) ;;
+    sixes)  echo $(( 6 * c[6] )) ;;
+    three_of_a_kind) (( maxc >= 3 )) && echo "$sum" || echo 0 ;;
+    four_of_a_kind)  (( maxc >= 4 )) && echo "$sum" || echo 0 ;;
+    full_house)
+      if (( joker )); then echo 25
+      elif (( maxc == 3 && distinct == 2 )); then echo 25
+      else echo 0
+      fi
+      ;;
+    small_straight)
+      if (( joker )); then echo 30
+      elif (( (c[1] && c[2] && c[3] && c[4]) || (c[2] && c[3] && c[4] && c[5]) \
+              || (c[3] && c[4] && c[5] && c[6]) )); then echo 30
+      else echo 0
+      fi
+      ;;
+    large_straight)
+      if (( joker )); then echo 40
+      elif (( distinct == 5 && (c[1] && c[5] || c[2] && c[6]) )); then echo 40
+      else echo 0
+      fi
+      ;;
+    yahtzee) (( maxc == 5 )) && echo 50 || echo 0 ;;
+    chance)  echo "$sum" ;;
+  esac
+}
+
+valid_die() { [[ $1 =~ ^[1-6]$ ]]; }
+
+(( $# >= 1 )) || usage
+cmd=$1
+
+if [[ $cmd == score ]]; then
+  (( $# >= 2 )) || usage
+  cat=$2
+  shift 2
+  known_cat "$cat" || die "error: unknown category: $cat"
+  (( $# == 5 )) || die 'error: dice must be five values 1-6'
+  for d in "$@"; do
+    valid_die "$d" || die 'error: dice must be five values 1-6'
+  done
+  score_cat 0 "$cat" "$@"
+  exit 0
+fi
+
+[[ $cmd == play ]] || usage
+(( $# == 3 )) || usage
+rolls_file=$2
+script_file=$3
+[[ -f $rolls_file && -r $rolls_file ]] || die "error: cannot read $rolls_file"
+[[ -f $script_file && -r $script_file ]] || die "error: cannot read $script_file"
+
+rolls=()
+while IFS= read -r line || [[ -n $line ]]; do
+  [[ -z $line ]] && continue
+  valid_die "$line" || die "error: bad roll line: $line"
+  rolls+=("$line")
+done < "$rolls_file"
+
+script=()
+while IFS= read -r line || [[ -n $line ]]; do
+  script+=("$line")
+done < "$script_file"
+
+ri=0
+si=0
+declare -A card=()
+bonus_total=0
+dice=()
+
+draw() { # draw <n> -> DRAWN=(...)
+  local n=$1
+  (( ri + n <= ${#rolls[@]} )) || die 'error: out of rolls'
+  DRAWN=("${rolls[@]:ri:n}")
+  ri=$((ri + n))
+}
+
+next_cmd() { # -> CMD, or dies at script end
+  while (( si < ${#script[@]} )); do
+    CMD=${script[si]}
+    si=$((si + 1))
+    [[ -z $CMD || $CMD == '#'* ]] && continue
+    return 0
+  done
+  die 'error: script ended early'
+}
+
+lower_cat() {
+  case $1 in
+    three_of_a_kind|four_of_a_kind|full_house|small_straight|large_straight|yahtzee|chance) return 0 ;;
+  esac
+  return 1
+}
+
+for ((turn = 1; turn <= 13; turn++)); do
+  draw 5
+  dice=("${DRAWN[@]}")
+  printf 'turn %d: roll %s\n' "$turn" "${dice[*]}"
+  rerolls=0
+  while :; do
+    next_cmd
+    read -ra parts <<< "$CMD"
+    if [[ ${parts[0]} == reroll ]]; then
+      (( rerolls < 2 )) || die 'error: too many rerolls'
+      pos=("${parts[@]:1}")
+      ok=1
+      (( ${#pos[@]} >= 1 )) || ok=0
+      declare -A seen=()
+      for p in "${pos[@]}"; do
+        [[ $p =~ ^[1-5]$ ]] || ok=0
+        [[ -n ${seen[$p]:-} ]] && ok=0
+        seen[$p]=1
+      done
+      unset seen
+      (( ok )) || die "error: bad reroll: $CMD"
+      draw "${#pos[@]}"
+      for ((k = 0; k < ${#pos[@]}; k++)); do
+        dice[pos[k] - 1]=${DRAWN[k]}
+      done
+      rerolls=$((rerolls + 1))
+      printf '  reroll %s -> %s\n' "${pos[*]}" "${dice[*]}"
+      continue
+    fi
+    if [[ ${parts[0]} == score && ${#parts[@]} == 2 ]]; then
+      cat=${parts[1]}
+      known_cat "$cat" || die "error: unknown category: $cat"
+      [[ -z ${card[$cat]+x} ]] || die "error: category already used: $cat"
+      five=0
+      (( dice[0] == dice[1] && dice[1] == dice[2] && dice[2] == dice[3] && dice[3] == dice[4] )) && five=1
+      joker=0
+      if (( five )) && [[ -n ${card[yahtzee]+x} ]]; then
+        face_cat=${UPPER[dice[0] - 1]}
+        if [[ -z ${card[$face_cat]+x} ]]; then
+          [[ $cat == "$face_cat" ]] || die "error: joker rule: must score $face_cat"
+        else
+          if lower_cat "$cat"; then
+            joker=1
+          else
+            for lc in "${LOWER[@]}"; do
+              [[ -z ${card[$lc]+x} ]] && die 'error: joker rule: score a lower category'
+            done
+          fi
+        fi
+        if (( card[yahtzee] == 50 )); then
+          bonus_total=$((bonus_total + 100))
+          printf '  yahtzee bonus! +100\n'
+        fi
+      fi
+      val=$(score_cat "$joker" "$cat" "${dice[@]}")
+      card[$cat]=$val
+      printf '  score %s = %d\n' "$cat" "$val"
+      break
+    fi
+    die "error: bad script line: $CMD"
+  done
+done
+
+upper_sub=0
+for c in "${UPPER[@]}"; do upper_sub=$((upper_sub + card[$c])); done
+upper_bonus=0
+(( upper_sub >= 63 )) && upper_bonus=35
+total=$((upper_sub + upper_bonus + bonus_total))
+for c in "${LOWER[@]}"; do total=$((total + card[$c])); done
+
+printf 'scorecard\n'
+for c in "${UPPER[@]}"; do printf '  %-15s %d\n' "$c" "${card[$c]}"; done
+printf '  %-15s %d\n' 'upper subtotal' "$upper_sub"
+printf '  %-15s %d\n' 'upper bonus' "$upper_bonus"
+for c in "${LOWER[@]}"; do printf '  %-15s %d\n' "$c" "${card[$c]}"; done
+printf '  %-15s %d\n' 'yahtzee bonus' "$bonus_total"
+printf '  %-15s %d\n' 'total' "$total"
+exit 0
