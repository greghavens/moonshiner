+// cascade.ts — specificity + cascade resolver for the newsletter style inliner.
+//
+// Matching is deliberately minimal (single compound selectors); the work here
+// is deciding which declaration wins and how inheritable properties flow down.
+
+export type StyleNode = { tag: string; attrs: Record<string, string>; children: StyleNode[] };
+export type Declaration = { prop: string; value: string };
+export type Rule = { selector: string; declarations: Declaration[] };
+
+// Inheritable properties; everything else stays on the element it was set on.
+export const INHERITED: ReadonlyArray<string> = ['color', 'font-size', 'font-family', 'text-align'];
+
+// Root-level fallbacks for inheritable properties. font-family and text-align
+// intentionally have none: absent unless a rule sets them somewhere.
+export const DEFAULTS: Record<string, string> = { color: 'black', 'font-size': '16px' };
+
+type Simple =
+  | { kind: 'universal' }
+  | { kind: 'type'; name: string }
+  | { kind: 'class'; name: string }
+  | { kind: 'id'; name: string }
+  | { kind: 'attr'; name: string; value: string | null };
+
+const IDENT_CHAR = /[A-Za-z0-9_-]/;
+const IMPORTANT_RE = /\s*!important\s*$/i;
+
+function parseCompound(source: string): Simple[] {
+  const src = source.trim();
+  const n = src.length;
+  let i = 0;
+
+  function fail(detail: string): never {
+    throw new Error(`unsupported selector ${JSON.stringify(source)}: ${detail}`);
+  }
+
+  function ident(what: string): string {
+    const start = i;
+    while (i < n && IDENT_CHAR.test(src[i])) i++;
+    if (i === start) fail(`expected ${what}`);
+    return src.slice(start, i);
+  }
+
+  if (n === 0) fail('empty selector');
+  const parts: Simple[] = [];
+  if (src[i] === '*') {
+    i++;
+    parts.push({ kind: 'universal' });
+  } else if (IDENT_CHAR.test(src[i])) {
+    parts.push({ kind: 'type', name: ident('a type name') });
+  }
+  while (i < n) {
+    const c = src[i];
+    if (c === '.') {
+      i++;
+      parts.push({ kind: 'class', name: ident('a class name') });
+    } else if (c === '#') {
+      i++;
+      parts.push({ kind: 'id', name: ident('an id') });
+    } else if (c === '[') {
+      i++;
+      const name = ident('an attribute name');
+      let value: string | null = null;
+      if (src[i] === '=') {
+        i++;
+        if (src[i] === '"') {
+          i++;
+          const start = i;
+          while (i < n && src[i] !== '"') i++;
+          if (i >= n) fail('unclosed quoted attribute value');
+          value = src.slice(start, i);
+          i++;
+        } else {
+          value = ident('an attribute value');
+        }
+      }
+      if (src[i] !== ']') fail("expected ']'");
+      i++;
+      parts.push({ kind: 'attr', name, value });
+    } else {
+      // combinators, commas, pseudo-classes, stray characters: out of scope
+      fail(`unexpected character ${JSON.stringify(c)}`);
+    }
+  }
+  if (parts.length === 0) fail('empty selector');
+  return parts;
+}
+
+function specificityOf(parts: Simple[]): [number, number, number] {
+  let ids = 0;
+  let classesAndAttrs = 0;
+  let types = 0;
+  for (const part of parts) {
+    if (part.kind === 'id') ids++;
+    else if (part.kind === 'class' || part.kind === 'attr') classesAndAttrs++;
+    else if (part.kind === 'type') types++;
+  }
+  return [ids, classesAndAttrs, types];
+}
+
+export function specificity(selector: string): [number, number, number] {
+  return specificityOf(parseCompound(selector));
+}
+
+function matches(parts: Simple[], node: StyleNode): boolean {
+  return parts.every((part) => {
+    switch (part.kind) {
+      case 'universal':
+        return true;
+      case 'type':
+        return node.tag === part.name;
+      case 'class': {
+        const cls = node.attrs['class'];
+        return cls !== undefined && cls.split(/\s+/).includes(part.name);
+      }
+      case 'id':
+        return node.attrs['id'] === part.name;
+      case 'attr': {
+        const value = node.attrs[part.name];
+        if (value === undefined) return false;
+        return part.value === null || value === part.value;
+      }
+    }
+  });
+}
+
+type Candidate = {
+  value: string;
+  important: boolean;
+  spec: [number, number, number];
+  ruleIdx: number;
+  declIdx: number;
+};
+
+function beats(a: Candidate, b: Candidate): boolean {
+  if (a.important !== b.important) return a.important;
+  for (let k = 0; k < 3; k++) {
+    if (a.spec[k] !== b.spec[k]) return a.spec[k] > b.spec[k];
+  }
+  if (a.ruleIdx !== b.ruleIdx) return a.ruleIdx > b.ruleIdx;
+  return a.declIdx > b.declIdx;
+}
+
+export function computeStyles(
+  root: StyleNode,
+  rules: Rule[],
+): Map<StyleNode, Record<string, string>> {
+  // Parse everything up front: a bad selector is a stylesheet bug even if
+  // the rule would never match.
+  const parsed = rules.map((r) => {
+    const parts = parseCompound(r.selector);
+    return { parts, spec: specificityOf(parts) };
+  });
+
+  const styles = new Map<StyleNode, Record<string, string>>();
+
+  function resolve(node: StyleNode, parentStyle: Record<string, string> | null): void {
+    const winners = new Map<string, Candidate>();
+    rules.forEach((r, ruleIdx) => {
+      if (!matches(parsed[ruleIdx].parts, node)) return;
+      r.declarations.forEach((decl, declIdx) => {
+        let value = decl.value.trim();
+        let important = false;
+        if (IMPORTANT_RE.test(value)) {
+          important = true;
+          value = value.replace(IMPORTANT_RE, '').trim();
+        }
+        const candidate: Candidate = { value, important, spec: parsed[ruleIdx].spec, ruleIdx, declIdx };
+        const current = winners.get(decl.prop);
+        if (current === undefined || beats(candidate, current)) {
+          winners.set(decl.prop, candidate);
+        }
+      });
+    });
+
+    const style: Record<string, string> = {};
+    for (const [prop, candidate] of winners) style[prop] = candidate.value;
+    for (const prop of INHERITED) {
+      if (prop in style) continue;
+      if (parentStyle !== null) {
+        if (prop in parentStyle) style[prop] = parentStyle[prop];
+      } else if (prop in DEFAULTS) {
+        style[prop] = DEFAULTS[prop];
+      }
+    }
+
+    styles.set(node, style);
+    for (const child of node.children) resolve(child, style);
+  }
+
+  resolve(root, null);
+  return styles;
+}
