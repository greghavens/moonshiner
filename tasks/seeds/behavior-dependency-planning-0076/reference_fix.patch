+#!/usr/bin/env python3
+"""Reconcile the two review-queue claims through the local claims command."""
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import subprocess
+import sys
+from typing import Any
+
+
+TARGETS = (
+    ("Clinic Refrigeration Claim", "Medical Desk"),
+    ("Museum Glass Damage Claim", "Arts Desk"),
+)
+CLAIMS_COMMAND = Path(__file__).with_name("claims_cli.py")
+
+
+class AuditFailure(Exception):
+    """Raised when the claims command cannot provide trustworthy data."""
+
+
+def run_stage(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Start a complete independent stage before awaiting any child."""
+    processes: list[subprocess.Popen[str]] = []
+    try:
+        for command in commands:
+            processes.append(subprocess.Popen(
+                command,
+                cwd=Path(__file__).resolve().parent,
+                stdout=subprocess.PIPE,
+                stderr=subprocess.PIPE,
+                text=True,
+            ))
+    except OSError:
+        for process in processes:
+            process.communicate()
+        raise
+
+    completed = [process.communicate() for process in processes]
+    failures = [
+        (process, stderr)
+        for process, (_, stderr) in zip(processes, completed, strict=True)
+        if process.returncode != 0
+    ]
+    if failures:
+        process, stderr = failures[0]
+        detail = stderr.strip() or f"exit status {process.returncode}"
+        raise AuditFailure(f"claims command failed: {detail}")
+
+    results: list[dict[str, Any]] = []
+    for stdout, _ in completed:
+        try:
+            value = json.loads(stdout)
+        except json.JSONDecodeError as error:
+            raise AuditFailure("claims command returned malformed JSON") from error
+        if not isinstance(value, dict):
+            raise AuditFailure("claims command returned a non-object response")
+        results.append(value)
+    return results
+
+
+def command(*arguments: str) -> list[str]:
+    return [sys.executable, str(CLAIMS_COMMAND), *arguments]
+
+
+def reconcile() -> str:
+    search_commands = [
+        command("search", "--name", name, "--location", location)
+        for name, location in TARGETS
+    ]
+    search_results = run_stage(search_commands)
+
+    eligible: list[tuple[int, str]] = []
+    unresolved: set[int] = set()
+    for index, result in enumerate(search_results):
+        stable_ids = result.get("stable_ids")
+        if (not isinstance(stable_ids, list)
+                or any(not isinstance(value, str) or not value
+                       for value in stable_ids)):
+            raise AuditFailure("search command returned malformed stable IDs")
+        if len(stable_ids) == 1:
+            eligible.append((index, stable_ids[0]))
+        else:
+            unresolved.add(index)
+
+    get_results = run_stage([
+        command("get", "--id", stable_id) for _, stable_id in eligible
+    ])
+    resolved: list[tuple[int, dict[str, str]]] = []
+    required_fields = ("id", "name", "location", "status", "date")
+    for (index, stable_id), result in zip(eligible, get_results, strict=True):
+        if (not all(isinstance(result.get(field), str) and result[field]
+                    for field in required_fields)
+                or result["id"] != stable_id
+                or result["name"] != TARGETS[index][0]
+                or result["location"] != TARGETS[index][1]):
+            raise AuditFailure("get response did not match its searched branch")
+        resolved.append((index, {field: result[field] for field in required_fields}))
+
+    resolved.sort(key=lambda item: (item[1]["date"], item[0]))
+    lines = [
+        "\t".join(record[field] for field in
+                  ("date", "id", "name", "location", "status"))
+        for _, record in resolved
+    ]
+    for index, (name, location) in enumerate(TARGETS):
+        if index in unresolved:
+            lines.append(f"UNRESOLVED\t{name}\t{location}")
+
+    if not unresolved:
+        earlier, later = (record for _, record in resolved)
+        lines.append(
+            f"Status comparison: {earlier['name']} is {earlier['status']}; "
+            f"{later['name']} is {later['status']}.")
+    else:
+        names = " and ".join(TARGETS[index][0] for index in sorted(unresolved))
+        lines.append(
+            f"Status comparison: unavailable because {names} "
+            "did not resolve uniquely.")
+    return "\n".join(lines) + "\n"
+
+
+def main() -> int:
+    try:
+        sys.stdout.write(reconcile())
+    except (AuditFailure, OSError) as error:
+        print(f"reconcile_claims.py: {error}", file=sys.stderr)
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
