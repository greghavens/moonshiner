@@ -0,0 +1,82 @@
+"""Deterministic logical-time event scheduler."""
+import heapq
+
+
+class _Event:
+    __slots__ = ("time", "priority", "seq", "callback", "args", "cancelled")
+
+    def __init__(self, time, priority, seq, callback, args):
+        self.time = time
+        self.priority = priority
+        self.seq = seq
+        self.callback = callback
+        self.args = args
+        self.cancelled = False
+
+    def __lt__(self, other):
+        return (self.time, self.priority, self.seq) < \
+               (other.time, other.priority, other.seq)
+
+
+class Scheduler:
+    """Single-threaded scheduler over logical time, starting at 0."""
+
+    def __init__(self):
+        self.now = 0
+        self._heap = []
+        self._seq = 0
+        self._pending = 0
+
+    @property
+    def pending(self):
+        return self._pending
+
+    def schedule(self, delay, callback, *args, priority=0):
+        if delay < 0:
+            raise ValueError(f"delay must be >= 0, got {delay}")
+        event = _Event(self.now + delay, priority, self._seq, callback, args)
+        self._seq += 1
+        heapq.heappush(self._heap, event)
+        self._pending += 1
+        return event
+
+    def cancel(self, handle):
+        if handle.cancelled or handle.time is None:
+            return False
+        handle.cancelled = True
+        self._pending -= 1
+        return True
+
+    def _pop_due(self, horizon):
+        """Pop the earliest live event with time <= horizon, or None."""
+        while self._heap and self._heap[0].time <= horizon:
+            event = heapq.heappop(self._heap)
+            if not event.cancelled:
+                return event
+        return None
+
+    def _fire(self, event):
+        self.now = event.time
+        self._pending -= 1
+        event.time = None  # mark fired so cancel() reports False
+        event.callback(*event.args)
+
+    def run_until(self, t):
+        if t < self.now:
+            raise ValueError(f"cannot run backwards: now={self.now}, asked {t}")
+        while True:
+            event = self._pop_due(t)
+            if event is None:
+                break
+            # _fire moves the clock first, so a raising callback leaves
+            # now on the failed event and the survivors in the heap.
+            self._fire(event)
+        self.now = t
+
+    def run_next(self):
+        event = self._pop_due(float("inf"))
+        if event is None:
+            return None
+        when = event.time
+        self._fire(event)
+        return when
