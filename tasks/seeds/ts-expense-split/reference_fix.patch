+// Largest-remainder allocation of an integer amount of cents across weighted
+// portions. Every portion gets floor(amount * weight / total); leftover cents
+// go one each to the largest fractional remainders, ties broken by name.
+
+export type Portion = { name: string; weight: number };
+
+export function distribute(amountCents: number, portions: Portion[]): Map<string, number> {
+  const totalWeight = portions.reduce((s, p) => s + p.weight, 0);
+  const shares = new Map<string, number>();
+  const remainders: { name: string; frac: number }[] = [];
+  let assigned = 0;
+  for (const p of portions) {
+    const raw = (amountCents * p.weight) / totalWeight;
+    const floor = Math.floor(raw);
+    shares.set(p.name, floor);
+    remainders.push({ name: p.name, frac: raw - floor });
+    assigned += floor;
+  }
+  remainders.sort((a, b) => (b.frac - a.frac) || (a.name < b.name ? -1 : a.name > b.name ? 1 : 0));
+  let leftover = amountCents - assigned;
+  for (const r of remainders) {
+    if (leftover <= 0) break;
+    shares.set(r.name, (shares.get(r.name) ?? 0) + 1);
+    leftover -= 1;
+  }
+  return shares;
+}
