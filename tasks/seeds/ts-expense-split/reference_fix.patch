+// Turn a column of net balances into a short list of settlement transfers.
+//
+// Policy: drop zeros, pair exact debt/credit matches first (debtors in name
+// order, each taking the alphabetically first exact creditor), then greedily
+// match the largest remaining debtor with the largest remaining creditor.
+
+export type BalanceRow = { name: string; netCents: number };
+export type Transfer = { from: string; to: string; amountCents: number };
+
+type Party = { name: string; cents: number };
+
+function byName(a: Party, b: Party): number {
+  return a.name < b.name ? -1 : a.name > b.name ? 1 : 0;
+}
+
+function bySizeThenName(a: Party, b: Party): number {
+  return (b.cents - a.cents) || byName(a, b);
+}
+
+export function settle(balances: BalanceRow[]): Transfer[] {
+  const sum = balances.reduce((s, r) => s + r.netCents, 0);
+  if (sum !== 0) {
+    throw new Error(`balances must sum to zero, got ${sum}`);
+  }
+
+  const creditors: Party[] = [];
+  const debtors: Party[] = [];
+  for (const row of balances) {
+    if (row.netCents > 0) creditors.push({ name: row.name, cents: row.netCents });
+    else if (row.netCents < 0) debtors.push({ name: row.name, cents: -row.netCents });
+  }
+  creditors.sort(byName);
+  debtors.sort(byName);
+
+  const transfers: Transfer[] = [];
+
+  // Pass 1: exact matches, debtors in alphabetical order.
+  for (const debtor of debtors) {
+    const match = creditors.find((c) => c.cents === debtor.cents);
+    if (match) {
+      transfers.push({ from: debtor.name, to: match.name, amountCents: debtor.cents });
+      debtor.cents = 0;
+      match.cents = 0;
+    }
+  }
+
+  // Pass 2: largest debtor pays largest creditor.
+  for (;;) {
+    const ds = debtors.filter((d) => d.cents > 0).sort(bySizeThenName);
+    const cs = creditors.filter((c) => c.cents > 0).sort(bySizeThenName);
+    if (ds.length === 0) break;
+    const debtor = ds[0];
+    const creditor = cs[0];
+    const amount = Math.min(debtor.cents, creditor.cents);
+    transfers.push({ from: debtor.name, to: creditor.name, amountCents: amount });
+    debtor.cents -= amount;
+    creditor.cents -= amount;
+  }
+
+  return transfers;
+}
