+import { distribute } from './money.ts';
+
+export type SplitSpec =
+  | { kind: 'equal'; among?: string[] }
+  | { kind: 'exact'; shares: Record<string, number> }
+  | { kind: 'percent'; shares: Record<string, number> }
+  | { kind: 'weights'; shares: Record<string, number> };
+
+export type Expense = {
+  payer: string;
+  amountCents: number;
+  description?: string;
+  split: SplitSpec;
+};
+
+export class Ledger {
+  private net = new Map<string, number>();
+
+  addMember(name: string): void {
+    if (typeof name !== 'string' || name.trim() === '') {
+      throw new Error('member name must not be blank');
+    }
+    if (this.net.has(name)) {
+      throw new Error(`"${name}" is already a member`);
+    }
+    this.net.set(name, 0);
+  }
+
+  members(): string[] {
+    return [...this.net.keys()].sort();
+  }
+
+  addExpense(expense: Expense): void {
+    const { payer, amountCents, split } = expense;
+    if (!Number.isInteger(amountCents) || amountCents <= 0) {
+      throw new RangeError(`amountCents must be a positive integer, got ${amountCents}`);
+    }
+    this.assertMember(payer);
+    const shares = this.computeShares(amountCents, split);
+    // Nothing above threw: commit atomically.
+    this.net.set(payer, (this.net.get(payer) ?? 0) + amountCents);
+    for (const [name, cents] of shares) {
+      this.net.set(name, (this.net.get(name) ?? 0) - cents);
+    }
+  }
+
+  balances(): { name: string; netCents: number }[] {
+    return this.members().map((name) => ({ name, netCents: this.net.get(name) ?? 0 }));
+  }
+
+  private assertMember(name: string): void {
+    if (!this.net.has(name)) throw new Error(`unknown member "${name}"`);
+  }
+
+  private computeShares(amountCents: number, split: SplitSpec): Map<string, number> {
+    switch (split.kind) {
+      case 'equal': {
+        const among = split.among ?? this.members();
+        const seen = new Set<string>();
+        for (const name of among) {
+          this.assertMember(name);
+          if (seen.has(name)) throw new Error(`duplicate participant "${name}"`);
+          seen.add(name);
+        }
+        if (among.length === 0) throw new Error('no participants to split across');
+        return distribute(amountCents, among.map((name) => ({ name, weight: 1 })));
+      }
+      case 'exact': {
+        const entries = Object.entries(split.shares);
+        if (entries.length === 0) throw new Error('no participants to split across');
+        let sum = 0;
+        for (const [name, cents] of entries) {
+          this.assertMember(name);
+          if (!Number.isInteger(cents) || cents < 0) {
+            throw new RangeError(`exact share for "${name}" must be a non-negative integer, got ${cents}`);
+          }
+          sum += cents;
+        }
+        if (sum !== amountCents) {
+          throw new Error(`exact shares sum to ${sum}, expected ${amountCents}`);
+        }
+        return new Map(entries);
+      }
+      case 'percent': {
+        const entries = Object.entries(split.shares);
+        if (entries.length === 0) throw new Error('no participants to split across');
+        let total = 0;
+        for (const [name, pct] of entries) {
+          this.assertMember(name);
+          if (!Number.isFinite(pct) || pct < 0) {
+            throw new RangeError(`percent share for "${name}" must be non-negative, got ${pct}`);
+          }
+          total += pct;
+        }
+        if (total !== 100) {
+          throw new Error(`percent shares must total 100, got ${total}`);
+        }
+        return distribute(amountCents, entries.map(([name, pct]) => ({ name, weight: pct })));
+      }
+      case 'weights': {
+        const entries = Object.entries(split.shares);
+        if (entries.length === 0) throw new Error('no participants to split across');
+        for (const [name, weight] of entries) {
+          this.assertMember(name);
+          if (!Number.isFinite(weight) || weight <= 0) {
+            throw new RangeError(`weight for "${name}" must be a positive finite number, got ${weight}`);
+          }
+        }
+        return distribute(amountCents, entries.map(([name, weight]) => ({ name, weight })));
+      }
+      default: {
+        const kind = (split as { kind: string }).kind;
+        throw new Error(`unknown split kind "${kind}"`);
+      }
+    }
+  }
+}
