+import { regionEndpoint } from "./regions.ts";
+import { NerdGraphHttpError } from "./errors.ts";
+
+export type Sleeper = (ms: number) => Promise<void>;
+
+export interface ClientOptions {
+  apiKey: string;
+  region?: string;
+  endpointUrl?: string;
+  sleeper: Sleeper;
+  maxAttempts?: number;
+  baseDelayMs?: number;
+}
+
+export interface GraphQLEnvelope {
+  data?: unknown;
+  errors?: unknown[];
+}
+
+/**
+ * NerdGraph transport: POSTs {query, variables} with the user key in the
+ * documented API-Key header. 429 (the documented concurrency-limit
+ * rejection) backs off through the injected sleeper and retries; every
+ * other non-2xx status surfaces immediately. The key never travels in a
+ * URL, a Bearer header, or an error message.
+ */
+export class NerdGraphClient {
+  endpoint: string;
+  #apiKey: string;
+  #sleeper: Sleeper;
+  #maxAttempts: number;
+  #baseDelayMs: number;
+
+  constructor(options: ClientOptions) {
+    if (!options.endpointUrl && !options.region) {
+      throw new Error("either endpointUrl or region is required");
+    }
+    this.endpoint = options.endpointUrl ?? regionEndpoint(options.region!);
+    this.#apiKey = options.apiKey;
+    this.#sleeper = options.sleeper;
+    this.#maxAttempts = options.maxAttempts ?? 4;
+    this.#baseDelayMs = options.baseDelayMs ?? 1000;
+  }
+
+  async execute(query: string, variables: Record<string, unknown>): Promise<GraphQLEnvelope> {
+    for (let attempt = 1; ; attempt++) {
+      const response = await fetch(this.endpoint, {
+        method: "POST",
+        headers: {
+          "API-Key": this.#apiKey,
+          "Content-Type": "application/json",
+        },
+        body: JSON.stringify({ query, variables }),
+      });
+      const text = await response.text();
+      if (response.status === 429) {
+        if (attempt >= this.#maxAttempts) {
+          throw new NerdGraphHttpError(429, text);
+        }
+        await this.#sleeper(this.#baseDelayMs * 2 ** (attempt - 1));
+        continue;
+      }
+      if (!response.ok) {
+        throw new NerdGraphHttpError(response.status, text);
+      }
+      return JSON.parse(text) as GraphQLEnvelope;
+    }
+  }
+}
diff --git a/src/errors.ts b/src/errors.ts
new file mode 100644
index 0000000..5617f1d
--- /dev/null
+++ b/src/errors.ts
@@ -0,0 +1,34 @@
+export interface GraphQLErrorEntry {
+  message?: string;
+  path?: unknown[];
+  extensions?: { errorClass?: string };
+}
+
+/** Non-2xx NerdGraph response. Carries status and raw body, never the key. */
+export class NerdGraphHttpError extends Error {
+  status: number;
+  body: string;
+
+  constructor(status: number, body: string) {
+    super(`NerdGraph request failed with HTTP ${status}`);
+    this.name = "NerdGraphHttpError";
+    this.status = status;
+    this.body = body;
+  }
+}
+
+/** A GraphQL response with errors and no usable data. */
+export class NerdGraphQueryError extends Error {
+  errors: GraphQLErrorEntry[];
+  errorClasses: string[];
+
+  constructor(errors: GraphQLErrorEntry[]) {
+    const messages = errors.map((e) => e?.message).filter(Boolean);
+    super(`NerdGraph query failed: ${messages.join("; ") || "no usable data returned"}`);
+    this.name = "NerdGraphQueryError";
+    this.errors = errors;
+    this.errorClasses = errors
+      .map((e) => e?.extensions?.errorClass)
+      .filter((c): c is string => typeof c === "string");
+  }
+}
