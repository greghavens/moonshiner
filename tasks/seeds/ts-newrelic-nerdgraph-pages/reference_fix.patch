diff --git a/src/inventory.ts b/src/inventory.ts
new file mode 100644
index 0000000..0a08515
--- /dev/null
+++ b/src/inventory.ts
@@ -0,0 +1,98 @@
+import { NerdGraphClient } from "./client.ts";
+import { NerdGraphQueryError, type GraphQLErrorEntry } from "./errors.ts";
+
+export interface Entity {
+  guid: string;
+  name: string;
+  entityType: string;
+  domain: string;
+  accountId: number;
+  reporting?: boolean;
+  tags?: Array<{ key: string; values: string[] }>;
+}
+
+export interface InventoryResult {
+  entities: Entity[];
+  warnings: Array<{ message: string | undefined; errorClass: string | null }>;
+}
+
+// One document for every page: the search string and the cursor travel as
+// variables, never spliced into the text. NerdGraph caps a page at 200
+// entities; traversal follows nextCursor until it is null.
+const SEARCH_DOCUMENT = `query EntityInventory($query: String!, $cursor: String) {
+  actor {
+    entitySearch(query: $query) {
+      results(cursor: $cursor) {
+        entities {
+          guid
+          name
+          entityType
+          domain
+          accountId
+          reporting
+          tags {
+            key
+            values
+          }
+        }
+        nextCursor
+      }
+    }
+  }
+}`;
+
+interface SearchResults {
+  entities?: Entity[];
+  nextCursor?: string | null;
+}
+
+export class EntityInventory {
+  #client: NerdGraphClient;
+
+  constructor(options: { client: NerdGraphClient }) {
+    this.#client = options.client;
+  }
+
+  async collect(searchQuery: string): Promise<InventoryResult> {
+    const entities: Entity[] = [];
+    const warnings: InventoryResult["warnings"] = [];
+    let cursor: string | null = null;
+
+    for (;;) {
+      const variables: Record<string, unknown> = { query: searchQuery };
+      if (cursor !== null) {
+        variables.cursor = cursor;
+      }
+      const envelope = await this.#client.execute(SEARCH_DOCUMENT, variables);
+      const errors = Array.isArray(envelope.errors)
+        ? (envelope.errors as GraphQLErrorEntry[])
+        : [];
+      const results = extractResults(envelope.data);
+      if (!results) {
+        throw new NerdGraphQueryError(errors);
+      }
+      for (const error of errors) {
+        warnings.push({
+          message: error?.message,
+          errorClass: error?.extensions?.errorClass ?? null,
+        });
+      }
+      entities.push(...(results.entities ?? []));
+      if (!results.nextCursor) {
+        return { entities, warnings };
+      }
+      cursor = results.nextCursor;
+    }
+  }
+}
+
+function extractResults(data: unknown): SearchResults | null {
+  if (typeof data !== "object" || data === null) return null;
+  const actor = (data as Record<string, unknown>).actor;
+  if (typeof actor !== "object" || actor === null) return null;
+  const search = (actor as Record<string, unknown>).entitySearch;
+  if (typeof search !== "object" || search === null) return null;
+  const results = (search as Record<string, unknown>).results;
+  if (typeof results !== "object" || results === null) return null;
+  return results as SearchResults;
+}
