--- /dev/null
+++ b/src/regions.ts
@@ -0,0 +1,13 @@
+const REGION_ENDPOINTS: Record<string, string> = {
+  US: "https://api.newrelic.com/graphql",
+  EU: "https://api.eu.newrelic.com/graphql",
+};
+
+export function regionEndpoint(region: string): string {
+  const endpoint = REGION_ENDPOINTS[region];
+  if (!endpoint) {
+    const valid = Object.keys(REGION_ENDPOINTS).join(", ");
+    throw new Error(`unknown New Relic region "${region}" (valid regions: ${valid})`);
+  }
+  return endpoint;
+}
