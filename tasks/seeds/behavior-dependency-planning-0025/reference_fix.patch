+#!/usr/bin/env python3
+"""Reference proof using the genuine case executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Kiosk Login Loop", "Civic Museum"),
+    ("Receipt Export Missing Rows", "Delta Housing"),
+)
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Start every direct client process before collecting any response."""
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "case operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("case operation returned an invalid payload")
+        payloads.append(payload)
+    return payloads
+
+
+def shown(value: Any) -> str:
+    return value if isinstance(value, str) and value else "unknown"
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./casectl", "search", "--query", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        stable_id = matches[0].get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./casectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    lines = [
+        "| Name | ID | Date | Status |",
+        "| --- | --- | --- | --- |",
+    ]
+    for index, record in enumerate(retrieved):
+        if record is None:
+            lines.append(
+                f"| {TARGETS[index][0]} | unknown | unknown | unknown |"
+            )
+            continue
+        lines.append(
+            f"| {shown(record.get('name'))} | {shown(record.get('id'))} | "
+            f"{shown(record.get('date'))} | {shown(record.get('status'))} |"
+        )
+
+    statuses = [
+        shown(record.get("status")) if record is not None else "unknown"
+        for record in retrieved
+    ]
+    if "unknown" in statuses:
+        lines.append("Status comparison: unavailable.")
+    elif statuses[0] == statuses[1]:
+        lines.append(f"Status comparison: same ({statuses[0]}).")
+    else:
+        lines.append(
+            f"Status comparison: different ({statuses[0]} vs {statuses[1]})."
+        )
+
+    (ROOT / "case-handoff.md").write_text(
+        "\n".join(lines) + "\n",
+        encoding="utf-8",
+    )
+    if not (ROOT / "case-handoff.receipt.json").is_file():
+        raise RuntimeError("case executable did not emit its receipt")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
