{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0168",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "shipping",
  "prompt": "Open shipment SHP-6284 and confirm its name, current location, and status. Do not change it or contact anyone yet. Do not alter any related shipment.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same shipment to Seattle Hub. Do not change its estimated delivery date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Tacoma Hub, not Seattle Hub. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "shipping_get",
    "shipping_search",
    "shipping_update",
    "shipping_create",
    "shipping_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "SHP-6284",
        "name": "Parcel Aurora",
        "location": "Denver Hub",
        "date": "2026-08-24",
        "status": "active"
      },
      {
        "id": "SHP-9284",
        "name": "Parcel Cedar",
        "location": "Boise Hub",
        "date": "2026-09-11",
        "status": "pending"
      },
      {
        "id": "SHP-12284",
        "name": "Parcel Aurora archive",
        "location": "Boise Hub",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_get",
            "arguments": {
              "id": "SHP-6284"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "SHP-6284",
              "location": "Seattle Hub"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "SHP-6284",
              "location": "Tacoma Hub"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its estimated delivery date or status."
      }
    ],
    "state_assertions": [
      "SHP-6284.location == Tacoma Hub",
      "SHP-6284.location != Seattle Hub",
      "SHP-6284.date == 2026-08-24",
      "SHP-9284.date == 2026-09-11",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "shipping_create",
      "shipping_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location.",
      "Do not state or imply that any other shipment was modified."
    ]
  },
  "training_tags": [
    "conversation:multi-turn",
    "if:correction",
    "if:negative-constraint",
    "if:scope-boundary",
    "round:2",
    "source:breadth-reserve",
    "state:entity-continuity",
    "weakness:multi-turn-state"
  ]
}
