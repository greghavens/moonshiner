new file mode 100644
index 0000000..fbdcdbf
--- /dev/null
+++ b/undostack.py
@@ -0,0 +1,91 @@
+"""Command-pattern undo/redo stack with nestable transactions."""
+
+
+class _Group:
+    """Several commands undone/redone as one unit."""
+
+    def __init__(self, commands):
+        self.commands = commands
+
+    def apply(self):
+        for command in self.commands:
+            command.apply()
+
+    def revert(self):
+        for command in reversed(self.commands):
+            command.revert()
+
+
+class UndoStack:
+    def __init__(self):
+        self._undo = []
+        self._redo = []
+        self._transactions = []  # stack of open transaction command lists
+
+    # -- introspection ----------------------------------------------------
+    @property
+    def can_undo(self):
+        return bool(self._undo)
+
+    @property
+    def can_redo(self):
+        return bool(self._redo)
+
+    @property
+    def undo_depth(self):
+        return len(self._undo)
+
+    @property
+    def redo_depth(self):
+        return len(self._redo)
+
+    # -- recording --------------------------------------------------------
+    def execute(self, command):
+        command.apply()
+        self._redo.clear()  # history diverged, even if this gets rolled back
+        if self._transactions:
+            self._transactions[-1].append(command)
+        else:
+            self._undo.append(command)
+
+    def begin(self):
+        self._transactions.append([])
+
+    def commit(self):
+        if not self._transactions:
+            raise RuntimeError("commit with no open transaction")
+        commands = self._transactions.pop()
+        if not commands:
+            return
+        if self._transactions:
+            self._transactions[-1].extend(commands)  # fold into the outer one
+        else:
+            self._undo.append(_Group(commands))
+
+    def rollback(self):
+        if not self._transactions:
+            raise RuntimeError("rollback with no open transaction")
+        commands = self._transactions.pop()
+        for command in reversed(commands):
+            command.revert()
+
+    # -- time travel ------------------------------------------------------
+    def undo(self):
+        if self._transactions:
+            raise RuntimeError("cannot undo while a transaction is open")
+        if not self._undo:
+            return False
+        command = self._undo.pop()
+        command.revert()
+        self._redo.append(command)
+        return True
+
+    def redo(self):
+        if self._transactions:
+            raise RuntimeError("cannot redo while a transaction is open")
+        if not self._redo:
+            return False
+        command = self._redo.pop()
+        command.apply()
+        self._undo.append(command)
+        return True
