@@ -0,0 +1,81 @@
+using System.Text.Json;
+
+namespace OracleHcm;
+
+/// <summary>One entry of a structured error document's o:errorDetails array.</summary>
+public sealed record OracleErrorEntry(string Detail, string ErrorCode, string ErrorPath);
+
+/// <summary>
+/// Non-2xx reply from the HCM REST framework. With REST-Framework-Version 4+
+/// the body is application/vnd.oracle.adf.error+json:
+/// { "title", "status" (string), "o:errorDetails": [{ "detail", "o:errorCode", "o:errorPath" }] }.
+/// The whole document is preserved; credentials never enter the message.
+/// </summary>
+public sealed class OracleRestException : Exception
+{
+    public int HttpStatus { get; }
+    public string Title { get; }
+    public string ErrorStatus { get; }
+    public IReadOnlyList<OracleErrorEntry> Details { get; }
+
+    public OracleRestException(int httpStatus, string title, string errorStatus,
+        IReadOnlyList<OracleErrorEntry> details)
+        : base(BuildMessage(httpStatus, title, details))
+    {
+        HttpStatus = httpStatus;
+        Title = title;
+        ErrorStatus = errorStatus;
+        Details = details;
+    }
+
+    private static string BuildMessage(int httpStatus, string title, IReadOnlyList<OracleErrorEntry> details)
+    {
+        var message = $"Oracle HCM request failed (HTTP {httpStatus}): {title}";
+        if (details.Count > 0)
+            message += $" [{details[0].ErrorCode}] {details[0].Detail}";
+        return message;
+    }
+
+    public static OracleRestException FromBody(int httpStatus, string body)
+    {
+        var title = $"HTTP {httpStatus}";
+        var errorStatus = httpStatus.ToString();
+        var details = new List<OracleErrorEntry>();
+        try
+        {
+            using var doc = JsonDocument.Parse(body);
+            var root = doc.RootElement;
+            if (root.TryGetProperty("title", out var t) && t.ValueKind == JsonValueKind.String)
+                title = t.GetString()!;
+            if (root.TryGetProperty("status", out var s) && s.ValueKind == JsonValueKind.String)
+                errorStatus = s.GetString()!;
+            if (root.TryGetProperty("o:errorDetails", out var arr) && arr.ValueKind == JsonValueKind.Array)
+            {
+                foreach (var entry in arr.EnumerateArray())
+                {
+                    details.Add(new OracleErrorEntry(
+                        entry.TryGetProperty("detail", out var d) ? d.GetString() ?? "" : "",
+                        entry.TryGetProperty("o:errorCode", out var c) ? c.GetString() ?? "" : "",
+                        entry.TryGetProperty("o:errorPath", out var p) ? p.GetString() ?? "" : ""));
+                }
+            }
+        }
+        catch (JsonException)
+        {
+            details.Add(new OracleErrorEntry(body, "", ""));
+        }
+        return new OracleRestException(httpStatus, title, errorStatus, details);
+    }
+}
+
+/// <summary>Raised when a 202-accepted action never resolves within the poll budget.</summary>
+public sealed class HcmAsyncTimeoutException : Exception
+{
+    public int Polls { get; }
+
+    public HcmAsyncTimeoutException(int polls, string statusUrl)
+        : base($"cancelWorkRelationship still in progress after {polls} status polls of {statusUrl}")
+    {
+        Polls = polls;
+    }
+}
