+namespace OracleHcm;
+
+/// <summary>A worker resolved from the workers collection. WorkersUniqId is the
+/// hash key taken from the item's self link — never synthesized client-side.</summary>
+public sealed record WorkerRef(long PersonId, string PersonNumber, string WorkersUniqId);
+
+/// <summary>A work relationship resolved from the worker's child collection.</summary>
+public sealed record RelationshipRef(WorkerRef Worker, long PeriodOfServiceId, string LegalEmployerName);
+
+/// <summary>Outcome of a cancelWorkRelationship action. Mode is "sync" for a
+/// 200/actionresult reply and "async" for a 202 confirmed by status polling.
+/// RawResult retains the action reply body verbatim.</summary>
+public sealed record CancelOutcome(string Mode, int Polls, string? ReturnValue, string RawResult);
+
+/// <summary>Documented HCM REST status semantics.</summary>
+public enum HcmResponseKind
+{
+    Ok,
+    Created,
+    Accepted,
+    NoContent,
+    ClientError,
+    ServerError,
+}
+
+public static class HcmStatusClassifier
+{
+    public static HcmResponseKind Classify(int statusCode) => statusCode switch
+    {
+        200 => HcmResponseKind.Ok,
+        201 => HcmResponseKind.Created,
+        202 => HcmResponseKind.Accepted,
+        204 => HcmResponseKind.NoContent,
+        >= 400 and < 500 => HcmResponseKind.ClientError,
+        >= 500 and < 600 => HcmResponseKind.ServerError,
+        _ => throw new ArgumentOutOfRangeException(nameof(statusCode),
+            $"status {statusCode} is outside the documented HCM REST status set"),
+    };
+}
