diff --git a/run_status_audit.sh b/run_status_audit.sh
new file mode 100755
index 0000000..de51754
--- /dev/null
+++ b/run_status_audit.sh
@@ -0,0 +1,60 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+audit_tmp_dir="$(mktemp -d)"
+trap 'rm -rf -- "$audit_tmp_dir"' EXIT
+
+./records search --name "Juniper Bakery" --region "West Region" >"$audit_tmp_dir/juniper.json" &
+juniper_pid=$!
+./records search --name "Northline Pediatrics" --region "Central Region" >"$audit_tmp_dir/northline.json" &
+northline_pid=$!
+wait "$juniper_pid"
+wait "$northline_pid"
+
+juniper_id="$({
+  python3 - "$audit_tmp_dir/juniper.json" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    matches = json.load(stream)["matches"]
+if len(matches) != 1:
+    raise SystemExit("Juniper Bakery search was not unique")
+print(matches[0]["id"])
+PY
+})"
+northline_id="$({
+  python3 - "$audit_tmp_dir/northline.json" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    matches = json.load(stream)["matches"]
+if len(matches) != 1:
+    raise SystemExit("Northline Pediatrics search was not unique")
+print(matches[0]["id"])
+PY
+})"
+
+./records retrieve "$juniper_id" "$northline_id" >"$audit_tmp_dir/records.json"
+
+python3 - "$audit_tmp_dir/records.json" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    records = json.load(stream)["records"]
+if len(records) != 2:
+    raise SystemExit("combined retrieval did not return two records")
+by_name = {record["name"]: record["status"] for record in records}
+names = ["Juniper Bakery", "Northline Pediatrics"]
+if set(by_name) != set(names):
+    raise SystemExit("combined retrieval returned unexpected records")
+for name in names:
+    print(f"{name}: {by_name[name]}")
+comparison = "match" if by_name[names[0]] == by_name[names[1]] else "differ"
+print(
+    f"Comparison: statuses {comparison} — "
+    f"{names[0]} is {by_name[names[0]]}; {names[1]} is {by_name[names[1]]}."
+)
+PY
