+import { Board, type BoardDocument } from './board.ts';
+
+export function serialize(board: Board): string {
+  return JSON.stringify(board.snapshot());
+}
+
+function fail(reason: string): never {
+  throw new Error(`invalid board document: ${reason}`);
+}
+
+function validate(doc: unknown): BoardDocument {
+  if (typeof doc !== 'object' || doc === null || Array.isArray(doc)) fail('not an object');
+  const d = doc as Record<string, unknown>;
+
+  if (!Array.isArray(d.columns) || d.columns.length === 0) fail('needs a non-empty columns array');
+  for (const col of d.columns) {
+    if (typeof col !== 'object' || col === null) fail('column entries must be objects');
+    if (typeof (col as Record<string, unknown>).id !== 'string') fail('column entries need a string id');
+  }
+
+  if (!Array.isArray(d.lanes) || d.lanes.length === 0 || d.lanes.some((l) => typeof l !== 'string')) {
+    fail('needs a non-empty lanes array of strings');
+  }
+  if (!Number.isInteger(d.seq) || (d.seq as number) < 0) fail('needs a non-negative integer seq');
+  if (!Array.isArray(d.cards)) fail('needs a cards array');
+
+  for (const card of d.cards) {
+    if (typeof card !== 'object' || card === null) fail('card entries must be objects');
+    const c = card as Record<string, unknown>;
+    for (const key of ['id', 'title', 'column', 'lane']) {
+      if (typeof c[key] !== 'string') fail(`card entries need a string ${key}`);
+    }
+    if (!Array.isArray(c.history) || c.history.length === 0) fail('card entries need a history');
+  }
+
+  return d as unknown as BoardDocument;
+}
+
+export function deserialize(text: string): Board {
+  let parsed: unknown;
+  try {
+    parsed = JSON.parse(text);
+  } catch {
+    throw new Error('input is not valid JSON');
+  }
+  return Board.restore(validate(parsed));
+}
