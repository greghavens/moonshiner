@@ -0,0 +1,198 @@
+export interface ColumnConfig {
+  id: string;
+  wipLimit?: number;
+}
+
+export interface BoardConfig {
+  columns: ColumnConfig[];
+  lanes?: string[];
+}
+
+export interface Position {
+  column: string;
+  lane: string;
+}
+
+export type HistoryEvent =
+  | { seq: number; event: 'created'; to: Position }
+  | { seq: number; event: 'moved'; from: Position; to: Position };
+
+export interface CardSnapshot {
+  id: string;
+  title: string;
+  column: string;
+  lane: string;
+}
+
+export interface BoardDocument {
+  columns: ColumnConfig[];
+  lanes: string[];
+  seq: number;
+  cards: (CardSnapshot & { history: HistoryEvent[] })[];
+}
+
+interface Card {
+  id: string;
+  title: string;
+  column: string;
+  lane: string;
+  history: HistoryEvent[];
+}
+
+export class Board {
+  private columnOrder: string[] = [];
+  private wipLimits = new Map<string, number | null>();
+  private lanes: string[];
+  private cardsById = new Map<string, Card>();
+  private arrival = new Map<string, string[]>(); // column id -> card ids in arrival order
+  private seq = 0;
+
+  constructor(config: BoardConfig) {
+    if (!config.columns || config.columns.length === 0) {
+      throw new Error('a board needs at least one column');
+    }
+    for (const col of config.columns) {
+      if (this.wipLimits.has(col.id)) throw new Error(`duplicate column "${col.id}"`);
+      if (col.wipLimit !== undefined && (!Number.isInteger(col.wipLimit) || col.wipLimit < 1)) {
+        throw new Error(`column "${col.id}" has an invalid wipLimit`);
+      }
+      this.wipLimits.set(col.id, col.wipLimit ?? null);
+      this.columnOrder.push(col.id);
+      this.arrival.set(col.id, []);
+    }
+    const lanes = config.lanes ?? ['default'];
+    const seen = new Set<string>();
+    for (const lane of lanes) {
+      if (seen.has(lane)) throw new Error(`duplicate lane "${lane}"`);
+      seen.add(lane);
+    }
+    this.lanes = [...lanes];
+  }
+
+  private requireColumn(id: string): void {
+    if (!this.wipLimits.has(id)) throw new Error(`unknown column "${id}"`);
+  }
+
+  private requireLane(lane: string): void {
+    if (!this.lanes.includes(lane)) throw new Error(`unknown lane "${lane}"`);
+  }
+
+  private card(id: string): Card {
+    const card = this.cardsById.get(id);
+    if (!card) throw new Error(`unknown card "${id}"`);
+    return card;
+  }
+
+  private hasSpace(column: string): boolean {
+    const limit = this.wipLimits.get(column);
+    return limit === null || this.arrival.get(column)!.length < (limit as number);
+  }
+
+  addCard(input: { id: string; title: string; column?: string; lane?: string }): void {
+    if (this.cardsById.has(input.id)) throw new Error(`duplicate card id "${input.id}"`);
+    const column = input.column ?? this.columnOrder[0];
+    this.requireColumn(column);
+    const lane = input.lane ?? this.lanes[0];
+    this.requireLane(lane);
+    if (!this.hasSpace(column)) throw new Error(`WIP limit reached on column "${column}"`);
+
+    const card: Card = {
+      id: input.id,
+      title: input.title,
+      column,
+      lane,
+      history: [{ seq: ++this.seq, event: 'created', to: { column, lane } }],
+    };
+    this.cardsById.set(input.id, card);
+    this.arrival.get(column)!.push(input.id);
+  }
+
+  move(id: string, to: { column?: string; lane?: string }): void {
+    const card = this.card(id);
+    if (to.column === undefined && to.lane === undefined) {
+      throw new Error('move needs a target column and/or lane');
+    }
+    const column = to.column ?? card.column;
+    const lane = to.lane ?? card.lane;
+    this.requireColumn(column);
+    this.requireLane(lane);
+    if (column === card.column && lane === card.lane) {
+      throw new Error(`card "${id}" is already in ${column}/${lane}`);
+    }
+    if (column !== card.column && !this.hasSpace(column)) {
+      throw new Error(`WIP limit reached on column "${column}"`);
+    }
+
+    const from: Position = { column: card.column, lane: card.lane };
+    if (column !== card.column) {
+      const source = this.arrival.get(card.column)!;
+      source.splice(source.indexOf(id), 1);
+      this.arrival.get(column)!.push(id);
+    }
+    card.column = column;
+    card.lane = lane;
+    card.history.push({ seq: ++this.seq, event: 'moved', from, to: { column, lane } });
+  }
+
+  find(id: string): CardSnapshot {
+    const card = this.card(id);
+    return { id: card.id, title: card.title, column: card.column, lane: card.lane };
+  }
+
+  count(column: string): number {
+    this.requireColumn(column);
+    return this.arrival.get(column)!.length;
+  }
+
+  cards(column?: string, lane?: string): CardSnapshot[] {
+    if (column !== undefined) this.requireColumn(column);
+    if (lane !== undefined) this.requireLane(lane);
+    const walk = column !== undefined ? [column] : this.columnOrder;
+    const out: CardSnapshot[] = [];
+    for (const col of walk) {
+      for (const id of this.arrival.get(col)!) {
+        const card = this.cardsById.get(id)!;
+        if (lane !== undefined && card.lane !== lane) continue;
+        out.push(this.find(id));
+      }
+    }
+    return out;
+  }
+
+  history(id: string): HistoryEvent[] {
+    return this.card(id).history.map((event) => structuredClone(event));
+  }
+
+  /** Plain-data image of the whole board, used by the JSON snapshot layer. */
+  snapshot(): BoardDocument {
+    return {
+      columns: this.columnOrder.map((id) => {
+        const limit = this.wipLimits.get(id);
+        return limit === null ? { id } : { id, wipLimit: limit as number };
+      }),
+      lanes: [...this.lanes],
+      seq: this.seq,
+      cards: this.cards().map((card) => ({ ...card, history: this.history(card.id) })),
+    };
+  }
+
+  /** Rebuild a live board from a (validated) document. */
+  static restore(doc: BoardDocument): Board {
+    const board = new Board({ columns: doc.columns, lanes: doc.lanes });
+    for (const card of doc.cards) {
+      if (board.cardsById.has(card.id)) throw new Error(`duplicate card id "${card.id}"`);
+      board.requireColumn(card.column);
+      board.requireLane(card.lane);
+      board.cardsById.set(card.id, {
+        id: card.id,
+        title: card.title,
+        column: card.column,
+        lane: card.lane,
+        history: card.history.map((event) => structuredClone(event)),
+      });
+      board.arrival.get(card.column)!.push(card.id);
+    }
+    board.seq = doc.seq;
+    return board;
+  }
+}
