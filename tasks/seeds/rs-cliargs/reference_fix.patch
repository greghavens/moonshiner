+    /// Deterministic usage text, assembled purely from the declarations, in
+    /// declaration order. Ends with a newline.
+    pub fn usage(&self) -> String {
+        let mut out = String::new();
+        if !self.about.is_empty() {
+            out.push_str(&self.about);
+            out.push_str("\n\n");
+        }
+        out.push_str("Usage: ");
+        out.push_str(&self.name);
+        if !self.flags.is_empty() {
+            out.push_str(" [OPTIONS]");
+        }
+        for p in &self.positionals {
+            out.push_str(" <");
+            out.push_str(&p.name);
+            out.push('>');
+        }
+        out.push('\n');
+        if !self.subcommands.is_empty() {
+            out.push_str("       ");
+            out.push_str(&self.name);
+            out.push_str(" <COMMAND>\n");
+            let rows: Vec<(String, &str)> = self
+                .subcommands
+                .iter()
+                .map(|s| (s.name.clone(), s.about.as_str()))
+                .collect();
+            push_section(&mut out, "Commands:", &rows);
+        }
+        if !self.positionals.is_empty() {
+            let rows: Vec<(String, &str)> = self
+                .positionals
+                .iter()
+                .map(|p| (format!("<{}>", p.name), p.help.as_str()))
+                .collect();
+            push_section(&mut out, "Arguments:", &rows);
+        }
+        if !self.flags.is_empty() {
+            let rows: Vec<(String, &str)> = self
+                .flags
+                .iter()
+                .map(|fl| {
+                    let cell = match &fl.kind {
+                        FlagKind::Switch => format!("--{}", fl.name),
+                        FlagKind::Value { value_name } => {
+                            format!("--{} <{}>", fl.name, value_name)
+                        }
+                    };
+                    (cell, fl.help.as_str())
+                })
+                .collect();
+            push_section(&mut out, "Options:", &rows);
+        }
+        out
+    }
+}
+
+/// Append one help section: a blank line, the header, then aligned rows.
+fn push_section(out: &mut String, header: &str, rows: &[(String, &str)]) {
+    out.push('\n');
+    out.push_str(header);
+    out.push('\n');
+    let width = rows.iter().map(|(cell, _)| cell.len()).max().unwrap_or(0);
+    for (cell, help) in rows {
+        if help.is_empty() {
+            out.push_str(&format!("  {cell}\n"));
+        } else {
+            out.push_str(&format!("  {cell:<width$}  {help}\n"));
+        }
+    }
 }
 
