index 0000000..aa48a91
--- /dev/null
+++ b/DepotOps.psm1
@@ -0,0 +1,200 @@
+# DepotOps.psm1 -- spare-parts depot operations, as a reusable module.
+#
+# Public surface (see DepotOps.psd1):
+#   Import-DepotStock, Import-DepotOrders, Get-DepotReport,
+#   Get-DepotShortfall, Get-DepotFindings
+#
+# Everything else in this file is a private helper.
+
+Set-StrictMode -Version Latest
+
+function Test-DepotIntText {
+    param([string]$Value)
+    $parsed = 0
+    return [int]::TryParse($Value, [ref]$parsed)
+}
+
+function Read-DepotCsvRows {
+    param([string]$Path, [string[]]$Columns)
+    if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+        throw "file not found: $Path"
+    }
+    $rows = @(Import-Csv -LiteralPath $Path)
+    if ($rows.Count -gt 0) {
+        $have = @($rows[0].PSObject.Properties.Name)
+        foreach ($col in $Columns) {
+            if ($have -cnotcontains $col) {
+                $leaf = Split-Path -Leaf $Path
+                throw "${leaf}: missing column '$col'"
+            }
+        }
+    }
+    return $rows
+}
+
+function Sort-DepotBySku {
+    param([object[]]$Records)
+    $list = [System.Collections.Generic.List[object]]::new()
+    foreach ($r in $Records) { [void]$list.Add($r) }
+    $list.Sort([System.Comparison[object]]{
+        param($a, $b)
+        [string]::CompareOrdinal($a.Sku, $b.Sku)
+    })
+    return $list.ToArray()
+}
+
+function Sort-DepotOrdinal {
+    param([string[]]$Values)
+    $copy = @($Values)
+    [Array]::Sort($copy, [System.StringComparer]::Ordinal)
+    return $copy
+}
+
+function Import-DepotStock {
+    param([Parameter(Mandatory)][string]$Path)
+    $rows = @(Read-DepotCsvRows -Path $Path -Columns @('sku', 'desc', 'qty', 'min'))
+    $leaf = Split-Path -Leaf $Path
+    $records = @()
+    $line = 1   # the header sits on line 1
+    foreach ($row in $rows) {
+        $line++
+        if ([string]::IsNullOrEmpty($row.sku) -or
+            -not (Test-DepotIntText $row.qty) -or
+            -not (Test-DepotIntText $row.min)) {
+            throw "${leaf}: bad row $line"
+        }
+        $records += [pscustomobject]@{
+            Sku  = [string]$row.sku
+            Desc = [string]$row.desc
+            Qty  = [int]$row.qty
+            Min  = [int]$row.min
+        }
+    }
+    return $records
+}
+
+function Import-DepotOrders {
+    param([Parameter(Mandatory)][string]$Path)
+    $rows = @(Read-DepotCsvRows -Path $Path -Columns @('order', 'sku', 'qty'))
+    $leaf = Split-Path -Leaf $Path
+    $records = @()
+    $line = 1
+    foreach ($row in $rows) {
+        $line++
+        if ([string]::IsNullOrEmpty($row.order) -or
+            [string]::IsNullOrEmpty($row.sku) -or
+            -not (Test-DepotIntText $row.qty)) {
+            throw "${leaf}: bad row $line"
+        }
+        $records += [pscustomobject]@{
+            Order = [string]$row.order
+            Sku   = [string]$row.sku
+            Qty   = [int]$row.qty
+        }
+    }
+    return $records
+}
+
+function Get-DepotReport {
+    param([Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Stock)
+    $report = @()
+    foreach ($r in @(Sort-DepotBySku $Stock)) {
+        $status = if ($r.Qty -lt $r.Min) { 'LOW' } else { 'ok' }
+        $report += [pscustomobject]@{
+            Sku    = $r.Sku
+            Qty    = $r.Qty
+            Min    = $r.Min
+            Status = $status
+        }
+    }
+    return $report
+}
+
+function Get-DepotShortfall {
+    param(
+        [Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Stock,
+        [Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Orders
+    )
+    $known = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+    foreach ($r in $Stock) { [void]$known.Add($r.Sku) }
+
+    $unknown = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+    $reserved = [System.Collections.Generic.Dictionary[string, int]]::new([System.StringComparer]::Ordinal)
+    foreach ($o in $Orders) {
+        if (-not $known.Contains($o.Sku)) {
+            [void]$unknown.Add($o.Sku)
+            continue
+        }
+        if ($reserved.ContainsKey($o.Sku)) {
+            $reserved[$o.Sku] = $reserved[$o.Sku] + $o.Qty
+        } else {
+            $reserved[$o.Sku] = $o.Qty
+        }
+    }
+    if ($unknown.Count -gt 0) {
+        $bad = @(Sort-DepotOrdinal @($unknown))
+        throw "unknown sku in orders: $($bad[0])"
+    }
+
+    $result = @()
+    foreach ($r in @(Sort-DepotBySku $Stock)) {
+        $held = if ($reserved.ContainsKey($r.Sku)) { $reserved[$r.Sku] } else { 0 }
+        $available = $r.Qty - $held
+        if ($available -lt $r.Min) {
+            $result += [pscustomobject]@{
+                Sku  = $r.Sku
+                Need = [int]($r.Min - $available)
+            }
+        }
+    }
+    return $result
+}
+
+function Get-DepotFindings {
+    param(
+        [Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Stock,
+        [object[]]$Orders
+    )
+    $found = @()
+
+    $skuCount = [System.Collections.Generic.Dictionary[string, int]]::new([System.StringComparer]::Ordinal)
+    foreach ($r in $Stock) {
+        if ($skuCount.ContainsKey($r.Sku)) {
+            $skuCount[$r.Sku] = $skuCount[$r.Sku] + 1
+        } else {
+            $skuCount[$r.Sku] = 1
+        }
+        if ($r.Qty -lt 0) { $found += [pscustomobject]@{ Kind = 'neg-qty'; Subject = $r.Sku } }
+        if ($r.Min -lt 0) { $found += [pscustomobject]@{ Kind = 'neg-min'; Subject = $r.Sku } }
+    }
+    foreach ($sku in $skuCount.Keys) {
+        if ($skuCount[$sku] -gt 1) { $found += [pscustomobject]@{ Kind = 'dup-sku'; Subject = $sku } }
+    }
+
+    if ($null -ne $Orders) {
+        $known = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+        foreach ($r in $Stock) { [void]$known.Add($r.Sku) }
+        $orderCount = [System.Collections.Generic.Dictionary[string, int]]::new([System.StringComparer]::Ordinal)
+        foreach ($o in $Orders) {
+            if ($orderCount.ContainsKey($o.Order)) {
+                $orderCount[$o.Order] = $orderCount[$o.Order] + 1
+            } else {
+                $orderCount[$o.Order] = 1
+            }
+            if (-not $known.Contains($o.Sku)) {
+                $found += [pscustomobject]@{ Kind = 'unknown-sku'; Subject = "$($o.Order) $($o.Sku)" }
+            }
+        }
+        foreach ($id in $orderCount.Keys) {
+            if ($orderCount[$id] -gt 1) { $found += [pscustomobject]@{ Kind = 'dup-order'; Subject = $id } }
+        }
+    }
+
+    $list = [System.Collections.Generic.List[object]]::new()
+    foreach ($f in $found) { [void]$list.Add($f) }
+    $list.Sort([System.Comparison[object]]{
+        param($a, $b)
+        [string]::CompareOrdinal("$($a.Kind) $($a.Subject)", "$($b.Kind) $($b.Subject)")
+    })
+    return $list.ToArray()
+}
