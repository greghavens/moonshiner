+"""Secret-metadata inventory over the Key Vault list endpoints.
+
+Pages /secrets and /deletedsecrets with the current GA api-version
+(2025-07-01), follows nextLink verbatim, and never touches a secret value.
+"""
+
+import urllib.parse
+
+from kvclient import API_VERSION
+
+
+class VaultRequestError(Exception):
+    """A Key Vault request failed; carries the documented error body."""
+
+    def __init__(self, status, code, message):
+        super().__init__("HTTP %d %s: %s" % (status, code, message))
+        self.status = status
+        self.code = code
+        self.message = message
+
+
+class VaultAuthenticationError(VaultRequestError):
+    """401: the token was missing, invalid, or expired."""
+
+
+class VaultAuthorizationError(VaultRequestError):
+    """403: authenticated but not permitted (RBAC/access policy or firewall)."""
+
+
+class VaultThrottledError(VaultRequestError):
+    """429: over the vault's transaction limits; back off before retrying."""
+
+    def __init__(self, status, code, message, retry_after):
+        super().__init__(status, code, message)
+        self.retry_after = retry_after
+
+
+def collect_inventory(session, include_deleted=False, max_page_size=None):
+    active = [
+        _secret_entry(raw)
+        for raw in _pages(session, "/secrets", max_page_size)
+    ]
+    deleted = []
+    if include_deleted:
+        deleted = [
+            _deleted_entry(raw)
+            for raw in _pages(session, "/deletedsecrets", max_page_size)
+        ]
+    return {"vault": session.vault_url, "active": active, "deleted": deleted}
+
+
+def _pages(session, path, max_page_size):
+    query = {"api-version": API_VERSION}
+    if max_page_size is not None:
+        query["maxresults"] = str(max_page_size)
+    url = "%s%s?%s" % (session.vault_url, path, urllib.parse.urlencode(query))
+    while url:
+        status, headers, body = session.get_json(url)
+        if status != 200:
+            raise _map_error(status, headers, body)
+        for raw in body.get("value") or []:
+            yield raw
+        # nextLink is opaque: the service owns its query string (including a
+        # possibly different api-version); follow it byte-for-byte.
+        url = body.get("nextLink") or None
+
+
+def _map_error(status, headers, body):
+    error = body.get("error") or {}
+    code = error.get("code") or ""
+    message = error.get("message") or ""
+    if status == 401:
+        return VaultAuthenticationError(status, code, message)
+    if status == 403:
+        return VaultAuthorizationError(status, code, message)
+    if status == 429:
+        return VaultThrottledError(status, code, message, _retry_after(headers))
+    return VaultRequestError(status, code, message)
+
+
+def _retry_after(headers):
+    for name, value in headers.items():
+        if name.lower() == "retry-after":
+            try:
+                return int(value)
+            except (TypeError, ValueError):
+                return None
+    return None
+
+
+def _secret_entry(raw):
+    attributes = raw.get("attributes") or {}
+    secret_id = raw.get("id") or ""
+    return {
+        "name": secret_id.rstrip("/").rsplit("/", 1)[-1],
+        "id": secret_id,
+        "enabled": attributes.get("enabled"),
+        "created": attributes.get("created"),
+        "updated": attributes.get("updated"),
+        "not_before": attributes.get("nbf"),
+        "expires": attributes.get("exp"),
+        "tags": dict(raw.get("tags") or {}),
+        "content_type": raw.get("contentType"),
+        "managed": raw.get("managed"),
+    }
+
+
+def _deleted_entry(raw):
+    entry = _secret_entry(raw)
+    entry["recovery_id"] = raw.get("recoveryId")
+    entry["deleted_date"] = raw.get("deletedDate")
+    entry["scheduled_purge_date"] = raw.get("scheduledPurgeDate")
+    return entry
