diff --git a/csvrow.c b/csvrow.c
new file mode 100644
index 0000000..c52cc1d
--- /dev/null
+++ b/csvrow.c
@@ -0,0 +1,84 @@
+#include "csvrow.h"
+
+int csv_row_parse(char *buf, size_t buflen, size_t *pos,
+                  csv_span *fields, size_t max_fields) {
+    size_t i = *pos;
+    if (i >= buflen)
+        return 0;
+
+    size_t nf = 0;
+    for (;;) {
+        if (nf == max_fields)
+            return -1; /* record has more fields than the caller's array */
+
+        size_t fstart;
+        size_t flen;
+        if (i < buflen && buf[i] == '"') {
+            /* Quoted field: decode in place right after the opening
+             * quote; doubled quotes collapse as we copy. */
+            i++;
+            fstart = i;
+            size_t w = i;
+            for (;;) {
+                if (i >= buflen)
+                    return -1; /* quote never closed */
+                char c = buf[i];
+                if (c == '"') {
+                    if (i + 1 < buflen && buf[i + 1] == '"') {
+                        buf[w++] = '"';
+                        i += 2;
+                    } else {
+                        i++; /* closing quote */
+                        break;
+                    }
+                } else {
+                    buf[w++] = c;
+                    i++;
+                }
+            }
+            flen = w - fstart;
+            /* Only a delimiter (or end of buffer) may follow. */
+            if (i < buflen) {
+                char c = buf[i];
+                int crlf = (c == '\r' && i + 1 < buflen && buf[i + 1] == '\n');
+                if (c != ',' && c != '\n' && !crlf)
+                    return -1;
+            }
+        } else {
+            /* Unquoted field: bytes up to a comma or record end. A CR
+             * only matters as the first half of CRLF. */
+            fstart = i;
+            while (i < buflen) {
+                char c = buf[i];
+                if (c == ',' || c == '\n')
+                    break;
+                if (c == '\r' && i + 1 < buflen && buf[i + 1] == '\n')
+                    break;
+                i++;
+            }
+            flen = i - fstart;
+        }
+
+        fields[nf].start = fstart;
+        fields[nf].len = flen;
+        nf++;
+
+        if (i >= buflen) {
+            *pos = i;
+            return (int)nf;
+        }
+        char c = buf[i];
+        if (c == ',') {
+            i++;
+            continue;
+        }
+        if (c == '\n') {
+            *pos = i + 1;
+            return (int)nf;
+        }
+        /* Here c must be the CR of a CRLF (both field scanners stop
+         * only on the delimiters checked above). */
+        *pos = i + 2;
+        return (int)nf;
+    }
+}
diff --git a/csvrow.h b/csvrow.h
new file mode 100644
index 0000000..bfac638
--- /dev/null
+++ b/csvrow.h
@@ -0,0 +1,26 @@
+/* csvrow.h — in-place CSV record parser (spans, no per-field heap). */
+#ifndef CSVROW_H
+#define CSVROW_H
+
+#include <stddef.h>
+
+typedef struct {
+    size_t start; /* byte offset into buf */
+    size_t len;
+} csv_span;
+
+/* Parse one CSV record starting at buf[*pos].
+ *
+ * Returns the field count (>= 1) and advances *pos past the record and
+ * its terminator (unquoted LF or CRLF, or end of buffer). Returns 0 if
+ * *pos is already at buflen. Returns -1 on a malformed record
+ * (unterminated quote, junk after a closing quote, more than
+ * max_fields fields) with *pos unchanged.
+ *
+ * Quoted fields are decoded in place ("" -> ") and each span points at
+ * the decoded bytes inside the record's own byte range. The buffer is
+ * length-bounded (no NUL expected) and spans are not NUL-terminated. */
+int csv_row_parse(char *buf, size_t buflen, size_t *pos,
+                  csv_span *fields, size_t max_fields);
+
+#endif /* CSVROW_H */
