+namespace SnowCmdb;
+
+/// <summary>
+/// A non-2xx answer from the instance, carrying ServiceNow's error envelope
+/// fields ({"error": {"message", "detail"}, "status": "failure"}).
+/// Exception text never contains credentials.
+/// </summary>
+public class SnowApiError : Exception
+{
+    public SnowApiError(int statusCode, string message, string detail)
+        : base(message)
+    {
+        StatusCode = statusCode;
+        Detail = detail;
+    }
+
+    public int StatusCode { get; }
+    public string Detail { get; }
+}
+
+public sealed class SnowRateLimitError : SnowApiError
+{
+    public SnowRateLimitError(string message, string detail, int retryAfterSeconds)
+        : base(429, message, detail)
+    {
+        RetryAfterSeconds = retryAfterSeconds;
+    }
+
+    public int RetryAfterSeconds { get; }
+}
