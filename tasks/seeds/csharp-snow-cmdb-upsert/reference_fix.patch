+namespace SnowCmdb;
+
+/// <summary>One configuration item to identify and reconcile into the CMDB.</summary>
+public sealed class CmdbItem
+{
+    public required string ClassName { get; init; }
+    public required string SourceNativeKey { get; init; }
+    public required IReadOnlyDictionary<string, object?> Values { get; init; }
+}
+
+public sealed class ReconcileError
+{
+    public ReconcileError(string error, string message)
+    {
+        Error = error;
+        Message = message;
+    }
+
+    public string Error { get; }
+    public string Message { get; }
+}
+
+/// <summary>Per-item outcome, in request order.</summary>
+public sealed class ItemResult
+{
+    public ItemResult(string className, string? sysId, string? operation,
+        IReadOnlyList<ReconcileError> errors)
+    {
+        ClassName = className;
+        SysId = sysId;
+        Operation = operation;
+        Errors = errors;
+    }
+
+    public string ClassName { get; }
+    public string? SysId { get; }
+    public string? Operation { get; }
+    public IReadOnlyList<ReconcileError> Errors { get; }
+}
+
+public sealed class ReconcileReport
+{
+    public ReconcileReport(IReadOnlyList<ItemResult> items, bool hasErrors)
+    {
+        Items = items;
+        HasErrors = hasErrors;
+        foreach (var item in items)
+        {
+            if (item.Errors.Count > 0) Failed++;
+            else if (item.Operation == "INSERT") Inserted++;
+            else if (item.Operation == "NO_CHANGE") Unchanged++;
+            else if (item.Operation is not null && item.Operation.StartsWith("UPDATE",
+                         StringComparison.Ordinal)) Updated++;
+        }
+    }
+
+    public IReadOnlyList<ItemResult> Items { get; }
+    public bool HasErrors { get; }
+    public int Inserted { get; }
+    public int Updated { get; }
+    public int Unchanged { get; }
+    public int Failed { get; }
+}
