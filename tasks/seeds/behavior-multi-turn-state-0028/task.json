{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0028",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "shipping",
  "prompt": "Search for the exact shipment “Northstar Parts Pallet” at Denver Terminal, then open the matching record before reporting its ID, date, and status. Do not change it on this turn. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 2,
      "content": "Thanks. Move that same shipment to 2026-10-18; change no other field and send no notification."
    },
    {
      "after_stage": 3,
      "content": "One correction: the date should be 2026-11-22, not 2026-10-18. Keep the same record and do not notify anyone."
    }
  ],
  "available_tools": [
    "shipping_search",
    "shipping_get",
    "shipping_list",
    "shipping_update",
    "shipping_cancel",
    "shipping_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "shi-128",
        "name": "Northstar Parts Pallet",
        "location": "Denver Terminal",
        "date": "2026-08-15",
        "status": "active"
      },
      {
        "id": "shi-528",
        "name": "Northstar Parts Pallet",
        "location": "Boise Terminal",
        "date": "2026-09-22",
        "status": "active"
      },
      {
        "id": "shi-828",
        "name": "Summit Tools Pallet",
        "location": "Denver Terminal",
        "date": "2026-09-22",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_search",
            "arguments": {
              "query": "Northstar Parts Pallet",
              "location": "Denver Terminal"
            }
          }
        ],
        "purpose": "Find the stable identifier for the uniquely located record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_get",
            "arguments": {
              "id": "shi-128"
            }
          }
        ],
        "purpose": "Retrieve the exact record identified by the search; this call depends on the search result."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-128",
              "date": "2026-10-18"
            }
          }
        ],
        "purpose": "Update only the resolved record after the user's follow-up."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-128",
              "date": "2026-11-22"
            }
          }
        ],
        "purpose": "Replace the earlier date with the user's later correction."
      }
    ],
    "state_assertions": [
      "shi-128.date == 2026-11-22",
      "shi-128.location == Denver Terminal",
      "shi-128.status == active",
      "shi-528.date == 2026-09-22",
      "shi-828.date == 2026-09-22",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "shipping_notify",
      "shipping_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "Do not skip the record retrieval or use an ID belonging to a distractor.",
      "State that the later date replaced the earlier instruction."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:search-get-update"
  ]
}
