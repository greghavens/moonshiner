+// ICU-MessageFormat-lite: {name}, {n, plural, ...}, {v, select, ...} with
+// nesting, ICU apostrophe quoting, a CLDR-lite plural table for en/pl/ar,
+// and parse errors carrying exact 1-based line:col positions.
+
+export class MessageFormatError extends Error {
+  line: number;
+  col: number;
+
+  constructor(line: number, col: number, detail: string) {
+    super(`parse error at ${line}:${col}: ${detail}`);
+    this.name = 'MessageFormatError';
+    this.line = line;
+    this.col = col;
+  }
+}
+
+// ---------- plural rules ----------
+
+const PLURAL_RULES: Record<string, (n: number) => string> = {
+  en: (n) => (n === 1 ? 'one' : 'other'),
+  pl: (n) => {
+    if (n === 1) return 'one';
+    const d10 = n % 10;
+    const d100 = n % 100;
+    if (d10 >= 2 && d10 <= 4 && !(d100 >= 12 && d100 <= 14)) return 'few';
+    return 'many';
+  },
+  ar: (n) => {
+    if (n === 0) return 'zero';
+    if (n === 1) return 'one';
+    if (n === 2) return 'two';
+    const d100 = n % 100;
+    if (d100 >= 3 && d100 <= 10) return 'few';
+    if (d100 >= 11 && d100 <= 99) return 'many';
+    return 'other';
+  },
+};
+
+function languageOf(locale: string): string {
+  return String(locale).split('-')[0].toLowerCase();
+}
+
+export function pluralCategory(locale: string, n: number): string {
+  const rules = PLURAL_RULES[languageOf(locale)];
+  if (!rules) throw new Error(`unsupported locale "${locale}"`);
+  const abs = Math.abs(n);
+  if (!Number.isInteger(abs)) return 'other';
+  return rules(abs);
+}
+
+// ---------- AST ----------
+
+type Branch = { selector: string; body: Node[] };
+
+type Node =
+  | { kind: 'text'; text: string }
+  | { kind: 'arg'; name: string }
+  | { kind: 'pound' }
+  | { kind: 'plural'; name: string; branches: Branch[] }
+  | { kind: 'select'; name: string; branches: Branch[] };
+
+// ---------- parser ----------
+
+const NAME_START = /[A-Za-z_]/;
+const NAME_CHAR = /[A-Za-z0-9_]/;
+const CATEGORIES = new Set(['zero', 'one', 'two', 'few', 'many', 'other']);
+
+type Pos = { line: number; col: number };
+
+class Parser {
+  private src: string;
+  private i = 0;
+  private line = 1;
+  private col = 1;
+
+  constructor(src: string) {
+    this.src = src;
+  }
+
+  parse(): Node[] {
+    const nodes = this.parseMessage(false, 0);
+    return nodes;
+  }
+
+  private pos(): Pos {
+    return { line: this.line, col: this.col };
+  }
+
+  private fail(at: Pos, detail: string): never {
+    throw new MessageFormatError(at.line, at.col, detail);
+  }
+
+  private peek(): string | undefined {
+    return this.src[this.i];
+  }
+
+  private advance(): string {
+    const c = this.src[this.i++];
+    if (c === '\n') {
+      this.line++;
+      this.col = 1;
+    } else {
+      this.col++;
+    }
+    return c;
+  }
+
+  private atEnd(): boolean {
+    return this.i >= this.src.length;
+  }
+
+  private skipWs(): void {
+    while (!this.atEnd() && /\s/.test(this.src[this.i])) this.advance();
+  }
+
+  // Parses until an unmatched '}' (left unconsumed, depth > 0) or EOF.
+  private parseMessage(insidePlural: boolean, depth: number): Node[] {
+    const nodes: Node[] = [];
+    let text = '';
+    const flush = () => {
+      if (text !== '') {
+        nodes.push({ kind: 'text', text });
+        text = '';
+      }
+    };
+
+    while (!this.atEnd()) {
+      const c = this.peek();
+      if (c === '}') {
+        if (depth > 0) break;
+        this.fail(this.pos(), "unexpected '}'");
+      } else if (c === '{') {
+        flush();
+        nodes.push(this.parseArg(insidePlural));
+      } else if (c === '#' && insidePlural) {
+        flush();
+        nodes.push({ kind: 'pound' });
+        this.advance();
+      } else if (c === "'") {
+        const next = this.src[this.i + 1];
+        if (next === "'") {
+          text += "'";
+          this.advance();
+          this.advance();
+        } else if (next === '{' || next === '}' || (next === '#' && insidePlural)) {
+          text += this.quotedLiteral();
+        } else {
+          text += "'";
+          this.advance();
+        }
+      } else {
+        text += this.advance();
+      }
+    }
+    flush();
+    return nodes;
+  }
+
+  // At an opening apostrophe that starts a quoted literal.
+  private quotedLiteral(): string {
+    const open = this.pos();
+    this.advance(); // the opening apostrophe
+    let out = '';
+    while (!this.atEnd()) {
+      const c = this.peek();
+      if (c === "'") {
+        if (this.src[this.i + 1] === "'") {
+          out += "'";
+          this.advance();
+          this.advance();
+        } else {
+          this.advance(); // closing apostrophe
+          return out;
+        }
+      } else {
+        out += this.advance();
+      }
+    }
+    this.fail(open, 'unclosed quoted literal');
+  }
+
+  private parseArg(insidePlural: boolean): Node {
+    const open = this.pos();
+    this.advance(); // '{'
+    this.skipWs();
+
+    const namePos = this.pos();
+    const name = this.readName();
+    if (name === '') this.fail(namePos, 'empty argument name');
+    this.skipWs();
+
+    if (this.peek() === '}') {
+      this.advance();
+      return { kind: 'arg', name };
+    }
+    if (this.peek() !== ',') this.fail(this.pos(), "expected '}'");
+    this.advance(); // ','
+    this.skipWs();
+
+    const typePos = this.pos();
+    const type = this.readWord();
+    if (type !== 'plural' && type !== 'select') {
+      this.fail(typePos, `unknown argument type "${type}"`);
+    }
+    this.skipWs();
+    if (this.peek() !== ',') this.fail(this.pos(), "expected ','");
+    this.advance(); // ','
+
+    const branches: Branch[] = [];
+    const seen = new Set<string>();
+    const childInsidePlural = type === 'plural' ? true : insidePlural;
+
+    for (;;) {
+      this.skipWs();
+      if (this.atEnd()) this.fail(this.pos(), "expected '}'");
+      if (this.peek() === '}') {
+        this.advance();
+        if (!seen.has('other')) {
+          this.fail(open, `${type} requires an "other" branch`);
+        }
+        return { kind: type, name, branches };
+      }
+
+      const selPos = this.pos();
+      const selector = this.readSelector();
+      const valid =
+        type === 'plural'
+          ? CATEGORIES.has(selector) || /^=\d+$/.test(selector)
+          : /^[A-Za-z0-9_]+$/.test(selector);
+      if (!valid) this.fail(selPos, `invalid selector "${selector}"`);
+      if (seen.has(selector)) this.fail(selPos, `duplicate selector "${selector}"`);
+      seen.add(selector);
+
+      this.skipWs();
+      if (this.peek() !== '{') this.fail(this.pos(), "expected '{' after selector");
+      this.advance(); // '{'
+      const body = this.parseMessage(childInsidePlural, 1);
+      if (this.atEnd()) this.fail(this.pos(), "expected '}'");
+      this.advance(); // '}'
+      branches.push({ selector, body });
+    }
+  }
+
+  private readName(): string {
+    if (this.atEnd() || !NAME_START.test(this.src[this.i])) return '';
+    let out = '';
+    while (!this.atEnd() && NAME_CHAR.test(this.src[this.i])) out += this.advance();
+    return out;
+  }
+
+  private readWord(): string {
+    let out = '';
+    while (!this.atEnd() && NAME_CHAR.test(this.src[this.i])) out += this.advance();
+    return out;
+  }
+
+  private readSelector(): string {
+    let out = '';
+    while (
+      !this.atEnd() &&
+      !/\s/.test(this.src[this.i]) &&
+      this.src[this.i] !== '{' &&
+      this.src[this.i] !== '}'
+    ) {
+      out += this.advance();
+    }
+    return out;
+  }
+}
+
+// ---------- formatter ----------
+
+export class MessageFormat {
+  private ast: Node[];
+  private locale: string;
+
+  constructor(src: string, locale: string) {
+    if (!PLURAL_RULES[languageOf(locale)]) {
+      throw new Error(`unsupported locale "${locale}"`);
+    }
+    this.locale = locale;
+    this.ast = new Parser(src).parse();
+  }
+
+  format(values: Record<string, unknown> = {}): string {
+    return this.render(this.ast, values, null);
+  }
+
+  private render(nodes: Node[], values: Record<string, unknown>, pound: number | null): string {
+    let out = '';
+    for (const node of nodes) {
+      switch (node.kind) {
+        case 'text':
+          out += node.text;
+          break;
+        case 'pound':
+          out += String(pound);
+          break;
+        case 'arg':
+          out += String(this.lookup(values, node.name));
+          break;
+        case 'select': {
+          const value = String(this.lookup(values, node.name));
+          const branch =
+            node.branches.find((b) => b.selector === value) ??
+            node.branches.find((b) => b.selector === 'other');
+          out += this.render((branch as Branch).body, values, pound);
+          break;
+        }
+        case 'plural': {
+          const raw = this.lookup(values, node.name);
+          if (typeof raw !== 'number' || !Number.isFinite(raw)) {
+            throw new Error(`plural argument "${node.name}" must be a number`);
+          }
+          const exact = node.branches.find((b) => b.selector === `=${raw}`);
+          const category = pluralCategory(this.locale, raw);
+          const branch =
+            exact ??
+            node.branches.find((b) => b.selector === category) ??
+            node.branches.find((b) => b.selector === 'other');
+          out += this.render((branch as Branch).body, values, raw);
+          break;
+        }
+      }
+    }
+    return out;
+  }
+
+  private lookup(values: Record<string, unknown>, name: string): unknown {
+    if (!Object.prototype.hasOwnProperty.call(values, name)) {
+      throw new Error(`unknown variable "${name}"`);
+    }
+    return values[name];
+  }
+}
