+using System.Globalization;
+
 /// <summary>
 /// Money rendering for the remittance desk. Amounts are integer cents
 /// everywhere; the printed form is "$D.CC" with no thousands separator.
 /// </summary>
 public static class MoneyFmt
 {
-    // TODO per the fulfillment brief: static string Format(long cents).
+    /// <summary>Renders cents as "$12.50", culture-independent.</summary>
+    public static string Format(long cents)
+    {
+        long dollars = cents / 100;
+        long rest = cents % 100;
+        return "$" + dollars.ToString(CultureInfo.InvariantCulture)
+                   + "." + rest.ToString("00", CultureInfo.InvariantCulture);
+    }
 }
