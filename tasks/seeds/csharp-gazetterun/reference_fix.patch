 /// </summary>
 public class Publisher
 {
-    // TODO per the fulfillment brief: ctor(IssueCalendar), Calendar, Routes,
-    // Subscribe / Get / Renew, DeliverableOn / All, CollectedFor /
-    // TotalCollected.
+    private readonly SortedDictionary<string, Subscription> subscriptions =
+            new(StringComparer.Ordinal);
+
+    public Publisher(IssueCalendar calendar)
+    {
+        Calendar = calendar;
+    }
+
+    public IssueCalendar Calendar { get; }
+
+    public RouteBook Routes { get; } = new RouteBook();
+
+    /// <summary>
+    /// Registers a subscriber; the first issue is the next one publishing on
+    /// or after the start day, and the first term accrues immediately.
+    /// </summary>
+    public Subscription Subscribe(string id, string planCode, string routeCode, int startDay)
+    {
+        if (subscriptions.ContainsKey(id))
+        {
+            throw new ArgumentException("subscriber " + id + " already exists");
+        }
+        Plan plan = Plan.ByCode(planCode);
+        if (!Routes.Has(routeCode))
+        {
+            throw new ArgumentException("unknown route " + routeCode);
+        }
+        int firstIssue = Calendar.NextIssueOnOrAfter(startDay);
+        var subscription = new Subscription(id, plan, routeCode, firstIssue);
+        subscriptions[id] = subscription;
+        return subscription;
+    }
+
+    public Subscription Get(string id)
+    {
+        if (!subscriptions.TryGetValue(id, out Subscription? subscription))
+        {
+            throw new ArgumentException("unknown subscriber " + id);
+        }
+        return subscription;
+    }
+
+    /// <summary>Renews by id and returns the charged term price.</summary>
+    public long Renew(string id)
+    {
+        return Get(id).Renew();
+    }
+
+    /// <summary>Deliverable subscriptions for the issue, id-ordinal order.</summary>
+    public IReadOnlyList<Subscription> DeliverableOn(int issueNumber)
+    {
+        return subscriptions.Values.Where(s => s.IsDeliverable(issueNumber)).ToList();
+    }
+
+    /// <summary>Every registered subscription, id-ordinal order.</summary>
+    public IReadOnlyList<Subscription> All()
+    {
+        return subscriptions.Values.ToList();
+    }
+
+    /// <summary>Summed PaidCents of subscriptions on the plan, any state.</summary>
+    public long CollectedFor(string planCode)
+    {
+        return subscriptions.Values
+                .Where(s => s.Plan.Code == planCode)
+                .Sum(s => s.PaidCents);
+    }
+
+    public long TotalCollected()
+    {
+        return subscriptions.Values.Sum(s => s.PaidCents);
+    }
 }
diff --git a/Remittance.cs b/Remittance.cs
index 8a83f87..cc1c8d3 100644
--- a/Remittance.cs
+++ b/Remittance.cs
@@ -1,8 +1,43 @@
+using System.Text;
+
 /// <summary>
 /// The remittance summary export: per-plan collections, state counts, skip
 /// credits, and the grand total in one fixed plaintext format.
 /// </summary>
 public static class Remittance
 {
-    // TODO per the fulfillment brief: static string Render(Publisher).
+    /// <summary>Renders the owners' summary, character-exact.</summary>
+    public static string Render(Publisher publisher)
+    {
+        IReadOnlyList<Subscription> all = publisher.All();
+        var sb = new StringBuilder();
+        sb.Append("== gazetterun remittance ==\n");
+
+        List<string> planCodes = all
+                .Select(s => s.Plan.Code)
+                .Distinct()
+                .OrderBy(c => c, StringComparer.Ordinal)
+                .ToList();
+        foreach (string code in planCodes)
+        {
+            int count = all.Count(s => s.Plan.Code == code);
+            long collected = publisher.CollectedFor(code);
+            sb.Append("plan ").Append(code).Append(": subs ").Append(count)
+                    .Append(", collected ").Append(MoneyFmt.Format(collected)).Append('\n');
+        }
+
+        int active = all.Count(s => s.State == SubState.Active);
+        int paused = all.Count(s => s.State == SubState.Paused);
+        int cancelled = all.Count(s => s.State == SubState.Cancelled);
+        sb.Append("states: active ").Append(active)
+                .Append(", paused ").Append(paused)
+                .Append(", cancelled ").Append(cancelled).Append('\n');
+
+        int skips = all.Sum(s => s.SkippedIssues.Count);
+        sb.Append("skips credited: ").Append(skips).Append('\n');
+
+        sb.Append("total collected: ")
+                .Append(MoneyFmt.Format(publisher.TotalCollected())).Append('\n');
+        return sb.ToString();
+    }
 }
