 /// </summary>
 public class IssueCalendar
 {
-    // TODO per the fulfillment brief: ctor(int firstPublishDay),
-    // FirstPublishDay, PublishDay, NextIssueOnOrAfter, IsPublishDay, IssueOn.
+    private const int CadenceDays = 7;
+
+    public IssueCalendar(int firstPublishDay)
+    {
+        if (firstPublishDay < 0)
+        {
+            throw new ArgumentException("first publish day must be non-negative");
+        }
+        FirstPublishDay = firstPublishDay;
+    }
+
+    public int FirstPublishDay { get; }
+
+    /// <summary>The logical day issue <paramref name="issueNumber"/> publishes.</summary>
+    public int PublishDay(int issueNumber)
+    {
+        if (issueNumber < 1)
+        {
+            throw new ArgumentException("issue numbers start at 1");
+        }
+        return FirstPublishDay + (issueNumber - 1) * CadenceDays;
+    }
+
+    /// <summary>The smallest issue number publishing on or after the day.</summary>
+    public int NextIssueOnOrAfter(int day)
+    {
+        if (day <= FirstPublishDay)
+        {
+            return 1;
+        }
+        return 1 + (day - FirstPublishDay + CadenceDays - 1) / CadenceDays;
+    }
+
+    public bool IsPublishDay(int day)
+    {
+        return day >= FirstPublishDay && (day - FirstPublishDay) % CadenceDays == 0;
+    }
+
+    /// <summary>The issue published on the day; the day must be a publish day.</summary>
+    public int IssueOn(int day)
+    {
+        if (!IsPublishDay(day))
+        {
+            throw new ArgumentException("day " + day + " is not a publish day");
+        }
+        return 1 + (day - FirstPublishDay) / CadenceDays;
+    }
 }
