index 1b6d488..7a48261 100644
--- a/Bundler.cs
+++ b/Bundler.cs
@@ -1,10 +1,55 @@
+/// <summary>One strapped bundle of papers for a carrier route.</summary>
+public class Bundle
+{
+    internal Bundle(string route, int sequence, IReadOnlyList<string> subscriberIds)
+    {
+        Route = route;
+        Sequence = sequence;
+        SubscriberIds = subscriberIds;
+    }
+
+    public string Route { get; }
+
+    /// <summary>1-based position of the bundle within its route.</summary>
+    public int Sequence { get; }
+
+    public string Label => Route + "-" + Sequence;
+
+    public IReadOnlyList<string> SubscriberIds { get; }
+}
+
 /// <summary>
 /// Carrier batching: the deliverable subscriptions for one issue, grouped by
 /// route, split into bundles of the route's capacity, everything in ordinal
-/// order. This file also declares the Bundle type.
+/// order.
 /// </summary>
 public static class Bundler
 {
-    // TODO per the fulfillment brief: BundlesFor(Publisher, int issueNumber)
-    // plus the Bundle type (Route / Sequence / Label / SubscriberIds).
+    public static IReadOnlyList<Bundle> BundlesFor(Publisher publisher, int issueNumber)
+    {
+        var byRoute = new SortedDictionary<string, List<string>>(StringComparer.Ordinal);
+        foreach (Subscription subscription in publisher.DeliverableOn(issueNumber))
+        {
+            if (!byRoute.TryGetValue(subscription.Route, out List<string>? ids))
+            {
+                ids = new List<string>();
+                byRoute[subscription.Route] = ids;
+            }
+            ids.Add(subscription.Id);
+        }
+
+        var bundles = new List<Bundle>();
+        foreach ((string route, List<string> ids) in byRoute)
+        {
+            int capacity = publisher.Routes.Capacity(route);
+            int sequence = 1;
+            for (int start = 0; start < ids.Count; start += capacity)
+            {
+                int size = Math.Min(capacity, ids.Count - start);
+                bundles.Add(new Bundle(route, sequence, ids.GetRange(start, size)));
+                sequence++;
+            }
+        }
+        return bundles;
+    }
 }
