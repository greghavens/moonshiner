+    {
+        return routes.ContainsKey(code);
+    }
+
+    /// <summary>All route codes in ordinal order.</summary>
+    public IReadOnlyList<string> Codes => routes.Keys.ToList();
 }
diff --git a/Subscription.cs b/Subscription.cs
index a690995..769ab3c 100644
--- a/Subscription.cs
+++ b/Subscription.cs
@@ -1,10 +1,120 @@
+/// <summary>Lifecycle states of a subscription.</summary>
+public enum SubState
+{
+    Active,
+    Paused,
+    Cancelled,
+}
+
 /// <summary>
 /// One subscription: paid issue window, money accrued, skip credits, and the
 /// Active / Paused / Cancelled lifecycle with its legal-transition table.
 /// </summary>
 public class Subscription
 {
-    // TODO per the fulfillment brief: SubState enum (in this file), ctor,
-    // window/money/skip properties, Pause/Resume/Cancel/Renew/Skip, and
-    // IsDeliverable.
+    private readonly List<int> skipped = new();
+
+    public Subscription(string id, Plan plan, string route, int firstIssue)
+    {
+        Id = id;
+        Plan = plan;
+        Route = route;
+        FirstIssue = firstIssue;
+        PaidThroughIssue = firstIssue + plan.TermIssues - 1;
+        PaidCents = plan.PriceCents;
+        State = SubState.Active;
+    }
+
+    public string Id { get; }
+
+    public Plan Plan { get; }
+
+    public string Route { get; }
+
+    public SubState State { get; private set; }
+
+    public int FirstIssue { get; }
+
+    public int PaidThroughIssue { get; private set; }
+
+    public long PaidCents { get; private set; }
+
+    /// <summary>Skipped issue numbers, ascending.</summary>
+    public IReadOnlyList<int> SkippedIssues => skipped;
+
+    private void RequireActive(string operation)
+    {
+        if (State != SubState.Active)
+        {
+            throw new InvalidOperationException(
+                    "cannot " + operation + " " + Id + " in state " + State);
+        }
+    }
+
+    /// <summary>Active -> Paused.</summary>
+    public void Pause()
+    {
+        RequireActive("pause");
+        State = SubState.Paused;
+    }
+
+    /// <summary>Paused -> Active.</summary>
+    public void Resume()
+    {
+        if (State != SubState.Paused)
+        {
+            throw new InvalidOperationException("cannot resume " + Id + " in state " + State);
+        }
+        State = SubState.Active;
+    }
+
+    /// <summary>Active or Paused -> Cancelled.</summary>
+    public void Cancel()
+    {
+        if (State == SubState.Cancelled)
+        {
+            throw new InvalidOperationException(Id + " is already cancelled");
+        }
+        State = SubState.Cancelled;
+    }
+
+    /// <summary>Extends the paid window by one term and accrues its price.</summary>
+    public long Renew()
+    {
+        RequireActive("renew");
+        PaidThroughIssue += Plan.TermIssues;
+        PaidCents += Plan.PriceCents;
+        return Plan.PriceCents;
+    }
+
+    /// <summary>
+    /// Records a vacation skip inside the current paid window and credits one
+    /// issue at the end of the run.
+    /// </summary>
+    public void Skip(int issueNumber)
+    {
+        RequireActive("skip on");
+        if (issueNumber < FirstIssue || issueNumber > PaidThroughIssue)
+        {
+            throw new ArgumentException(
+                    "issue " + issueNumber + " is outside the paid window of " + Id);
+        }
+        if (skipped.Contains(issueNumber))
+        {
+            throw new InvalidOperationException(
+                    "issue " + issueNumber + " already skipped on " + Id);
+        }
+        int at = skipped.BinarySearch(issueNumber);
+        skipped.Insert(~at, issueNumber);
+        PaidThroughIssue += 1;
+    }
+
+    /// <summary>Active, inside the paid window, and not skipped.</summary>
+    public bool IsDeliverable(int issueNumber)
+    {
+        return State == SubState.Active
+                && issueNumber >= FirstIssue
+                && issueNumber <= PaidThroughIssue
+                && !skipped.Contains(issueNumber);
+    }
 }
