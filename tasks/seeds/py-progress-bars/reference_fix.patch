-"""Single-line text progress bar for long-running CLI jobs.
+"""Single-line text progress bars for long-running CLI jobs.
 
 A ProgressBar tracks one counted job and renders the classic
 ``[#####-----]  50% (5/10)`` line.  The bar-body width is injectable so
 callers can size it to their terminal, and the percentage is floored so a
 job never reads 100% until it truly is finished.
+
+A MultiBar groups several jobs: aligned per-job lines in a stable order,
+smoothed ETAs off an injectable clock, and a compact one-line summary().
 """
+import time
+
+# Exponential-moving-average weight for the newest rate sample.
+SMOOTHING = 0.5
 
 
 def format_bar(current, total, width):
@@ -23,10 +30,16 @@ def percent_done(current, total):
     return min(100, current * 100 // total)
 
 
+def format_eta(seconds):
+    """``M:SS`` to the nearest second: 90 -> ``1:30``."""
+    minutes, secs = divmod(int(round(seconds)), 60)
+    return "%d:%02d" % (minutes, secs)
+
+
 class ProgressBar:
-    """Progress of one counted job."""
+    """Progress of one counted job, with a smoothed completion estimate."""
 
-    def __init__(self, total, label="", width=24):
+    def __init__(self, total, label="", width=24, clock=None):
         if total < 0:
             raise ValueError("total must be >= 0")
         if width < 1:
@@ -35,24 +48,88 @@ class ProgressBar:
         self.label = label
         self.width = width
         self.current = 0
+        self._clock = clock if clock is not None else time.monotonic
+        self._last = self._clock()
+        self._rate = None
 
     def advance(self, n=1):
         """Record ``n`` more completed units; progress never passes total."""
-        if n > 0:
-            self.current = min(self.total, self.current + n)
+        if n <= 0:
+            return
+        now = self._clock()
+        elapsed = now - self._last
+        if elapsed > 0:
+            sample = n / elapsed
+            if self._rate is None:
+                self._rate = sample
+            else:
+                self._rate = SMOOTHING * sample + (1 - SMOOTHING) * self._rate
+        self._last = now
+        self.current = min(self.total, self.current + n)
 
     @property
     def done(self):
         return self.current >= self.total
 
-    def render(self):
-        """The full line, e.g. ``fetch [##--]  50% (2/4)``."""
+    def eta(self):
+        """Seconds remaining: 0.0 when done, None before any rate sample."""
+        if self.done:
+            return 0.0
+        if self._rate is None:
+            return None
+        return (self.total - self.current) / self._rate
+
+    def render(self, show_eta=False):
+        """The full line, e.g. ``fetch [##--]  50% (2/4) ETA 0:10``."""
         line = "[%s] %3d%% (%d/%d)" % (
             format_bar(self.current, self.total, self.width),
             percent_done(self.current, self.total),
             self.current,
             self.total,
         )
+        if show_eta and not self.done:
+            eta = self.eta()
+            if eta is not None:
+                line += " ETA %s" % format_eta(eta)
         if self.label:
             line = "%s %s" % (self.label, line)
         return line
+
+
+class MultiBar:
+    """A fixed-order group of labelled progress bars sharing one clock."""
+
+    def __init__(self, width=24, clock=None):
+        self.width = width
+        self.clock = clock
+        self._jobs = []  # (label, bar), in add() order
+
+    def add(self, label, total):
+        """Register a job under ``label`` and return its ProgressBar."""
+        if any(name == label for name, _ in self._jobs):
+            raise ValueError("duplicate job label: %r" % label)
+        bar = ProgressBar(total, width=self.width, clock=self.clock)
+        self._jobs.append((label, bar))
+        return bar
+
+    def render(self, show_eta=False):
+        """One aligned line per job, always in the order jobs were added."""
+        if not self._jobs:
+            return []
+        pad = max(len(name) for name, _ in self._jobs)
+        return ["%s %s" % (name.ljust(pad), bar.render(show_eta=show_eta))
+                for name, bar in self._jobs]
+
+    def summary(self):
+        """Compact one-liner: per-job percents, overall percent, worst ETA."""
+        parts = ["%s %d%%" % (name, percent_done(bar.current, bar.total))
+                 for name, bar in self._jobs]
+        grand_total = sum(bar.total for _, bar in self._jobs)
+        grand_current = sum(bar.current for _, bar in self._jobs)
+        line = "%s >> %d%%" % (" | ".join(parts),
+                               percent_done(grand_current, grand_total))
+        etas = [bar.eta() for _, bar in self._jobs
+                if not bar.done and bar.eta() is not None]
+        if etas:
+            line += " ETA %s" % format_eta(max(etas))
+        return line
