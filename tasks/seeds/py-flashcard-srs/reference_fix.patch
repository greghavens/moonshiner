+"""Leitner-box scheduling rules."""
+from datetime import timedelta
+
+TOP_BOX = 5
+INTERVAL_DAYS = {1: 1, 2: 2, 3: 4, 4: 7, 5: 15}
+
+
+def new_card_state(today):
+    """Fresh cards start in box 1, due immediately."""
+    return 1, today
+
+
+def apply_review(box, passed, today):
+    """Return (new_box, new_due) for a review that happened on `today`."""
+    if passed:
+        new_box = min(box + 1, TOP_BOX)
+    else:
+        new_box = 1
+    return new_box, today + timedelta(days=INTERVAL_DAYS[new_box])
+
+
+def is_due(card_due, today):
+    return card_due <= today
+
+
+def due_sort_key(card):
+    """Lowest box first, then earliest due date, then front A-Z."""
+    return (card["box"], card["due"], card["front"])
