+#!/usr/bin/env python3
+"""Leitner spaced-repetition trainer CLI."""
+import argparse
+import sys
+from datetime import date
+
+import deckstore
+import scheduler
+
+
+def iso_date(text):
+    try:
+        return date.fromisoformat(text)
+    except ValueError:
+        raise argparse.ArgumentTypeError(f"not a YYYY-MM-DD date: {text!r}")
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="srs.py")
+    parser.add_argument("--deck", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_add = sub.add_parser("add")
+    p_add.add_argument("front")
+    p_add.add_argument("back")
+    p_add.add_argument("--today", type=iso_date, required=True)
+
+    p_due = sub.add_parser("due")
+    p_due.add_argument("--today", type=iso_date, required=True)
+
+    p_rev = sub.add_parser("review")
+    p_rev.add_argument("front")
+    p_rev.add_argument("grade", choices=["pass", "fail"])
+    p_rev.add_argument("--today", type=iso_date, required=True)
+
+    p_stats = sub.add_parser("stats")
+    p_stats.add_argument("--today", type=iso_date, required=True)
+    return parser
+
+
+def fail(message):
+    print(message, file=sys.stderr)
+    return 1
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    cards = deckstore.load(args.deck)
+
+    if args.command == "add":
+        if deckstore.find(cards, args.front) is not None:
+            return fail(f"card already exists: {args.front!r}")
+        box, due = scheduler.new_card_state(args.today)
+        cards.append({"front": args.front, "back": args.back, "box": box, "due": due})
+        deckstore.save(args.deck, cards)
+        return 0
+
+    if args.command == "due":
+        for card in sorted(cards, key=scheduler.due_sort_key):
+            if scheduler.is_due(card["due"], args.today):
+                print(card["front"])
+        return 0
+
+    if args.command == "review":
+        card = deckstore.find(cards, args.front)
+        if card is None:
+            return fail(f"no such card: {args.front!r}")
+        if not scheduler.is_due(card["due"], args.today):
+            return fail(f"{args.front!r} is not due until {card['due'].isoformat()}")
+        card["box"], card["due"] = scheduler.apply_review(
+            card["box"], args.grade == "pass", args.today)
+        deckstore.save(args.deck, cards)
+        print(f"{card['front']}: box {card['box']}, due {card['due'].isoformat()}")
+        return 0
+
+    if args.command == "stats":
+        for box in range(1, scheduler.TOP_BOX + 1):
+            print(f"box {box}: {sum(1 for c in cards if c['box'] == box)}")
+        print(f"due: {sum(1 for c in cards if scheduler.is_due(c['due'], args.today))}")
+        return 0
+
+    return 2  # unreachable
+
+
+if __name__ == "__main__":
+    sys.exit(main())
