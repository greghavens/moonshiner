+"""Deck persistence: JSON file, dates stored as ISO strings."""
+import json
+import os
+from datetime import date
+
+
+def load(path):
+    """Missing deck file = empty deck; never creates the file."""
+    if not os.path.exists(path):
+        return []
+    with open(path, encoding="utf-8") as f:
+        raw = json.load(f)
+    return [{"front": c["front"], "back": c["back"], "box": c["box"],
+             "due": date.fromisoformat(c["due"])} for c in raw["cards"]]
+
+
+def save(path, cards):
+    raw = {"cards": [{"front": c["front"], "back": c["back"], "box": c["box"],
+                      "due": c["due"].isoformat()} for c in cards]}
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(raw, f, indent=1)
+        f.write("\n")
+
+
+def find(cards, front):
+    for card in cards:
+        if card["front"] == front:
+            return card
+    return None
