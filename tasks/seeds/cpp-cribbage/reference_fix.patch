+#ifndef CRIBBAGE_H
+#define CRIBBAGE_H
+
+#include <string>
+
+struct CribBreakdown {
+    int fifteens;
+    int pairs;
+    int runs;
+    int flush;
+    int nobs;
+    int total;
+};
+
+CribBreakdown crib_score(const std::string &hand,
+                         const std::string &starter,
+                         bool is_crib);
+
+#endif
