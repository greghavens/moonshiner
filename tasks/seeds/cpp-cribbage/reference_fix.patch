@@ -0,0 +1,100 @@
+#include "cribbage.h"
+
+#include <array>
+#include <sstream>
+#include <vector>
+
+namespace {
+
+struct Card {
+    int rank;  // 1 (ace) .. 13 (king)
+    char suit;
+};
+
+int rank_of(char r) {
+    switch (r) {
+        case 'A': return 1;
+        case 'T': return 10;
+        case 'J': return 11;
+        case 'Q': return 12;
+        case 'K': return 13;
+        default:  return r - '0';
+    }
+}
+
+int value_of(int rank) { return rank > 10 ? 10 : rank; }
+
+std::vector<Card> parse(const std::string &hand, const std::string &starter) {
+    std::vector<Card> cards;
+    std::istringstream in(hand + " " + starter);
+    std::string tok;
+    while (in >> tok)
+        cards.push_back({rank_of(tok[0]), tok[1]});
+    return cards;
+}
+
+}  // namespace
+
+CribBreakdown crib_score(const std::string &hand,
+                         const std::string &starter,
+                         bool is_crib) {
+    std::vector<Card> cards = parse(hand, starter);
+    CribBreakdown bd{0, 0, 0, 0, 0, 0};
+
+    // Fifteens: every subset of size >= 2 summing to 15.
+    for (int mask = 1; mask < 32; mask++) {
+        if (__builtin_popcount(mask) < 2) continue;
+        int sum = 0;
+        for (int i = 0; i < 5; i++)
+            if (mask & (1 << i)) sum += value_of(cards[i].rank);
+        if (sum == 15) bd.fifteens += 2;
+    }
+
+    // Pairs.
+    for (int i = 0; i < 5; i++)
+        for (int j = i + 1; j < 5; j++)
+            if (cards[i].rank == cards[j].rank) bd.pairs += 2;
+
+    // Runs: longest stretch of consecutive present ranks, length >= 3,
+    // scored length * product of multiplicities.
+    std::array<int, 14> count{};
+    for (const Card &c : cards) count[c.rank]++;
+    int best_len = 0;
+    for (int start = 1; start <= 13; start++) {
+        if (!count[start]) continue;
+        int len = 0;
+        while (start + len <= 13 && count[start + len]) len++;
+        if (len > best_len) best_len = len;
+    }
+    if (best_len >= 3) {
+        for (int start = 1; start + best_len - 1 <= 13; start++) {
+            bool maximal = true;
+            for (int k = 0; k < best_len; k++)
+                if (!count[start + k]) { maximal = false; break; }
+            if (!maximal) continue;
+            if (start > 1 && count[start - 1]) continue;
+            if (start + best_len <= 13 && count[start + best_len]) continue;
+            int mult = 1;
+            for (int k = 0; k < best_len; k++) mult *= count[start + k];
+            bd.runs += best_len * mult;
+        }
+    }
+
+    // Flush.
+    bool hand_flush = cards[0].suit == cards[1].suit &&
+                      cards[0].suit == cards[2].suit &&
+                      cards[0].suit == cards[3].suit;
+    if (hand_flush) {
+        if (cards[0].suit == cards[4].suit)
+            bd.flush = 5;
+        else if (!is_crib)
+            bd.flush = 4;
+    }
+
+    // His nobs: jack in hand matching the starter suit.
+    for (int i = 0; i < 4; i++)
+        if (cards[i].rank == 11 && cards[i].suit == cards[4].suit) bd.nobs = 1;
+
+    bd.total = bd.fifteens + bd.pairs + bd.runs + bd.flush + bd.nobs;
+    return bd;
+}
