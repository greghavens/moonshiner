@@ -0,0 +1,61 @@
+// Atlassian Document Format builders for the node shapes this tooling emits.
+// Reference: https://developer.atlassian.com/cloud/jira/platform/apis/document/structure/
+
+export interface AdfNode {
+  type: string;
+  [key: string]: unknown;
+}
+
+export function doc(...blocks: AdfNode[]): AdfNode {
+  return { type: "doc", version: 1, content: blocks };
+}
+
+export function paragraph(...inline: AdfNode[]): AdfNode {
+  return { type: "paragraph", content: inline };
+}
+
+export function text(value: string, marks?: string[]): AdfNode {
+  const node: AdfNode = { type: "text", text: value };
+  if (marks && marks.length > 0) {
+    node.marks = marks.map((mark) => ({ type: mark }));
+  }
+  return node;
+}
+
+export function link(value: string, href: string): AdfNode {
+  return { type: "text", text: value, marks: [{ type: "link", attrs: { href } }] };
+}
+
+export function codeBlock(language: string, code: string): AdfNode {
+  return { type: "codeBlock", attrs: { language }, content: [{ type: "text", text: code }] };
+}
+
+export function bulletList(...items: string[]): AdfNode {
+  return {
+    type: "bulletList",
+    content: items.map((item) => ({
+      type: "listItem",
+      content: [paragraph(text(item))],
+    })),
+  };
+}
+
+/** One paragraph per line of plain text; empty input is a valid empty document. */
+export function descriptionFromText(input: string): AdfNode {
+  if (input === "") {
+    return doc();
+  }
+  return doc(...input.split("\n").map((line) => paragraph(text(line))));
+}
+
+/** True when the value is a root ADF document usable as a v3 description. */
+export function isAdfDoc(value: unknown): boolean {
+  return (
+    typeof value === "object" &&
+    value !== null &&
+    !Array.isArray(value) &&
+    (value as AdfNode).type === "doc" &&
+    (value as AdfNode).version === 1 &&
+    Array.isArray((value as AdfNode).content)
+  );
+}
diff --git a/jira/client.ts b/jira/client.ts
new file mode 100644
index 0000000..cf9da57
--- /dev/null
+++ b/jira/client.ts
@@ -0,0 +1,212 @@
+// Jira Cloud platform REST API v3 issue writer (create/edit).
+import { descriptionFromText, isAdfDoc, type AdfNode } from "./adf.ts";
+
+export class JiraHttpError extends Error {
+  readonly status: number;
+  readonly errorMessages: string[];
+
+  constructor(status: number, errorMessages: string[], message: string) {
+    super(message);
+    this.name = "JiraHttpError";
+    this.status = status;
+    this.errorMessages = errorMessages;
+  }
+}
+
+export class JiraFieldError extends JiraHttpError {
+  readonly fieldErrors: Record<string, string>;
+
+  constructor(
+    status: number,
+    errorMessages: string[],
+    fieldErrors: Record<string, string>,
+    message: string,
+  ) {
+    super(status, errorMessages, message);
+    this.name = "JiraFieldError";
+    this.fieldErrors = fieldErrors;
+  }
+}
+
+export interface JiraConfig {
+  baseUrl: string;
+  email: string;
+  apiToken: string;
+}
+
+export interface CreateIssueInput {
+  projectKey: string;
+  issueTypeId: string;
+  summary: string;
+  description?: string | AdfNode;
+  assigneeAccountId?: string;
+  reporterAccountId?: string;
+  labels?: string[];
+  dueDate?: string;
+}
+
+export interface UpdateIssueChanges {
+  summary?: string;
+  description?: string | AdfNode;
+  assigneeAccountId?: string;
+  addLabels?: string[];
+  removeLabels?: string[];
+}
+
+export interface UpdateIssueOptions {
+  notifyUsers?: boolean;
+  returnIssue?: boolean;
+}
+
+function normalizeDescription(description: string | AdfNode): AdfNode {
+  if (typeof description === "string") {
+    return descriptionFromText(description);
+  }
+  if (!isAdfDoc(description)) {
+    throw new TypeError(
+      "description must be a plain string or an ADF root document " +
+        '({type: "doc", version: 1, content: [...]}); v3 does not accept other shapes',
+    );
+  }
+  return description;
+}
+
+export class JiraIssueClient {
+  readonly #baseUrl: string;
+  readonly #authorization: string;
+
+  constructor(config: JiraConfig) {
+    this.#baseUrl = config.baseUrl.replace(/\/+$/, "");
+    const raw = Buffer.from(`${config.email}:${config.apiToken}`, "utf8");
+    this.#authorization = `Basic ${raw.toString("base64")}`;
+  }
+
+  async createIssue(input: CreateIssueInput): Promise<{ id: string; key: string; self: string }> {
+    const fields: Record<string, unknown> = {
+      project: { key: input.projectKey },
+      issuetype: { id: input.issueTypeId },
+      summary: input.summary,
+    };
+    if (input.description !== undefined) {
+      fields.description = normalizeDescription(input.description);
+    }
+    if (input.assigneeAccountId !== undefined) {
+      fields.assignee = { id: input.assigneeAccountId };
+    }
+    if (input.reporterAccountId !== undefined) {
+      fields.reporter = { id: input.reporterAccountId };
+    }
+    if (input.labels !== undefined) {
+      fields.labels = input.labels;
+    }
+    if (input.dueDate !== undefined) {
+      fields.duedate = input.dueDate;
+    }
+
+    const response = await this.#send("POST", "/rest/api/3/issue", { fields });
+    const body = await readJson(response);
+    if (response.status !== 201) {
+      throw decodeError(response.status, body);
+    }
+    return { id: body.id, key: body.key, self: body.self };
+  }
+
+  async updateIssue(
+    issueIdOrKey: string,
+    changes: UpdateIssueChanges,
+    options: UpdateIssueOptions = {},
+  ): Promise<any> {
+    const fields: Record<string, unknown> = {};
+    if (changes.summary !== undefined) {
+      fields.summary = changes.summary;
+    }
+    if (changes.description !== undefined) {
+      fields.description = normalizeDescription(changes.description);
+    }
+    if (changes.assigneeAccountId !== undefined) {
+      fields.assignee = { id: changes.assigneeAccountId };
+    }
+    const labelOps = [
+      ...(changes.addLabels ?? []).map((label) => ({ add: label })),
+      ...(changes.removeLabels ?? []).map((label) => ({ remove: label })),
+    ];
+
+    const body: Record<string, unknown> = {};
+    if (Object.keys(fields).length > 0) {
+      body.fields = fields;
+    }
+    if (labelOps.length > 0) {
+      body.update = { labels: labelOps };
+    }
+
+    const query = new URLSearchParams();
+    if (options.notifyUsers !== undefined) {
+      query.set("notifyUsers", String(options.notifyUsers));
+    }
+    if (options.returnIssue !== undefined) {
+      query.set("returnIssue", String(options.returnIssue));
+    }
+    const suffix = query.size > 0 ? `?${query}` : "";
+
+    const response = await this.#send(
+      "PUT",
+      `/rest/api/3/issue/${encodeURIComponent(issueIdOrKey)}${suffix}`,
+      body,
+    );
+    if (response.status === 204) {
+      return null;
+    }
+    const parsed = await readJson(response);
+    if (response.status === 200) {
+      return parsed;
+    }
+    throw decodeError(response.status, parsed);
+  }
+
+  #send(method: string, pathAndQuery: string, body: unknown): Promise<Response> {
+    return fetch(this.#baseUrl + pathAndQuery, {
+      method,
+      headers: {
+        authorization: this.#authorization,
+        "content-type": "application/json",
+        accept: "application/json",
+      },
+      body: JSON.stringify(body),
+    });
+  }
+}
+
+async function readJson(response: Response): Promise<any> {
+  const raw = await response.text();
+  if (raw === "") {
+    return null;
+  }
+  try {
+    return JSON.parse(raw);
+  } catch {
+    return null;
+  }
+}
+
+function decodeError(status: number, body: any): JiraHttpError {
+  const errorMessages: string[] = Array.isArray(body?.errorMessages)
+    ? body.errorMessages.map(String)
+    : [];
+  const fieldErrors: Record<string, string> = {};
+  if (body?.errors && typeof body.errors === "object") {
+    for (const [field, message] of Object.entries(body.errors)) {
+      fieldErrors[field] = String(message);
+    }
+  }
+  const parts = [
+    ...errorMessages,
+    ...Object.entries(fieldErrors).map(([field, message]) => `${field}: ${message}`),
+  ];
+  const message = `Jira rejected the request (HTTP ${status})${
+    parts.length > 0 ? `: ${parts.join("; ")}` : ""
+  }`;
+  if (Object.keys(fieldErrors).length > 0) {
+    return new JiraFieldError(status, errorMessages, fieldErrors, message);
+  }
+  return new JiraHttpError(status, errorMessages, message);
+}
