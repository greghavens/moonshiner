+"""cmdlex — tokenizer for the ops-console command box.
+
+Shell-ish quoting rules, hand-rolled on purpose (no shlex, no re):
+see tokenize() for the full contract.
+"""
+
+
+def tokenize(line):
+    """Split a command line into arguments.
+
+    Raises ValueError on unterminated quotes or a dangling backslash.
+    """
+    tokens = []
+    i = 0
+    n = len(line)
+    current = None  # None = between tokens; str = token being built
+
+    def emit():
+        nonlocal current
+        if current is not None:
+            tokens.append(current)
+            current = None
+
+    while i < n:
+        c = line[i]
+        if c in " \t":
+            emit()
+            i += 1
+        elif c == "#" and current is None:
+            break  # comment runs to end of line
+        elif c == "'":
+            end = line.find("'", i + 1)
+            if end == -1:
+                raise ValueError(f"unterminated single quote at column {i}")
+            current = (current or "") + line[i + 1:end]
+            i = end + 1
+        elif c == '"':
+            buf = []
+            i += 1
+            closed = False
+            while i < n:
+                c = line[i]
+                if c == "\\" and i + 1 < n and line[i + 1] in '"\\':
+                    buf.append(line[i + 1])
+                    i += 2
+                elif c == '"':
+                    closed = True
+                    i += 1
+                    break
+                else:
+                    buf.append(c)
+                    i += 1
+            if not closed:
+                raise ValueError("unterminated double quote")
+            current = (current or "") + "".join(buf)
+        elif c == "\\":
+            if i + 1 >= n:
+                raise ValueError("dangling backslash at end of line")
+            current = (current or "") + line[i + 1]
+            i += 2
+        else:
+            current = (current or "") + c
+            i += 1
+    emit()
+    return tokens
