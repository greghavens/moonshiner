diff --git a/scripts/archive-library.sh b/scripts/archive-library.sh
index e77a139..8604ae2 100755
--- a/scripts/archive-library.sh
+++ b/scripts/archive-library.sh
@@ -13,9 +13,7 @@ object_dir=$2
 
 rm -f "$archive"
 
-# Preserve compiler completion order to make post-build inspection convenient.
-# GNU ar's U modifier also carries the original member metadata into the file.
-find "$object_dir" -type f -name '*.o' -printf '%T@ %p\0' |
-    sort -z -n |
-    cut -z -d ' ' -f 2- |
-    xargs -0 "$AR" rcsU "$archive"
+# Canonical input order plus deterministic ar headers make the library stable.
+find "$object_dir" -type f -name '*.o' -print0 |
+    LC_ALL=C sort -z |
+    xargs -0 "$AR" rcsD "$archive"
