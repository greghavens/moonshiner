diff --git a/argshow.zsh b/argshow.zsh
new file mode 100644
index 0000000..4bbb237
--- /dev/null
+++ b/argshow.zsh
@@ -0,0 +1,52 @@
+#!/usr/bin/env zsh
+# argshow.zsh -- make zsh's quoting-flag renderings of an argv visible.
+emulate -L zsh
+setopt no_unset
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  print -ru2 -- 'usage: argshow.zsh [--line|--unquote] [word ...]'
+  exit 2
+}
+
+mode=report
+if (( $# > 0 )); then
+  case $1 in
+    --line)    mode=line;    shift ;;
+    --unquote) mode=unquote; shift ;;
+    --*)       usage ;;
+  esac
+fi
+
+case $mode in
+  line)
+    local -a rendered
+    rendered=()
+    local w
+    for w in "$@"; do
+      rendered+=("${(q-)w}")
+    done
+    print -r -- "${(j: :)rendered}"
+    ;;
+  unquote)
+    local w
+    for w in "$@"; do
+      print -r -- "<${(Q)w}>"
+    done
+    ;;
+  report)
+    integer i=0
+    local w rt
+    for w in "$@"; do
+      (( i += 1 ))
+      print -r -- "[$i] raw: <$w>"
+      print -r -- "[$i] q: <${(q)w}>"
+      print -r -- "[$i] qq: <${(qq)w}>"
+      print -r -- "[$i] q-: <${(q-)w}>"
+      rt=ok
+      [[ "${(Q)${(q)w}}" == "$w" && "${(Q)${(qq)w}}" == "$w" && "${(Q)${(q-)w}}" == "$w" ]] || rt=MISMATCH
+      print -r -- "[$i] rt: $rt"
+    done
+    ;;
+esac
