+// Package glob implements a slash-aware glob matcher with *, **, ?,
+// character classes, and backslash escapes. It is deliberately
+// independent of path.Match / filepath.Match / regexp.
+package glob
+
+import "errors"
+
+// ErrBadPattern reports a malformed pattern: an unterminated or empty
+// character class, an inverted range, or a trailing backslash.
+var ErrBadPattern = errors.New("glob: bad pattern")
+
+// Match reports whether name matches pattern.
+//
+//	*   any run (possibly empty) of runes except '/'
+//	**  any run (possibly empty) of runes including '/'
+//	?   exactly one rune, never '/'
+//	[…] one rune from the class; ranges a-c; leading ! negates
+//	\x  the literal rune x
+//
+// Malformed patterns return (false, ErrBadPattern) regardless of name.
+func Match(pattern, name string) (bool, error) {
+	p := []rune(pattern)
+	if err := validate(p); err != nil {
+		return false, err
+	}
+	return match(p, []rune(name)), nil
+}
+
+// validate scans the whole pattern so malformed classes are reported
+// even when matching would have failed before reaching them.
+func validate(p []rune) error {
+	for i := 0; i < len(p); i++ {
+		switch p[i] {
+		case '\\':
+			if i+1 >= len(p) {
+				return ErrBadPattern
+			}
+			i++
+		case '[':
+			j := i + 1
+			if j < len(p) && p[j] == '!' {
+				j++
+			}
+			entries := 0
+			for j < len(p) && p[j] != ']' {
+				lo := p[j]
+				if j+2 < len(p) && p[j+1] == '-' && p[j+2] != ']' {
+					if lo > p[j+2] {
+						return ErrBadPattern
+					}
+					j += 3
+				} else {
+					j++
+				}
+				entries++
+			}
+			if j >= len(p) || entries == 0 {
+				return ErrBadPattern
+			}
+			i = j
+		}
+	}
+	return nil
+}
+
+// match assumes p has been validated.
+func match(p, s []rune) bool {
+	if len(p) == 0 {
+		return len(s) == 0
+	}
+	switch p[0] {
+	case '*':
+		if len(p) > 1 && p[1] == '*' {
+			rest := p[2:]
+			for i := 0; i <= len(s); i++ {
+				if match(rest, s[i:]) {
+					return true
+				}
+			}
+			return false
+		}
+		rest := p[1:]
+		for i := 0; ; i++ {
+			if match(rest, s[i:]) {
+				return true
+			}
+			if i >= len(s) || s[i] == '/' {
+				return false
+			}
+		}
+	case '?':
+		return len(s) > 0 && s[0] != '/' && match(p[1:], s[1:])
+	case '\\':
+		return len(s) > 0 && s[0] == p[1] && match(p[2:], s[1:])
+	case '[':
+		if len(s) == 0 {
+			return false
+		}
+		ok, rest := classMatch(p, s[0])
+		return ok && match(rest, s[1:])
+	default:
+		return len(s) > 0 && s[0] == p[0] && match(p[1:], s[1:])
+	}
+}
+
+// classMatch matches one rune against the class starting at p[0] == '['
+// and returns the remaining pattern after the closing bracket.
+func classMatch(p []rune, c rune) (bool, []rune) {
+	i := 1
+	negate := false
+	if p[i] == '!' {
+		negate = true
+		i++
+	}
+	matched := false
+	for p[i] != ']' {
+		lo := p[i]
+		if p[i+1] == '-' && p[i+2] != ']' {
+			if lo <= c && c <= p[i+2] {
+				matched = true
+			}
+			i += 3
+		} else {
+			if c == lo {
+				matched = true
+			}
+			i++
+		}
+	}
+	return matched != negate, p[i+1:]
+}
