+import { readFileSync, writeFileSync } from 'node:fs';
+import { hasMarkers, insertToc } from './toc.ts';
+
+function usage(): never {
+  process.stderr.write('usage: node cli.ts [--check] [--max-level N] <file>\n');
+  process.exit(2);
+}
+
+function main(argv: string[]): number {
+  let check = false;
+  let maxLevel: number | undefined;
+  const positional: string[] = [];
+
+  for (let i = 0; i < argv.length; i++) {
+    const arg = argv[i];
+    if (arg === '--check') {
+      check = true;
+    } else if (arg === '--max-level') {
+      const n = Number(argv[++i]);
+      if (!Number.isInteger(n) || n < 1) usage();
+      maxLevel = n;
+    } else {
+      positional.push(arg);
+    }
+  }
+  if (positional.length !== 1) usage();
+  const file = positional[0];
+
+  let original: string;
+  try {
+    original = readFileSync(file, 'utf8');
+  } catch (err) {
+    process.stderr.write(`cannot read ${file}: ${(err as Error).message}\n`);
+    return 2;
+  }
+
+  if (!hasMarkers(original)) {
+    process.stderr.write(`no toc markers in ${file}\n`);
+    return 2;
+  }
+
+  const updated = insertToc(original, maxLevel === undefined ? {} : { maxLevel });
+  const stale = updated !== original;
+
+  if (check) {
+    process.stdout.write(stale ? `stale ${file}\n` : `ok ${file}\n`);
+    return stale ? 1 : 0;
+  }
+  if (stale) {
+    writeFileSync(file, updated);
+    process.stdout.write(`updated ${file}\n`);
+  } else {
+    process.stdout.write(`unchanged ${file}\n`);
+  }
+  return 0;
+}
+
+process.exit(main(process.argv.slice(2)));
