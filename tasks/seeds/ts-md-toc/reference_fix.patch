+import { slugify } from './slug.ts';
+
+export type Heading = { level: number; text: string; slug: string };
+
+// Flatten inline markdown down to its visible text: strip closing ATX
+// hashes, keep link text, drop bold/em/inline-code markers.
+function cleanInline(raw: string): string {
+  return raw
+    .trim()
+    .replace(/\s+#+\s*$/, '')
+    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
+    .replace(/\*\*/g, '')
+    .replace(/\*/g, '')
+    .replace(/`/g, '')
+    .trim();
+}
+
+export function extractHeadings(markdown: string): Heading[] {
+  const headings: Heading[] = [];
+  const used = new Map<string, number>();
+  let fence: string | null = null; // fence character while inside a code block
+
+  for (const line of markdown.split('\n')) {
+    const fenceMatch = line.match(/^(`{3,}|~{3,})/);
+    if (fenceMatch) {
+      const ch = fenceMatch[1][0];
+      if (fence === null) fence = ch;
+      else if (ch === fence) fence = null;
+      continue;
+    }
+    if (fence !== null) continue;
+
+    const m = line.match(/^(#{1,6}) (.*)$/);
+    if (!m) continue;
+    const text = cleanInline(m[2]);
+    const base = slugify(text);
+    const taken = used.get(base) ?? 0;
+    used.set(base, taken + 1);
+    headings.push({
+      level: m[1].length,
+      text,
+      slug: taken === 0 ? base : `${base}-${taken}`,
+    });
+  }
+  return headings;
+}
