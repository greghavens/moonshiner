+import { extractHeadings } from './headings.ts';
+import { slugify } from './slug.ts';
+
+export { extractHeadings, slugify };
+
+export type TocOptions = { maxLevel?: number };
+
+const TOC_START = '<!-- toc -->';
+const TOC_END = '<!-- tocstop -->';
+
+export function generateToc(markdown: string, opts: TocOptions = {}): string {
+  const maxLevel = opts.maxLevel ?? 3;
+  const included = extractHeadings(markdown).filter((h) => h.level <= maxLevel);
+  if (included.length === 0) return '';
+  const shallowest = Math.min(...included.map((h) => h.level));
+  return included
+    .map((h) => `${'  '.repeat(h.level - shallowest)}- [${h.text}](#${h.slug})`)
+    .join('\n');
+}
+
+export function hasMarkers(markdown: string): boolean {
+  const lines = markdown.split('\n').map((l) => l.trim());
+  const start = lines.indexOf(TOC_START);
+  return start !== -1 && lines.indexOf(TOC_END, start + 1) !== -1;
+}
+
+export function insertToc(markdown: string, opts: TocOptions = {}): string {
+  const lines = markdown.split('\n');
+  const start = lines.findIndex((l) => l.trim() === TOC_START);
+  if (start === -1) return markdown;
+  const end = lines.findIndex((l, i) => i > start && l.trim() === TOC_END);
+  if (end === -1) return markdown;
+  const toc = generateToc(markdown, opts);
+  const block = toc === '' ? [''] : ['', toc, ''];
+  return [...lines.slice(0, start + 1), ...block, ...lines.slice(end)].join('\n');
+}
