+// GitHub-style anchor slugs: lowercase, strip punctuation, then map every
+// space to a hyphen (so consecutive spaces produce consecutive hyphens).
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .replace(/[^a-z0-9 \-_]/g, '')
+    .replace(/ /g, '-');
+}
