+#!/usr/bin/env python3
+"""Reference proof: execute the real client in the required dependency stages."""
+
+from __future__ import annotations
+
+import json
+import os
+from pathlib import Path
+import shlex
+import subprocess
+
+
+ROOT = Path(__file__).resolve().parent
+CLIENT = ROOT / "clinicctl"
+AUDIT = ROOT / ".clinic-runtime" / "audit.jsonl"
+
+
+def run_pair(arguments: list[list[str]]) -> list[dict]:
+    outputs = [AUDIT.parent / f"reference-output-{index}.json"
+               for index in range(len(arguments))]
+    commands = [
+        f"{shlex.join([str(CLIENT), *item])} > {shlex.quote(str(output))} &"
+        for item, output in zip(arguments, outputs)
+    ]
+    completed = subprocess.run(
+        ["bash", "-c", "\n".join([*commands, "wait"])],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=10,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(f"clinicctl stage failed: {completed.stderr.strip()}")
+    results = [json.loads(output.read_text(encoding="utf-8")) for output in outputs]
+    for output in outputs:
+        output.unlink()
+    return results
+
+
+def main() -> None:
+    AUDIT.parent.mkdir(parents=True, exist_ok=True)
+    AUDIT.unlink(missing_ok=True)
+    os.environ["CLINIC_AUDIT_LOG"] = str(AUDIT)
+    help_result = subprocess.run(
+        [str(CLIENT), "--help"],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=10,
+    )
+    if help_result.returncode != 0:
+        raise RuntimeError(f"clinicctl help failed: {help_result.stderr.strip()}")
+
+    targets = [
+        ("Preventive Dental Cleaning", "Cedar Clinic"),
+        ("Routine Lab Follow-Up", "Dale Clinic"),
+    ]
+    searches = run_pair([
+        ["search", "--name", name, "--location", location]
+        for name, location in targets
+    ])
+
+    stable_ids = []
+    for result in searches:
+        matches = result.get("matches", [])
+        if len(matches) != 1 or not matches[0].get("stable_id"):
+            raise RuntimeError("reference target did not resolve to one stable ID")
+        stable_ids.append(matches[0]["stable_id"])
+
+    records = run_pair([
+        ["get", "--id", stable_id]
+        for stable_id in stable_ids
+    ])
+    records.sort(key=lambda record: (record["date"], record["stable_id"]))
+    handoff = (
+        "# Front-desk handoff\n\n"
+        f"1. {records[0]['date']} | {records[0]['name']} | "
+        f"{records[0]['location']} | {records[0]['status']}\n"
+        f"2. {records[1]['date']} | {records[1]['name']} | "
+        f"{records[1]['location']} | {records[1]['status']}\n\n"
+        f"Status comparison: the earlier record is {records[0]['status']}; "
+        f"the later record is {records[1]['status']}.\n"
+    )
+    (ROOT / "front_desk_handoff.md").write_text(handoff, encoding="utf-8")
+
+
+if __name__ == "__main__":
+    main()
