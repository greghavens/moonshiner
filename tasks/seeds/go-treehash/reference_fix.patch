new file mode 100644
index 0000000..8e23446
--- /dev/null
+++ b/hash.go
@@ -0,0 +1,71 @@
+package treehash
+
+import (
+	"crypto/sha256"
+	"encoding/hex"
+	"fmt"
+	"io"
+	"os"
+	"path/filepath"
+	"sync"
+)
+
+// hashAll hashes candidates with at most opts.Workers files in flight.
+// Results land at their input index, so no ordering is lost to scheduling.
+func hashAll(root string, candidates []candidate, opts Options) ([]Entry, error) {
+	entries := make([]Entry, len(candidates))
+	jobs := make(chan int)
+	var (
+		wg       sync.WaitGroup
+		errOnce  sync.Once
+		firstErr error
+	)
+	fail := func(err error) {
+		errOnce.Do(func() { firstErr = err })
+	}
+
+	for w := 0; w < opts.Workers; w++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			for i := range jobs {
+				c := candidates[i]
+				if opts.Progress != nil {
+					opts.Progress(Event{Path: c.rel, Done: false})
+				}
+				sum, err := hashFile(filepath.Join(root, filepath.FromSlash(c.rel)))
+				if opts.Progress != nil {
+					opts.Progress(Event{Path: c.rel, Done: true})
+				}
+				if err != nil {
+					fail(fmt.Errorf("hash %s: %w", c.rel, err))
+					continue
+				}
+				entries[i] = Entry{Path: c.rel, Size: c.size, SHA256: sum}
+			}
+		}()
+	}
+	for i := range candidates {
+		jobs <- i
+	}
+	close(jobs)
+	wg.Wait()
+
+	if firstErr != nil {
+		return nil, firstErr
+	}
+	return entries, nil
+}
+
+func hashFile(path string) (string, error) {
+	f, err := os.Open(path)
+	if err != nil {
+		return "", err
+	}
+	defer f.Close()
+	h := sha256.New()
+	if _, err := io.Copy(h, f); err != nil {
+		return "", err
+	}
+	return hex.EncodeToString(h.Sum(nil)), nil
+}
diff --git a/treehash.go b/treehash.go
new file mode 100644
index 0000000..918f1f1
--- /dev/null
+++ b/treehash.go
@@ -0,0 +1,49 @@
+// Package treehash walks a directory tree and produces a deterministic,
+// sorted SHA-256 manifest of its regular files.
+package treehash
+
+import (
+	"fmt"
+	"sort"
+)
+
+// Event describes progress on one file: a start (Done=false) followed by a
+// completion (Done=true). Callbacks fire synchronously on worker goroutines.
+type Event struct {
+	Path string
+	Done bool
+}
+
+// Options tunes a HashTree run.
+type Options struct {
+	Workers  int         // max files hashed concurrently; < 1 means 1
+	MinSize  int64       // keep files with size >= MinSize
+	MaxSize  int64       // if > 0, keep files with size <= MaxSize
+	Progress func(Event) // optional progress callback
+}
+
+// Entry is one manifest line: a regular file below the root.
+type Entry struct {
+	Path   string // relative to root, forward slashes
+	Size   int64
+	SHA256 string // lowercase hex
+}
+
+// HashTree walks root, hashes every regular file passing the size filters,
+// and returns entries sorted by Path (byte-wise). Symlinks are neither
+// followed nor reported.
+func HashTree(root string, opts Options) ([]Entry, error) {
+	if opts.Workers < 1 {
+		opts.Workers = 1
+	}
+	candidates, err := collect(root, opts)
+	if err != nil {
+		return nil, fmt.Errorf("treehash: %w", err)
+	}
+	entries, err := hashAll(root, candidates, opts)
+	if err != nil {
+		return nil, fmt.Errorf("treehash: %w", err)
+	}
+	sort.Slice(entries, func(i, j int) bool { return entries[i].Path < entries[j].Path })
+	return entries, nil
+}
diff --git a/walk.go b/walk.go
new file mode 100644
index 0000000..865c3b9
--- /dev/null
+++ b/walk.go
@@ -0,0 +1,51 @@
+package treehash
+
+import (
+	"io/fs"
+	"path/filepath"
+)
+
+// candidate is a file that passed the filters and is waiting to be hashed.
+type candidate struct {
+	rel  string // slash-separated, relative to root
+	size int64
+}
+
+// collect walks the tree and applies the symlink and size filters.
+// filepath.WalkDir lstats entries, so symlinked directories are never
+// descended into; we additionally drop any non-regular entry.
+func collect(root string, opts Options) ([]candidate, error) {
+	var out []candidate
+	err := filepath.WalkDir(root, func(path string, d fs.DirEntry, err error) error {
+		if err != nil {
+			return err
+		}
+		if d.IsDir() {
+			return nil
+		}
+		if !d.Type().IsRegular() { // symlinks, devices, sockets, fifos
+			return nil
+		}
+		info, err := d.Info()
+		if err != nil {
+			return err
+		}
+		size := info.Size()
+		if size < opts.MinSize {
+			return nil
+		}
+		if opts.MaxSize > 0 && size > opts.MaxSize {
+			return nil
+		}
+		rel, err := filepath.Rel(root, path)
+		if err != nil {
+			return err
+		}
+		out = append(out, candidate{rel: filepath.ToSlash(rel), size: size})
+		return nil
+	})
+	if err != nil {
+		return nil, err
+	}
+	return out, nil
+}
