+"""Grid statistics for greenhouse sensor telemetry.
+
+All functions accept plain sequences or numpy arrays of integer readings
+and return int64 numpy arrays; nothing here mutates its inputs. The
+dashboards downstream do exact integer arithmetic, so no computation is
+allowed to drift into floats.
+"""
+import numpy as np
+
+
+def _series(values):
+    a = np.asarray(values, dtype=np.int64)
+    if a.ndim != 1:
+        raise ValueError(f"expected a 1-D series, got {a.ndim}-D")
+    return a
+
+
+def _check_width(n, width):
+    if width < 1 or width > n:
+        raise ValueError(f"window width {width} invalid for series of length {n}")
+
+
+def window_sums(values, width):
+    """Sliding-window sums: n readings, width w -> n-w+1 sums."""
+    a = _series(values)
+    _check_width(a.size, width)
+    csum = np.concatenate(([np.int64(0)], np.cumsum(a)))
+    return (csum[width:] - csum[:-width]).astype(np.int64)
+
+
+def window_peaks(values, width):
+    """Sliding-window maxima with the same shape rules as window_sums."""
+    a = _series(values)
+    _check_width(a.size, width)
+    windows = np.lib.stride_tricks.sliding_window_view(a, width)
+    return windows.max(axis=1).astype(np.int64)
+
+
+def calibrate(raw, offsets, gains):
+    """Per-sensor calibration: (row - offset) * gain, row-wise, no mutation."""
+    grid = np.asarray(raw, dtype=np.int64)
+    off = np.asarray(offsets, dtype=np.int64)
+    gain = np.asarray(gains, dtype=np.int64)
+    if grid.ndim != 2:
+        raise ValueError(f"raw grid must be 2-D, got {grid.ndim}-D")
+    if off.ndim != 1 or gain.ndim != 1:
+        raise ValueError("offsets and gains must be 1-D vectors")
+    sensors = grid.shape[0]
+    if off.size != sensors or gain.size != sensors:
+        raise ValueError(
+            f"per-sensor vectors must have length {sensors} "
+            f"(got offsets={off.size}, gains={gain.size})")
+    return (grid - off[:, None]) * gain[:, None]
+
+
+def downsample_sums(values, k):
+    """Sums of consecutive non-overlapping blocks of k readings."""
+    a = _series(values)
+    if k < 1:
+        raise ValueError(f"block size must be >= 1, got {k}")
+    if a.size % k != 0:
+        raise ValueError(f"series length {a.size} is not a multiple of {k}")
+    return a.reshape(-1, k).sum(axis=1).astype(np.int64)
+
+
+def above_streaks(grid, limit):
+    """Per-row longest run of readings strictly above limit."""
+    g = np.asarray(grid, dtype=np.int64)
+    if g.ndim != 2:
+        raise ValueError(f"grid must be 2-D, got {g.ndim}-D")
+    above = g > limit
+    # Pad each row with False on both sides, then diff to find run edges.
+    padded = np.zeros((above.shape[0], above.shape[1] + 2), dtype=np.int8)
+    padded[:, 1:-1] = above
+    edges = np.diff(padded, axis=1)
+    longest = np.zeros(g.shape[0], dtype=np.int64)
+    for row in range(g.shape[0]):
+        starts = np.flatnonzero(edges[row] == 1)
+        ends = np.flatnonzero(edges[row] == -1)
+        if starts.size:
+            longest[row] = np.max(ends - starts)
+    return longest
