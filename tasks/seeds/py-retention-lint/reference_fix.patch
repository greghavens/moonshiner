diff --git a/retention.py b/retention.py
index 230dea2..d32bf76 100644
--- a/retention.py
+++ b/retention.py
@@ -108,3 +108,75 @@ def evaluate(policy, name, age_hours):
         if pattern_matches(rule.pattern, name) and age_hours < rule.max_age_hours:
             return rule.action
     return policy.default_action
+
+
+def _covers(broad, narrow):
+    """Does `broad` match every name `narrow` matches? (patterns differ)"""
+    if not broad.endswith("*"):
+        return False
+    prefix = broad[:-1]
+    if narrow.endswith("*"):
+        return narrow[:-1].startswith(prefix)
+    return narrow.startswith(prefix)
+
+
+def _pair_finding(earlier, later):
+    if earlier.pattern == later.pattern:
+        if earlier.max_age_hours == later.max_age_hours:
+            if earlier.action == later.action:
+                return {
+                    "code": "duplicate-rule",
+                    "rule": later.name,
+                    "other": earlier.name,
+                    "message": f"rule '{later.name}' repeats rule '{earlier.name}'",
+                    "suggestion": f"delete rule '{later.name}'",
+                }
+            return {
+                "code": "conflicting-action",
+                "rule": later.name,
+                "other": earlier.name,
+                "message": (f"rule '{later.name}' contradicts rule "
+                            f"'{earlier.name}': same scope, action "
+                            f"'{later.action}' vs '{earlier.action}'"),
+                "suggestion": (f"keep one action for pattern "
+                               f"'{later.pattern}' at {later.max_age_hours}h"),
+            }
+        if earlier.max_age_hours > later.max_age_hours:
+            return {
+                "code": "unreachable-tier",
+                "rule": later.name,
+                "other": earlier.name,
+                "message": (f"rule '{later.name}' never fires: rule "
+                            f"'{earlier.name}' already covers pattern "
+                            f"'{later.pattern}' up to {earlier.max_age_hours}h"),
+                "suggestion": (f"order '{later.pattern}' tiers by "
+                               "increasing max_age"),
+            }
+        return None
+    if _covers(earlier.pattern, later.pattern) and \
+            earlier.max_age_hours >= later.max_age_hours:
+        return {
+            "code": "shadowed-rule",
+            "rule": later.name,
+            "other": earlier.name,
+            "message": (f"rule '{later.name}' never fires: rule "
+                        f"'{earlier.name}' matches everything it matches first"),
+            "suggestion": f"move rule '{later.name}' above rule '{earlier.name}'",
+        }
+    return None
+
+
+def lint_policy(policy):
+    """Static checks over rule order: one finding per dead/conflicted rule.
+
+    Each rule is reported at most once, against the EARLIEST earlier rule
+    responsible; findings come back in rule-definition order.
+    """
+    findings = []
+    for j, later in enumerate(policy.rules):
+        for earlier in policy.rules[:j]:
+            finding = _pair_finding(earlier, later)
+            if finding is not None:
+                findings.append(finding)
+                break
+    return findings
