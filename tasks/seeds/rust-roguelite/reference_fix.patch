+//! Deterministic dungeon-crawl engine for the game-jam kiosk build: fixture
+//! maps, fog of war, chasing monsters with a pinned tie-break, fixed-damage
+//! combat, potions, stairs. Everything replayable byte for byte.
+
+pub const PLAYER_MAX_HP: i32 = 10;
+pub const PLAYER_ATTACK: i32 = 3;
+pub const MONSTER_HP: i32 = 6;
+pub const MONSTER_ATTACK: i32 = 2;
+pub const SIGHT_RADIUS: usize = 2; // Chebyshev
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum Status {
+    Playing,
+    Won,
+    Dead,
+}
+
+#[derive(Debug, Clone)]
+pub struct Game {
+    tiles: Vec<Vec<u8>>, // b'#', b'.', b'!', b'>'
+    revealed: Vec<Vec<bool>>,
+    player: (usize, usize),
+    hp: i32,
+    monsters: Vec<(usize, usize, i32)>, // row, col, hp
+    status: Status,
+}
+
+// Chase priority order (and the order the player commands use too).
+const DIRS: [(char, i32, i32); 4] = [('N', -1, 0), ('E', 0, 1), ('S', 1, 0), ('W', 0, -1)];
+
+fn manhattan(a: (usize, usize), b: (usize, usize)) -> usize {
+    a.0.abs_diff(b.0) + a.1.abs_diff(b.1)
+}
+
+impl Game {
+    pub fn load(map: &str) -> Result<Game, String> {
+        let lines: Vec<&str> = map.lines().filter(|l| !l.is_empty()).collect();
+        if lines.is_empty() {
+            return Err("empty map".to_string());
+        }
+        let width = lines[0].len();
+        let mut tiles = Vec::new();
+        let mut player = None;
+        let mut players = 0;
+        let mut monsters = Vec::new();
+        for (r, line) in lines.iter().enumerate() {
+            if line.len() != width {
+                return Err("map must be rectangular".to_string());
+            }
+            let mut row = Vec::with_capacity(width);
+            for (c, ch) in line.bytes().enumerate() {
+                match ch {
+                    b'#' | b'.' | b'!' | b'>' => row.push(ch),
+                    b'@' => {
+                        players += 1;
+                        player = Some((r, c));
+                        row.push(b'.');
+                    }
+                    b'M' => {
+                        monsters.push((r, c, MONSTER_HP));
+                        row.push(b'.');
+                    }
+                    _ => return Err(format!("bad tile: '{}'", ch as char)),
+                }
+            }
+            tiles.push(row);
+        }
+        if players != 1 {
+            return Err(format!("expected exactly one '@', got {players}"));
+        }
+        let revealed = vec![vec![false; width]; tiles.len()];
+        let mut game = Game {
+            tiles,
+            revealed,
+            player: player.unwrap(),
+            hp: PLAYER_MAX_HP,
+            monsters,
+            status: Status::Playing,
+        };
+        game.reveal();
+        Ok(game)
+    }
+
+    fn reveal(&mut self) {
+        let (pr, pc) = self.player;
+        for r in 0..self.tiles.len() {
+            for c in 0..self.tiles[0].len() {
+                if pr.abs_diff(r) <= SIGHT_RADIUS && pc.abs_diff(c) <= SIGHT_RADIUS {
+                    self.revealed[r][c] = true;
+                }
+            }
+        }
+    }
+
+    pub fn hp(&self) -> i32 {
+        self.hp
+    }
+
+    pub fn status(&self) -> Status {
+        self.status
+    }
+
+    pub fn monsters_left(&self) -> usize {
+        self.monsters.len()
+    }
+
+    pub fn render(&self) -> String {
+        let (pr, pc) = self.player;
+        let mut out = Vec::new();
+        for r in 0..self.tiles.len() {
+            let mut line = String::new();
+            for c in 0..self.tiles[0].len() {
+                let ch = if !self.revealed[r][c] {
+                    '?'
+                } else if (r, c) == self.player {
+                    '@'
+                } else if pr.abs_diff(r) <= SIGHT_RADIUS
+                    && pc.abs_diff(c) <= SIGHT_RADIUS
+                    && self.monsters.iter().any(|&(mr, mc, _)| (mr, mc) == (r, c))
+                {
+                    'M'
+                } else {
+                    self.tiles[r][c] as char
+                };
+                line.push(ch);
+            }
+            out.push(line);
+        }
+        out.join("\n")
+    }
+
+    fn walkable(&self, r: i32, c: i32) -> bool {
+        r >= 0
+            && c >= 0
+            && (r as usize) < self.tiles.len()
+            && (c as usize) < self.tiles[0].len()
+            && self.tiles[r as usize][c as usize] != b'#'
+    }
+
+    pub fn step(&mut self, cmd: char) -> Result<(), String> {
+        if self.status != Status::Playing {
+            return Err("game over".to_string());
+        }
+        match cmd {
+            '.' => {}
+            'N' | 'E' | 'S' | 'W' => {
+                let (_, dr, dc) = *DIRS.iter().find(|(d, _, _)| *d == cmd).unwrap();
+                let (nr, nc) = (self.player.0 as i32 + dr, self.player.1 as i32 + dc);
+                if !self.walkable(nr, nc) {
+                    return Err("blocked".to_string());
+                }
+                let (nr, nc) = (nr as usize, nc as usize);
+                if let Some(i) = self
+                    .monsters
+                    .iter()
+                    .position(|&(mr, mc, _)| (mr, mc) == (nr, nc))
+                {
+                    // Bump attack: the player stays put.
+                    self.monsters[i].2 -= PLAYER_ATTACK;
+                    if self.monsters[i].2 <= 0 {
+                        self.monsters.remove(i);
+                    }
+                } else {
+                    self.player = (nr, nc);
+                    match self.tiles[nr][nc] {
+                        b'!' => {
+                            self.hp = (self.hp + 4).min(PLAYER_MAX_HP);
+                            self.tiles[nr][nc] = b'.';
+                        }
+                        b'>' => {
+                            self.reveal();
+                            self.status = Status::Won;
+                            return Ok(()); // descending ends the turn instantly
+                        }
+                        _ => {}
+                    }
+                }
+            }
+            other => return Err(format!("bad command: {other}")),
+        }
+        self.reveal();
+        self.monster_phase();
+        Ok(())
+    }
+
+    fn monster_phase(&mut self) {
+        // Row-major order of positions at the start of the phase.
+        let mut order: Vec<(usize, usize)> = self.monsters.iter().map(|&(r, c, _)| (r, c)).collect();
+        order.sort();
+        for start_pos in order {
+            let Some(i) = self
+                .monsters
+                .iter()
+                .position(|&(mr, mc, _)| (mr, mc) == start_pos)
+            else {
+                continue;
+            };
+            let (mr, mc, _) = self.monsters[i];
+            if manhattan((mr, mc), self.player) == 1 {
+                self.hp -= MONSTER_ATTACK;
+                if self.hp <= 0 {
+                    self.status = Status::Dead;
+                    return;
+                }
+                continue;
+            }
+            let here = manhattan((mr, mc), self.player);
+            for (_, dr, dc) in DIRS {
+                let (nr, nc) = (mr as i32 + dr, mc as i32 + dc);
+                if !self.walkable(nr, nc) {
+                    continue;
+                }
+                let (nr, nc) = (nr as usize, nc as usize);
+                // Monsters keep to plain floor: no potions, no stairs, no
+                // stacking, and the player square is handled by the attack
+                // rule above.
+                if self.tiles[nr][nc] != b'.'
+                    || (nr, nc) == self.player
+                    || self.monsters.iter().any(|&(or, oc, _)| (or, oc) == (nr, nc))
+                {
+                    continue;
+                }
+                if manhattan((nr, nc), self.player) < here {
+                    self.monsters[i].0 = nr;
+                    self.monsters[i].1 = nc;
+                    break;
+                }
+            }
+        }
+    }
+
+    pub fn run(&mut self, script: &str) -> Result<usize, String> {
+        let mut n = 0;
+        for cmd in script.chars().filter(|c| !c.is_whitespace()) {
+            n += 1;
+            self.step(cmd).map_err(|e| format!("step {n} ({cmd}): {e}"))?;
+        }
+        Ok(n)
+    }
+}
