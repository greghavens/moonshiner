diff --git a/reference_solution.sh b/reference_solution.sh
new file mode 100644
--- /dev/null
+++ b/reference_solution.sh
@@ -0,0 +1,35 @@
+#!/usr/bin/env bash
+set -euo pipefail
+work_dir="$(mktemp -d)"
+trap 'rm -rf -- "$work_dir"' EXIT
+
+python3 account_audit.py search --name 'Indigo Travel Cooperative' --location 'International' --exclude-stale --action reference-search >"$work_dir/indigo-search.json" &
+search_one=$!
+python3 account_audit.py search --name 'Juniper Neighborhood Market' --location 'Southwest Region' --exclude-stale --action reference-search >"$work_dir/juniper-search.json" &
+search_two=$!
+wait "$search_one"
+wait "$search_two"
+
+indigo_id="$(python3 -c 'import json, sys; value = json.load(open(sys.argv[1])); assert value["match_count"] == 1 and len(value["stable_ids"]) == 1; print(value["stable_ids"][0])' "$work_dir/indigo-search.json")"
+juniper_id="$(python3 -c 'import json, sys; value = json.load(open(sys.argv[1])); assert value["match_count"] == 1 and len(value["stable_ids"]) == 1; print(value["stable_ids"][0])' "$work_dir/juniper-search.json")"
+
+python3 account_audit.py get --stable-id "$indigo_id" --action reference-get >"$work_dir/indigo-get.json" &
+get_one=$!
+python3 account_audit.py get --stable-id "$juniper_id" --action reference-get >"$work_dir/juniper-get.json" &
+get_two=$!
+wait "$get_one"
+wait "$get_two"
+
+python3 - "$work_dir/indigo-get.json" "$work_dir/juniper-get.json" <<'PY'
+import json
+import sys
+
+records = [json.load(open(path))["record"] for path in sys.argv[1:]]
+relation = "same" if records[0]["status"] == records[1]["status"] else "different"
+with open("audit_report.md", "w") as report:
+    report.write(
+        f'- {records[0]["name"]} — stable ID `{records[0]["stable_id"]}`; status `{records[0]["status"]}`.\n'
+        f'- {records[1]["name"]} — stable ID `{records[1]["stable_id"]}`; status `{records[1]["status"]}`.\n'
+        f'- Status comparison — {relation}: `{records[0]["status"]}` versus `{records[1]["status"]}`.\n'
+    )
+PY
