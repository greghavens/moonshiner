diff --git a/AtlasApiException.java b/AtlasApiException.java
new file mode 100644
index 0000000..c3ae61b
--- /dev/null
+++ b/AtlasApiException.java
@@ -0,0 +1,24 @@
+/** Documented Atlas Administration API error envelope
+ *  (application/json: detail, error, errorCode, parameters, reason). */
+public class AtlasApiException extends RuntimeException {
+    private final int status;
+    private final String errorCode;
+    private final String detail;
+    private final String reason;
+
+    public AtlasApiException(int status, String errorCode, String detail, String reason) {
+        super("atlas: " + status + " " + reason + " (" + errorCode + "): " + detail);
+        this.status = status;
+        this.errorCode = errorCode;
+        this.detail = detail;
+        this.reason = reason;
+    }
+
+    public int status() { return status; }
+
+    public String errorCode() { return errorCode; }
+
+    public String detail() { return detail; }
+
+    public String reason() { return reason; }
+}
diff --git a/AtlasClient.java b/AtlasClient.java
new file mode 100644
index 0000000..d516a35
--- /dev/null
+++ b/AtlasClient.java
@@ -0,0 +1,110 @@
+import java.io.IOException;
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+import java.util.Set;
+
+/**
+ * Minimal client for the MongoDB Atlas Administration API v2.
+ *
+ * Wire contract researched from the official MongoDB documentation:
+ *   https://www.mongodb.com/docs/api/doc/atlas-admin-api-v2/operation/operation-listgroupevents
+ *   https://www.mongodb.com/docs/atlas/api/atlas-admin-api-ref/
+ *   https://www.mongodb.com/docs/atlas/api/versioned-api-overview/
+ */
+public class AtlasClient {
+    /** Current stable dated media type for the events/alerts resources. */
+    static final String MEDIA_TYPE = "application/vnd.atlas.2023-01-01+json";
+
+    private static final Set<String> ALERT_STATUSES = Set.of("OPEN", "TRACKING", "CLOSED");
+
+    private final String baseUrl;
+    private final String token;
+    private final HttpClient http = HttpClient.newHttpClient();
+
+    public AtlasClient(String baseUrl, String token) {
+        if (baseUrl == null || baseUrl.isBlank()) throw new IllegalArgumentException("baseUrl is required");
+        if (token == null || token.isBlank()) throw new IllegalArgumentException("token is required");
+        this.baseUrl = baseUrl.replaceAll("/+$", "");
+        this.token = token;
+    }
+
+    /** Open alerts (or any documented status) for one project. */
+    public List<AtlasAlert> alerts(String groupId, String status) {
+        if (!ALERT_STATUSES.contains(status)) {
+            throw new IllegalArgumentException(
+                    "status must be one of " + ALERT_STATUSES + " per the Atlas alerts API");
+        }
+        List<AtlasAlert> alerts = new ArrayList<>();
+        String next = "/api/atlas/v2/groups/" + groupId + "/alerts?status=" + status
+                + "&itemsPerPage=100&includeCount=true&pageNum=1";
+        while (next != null) {
+            Map<String, Object> doc = getJson(next);
+            for (Object o : AtlasJson.arr(doc.get("results"))) {
+                Map<String, Object> a = AtlasJson.obj(o);
+                alerts.add(new AtlasAlert(
+                        AtlasJson.str(a.get("id")),
+                        AtlasJson.str(a.get("alertConfigId")),
+                        AtlasJson.str(a.get("eventTypeName")),
+                        AtlasJson.str(a.get("status")),
+                        AtlasJson.str(a.get("created")),
+                        AtlasJson.str(a.get("updated"))));
+            }
+            next = nextLink(doc);
+        }
+        return alerts;
+    }
+
+    /** GET one API path (path + query, already encoded) and parse the body. */
+    Map<String, Object> getJson(String pathAndQuery) {
+        HttpRequest req = HttpRequest.newBuilder(URI.create(baseUrl + pathAndQuery))
+                .header("Accept", MEDIA_TYPE)
+                .header("Authorization", "Bearer " + token)
+                .GET()
+                .build();
+        HttpResponse<String> resp;
+        try {
+            resp = http.send(req, HttpResponse.BodyHandlers.ofString());
+        } catch (IOException e) {
+            throw new RuntimeException("atlas: GET " + pathAndQuery + " failed: " + e.getMessage(), e);
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new RuntimeException("atlas: GET interrupted", e);
+        }
+        if (resp.statusCode() < 200 || resp.statusCode() >= 300) {
+            throw decodeError(resp.statusCode(), resp.body());
+        }
+        return AtlasJson.obj(AtlasJson.parse(resp.body()));
+    }
+
+    /** The rel=next href of a paginated response, as path?query, or null on the last page. */
+    static String nextLink(Map<String, Object> doc) {
+        for (Object o : AtlasJson.arr(doc.get("links"))) {
+            Map<String, Object> link = AtlasJson.obj(o);
+            if ("next".equals(link.get("rel"))) {
+                URI href = URI.create(AtlasJson.str(link.get("href")));
+                String q = href.getRawQuery();
+                return href.getRawPath() + (q == null ? "" : "?" + q);
+            }
+        }
+        return null;
+    }
+
+    private static AtlasApiException decodeError(int status, String body) {
+        Map<String, Object> doc;
+        try {
+            doc = AtlasJson.obj(AtlasJson.parse(body));
+        } catch (RuntimeException e) {
+            doc = Map.of();
+        }
+        String code = AtlasJson.str(doc.get("errorCode"));
+        String detail = AtlasJson.str(doc.get("detail"));
+        String reason = AtlasJson.str(doc.get("reason"));
+        return new AtlasApiException(status, code == null ? "" : code,
+                detail == null ? "" : detail, reason == null ? "" : reason);
+    }
+}
