diff --git a/AtlasJson.java b/AtlasJson.java
new file mode 100644
index 0000000..4e4bd93
--- /dev/null
+++ b/AtlasJson.java
@@ -0,0 +1,111 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** Minimal JSON reader for the small Atlas response documents this
+ *  exporter consumes (objects, arrays, strings, numbers, booleans, null). */
+final class AtlasJson {
+    private final String s;
+    private int i = 0;
+
+    private AtlasJson(String s) { this.s = s; }
+
+    static Object parse(String text) {
+        AtlasJson p = new AtlasJson(text);
+        Object v = p.value();
+        p.ws();
+        if (p.i != p.s.length()) throw new IllegalArgumentException("trailing JSON at offset " + p.i);
+        return v;
+    }
+
+    @SuppressWarnings("unchecked")
+    static Map<String, Object> obj(Object o) { return o instanceof Map ? (Map<String, Object>) o : Map.of(); }
+
+    @SuppressWarnings("unchecked")
+    static List<Object> arr(Object o) { return o instanceof List ? (List<Object>) o : List.of(); }
+
+    static String str(Object o) { return o instanceof String ? (String) o : null; }
+
+    private void ws() { while (i < s.length() && Character.isWhitespace(s.charAt(i))) i++; }
+
+    private void expect(char c) {
+        if (i >= s.length() || s.charAt(i) != c) throw new IllegalArgumentException("expected '" + c + "' at " + i);
+        i++;
+    }
+
+    private Object value() {
+        ws();
+        char c = s.charAt(i);
+        switch (c) {
+            case '{': return object();
+            case '[': return array();
+            case '"': return string();
+            case 't': i += 4; return Boolean.TRUE;
+            case 'f': i += 5; return Boolean.FALSE;
+            case 'n': i += 4; return null;
+            default: return number();
+        }
+    }
+
+    private Map<String, Object> object() {
+        Map<String, Object> m = new LinkedHashMap<>();
+        expect('{');
+        ws();
+        if (s.charAt(i) == '}') { i++; return m; }
+        while (true) {
+            ws();
+            String k = string();
+            ws();
+            expect(':');
+            m.put(k, value());
+            ws();
+            if (s.charAt(i) == ',') { i++; continue; }
+            expect('}');
+            return m;
+        }
+    }
+
+    private List<Object> array() {
+        List<Object> l = new ArrayList<>();
+        expect('[');
+        ws();
+        if (s.charAt(i) == ']') { i++; return l; }
+        while (true) {
+            l.add(value());
+            ws();
+            if (s.charAt(i) == ',') { i++; continue; }
+            expect(']');
+            return l;
+        }
+    }
+
+    private String string() {
+        expect('"');
+        StringBuilder b = new StringBuilder();
+        while (true) {
+            char c = s.charAt(i++);
+            if (c == '"') return b.toString();
+            if (c == '\\') {
+                char e = s.charAt(i++);
+                switch (e) {
+                    case 'n': b.append('\n'); break;
+                    case 't': b.append('\t'); break;
+                    case 'b': b.append('\b'); break;
+                    case 'f': b.append('\f'); break;
+                    case 'r': b.append('\r'); break;
+                    case 'u': b.append((char) Integer.parseInt(s.substring(i, i + 4), 16)); i += 4; break;
+                    default: b.append(e);
+                }
+            } else {
+                b.append(c);
+            }
+        }
+    }
+
+    private Double number() {
+        int start = i;
+        while (i < s.length() && "+-0123456789.eE".indexOf(s.charAt(i)) >= 0) i++;
+        return Double.valueOf(s.substring(start, i));
+    }
+}
diff --git a/EventExporter.java b/EventExporter.java
new file mode 100644
index 0000000..5b5581c
--- /dev/null
+++ b/EventExporter.java
@@ -0,0 +1,98 @@
+import java.io.IOException;
+import java.io.UncheckedIOException;
+import java.net.URLEncoder;
+import java.nio.charset.StandardCharsets;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Exports project events to a sink with a durable checkpoint.
+ *
+ * Ordering guarantees per the audit requirements: the full paginated scan
+ * is buffered and deduplicated by event id (pages can drift while new
+ * events arrive), the sink gets exactly one in-order delivery, and the
+ * checkpoint file advances only after that delivery succeeded.
+ */
+public class EventExporter {
+    private final AtlasClient client;
+    private final Path checkpointFile;
+
+    public EventExporter(AtlasClient client, Path checkpointFile) {
+        this.client = client;
+        this.checkpointFile = checkpointFile;
+    }
+
+    public ExportReport export(String groupId, List<String> eventTypes, EventSink sink) {
+        String checkpoint = readCheckpoint();
+
+        StringBuilder query = new StringBuilder();
+        for (String type : eventTypes) {
+            query.append("eventType=").append(encode(type)).append('&');
+        }
+        if (checkpoint != null) {
+            query.append("minDate=").append(encode(checkpoint)).append('&');
+        }
+        query.append("itemsPerPage=100&includeCount=true&pageNum=1");
+
+        String next = "/api/atlas/v2/groups/" + groupId + "/events?" + query;
+        Map<String, AtlasEvent> byId = new LinkedHashMap<>();
+        int totalCount = 0;
+        while (next != null) {
+            Map<String, Object> doc = client.getJson(next);
+            Object count = doc.get("totalCount");
+            if (count instanceof Number n) totalCount = n.intValue();
+            for (Object o : AtlasJson.arr(doc.get("results"))) {
+                Map<String, Object> e = AtlasJson.obj(o);
+                AtlasEvent event = new AtlasEvent(
+                        AtlasJson.str(e.get("id")),
+                        AtlasJson.str(e.get("eventTypeName")),
+                        AtlasJson.str(e.get("created")),
+                        AtlasJson.str(e.get("username")));
+                byId.putIfAbsent(event.id(), event);
+            }
+            next = AtlasClient.nextLink(doc);
+        }
+
+        List<AtlasEvent> events = List.copyOf(new ArrayList<>(byId.values()));
+        if (!events.isEmpty()) {
+            sink.deliver(events);
+            writeCheckpoint(newestCreated(events));
+        }
+        return new ExportReport(events.size(), totalCount);
+    }
+
+    private static String newestCreated(List<AtlasEvent> events) {
+        // ISO 8601 UTC timestamps order lexicographically.
+        String newest = null;
+        for (AtlasEvent e : events) {
+            if (newest == null || e.created().compareTo(newest) > 0) newest = e.created();
+        }
+        return newest;
+    }
+
+    private String readCheckpoint() {
+        try {
+            if (!Files.exists(checkpointFile)) return null;
+            String value = Files.readString(checkpointFile, StandardCharsets.UTF_8).strip();
+            return value.isEmpty() ? null : value;
+        } catch (IOException e) {
+            throw new UncheckedIOException("reading checkpoint " + checkpointFile, e);
+        }
+    }
+
+    private void writeCheckpoint(String value) {
+        try {
+            Files.writeString(checkpointFile, value, StandardCharsets.UTF_8);
+        } catch (IOException e) {
+            throw new UncheckedIOException("writing checkpoint " + checkpointFile, e);
+        }
+    }
+
+    private static String encode(String value) {
+        return URLEncoder.encode(value, StandardCharsets.UTF_8);
+    }
+}
