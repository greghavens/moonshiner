+// Minesweeper engine as pure functions. No CLI, no timers, no randomness:
+// boards come from fixture layout strings, every mutator returns a fresh
+// Game and never touches its argument. No-op actions return the SAME object.
+
+export type Mark = 'none' | 'flag' | 'question';
+export type Status = 'playing' | 'won' | 'lost';
+
+export interface Game {
+  readonly rows: number;
+  readonly cols: number;
+  readonly mines: ReadonlyArray<ReadonlyArray<boolean>>;
+  readonly revealed: ReadonlyArray<ReadonlyArray<boolean>>;
+  readonly marks: ReadonlyArray<ReadonlyArray<Mark>>;
+  readonly status: Status;
+  readonly boom: readonly [number, number] | null;
+}
+
+export function parseLayout(text: string): boolean[][] {
+  const lines = text.split('\n');
+  while (lines.length > 0 && lines[lines.length - 1] === '') lines.pop();
+  if (lines.length === 0 || lines[0].length === 0) {
+    throw new Error('empty layout');
+  }
+  const cols = lines[0].length;
+  return lines.map((line, r) => {
+    if (line.length !== cols) {
+      throw new Error(`ragged layout at line ${r + 1}`);
+    }
+    return [...line].map((ch) => {
+      if (ch === '*') return true;
+      if (ch === '.') return false;
+      throw new Error(`bad layout character: ${JSON.stringify(ch)}`);
+    });
+  });
+}
+
+export function newGame(layout: string): Game {
+  const mines = parseLayout(layout);
+  const rows = mines.length;
+  const cols = mines[0].length;
+  return {
+    rows,
+    cols,
+    mines,
+    revealed: mines.map((row) => row.map(() => false)),
+    marks: mines.map((row) => row.map(() => 'none' as Mark)),
+    status: 'playing',
+    boom: null,
+  };
+}
+
+function checkBounds(game: Game, r: number, c: number): void {
+  if (!Number.isInteger(r) || !Number.isInteger(c) ||
+      r < 0 || r >= game.rows || c < 0 || c >= game.cols) {
+    throw new RangeError(`cell out of range: (${r}, ${c})`);
+  }
+}
+
+interface Draft {
+  rows: number;
+  cols: number;
+  mines: ReadonlyArray<ReadonlyArray<boolean>>;
+  revealed: boolean[][];
+  marks: Mark[][];
+  status: Status;
+  boom: readonly [number, number] | null;
+}
+
+function draft(game: Game): Draft {
+  return {
+    rows: game.rows,
+    cols: game.cols,
+    mines: game.mines,
+    revealed: game.revealed.map((row) => row.slice()),
+    marks: game.marks.map((row) => row.slice()),
+    status: game.status,
+    boom: game.boom,
+  };
+}
+
+function neighbors(game: { rows: number; cols: number }, r: number, c: number): Array<[number, number]> {
+  const out: Array<[number, number]> = [];
+  for (let dr = -1; dr <= 1; dr++) {
+    for (let dc = -1; dc <= 1; dc++) {
+      if (dr === 0 && dc === 0) continue;
+      const nr = r + dr;
+      const nc = c + dc;
+      if (nr >= 0 && nr < game.rows && nc >= 0 && nc < game.cols) {
+        out.push([nr, nc]);
+      }
+    }
+  }
+  return out;
+}
+
+export function adjacency(game: Game, r: number, c: number): number {
+  checkBounds(game, r, c);
+  let n = 0;
+  for (const [nr, nc] of neighbors(game, r, c)) {
+    if (game.mines[nr][nc]) n++;
+  }
+  return n;
+}
+
+function adjacencyOf(d: Draft, r: number, c: number): number {
+  let n = 0;
+  for (const [nr, nc] of neighbors(d, r, c)) {
+    if (d.mines[nr][nc]) n++;
+  }
+  return n;
+}
+
+// Flood-fill from a safe cell: reveal it (clearing a question mark), and if
+// its adjacency is zero keep expanding through the 8-neighborhood. Flagged
+// cells are never revealed by the flood; question-marked cells are.
+function floodReveal(d: Draft, r: number, c: number): void {
+  const stack: Array<[number, number]> = [[r, c]];
+  while (stack.length > 0) {
+    const [cr, cc] = stack.pop()!;
+    if (d.revealed[cr][cc] || d.marks[cr][cc] === 'flag') continue;
+    d.revealed[cr][cc] = true;
+    d.marks[cr][cc] = 'none';
+    if (adjacencyOf(d, cr, cc) === 0) {
+      for (const [nr, nc] of neighbors(d, cr, cc)) {
+        if (!d.revealed[nr][nc] && !d.mines[nr][nc]) stack.push([nr, nc]);
+      }
+    }
+  }
+}
+
+function settleWin(d: Draft): void {
+  for (let r = 0; r < d.rows; r++) {
+    for (let c = 0; c < d.cols; c++) {
+      if (!d.mines[r][c] && !d.revealed[r][c]) return;
+    }
+  }
+  d.status = 'won';
+}
+
+export function reveal(game: Game, r: number, c: number): Game {
+  checkBounds(game, r, c);
+  if (game.status !== 'playing') return game;
+  if (game.revealed[r][c]) return game;
+  if (game.marks[r][c] === 'flag') return game;
+  const d = draft(game);
+  if (d.mines[r][c]) {
+    d.revealed[r][c] = true;
+    d.marks[r][c] = 'none';
+    d.status = 'lost';
+    d.boom = [r, c];
+    return d;
+  }
+  floodReveal(d, r, c);
+  settleWin(d);
+  return d;
+}
+
+export function mark(game: Game, r: number, c: number): Game {
+  checkBounds(game, r, c);
+  if (game.status !== 'playing') return game;
+  if (game.revealed[r][c]) return game;
+  const d = draft(game);
+  const cycle: Record<Mark, Mark> = { none: 'flag', flag: 'question', question: 'none' };
+  d.marks[r][c] = cycle[d.marks[r][c]];
+  return d;
+}
+
+// Chord a satisfied number: the cell must already be revealed, its adjacency
+// must be non-zero, and the count of FLAGGED neighbors (question marks do
+// not count) must equal that adjacency. Neighbors are then revealed in
+// reading order (row-major over the 3x3 block, centre skipped); the first
+// mine hit ends the game on the spot with that cell as the boom.
+export function chord(game: Game, r: number, c: number): Game {
+  checkBounds(game, r, c);
+  if (game.status !== 'playing') return game;
+  if (!game.revealed[r][c]) return game;
+  const adj = adjacency(game, r, c);
+  if (adj === 0) return game;
+  let flags = 0;
+  for (const [nr, nc] of neighbors(game, r, c)) {
+    if (game.marks[nr][nc] === 'flag') flags++;
+  }
+  if (flags !== adj) return game;
+  const d = draft(game);
+  for (const [nr, nc] of neighbors(d, r, c)) {
+    if (d.revealed[nr][nc] || d.marks[nr][nc] === 'flag') continue;
+    if (d.mines[nr][nc]) {
+      d.revealed[nr][nc] = true;
+      d.marks[nr][nc] = 'none';
+      d.status = 'lost';
+      d.boom = [nr, nc];
+      return d;
+    }
+    floodReveal(d, nr, nc);
+  }
+  settleWin(d);
+  return d;
+}
+
+export function flagsRemaining(game: Game): number {
+  let mines = 0;
+  let flags = 0;
+  for (let r = 0; r < game.rows; r++) {
+    for (let c = 0; c < game.cols; c++) {
+      if (game.mines[r][c]) mines++;
+      if (game.marks[r][c] === 'flag') flags++;
+    }
+  }
+  return mines - flags;
+}
+
+export function render(game: Game): string {
+  const lines: string[] = [];
+  for (let r = 0; r < game.rows; r++) {
+    let line = '';
+    for (let c = 0; c < game.cols; c++) {
+      line += cellChar(game, r, c);
+    }
+    lines.push(line);
+  }
+  return lines.join('\n');
+}
+
+function cellChar(game: Game, r: number, c: number): string {
+  const mine = game.mines[r][c];
+  const mk = game.marks[r][c];
+  if (game.status === 'lost') {
+    if (mine) {
+      if (game.boom && game.boom[0] === r && game.boom[1] === c) return '!';
+      return mk === 'flag' ? 'F' : '*';
+    }
+    if (mk === 'flag') return 'X';
+  }
+  if (game.revealed[r][c]) {
+    const adj = adjacency(game, r, c);
+    return adj === 0 ? '.' : String(adj);
+  }
+  if (mk === 'flag') return 'F';
+  if (mk === 'question') return '?';
+  return '#';
+}
