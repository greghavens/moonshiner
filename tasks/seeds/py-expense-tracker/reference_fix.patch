+#!/usr/bin/env python3
+"""Expense tracker CLI: import bank CSVs, monthly category reports, balances."""
+import argparse
+import os
+import sys
+from collections import defaultdict
+
+import ledger
+import money
+import rulebook
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="expenses.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_imp = sub.add_parser("import")
+    p_imp.add_argument("csvfile")
+    p_imp.add_argument("--db", required=True)
+
+    p_rep = sub.add_parser("report")
+    p_rep.add_argument("--db", required=True)
+    p_rep.add_argument("--rules", required=True)
+    p_rep.add_argument("--month", required=True)
+
+    p_bal = sub.add_parser("balance")
+    p_bal.add_argument("--db", required=True)
+    p_bal.add_argument("--until", default=None)
+    return parser
+
+
+def cmd_import(args):
+    if not os.path.exists(args.csvfile):
+        print(f"no such file: {args.csvfile}", file=sys.stderr)
+        return 2
+    txns = ledger.load(args.db)
+    try:
+        incoming = ledger.parse_csv(args.csvfile)
+    except ValueError as exc:
+        print(f"import aborted, ledger unchanged: {exc}", file=sys.stderr)
+        return 1
+    imported, skipped = ledger.merge(txns, incoming)
+    ledger.save(args.db, txns)
+    print(f"imported {imported}, skipped {skipped}")
+    return 0
+
+
+def cmd_report(args):
+    if not os.path.exists(args.rules):
+        print(f"no such rules file: {args.rules}", file=sys.stderr)
+        return 2
+    rules = rulebook.load(args.rules)
+    txns = [t for t in ledger.load(args.db) if t["date"][:7] == args.month]
+    income = sum(t["cents"] for t in txns if t["cents"] > 0)
+    spent = -sum(t["cents"] for t in txns if t["cents"] < 0)
+    by_category = defaultdict(int)
+    for t in txns:
+        if t["cents"] < 0:
+            by_category[rulebook.categorize(rules, t["description"])] += -t["cents"]
+    print(f"month: {args.month}")
+    print(f"income: {money.fmt(income)}")
+    print(f"expenses: {money.fmt(spent)}")
+    print(f"net: {money.fmt(income - spent)}")
+    for category, cents in sorted(by_category.items(), key=lambda kv: (-kv[1], kv[0])):
+        print(f"  {category}: {money.fmt(cents)}")
+    return 0
+
+
+def cmd_balance(args):
+    txns = ledger.load(args.db)
+    if args.until is not None:
+        txns = [t for t in txns if t["date"] <= args.until]
+    print(f"balance: {money.fmt(sum(t['cents'] for t in txns))}")
+    return 0
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    handler = {"import": cmd_import, "report": cmd_report, "balance": cmd_balance}
+    return handler[args.command](args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
