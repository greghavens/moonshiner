+"""Category rules: ordered `substring=category` lines, first match wins."""
+
+UNCATEGORIZED = "uncategorized"
+
+
+def load(path):
+    rules = []
+    with open(path, encoding="utf-8") as f:
+        for line in f:
+            line = line.strip()
+            if not line:
+                continue
+            needle, _, category = line.partition("=")
+            rules.append((needle.casefold(), category.strip()))
+    return rules
+
+
+def categorize(rules, description):
+    folded = description.casefold()
+    for needle, category in rules:
+        if needle in folded:
+            return category
+    return UNCATEGORIZED
