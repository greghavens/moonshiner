+"""JSON ledger storage and CSV import (atomic: all rows or none)."""
+import csv
+import json
+import os
+from datetime import date
+
+import money
+
+HEADER = ["date", "description", "amount"]
+
+
+def load(path):
+    if not os.path.exists(path):
+        return []
+    with open(path, encoding="utf-8") as f:
+        return json.load(f)
+
+
+def save(path, txns):
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(txns, f, indent=1)
+        f.write("\n")
+
+
+def parse_csv(path):
+    """Read a bank CSV -> list of txn dicts. Raises ValueError on any bad row
+    or wrong header, so a broken file imports nothing."""
+    txns = []
+    with open(path, newline="", encoding="utf-8") as f:
+        reader = csv.reader(f)
+        header = next(reader, None)
+        if header != HEADER:
+            raise ValueError(f"expected header {HEADER}, got {header}")
+        for lineno, row in enumerate(reader, start=2):
+            if not row:
+                continue
+            if len(row) != 3:
+                raise ValueError(f"line {lineno}: expected 3 fields, got {len(row)}")
+            when, description, amount = row
+            try:
+                date.fromisoformat(when)
+            except ValueError:
+                raise ValueError(f"line {lineno}: bad date {when!r}")
+            txns.append({"date": when, "description": description,
+                         "cents": money.parse_amount(amount)})
+    return txns
+
+
+def key(txn):
+    return (txn["date"], txn["description"], txn["cents"])
+
+
+def merge(existing, incoming):
+    """Append non-duplicate incoming txns. Returns (imported, skipped)."""
+    seen = {key(t) for t in existing}
+    imported = skipped = 0
+    for txn in incoming:
+        if key(txn) in seen:
+            skipped += 1
+            continue
+        seen.add(key(txn))
+        existing.append(txn)
+        imported += 1
+    return imported, skipped
