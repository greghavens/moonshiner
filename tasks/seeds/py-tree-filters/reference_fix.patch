+
+def tree_lines(root, include=None, exclude=None, max_depth=None):
     """Return the tree under ``root`` as a list of lines.
 
     Directories come first at every level, everything is sorted
     case-insensitively, directories carry a trailing '/', and each level
     of nesting indents by two spaces.  The root itself is not printed.
+
+    ``include`` — glob patterns matched against file basenames; when given,
+    only matching files appear and directories with no visible file beneath
+    them are pruned.  ``exclude`` — glob patterns matched against file AND
+    directory basenames; excluded directories are not walked, and exclude
+    beats include.  Empty pattern lists mean "no filter".  ``max_depth``
+    caps the walk (direct children of the root are depth 1); it must be at
+    least 1.  Pruning only counts matches within the depth cap.
     """
     if not os.path.isdir(root):
         raise ValueError("not a directory: %s" % root)
+    if max_depth is not None and max_depth < 1:
+        raise ValueError("max_depth must be at least 1, got %r" % max_depth)
+
+    include = list(include) if include else None
+    exclude = list(exclude) if exclude else []
 
     lines = []
 
     def walk(path, depth):
+        """Emit lines for ``path``'s entries; report whether any file that
+        survives the filters was emitted at or below this level."""
+        if max_depth is not None and depth > max_depth:
+            return False
         dirs, files = _entries(path)
         indent = "  " * (depth - 1)
+        any_file = False
         for d in dirs:
+            if _matches(d, exclude):
+                continue
+            mark = len(lines)
             lines.append("%s%s/" % (indent, d))
-            walk(os.path.join(path, d), depth + 1)
+            sub_file = walk(os.path.join(path, d), depth + 1)
+            if include is not None and not sub_file:
+                del lines[mark:]  # prune the empty directory chain
+            any_file = any_file or sub_file
         for f in files:
+            if _matches(f, exclude):
+                continue
+            if include is not None and not _matches(f, include):
+                continue
             lines.append(indent + f)
+            any_file = True
+        return any_file
 
     walk(root, 1)
     return lines
