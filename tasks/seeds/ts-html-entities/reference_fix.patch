+export interface EncodeOptions {
+  mode?: 'minimal' | 'full';
+  doubleEncode?: boolean;
+}
+
+export interface DecodeOptions {
+  mode?: 'lenient' | 'strict';
+}
+
+// The critical five, always escaped.
+const CORE: Record<string, string> = {
+  '&': 'amp',
+  '<': 'lt',
+  '>': 'gt',
+  '"': 'quot',
+  "'": 'apos',
+};
+
+// Common named entities beyond the core five.
+const COMMON: Record<string, string> = {
+  ' ': 'nbsp',
+  '©': 'copy',
+  '®': 'reg',
+  '™': 'trade',
+  '§': 'sect',
+  '¶': 'para',
+  '°': 'deg',
+  '·': 'middot',
+  '±': 'plusmn',
+  '×': 'times',
+  '÷': 'divide',
+  '…': 'hellip',
+  '—': 'mdash',
+  '–': 'ndash',
+  '«': 'laquo',
+  '»': 'raquo',
+  '•': 'bull',
+  '€': 'euro',
+  '£': 'pound',
+  '¥': 'yen',
+};
+
+const NAME_TO_CHAR: Record<string, string> = {};
+for (const [ch, name] of Object.entries(CORE)) NAME_TO_CHAR[name] = ch;
+for (const [ch, name] of Object.entries(COMMON)) NAME_TO_CHAR[name] = ch;
+
+const ENTITY_HEAD = /^&(?:#(\d+)|#[xX]([0-9a-fA-F]+)|([a-zA-Z][a-zA-Z0-9]*));/;
+
+function isDecodableEntity(text: string, index: number): boolean {
+  const m = ENTITY_HEAD.exec(text.slice(index));
+  if (m === null) return false;
+  if (m[3] !== undefined) return Object.prototype.hasOwnProperty.call(NAME_TO_CHAR, m[3]);
+  return true; // any well-formed numeric reference
+}
+
+export function encodeEntities(text: string, options: EncodeOptions = {}): string {
+  const mode = options.mode ?? 'minimal';
+  const doubleEncode = options.doubleEncode ?? false;
+
+  let out = '';
+  let i = 0;
+  while (i < text.length) {
+    const cp = text.codePointAt(i) as number;
+    const ch = String.fromCodePoint(cp);
+
+    if (ch === '&' && !doubleEncode && isDecodableEntity(text, i)) {
+      out += '&';
+      i += 1;
+      continue;
+    }
+
+    if (CORE[ch] !== undefined) {
+      out += `&${CORE[ch]};`;
+    } else if (mode === 'full' && COMMON[ch] !== undefined) {
+      out += `&${COMMON[ch]};`;
+    } else if (mode === 'full' && cp > 0x7e) {
+      out += `&#x${cp.toString(16).toUpperCase()};`;
+    } else {
+      out += ch;
+    }
+    i += ch.length;
+  }
+  return out;
+}
+
+function decodeCodePoint(cp: number, strict: boolean, raw: string, index: number): string {
+  const invalid = cp === 0 || (cp >= 0xd800 && cp <= 0xdfff) || cp > 0x10ffff;
+  if (invalid) {
+    if (strict) {
+      throw new Error(`invalid numeric character reference "${raw}" at index ${index}`);
+    }
+    return '�';
+  }
+  return String.fromCodePoint(cp);
+}
+
+export function decodeEntities(text: string, options: DecodeOptions = {}): string {
+  const strict = (options.mode ?? 'lenient') === 'strict';
+
+  let out = '';
+  let i = 0;
+  while (i < text.length) {
+    const amp = text.indexOf('&', i);
+    if (amp < 0) {
+      out += text.slice(i);
+      break;
+    }
+    out += text.slice(i, amp);
+
+    const m = ENTITY_HEAD.exec(text.slice(amp));
+    if (m === null) {
+      if (strict) {
+        throw new Error(`bare "&" is not a valid entity at index ${amp}`);
+      }
+      out += '&';
+      i = amp + 1;
+      continue;
+    }
+
+    const raw = m[0];
+    if (m[1] !== undefined) {
+      out += decodeCodePoint(parseInt(m[1], 10), strict, raw, amp);
+    } else if (m[2] !== undefined) {
+      out += decodeCodePoint(parseInt(m[2], 16), strict, raw, amp);
+    } else {
+      const name = m[3];
+      if (Object.prototype.hasOwnProperty.call(NAME_TO_CHAR, name)) {
+        out += NAME_TO_CHAR[name];
+      } else if (strict) {
+        throw new Error(`unknown entity "&${name};" at index ${amp}`);
+      } else {
+        out += raw;
+      }
+    }
+    i = amp + raw.length;
+  }
+  return out;
+}
