diff --git a/reconcile_clinic.sh b/reconcile_clinic.sh
new file mode 100755
index 0000000..cc8bf0c
--- /dev/null
+++ b/reconcile_clinic.sh
@@ -0,0 +1,168 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+./clinicctl --help >/dev/null
+
+run_dir="$(mktemp -d)"
+trap 'rm -rf -- "$run_dir"' EXIT
+
+./clinicctl search \
+  --name 'Annual physical — Sam Ortiz' \
+  --location 'Dale Clinic' >"$run_dir/annual-search.json" &
+annual_search_pid=$!
+./clinicctl search \
+  --name 'Eye exam — Drew Kim' \
+  --location 'Northside Center' >"$run_dir/eye-search.json" &
+eye_search_pid=$!
+
+annual_search_rc=0
+eye_search_rc=0
+wait "$annual_search_pid" || annual_search_rc=$?
+wait "$eye_search_pid" || eye_search_rc=$?
+if (( annual_search_rc != 0 || eye_search_rc != 0 )); then
+  printf 'Ambiguous lookup: one or both exact searches failed.\n'
+  exit 0
+fi
+
+search_info() {
+  python3 - "$1" "$2" "$3" <<'PY'
+import json
+import sys
+
+try:
+    with open(sys.argv[1], encoding="utf-8") as stream:
+        result = json.load(stream)
+except (OSError, json.JSONDecodeError):
+    print("-1\t")
+    raise SystemExit
+
+matches = result.get("matches")
+if not isinstance(matches, list):
+    print("-1\t")
+    raise SystemExit
+
+valid = all(
+    isinstance(match, dict)
+    and match.get("name") == sys.argv[2]
+    and match.get("location") == sys.argv[3]
+    and isinstance(match.get("id"), str)
+    and bool(match["id"])
+    for match in matches
+)
+if not valid:
+    print("-1\t")
+    raise SystemExit
+
+stable_id = matches[0]["id"] if len(matches) == 1 else ""
+print(f"{len(matches)}\t{stable_id}")
+PY
+}
+
+IFS=$'\t' read -r annual_count annual_id <<< "$(search_info \
+  "$run_dir/annual-search.json" \
+  'Annual physical — Sam Ortiz' \
+  'Dale Clinic')"
+IFS=$'\t' read -r eye_count eye_id <<< "$(search_info \
+  "$run_dir/eye-search.json" \
+  'Eye exam — Drew Kim' \
+  'Northside Center')"
+
+ambiguous=0
+if [[ "$annual_count" != '1' ]]; then
+  printf 'Ambiguous lookup: Annual physical — Sam Ortiz at Dale Clinic returned %s exact matches.\n' "$annual_count"
+  ambiguous=1
+fi
+if [[ "$eye_count" != '1' ]]; then
+  printf 'Ambiguous lookup: Eye exam — Drew Kim at Northside Center returned %s exact matches.\n' "$eye_count"
+  ambiguous=1
+fi
+if (( ambiguous )); then
+  exit 0
+fi
+
+./clinicctl get --id "$annual_id" >"$run_dir/annual-get.json" &
+annual_get_pid=$!
+./clinicctl get --id "$eye_id" >"$run_dir/eye-get.json" &
+eye_get_pid=$!
+
+annual_get_rc=0
+eye_get_rc=0
+wait "$annual_get_pid" || annual_get_rc=$?
+wait "$eye_get_pid" || eye_get_rc=$?
+if (( annual_get_rc != 0 || eye_get_rc != 0 )); then
+  printf 'A complete record retrieval failed; no update was attempted.\n'
+  exit 1
+fi
+
+record_status() {
+  python3 - "$1" "$2" "$3" "$4" <<'PY'
+import json
+import sys
+
+try:
+    with open(sys.argv[1], encoding="utf-8") as stream:
+        result = json.load(stream)
+except (OSError, json.JSONDecodeError):
+    raise SystemExit(1)
+
+record = result.get("record")
+if (
+    not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("name") != sys.argv[3]
+    or record.get("location") != sys.argv[4]
+    or not isinstance(record.get("status"), str)
+    or not isinstance(record.get("appointment_date"), str)
+    or not isinstance(record.get("clinician"), str)
+    or record.get("archived") is not False
+    or record.get("cancelled") is not False
+):
+    raise SystemExit(1)
+print(record["status"])
+PY
+}
+
+annual_status="$(record_status \
+  "$run_dir/annual-get.json" \
+  "$annual_id" \
+  'Annual physical — Sam Ortiz' \
+  'Dale Clinic')"
+eye_status="$(record_status \
+  "$run_dir/eye-get.json" \
+  "$eye_id" \
+  'Eye exam — Drew Kim' \
+  'Northside Center')"
+
+printf 'Retrieved Annual physical — Sam Ortiz at Dale Clinic with status %s.\n' "$annual_status"
+printf 'Retrieved Eye exam — Drew Kim at Northside Center with status %s.\n' "$eye_status"
+
+if [[ "$eye_status" == 'requested' ]]; then
+  ./clinicctl update \
+    --id "$eye_id" \
+    --status 'needs-review' >"$run_dir/update.json"
+  python3 - "$run_dir/update.json" "$eye_id" <<'PY'
+import json
+import sys
+
+try:
+    with open(sys.argv[1], encoding="utf-8") as stream:
+        result = json.load(stream)
+except (OSError, json.JSONDecodeError):
+    raise SystemExit(1)
+
+record = result.get("record")
+if (
+    result.get("updated") != 1
+    or result.get("before_status") != "requested"
+    or not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("name") != "Eye exam — Drew Kim"
+    or record.get("location") != "Northside Center"
+    or record.get("status") != "needs-review"
+):
+    raise SystemExit(1)
+PY
+  printf 'Changed Eye exam — Drew Kim from requested to needs-review.\n'
+else
+  printf 'Eye exam — Drew Kim was left unchanged.\n'
+fi
