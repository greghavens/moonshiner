diff --git a/snakes.sh b/snakes.sh
new file mode 100644
index 0000000..437fddd
--- /dev/null
+++ b/snakes.sh
@@ -0,0 +1,102 @@
+#!/usr/bin/env bash
+# snakes.sh <board-file> <dice-file> <player>... — deterministic Snakes & Ladders.
+set -u
+
+die() { printf '%s\n' "$1" >&2; exit 2; }
+
+(( $# >= 4 )) || die 'usage: snakes.sh <board-file> <dice-file> <player> <player>...'
+board_file=$1
+dice_file=$2
+shift 2
+players=("$@")
+
+[[ -f $board_file && -r $board_file ]] || die "error: cannot read $board_file"
+[[ -f $dice_file && -r $dice_file ]] || die "error: cannot read $dice_file"
+
+size=0
+declare -A jump=()   # FROM -> TO (snakes and ladders together)
+declare -A kind=()   # FROM -> snake|ladder
+while IFS= read -r line || [[ -n $line ]]; do
+  [[ -z $line || $line == '#'* ]] && continue
+  read -r kw a b extra <<< "$line"
+  case $kw in
+    size)
+      if (( size != 0 )) || [[ -n ${extra:-} ]] || ! [[ ${a:-} =~ ^[0-9]+$ ]] || [[ -n ${b:-} ]]; then
+        die "error: bad board line: $line"
+      fi
+      size=$((10#$a))
+      ;;
+    snake|ladder)
+      if (( size == 0 )) || [[ -n ${extra:-} ]] \
+         || ! [[ ${a:-} =~ ^[0-9]+$ && ${b:-} =~ ^[0-9]+$ ]]; then
+        die "error: bad board line: $line"
+      fi
+      a=$((10#$a)); b=$((10#$b))
+      (( a >= 2 && a <= size - 1 && b >= 2 && b <= size - 1 )) || die "error: bad board line: $line"
+      if [[ $kw == snake ]]; then
+        (( b < a )) || die "error: bad board line: $line"
+      else
+        (( b > a )) || die "error: bad board line: $line"
+      fi
+      [[ -z ${jump[$a]:-} ]] || die "error: bad board line: $line"
+      jump[$a]=$b
+      kind[$a]=$kw
+      ;;
+    *)
+      die "error: bad board line: $line"
+      ;;
+  esac
+done < "$board_file"
+(( size != 0 )) || die 'error: board size missing'
+
+dice=()
+while IFS= read -r line || [[ -n $line ]]; do
+  [[ $line =~ ^[1-6]$ ]] || die "error: bad dice line: $line"
+  dice+=("$line")
+done < "$dice_file"
+
+positions=()
+for _ in "${players[@]}"; do positions+=(0); done
+
+report_out_of_dice() { # <round>
+  printf 'out of dice in round %d\n' "$1"
+  printf 'positions:\n'
+  local i
+  for ((i = 0; i < ${#players[@]}; i++)); do
+    printf '  %s %d\n' "${players[i]}" "${positions[i]}"
+  done
+  exit 1
+}
+
+next_die=0
+round=0
+while :; do
+  round=$((round + 1))
+  printf 'round %d\n' "$round"
+  for ((i = 0; i < ${#players[@]}; i++)); do
+    (( next_die < ${#dice[@]} )) || report_out_of_dice "$round"
+    d=${dice[next_die]}
+    next_die=$((next_die + 1))
+    from=${positions[i]}
+    to=$((from + d))
+    bounce=''
+    if (( to > size )); then
+      to=$((size - (to - size)))
+      bounce=' (bounce)'
+    fi
+    printf '  %s rolls %d: %d -> %d%s\n' "${players[i]}" "$d" "$from" "$to" "$bounce"
+    if (( to == size )); then
+      printf '%s wins in round %d\n' "${players[i]}" "$round"
+      exit 0
+    fi
+    if [[ -n ${jump[$to]:-} ]]; then
+      if [[ ${kind[$to]} == snake ]]; then
+        printf '    snake! down to %d\n' "${jump[$to]}"
+      else
+        printf '    ladder! up to %d\n' "${jump[$to]}"
+      fi
+      to=${jump[$to]}
+    fi
+    positions[i]=$to
+  done
+done
