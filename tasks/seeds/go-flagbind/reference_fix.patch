+// checkRequired reports the first (in field-declaration order) required
+// flag that was never provided.
+func checkRequired(fields map[string]*binding) error {
+	var missing *binding
+	var missingName string
+	for name, b := range fields {
+		if !b.required || b.seen {
+			continue
+		}
+		if missing == nil || b.order < missing.order {
+			missing, missingName = b, name
+		}
+	}
+	if missing != nil {
+		return &MissingFlagError{Flag: missingName}
+	}
 	return nil
