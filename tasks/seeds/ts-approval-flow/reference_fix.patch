+// Approval routing policy: ordered amount tiers, each naming the chain of
+// approver roles an expense in that tier must pass through.
+
+export type Tier = { upTo?: number; approvers: string[] };
+
+export class Policy {
+  private tiers: { upTo: number | null; approvers: string[] }[];
+
+  constructor(tiers: Tier[]) {
+    if (!Array.isArray(tiers) || tiers.length === 0) {
+      throw new Error('a policy needs at least one tier');
+    }
+    this.tiers = tiers.map((tier, index) => {
+      if (!Array.isArray(tier.approvers) || tier.approvers.length === 0) {
+        throw new Error(`tier ${index + 1} has no approver roles`);
+      }
+      const seen = new Set<string>();
+      for (const role of tier.approvers) {
+        if (seen.has(role)) {
+          throw new Error(`tier ${index + 1} lists role '${role}' twice`);
+        }
+        seen.add(role);
+      }
+      const last = index === tiers.length - 1;
+      if (last) {
+        if (tier.upTo !== undefined) {
+          throw new Error('the last tier is the catch-all and must not set upTo');
+        }
+        return { upTo: null, approvers: [...tier.approvers] };
+      }
+      if (tier.upTo === undefined) {
+        throw new Error(`tier ${index + 1} needs an upTo (only the last tier is open-ended)`);
+      }
+      if (typeof tier.upTo !== 'number' || !Number.isFinite(tier.upTo) || tier.upTo <= 0) {
+        throw new Error(`tier ${index + 1} upTo must be a positive finite number, got ${tier.upTo}`);
+      }
+      return { upTo: tier.upTo, approvers: [...tier.approvers] };
+    });
+    for (let i = 1; i < this.tiers.length; i++) {
+      const prev = this.tiers[i - 1].upTo;
+      const cur = this.tiers[i].upTo;
+      if (prev !== null && cur !== null && cur <= prev) {
+        throw new Error(`tier thresholds must strictly increase (${cur} after ${prev})`);
+      }
+    }
+  }
+
+  chainFor(amount: number): string[] {
+    if (typeof amount !== 'number' || !Number.isFinite(amount) || amount <= 0) {
+      throw new Error(`amount must be a positive finite number, got ${amount}`);
+    }
+    for (const tier of this.tiers) {
+      if (tier.upTo === null || amount <= tier.upTo) {
+        return [...tier.approvers];
+      }
+    }
+    // unreachable: the last tier is always the catch-all
+    throw new Error('no tier covers this amount');
+  }
+
+  roles(): string[] {
+    const out: string[] = [];
+    const seen = new Set<string>();
+    for (const tier of this.tiers) {
+      for (const role of tier.approvers) {
+        if (!seen.has(role)) {
+          seen.add(role);
+          out.push(role);
+        }
+      }
+    }
+    return out;
+  }
+}
