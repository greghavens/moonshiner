+// Expense approval workflow engine: submission, chain approvals, rejection
+// with reasons, resubmission, out-of-office delegation, and a per-expense
+// audit trail.
+import type { Policy } from './policy.ts';
+
+export type AuditEvent = {
+  seq: number;
+  event: 'submitted' | 'approved' | 'rejected' | 'resubmitted';
+  by: string;
+  role?: string;
+  amount?: number;
+  comment?: string;
+  reason?: string;
+  onBehalfOf?: string;
+};
+
+export type Snapshot = {
+  id: string;
+  submitter: string;
+  amount: number;
+  description?: string;
+  status: 'pending' | 'approved' | 'rejected';
+  chain: string[];
+  pendingWith: { role: string; approver: string } | null;
+};
+
+type Expense = {
+  id: string;
+  submitter: string;
+  amount: number;
+  description?: string;
+  status: 'pending' | 'approved' | 'rejected';
+  chain: string[];
+  step: number;
+  trail: AuditEvent[];
+};
+
+function checkAmount(amount: number): void {
+  if (typeof amount !== 'number' || !Number.isFinite(amount) || amount <= 0) {
+    throw new Error(`amount must be a positive finite number, got ${amount}`);
+  }
+}
+
+export class ApprovalEngine {
+  private policy: Policy;
+  private assignments: Map<string, string>;
+  private delegates = new Map<string, string>();
+  private expenses = new Map<string, Expense>();
+
+  constructor(policy: Policy, assignments: { [role: string]: string }) {
+    this.policy = policy;
+    this.assignments = new Map(Object.entries(assignments));
+    for (const role of policy.roles()) {
+      if (!this.assignments.get(role)) {
+        throw new Error(`policy role '${role}' has no assigned approver`);
+      }
+    }
+  }
+
+  private expense(id: string): Expense {
+    const exp = this.expenses.get(id);
+    if (!exp) throw new Error(`unknown expense '${id}'`);
+    return exp;
+  }
+
+  private snapshot(exp: Expense): Snapshot {
+    const pending =
+      exp.status === 'pending'
+        ? {
+            role: exp.chain[exp.step],
+            approver: this.assignments.get(exp.chain[exp.step])!,
+          }
+        : null;
+    return {
+      id: exp.id,
+      submitter: exp.submitter,
+      amount: exp.amount,
+      description: exp.description,
+      status: exp.status,
+      chain: [...exp.chain],
+      pendingWith: pending,
+    };
+  }
+
+  submit(input: { id: string; submitter: string; amount: number; description?: string }): Snapshot {
+    const { id, submitter, amount, description } = input;
+    if (this.expenses.has(id)) {
+      throw new Error(`expense id '${id}' is already taken`);
+    }
+    if (typeof submitter !== 'string' || submitter.trim() === '') {
+      throw new Error('submitter must be a non-empty user id');
+    }
+    checkAmount(amount);
+    const exp: Expense = {
+      id,
+      submitter,
+      amount,
+      description,
+      status: 'pending',
+      chain: this.policy.chainFor(amount),
+      step: 0,
+      trail: [{ seq: 1, event: 'submitted', by: submitter, amount }],
+    };
+    this.expenses.set(id, exp);
+    return this.snapshot(exp);
+  }
+
+  get(id: string): Snapshot {
+    return this.snapshot(this.expense(id));
+  }
+
+  // Validates that userId may decide the current step of exp; returns the
+  // role and, when a delegate is acting, who they act for.
+  private authority(exp: Expense, userId: string): { role: string; onBehalfOf?: string } {
+    if (exp.status !== 'pending') {
+      throw new Error(`expense '${exp.id}' is already ${exp.status}`);
+    }
+    const role = exp.chain[exp.step];
+    const assignee = this.assignments.get(role)!;
+    const isAssignee = userId === assignee;
+    const isDelegate = this.delegates.get(assignee) === userId;
+    if (!isAssignee && !isDelegate) {
+      throw new Error(`expense '${exp.id}' is waiting on ${assignee}, not ${userId}`);
+    }
+    if (userId === exp.submitter || assignee === exp.submitter) {
+      throw new Error(`${userId} cannot decide their own expense '${exp.id}'`);
+    }
+    return isDelegate ? { role, onBehalfOf: assignee } : { role };
+  }
+
+  private nextSeq(exp: Expense): number {
+    return exp.trail[exp.trail.length - 1].seq + 1;
+  }
+
+  approve(id: string, userId: string, comment?: string): Snapshot {
+    const exp = this.expense(id);
+    const { role, onBehalfOf } = this.authority(exp, userId);
+    const event: AuditEvent = { seq: this.nextSeq(exp), event: 'approved', role, by: userId };
+    if (comment !== undefined) event.comment = comment;
+    if (onBehalfOf !== undefined) event.onBehalfOf = onBehalfOf;
+    exp.trail.push(event);
+    exp.step += 1;
+    if (exp.step >= exp.chain.length) exp.status = 'approved';
+    return this.snapshot(exp);
+  }
+
+  reject(id: string, userId: string, reason: string): Snapshot {
+    const exp = this.expense(id);
+    const { role, onBehalfOf } = this.authority(exp, userId);
+    if (typeof reason !== 'string' || reason.trim() === '') {
+      throw new Error('rejection requires a non-empty reason');
+    }
+    const event: AuditEvent = {
+      seq: this.nextSeq(exp),
+      event: 'rejected',
+      role,
+      by: userId,
+      reason,
+    };
+    if (onBehalfOf !== undefined) event.onBehalfOf = onBehalfOf;
+    exp.trail.push(event);
+    exp.status = 'rejected';
+    return this.snapshot(exp);
+  }
+
+  resubmit(id: string, changes: { amount?: number; description?: string } = {}): Snapshot {
+    const exp = this.expense(id);
+    if (exp.status !== 'rejected') {
+      throw new Error(`only rejected expenses can be resubmitted; '${id}' is ${exp.status}`);
+    }
+    const amount = changes.amount !== undefined ? changes.amount : exp.amount;
+    checkAmount(amount);
+    const chain = this.policy.chainFor(amount);
+    exp.amount = amount;
+    if (changes.description !== undefined) exp.description = changes.description;
+    exp.chain = chain;
+    exp.step = 0;
+    exp.status = 'pending';
+    exp.trail.push({ seq: this.nextSeq(exp), event: 'resubmitted', by: exp.submitter, amount });
+    return this.snapshot(exp);
+  }
+
+  setDelegate(userId: string, delegateId: string): void {
+    if (userId === delegateId) {
+      throw new Error(`${userId} cannot delegate to themselves`);
+    }
+    this.delegates.set(userId, delegateId);
+  }
+
+  clearDelegate(userId: string): void {
+    this.delegates.delete(userId);
+  }
+
+  auditTrail(id: string): AuditEvent[] {
+    return this.expense(id).trail.map((event) => ({ ...event }));
+  }
+}
