+
+// ---------------------------------------------------------------------------
+// Draft restore: the decode direction.
+// ---------------------------------------------------------------------------
+
+export class FormDecodeError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'FormDecodeError';
+  }
+}
+
+const TWO_HEX = /^[0-9A-Fa-f]{2}$/;
+
+function decodeComponent(text: string): string {
+  const bytes: number[] = [];
+  const encoder = new TextEncoder();
+  let i = 0;
+  while (i < text.length) {
+    const ch = text[i];
+    if (ch === '+') {
+      bytes.push(0x20);
+      i += 1;
+    } else if (ch === '%') {
+      const hex = text.slice(i + 1, i + 3);
+      if (!TWO_HEX.test(hex)) {
+        throw new FormDecodeError(
+          `expected two hex digits after '%' at offset ${i}`,
+        );
+      }
+      bytes.push(parseInt(hex, 16));
+      i += 3;
+    } else {
+      // Literal character: contribute its utf-8 bytes. Walk by code point so
+      // characters outside the BMP stay intact.
+      const codePoint = text.codePointAt(i)!;
+      for (const byte of encoder.encode(String.fromCodePoint(codePoint))) {
+        bytes.push(byte);
+      }
+      i += codePoint > 0xffff ? 2 : 1;
+    }
+  }
+  try {
+    return new TextDecoder('utf-8', { fatal: true }).decode(
+      new Uint8Array(bytes),
+    );
+  } catch {
+    throw new FormDecodeError('decoded bytes are not valid utf-8');
+  }
+}
+
+// Inverse of encodePairs for canonical input, and tolerant of either hex case
+// on the way in. Order and duplicate names are preserved: repeated names are
+// meaningful (multi-selects, repeated fields).
+export function parse(encoded: string): Array<[string, string]> {
+  const pairs: Array<[string, string]> = [];
+  for (const segment of encoded.split('&')) {
+    if (segment === '') continue;
+    const eq = segment.indexOf('=');
+    const rawName = eq === -1 ? segment : segment.slice(0, eq);
+    const rawValue = eq === -1 ? '' : segment.slice(eq + 1);
+    pairs.push([decodeComponent(rawName), decodeComponent(rawValue)]);
+  }
+  return pairs;
+}
