new file mode 100644
index 0000000..99f71bb
--- /dev/null
+++ b/fuzzyrank.py
@@ -0,0 +1,66 @@
+"""Fuzzy 'did you mean' suggestions: Levenshtein + prefix/subsequence bonuses."""
+
+
+def edit_distance(a, b):
+    """Levenshtein distance with unit costs, exactly on the strings given."""
+    if a == b:
+        return 0
+    if not a:
+        return len(b)
+    if not b:
+        return len(a)
+    previous = list(range(len(b) + 1))
+    for i, ca in enumerate(a, start=1):
+        current = [i]
+        for j, cb in enumerate(b, start=1):
+            cost = 0 if ca == cb else 1
+            current.append(min(
+                previous[j] + 1,        # deletion
+                current[j - 1] + 1,     # insertion
+                previous[j - 1] + cost  # substitution
+            ))
+        previous = current
+    return previous[-1]
+
+
+def _is_subsequence(needle, haystack):
+    it = iter(haystack)
+    return all(ch in it for ch in needle)
+
+
+def _scored(query, candidates, max_distance):
+    q = query.lower()
+    rows = []
+    for cand in candidates:
+        c = cand.lower()
+        d = edit_distance(q, c)
+        is_prefix = c.startswith(q)
+        if d > max_distance and not is_prefix:
+            continue
+        score = 2 * d
+        if is_prefix:
+            score -= 2
+        elif _is_subsequence(q, c):
+            score -= 1
+        score = max(score, 0)
+        rows.append((score, d, c, cand))
+    rows.sort()
+    return rows
+
+
+def rank(query, candidates, limit=3, max_distance=2):
+    if not query:
+        raise ValueError("query must not be empty")
+    return [cand for _, _, _, cand in _scored(query, candidates, max_distance)][:limit]
+
+
+def did_you_mean(query, candidates, max_distance=2):
+    if not query:
+        raise ValueError("query must not be empty")
+    q = query.lower()
+    if any(c.lower() == q for c in candidates):
+        return None
+    best = rank(query, candidates, limit=1, max_distance=max_distance)
+    if not best:
+        return None
+    return f'did you mean "{best[0]}"?'
