+export type RoundingMode = 'half-up' | 'half-even' | 'floor';
+
+export interface CurrencyLocale {
+  symbol: string;
+  position: 'prefix' | 'suffix';
+  symbolSpace: boolean;
+  groupSep: string;
+  decimalSep: string;
+  decimals: number;
+}
+
+function groupDigits(digits: string, sep: string): string {
+  if (sep === '') return digits;
+  let out = '';
+  for (let i = 0; i < digits.length; i++) {
+    if (i > 0 && (digits.length - i) % 3 === 0) out += sep;
+    out += digits[i];
+  }
+  return out;
+}
+
+export function formatMoney(minorUnits: number, locale: CurrencyLocale): string {
+  if (!Number.isSafeInteger(minorUnits)) {
+    throw new TypeError(`formatMoney: amount must be a safe integer of minor units, got ${minorUnits}`);
+  }
+  const negative = minorUnits < 0;
+  let digits = String(Math.abs(minorUnits));
+  if (digits.length < locale.decimals + 1) {
+    digits = digits.padStart(locale.decimals + 1, '0');
+  }
+
+  const intPart = locale.decimals > 0 ? digits.slice(0, -locale.decimals) : digits;
+  const decPart = locale.decimals > 0 ? digits.slice(-locale.decimals) : '';
+
+  let num = groupDigits(intPart, locale.groupSep);
+  if (locale.decimals > 0) num += locale.decimalSep + decPart;
+
+  const gap = locale.symbolSpace ? ' ' : '';
+  const body = locale.position === 'prefix' ? locale.symbol + gap + num : num + gap + locale.symbol;
+  return negative ? '-' + body : body;
+}
+
+export function parseMoney(text: string, locale: CurrencyLocale): number {
+  let t = text.trim();
+  if (t === '') throw new Error('parseMoney: input is empty');
+
+  const symbolAt = t.indexOf(locale.symbol);
+  if (symbolAt >= 0) {
+    t = (t.slice(0, symbolAt) + t.slice(symbolAt + locale.symbol.length)).trim();
+  }
+
+  let sign = 1;
+  if (t.startsWith('-') || t.startsWith('+')) {
+    if (t[0] === '-') sign = -1;
+    t = t.slice(1).trim();
+  }
+
+  let intRaw: string;
+  let decRaw: string;
+  const decAt = t.indexOf(locale.decimalSep);
+  if (decAt >= 0) {
+    intRaw = t.slice(0, decAt);
+    decRaw = t.slice(decAt + locale.decimalSep.length);
+    if (decRaw.includes(locale.decimalSep)) {
+      throw new Error(`parseMoney: more than one decimal separator in "${text}"`);
+    }
+  } else {
+    intRaw = t;
+    decRaw = '';
+  }
+
+  if (locale.groupSep !== '') {
+    intRaw = intRaw.split(locale.groupSep).join('');
+  }
+
+  if (!/^\d*$/.test(intRaw) || !/^\d*$/.test(decRaw)) {
+    throw new Error(`parseMoney: unexpected character in "${text}"`);
+  }
+  if (intRaw === '' && decRaw === '') {
+    throw new Error(`parseMoney: no digits in "${text}"`);
+  }
+  if (decRaw.length > locale.decimals) {
+    throw new Error(
+      `parseMoney: "${text}" has ${decRaw.length} decimal digits but the currency allows ${locale.decimals}`,
+    );
+  }
+
+  const digits = (intRaw === '' ? '0' : intRaw) + decRaw.padEnd(locale.decimals, '0');
+  const minor = sign * Number(digits);
+  return minor === 0 ? 0 : minor;
+}
+
+export function toMinorUnits(
+  decimalText: string,
+  decimals: number,
+  mode: RoundingMode = 'half-up',
+): number {
+  const match = /^([+-]?)(\d+)(?:\.(\d+))?$/.exec(decimalText.trim());
+  if (match === null) {
+    throw new Error(`toMinorUnits: "${decimalText}" is not a plain decimal number`);
+  }
+  const negative = match[1] === '-';
+  const intPart = match[2];
+  const decPart = match[3] ?? '';
+
+  const kept = decPart.slice(0, decimals).padEnd(decimals, '0');
+  const rest = decPart.slice(decimals).replace(/0+$/, '');
+
+  let magnitude = Number(intPart + kept);
+
+  if (rest !== '') {
+    let up = false;
+    const first = rest.charCodeAt(0) - 48;
+    switch (mode) {
+      case 'half-up':
+        up = first >= 5;
+        break;
+      case 'half-even':
+        if (first > 5) up = true;
+        else if (first === 5) {
+          const exactHalf = rest.length === 1;
+          up = exactHalf ? magnitude % 2 === 1 : true;
+        }
+        break;
+      case 'floor':
+        up = negative;
+        break;
+    }
+    if (up) magnitude += 1;
+  }
+
+  const result = negative ? -magnitude : magnitude;
+  return result === 0 ? 0 : result;
+}
