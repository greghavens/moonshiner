+"""Verification of signed webhook deliveries.
+
+Deliveries carry a signature header of the form ``t=<unix_ts>,v1=<hex>`` where
+``v1`` is HMAC-SHA256 over ``"<t>.<body>"`` keyed with the endpoint secret.
+Several ``v1`` entries may appear while the sender rotates secrets, and the
+receiver may hold several active secrets; any matching pair verifies.
+"""
+import hashlib
+import hmac
+import time
+from collections import OrderedDict
+
+
+def _digest(secret, body, timestamp):
+    payload = str(timestamp).encode("utf-8") + b"." + body
+    return hmac.new(secret.encode("utf-8"), payload, hashlib.sha256).hexdigest()
+
+
+def sign(secret, body, timestamp):
+    """Build the full signature header for an outgoing delivery."""
+    return "t=%d,v1=%s" % (timestamp, _digest(secret, body, timestamp))
+
+
+class VerifyResult:
+    __slots__ = ("accepted", "reason")
+
+    def __init__(self, accepted, reason=None):
+        self.accepted = accepted
+        self.reason = reason
+
+    def __repr__(self):
+        return "VerifyResult(accepted=%r, reason=%r)" % (self.accepted, self.reason)
+
+
+class WebhookVerifier:
+    """Checks delivery signatures, timestamp freshness, and repeat delivery ids."""
+
+    def __init__(self, secrets, tolerance=300, clock=time.time, cache_size=1024):
+        if not secrets:
+            raise ValueError("at least one active secret is required")
+        self._secrets = list(secrets)
+        self._tolerance = tolerance
+        self._clock = clock
+        self._cache_size = cache_size
+        self._seen = OrderedDict()  # delivery_id -> True, oldest first
+
+    def verify(self, body, header, delivery_id=None):
+        parsed = self._parse(header)
+        if parsed is None:
+            return VerifyResult(False, "bad_header")
+        timestamp, sigs = parsed
+        if abs(self._clock() - timestamp) > self._tolerance:
+            return VerifyResult(False, "stale_timestamp")
+        if not self._any_match(body, timestamp, sigs):
+            return VerifyResult(False, "no_matching_signature")
+        if delivery_id is not None:
+            if delivery_id in self._seen:
+                return VerifyResult(False, "duplicate")
+            self._seen[delivery_id] = True
+            while len(self._seen) > self._cache_size:
+                self._seen.popitem(last=False)
+        return VerifyResult(True, None)
+
+    def _parse(self, header):
+        if not header:
+            return None
+        timestamps = []
+        sigs = []
+        for item in header.split(","):
+            item = item.strip()
+            if "=" not in item:
+                return None
+            key, _, value = item.partition("=")
+            if key == "t":
+                timestamps.append(value)
+            elif key == "v1":
+                sigs.append(value)
+            # unknown keys (v0, ...) are ignored
+        if len(timestamps) != 1 or not sigs:
+            return None
+        try:
+            timestamp = int(timestamps[0])
+        except ValueError:
+            return None
+        return timestamp, sigs
+
+    def _any_match(self, body, timestamp, sigs):
+        for secret in self._secrets:
+            expected = _digest(secret, body, timestamp)
+            for provided in sigs:
+                if hmac.compare_digest(expected, provided.lower()):
+                    return True
+        return False
