+"""syncplan — dry-run planner for the deploy mirror job.
+
+Pure manifest comparison: dicts in, an ordered action plan out. Nothing here
+touches the filesystem; the executor does that elsewhere.
+"""
+
+_ALLOWED_TYPES = ("file", "dir")
+
+
+def _check_path(path):
+    if not isinstance(path, str) or not path:
+        raise ValueError(f"bad path: {path!r}")
+    if path.startswith("/") or path.endswith("/"):
+        raise ValueError(f"bad path: {path!r}")
+    parts = path.split("/")
+    if any(p in ("", ".", "..") for p in parts):
+        raise ValueError(f"bad path: {path!r}")
+
+
+def validate_manifest(manifest):
+    """Sanity-check one manifest; raises ValueError on structural problems."""
+    if not isinstance(manifest, dict):
+        raise ValueError("manifest must be a dict of path -> entry")
+    for path, entry in manifest.items():
+        _check_path(path)
+        if not isinstance(entry, dict) or entry.get("type") not in _ALLOWED_TYPES:
+            raise ValueError(f"bad entry for {path!r}: unknown type")
+        if entry["type"] == "file":
+            size = entry.get("size")
+            mtime = entry.get("mtime")
+            if not isinstance(size, int) or isinstance(size, bool) or size < 0:
+                raise ValueError(f"bad entry for {path!r}: size must be a non-negative int")
+            if not isinstance(mtime, (int, float)) or isinstance(mtime, bool):
+                raise ValueError(f"bad entry for {path!r}: mtime must be a number")
+    for path in manifest:
+        if "/" in path:
+            parent = path.rsplit("/", 1)[0]
+            if parent not in manifest:
+                raise ValueError(f"missing parent directory for {path!r}")
+            if manifest[parent]["type"] != "dir":
+                raise ValueError(f"parent of {path!r} is not a directory")
+
+
+def _files_differ(src_entry, dst_entry):
+    if "checksum" in src_entry and "checksum" in dst_entry:
+        return src_entry["checksum"] != dst_entry["checksum"]
+    return (src_entry["size"] != dst_entry["size"]
+            or src_entry["mtime"] != dst_entry["mtime"])
+
+
+def plan_sync(src, dst):
+    """Compare two manifests and return the ordered action plan.
+
+    Actions are dicts {op, path, reason}. Order: removals (deepest first),
+    then mkdirs (parents first), then copies/updates (path order).
+    """
+    validate_manifest(src)
+    validate_manifest(dst)
+
+    removals = []    # delete / rmdir
+    mkdirs = []
+    transfers = []   # copy / update
+
+    for path in dst:
+        s, d = src.get(path), dst[path]
+        if s is None:
+            op = "delete" if d["type"] == "file" else "rmdir"
+            removals.append({"op": op, "path": path, "reason": "extra"})
+        elif s["type"] != d["type"]:
+            op = "delete" if d["type"] == "file" else "rmdir"
+            removals.append({"op": op, "path": path, "reason": "type-changed"})
+
+    for path in src:
+        s, d = src[path], dst.get(path)
+        if d is None:
+            reason = "new"
+        elif s["type"] != d["type"]:
+            reason = "type-changed"
+        elif s["type"] == "file" and _files_differ(s, d):
+            transfers.append({"op": "update", "path": path, "reason": "changed"})
+            continue
+        else:
+            continue
+        if s["type"] == "dir":
+            mkdirs.append({"op": "mkdir", "path": path, "reason": reason})
+        else:
+            transfers.append({"op": "copy", "path": path, "reason": reason})
+
+    removals.sort(key=lambda a: a["path"], reverse=True)
+    mkdirs.sort(key=lambda a: a["path"])
+    transfers.sort(key=lambda a: a["path"])
+    return removals + mkdirs + transfers
+
+
+def render_plan(actions):
+    """Human-readable dry-run listing, one line per action."""
+    if not actions:
+        return "(nothing to do)\n"
+    lines = [f"{a['op']:<6}  {a['path']}  ({a['reason']})" for a in actions]
+    return "\n".join(lines) + "\n"
