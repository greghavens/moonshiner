+import { clone, deepEqual, isObject } from './json.ts';
+import type { JsonObject, JsonValue } from './json.ts';
+
+export type ConflictKind = 'edit-edit' | 'delete-edit' | 'add-add';
+
+export interface Conflict {
+  path: string;
+  kind: ConflictKind;
+  base?: JsonValue;
+  ours?: JsonValue;
+  theirs?: JsonValue;
+}
+
+export type ArrayStrategy = 'atomic' | 'union' | 'ours' | 'theirs';
+
+export interface MergeOptions {
+  arrays?: ArrayStrategy;
+  arrayOverrides?: Record<string, ArrayStrategy>;
+}
+
+export interface MergeResult {
+  merged: JsonValue;
+  conflicts: Conflict[];
+}
+
+const STRATEGIES: readonly ArrayStrategy[] = ['atomic', 'union', 'ours', 'theirs'];
+
+const MISSING: unique symbol = Symbol('missing');
+type Maybe = JsonValue | typeof MISSING;
+
+function checkStrategy(name: string): ArrayStrategy {
+  if (!STRATEGIES.includes(name as ArrayStrategy)) {
+    throw new Error(`unknown array strategy: ${name}`);
+  }
+  return name as ArrayStrategy;
+}
+
+function unionArrays(ours: JsonValue[], theirs: JsonValue[]): JsonValue[] {
+  const out = ours.map((v) => clone(v));
+  for (const item of theirs) {
+    if (!out.some((seen) => deepEqual(seen, item))) out.push(clone(item));
+  }
+  return out;
+}
+
+export function merge3(
+  base: JsonValue,
+  ours: JsonValue,
+  theirs: JsonValue,
+  options: MergeOptions = {},
+): MergeResult {
+  const globalStrategy = checkStrategy(options.arrays ?? 'atomic');
+  const overrides = new Map<string, ArrayStrategy>();
+  for (const [path, name] of Object.entries(options.arrayOverrides ?? {})) {
+    overrides.set(path, checkStrategy(name));
+  }
+  const conflicts: Conflict[] = [];
+
+  function conflict(path: string, b: Maybe, o: Maybe, t: Maybe): Maybe {
+    const kind: ConflictKind =
+      b === MISSING ? 'add-add' : o === MISSING || t === MISSING ? 'delete-edit' : 'edit-edit';
+    const record: Conflict = { path, kind };
+    if (b !== MISSING) record.base = clone(b);
+    if (o !== MISSING) record.ours = clone(o);
+    if (t !== MISSING) record.theirs = clone(t);
+    conflicts.push(record);
+    return b === MISSING ? MISSING : clone(b);
+  }
+
+  function mergeValue(path: string, b: Maybe, o: Maybe, t: Maybe): Maybe {
+    const eq = (x: Maybe, y: Maybe) =>
+      x === MISSING || y === MISSING ? x === y : deepEqual(x, y);
+
+    if (eq(o, t)) return o === MISSING ? MISSING : clone(o);
+    if (eq(o, b)) return t === MISSING ? MISSING : clone(t);
+    if (eq(t, b)) return o === MISSING ? MISSING : clone(o);
+
+    // Both sides changed, differently.
+    if (Array.isArray(o) && Array.isArray(t)) {
+      const strategy = overrides.get(path) ?? globalStrategy;
+      if (strategy === 'union') return unionArrays(o, t);
+      if (strategy === 'ours') return clone(o);
+      if (strategy === 'theirs') return clone(t);
+    }
+    if (isObject(o) && isObject(t)) {
+      const bObj: JsonObject = isObject(b) ? (b as JsonObject) : {};
+      const keys: string[] = [];
+      for (const source of [bObj, o, t]) {
+        for (const k of Object.keys(source)) if (!keys.includes(k)) keys.push(k);
+      }
+      const out: JsonObject = {};
+      for (const k of keys) {
+        const sub = mergeValue(
+          path === '' ? k : `${path}.${k}`,
+          Object.hasOwn(bObj, k) ? bObj[k] : MISSING,
+          Object.hasOwn(o, k) ? o[k] : MISSING,
+          Object.hasOwn(t, k) ? t[k] : MISSING,
+        );
+        if (sub !== MISSING) out[k] = sub;
+      }
+      return out;
+    }
+    return conflict(path, b, o, t);
+  }
+
+  const merged = mergeValue('', base, ours, theirs);
+  return { merged: merged === MISSING ? null : merged, conflicts };
+}
