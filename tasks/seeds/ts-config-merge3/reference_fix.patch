+import { clone, isObject } from './json.ts';
+import type { JsonValue } from './json.ts';
+import type { Conflict, MergeResult } from './merge.ts';
+
+export type Choice = 'ours' | 'theirs' | 'base';
+
+const CHOICES: readonly Choice[] = ['ours', 'theirs', 'base'];
+
+function setAtPath(root: JsonValue, path: string, value: JsonValue | undefined): JsonValue {
+  if (path === '') {
+    return value === undefined ? null : value;
+  }
+  const keys = path.split('.');
+  const last = keys.pop() as string;
+  let node = root;
+  for (const k of keys) {
+    if (!isObject(node) || !Object.hasOwn(node, k)) {
+      throw new Error(`cannot resolve path ${path}: missing ${k}`);
+    }
+    node = node[k];
+  }
+  if (!isObject(node)) {
+    throw new Error(`cannot resolve path ${path}: parent is not an object`);
+  }
+  if (value === undefined) {
+    delete node[last];
+  } else {
+    node[last] = value;
+  }
+  return root;
+}
+
+export function resolve(
+  result: MergeResult,
+  choices: Record<string, Choice>,
+): MergeResult {
+  const pending = new Map(result.conflicts.map((c) => [c.path, c]));
+  for (const [path, choice] of Object.entries(choices)) {
+    if (!pending.has(path)) {
+      throw new Error(`no pending conflict at path: ${path}`);
+    }
+    if (!CHOICES.includes(choice)) {
+      throw new Error(`unknown resolution choice: ${choice}`);
+    }
+  }
+
+  let merged = clone(result.merged);
+  const remaining: Conflict[] = [];
+  for (const c of result.conflicts) {
+    const choice = choices[c.path];
+    if (choice === undefined) {
+      remaining.push(clone2(c));
+      continue;
+    }
+    const value = c[choice]; // absent side => undefined => delete
+    merged = setAtPath(merged, c.path, value === undefined ? undefined : clone(value));
+  }
+  return { merged, conflicts: remaining };
+}
+
+function clone2(c: Conflict): Conflict {
+  const out: Conflict = { path: c.path, kind: c.kind };
+  if ('base' in c) out.base = clone(c.base as JsonValue);
+  if ('ours' in c) out.ours = clone(c.ours as JsonValue);
+  if ('theirs' in c) out.theirs = clone(c.theirs as JsonValue);
+  return out;
+}
