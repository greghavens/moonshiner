+import type { Conflict, MergeResult } from './merge.ts';
+
+function side(c: Conflict, key: 'base' | 'ours' | 'theirs'): string {
+  return key in c ? JSON.stringify(c[key], null, 2) : '(missing)';
+}
+
+export function renderConflicts(result: MergeResult): string {
+  if (result.conflicts.length === 0) return '';
+  const blocks = result.conflicts.map((c) =>
+    [
+      `# ${c.path === '' ? '(root)' : c.path}: ${c.kind}`,
+      '<<<<<<< ours',
+      side(c, 'ours'),
+      '||||||| base',
+      side(c, 'base'),
+      '=======',
+      side(c, 'theirs'),
+      '>>>>>>> theirs',
+    ].join('\n'),
+  );
+  return blocks.join('\n\n') + '\n';
+}
