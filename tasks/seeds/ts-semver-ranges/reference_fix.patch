+export interface SemVer {
+  major: number;
+  minor: number;
+  patch: number;
+  prerelease: string[];
+  build: string | null;
+}
+
+const NUMERIC = /^(0|[1-9]\d*)$/;
+const IDENT = /^[0-9A-Za-z-]+$/;
+
+export function parse(input: string): SemVer {
+  if (typeof input !== 'string') throw new TypeError('version must be a string');
+  let s = input;
+  if (s.startsWith('v')) s = s.slice(1);
+
+  let build: string | null = null;
+  const plus = s.indexOf('+');
+  if (plus !== -1) {
+    build = s.slice(plus + 1);
+    s = s.slice(0, plus);
+    if (build === '' || !build.split('.').every((id) => IDENT.test(id))) {
+      throw new TypeError(`invalid build metadata in ${JSON.stringify(input)}`);
+    }
+  }
+
+  let prerelease: string[] = [];
+  const dash = s.indexOf('-');
+  if (dash !== -1) {
+    const pre = s.slice(dash + 1);
+    s = s.slice(0, dash);
+    prerelease = pre.split('.');
+    for (const id of prerelease) {
+      if (!IDENT.test(id)) throw new TypeError(`invalid prerelease in ${JSON.stringify(input)}`);
+      if (/^\d+$/.test(id) && !NUMERIC.test(id)) {
+        throw new TypeError(`leading zeros in prerelease of ${JSON.stringify(input)}`);
+      }
+    }
+  }
+
+  const parts = s.split('.');
+  if (parts.length !== 3 || !parts.every((p) => NUMERIC.test(p))) {
+    throw new TypeError(`invalid version ${JSON.stringify(input)}`);
+  }
+  const [major, minor, patch] = parts.map(Number);
+  return { major, minor, patch, prerelease, build };
+}
+
+function compareIdentifiers(a: string, b: string): number {
+  const an = /^\d+$/.test(a);
+  const bn = /^\d+$/.test(b);
+  if (an && bn) {
+    const d = Number(a) - Number(b);
+    return d === 0 ? 0 : d < 0 ? -1 : 1;
+  }
+  if (an) return -1; // numeric sorts below alphanumeric
+  if (bn) return 1;
+  return a === b ? 0 : a < b ? -1 : 1;
+}
+
+function comparePre(a: string[], b: string[]): number {
+  if (a.length === 0 && b.length === 0) return 0;
+  if (a.length === 0) return 1; // release outranks prerelease
+  if (b.length === 0) return -1;
+  const shared = Math.min(a.length, b.length);
+  for (let i = 0; i < shared; i++) {
+    const d = compareIdentifiers(a[i], b[i]);
+    if (d !== 0) return d;
+  }
+  return a.length === b.length ? 0 : a.length < b.length ? -1 : 1;
+}
+
+function compareParsed(a: SemVer, b: SemVer): number {
+  for (const key of ['major', 'minor', 'patch'] as const) {
+    if (a[key] !== b[key]) return a[key] < b[key] ? -1 : 1;
+  }
+  return comparePre(a.prerelease, b.prerelease);
+}
+
+export function compare(a: string, b: string): number {
+  return compareParsed(parse(a), parse(b));
+}
+
+interface Bound {
+  base: SemVer;
+  upper: { major: number; minor: number; patch: number } | null; // exclusive; null = exact match
+}
+
+function parseRange(range: string): Bound {
+  const op = range.startsWith('^') ? '^' : range.startsWith('~') ? '~' : '';
+  const base = parse(op === '' ? range : range.slice(1));
+  if (op === '') return { base, upper: null };
+  if (op === '~') {
+    return { base, upper: { major: base.major, minor: base.minor + 1, patch: 0 } };
+  }
+  // caret
+  if (base.major > 0) return { base, upper: { major: base.major + 1, minor: 0, patch: 0 } };
+  if (base.minor > 0) return { base, upper: { major: 0, minor: base.minor + 1, patch: 0 } };
+  return { base, upper: { major: 0, minor: 0, patch: base.patch + 1 } };
+}
+
+export function satisfies(version: string, range: string): boolean {
+  const v = parse(version);
+  const { base, upper } = parseRange(range);
+
+  if (upper === null) return compareParsed(v, base) === 0;
+
+  // npm rule: a prerelease version only matches when the range base also has a
+  // prerelease and shares the same [major, minor, patch] triple.
+  if (v.prerelease.length > 0) {
+    const sameTriple =
+      v.major === base.major && v.minor === base.minor && v.patch === base.patch;
+    if (base.prerelease.length === 0 || !sameTriple) return false;
+  }
+
+  if (compareParsed(v, base) < 0) return false;
+  const u: SemVer = { ...upper, prerelease: [], build: null };
+  return compareParsed(v, u) < 0;
+}
+
+export function maxSatisfying(versions: string[], range: string): string | null {
+  let best: string | null = null;
+  for (const candidate of versions) {
+    if (!satisfies(candidate, range)) continue;
+    if (best === null || compare(candidate, best) > 0) best = candidate;
+  }
+  return best;
+}
