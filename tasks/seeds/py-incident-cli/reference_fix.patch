+"""Postmortem timeline export: merged event stream, text and JSON shapes."""
+import json
+
+_KIND_RANK = {"alert": 0, "page": 1, "ack": 2, "resolve": 3}
+
+
+def status_of(inc):
+    if inc["resolved_at"] is not None:
+        return "resolved"
+    if inc["acked_at"] is not None:
+        return "acked"
+    return "open"
+
+
+def events_of(inc):
+    """All events, ordered by time; ties alert < page < ack < resolve,
+    then insertion order (the sort is stable)."""
+    events = []
+    for a in inc["alerts"]:
+        events.append((a["at_min"], {"at": a["at"], "kind": "alert",
+                                     "severity": a["severity"],
+                                     "message": a["message"]}))
+    for p in inc["pages"]:
+        events.append((p["at_min"], {"at": p["at"], "kind": "page",
+                                     "level": p["level"],
+                                     "target": p["target"]}))
+    if inc["acked_at"] is not None:
+        events.append((inc["acked_at_min"], {"at": inc["acked_at"],
+                                             "kind": "ack",
+                                             "by": inc["acked_by"]}))
+    if inc["resolved_at"] is not None:
+        events.append((inc["resolved_at_min"], {"at": inc["resolved_at"],
+                                                "kind": "resolve"}))
+    events.sort(key=lambda pair: (pair[0], _KIND_RANK[pair[1]["kind"]]))
+    return [e for _, e in events]
+
+
+def render_text(inc):
+    lines = ["timeline %s (%s)" % (inc["id"], inc["fingerprint"])]
+    for e in events_of(inc):
+        if e["kind"] == "alert":
+            lines.append("%s alert %s %s" % (e["at"], e["severity"], e["message"]))
+        elif e["kind"] == "page":
+            lines.append("%s page level=%d %s" % (e["at"], e["level"], e["target"]))
+        elif e["kind"] == "ack":
+            lines.append("%s ack %s" % (e["at"], e["by"]))
+        else:
+            lines.append("%s resolve" % e["at"])
+    return "\n".join(lines)
+
+
+def render_json(inc):
+    doc = {
+        "incident": inc["id"],
+        "fingerprint": inc["fingerprint"],
+        "status": status_of(inc),
+        "events": events_of(inc),
+    }
+    return json.dumps(doc)
