+++ b/incidents/store.py
@@ -0,0 +1,38 @@
+"""State persistence: one JSON document on disk."""
+import json
+import os
+
+
+class CorruptState(Exception):
+    """Raised when the state file exists but is not a JSON object."""
+
+
+def fresh_state():
+    return {
+        "rotations": {},
+        "policies": {},
+        "routes": {},
+        "incidents": [],
+        "counter": 0,
+    }
+
+
+def load(path):
+    if not os.path.exists(path):
+        return fresh_state()
+    try:
+        with open(path, encoding="utf-8") as f:
+            doc = json.load(f)
+    except ValueError as exc:
+        raise CorruptState(path) from exc
+    if not isinstance(doc, dict):
+        raise CorruptState(path)
+    base = fresh_state()
+    base.update(doc)
+    return base
+
+
+def save(path, state):
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(state, f, indent=1)
+        f.write("\n")
