diff --git a/reference_solution.sh b/reference_solution.sh
new file mode 100755
--- /dev/null
+++ b/reference_solution.sh
@@ -0,0 +1,77 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+work=$(mktemp -d)
+trap 'rm -rf -- "$work"' EXIT
+
+"$PWD/casebook" --help >/dev/null
+
+bash -c '
+  set -u
+  root=$1
+  out=$2
+  "$root/casebook" search \
+    --name "Partial Refund Not Posted" \
+    --location "Indigo Travel" > "$out/search-one.json" &
+  first=$!
+  "$root/casebook" search \
+    --name "Shipment Notice Sent Twice" \
+    --location "Juniper Market" > "$out/search-two.json" &
+  second=$!
+  status=0
+  wait "$first" || status=$?
+  wait "$second" || status=$?
+  exit "$status"
+' _ "$PWD" "$work"
+
+mapfile -t ids < <(python3 - "$work/search-one.json" "$work/search-two.json" <<'PY'
+import json
+import sys
+
+for filename in sys.argv[1:]:
+    payload = json.load(open(filename, encoding="utf-8"))
+    matches = payload.get("matches", [])
+    if payload.get("count") != 1 or len(matches) != 1:
+        raise SystemExit("reference search did not resolve uniquely")
+    print(matches[0]["stable_id"])
+PY
+)
+
+if [[ ${#ids[@]} -ne 2 ]]; then
+  echo "reference search ID extraction failed" >&2
+  exit 1
+fi
+
+bash -c '
+  set -u
+  root=$1
+  out=$2
+  first_id=$3
+  second_id=$4
+  "$root/casebook" get --stable-id "$first_id" > "$out/get-one.json" &
+  first=$!
+  "$root/casebook" get --stable-id "$second_id" > "$out/get-two.json" &
+  second=$!
+  status=0
+  wait "$first" || status=$?
+  wait "$second" || status=$?
+  exit "$status"
+' _ "$PWD" "$work" "${ids[0]}" "${ids[1]}"
+
+python3 - "$work/get-one.json" "$work/get-two.json" shift_handoff.txt <<'PY'
+import json
+import sys
+
+records = [json.load(open(filename, encoding="utf-8")) for filename in sys.argv[1:3]]
+lines = [" | ".join(record[field] for field in
+         ("name", "stable_id", "location", "date", "status"))
+         for record in records]
+first, second = records
+if first["status"] == second["status"]:
+    lines.append(f"Statuses match: both are {first['status']}.")
+else:
+    lines.append(f"Statuses differ: {first['name']} is {first['status']}, while "
+                 f"{second['name']} is {second['status']}.")
+with open(sys.argv[3], "w", encoding="utf-8") as handle:
+    handle.write("\n".join(lines) + "\n")
+PY
diff --git a/shift_handoff.txt b/shift_handoff.txt
new file mode 100644
--- /dev/null
+++ b/shift_handoff.txt
@@ -0,0 +1,3 @@
+Partial Refund Not Posted | sup-185 | Indigo Travel | 2026-10-06 | escalated
+Shipment Notice Sent Twice | sup-585 | Juniper Market | 2026-10-07 | open
+Statuses differ: Partial Refund Not Posted is escalated, while Shipment Notice Sent Twice is open.
