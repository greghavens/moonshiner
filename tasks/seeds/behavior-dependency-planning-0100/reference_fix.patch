diff --git a/run_audit.sh b/run_audit.sh
new file mode 100755
index 0000000..ea438dd
--- /dev/null
+++ b/run_audit.sh
@@ -0,0 +1,58 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+audit_root=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
+audit_tmp=$(mktemp -d)
+cleanup() {
+    rm -rf -- "$audit_tmp"
+}
+trap cleanup EXIT
+
+if [[ -z ${FLEET_TRACE:-} ]]; then
+    export FLEET_TRACE="$audit_tmp/operations.jsonl"
+fi
+
+shuttle_search="$audit_tmp/shuttle.json"
+cargo_search="$audit_tmp/cargo.json"
+
+"$audit_root/fleetctl" search --name "Shuttle 30" --location "Depot D" >"$shuttle_search" &
+shuttle_pid=$!
+"$audit_root/fleetctl" search --name "Cargo van 12" --location "Depot A" >"$cargo_search" &
+cargo_pid=$!
+
+search_status=0
+wait "$shuttle_pid" || search_status=$?
+wait "$cargo_pid" || search_status=$?
+if (( search_status != 0 )); then
+    printf 'audit: a fleet search failed\n' >&2
+    exit "$search_status"
+fi
+
+shuttle_id=$(jq -er '
+    if (.matches | length) == 1 then .matches[0].id
+    else error("Shuttle 30 search was not unique") end
+' "$shuttle_search")
+cargo_id=$(jq -er '
+    if (.matches | length) == 1 then .matches[0].id
+    else error("Cargo van 12 search was not unique") end
+' "$cargo_search")
+
+records="$audit_tmp/records.json"
+"$audit_root/fleetctl" get --id "$shuttle_id" --id "$cargo_id" >"$records"
+
+shuttle_status=$(jq -er --arg id "$shuttle_id" '
+    [.records[] | select(.id == $id)] |
+    if length == 1 then .[0].status else error("Shuttle 30 get failed") end
+' "$records")
+cargo_status=$(jq -er --arg id "$cargo_id" '
+    [.records[] | select(.id == $id)] |
+    if length == 1 then .[0].status else error("Cargo van 12 get failed") end
+' "$records")
+
+comparison="different statuses"
+if [[ "$shuttle_status" == "$cargo_status" ]]; then
+    comparison="same status"
+fi
+printf '%s\n' "- Shuttle 30: $shuttle_status"
+printf '%s\n' "- Cargo van 12: $cargo_status"
+printf '%s\n' "- Result: $comparison"
