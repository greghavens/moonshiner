new file mode 100644
index 0000000..cf72dc1
--- /dev/null
+++ b/client.go
@@ -0,0 +1,182 @@
+package ddmon
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"net/url"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+)
+
+// defaultPageSize matches the official datadog-api-client-go pager.
+const defaultPageSize = 100
+
+type Config struct {
+	BaseURL    string
+	APIKey     string
+	AppKey     string
+	PageSize   int                 // 0 -> defaultPageSize
+	MaxRetries int                 // 0 -> 2
+	Sleep      func(time.Duration) // nil -> time.Sleep
+	HTTPClient *http.Client
+}
+
+type Client struct {
+	cfg  Config
+	mu   sync.Mutex
+	wait time.Duration // pending pause from an exhausted rate-limit window
+}
+
+func NewClient(cfg Config) *Client {
+	if cfg.PageSize <= 0 {
+		cfg.PageSize = defaultPageSize
+	}
+	if cfg.MaxRetries <= 0 {
+		cfg.MaxRetries = 2
+	}
+	if cfg.Sleep == nil {
+		cfg.Sleep = time.Sleep
+	}
+	if cfg.HTTPClient == nil {
+		cfg.HTTPClient = http.DefaultClient
+	}
+	cfg.BaseURL = strings.TrimRight(cfg.BaseURL, "/")
+	return &Client{cfg: cfg}
+}
+
+// APIError is a decoded Datadog {"errors": [...]} envelope. It never carries
+// request headers, so credentials cannot leak through error text.
+type APIError struct {
+	StatusCode int
+	Errors     []string
+}
+
+func (e *APIError) Error() string {
+	return fmt.Sprintf("datadog API error %d: %s", e.StatusCode, strings.Join(e.Errors, "; "))
+}
+
+// ListMonitors pages through GET /api/v1/monitor until a short page.
+func (c *Client) ListMonitors(ctx context.Context, f Filter) ([]Monitor, error) {
+	var all []Monitor
+	for page := 0; ; page++ {
+		q := url.Values{}
+		q.Set("page", strconv.Itoa(page))
+		q.Set("page_size", strconv.Itoa(c.cfg.PageSize))
+		if f.Name != "" {
+			q.Set("name", f.Name)
+		}
+		if len(f.MonitorTags) > 0 {
+			q.Set("monitor_tags", strings.Join(f.MonitorTags, ","))
+		}
+		data, err := c.do(ctx, http.MethodGet, "/api/v1/monitor", q, nil)
+		if err != nil {
+			return nil, err
+		}
+		var batch []Monitor
+		if err := json.Unmarshal(data, &batch); err != nil {
+			return nil, fmt.Errorf("decoding monitor page %d: %w", page, err)
+		}
+		all = append(all, batch...)
+		if len(batch) < c.cfg.PageSize {
+			return all, nil
+		}
+	}
+}
+
+func (c *Client) do(ctx context.Context, method, path string, query url.Values, body any) ([]byte, error) {
+	var payload []byte
+	if body != nil {
+		var err error
+		if payload, err = json.Marshal(body); err != nil {
+			return nil, err
+		}
+	}
+	for attempts := 1; ; attempts++ {
+		c.pauseIfThrottled()
+		target := c.cfg.BaseURL + path
+		if len(query) > 0 {
+			target += "?" + query.Encode()
+		}
+		req, err := http.NewRequestWithContext(ctx, method, target, bytes.NewReader(payload))
+		if err != nil {
+			return nil, err
+		}
+		req.Header.Set("DD-API-KEY", c.cfg.APIKey)
+		req.Header.Set("DD-APPLICATION-KEY", c.cfg.AppKey)
+		req.Header.Set("Accept", "application/json")
+		if body != nil {
+			req.Header.Set("Content-Type", "application/json")
+		}
+		resp, err := c.cfg.HTTPClient.Do(req)
+		if err != nil {
+			return nil, fmt.Errorf("datadog request failed: %w", err)
+		}
+		data, readErr := io.ReadAll(resp.Body)
+		resp.Body.Close()
+		if readErr != nil {
+			return nil, readErr
+		}
+		c.noteRateLimit(resp.Header)
+		if resp.StatusCode == http.StatusTooManyRequests && attempts <= c.cfg.MaxRetries {
+			c.cfg.Sleep(retryWait(resp.Header))
+			continue
+		}
+		if resp.StatusCode >= 400 {
+			return nil, &APIError{StatusCode: resp.StatusCode, Errors: decodeErrors(data)}
+		}
+		return data, nil
+	}
+}
+
+// pauseIfThrottled consumes a pending wait recorded from a response whose
+// X-RateLimit-Remaining hit 0, delaying the NEXT request by the window reset.
+func (c *Client) pauseIfThrottled() {
+	c.mu.Lock()
+	wait := c.wait
+	c.wait = 0
+	c.mu.Unlock()
+	if wait > 0 {
+		c.cfg.Sleep(wait)
+	}
+}
+
+func (c *Client) noteRateLimit(h http.Header) {
+	if h.Get("X-RateLimit-Remaining") != "0" {
+		return
+	}
+	secs, err := strconv.Atoi(h.Get("X-RateLimit-Reset"))
+	if err != nil || secs <= 0 {
+		return
+	}
+	c.mu.Lock()
+	c.wait = time.Duration(secs) * time.Second
+	c.mu.Unlock()
+}
+
+// retryWait picks the 429 backoff: Retry-After, then X-RateLimit-Reset, then 1s.
+func retryWait(h http.Header) time.Duration {
+	for _, name := range []string{"Retry-After", "X-RateLimit-Reset"} {
+		if v := h.Get(name); v != "" {
+			if secs, err := strconv.Atoi(v); err == nil && secs >= 0 {
+				return time.Duration(secs) * time.Second
+			}
+		}
+	}
+	return time.Second
+}
+
+func decodeErrors(data []byte) []string {
+	var envelope struct {
+		Errors []string `json:"errors"`
+	}
+	if err := json.Unmarshal(data, &envelope); err == nil && len(envelope.Errors) > 0 {
+		return envelope.Errors
+	}
+	return []string{strings.TrimSpace(string(data))}
+}
