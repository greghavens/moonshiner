@@ -0,0 +1,46 @@
+// Package ddmon inventories and reconciles Datadog monitors over the
+// documented v1 monitor operations (GET /api/v1/monitor and
+// PUT /api/v1/monitor/{monitor_id}). Monitor CRUD is a v1 surface: the v2
+// monitor namespace only holds configuration policies, notification rules,
+// and templates, so this package intentionally stays on v1.
+package ddmon
+
+import "encoding/json"
+
+// Monitor is the subset of the v1 monitor object this reconciler reads.
+// Options stays raw JSON so option keys we don't model survive round-trips.
+type Monitor struct {
+	ID              int64           `json:"id"`
+	Name            string          `json:"name"`
+	Type            string          `json:"type"`
+	Query           string          `json:"query"`
+	Message         string          `json:"message"`
+	Tags            []string        `json:"tags"`
+	Priority        *int64          `json:"priority"`
+	RestrictedRoles []string        `json:"restricted_roles"`
+	Options         json.RawMessage `json:"options"`
+}
+
+// Filter narrows the monitor list call with the documented query params.
+type Filter struct {
+	Name        string
+	MonitorTags []string
+}
+
+// Desired is the reconciler-owned projection of a monitor: query, message,
+// tags, and priority. A nil Priority means priority is unmanaged.
+type Desired struct {
+	Name     string
+	Query    string
+	Message  string
+	Tags     []string
+	Priority *int64
+}
+
+// Report summarizes one reconcile pass, in desired order.
+type Report struct {
+	Updated   []int64
+	Unchanged []int64
+	Missing   []string
+	Failed    map[int64]string
+}
diff --git a/reconcile.go b/reconcile.go
new file mode 100644
index 0000000..dc8fc4e
--- /dev/null
+++ b/reconcile.go
@@ -0,0 +1,85 @@
+package ddmon
+
+import (
+	"context"
+	"encoding/json"
+	"net/http"
+	"sort"
+	"strconv"
+)
+
+// Reconcile matches desired monitors to the live inventory by name and
+// updates only the fields this tool owns (query, message, tags, priority).
+// Everything else — options, restricted_roles — is echoed back verbatim so
+// an edit never resets fields owned by humans. An unrestricted monitor's
+// restricted_roles key is omitted entirely: sending null would open the
+// monitor to every user with Monitor Write.
+func (c *Client) Reconcile(ctx context.Context, f Filter, desired []Desired) (Report, error) {
+	report := Report{Failed: map[int64]string{}}
+	monitors, err := c.ListMonitors(ctx, f)
+	if err != nil {
+		return report, err
+	}
+	byName := make(map[string]*Monitor, len(monitors))
+	for i := range monitors {
+		byName[monitors[i].Name] = &monitors[i]
+	}
+	for _, d := range desired {
+		monitor, found := byName[d.Name]
+		if !found {
+			report.Missing = append(report.Missing, d.Name)
+			continue
+		}
+		if !hasDrift(monitor, d) {
+			report.Unchanged = append(report.Unchanged, monitor.ID)
+			continue
+		}
+		body := map[string]any{
+			"query":   d.Query,
+			"message": d.Message,
+			"tags":    d.Tags,
+		}
+		if d.Priority != nil {
+			body["priority"] = *d.Priority
+		}
+		if len(monitor.Options) > 0 {
+			body["options"] = json.RawMessage(monitor.Options)
+		}
+		if len(monitor.RestrictedRoles) > 0 {
+			body["restricted_roles"] = monitor.RestrictedRoles
+		}
+		path := "/api/v1/monitor/" + strconv.FormatInt(monitor.ID, 10)
+		if _, err := c.do(ctx, http.MethodPut, path, nil, body); err != nil {
+			report.Failed[monitor.ID] = err.Error()
+			continue
+		}
+		report.Updated = append(report.Updated, monitor.ID)
+	}
+	return report, nil
+}
+
+func hasDrift(m *Monitor, d Desired) bool {
+	if m.Query != d.Query || m.Message != d.Message {
+		return true
+	}
+	if d.Priority != nil && (m.Priority == nil || *m.Priority != *d.Priority) {
+		return true
+	}
+	return !sameTagSet(m.Tags, d.Tags)
+}
+
+func sameTagSet(a, b []string) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	as := append([]string(nil), a...)
+	bs := append([]string(nil), b...)
+	sort.Strings(as)
+	sort.Strings(bs)
+	for i := range as {
+		if as[i] != bs[i] {
+			return false
+		}
+	}
+	return true
+}
