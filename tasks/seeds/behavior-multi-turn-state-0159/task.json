{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0159",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "public-services",
  "prompt": "Pull up application APP-6167 and confirm its name, current location, and status. Do not change it or contact anyone yet. If the tool omits a requested field, call it unknown instead of filling it in.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same application to Lakewood North Office. Do not change its review date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Lakewood City Hall, not Lakewood North Office. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "public-services_get",
    "public-services_search",
    "public-services_update",
    "public-services_create",
    "public-services_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "APP-6167",
        "name": "Community garden permit",
        "location": "Lakewood",
        "date": "2026-08-15",
        "status": "active"
      },
      {
        "id": "APP-9167",
        "name": "Block party application",
        "location": "Denver",
        "date": "2026-09-20",
        "status": "pending"
      },
      {
        "id": "APP-12167",
        "name": "Community garden permit archive",
        "location": "Denver",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_get",
            "arguments": {
              "id": "APP-6167"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "APP-6167",
              "location": "Lakewood North Office"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "APP-6167",
              "location": "Lakewood City Hall"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its review date or status."
      }
    ],
    "state_assertions": [
      "APP-6167.location == Lakewood City Hall",
      "APP-6167.location != Lakewood North Office",
      "APP-6167.date == 2026-08-15",
      "APP-9167.date == 2026-09-20",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "public-services_create",
      "public-services_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location.",
      "Label any requested field omitted by a tool result as unknown."
    ]
  },
  "training_tags": [
