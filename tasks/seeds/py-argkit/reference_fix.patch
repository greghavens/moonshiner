index 0000000..10e28d2
--- /dev/null
+++ b/argkit.py
@@ -0,0 +1,288 @@
+"""argkit — a small argument-parsing engine for internal ops tooling.
+
+No argparse/optparse/getopt: this replaces them on the trimmed runtime image.
+Errors never exit the process; they surface as structured exceptions.
+"""
+
+
+class UsageError(Exception):
+    """A bad invocation. Carries a machine code, the human message, and usage."""
+
+    def __init__(self, code, message, usage):
+        super().__init__(f"{usage}\nerror: {message}")
+        self.code = code
+        self.message = message
+        self.usage = usage
+
+
+class HelpRequested(Exception):
+    """Raised when -h/--help is parsed; .text is the full help output."""
+
+    def __init__(self, text):
+        super().__init__(text)
+        self.text = text
+
+
+class Namespace:
+    """Parse result: plain attribute access."""
+
+    def __repr__(self):
+        inner = ", ".join(f"{k}={v!r}" for k, v in sorted(vars(self).items()))
+        return f"Namespace({inner})"
+
+
+def _dest(name):
+    return name.lstrip("-").replace("-", "_")
+
+
+class _Option:
+    def __init__(self, long, aliases, type_, default, flag, required, help_, is_help=False):
+        self.long = long
+        self.aliases = aliases
+        self.type = type_
+        self.default = default
+        self.flag = flag
+        self.required = required
+        self.help = help_
+        self.is_help = is_help
+        self.dest = _dest(long)
+        self.metavar = self.dest.upper()
+
+    def invocation(self):
+        names = ", ".join([self.long] + self.aliases)
+        if self.flag or self.is_help:
+            return names
+        return f"{names} {self.metavar}"
+
+    def usage_piece(self):
+        if self.flag or self.is_help:
+            return f"[{self.long}]"
+        if self.required:
+            return f"{self.long} {self.metavar}"
+        return f"[{self.long} {self.metavar}]"
+
+    def help_text(self):
+        text = self.help or ""
+        if not self.flag and not self.is_help and not self.required and self.default is not None:
+            suffix = f"(default: {self.default})"
+            text = f"{text} {suffix}" if text else suffix
+        return text
+
+
+class _Positional:
+    def __init__(self, name, type_, help_):
+        self.name = name
+        self.type = type_
+        self.help = help_
+        self.dest = _dest(name)
+
+
+class Parser:
+    def __init__(self, prog, description=None, add_help=True):
+        self.prog = prog
+        self.description = description
+        self._positionals = []
+        self._options = []
+        self._commands = {}       # name -> Parser
+        self._command_order = []
+        if add_help:
+            self._options.append(_Option(
+                "--help", ["-h"], None, None, False, False,
+                "show this help message and exit", is_help=True))
+
+    # ------------------------------------------------------------ definition
+
+    def _taken_names(self):
+        names = set()
+        for o in self._options:
+            names.add(o.long)
+            names.update(o.aliases)
+        for p in self._positionals:
+            names.add(p.name)
+        return names
+
+    def add_argument(self, *names, **kw):
+        if not names:
+            raise ValueError("add_argument needs at least one name")
+        if not names[0].startswith("-"):
+            if len(names) != 1:
+                raise ValueError("positional arguments take exactly one name")
+            name = names[0]
+            if self._commands:
+                raise ValueError("cannot mix positional arguments and commands")
+            if name in self._taken_names():
+                raise ValueError(f"duplicate argument name: {name}")
+            bad = set(kw) - {"type", "help"}
+            if bad:
+                raise ValueError(f"positional arguments do not accept: {sorted(bad)}")
+            self._positionals.append(_Positional(name, kw.get("type", str), kw.get("help")))
+            return
+
+        long = names[0]
+        if not long.startswith("--") or len(long) <= 2:
+            raise ValueError(f"the first option name must be a long --name: {long!r}")
+        aliases = list(names[1:])
+        for a in aliases:
+            if not a.startswith("-") or a.startswith("--") or len(a) < 2:
+                raise ValueError(f"option aliases must be short -x names: {a!r}")
+        for n in [long] + aliases:
+            if n in self._taken_names():
+                raise ValueError(f"duplicate argument name: {n}")
+        bad = set(kw) - {"type", "default", "flag", "required", "help"}
+        if bad:
+            raise ValueError(f"unknown add_argument keywords: {sorted(bad)}")
+        flag = bool(kw.get("flag", False))
+        required = bool(kw.get("required", False))
+        default = kw.get("default")
+        if flag and ("type" in kw or "default" in kw or required):
+            raise ValueError("flag options take no type, default, or required")
+        if required and "default" in kw:
+            raise ValueError("required options cannot have a default")
+        if flag:
+            default = False
+        self._options.append(_Option(
+            long, aliases, kw.get("type", str), default, flag, required, kw.get("help")))
+
+    def add_command(self, name, description=None):
+        if self._positionals:
+            raise ValueError("cannot mix positional arguments and commands")
+        if name in self._commands:
+            raise ValueError(f"duplicate command: {name}")
+        sub = Parser(f"{self.prog} {name}", description=description)
+        self._commands[name] = sub
+        self._command_order.append(name)
+        return sub
+
+    # ------------------------------------------------------------ help text
+
+    def format_usage(self):
+        pieces = [f"usage: {self.prog}"]
+        pieces.extend(o.usage_piece() for o in self._options)
+        pieces.extend(p.name for p in self._positionals)
+        if self._commands:
+            pieces.append("<command> ...")
+        return " ".join(pieces)
+
+    @staticmethod
+    def _section(title, rows):
+        width = max(len(invocation) for invocation, _ in rows)
+        lines = [title]
+        for invocation, text in rows:
+            if text:
+                lines.append(f"  {invocation.ljust(width)}  {text}")
+            else:
+                lines.append(f"  {invocation}")
+        return "\n".join(lines)
+
+    def format_help(self):
+        blocks = [self.format_usage()]
+        if self.description:
+            blocks.append(self.description)
+        if self._positionals:
+            blocks.append(self._section(
+                "arguments:", [(p.name, p.help or "") for p in self._positionals]))
+        if self._commands:
+            blocks.append(self._section(
+                "commands:",
+                [(n, self._commands[n].description or "") for n in self._command_order]))
+        if self._options:
+            blocks.append(self._section(
+                "options:", [(o.invocation(), o.help_text()) for o in self._options]))
+        return "\n\n".join(blocks) + "\n"
+
+    # ------------------------------------------------------------ parsing
+
+    def _fail(self, code, message):
+        raise UsageError(code, message, self.format_usage())
+
+    def _lookup(self, name):
+        for o in self._options:
+            if name == o.long or name in o.aliases:
+                return o
+        return None
+
+    def _coerce(self, type_, display, raw):
+        try:
+            return type_(raw)
+        except (ValueError, TypeError):
+            self._fail("bad-value", f"invalid {type_.__name__} for {display}: {raw!r}")
+
+    def _check_required(self, seen):
+        for o in self._options:
+            if o.required and o.dest not in seen:
+                self._fail("missing-option", f"missing required option: {o.long}")
+
+    def _finish(self, values):
+        ns = Namespace()
+        for o in self._options:
+            if o.is_help:
+                continue
+            setattr(ns, o.dest, values.get(o.dest, o.default))
+        for p in self._positionals:
+            setattr(ns, p.dest, values[p.dest])
+        return ns
+
+    def parse(self, argv):
+        values = {}
+        pos_idx = 0
+        only_positional = False
+        tokens = list(argv)
+        i = 0
+        while i < len(tokens):
+            tok = tokens[i]
+            if not only_positional and tok == "--":
+                only_positional = True
+                i += 1
+                continue
+            if not only_positional and len(tok) > 1 and tok.startswith("-"):
+                if tok.startswith("--"):
+                    name, _, inline = tok.partition("=")
+                    has_inline = "=" in tok
+                else:
+                    name, inline, has_inline = tok, "", False
+                opt = self._lookup(name)
+                if opt is None:
+                    self._fail("unknown-option", f"unrecognized option: {name}")
+                if opt.is_help:
+                    raise HelpRequested(self.format_help())
+                if opt.flag:
+                    if has_inline:
+                        self._fail("unexpected-value",
+                                   f"option {opt.long} does not take a value")
+                    values[opt.dest] = True
+                else:
+                    if has_inline:
+                        raw = inline
+                    else:
+                        i += 1
+                        if i >= len(tokens):
+                            self._fail("missing-value",
+                                       f"option {opt.long} expects a value")
+                        raw = tokens[i]
+                    values[opt.dest] = self._coerce(opt.type, opt.long, raw)
+                i += 1
+                continue
+            # a plain token: command name or positional
+            if self._commands:
+                self._check_required(values)
+                if tok not in self._commands:
+                    self._fail("unknown-command", f"unknown command: {tok!r}")
+                sub_ns = self._commands[tok].parse(tokens[i + 1:])
+                ns = self._finish(values)
+                for k, v in vars(sub_ns).items():
+                    setattr(ns, k, v)
+                ns.command = tok
+                return ns
+            if pos_idx >= len(self._positionals):
+                self._fail("extra-argument", f"unexpected extra argument: {tok!r}")
+            p = self._positionals[pos_idx]
+            pos_idx += 1
+            values[p.dest] = self._coerce(p.type, p.name, tok)
+            i += 1
+        if self._commands:
+            self._fail("missing-command", "missing command")
+        if pos_idx < len(self._positionals):
+            self._fail("missing-argument",
+                       f"missing required argument: {self._positionals[pos_idx].name}")
+        self._check_required(values)
+        return self._finish(values)
