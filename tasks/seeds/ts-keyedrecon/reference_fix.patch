+// keyed_recon.ts — a keyed reconciler: diff two element trees into a flat
+// list of patch ops (insert / remove / move / update).
+//
+// Plain TypeScript under node's type stripping: no JSX, no React. Paths are
+// child-index lists into the NEW tree; removes are addressed by OLD index.
+// Children that hold their place form a longest strictly increasing
+// subsequence of old indices in new order, so keyed reorders emit the fewest
+// possible moves; ties prefer the earliest new positions.
+
+export type PropValue = string | number | boolean;
+
+export interface VElement {
+  type: string;
+  key: string | null;
+  props: Record<string, PropValue>;
+  children: VElement[];
+}
+
+export type Path = number[];
+
+export type Op =
+  | { op: "insert"; parent: Path; index: number; node: VElement }
+  | { op: "remove"; parent: Path; index: number }
+  | { op: "move"; parent: Path; from: number; to: number }
+  | { op: "update"; path: Path; set: Record<string, PropValue>; remove: string[] };
+
+export function diff(oldRoot: VElement, newRoot: VElement): Op[] {
+  if (oldRoot.type !== newRoot.type) {
+    throw new Error(`root type changed: expected ${oldRoot.type}, got ${newRoot.type}`);
+  }
+  const ops: Op[] = [];
+  diffNode(oldRoot, newRoot, [], ops);
+  return ops;
+}
+
+// ------------------------------------------------------------- one node
+
+function diffNode(oldNode: VElement, newNode: VElement, path: Path, ops: Op[]): void {
+  const set: Record<string, PropValue> = {};
+  for (const name of Object.keys(newNode.props)) {
+    if (!(name in oldNode.props) || !Object.is(oldNode.props[name], newNode.props[name])) {
+      set[name] = newNode.props[name];
+    }
+  }
+  const removed = Object.keys(oldNode.props)
+    .filter((name) => !(name in newNode.props))
+    .sort();
+  if (Object.keys(set).length > 0 || removed.length > 0) {
+    ops.push({ op: "update", path, set, remove: removed });
+  }
+  diffChildren(oldNode.children, newNode.children, path, ops);
+}
+
+// ------------------------------------------------------------- children
+
+function checkKeys(children: VElement[]): void {
+  const seen = new Set<string>();
+  for (const child of children) {
+    if (child.key !== null) {
+      if (seen.has(child.key)) {
+        throw new Error(`duplicate key: ${child.key}`);
+      }
+      seen.add(child.key);
+    }
+  }
+}
+
+function diffChildren(
+  oldChildren: VElement[],
+  newChildren: VElement[],
+  path: Path,
+  ops: Op[],
+): void {
+  checkKeys(oldChildren);
+  checkKeys(newChildren);
+
+  // Match new children against old children: by key (same key AND same
+  // type), or positionally among the unkeyed (i-th unkeyed with i-th
+  // unkeyed, types must agree; a mismatched pair still consumes the slot).
+  const oldKeyed = new Map<string, number>();
+  const oldUnkeyed: number[] = [];
+  oldChildren.forEach((child, i) => {
+    if (child.key !== null) {
+      oldKeyed.set(child.key, i);
+    } else {
+      oldUnkeyed.push(i);
+    }
+  });
+
+  let unkeyedCursor = 0;
+  const matchedOldIndex: (number | null)[] = newChildren.map((child) => {
+    let candidate: number | undefined;
+    if (child.key !== null) {
+      candidate = oldKeyed.get(child.key);
+    } else if (unkeyedCursor < oldUnkeyed.length) {
+      candidate = oldUnkeyed[unkeyedCursor];
+      unkeyedCursor += 1;
+    }
+    if (candidate === undefined || oldChildren[candidate].type !== child.type) {
+      return null;
+    }
+    return candidate;
+  });
+
+  // Removes first, in descending old-index order.
+  const matched = new Set<number>();
+  for (const index of matchedOldIndex) {
+    if (index !== null) {
+      matched.add(index);
+    }
+  }
+  for (let i = oldChildren.length - 1; i >= 0; i -= 1) {
+    if (!matched.has(i)) {
+      ops.push({ op: "remove", parent: path, index: i });
+    }
+  }
+
+  // Decide which matched children hold their place: a longest strictly
+  // increasing subsequence of old indices in new order, preferring the
+  // earliest new positions on ties.
+  const pairs: { newIndex: number; oldIndex: number }[] = [];
+  matchedOldIndex.forEach((oldIndex, newIndex) => {
+    if (oldIndex !== null) {
+      pairs.push({ newIndex, oldIndex });
+    }
+  });
+  const kept = keptNewPositions(pairs);
+
+  // One left-to-right walk of the new children: inserts and moves.
+  newChildren.forEach((child, newIndex) => {
+    const oldIndex = matchedOldIndex[newIndex];
+    if (oldIndex === null) {
+      ops.push({ op: "insert", parent: path, index: newIndex, node: child });
+    } else if (!kept.has(newIndex)) {
+      ops.push({ op: "move", parent: path, from: oldIndex, to: newIndex });
+    }
+  });
+
+  // Recurse into matched pairs, in new-list order.
+  newChildren.forEach((child, newIndex) => {
+    const oldIndex = matchedOldIndex[newIndex];
+    if (oldIndex !== null) {
+      diffNode(oldChildren[oldIndex], child, [...path, newIndex], ops);
+    }
+  });
+}
+
+/**
+ * New positions of the children that stay put. Among all longest strictly
+ * increasing subsequences of old indices (in new order) this picks the one
+ * with the lexicographically smallest set of new positions: compute, for
+ * each pair, the length of the longest run starting there, then scan left
+ * to right keeping a pair whenever a maximum-length run can still pass
+ * through it.
+ */
+function keptNewPositions(pairs: { newIndex: number; oldIndex: number }[]): Set<number> {
+  const n = pairs.length;
+  const startLength = new Array<number>(n).fill(1);
+  for (let i = n - 1; i >= 0; i -= 1) {
+    for (let j = i + 1; j < n; j += 1) {
+      if (pairs[j].oldIndex > pairs[i].oldIndex && startLength[j] + 1 > startLength[i]) {
+        startLength[i] = startLength[j] + 1;
+      }
+    }
+  }
+  let need = 0;
+  for (const length of startLength) {
+    if (length > need) {
+      need = length;
+    }
+  }
+  const kept = new Set<number>();
+  let lastOldIndex = -1;
+  for (let i = 0; i < n && need > 0; i += 1) {
+    if (startLength[i] === need && pairs[i].oldIndex > lastOldIndex) {
+      kept.add(pairs[i].newIndex);
+      lastOldIndex = pairs[i].oldIndex;
+      need -= 1;
+    }
+  }
+  return kept;
+}
