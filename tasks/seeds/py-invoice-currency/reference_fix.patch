 """Plain-text invoice rendering for the billing service.
 
 Amounts are floats in the invoice currency. Every computed amount is
-rounded to cents as soon as it is produced so the numbers printed on an
-invoice always add up to the printed total.
+rounded to the currency's precision as soon as it is produced so the
+numbers printed on an invoice always add up to the printed total.
+
+Rounding is half-up (finance requirement), performed in decimal so that
+values like 1.005 round to 1.01 regardless of binary float artifacts.
 """
 
+from decimal import Decimal, ROUND_HALF_UP
+
+# Per-currency display + rounding rules. `decimals` is the minor-unit
+# precision; `cash_increment` (optional) rounds amounts to a coarser cash
+# step after decimal rounding (Swiss 5-rappen rule).
+CURRENCIES = {
+    "USD": {"symbol": "$", "decimals": 2, "cash_increment": None},
+    "EUR": {"symbol": "€", "decimals": 2, "cash_increment": None},
+    "JPY": {"symbol": "¥", "decimals": 0, "cash_increment": None},
+    "CHF": {"symbol": "CHF ", "decimals": 2, "cash_increment": "0.05"},
+}
+
+
+def _spec(currency):
+    try:
+        return CURRENCIES[currency]
+    except KeyError:
+        raise ValueError("unknown currency: %r" % (currency,)) from None
+
+
+def round_amount(amount, currency="USD"):
+    """Round `amount` per the currency's rules; returns a float."""
+    spec = _spec(currency)
+    d = amount if isinstance(amount, Decimal) else Decimal(str(amount))
+    if spec["cash_increment"]:
+        inc = Decimal(spec["cash_increment"])
+        d = (d / inc).quantize(Decimal("1"), rounding=ROUND_HALF_UP) * inc
+    quantum = Decimal(1).scaleb(-spec["decimals"])
+    return float(d.quantize(quantum, rounding=ROUND_HALF_UP))
+
 
