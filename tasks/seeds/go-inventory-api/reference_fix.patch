@@ -0,0 +1,39 @@
+// Package inventory is the warehouse inventory API: a JSON REST layer over
+// a pluggable, versioned storage backend.
+package inventory
+
+import (
+	"context"
+	"errors"
+)
+
+// Item is one inventory record. Version is storage metadata: it travels in
+// the ETag header, never in JSON bodies.
+type Item struct {
+	SKU        string `json:"sku"`
+	Name       string `json:"name"`
+	Quantity   int    `json:"quantity"`
+	PriceCents int    `json:"price_cents"`
+	Version    int    `json:"-"`
+}
+
+// Storage sentinels the HTTP layer maps onto statuses.
+var (
+	ErrNotFound        = errors.New("item not found")
+	ErrExists          = errors.New("item already exists")
+	ErrVersionMismatch = errors.New("item version mismatch")
+)
+
+// Store is the storage seam. Implementations must be safe for concurrent
+// use; Update and Delete are compare-and-swap on the item version.
+type Store interface {
+	List(ctx context.Context) ([]Item, error)
+	Get(ctx context.Context, sku string) (Item, error)
+	// Create assigns Version 1. An existing sku is ErrExists.
+	Create(ctx context.Context, it Item) (Item, error)
+	// Update replaces the item iff its current version is expectVersion,
+	// bumping the version. ErrNotFound / ErrVersionMismatch otherwise.
+	Update(ctx context.Context, it Item, expectVersion int) (Item, error)
+	// Delete removes the item iff its current version is expectVersion.
+	Delete(ctx context.Context, sku string, expectVersion int) error
+}
