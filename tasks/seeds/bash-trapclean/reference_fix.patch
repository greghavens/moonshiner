diff --git a/packup.sh b/packup.sh
new file mode 100644
index 0000000..0be21a0
--- /dev/null
+++ b/packup.sh
@@ -0,0 +1,74 @@
+#!/usr/bin/env bash
+# packup.sh — snapshot the sizes of the files in a directory into a manifest.
+#
+# Careful-lifecycle packer: takes <out>.lock (mkdir), stages into <out>.part,
+# finalizes with an atomic mv. EXIT/INT/TERM traps guarantee that whatever
+# this run created is removed again, and cleanup is safe to run twice.
+set -u
+LC_ALL=C
+export LC_ALL
+
+if [[ $# -ne 2 ]]; then
+  echo "usage: packup.sh <src-dir> <out-file>" >&2
+  exit 64
+fi
+src=$1
+out=$2
+
+if [[ ! -d "$src" || ! -r "$src" ]]; then
+  echo "packup.sh: not a directory: $src" >&2
+  exit 66
+fi
+
+lock="$out.lock"
+part="$out.part"
+have_lock=0
+cleaned=0
+
+cleanup() {
+  # idempotent: a second signal while cleanup runs must be a no-op
+  [[ "$cleaned" -eq 1 ]] && return 0
+  cleaned=1
+  # we only ever create the staging file after winning the lock, so if the
+  # lock is not ours there is nothing of ours to remove
+  [[ "$have_lock" -eq 1 ]] || return 0
+  rm -f -- "$part"
+  rmdir -- "$lock" 2>/dev/null || true
+}
+trap 'cleanup' EXIT
+trap 'cleanup; trap - EXIT; exit 130' INT
+trap 'cleanup; trap - EXIT; exit 143' TERM
+
+# atomic check-and-take: mkdir wins exactly once
+if ! mkdir -- "$lock" 2>/dev/null; then
+  echo "packup.sh: lock held: $lock" >&2
+  exit 75
+fi
+have_lock=1
+
+count=0
+total=0
+: > "$part"
+for f in "$src"/*; do
+  [[ -f "$f" ]] || continue
+  bytes=$(wc -c < "$f")
+  bytes=$((bytes))
+  printf '%s\t%d\n' "${f##*/}" "$bytes" >> "$part"
+  count=$((count + 1))
+  total=$((total + bytes))
+done
+printf 'total\t%d\n' "$total" >> "$part"
+
+# supervisor hooks: announce the staged manifest, then wait out any hold
+if [[ -n "${PACKUP_READY_FILE:-}" ]]; then
+  : > "$PACKUP_READY_FILE"
+fi
+if [[ -n "${PACKUP_HOLD_FILE:-}" ]]; then
+  while [[ -e "$PACKUP_HOLD_FILE" ]]; do
+    sleep 0.05
+  done
+fi
+
+mv -- "$part" "$out"
+printf 'packed %d file(s) -> %s\n' "$count" "$out"
+exit 0
