diff --git a/FareRules.java b/FareRules.java
new file mode 100644
index 0000000..f208043
--- /dev/null
+++ b/FareRules.java
@@ -0,0 +1,144 @@
+import java.time.LocalDate;
+import java.time.temporal.ChronoUnit;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Locale;
+
+/**
+ * The fare rules engine. Pure functions of the dates handed in — no clock
+ * reads, ever. Explanation strings are contract: ops greps for them.
+ */
+public final class FareRules {
+
+    private FareRules() {}
+
+    public static String money(long cents) {
+        return String.format(Locale.ROOT, "$%d.%02d", cents / 100, cents % 100);
+    }
+
+    // ------------------------------------------------------------------
+
+    public static Decision evaluate(FareClass fare, TripRequest trip) {
+        // Rule 1: booking-window sanity. Terminal on failure.
+        if (trip.departure().isBefore(trip.bookingDate())) {
+            return new Decision(false, List.of(
+                    "FAIL booking-window: departure " + trip.departure()
+                            + " is before booking date " + trip.bookingDate()));
+        }
+        if (trip.returnDate() != null && trip.returnDate().isBefore(trip.departure())) {
+            return new Decision(false, List.of(
+                    "FAIL booking-window: return " + trip.returnDate()
+                            + " is before departure " + trip.departure()));
+        }
+
+        List<String> lines = new ArrayList<>();
+
+        // Rule 2: advance-purchase.
+        int needDays = fare.advancePurchaseDays();
+        if (needDays == 0) {
+            lines.add("PASS advance-purchase: not required");
+        } else {
+            long hasDays = ChronoUnit.DAYS.between(trip.bookingDate(), trip.departure());
+            lines.add((hasDays >= needDays ? "PASS" : "FAIL")
+                    + " advance-purchase: needs " + needDays + " days, has " + hasDays);
+        }
+
+        // Rule 3: min-stay.
+        int needNights = fare.minStayNights();
+        if (needNights == 0) {
+            lines.add("PASS min-stay: not required");
+        } else if (trip.returnDate() == null) {
+            lines.add("FAIL min-stay: requires a round trip");
+        } else {
+            long nights = ChronoUnit.DAYS.between(trip.departure(), trip.returnDate());
+            lines.add((nights >= needNights ? "PASS" : "FAIL")
+                    + " min-stay: needs " + needNights + " nights, has " + nights);
+        }
+
+        boolean eligible = lines.stream().noneMatch(l -> l.startsWith("FAIL"));
+        return new Decision(eligible, List.copyOf(lines));
+    }
+
+    // ------------------------------------------------------------------
+
+    public static Quote cheapestEligible(List<FareClass> fares, TripRequest trip) {
+        List<String> verdicts = new ArrayList<>();
+        FareClass best = null;
+        for (FareClass fare : fares) {
+            Decision decision = evaluate(fare, trip);
+            if (decision.eligible()) {
+                verdicts.add(fare.code() + ": eligible at " + money(fare.baseCents()));
+                if (best == null
+                        || fare.baseCents() < best.baseCents()
+                        || (fare.baseCents() == best.baseCents()
+                            && fare.code().compareTo(best.code()) < 0)) {
+                    best = fare;
+                }
+            } else {
+                verdicts.add(fare.code() + ": ineligible (" + firstFailingRule(decision) + ")");
+            }
+        }
+        if (best == null) {
+            verdicts.add("no eligible fare");
+            return new Quote(null, 0, List.copyOf(verdicts));
+        }
+        verdicts.add("selected " + best.code() + " at " + money(best.baseCents()));
+        return new Quote(best.code(), best.baseCents(), List.copyOf(verdicts));
+    }
+
+    private static String firstFailingRule(Decision decision) {
+        for (String line : decision.explanations()) {
+            if (line.startsWith("FAIL ")) {
+                int colon = line.indexOf(':');
+                return line.substring("FAIL ".length(), colon);
+            }
+        }
+        throw new IllegalStateException("no failing rule in an ineligible decision");
+    }
+
+    // ------------------------------------------------------------------
+
+    public static ChangeQuote change(FareClass oldFare, FareClass newFare,
+                                     LocalDate purchaseDate, TripRequest newTrip) {
+        // Precedence 1: the old fare must permit changes at all.
+        if (!oldFare.changeable()) {
+            return new ChangeQuote(false, 0, 0, 0, List.of(
+                    "DENY change: fare " + oldFare.code() + " does not permit changes"));
+        }
+
+        // Precedence 2: the new fare re-validates as of the change date.
+        Decision decision = evaluate(newFare, newTrip);
+        if (!decision.eligible()) {
+            List<String> lines = new ArrayList<>();
+            lines.add("DENY change: fare " + newFare.code() + " fails its rules");
+            lines.addAll(decision.explanations());
+            return new ChangeQuote(false, 0, 0, 0, List.copyOf(lines));
+        }
+
+        List<String> lines = new ArrayList<>();
+        lines.add("ALLOW change: " + oldFare.code() + " -> " + newFare.code());
+
+        // Precedence 3: fee, waived only inside the same-day void window.
+        long fee;
+        if (newTrip.bookingDate().equals(purchaseDate)) {
+            fee = 0;
+            lines.add("WAIVE fee: change within the same-day void window");
+        } else {
+            fee = oldFare.changeFeeCents();
+            lines.add("FEE change: " + money(fee));
+        }
+
+        // Precedence 4: fare difference, never refunded.
+        long rawDifference = newFare.baseCents() - oldFare.baseCents();
+        long charged = Math.max(0, rawDifference);
+        if (rawDifference > 0) {
+            lines.add("FARE-DIFFERENCE: " + money(charged));
+        } else {
+            lines.add("FARE-DIFFERENCE: " + money(0) + " (no refund on downgrade)");
+        }
+
+        long total = fee + charged;
+        lines.add("TOTAL DUE: " + money(total));
+        return new ChangeQuote(true, fee, charged, total, List.copyOf(lines));
+    }
+}
