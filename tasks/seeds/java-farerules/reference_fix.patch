+import java.time.LocalDate;
+
+/**
+ * What the agent is trying to book, plus the date the decision is made on.
+ * returnDate null means one-way. The engine never reads a clock: bookingDate
+ * is the only "today" there is.
+ */
+public record TripRequest(LocalDate bookingDate, LocalDate departure, LocalDate returnDate) {
+}
