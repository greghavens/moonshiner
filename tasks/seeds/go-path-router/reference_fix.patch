+
+func splitPath(p string) []string {
+	if p == "/" {
+		return nil
+	}
+	return strings.Split(p[1:], "/")
+}
+
+func parsePattern(p string) ([]segment, error) {
+	parts := splitPath(p)
+	segs := make([]segment, 0, len(parts))
+	for i, part := range parts {
+		switch {
+		case strings.HasPrefix(part, "*"):
+			if part == "*" {
+				return nil, fmt.Errorf("router: %w: wildcard needs a name in %q", ErrInvalidPattern, p)
+			}
+			if i != len(parts)-1 {
+				return nil, fmt.Errorf("router: %w: wildcard must be the final segment in %q", ErrInvalidPattern, p)
+			}
+			segs = append(segs, segment{kind: segWildcard, text: part[1:]})
+		case strings.HasPrefix(part, ":"):
+			if part == ":" {
+				return nil, fmt.Errorf("router: %w: param needs a name in %q", ErrInvalidPattern, p)
+			}
+			segs = append(segs, segment{kind: segParam, text: part[1:]})
+		default:
+			segs = append(segs, segment{kind: segStatic, text: part})
+		}
+	}
+	return segs, nil
+}
+
+// rankMatch reports whether segs match parts and, if so, the per-path-
+// segment precedence ranks used to pick between competing patterns.
+func rankMatch(segs []segment, parts []string) ([]int, bool) {
+	wild := len(segs) > 0 && segs[len(segs)-1].kind == segWildcard
+	if wild {
+		// Everything before the wildcard must line up, and the wildcard
+		// itself consumes at least one segment.
+		if len(parts) < len(segs) {
+			return nil, false
+		}
+	} else if len(parts) != len(segs) {
+		return nil, false
+	}
+	rank := make([]int, len(parts))
+	for i, part := range parts {
+		if wild && i >= len(segs)-1 {
+			rank[i] = segWildcard
+			continue
+		}
+		seg := segs[i]
+		switch seg.kind {
+		case segStatic:
+			if seg.text != part {
+				return nil, false
+			}
+		case segParam:
+			if part == "" {
+				return nil, false
+			}
+		}
+		rank[i] = seg.kind
+	}
+	return rank, true
+}
+
+// lessRank reports whether a beats b, comparing left to right.
+func lessRank(a, b []int) bool {
+	for i := range a {
+		if i >= len(b) {
+			return false
+		}
+		if a[i] != b[i] {
+			return a[i] < b[i]
+		}
+	}
+	return false
+}
+
+// capture builds the Params for a successful match.
+func capture(segs []segment, parts []string) Params {
+	params := Params{}
+	for i, seg := range segs {
+		switch seg.kind {
+		case segParam:
+			params[seg.text] = parts[i]
+		case segWildcard:
+			params[seg.text] = strings.Join(parts[i:], "/")
+		}
+	}
+	return params
+}
