+// Match finds the registered pattern that best matches path and returns
+// its handler along with any captured parameters. When several patterns
+// match, precedence is decided per segment, left to right: static
+// segments beat ":param" segments, which beat "*wildcard" segments.
+func (r *Router[H]) Match(path string) (H, Params, bool) {
+	var zero H
+	p, err := normalize(path)
+	if err != nil {
+		return zero, nil, false
+	}
+	parts := splitPath(p)
+
+	var (
+		found    bool
+		best     route[H]
+		bestRank []int
+	)
+	for _, rt := range r.routes {
+		rank, ok := rankMatch(rt.segs, parts)
+		if !ok {
+			continue
+		}
+		if !found || lessRank(rank, bestRank) {
+			found, best, bestRank = true, rt, rank
+		}
+	}
