@@ -1,9 +1,13 @@
 """Sequential batch runner for the nightly maintenance jobs.
 
 Jobs are named callables registered in run order. The scheduler cron
-script builds a JobRunner, registers everything, and calls run().
+script builds a JobRunner, registers everything, and calls run() — or
+execute() when it wants per-job timeouts and a summary instead of an
+exception.
 """
 
+import threading
+
 
 class JobFailed(Exception):
     """Raised by run() when a job blows up; carries which one and why."""
@@ -50,3 +54,93 @@ class JobRunner:
             except Exception as exc:
                 raise JobFailed(name, exc) from exc
         return results
+
+    def execute(self, timeout=None, continue_on_error=False):
+        """Run the batch, never raising for job outcomes.
+
+        Jobs run one at a time in registration order. `timeout` bounds
+        each job in seconds (None = unlimited); a job that exceeds it is
+        recorded as "timeout" and abandoned immediately. Unless
+        `continue_on_error` is set, the first non-ok record stops the
+        batch and later jobs never start.
+        """
+        if timeout is not None and timeout <= 0:
+            raise ValueError("timeout must be positive (or None)")
+        summary = Summary(len(self._jobs))
+        for name, fn in self._jobs:
+            record = _run_one(name, fn, timeout)
+            summary.records.append(record)
+            if record.status != "ok" and not continue_on_error:
+                break
+        return summary
+
+
+class JobRecord:
+    """Outcome of one job inside an execute() batch."""
+
+    __slots__ = ("name", "status", "value", "error")
+
+    def __init__(self, name, status, value=None, error=None):
+        self.name = name
+        self.status = status  # "ok" | "error" | "timeout"
+        self.value = value
+        self.error = error
+
+    def __repr__(self):
+        return "JobRecord(%r, %r)" % (self.name, self.status)
+
+
+class Summary:
+    """What execute() hands back to the scheduler for logging/paging."""
+
+    def __init__(self, total_jobs):
+        self.records = []
+        self._total = total_jobs
+
+    def _names(self, status):
+        return [r.name for r in self.records if r.status == status]
+
+    @property
+    def ok(self):
+        return self._names("ok")
+
+    @property
+    def errors(self):
+        return self._names("error")
+
+    @property
+    def timeouts(self):
+        return self._names("timeout")
+
+    @property
+    def all_ok(self):
+        return (len(self.records) == self._total
+                and all(r.status == "ok" for r in self.records))
+
+
+def _run_one(name, fn, timeout):
+    """Run a single job, optionally bounded by `timeout` seconds."""
+    if timeout is None:
+        try:
+            return JobRecord(name, "ok", value=fn())
+        except Exception as exc:
+            return JobRecord(name, "error", error=exc)
+
+    outcome = {}
+
+    def worker():
+        try:
+            outcome["value"] = fn()
+        except Exception as exc:
+            outcome["error"] = exc
+
+    thread = threading.Thread(target=worker, daemon=True,
+                              name="job-%s" % name)
+    thread.start()
+    thread.join(timeout)
+    if thread.is_alive():
+        # The job is stuck; abandon the daemon thread and move on.
+        return JobRecord(name, "timeout")
+    if "error" in outcome:
+        return JobRecord(name, "error", error=outcome["error"])
+    return JobRecord(name, "ok", value=outcome.get("value"))
