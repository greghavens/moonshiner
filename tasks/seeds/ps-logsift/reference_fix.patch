diff --git a/logsift.ps1 b/logsift.ps1
new file mode 100644
index 0000000..dc89e13
--- /dev/null
+++ b/logsift.ps1
@@ -0,0 +1,83 @@
+# logsift.ps1 — turn a fleet-agent app log into a structured JSON report.
+# Usage: pwsh -NoProfile -File logsift.ps1 -Path <file> [-OnMalformed <skip|error|keep>]
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][AllowEmptyString()][string]$Path,
+    [ValidateSet('skip', 'error', 'keep')][string]$OnMalformed = 'skip'
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message, [int]$Code)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+if ($Path.Length -eq 0) {
+    Fail 'logsift: -Path requires a non-empty path' 64
+}
+if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+    Fail "logsift: log not found: $Path" 66
+}
+
+$linePattern = '^(?<ts>\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}) (?<level>DEBUG|INFO|WARN|ERROR) ' +
+    '(?<comp>[A-Za-z][A-Za-z0-9_-]*) (?<msg>.*)$'
+
+$records = [System.Collections.Generic.List[object]]::new()
+$malformed = 0
+$lineNo = 0
+
+$raw = Get-Content -LiteralPath $Path -Raw
+if ($null -eq $raw) { $raw = '' }
+foreach ($line in $raw.Split("`n")) {
+    $lineNo++
+    if ($line.Trim().Length -eq 0) { continue }
+    if ($line[0] -eq ' ' -or $line[0] -eq "`t") {
+        if ($records.Count -gt 0) {
+            $last = $records[$records.Count - 1]
+            $last['message'] = $last['message'] + "`n" + $line.TrimStart()
+            continue
+        }
+    } elseif ($line -cmatch $linePattern) {
+        $records.Add([ordered]@{
+            timestamp = $Matches['ts']
+            level     = $Matches['level']
+            component = $Matches['comp']
+            message   = $Matches['msg']
+        })
+        continue
+    }
+    # Anything that reaches here failed to parse.
+    $malformed++
+    switch ($OnMalformed) {
+        'error' { Fail "logsift: malformed line ${lineNo}: $line" 65 }
+        'keep' {
+            $records.Add([ordered]@{
+                timestamp = ''
+                level     = 'RAW'
+                component = '-'
+                message   = $line
+            })
+        }
+        'skip' { }
+    }
+}
+
+$levels = [ordered]@{}
+$levelNames = @($records | ForEach-Object { $_['level'] } | Select-Object -Unique)
+[System.Array]::Sort($levelNames, [System.StringComparer]::Ordinal)
+foreach ($name in $levelNames) {
+    $levels[$name] = @($records | Where-Object { $_['level'] -ceq $name }).Count
+}
+
+$report = [ordered]@{
+    total     = $records.Count
+    malformed = $malformed
+    levels    = $levels
+    records   = @($records | ForEach-Object { [pscustomobject]$_ })
+}
+
+Write-Output ($report | ConvertTo-Json -Depth 5)
+exit 0
