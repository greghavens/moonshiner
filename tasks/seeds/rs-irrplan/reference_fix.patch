 //! irrplan — watering-schedule planner for the community garden controller.
 //!
-//! CLI surface not built yet; tests/cli.rs pins the parse and planning
-//! contract the controller crew agreed on.
+//! The CLI surface lives in the lib so the binary stays a thin wrapper and
+//! the contract tests can drive the parser in-process.
+
+use clap::{Parser, Subcommand, ValueEnum};
+
+#[derive(Parser, Debug)]
+#[command(name = "irrplan", about = "plan watering runs against a time budget")]
+pub struct Cli {
+    #[command(subcommand)]
+    pub command: Cmd,
+}
+
+#[derive(Subcommand, Debug)]
+pub enum Cmd {
+    /// Allocate the day's water budget across zones, in flag order.
+    Plan {
+        #[arg(long, value_enum)]
+        day: Day,
+        #[arg(long = "budget-min", value_parser = clap::value_parser!(u32).range(1..=600))]
+        budget_min: u32,
+        #[arg(long = "zone", value_parser = parse_zone_spec, required = true)]
+        zones: Vec<ZoneSpec>,
+    },
+    /// Validate zone specs without producing a plan.
+    Check {
+        #[arg(long = "zone", value_parser = parse_zone_spec, required = true)]
+        zones: Vec<ZoneSpec>,
+    },
+}
+
+#[derive(ValueEnum, Clone, Copy, Debug, PartialEq, Eq)]
+pub enum Day {
+    Mon,
+    Tue,
+    Wed,
+    Thu,
+    Fri,
+    Sat,
+    Sun,
+}
+
+impl Day {
+    fn name(self) -> &'static str {
+        match self {
+            Day::Mon => "mon",
+            Day::Tue => "tue",
+            Day::Wed => "wed",
+            Day::Thu => "thu",
+            Day::Fri => "fri",
+            Day::Sat => "sat",
+            Day::Sun => "sun",
+        }
+    }
+}
+
+#[derive(Clone, Debug, PartialEq, Eq)]
+pub struct ZoneSpec {
+    pub name: String,
+    pub minutes: u32,
+}
+
+/// Custom clap value parser for `NAME:MINUTES` zone specs.
+fn parse_zone_spec(raw: &str) -> Result<ZoneSpec, String> {
+    let err = || format!("invalid zone spec {raw:?}: expected NAME:MINUTES with minutes 1..=180");
+    let (name, minutes) = raw.split_once(':').ok_or_else(err)?;
+    if name.is_empty() {
+        return Err(err());
+    }
+    let minutes: u32 = minutes.parse().map_err(|_| err())?;
+    if !(1..=180).contains(&minutes) {
+        return Err(err());
+    }
+    Ok(ZoneSpec {
+        name: name.to_string(),
+        minutes,
+    })
+}
+
+/// Water zones in flag order: full minutes while the budget lasts, the first
+/// zone that does not fit is cut to the remainder, everything after is
+/// skipped.
+pub fn render_plan(day: Day, budget_min: u32, zones: &[ZoneSpec]) -> String {
+    let mut out = format!("watering plan for {} (budget {} min)\n", day.name(), budget_min);
+    let mut remaining = budget_min;
+    let mut total = 0;
+    for zone in zones {
+        if remaining == 0 {
+            out.push_str(&format!("  {}: skipped (budget exhausted)\n", zone.name));
+        } else if zone.minutes <= remaining {
+            out.push_str(&format!("  {}: {} min\n", zone.name, zone.minutes));
+            remaining -= zone.minutes;
+            total += zone.minutes;
+        } else {
+            out.push_str(&format!(
+                "  {}: {} min (cut from {})\n",
+                zone.name, remaining, zone.minutes
+            ));
+            total += remaining;
+            remaining = 0;
+        }
+    }
+    out.push_str(&format!("total: {} min\n", total));
+    out
+}
+
+/// Summarize validated zones for `irrplan check`.
+pub fn render_check(zones: &[ZoneSpec]) -> String {
+    let total: u32 = zones.iter().map(|z| z.minutes).sum();
+    format!("ok: {} zones, {} min total\n", zones.len(), total)
+}
diff --git a/src/main.rs b/src/main.rs
new file mode 100644
index 0000000..db1632e
--- /dev/null
+++ b/src/main.rs
@@ -0,0 +1,15 @@
+use clap::Parser;
+use rs_irrplan::{render_check, render_plan, Cli, Cmd};
+
+fn main() {
+    let cli = Cli::parse();
+    let out = match cli.command {
+        Cmd::Plan {
+            day,
+            budget_min,
+            zones,
+        } => render_plan(day, budget_min, &zones),
+        Cmd::Check { zones } => render_check(&zones),
+    };
+    print!("{out}");
+}
