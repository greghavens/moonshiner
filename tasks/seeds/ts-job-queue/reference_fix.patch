+export type BackoffOpts = {
+  baseMs?: number;
+  factor?: number;
+  maxMs?: number;
+};
+
+export function backoffDelay(attempt: number, opts: BackoffOpts = {}): number {
+  if (!Number.isInteger(attempt) || attempt < 1) {
+    throw new RangeError(`attempt must be an integer >= 1, got ${attempt}`);
+  }
+  const baseMs = opts.baseMs ?? 1000;
+  const factor = opts.factor ?? 2;
+  const maxMs = opts.maxMs ?? Infinity;
+  return Math.min(baseMs * factor ** (attempt - 1), maxMs);
+}
