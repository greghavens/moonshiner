+import type { BackoffOpts } from './backoff.ts';
+
+export type JobState = 'waiting' | 'active' | 'done' | 'dead';
+
+export type JobError = { attempt: number; reason: string; at: number };
+
+export type Job = {
+  id: string;
+  seq: number;
+  type: string;
+  payload: unknown;
+  state: JobState;
+  priority: number;
+  readyAt: number;
+  attempts: number;
+  maxAttempts: number;
+  backoff: BackoffOpts;
+  errors: JobError[];
+};
+
+export type JobSnapshot = {
+  id: string;
+  type: string;
+  payload: unknown;
+  state: JobState;
+  attempts: number;
+  priority: number;
+  readyAt: number;
+  errors: JobError[];
+};
+
+export function snapshot(job: Job): JobSnapshot {
+  return {
+    id: job.id,
+    type: job.type,
+    payload: job.payload,
+    state: job.state,
+    attempts: job.attempts,
+    priority: job.priority,
+    readyAt: job.readyAt,
+    errors: job.errors.map((e) => ({ ...e })),
+  };
+}
+
+/** Claim order: highest priority, then earliest readyAt, then enqueue order. */
+export function compareReady(a: Job, b: Job): number {
+  return (b.priority - a.priority) || (a.readyAt - b.readyAt) || (a.seq - b.seq);
+}
