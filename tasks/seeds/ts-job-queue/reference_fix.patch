index 0000000..6b2a58e
--- /dev/null
+++ b/queue.ts
@@ -0,0 +1,138 @@
+import { backoffDelay, type BackoffOpts } from './backoff.ts';
+import { compareReady, snapshot, type Job, type JobSnapshot } from './job.ts';
+
+export type EnqueueOpts = {
+  priority?: number;
+  delayMs?: number;
+  maxAttempts?: number;
+  backoff?: BackoffOpts;
+};
+
+export type ClaimedJob = { id: string; type: string; payload: unknown; attempt: number };
+
+export type DeadLetter = { id: string; type: string; payload: unknown; errors: Job['errors'] };
+
+export class JobQueue {
+  private clock: number;
+  private nextSeq = 1;
+  private jobs = new Map<string, Job>();
+  private dead: Job[] = [];
+
+  constructor(opts: { now?: number } = {}) {
+    this.clock = opts.now ?? 0;
+  }
+
+  now(): number {
+    return this.clock;
+  }
+
+  advance(ms: number): void {
+    if (!Number.isFinite(ms) || ms < 0) {
+      throw new RangeError(`advance() needs a non-negative number of ms, got ${ms}`);
+    }
+    this.clock += ms;
+  }
+
+  enqueue(type: string, payload: unknown = null, opts: EnqueueOpts = {}): string {
+    if (typeof type !== 'string' || type.trim() === '') {
+      throw new Error('job type must be a non-empty string');
+    }
+    const delayMs = opts.delayMs ?? 0;
+    if (!Number.isFinite(delayMs) || delayMs < 0) {
+      throw new RangeError(`delayMs must be non-negative, got ${delayMs}`);
+    }
+    const maxAttempts = opts.maxAttempts ?? 3;
+    if (!Number.isInteger(maxAttempts) || maxAttempts < 1) {
+      throw new RangeError(`maxAttempts must be an integer >= 1, got ${maxAttempts}`);
+    }
+    const seq = this.nextSeq++;
+    const job: Job = {
+      id: `job-${seq}`,
+      seq,
+      type,
+      payload,
+      state: 'waiting',
+      priority: opts.priority ?? 0,
+      readyAt: this.clock + delayMs,
+      attempts: 0,
+      maxAttempts,
+      backoff: opts.backoff ?? {},
+      errors: [],
+    };
+    this.jobs.set(job.id, job);
+    return job.id;
+  }
+
+  claim(): ClaimedJob | null {
+    let best: Job | null = null;
+    for (const job of this.jobs.values()) {
+      if (job.state !== 'waiting' || job.readyAt > this.clock) continue;
+      if (best === null || compareReady(job, best) < 0) best = job;
+    }
+    if (best === null) return null;
+    best.state = 'active';
+    best.attempts += 1;
+    return { id: best.id, type: best.type, payload: best.payload, attempt: best.attempts };
+  }
+
+  complete(id: string): void {
+    const job = this.mustBeActive(id);
+    job.state = 'done';
+  }
+
+  fail(id: string, reason: string): void {
+    const job = this.mustBeActive(id);
+    job.errors.push({ attempt: job.attempts, reason, at: this.clock });
+    if (job.attempts >= job.maxAttempts) {
+      job.state = 'dead';
+      this.dead.push(job);
+    } else {
+      job.state = 'waiting';
+      job.readyAt = this.clock + backoffDelay(job.attempts, job.backoff);
+    }
+  }
+
+  requeue(id: string): void {
+    const job = this.mustExist(id);
+    if (job.state !== 'dead') {
+      throw new Error(`job ${id} is not dead`);
+    }
+    this.dead.splice(this.dead.indexOf(job), 1);
+    job.state = 'waiting';
+    job.attempts = 0;
+    job.readyAt = this.clock;
+  }
+
+  job(id: string): JobSnapshot {
+    return snapshot(this.mustExist(id));
+  }
+
+  deadLetters(): DeadLetter[] {
+    return this.dead.map((job) => ({
+      id: job.id,
+      type: job.type,
+      payload: job.payload,
+      errors: job.errors.map((e) => ({ ...e })),
+    }));
+  }
+
+  stats(): { waiting: number; active: number; done: number; dead: number } {
+    const counts = { waiting: 0, active: 0, done: 0, dead: 0 };
+    for (const job of this.jobs.values()) counts[job.state] += 1;
+    return counts;
+  }
+
+  private mustExist(id: string): Job {
+    const job = this.jobs.get(id);
+    if (!job) throw new Error(`unknown job ${id}`);
+    return job;
+  }
+
+  private mustBeActive(id: string): Job {
+    const job = this.mustExist(id);
+    if (job.state !== 'active') {
+      throw new Error(`job ${id} is not active (state: ${job.state})`);
+    }
+    return job;
+  }
+}
