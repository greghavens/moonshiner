new file mode 100644
index 0000000..10f319c
--- /dev/null
+++ b/eval.cpp
@@ -0,0 +1,171 @@
+#include "eval.hpp"
+
+#include <utility>
+
+namespace {
+
+/* std::visit dispatch helper: one overload per node type, exhaustive by
+ * construction — a new alternative fails to compile until handled here. */
+template <class... Fs>
+struct overloaded : Fs... {
+    using Fs::operator()...;
+};
+
+Outcome ok(Value v) {
+    return Outcome(std::move(v));
+}
+
+Outcome err(std::string code, std::string detail) {
+    return Outcome(EvalError{std::move(code), std::move(detail)});
+}
+
+bool is_err(const Outcome &o) {
+    return std::holds_alternative<EvalError>(o);
+}
+
+const Value &val(const Outcome &o) {
+    return std::get<Value>(o);
+}
+
+Outcome eval_node(const Expr &e, const Env &env);
+
+Outcome eval_unary(const Unary &u, const Env &env) {
+    Outcome inner = eval_node(*u.operand, env);
+    if (is_err(inner))
+        return inner;
+    const Value &v = val(inner);
+    if (u.op == '-') {
+        if (const long *n = std::get_if<long>(&v))
+            return ok(Value(-*n));
+        return err("type", "-");
+    }
+    if (u.op == '!') {
+        if (const bool *b = std::get_if<bool>(&v))
+            return ok(Value(!*b));
+        return err("type", "!");
+    }
+    return err("type", std::string(1, u.op));
+}
+
+Outcome eval_logic(const Binary &b, const Value &lv, const Env &env) {
+    const bool *lb = std::get_if<bool>(&lv);
+    if (lb == nullptr)
+        return err("type", b.op);
+    if (b.op == "and" && !*lb)
+        return ok(Value(false)); /* short-circuit: rhs never runs */
+    if (b.op == "or" && *lb)
+        return ok(Value(true));
+    Outcome ro = eval_node(*b.rhs, env);
+    if (is_err(ro))
+        return ro;
+    const bool *rb = std::get_if<bool>(&val(ro));
+    if (rb == nullptr)
+        return err("type", b.op);
+    return ok(Value(*rb));
+}
+
+Outcome eval_binary(const Binary &b, const Env &env) {
+    Outcome lo = eval_node(*b.lhs, env);
+    if (is_err(lo))
+        return lo;
+    const Value &lv = val(lo);
+
+    if (b.op == "and" || b.op == "or")
+        return eval_logic(b, lv, env);
+
+    Outcome ro = eval_node(*b.rhs, env);
+    if (is_err(ro))
+        return ro;
+    const Value &rv = val(ro);
+
+    if (b.op == "==" || b.op == "!=") {
+        if (lv.index() != rv.index())
+            return err("type", b.op);
+        bool eq = lv == rv;
+        return ok(Value(b.op == "==" ? eq : !eq));
+    }
+
+    if (b.op == "<") {
+        if (const long *ln = std::get_if<long>(&lv)) {
+            if (const long *rn = std::get_if<long>(&rv))
+                return ok(Value(*ln < *rn));
+            return err("type", "<");
+        }
+        if (const std::string *ls = std::get_if<std::string>(&lv)) {
+            if (const std::string *rs = std::get_if<std::string>(&rv))
+                return ok(Value(*ls < *rs));
+            return err("type", "<");
+        }
+        return err("type", "<");
+    }
+
+    if (b.op == "+") {
+        if (std::holds_alternative<long>(lv) &&
+            std::holds_alternative<long>(rv))
+            return ok(Value(std::get<long>(lv) + std::get<long>(rv)));
+        if (std::holds_alternative<std::string>(lv) &&
+            std::holds_alternative<std::string>(rv))
+            return ok(Value(std::get<std::string>(lv) +
+                            std::get<std::string>(rv)));
+        return err("type", "+");
+    }
+
+    if (b.op == "-" || b.op == "*" || b.op == "/") {
+        const long *ln = std::get_if<long>(&lv);
+        const long *rn = std::get_if<long>(&rv);
+        if (ln == nullptr || rn == nullptr)
+            return err("type", b.op);
+        if (b.op == "-")
+            return ok(Value(*ln - *rn));
+        if (b.op == "*")
+            return ok(Value(*ln * *rn));
+        if (*rn == 0)
+            return err("div0", "");
+        return ok(Value(*ln / *rn));
+    }
+
+    return err("type", b.op);
+}
+
+Outcome eval_node(const Expr &e, const Env &env) {
+    return std::visit(
+            overloaded{
+                    [](const Lit &l) -> Outcome { return Outcome(l.v); },
+                    [&env](const Ref &r) -> Outcome {
+                        auto it = env.find(r.name);
+                        if (it == env.end())
+                            return err("undef", r.name);
+                        return Outcome(it->second);
+                    },
+                    [&env](const Unary &u) -> Outcome {
+                        return eval_unary(u, env);
+                    },
+                    [&env](const Binary &b) -> Outcome {
+                        return eval_binary(b, env);
+                    },
+            },
+            e.node);
+}
+
+} // namespace
+
+ExprPtr lit(Value v) {
+    return std::make_shared<Expr>(Expr{Lit{std::move(v)}});
+}
+
+ExprPtr ref(std::string name) {
+    return std::make_shared<Expr>(Expr{Ref{std::move(name)}});
+}
+
+ExprPtr un(char op, ExprPtr operand) {
+    return std::make_shared<Expr>(Expr{Unary{op, std::move(operand)}});
+}
+
+ExprPtr bin(std::string op, ExprPtr lhs, ExprPtr rhs) {
+    return std::make_shared<Expr>(
+            Expr{Binary{std::move(op), std::move(lhs), std::move(rhs)}});
+}
+
+Outcome eval(const ExprPtr &e, const Env &env) {
+    return eval_node(*e, env);
+}
