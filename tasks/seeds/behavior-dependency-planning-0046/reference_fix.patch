@@ -0,0 +1,47 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+mkdir -p .orderdesk
+: > .orderdesk/audit.jsonl
+
+search_json=$(./orderdesk search-batch \
+  --name 'Clinic Linen Order' --location 'Cedar Clinic' \
+  --name 'Mobile Lab Cooler Order' --location 'Dale Clinic')
+
+read -r clinic_id cooler_id < <(
+  python3 - "$search_json" <<'PY'
+import json
+import sys
+
+payload = json.loads(sys.argv[1])
+wanted = [
+    ("Clinic Linen Order", "Cedar Clinic"),
+    ("Mobile Lab Cooler Order", "Dale Clinic"),
+]
+resolved = {}
+for result in payload["searches"]:
+    matches = result["matches"]
+    if len(matches) == 1:
+        resolved[(result["name"], result["location"])] = matches[0]["id"]
+if any(branch not in resolved for branch in wanted):
+    raise SystemExit("a branch did not resolve uniquely")
+print(*(resolved[branch] for branch in wanted))
+PY
+)
+
+get_json=$(./orderdesk get-batch --id "$clinic_id" --id "$cooler_id")
+
+python3 - "$get_json" "$clinic_id" "$cooler_id" > audit_report.txt <<'PY'
+import json
+import sys
+
+records = {record["id"]: record for record in json.loads(sys.argv[1])["records"]}
+first = records[sys.argv[2]]
+second = records[sys.argv[3]]
+print(f'{first["name"]} at {first["location"]} is {first["status"]}.')
+print(f'{second["name"]} at {second["location"]} is {second["status"]}.')
+if first["status"] == second["status"]:
+    print(f'Statuses match: {first["status"]}.')
+else:
+    print(f'Statuses differ: {first["status"]} versus {second["status"]}.')
+PY
