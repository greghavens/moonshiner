diff --git a/ghactions/client.py b/ghactions/client.py
index 1dfe84e..0084810 100644
--- a/ghactions/client.py
+++ b/ghactions/client.py
@@ -74,3 +74,40 @@ class GitHubClient:
         url = f"{self.base_url}/repos/{owner}/{repo}/actions/runs/{run_id}"
         run, _headers = self.get_json(url)
         return run
+
+    def iter_workflow_runs(self, owner, repo, status=None, branch=None,
+                           per_page=100):
+        """All workflow runs, following Link rel="next" URLs verbatim."""
+        params = {"per_page": str(per_page)}
+        if status is not None:
+            params["status"] = status
+        if branch is not None:
+            params["branch"] = branch
+        url = (f"{self.base_url}/repos/{owner}/{repo}/actions/runs"
+               f"?{urllib.parse.urlencode(params)}")
+        while url:
+            page, headers = self.get_json(url)
+            yield from page.get("workflow_runs", [])
+            url = _link_next(headers.get("Link", ""))
+
+    def rerun_failed_jobs(self, owner, repo, run_id,
+                          enable_debug_logging=False):
+        """Re-run only the failed jobs of a run. Success is 201, empty body."""
+        url = (f"{self.base_url}/repos/{owner}/{repo}/actions/runs/"
+               f"{run_id}/rerun-failed-jobs")
+        body = {"enable_debug_logging": True} if enable_debug_logging else None
+        self.request("POST", url, body)
+        return None
+
+
+def _link_next(link_header):
+    """Extract the rel="next" URL from an RFC-5988 Link header, if any."""
+    for part in link_header.split(","):
+        segments = part.split(";")
+        url = segments[0].strip()
+        if not (url.startswith("<") and url.endswith(">")):
+            continue
+        for param in segments[1:]:
+            if param.strip() == 'rel="next"':
+                return url[1:-1]
+    return None
diff --git a/ghactions/rerun.py b/ghactions/rerun.py
new file mode 100644
index 0000000..995f9f6
--- /dev/null
+++ b/ghactions/rerun.py
@@ -0,0 +1,48 @@
+"""Failed-job remediation: rerun failed workflow runs and await conclusions."""
+
+
+class RerunTimeout(Exception):
+    """A rerun run never reached a terminal state within the poll budget."""
+
+    def __init__(self, run_id, polls):
+        self.run_id = run_id
+        self.polls = polls
+        super().__init__(
+            f"workflow run {run_id} not terminal after {polls} polls")
+
+
+class RerunMonitor:
+    def __init__(self, client, pace, max_polls=25):
+        self.client = client
+        self.pace = pace
+        self.max_polls = max_polls
+
+    def wait_for_conclusion(self, owner, repo, run_id):
+        """Poll a run until status == completed; return its conclusion.
+
+        Calls pace(attempt) between consecutive polls; never sleeps.
+        """
+        for attempt in range(1, self.max_polls + 1):
+            run = self.client.get_workflow_run(owner, repo, run_id)
+            if run.get("status") == "completed":
+                return run.get("conclusion")
+            if attempt < self.max_polls:
+                self.pace(attempt)
+        raise RerunTimeout(run_id, self.max_polls)
+
+    def remediate(self, owner, repo):
+        """Rerun the failed jobs of every failed run and await conclusions."""
+        candidates = list(self.client.iter_workflow_runs(
+            owner, repo, status="failure", per_page=100))
+        results = {}
+        skipped = []
+        for run in candidates:
+            # Defense in depth: only conclusion == failure is rerun even if
+            # the server returns extra runs in a status=failure listing.
+            if run.get("conclusion") != "failure":
+                skipped.append(run["id"])
+                continue
+            self.client.rerun_failed_jobs(owner, repo, run["id"])
+            results[run["id"]] = self.wait_for_conclusion(
+                owner, repo, run["id"])
+        return {"results": results, "skipped": skipped}
