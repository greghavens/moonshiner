+"""Loading and parsing wiki source pages."""
+import os
+import re
+
+LINK = re.compile(r"\[\[([^\]|]+)(?:\|([^\]]+))?\]\]")
+_SLUG_JUNK = re.compile(r"[^a-z0-9]+")
+
+
+class PageError(Exception):
+    pass
+
+
+class Page:
+    def __init__(self, slug, title, paragraphs):
+        self.slug = slug
+        self.title = title
+        self.paragraphs = paragraphs  # list of paragraph strings (lines joined)
+
+    def links(self):
+        """Every wikilink in the page as (target_as_written, display) pairs."""
+        found = []
+        for para in self.paragraphs:
+            for m in LINK.finditer(para):
+                target = m.group(1).strip()
+                display = (m.group(2) or m.group(1)).strip()
+                found.append((target, display))
+        return found
+
+
+def slugify(name):
+    return _SLUG_JUNK.sub("-", name.lower()).strip("-")
+
+
+def parse_page(slug, text, filename):
+    lines = text.splitlines()
+    if not lines or not lines[0].startswith("# "):
+        raise PageError(f"{filename}: first line must be a '# Title' heading")
+    title = lines[0][2:].strip()
+    paragraphs = []
+    current = []
+    for line in lines[1:]:
+        if line.strip() == "":
+            if current:
+                paragraphs.append(" ".join(current))
+                current = []
+        else:
+            current.append(line.strip())
+    if current:
+        paragraphs.append(" ".join(current))
+    return Page(slug, title, paragraphs)
+
+
+def load_wiki(srcdir):
+    """Parse every .md page in srcdir. Returns {slug: Page}."""
+    pages = {}
+    for name in sorted(os.listdir(srcdir)):
+        if not name.endswith(".md"):
+            continue
+        slug = slugify(os.path.splitext(name)[0])
+        with open(os.path.join(srcdir, name)) as f:
+            pages[slug] = parse_page(slug, f.read(), name)
+    return pages
