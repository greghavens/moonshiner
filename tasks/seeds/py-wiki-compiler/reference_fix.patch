+"""HTML rendering for wiki pages, backlinks, and the index."""
+import html
+
+from wikipages import LINK
+from wikigraph import resolve
+
+
+def render_paragraph(pages, text):
+    """Escape text and turn wikilinks into anchors/missing spans."""
+    parts = []
+    pos = 0
+    for m in LINK.finditer(text):
+        parts.append(html.escape(text[pos:m.start()]))
+        target = m.group(1).strip()
+        display = html.escape((m.group(2) or m.group(1)).strip())
+        slug = resolve(pages, target)
+        if slug is None:
+            parts.append(f'<span class="missing">{display}</span>')
+        else:
+            parts.append(f'<a href="{slug}.html">{display}</a>')
+        pos = m.end()
+    parts.append(html.escape(text[pos:]))
+    return "".join(parts)
+
+
+def render_page(pages, page, incoming):
+    out = [f"<h1>{html.escape(page.title)}</h1>"]
+    for para in page.paragraphs:
+        out.append(f"<p>{render_paragraph(pages, para)}</p>")
+    if incoming:
+        out.append("<h2>Backlinks</h2>")
+        out.append("<ul>")
+        for src in sorted(incoming, key=lambda s: pages[s].title):
+            title = html.escape(pages[src].title)
+            out.append(f'<li><a href="{src}.html">{title}</a></li>')
+        out.append("</ul>")
+    return "\n".join(out) + "\n"
+
+
+def render_index(pages):
+    out = ["<h1>Index</h1>", "<ul>"]
+    for slug in sorted(pages, key=lambda s: pages[s].title):
+        title = html.escape(pages[slug].title)
+        out.append(f'<li><a href="{slug}.html">{title}</a></li>')
+    out.append("</ul>")
+    return "\n".join(out) + "\n"
