+"""Link resolution and the wiki link graph."""
+from wikipages import slugify
+
+HOME_SLUG = "home"
+
+
+def resolve(pages, target):
+    """Map a wikilink target (as written) to a page slug, or None."""
+    slug = slugify(target)
+    return slug if slug in pages else None
+
+
+def link_graph(pages):
+    """Compute incoming links and broken links.
+
+    Returns (backlinks, broken) where backlinks maps slug -> sorted set of
+    slugs of OTHER pages linking to it (deduplicated), and broken is a
+    sorted list of (source_slug, target_as_written).
+    """
+    backlinks = {slug: set() for slug in pages}
+    broken = set()
+    for slug, page in pages.items():
+        for target, _display in page.links():
+            resolved = resolve(pages, target)
+            if resolved is None:
+                broken.add((slug, target))
+            elif resolved != slug:
+                backlinks[resolved].add(slug)
+    return backlinks, sorted(broken)
+
+
+def orphans(pages, backlinks):
+    """Slugs with no incoming links, excluding the home page."""
+    return sorted(slug for slug, sources in backlinks.items()
+                  if not sources and slug != HOME_SLUG)
