+#!/usr/bin/env python3
+"""Wiki compiler.
+
+    python3 wikic.py build <srcdir> <outdir>
+    python3 wikic.py check <srcdir>
+"""
+import argparse
+import os
+import sys
+
+from wikipages import PageError, load_wiki
+from wikigraph import link_graph, orphans
+from wikirender import render_index, render_page
+
+
+def cmd_build(srcdir, outdir):
+    pages = load_wiki(srcdir)
+    backlinks, _broken = link_graph(pages)
+    os.makedirs(outdir, exist_ok=True)
+    for slug in sorted(pages):
+        html_text = render_page(pages, pages[slug], backlinks[slug])
+        with open(os.path.join(outdir, slug + ".html"), "w") as f:
+            f.write(html_text)
+    with open(os.path.join(outdir, "index.html"), "w") as f:
+        f.write(render_index(pages))
+    return 0
+
+
+def cmd_check(srcdir):
+    pages = load_wiki(srcdir)
+    backlinks, broken = link_graph(pages)
+    findings = [f"broken: {src} -> {target}" for src, target in broken]
+    findings += [f"orphan: {slug}" for slug in orphans(pages, backlinks)]
+    if findings:
+        print("\n".join(findings))
+        return 1
+    print("ok")
+    return 0
+
+
+def main():
+    parser = argparse.ArgumentParser(prog="wikic.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+    p_build = sub.add_parser("build")
+    p_build.add_argument("srcdir")
+    p_build.add_argument("outdir")
+    p_check = sub.add_parser("check")
+    p_check.add_argument("srcdir")
+    args = parser.parse_args()
+
+    if not os.path.isdir(args.srcdir):
+        print(f"error: source directory not found: {args.srcdir}", file=sys.stderr)
+        return 2
+    try:
+        if args.command == "build":
+            return cmd_build(args.srcdir, args.outdir)
+        return cmd_check(args.srcdir)
+    except PageError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+
+
+if __name__ == "__main__":
+    sys.exit(main())
