index 0000000..1a80ea9
--- /dev/null
+++ b/SystemLogExporter.cs
@@ -0,0 +1,67 @@
+namespace OktaSyslog;
+
+/// <summary>
+/// Checkpointed System Log sweep. Issues the documented polling query
+/// (ASCENDING, no until), resumes from the stored after cursor, follows the
+/// server's next links verbatim, dedupes by event uuid, and advances the
+/// checkpoint for a page only after that page has been fully delivered — a
+/// delivery failure leaves the checkpoint on the last good page so the next
+/// sweep refetches exactly the failed page.
+/// </summary>
+public sealed class SystemLogExporter
+{
+    private readonly SystemLogClient _client;
+    private readonly Func<string?> _loadCursor;
+    private readonly Action<string> _saveCursor;
+    private readonly Func<IReadOnlyList<LogEvent>, Task> _deliver;
+
+    public SystemLogExporter(
+        SystemLogClient client,
+        Func<string?> loadCursor,
+        Action<string> saveCursor,
+        Func<IReadOnlyList<LogEvent>, Task> deliver)
+    {
+        _client = client;
+        _loadCursor = loadCursor;
+        _saveCursor = saveCursor;
+        _deliver = deliver;
+    }
+
+    public async Task<SweepReport> RunSweepAsync(string since, string filter, int limit)
+    {
+        string url = $"/api/v1/logs?since={Uri.EscapeDataString(since)}"
+                     + $"&filter={Uri.EscapeDataString(filter)}"
+                     + $"&limit={limit}&sortOrder=ASCENDING";
+        if (_loadCursor() is string cursor)
+            url += "&after=" + Uri.EscapeDataString(cursor);
+
+        var seen = new HashSet<string>(StringComparer.Ordinal);
+        int pages = 0, delivered = 0, duplicates = 0;
+
+        while (true)
+        {
+            LogPage page = await _client.FetchPageAsync(url);
+            if (page.Events.Count == 0) break;
+
+            var fresh = new List<LogEvent>();
+            foreach (LogEvent e in page.Events)
+            {
+                if (seen.Add(e.Uuid)) fresh.Add(e);
+                else duplicates++;
+            }
+
+            if (fresh.Count > 0)
+            {
+                await _deliver(fresh);
+                pages++;
+                delivered += fresh.Count;
+                if (page.NextAfter is string after) _saveCursor(after);
+            }
+
+            if (page.NextUrl is null) break;
+            url = page.NextUrl;
+        }
+
+        return new SweepReport(pages, delivered, duplicates);
+    }
+}
