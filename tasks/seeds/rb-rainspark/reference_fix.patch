+# Terminal charts for rain-gauge series: unicode sparklines and labeled
+# histograms with deterministic scaling and rounding.
+module RainReport
+  BARS = %w[▁ ▂ ▃ ▄ ▅ ▆ ▇ █].freeze
+
+  module_function
+
+  def sparkline(values)
+    return "" if values.empty?
+    min, max = values.minmax
+    span = max - min
+    values.map do |v|
+      level = span.zero? ? 0 : ((v - min) * 7.0 / span).round
+      BARS[level]
+    end.join
+  end
+
+  def histogram(values, buckets:, width:)
+    raise ArgumentError, "no data" if values.empty?
+    raise ArgumentError, "buckets must be >= 1, got #{buckets}" if buckets < 1
+    raise ArgumentError, "width must be >= 1, got #{width}" if width < 1
+
+    lo, hi = values.minmax
+    span = hi - lo
+    counts = Array.new(buckets, 0)
+    values.each do |v|
+      index = span.zero? ? 0 : [((v - lo) * buckets / span.to_f).floor, buckets - 1].min
+      counts[index] += 1
+    end
+
+    bounds = (0..buckets).map { |i| lo + span * i / buckets.to_f }
+    labels = (0...buckets).map { |i| format("%.1f..%.1f", bounds[i], bounds[i + 1]) }
+    label_width = labels.map(&:length).max
+    max_count = counts.max
+
+    (0...buckets).map do |i|
+      bar_length =
+        if counts[i].zero?
+          0
+        else
+          [(counts[i] * width / max_count.to_f).round, 1].max
+        end
+      "#{labels[i].rjust(label_width)} |#{BARS.last * bar_length} #{counts[i]}"
+    end.join("\n")
+  end
+end
