+#pragma once
+
+#include <cstddef>
+#include <iterator>
+#include <memory>
+#include <utility>
+
+/* A tiny non-owning, non-allocating filter view over [first, last).
+ * Unlike std::ranges::views::filter it never caches begin() and is fully
+ * const-iterable, so panels can share views by const reference. */
+
+template <class It, class Pred>
+class FilterView {
+public:
+    class iterator {
+    public:
+        using iterator_category = std::forward_iterator_tag;
+        using value_type = typename std::iterator_traits<It>::value_type;
+        using difference_type = std::ptrdiff_t;
+        using reference = typename std::iterator_traits<It>::reference;
+        using pointer = typename std::iterator_traits<It>::pointer;
+
+        iterator() = default;
+
+        reference operator*() const { return *cur_; }
+        pointer operator->() const { return std::addressof(*cur_); }
+
+        iterator &operator++() {
+            ++cur_;
+            settle();
+            return *this;
+        }
+
+        iterator operator++(int) {
+            iterator old = *this;
+            ++*this;
+            return old;
+        }
+
+        bool operator==(const iterator &other) const {
+            if (view_ == nullptr && other.view_ == nullptr)
+                return true; /* default-constructed iterators are equal */
+            return cur_ == other.cur_;
+        }
+
+    private:
+        friend class FilterView;
+
+        iterator(const FilterView *view, It cur) : view_(view), cur_(cur) {
+            settle();
+        }
+
+        /* Walk forward to the next element the predicate accepts. */
+        void settle() {
+            while (cur_ != view_->last_ && !view_->pred_(*cur_))
+                ++cur_;
+        }
+
+        const FilterView *view_ = nullptr;
+        It cur_{};
+    };
+
+    FilterView(It first, It last, Pred pred)
+        : first_(first), last_(last), pred_(std::move(pred)) {}
+
+    iterator begin() const { return iterator(this, first_); }
+    iterator end() const { return iterator(this, last_); }
+    bool empty() const { return begin() == end(); }
+
+private:
+    It first_;
+    It last_;
+    Pred pred_;
+};
+
+template <class C, class Pred>
+FilterView<typename C::const_iterator, Pred> filtered(const C &c, Pred pred) {
+    return FilterView<typename C::const_iterator, Pred>(c.begin(), c.end(),
+                                                        std::move(pred));
+}
