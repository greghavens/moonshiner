+#!/usr/bin/env python3
+"""Reference proof using the genuine message executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import multiprocessing
+import subprocess
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Storm Closure Advisory", "Campus Operations"),
+    ("Library Hours Correction", "Student Services"),
+)
+
+
+def run_direct_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Start every direct client process before collecting any response."""
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "message operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("message operation returned an invalid payload")
+        payloads.append(payload)
+    return payloads
+
+
+def phase_worker(sender: Any, commands: list[list[str]]) -> None:
+    """Execute one phase under a parent dedicated to that shell-tool action."""
+    try:
+        sender.send({"payloads": run_direct_phase(commands)})
+    except Exception as error:
+        sender.send({"error": str(error)})
+    finally:
+        sender.close()
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Give each dependency phase a distinct process parent."""
+    context = multiprocessing.get_context("spawn")
+    receiver, sender = context.Pipe(duplex=False)
+    process = context.Process(target=phase_worker, args=(sender, commands))
+    process.start()
+    sender.close()
+    process.join()
+    if process.exitcode != 0:
+        raise RuntimeError("message phase worker failed")
+    try:
+        outcome = receiver.recv()
+    except EOFError as error:
+        raise RuntimeError("message phase worker returned no result") from error
+    finally:
+        receiver.close()
+    if "error" in outcome:
+        raise RuntimeError(outcome["error"])
+    payloads = outcome.get("payloads")
+    if not isinstance(payloads, list):
+        raise RuntimeError("message phase worker returned an invalid result")
+    return payloads
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./messagectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        stable_id = matches[0].get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./messagectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    rendered: list[str] = []
+    for (name, location), record in zip(TARGETS, retrieved, strict=True):
+        if record is None:
+            rendered.append(
+                f"{name} | UNRESOLVED | {location} | UNRESOLVED | UNRESOLVED"
+            )
+            continue
+        rendered.append(
+            f"{record['name']} | {record['id']} | {record['location']} | "
+            f"{record['date']} | {record['status']}"
+        )
+
+    if retrieved[0] is None or retrieved[1] is None:
+        rendered.append("Status comparison: unavailable.")
+    elif retrieved[0]["status"] == retrieved[1]["status"]:
+        rendered.append(f"Status comparison: same ({retrieved[0]['status']}).")
+    else:
+        rendered.append(
+            "Status comparison: different "
+            f"({retrieved[0]['status']} vs {retrieved[1]['status']})."
+        )
+
+    (ROOT / "message-audit.txt").write_text(
+        "\n".join(rendered) + "\n",
+        encoding="utf-8",
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
