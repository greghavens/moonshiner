+#!/usr/bin/env python3
+"""Produce the reference brief through genuine two-stage order execution."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import subprocess
+import sys
+
+
+ROOT = Path(__file__).resolve().parent
+CLIENT = ROOT / "order_desk.py"
+TARGETS = (
+    ("Ergonomic Chair Order", "Boise Office"),
+    ("New-Hire Welcome Kit Order", "Phoenix Branch"),
+)
+
+
+def run_parallel(commands: list[list[str]]) -> list[dict]:
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    results = []
+    for process in processes:
+        stdout, stderr = process.communicate()
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "order command failed")
+        results.append(json.loads(stdout))
+    return results
+
+
+def stage_search() -> int:
+    commands = [
+        [
+            sys.executable,
+            str(CLIENT),
+            "search",
+            "--name",
+            name,
+            "--location",
+            location,
+        ]
+        for name, location in TARGETS
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def stage_get(stable_ids: list[str]) -> int:
+    commands = [
+        [sys.executable, str(CLIENT), "get", "--id", stable_id]
+        for stable_id in stable_ids
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def orchestrate() -> int:
+    search = subprocess.run(
+        [sys.executable, str(Path(__file__).resolve()), "stage-search"],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    search_results = json.loads(search.stdout)
+    stable_ids = []
+    for target, result in zip(TARGETS, search_results, strict=True):
+        matches = result.get("matches", [])
+        if result.get("count") != 1 or len(matches) != 1:
+            raise RuntimeError(f"reference branch is not unique: {target!r}")
+        stable_ids.append(matches[0]["id"])
+
+    get = subprocess.run(
+        [
+            sys.executable,
+            str(Path(__file__).resolve()),
+            "stage-get",
+            *stable_ids,
+        ],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    records = json.loads(get.stdout)
+    first, second = records
+    lines = [
+        f"- {first['name']} at {first['location']} has status {first['status']}.",
+        f"- {second['name']} at {second['location']} has status {second['status']}.",
+    ]
+    if first["status"] == second["status"]:
+        lines[1] += f" Statuses match: {first['status']}."
+    else:
+        lines[1] += (
+            f" Statuses differ: {first['status']} versus {second['status']}."
+        )
+    (ROOT / "fulfillment-brief.md").write_text(
+        "\n".join(lines) + "\n", encoding="utf-8"
+    )
+    return 0
+
+
+def main() -> int:
+    if len(sys.argv) == 1:
+        return orchestrate()
+    if sys.argv[1:] == ["stage-search"]:
+        return stage_search()
+    if len(sys.argv) == 4 and sys.argv[1] == "stage-get":
+        return stage_get(sys.argv[2:])
+    raise SystemExit("invalid reference setup invocation")
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
