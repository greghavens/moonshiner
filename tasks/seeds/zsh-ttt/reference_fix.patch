diff --git a/ttt.zsh b/ttt.zsh
new file mode 100644
index 0000000..b1441b7
--- /dev/null
+++ b/ttt.zsh
@@ -0,0 +1,65 @@
+#!/usr/bin/env zsh
+# ttt.zsh — rule-enforcing tic-tac-toe over stdin move lines.
+emulate -L zsh
+setopt no_unset
+
+if (( $# != 0 )); then
+  print -r -- 'usage: ttt.zsh' >&2
+  exit 2
+fi
+
+typeset -A board=()
+typeset player=X raw move
+integer filled=0
+
+render() {
+  print -r -- '  1 2 3'
+  local r c line
+  for r in a b c; do
+    line=$r
+    for c in 1 2 3; do
+      line+=" ${board[$r$c]:-.}"
+    done
+    print -r -- "$line"
+  done
+}
+
+wins() { # wins <player>
+  local p=$1 ln
+  local -a lines=(a1a2a3 b1b2b3 c1c2c3 a1b1c1 a2b2c2 a3b3c3 a1b2c3 a3b2c1)
+  for ln in "$lines[@]"; do
+    if [[ ${board[${ln[1,2]}]:-} == "$p" && ${board[${ln[3,4]}]:-} == "$p" \
+          && ${board[${ln[5,6]}]:-} == "$p" ]]; then
+      return 0
+    fi
+  done
+  return 1
+}
+
+while IFS= read -r raw; do
+  [[ -z $raw ]] && continue
+  move=${(L)raw}
+  if [[ $move != [abc][123] ]]; then
+    print -r -- "invalid move: $raw"
+    continue
+  fi
+  if [[ -n ${board[$move]:-} ]]; then
+    print -r -- "square $move is taken"
+    continue
+  fi
+  board[$move]=$player
+  (( filled++ ))
+  print -r -- "$player plays $move"
+  render
+  if wins "$player"; then
+    print -r -- "$player wins"
+    exit 0
+  fi
+  if (( filled == 9 )); then
+    print -r -- draw
+    exit 0
+  fi
+  if [[ $player == X ]]; then player=O; else player=X; fi
+done
+print -r -- 'game aborted'
+exit 1
