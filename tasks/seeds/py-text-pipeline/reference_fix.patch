+#!/usr/bin/env python3
+"""Config-driven text pipeline CLI.
+
+    python3 textpipe.py --config cfg.json [--plugins extra.py] [--dry-run] FILE...
+"""
+import argparse
+import difflib
+import importlib.util
+import json
+import os
+import sys
+
+import pipeline  # noqa: F401  (registers built-ins)
+from pipeline import engine, registry
+
+
+class ConfigError(Exception):
+    pass
+
+
+def load_config(path):
+    try:
+        with open(path) as f:
+            config = json.load(f)
+    except (OSError, ValueError) as e:
+        raise ConfigError(f"cannot read config {path}: {e}")
+    steps = config.get("steps")
+    if not isinstance(steps, list):
+        raise ConfigError(f"config {path} must contain a 'steps' list")
+    return steps
+
+
+def load_extra_plugins(path):
+    try:
+        spec = importlib.util.spec_from_file_location("textpipe_extra", path)
+        module = importlib.util.module_from_spec(spec)
+        spec.loader.exec_module(module)
+    except FileNotFoundError as e:
+        raise ConfigError(f"cannot load plugins file {path}: {e}")
+
+
+def validate_steps(steps):
+    """Fail fast on unknown plugins/options, before any file is touched."""
+    for step in steps:
+        name = step.get("plugin")
+        try:
+            registry.get(name)
+            engine.resolve_options(name, step.get("options"))
+        except (LookupError, ValueError) as e:
+            raise ConfigError(str(e))
+
+
+def main():
+    parser = argparse.ArgumentParser(prog="textpipe.py")
+    parser.add_argument("--config", required=True)
+    parser.add_argument("--plugins")
+    parser.add_argument("--dry-run", action="store_true")
+    parser.add_argument("files", nargs="+")
+    args = parser.parse_args()
+
+    try:
+        if args.plugins:
+            load_extra_plugins(args.plugins)
+        steps = load_config(args.config)
+        validate_steps(steps)
+        missing = [p for p in args.files if not os.path.isfile(p)]
+        if missing:
+            raise ConfigError(f"input file not found: {', '.join(missing)}")
+        originals = {}
+        for path in args.files:
+            with open(path) as f:
+                originals[path] = f.read()
+        results = {p: engine.apply(text, steps) for p, text in originals.items()}
+    except ConfigError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 2
+
+    if args.dry_run:
+        changed = False
+        for path in args.files:
+            if results[path] == originals[path]:
+                continue
+            changed = True
+            diff = difflib.unified_diff(
+                originals[path].splitlines(keepends=True),
+                results[path].splitlines(keepends=True),
+                fromfile="a/" + path, tofile="b/" + path)
+            sys.stdout.writelines(diff)
+        return 1 if changed else 0
+
+    for path in args.files:
+        if results[path] == originals[path]:
+            print(f"ok {path}")
+        else:
+            with open(path, "w") as f:
+                f.write(results[path])
+            print(f"rewrote {path}")
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
