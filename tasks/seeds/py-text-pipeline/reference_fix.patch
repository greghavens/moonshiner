+"""Pipeline execution: run configured steps over text."""
+from pipeline import registry
+
+
+def resolve_options(name, supplied):
+    """Merge supplied options over the plugin's declared defaults."""
+    merged = registry.option_defaults(name)
+    for key, value in (supplied or {}).items():
+        if key not in merged:
+            raise ValueError(f"plugin {name!r} does not take option {key!r}")
+        merged[key] = value
+    return merged
+
+
+def apply(text, steps):
+    """Run steps (in list order) over text and return the result."""
+    for step in steps:
+        name = step["plugin"]
+        func = registry.get(name)
+        options = resolve_options(name, step.get("options"))
+        text = func(text, **options)
+    return text
