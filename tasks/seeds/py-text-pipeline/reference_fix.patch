+"""Built-in text plugins."""
+from pipeline.registry import register
+
+
+def _split_keep_trailing(text):
+    """Split into lines plus a flag for a trailing newline."""
+    ends_with_newline = text.endswith("\n")
+    lines = text.split("\n")
+    if ends_with_newline:
+        lines = lines[:-1]
+    return lines, ends_with_newline
+
+
+def _join(lines, ends_with_newline):
+    out = "\n".join(lines)
+    return out + "\n" if ends_with_newline else out
+
+
+@register("strip_trailing")
+def strip_trailing(text):
+    lines, nl = _split_keep_trailing(text)
+    return _join([line.rstrip(" \t") for line in lines], nl)
+
+
+@register("tabs_to_spaces", options={"width": 4})
+def tabs_to_spaces(text, width):
+    lines, nl = _split_keep_trailing(text)
+    return _join([line.expandtabs(width) for line in lines], nl)
+
+
+@register("squeeze_blanks", options={"max": 1})
+def squeeze_blanks(text, max):
+    lines, nl = _split_keep_trailing(text)
+    out = []
+    run = 0
+    for line in lines:
+        if line == "":
+            run += 1
+            if run > max:
+                continue
+        else:
+            run = 0
+        out.append(line)
+    return _join(out, nl)
+
+
+@register("ensure_final_newline")
+def ensure_final_newline(text):
+    if text == "":
+        return ""
+    return text.rstrip("\n") + "\n"
