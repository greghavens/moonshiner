+"""Plugin registry: decorator-based registration."""
+
+_PLUGINS = {}   # name -> function
+_OPTIONS = {}   # name -> {option: default}
+
+
+def register(name, options=None):
+    """Decorator registering a plugin under a unique name.
+
+    options declares the option names the plugin accepts, with defaults.
+    The decorated function is returned unchanged.
+    """
+    def decorator(func):
+        if name in _PLUGINS:
+            raise ValueError(f"plugin already registered: {name!r}")
+        _PLUGINS[name] = func
+        _OPTIONS[name] = dict(options or {})
+        return func
+    return decorator
+
+
+def get(name):
+    if name not in _PLUGINS:
+        raise LookupError(f"unknown plugin: {name!r}")
+    return _PLUGINS[name]
+
+
+def option_defaults(name):
+    if name not in _OPTIONS:
+        raise LookupError(f"unknown plugin: {name!r}")
+    return dict(_OPTIONS[name])
+
+
+def names():
+    return sorted(_PLUGINS)
