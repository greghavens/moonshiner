@@ -0,0 +1,52 @@
+package modcycles
+
+import "sort"
+
+// Cycles enumerates every elementary cycle in the import graph.
+//
+// Each cycle starts at its alphabetically smallest member (so it is found
+// exactly once: the search from a start node only travels through nodes
+// that sort after it) and consecutive elements follow import edges, the
+// last importing the first. The outer list is sorted element-by-element.
+func (g *Graph) Cycles() [][]string {
+	starts := g.Modules() // sorted
+	var cycles [][]string
+
+	var path []string
+	onPath := map[string]bool{}
+
+	var dfs func(start, node string)
+	dfs = func(start, node string) {
+		path = append(path, node)
+		onPath[node] = true
+		for _, dep := range g.declaredImports(node) {
+			if dep == start {
+				cycle := make([]string, len(path))
+				copy(cycle, path)
+				cycles = append(cycles, cycle)
+				continue
+			}
+			if dep < start || onPath[dep] {
+				continue
+			}
+			dfs(start, dep)
+		}
+		onPath[node] = false
+		path = path[:len(path)-1]
+	}
+
+	for _, start := range starts {
+		dfs(start, start)
+	}
+
+	sort.Slice(cycles, func(i, j int) bool {
+		a, b := cycles[i], cycles[j]
+		for k := 0; k < len(a) && k < len(b); k++ {
+			if a[k] != b[k] {
+				return a[k] < b[k]
+			}
+		}
+		return len(a) < len(b)
+	})
+	return cycles
+}
