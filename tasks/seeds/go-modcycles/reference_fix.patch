index 0000000..35749a7
--- /dev/null
+++ b/graph.go
@@ -0,0 +1,61 @@
+package modcycles
+
+import "sort"
+
+// Graph is the declared-module import graph. Read-only after Load.
+type Graph struct {
+	imports map[string][]string // declared module -> imports, declaration order
+}
+
+func newGraph() *Graph {
+	return &Graph{imports: map[string][]string{}}
+}
+
+func (g *Graph) add(m *manifest) {
+	g.imports[m.name] = m.imports
+}
+
+// Modules lists every declared module, sorted.
+func (g *Graph) Modules() []string {
+	names := make([]string, 0, len(g.imports))
+	for name := range g.imports {
+		names = append(names, name)
+	}
+	sort.Strings(names)
+	return names
+}
+
+// Imports reports a module's imports in declaration order.
+func (g *Graph) Imports(name string) ([]string, bool) {
+	imports, ok := g.imports[name]
+	return imports, ok
+}
+
+// Missing lists imported-but-undeclared names, sorted and deduplicated.
+func (g *Graph) Missing() []string {
+	set := map[string]bool{}
+	for _, imports := range g.imports {
+		for _, dep := range imports {
+			if _, declared := g.imports[dep]; !declared {
+				set[dep] = true
+			}
+		}
+	}
+	missing := make([]string, 0, len(set))
+	for name := range set {
+		missing = append(missing, name)
+	}
+	sort.Strings(missing)
+	return missing
+}
+
+// declaredImports yields only edges whose target is a declared module.
+func (g *Graph) declaredImports(name string) []string {
+	var out []string
+	for _, dep := range g.imports[name] {
+		if _, ok := g.imports[dep]; ok {
+			out = append(out, dep)
+		}
+	}
+	return out
+}
diff --git a/order.go b/order.go
new file mode 100644
index 0000000..60c592f
--- /dev/null
+++ b/order.go
@@ -0,0 +1,53 @@
+package modcycles
+
+import (
+	"errors"
+	"sort"
+)
+
+// Order returns a dependency-first topological order over declared
+// modules. When several modules are ready at once the alphabetically
+// smallest goes next, so the order is fully deterministic. Returns an
+// error if the graph contains any import cycle.
+func (g *Graph) Order() ([]string, error) {
+	pending := map[string]int{} // unmet declared dependencies
+	dependents := map[string][]string{}
+	for _, name := range g.Modules() {
+		deps := g.declaredImports(name)
+		pending[name] = len(deps)
+		for _, dep := range deps {
+			dependents[dep] = append(dependents[dep], name)
+		}
+	}
+
+	var ready []string
+	for name, n := range pending {
+		if n == 0 {
+			ready = append(ready, name)
+		}
+	}
+	sort.Strings(ready)
+
+	order := make([]string, 0, len(pending))
+	for len(ready) > 0 {
+		next := ready[0]
+		ready = ready[1:]
+		order = append(order, next)
+		var unlocked []string
+		for _, dependent := range dependents[next] {
+			pending[dependent]--
+			if pending[dependent] == 0 {
+				unlocked = append(unlocked, dependent)
+			}
+		}
+		if len(unlocked) > 0 {
+			ready = append(ready, unlocked...)
+			sort.Strings(ready)
+		}
+	}
+
+	if len(order) != len(pending) {
+		return nil, errors.New("import cycle detected: topological order impossible")
+	}
+	return order, nil
+}
