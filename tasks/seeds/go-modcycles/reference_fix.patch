new file mode 100644
index 0000000..aba51ac
--- /dev/null
+++ b/parse.go
@@ -0,0 +1,119 @@
+package modcycles
+
+import (
+	"bufio"
+	"fmt"
+	"io/fs"
+	"os"
+	"path/filepath"
+	"strings"
+)
+
+// manifest is one parsed .mod file.
+type manifest struct {
+	path    string
+	name    string
+	imports []string
+}
+
+func validName(s string) bool {
+	if s == "" {
+		return false
+	}
+	for _, r := range s {
+		switch {
+		case r >= 'a' && r <= 'z', r >= 'A' && r <= 'Z',
+			r >= '0' && r <= '9', r == '-', r == '_':
+		default:
+			return false
+		}
+	}
+	return true
+}
+
+func parseManifest(path string) (*manifest, error) {
+	f, err := os.Open(path)
+	if err != nil {
+		return nil, err
+	}
+	defer f.Close()
+
+	m := &manifest{path: path}
+	seen := map[string]bool{}
+	scanner := bufio.NewScanner(f)
+	lineNo := 0
+	for scanner.Scan() {
+		lineNo++
+		line := strings.TrimSpace(scanner.Text())
+		if line == "" || strings.HasPrefix(line, "#") {
+			continue
+		}
+		fields := strings.Fields(line)
+		switch fields[0] {
+		case "module":
+			if len(fields) != 2 || !validName(fields[1]) {
+				return nil, fmt.Errorf("%s:%d: malformed module line %q", path, lineNo, line)
+			}
+			if m.name != "" {
+				return nil, fmt.Errorf("%s:%d: second module line", path, lineNo)
+			}
+			if len(m.imports) > 0 {
+				return nil, fmt.Errorf("%s:%d: module line must come first", path, lineNo)
+			}
+			m.name = fields[1]
+		case "import":
+			if m.name == "" {
+				return nil, fmt.Errorf("%s:%d: import before module line", path, lineNo)
+			}
+			if len(fields) != 2 || !validName(fields[1]) {
+				return nil, fmt.Errorf("%s:%d: malformed import line %q", path, lineNo, line)
+			}
+			if seen[fields[1]] {
+				return nil, fmt.Errorf("%s:%d: duplicate import %q", path, lineNo, fields[1])
+			}
+			seen[fields[1]] = true
+			m.imports = append(m.imports, fields[1])
+		default:
+			return nil, fmt.Errorf("%s:%d: unknown directive %q", path, lineNo, fields[0])
+		}
+	}
+	if err := scanner.Err(); err != nil {
+		return nil, fmt.Errorf("%s: %w", path, err)
+	}
+	if m.name == "" {
+		return nil, fmt.Errorf("%s: no module line", path)
+	}
+	return m, nil
+}
+
+// Load walks root for .mod manifests and builds the import graph.
+func Load(root string) (*Graph, error) {
+	var paths []string
+	err := filepath.WalkDir(root, func(path string, d fs.DirEntry, err error) error {
+		if err != nil {
+			return err
+		}
+		if !d.IsDir() && strings.HasSuffix(d.Name(), ".mod") {
+			paths = append(paths, path)
+		}
+		return nil
+	})
+	if err != nil {
+		return nil, err
+	}
+
+	g := newGraph()
+	declaredIn := map[string]string{}
+	for _, path := range paths {
+		m, err := parseManifest(path)
+		if err != nil {
+			return nil, err
+		}
+		if other, ok := declaredIn[m.name]; ok {
+			return nil, fmt.Errorf("module %q declared in both %s and %s", m.name, other, path)
+		}
+		declaredIn[m.name] = path
+		g.add(m)
+	}
+	return g, nil
+}
