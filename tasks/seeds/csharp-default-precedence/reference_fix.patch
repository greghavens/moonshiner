+
+    private static IReadOnlyList<CompatibilityDiagnostic> CreateDiagnostics(
+        IReadOnlyList<ConfigurationLayer> layers)
+    {
+        var diagnostics = new List<CompatibilityDiagnostic>();
+
+        // Paths and layers are both least-to-most specific. That makes the
+        // diagnostic sequence independent of dictionary insertion order.
+        foreach (var optionPath in SupportedOptionPaths)
+        {
+            var configuredLayers = layers
+                .Where(layer => ContainsValue(layer.Values, optionPath))
+                .ToArray();
+
+            if (configuredLayers.Length < 2)
+            {
+                continue;
+            }
+
+            ConfigurationSource selected = configuredLayers[^1].Source;
+            foreach (var shadowed in configuredLayers[..^1])
+            {
+                diagnostics.Add(new CompatibilityDiagnostic(
+                    "CFG001",
+                    optionPath,
+                    selected,
+                    shadowed.Source,
+                    $"{optionPath}: {selected} value takes precedence over " +
+                    $"{shadowed.Source} value."));
+            }
+        }
+
+        return diagnostics;
+    }
+
+    private static bool ContainsValue(
+        IReadOnlyDictionary<string, string?> values,
+        string optionPath)
+    {
+        foreach (var pair in values)
+        {
+            if (pair.Value is not null &&
+                string.Equals(pair.Key, optionPath, StringComparison.OrdinalIgnoreCase))
+            {
+                return true;
+            }
+        }
+
+        return false;
+    }
 }
