+export type FieldType = 'text' | 'number' | 'boolean' | 'choice';
+
+export interface FieldDef {
+  id: string;
+  label?: string;
+  type: FieldType;
+  required?: boolean;
+  minLength?: number;
+  maxLength?: number;
+  pattern?: string;
+  min?: number;
+  max?: number;
+  options?: unknown[];
+}
+
+export function validateField(field: FieldDef, value: unknown): string[] {
+  if (value === undefined) {
+    return field.required ? [`${field.id} is required`] : [];
+  }
+
+  const errors: string[] = [];
+  switch (field.type) {
+    case 'text': {
+      if (typeof value !== 'string') {
+        errors.push(`${field.id} must be text`);
+        break;
+      }
+      if (field.minLength !== undefined && value.length < field.minLength) {
+        errors.push(`${field.id} must be at least ${field.minLength} characters`);
+      }
+      if (field.maxLength !== undefined && value.length > field.maxLength) {
+        errors.push(`${field.id} must be at most ${field.maxLength} characters`);
+      }
+      if (field.pattern !== undefined && !new RegExp(field.pattern).test(value)) {
+        errors.push(`${field.id} does not match the required pattern`);
+      }
+      break;
+    }
+    case 'number': {
+      if (typeof value !== 'number' || Number.isNaN(value)) {
+        errors.push(`${field.id} must be a number`);
+        break;
+      }
+      if (field.min !== undefined && value < field.min) {
+        errors.push(`${field.id} must be at least ${field.min}`);
+      }
+      if (field.max !== undefined && value > field.max) {
+        errors.push(`${field.id} must be at most ${field.max}`);
+      }
+      break;
+    }
+    case 'boolean': {
+      if (typeof value !== 'boolean') {
+        errors.push(`${field.id} must be a boolean`);
+      }
+      break;
+    }
+    case 'choice': {
+      if (!(field.options ?? []).includes(value)) {
+        errors.push(`${String(value)} is not one of the choices for ${field.id}`);
+      }
+      break;
+    }
+  }
+  return errors;
+}
