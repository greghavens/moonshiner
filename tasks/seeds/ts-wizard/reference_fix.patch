--- /dev/null
+++ b/schema.ts
@@ -0,0 +1,73 @@
+import type { FieldDef, FieldType } from './fields.ts';
+
+export interface ShowIf {
+  field: string;
+  equals?: unknown;
+  in?: unknown[];
+}
+
+export interface PageDef {
+  id: string;
+  title?: string;
+  showIf?: ShowIf;
+  fields: FieldDef[];
+}
+
+export interface SchemaDef {
+  pages: PageDef[];
+}
+
+const TYPES: readonly FieldType[] = ['text', 'number', 'boolean', 'choice'];
+
+export function loadSchema(def: SchemaDef): SchemaDef {
+  if (!Array.isArray(def.pages) || def.pages.length === 0) {
+    throw new Error('schema needs at least one page');
+  }
+
+  const pageIds = new Set<string>();
+  const fieldIds = new Set<string>();
+  // field id -> index of the page that defines it
+  const fieldPage = new Map<string, number>();
+
+  def.pages.forEach((page, pageIndex) => {
+    if (pageIds.has(page.id)) {
+      throw new Error(`duplicate page id: ${page.id}`);
+    }
+    pageIds.add(page.id);
+    if (!Array.isArray(page.fields) || page.fields.length === 0) {
+      throw new Error(`page ${page.id} has no fields`);
+    }
+    for (const field of page.fields) {
+      if (fieldIds.has(field.id)) {
+        throw new Error(`duplicate field id: ${field.id}`);
+      }
+      fieldIds.add(field.id);
+      fieldPage.set(field.id, pageIndex);
+      if (!TYPES.includes(field.type)) {
+        throw new Error(`unknown field type: ${String(field.type)}`);
+      }
+      if (
+        field.type === 'choice' &&
+        (!Array.isArray(field.options) || field.options.length === 0)
+      ) {
+        throw new Error(`choice field ${field.id} needs a non-empty options list`);
+      }
+    }
+  });
+
+  def.pages.forEach((page, pageIndex) => {
+    if (!page.showIf) return;
+    const target = page.showIf.field;
+    const definedOn = fieldPage.get(target);
+    if (definedOn === undefined) {
+      throw new Error(`showIf on page ${page.id} references unknown field: ${target}`);
+    }
+    if (definedOn >= pageIndex) {
+      throw new Error(
+        `showIf on page ${page.id} must reference a field from an earlier page, not ${target}`,
+      );
+    }
+  });
+
+  return def;
+}
diff --git a/wizard.ts b/wizard.ts
new file mode 100644
index 0000000..638dd09
--- /dev/null
+++ b/wizard.ts
@@ -0,0 +1,116 @@
+import { validateField } from './fields.ts';
+import { loadSchema } from './schema.ts';
+import type { PageDef, SchemaDef, ShowIf } from './schema.ts';
+
+export type Answers = Record<string, unknown>;
+
+export interface FieldErrors {
+  field: string;
+  messages: string[];
+}
+
+export type NextResult =
+  | { ok: true; done: boolean }
+  | { ok: false; errors: FieldErrors[] };
+
+export class Wizard {
+  private schema: SchemaDef;
+  private stored = new Map<string, Answers>();
+  private currentIdx = 0;
+
+  constructor(def: SchemaDef) {
+    this.schema = loadSchema(def);
+    for (const page of this.schema.pages) this.stored.set(page.id, {});
+  }
+
+  current(): PageDef {
+    const page = this.page();
+    return {
+      id: page.id,
+      ...(page.title !== undefined ? { title: page.title } : {}),
+      ...(page.showIf !== undefined ? { showIf: { ...page.showIf } } : {}),
+      fields: page.fields.map((f) => ({ ...f })),
+    };
+  }
+
+  next(answers: Answers): NextResult {
+    const page = this.page();
+    const known = new Set(page.fields.map((f) => f.id));
+    for (const key of Object.keys(answers)) {
+      if (!known.has(key)) {
+        throw new Error(`field ${key} does not belong to page ${page.id}`);
+      }
+    }
+
+    const merged: Answers = { ...this.stored.get(page.id), ...answers };
+    for (const key of Object.keys(merged)) {
+      if (merged[key] === undefined) delete merged[key];
+    }
+
+    const errors: FieldErrors[] = [];
+    for (const field of page.fields) {
+      const messages = validateField(field, merged[field.id]);
+      if (messages.length > 0) errors.push({ field: field.id, messages });
+    }
+    if (errors.length > 0) return { ok: false, errors };
+
+    this.stored.set(page.id, merged);
+    const ahead = this.visibleIndices().filter((i) => i > this.currentIdx);
+    this.currentIdx = ahead.length > 0 ? ahead[0] : this.schema.pages.length;
+    return { ok: true, done: this.currentIdx === this.schema.pages.length };
+  }
+
+  back(): void {
+    const behind = this.visibleIndices().filter((i) => i < this.currentIdx);
+    if (behind.length === 0) {
+      throw new Error('already at the first page, cannot go back');
+    }
+    this.currentIdx = behind[behind.length - 1];
+  }
+
+  pageAnswers(pageId: string): Answers {
+    if (!this.schema.pages.some((p) => p.id === pageId)) {
+      throw new Error(`unknown page: ${pageId}`);
+    }
+    return { ...this.stored.get(pageId) };
+  }
+
+  export(): Answers {
+    const out: Answers = {};
+    for (const i of this.visibleIndices()) {
+      const page = this.schema.pages[i];
+      const answers = this.stored.get(page.id) ?? {};
+      for (const field of page.fields) {
+        if (answers[field.id] !== undefined) out[field.id] = answers[field.id];
+      }
+    }
+    return out;
+  }
+
+  private page(): PageDef {
+    if (this.currentIdx >= this.schema.pages.length) {
+      throw new Error('the wizard is complete');
+    }
+    return this.schema.pages[this.currentIdx];
+  }
+
+  /** Indices of pages visible under the stored answers, honoring page order. */
+  private visibleIndices(): number[] {
+    const indices: number[] = [];
+    const effective: Answers = {};
+    this.schema.pages.forEach((page, i) => {
+      if (this.evalShowIf(page.showIf, effective)) {
+        indices.push(i);
+        Object.assign(effective, this.stored.get(page.id));
+      }
+    });
+    return indices;
+  }
+
+  private evalShowIf(cond: ShowIf | undefined, answers: Answers): boolean {
+    if (!cond) return true;
+    if ('equals' in cond) return answers[cond.field] === cond.equals;
+    if (Array.isArray(cond.in)) return cond.in.includes(answers[cond.field]);
+    return false;
+  }
+}
