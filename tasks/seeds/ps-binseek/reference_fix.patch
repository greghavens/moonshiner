+# binseek.ps1 — depot bin resolver.
+# Dot-source this file to get Resolve-BinQueries.
+Set-StrictMode -Version Latest
+
+function Resolve-BinQueries {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][object[]]$Records,
+        [Parameter(Mandatory)][string[]]$Queries
+    )
+
+    # Label reads proxy the depot backend and are expensive: read each
+    # record's Label exactly once per call and index it. Labels are
+    # case-sensitive, so the index must compare ordinally (a default
+    # hashtable would fold TOTE-12 onto tote-12).
+    $index = [System.Collections.Generic.Dictionary[string, object]]::new([System.StringComparer]::Ordinal)
+    foreach ($record in $Records) {
+        $label = [string]$record.Label
+        if (-not $index.ContainsKey($label)) {
+            $index[$label] = $record
+        }
+    }
+
+    $out = [System.Collections.Generic.List[string]]::new()
+    foreach ($query in $Queries) {
+        if ($index.ContainsKey($query)) {
+            $hit = $index[$query]
+            $out.Add(('{0} -> {1} owner={2}' -f $query, $hit.Bin, $hit.Owner))
+        } else {
+            $out.Add(('{0} -> (unlisted)' -f $query))
+        }
+    }
+    return $out
+}
