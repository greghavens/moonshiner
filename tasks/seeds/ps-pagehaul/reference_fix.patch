diff --git a/pagehaul.ps1 b/pagehaul.ps1
new file mode 100644
index 0000000..bbca9c6
--- /dev/null
+++ b/pagehaul.ps1
@@ -0,0 +1,46 @@
+# Drains the cursor-paginated asset-inventory API and prints one summary line.
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$BaseUrl,
+    [Parameter(Mandatory)][int]$PageSize
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+$ids = [System.Collections.Generic.List[string]]::new()
+# default @{} folds key case and would merge the 'Web'/'web' site tags
+$bySite = [System.Collections.Hashtable]::new([System.StringComparer]::Ordinal)
+$pages = 0
+$cursor = $null
+
+while ($true) {
+    $uri = if ($null -eq $cursor) {
+        "$BaseUrl/assets?limit=$PageSize"
+    } else {
+        "$BaseUrl/assets?cursor=$([uri]::EscapeDataString($cursor))&limit=$PageSize"
+    }
+    $page = Invoke-RestMethod -Uri $uri
+    $pages++
+    foreach ($item in $page.items) {
+        $ids.Add([string]$item.id)
+        $site = [string]$item.site
+        if ($bySite.ContainsKey($site)) { $bySite[$site]++ } else { $bySite[$site] = 1 }
+    }
+    if ($null -eq $page.next) { break }
+    $cursor = [string]$page.next
+}
+
+$siteNames = @($bySite.Keys)
+[Array]::Sort($siteNames, [System.StringComparer]::Ordinal)
+$sites = @(foreach ($name in $siteNames) {
+    [ordered]@{ site = $name; count = $bySite[$name] }
+})
+
+$report = [ordered]@{
+    total = $ids.Count
+    pages = $pages
+    sites = $sites
+    ids   = @($ids)
+}
+Write-Output ($report | ConvertTo-Json -Compress -Depth 5)
