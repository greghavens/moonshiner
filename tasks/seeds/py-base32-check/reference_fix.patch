+"""b32check — Crockford-style base32 with a mod-37 check symbol.
+
+Claim codes for gift cards: encode() emits canonical text, decode()
+tolerates human transcription (case, hyphens, I/L/O) but rejects any
+single-symbol substitution or adjacent transposition.
+"""
+
+ALPHABET = "0123456789ABCDEFGHJKMNPQRSTVWXYZ"
+CHECK_ALPHABET = ALPHABET + "*~$=U"
+
+_VALUE = {c: i for i, c in enumerate(ALPHABET)}
+_CHECK_VALUE = {c: i for i, c in enumerate(CHECK_ALPHABET)}
+
+# payload lengths (in symbols) that whole bytes can produce, per 8-symbol block
+_VALID_REMAINDERS = {0, 2, 4, 5, 7}
+
+
+class DecodeError(ValueError):
+    """Text is not a valid claim code."""
+
+
+class ChecksumError(DecodeError):
+    """Structure was fine but the check symbol disagrees."""
+
+
+def _check_symbol(data):
+    return CHECK_ALPHABET[int.from_bytes(data, "big") % 37]
+
+
+def encode(data):
+    """Encode bytes to canonical text: base32 payload + one check symbol."""
+    bits = 0
+    nbits = 0
+    out = []
+    for byte in data:
+        bits = (bits << 8) | byte
+        nbits += 8
+        while nbits >= 5:
+            nbits -= 5
+            out.append(ALPHABET[(bits >> nbits) & 0x1F])
+        bits &= (1 << nbits) - 1
+    if nbits:
+        out.append(ALPHABET[(bits << (5 - nbits)) & 0x1F])
+    return "".join(out) + _check_symbol(data)
+
+
+def _normalize(text):
+    text = text.replace("-", "").upper()
+    return text.replace("I", "1").replace("L", "1").replace("O", "0")
+
+
+def decode(text):
+    """Decode text back to bytes, or raise DecodeError/ChecksumError."""
+    text = _normalize(text)
+    if not text:
+        raise DecodeError("too short: a code is at least its check symbol")
+    payload, check = text[:-1], text[-1]
+    if check not in _CHECK_VALUE:
+        raise DecodeError(f"invalid check symbol {check!r}")
+    if len(payload) % 8 not in _VALID_REMAINDERS:
+        raise DecodeError(f"impossible payload length {len(payload)}")
+    bits = 0
+    nbits = 0
+    out = bytearray()
+    for c in payload:
+        if c not in _VALUE:
+            raise DecodeError(f"invalid symbol {c!r}")
+        bits = (bits << 5) | _VALUE[c]
+        nbits += 5
+        if nbits >= 8:
+            nbits -= 8
+            out.append((bits >> nbits) & 0xFF)
+            bits &= (1 << nbits) - 1
+    if bits:
+        raise DecodeError("nonzero padding bits")
+    data = bytes(out)
+    if _check_symbol(data) != check:
+        raise ChecksumError("check symbol mismatch")
+    return data
