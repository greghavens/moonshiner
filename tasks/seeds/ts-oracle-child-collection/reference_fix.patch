new file mode 100644
index 0000000..aafd16c
--- /dev/null
+++ b/hcm/checkpoint.ts
@@ -0,0 +1,52 @@
+// Durable walk checkpoints: one JSON file mapping walk key -> state.
+// Writes go through a temp file + rename so a crash never leaves a
+// half-written checkpoint behind.
+
+import fs from "node:fs";
+import path from "node:path";
+
+export interface CheckpointState {
+  offset: number;
+  seenIds: number[];
+}
+
+export class FileCheckpointStore {
+  private file: string;
+
+  constructor(file: string) {
+    this.file = file;
+  }
+
+  private readAll(): Record<string, CheckpointState> {
+    try {
+      return JSON.parse(fs.readFileSync(this.file, "utf8"));
+    } catch {
+      return {};
+    }
+  }
+
+  private writeAll(all: Record<string, CheckpointState>): void {
+    fs.mkdirSync(path.dirname(this.file), { recursive: true });
+    const tmp = `${this.file}.tmp`;
+    fs.writeFileSync(tmp, JSON.stringify(all, null, 2));
+    fs.renameSync(tmp, this.file);
+  }
+
+  load(key: string): CheckpointState | null {
+    return this.readAll()[key] ?? null;
+  }
+
+  save(key: string, state: CheckpointState): void {
+    const all = this.readAll();
+    all[key] = state;
+    this.writeAll(all);
+  }
+
+  clear(key: string): void {
+    const all = this.readAll();
+    if (key in all) {
+      delete all[key];
+      this.writeAll(all);
+    }
+  }
+}
