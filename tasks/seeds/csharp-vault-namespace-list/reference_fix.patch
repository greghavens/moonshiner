+/// A non-2xx Vault response carrying a non-empty {"errors": [...]} document.
+public sealed class VaultApiException : Exception
+{
+    public VaultApiException(int statusCode, IReadOnlyList<string> errors)
+        : base($"vault: HTTP {statusCode}: {string.Join("; ", errors)}")
+    {
+        StatusCode = statusCode;
+        Errors = errors;
+    }
+
+    public int StatusCode { get; }
+
+    public IReadOnlyList<string> Errors { get; }
+}
+
+/// One child namespace from sys/namespaces key_info (path is relative to the
+/// namespace that was listed).
+public sealed record VaultNamespaceInfo(string Path, string Id);
+
+/// One inventoried secret: the absolute namespace path ("" for root) plus the
+/// mount-relative secret path.
+public sealed record VaultSecretRef(string Namespace, string Path);
diff --git a/VaultListClient.cs b/VaultListClient.cs
