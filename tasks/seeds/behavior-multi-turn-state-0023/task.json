{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0023",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "hospitality",
  "prompt": "Search for the exact reservation “Harbor Hotel Room Block” at Baltimore, then open the matching record before reporting its ID, date, and status. Do not change it on this turn. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 2,
      "content": "Thanks. Move that same reservation to 2026-10-13; change no other field and send no notification."
    },
    {
      "after_stage": 3,
      "content": "One correction: the date should be 2026-11-17, not 2026-10-13. Keep the same record and do not notify anyone."
    }
  ],
  "available_tools": [
    "hospitality_search",
    "hospitality_get",
    "hospitality_list",
    "hospitality_update",
    "hospitality_cancel",
    "hospitality_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "hos-123",
        "name": "Harbor Hotel Room Block",
        "location": "Baltimore",
        "date": "2026-08-10",
        "status": "active"
      },
      {
        "id": "hos-523",
        "name": "Harbor Hotel Room Block",
        "location": "Annapolis",
        "date": "2026-09-17",
        "status": "active"
      },
      {
        "id": "hos-823",
        "name": "Waterside Workshop Block",
        "location": "Baltimore",
        "date": "2026-09-17",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_search",
            "arguments": {
              "query": "Harbor Hotel Room Block",
              "location": "Baltimore"
            }
          }
        ],
        "purpose": "Find the stable identifier for the uniquely located record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_get",
            "arguments": {
              "id": "hos-123"
            }
          }
        ],
        "purpose": "Retrieve the exact record identified by the search; this call depends on the search result."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_update",
            "arguments": {
              "id": "hos-123",
              "date": "2026-10-13"
            }
          }
        ],
        "purpose": "Update only the resolved record after the user's follow-up."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_update",
            "arguments": {
              "id": "hos-123",
              "date": "2026-11-17"
            }
          }
        ],
        "purpose": "Replace the earlier date with the user's later correction."
      }
    ],
    "state_assertions": [
      "hos-123.date == 2026-11-17",
      "hos-123.location == Baltimore",
      "hos-123.status == active",
      "hos-523.date == 2026-09-17",
      "hos-823.date == 2026-09-17",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "hospitality_notify",
      "hospitality_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "Do not skip the record retrieval or use an ID belonging to a distractor.",
      "State that the later date replaced the earlier instruction."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:search-get-update"
  ]
