+"""csvschema — column type inference for customer CSV uploads.
+
+Cells arrive as strings; we vote a type per column: int, float, bool,
+date or str, plus nullability. See infer_schema for the rules.
+"""
+from datetime import date
+
+_NULLS = {"", "null", "na", "n/a"}
+_BOOLS = {"true", "false"}
+
+
+def _is_null(cell):
+    return cell.lower() in _NULLS
+
+
+def _is_int(cell):
+    body = cell[1:] if cell[:1] in "+-" else cell
+    if not body or not body.isascii() or not body.isdigit():
+        return False
+    if len(body) > 1 and body[0] == "0":
+        return False  # leading zero: an identifier, not a number
+    return True
+
+
+def _is_float(cell):
+    """Strict decimal/exponent notation; no inf/nan/underscores."""
+    body = cell[1:] if cell[:1] in "+-" else cell
+    mantissa, exponent = body, ""
+    if "e" in body.lower():
+        idx = body.lower().index("e")
+        mantissa, exponent = body[:idx], body[idx + 1:]
+        exp_body = exponent[1:] if exponent[:1] in "+-" else exponent
+        if not exp_body or not exp_body.isascii() or not exp_body.isdigit():
+            return False
+    if mantissa.count(".") > 1:
+        return False
+    intpart, _, fracpart = mantissa.partition(".")
+    if not (intpart or fracpart):
+        return False
+    for part in (intpart, fracpart):
+        if part and not (part.isascii() and part.isdigit()):
+            return False
+    if "." not in mantissa and not exponent:
+        return False  # no decimal point and no exponent: that's int territory
+    return True
+
+
+def _is_date(cell):
+    if len(cell) != 10 or cell[4] != "-" or cell[7] != "-":
+        return False
+    y, m, d = cell[:4], cell[5:7], cell[8:10]
+    if not (y.isdigit() and m.isdigit() and d.isdigit()):
+        return False
+    try:
+        date(int(y), int(m), int(d))
+    except ValueError:
+        return False
+    return True
+
+
+def _classify(cell):
+    if cell.lower() in _BOOLS:
+        return "bool"
+    if _is_int(cell):
+        return "int"
+    if _is_float(cell):
+        return "float"
+    if _is_date(cell):
+        return "date"
+    return "str"
+
+
+def infer_schema(header, rows, sample_size=None):
+    """Infer {"name", "type", "nullable"} for each column, in header order."""
+    if len(set(header)) != len(header):
+        raise ValueError("duplicate column names in header")
+    ncols = len(header)
+    seen = [set() for _ in header]
+    nullable = [False] * ncols
+    for i, row in enumerate(rows):
+        if len(row) != ncols:
+            raise ValueError(
+                f"row {i} has {len(row)} fields, expected {ncols}")
+        if sample_size is not None and i >= sample_size:
+            continue  # structure is still validated, values are not sampled
+        for j, raw in enumerate(row):
+            cell = raw.strip()
+            if _is_null(cell):
+                nullable[j] = True
+            else:
+                seen[j].add(_classify(cell))
+    schema = []
+    for name, types, is_nullable in zip(header, seen, nullable):
+        if not types:
+            kind = "str"
+            is_nullable = True
+        elif len(types) == 1:
+            kind = next(iter(types))
+        elif types == {"int", "float"}:
+            kind = "float"
+        else:
+            kind = "str"
+        schema.append({"name": name, "type": kind, "nullable": is_nullable})
+    return schema
