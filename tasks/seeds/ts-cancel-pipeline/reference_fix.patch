+export interface Stage {
+  name: string;
+  run(input: unknown, signal: AbortSignal): unknown | Promise<unknown>;
+  cleanup?(): void | Promise<void>;
+}
+
+export interface PipelineOptions {
+  signal?: AbortSignal;
+}
+
+const NEVER_ABORTED: AbortSignal = new AbortController().signal;
+
+export async function runPipeline(
+  stages: Stage[],
+  input: unknown,
+  opts: PipelineOptions = {},
+): Promise<unknown> {
+  const signal = opts.signal ?? NEVER_ABORTED;
+  if (signal.aborted) throw signal.reason;
+
+  const completed: Stage[] = [];
+  let value: unknown = input;
+  let failure: { error: unknown } | null = null;
+
+  for (const stage of stages) {
+    if (signal.aborted) {
+      failure = { error: signal.reason };
+      break;
+    }
+    try {
+      value = await stage.run(value, signal);
+    } catch (error) {
+      // If cancellation landed while the stage was in flight, the abort
+      // reason wins over whatever the interrupted stage threw.
+      failure = { error: signal.aborted ? signal.reason : error };
+      break;
+    }
+    completed.push(stage);
+    if (signal.aborted) {
+      failure = { error: signal.reason };
+      break;
+    }
+  }
+
+  if (!failure) return value;
+
+  // Roll back completed stages in reverse, one at a time. Cleanup failures
+  // must neither halt the rollback nor mask the original error.
+  for (let i = completed.length - 1; i >= 0; i--) {
+    try {
+      await completed[i].cleanup?.();
+    } catch {
+      // ignored: the pipeline's failure reason takes precedence
+    }
+  }
+
+  throw failure.error;
+}
