+"""Dotted-path get/put/delete over nested dict/list documents.
+
+Path grammar: dot-separated keys; ``[N]`` indexes attach to the key in
+front of them and may chain (``grid[1][0]``); a path may start with an
+index when the root is a list.  Inside keys, backslash escapes the next
+character (``\\.``, ``\\[``, ``\\\\``).
+
+Malformed paths always raise ValueError.  Well-formed paths that fail to
+resolve raise PathError.
+"""
+
+import re
+
+_INDEX_RE = re.compile(r"-?\d+$")
+_MISSING = object()
+
+
+class PathError(Exception):
+    """A well-formed path did not resolve against the document."""
+
+
+def _parse(path):
+    """Return a list of segments: ('key', str) or ('idx', int)."""
+    if not isinstance(path, str) or not path:
+        raise ValueError("path must be a non-empty string: %r" % (path,))
+    segs = []
+    i, n = 0, len(path)
+    # expect_key: at start of path or right after a '.', where a key must
+    # begin -- except a leading '[' (index on the root) is allowed.
+    at_start = True
+    while i < n:
+        c = path[i]
+        if c == ".":
+            raise ValueError("empty segment in path %r" % path)
+        if c == "[":
+            if not at_start and not segs:
+                raise ValueError("empty segment in path %r" % path)
+            close = path.find("]", i)
+            if close == -1:
+                raise ValueError("unclosed '[' in path %r" % path)
+            token = path[i + 1:close]
+            if not _INDEX_RE.match(token):
+                raise ValueError("bad index %r in path %r" % (token, path))
+            segs.append(("idx", int(token)))
+            i = close + 1
+            if i < n:
+                if path[i] == "[":
+                    at_start = False
+                    continue
+                if path[i] != ".":
+                    raise ValueError("unexpected %r after ']' in path %r"
+                                     % (path[i], path))
+                i += 1
+                if i == n or path[i] in ".[":
+                    raise ValueError("empty segment in path %r" % path)
+            at_start = False
+            continue
+        # scan a key
+        key = []
+        while i < n and path[i] not in ".[":
+            if path[i] == "\\":
+                if i + 1 >= n:
+                    raise ValueError("dangling backslash in path %r" % path)
+                key.append(path[i + 1])
+                i += 2
+            else:
+                key.append(path[i])
+                i += 1
+        segs.append(("key", "".join(key)))
+        if i < n and path[i] == ".":
+            i += 1
+            if i == n or path[i] in ".[":
+                raise ValueError("empty segment in path %r" % path)
+        at_start = False
+    return segs
+
+
+def _step(node, seg, path):
+    kind, val = seg
+    if kind == "key":
+        if not isinstance(node, dict):
+            raise PathError("cannot key into %s at %r in %r"
+                            % (type(node).__name__, val, path))
+        if val not in node:
+            raise PathError("missing key %r in %r" % (val, path))
+        return node[val]
+    if not isinstance(node, list):
+        raise PathError("cannot index into %s in %r"
+                        % (type(node).__name__, path))
+    if not -len(node) <= val < len(node):
+        raise PathError("index %d out of range in %r" % (val, path))
+    return node[val]
+
+
+def get(data, path, default=_MISSING):
+    segs = _parse(path)
+    node = data
+    try:
+        for seg in segs:
+            node = _step(node, seg, path)
+    except PathError:
+        if default is not _MISSING:
+            return default
+        raise
+    return node
+
+
+def put(data, path, value, create=False):
+    segs = _parse(path)
+    node = data
+    for pos, seg in enumerate(segs[:-1]):
+        kind, val = seg
+        if (kind == "key" and create and isinstance(node, dict)
+                and val not in node):
+            node[val] = {}
+        node = _step(node, seg, path)
+    kind, val = segs[-1]
+    if kind == "key":
+        if not isinstance(node, dict):
+            raise PathError("cannot set key %r on %s in %r"
+                            % (val, type(node).__name__, path))
+        node[val] = value
+        return
+    if not isinstance(node, list):
+        raise PathError("cannot set index on %s in %r"
+                        % (type(node).__name__, path))
+    if -len(node) <= val < len(node):
+        node[val] = value
+    elif create and val == len(node):
+        node.append(value)
+    else:
+        raise PathError("index %d out of range in %r" % (val, path))
+
+
+def delete(data, path, missing_ok=False):
+    segs = _parse(path)
+    node = data
+    try:
+        for seg in segs[:-1]:
+            node = _step(node, seg, path)
+        kind, val = segs[-1]
+        if kind == "key":
+            if not isinstance(node, dict):
+                raise PathError("cannot delete key %r from %s in %r"
+                                % (val, type(node).__name__, path))
+            if val not in node:
+                raise PathError("missing key %r in %r" % (val, path))
+            del node[val]
+        else:
+            if not isinstance(node, list):
+                raise PathError("cannot delete index from %s in %r"
+                                % (type(node).__name__, path))
+            if not -len(node) <= val < len(node):
+                raise PathError("index %d out of range in %r" % (val, path))
+            node.pop(val)
+    except PathError:
+        if missing_ok:
+            return
+        raise
