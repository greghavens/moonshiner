+using System.Threading.Channels;
+
+namespace BagLine;
+
+/// <summary>One checked bag headed for the hold.</summary>
+public sealed record Bag(string Tag, string Flight);
+
+/// <summary>
+/// The makeup carousel between check-in and the tarmac: a bounded belt that
+/// check-in agents place bags onto and a single loader drains in placement
+/// order. All waiting is done by the channel — no timers, no polling.
+/// </summary>
+public sealed class MakeupCarousel
+{
+    private readonly Channel<Bag> _belt;
+
+    public MakeupCarousel(int capacity)
+    {
+        ArgumentOutOfRangeException.ThrowIfLessThan(capacity, 1);
+        Capacity = capacity;
+        _belt = Channel.CreateBounded<Bag>(new BoundedChannelOptions(capacity)
+        {
+            SingleReader = true,
+            SingleWriter = false,
+            FullMode = BoundedChannelFullMode.Wait,
+        });
+    }
+
+    public int Capacity { get; }
+
+    /// <summary>Place a bag, waiting for a free slot on a full belt.</summary>
+    public Task PlaceAsync(Bag bag, CancellationToken ct = default)
+        => _belt.Writer.WriteAsync(bag, ct).AsTask();
+
+    /// <summary>Non-waiting placement: false when the belt is full or closed.</summary>
+    public bool TryPlace(Bag bag) => _belt.Writer.TryWrite(bag);
+
+    /// <summary>No more bags for this flight; idempotent.</summary>
+    public void CloseFlight() => _belt.Writer.TryComplete();
+
+    /// <summary>
+    /// The single loader: drains bags strictly in placement order, one loader
+    /// callback in flight at a time, until the flight is closed and the belt
+    /// is empty. Returns the callback results in load order.
+    /// </summary>
+    public async Task<IReadOnlyList<string>> LoadAsync(Func<Bag, Task<string>> loader)
+    {
+        ArgumentNullException.ThrowIfNull(loader);
+        var loaded = new List<string>();
+        await foreach (var bag in _belt.Reader.ReadAllAsync())
+        {
+            loaded.Add(await loader(bag));
+        }
+        return loaded;
+    }
+}
