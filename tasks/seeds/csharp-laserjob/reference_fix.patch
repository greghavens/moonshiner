+using System.Text.Json;
+
+namespace LaserJob;
+
+/// <summary>Serialization entry point shared by the design station and the
+/// controller: compact camelCase JSON, byte-for-byte stable.</summary>
+public static class JobFile
+{
+    private static readonly JsonSerializerOptions Options = new()
+    {
+        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
+    };
+
+    public static string Serialize(IReadOnlyList<JobStep> steps)
+        => JsonSerializer.Serialize(steps, Options);
+
+    public static IReadOnlyList<JobStep> Deserialize(string json)
+        => JsonSerializer.Deserialize<IReadOnlyList<JobStep>>(json, Options)
+           ?? throw new JsonException("job file is null");
+}
