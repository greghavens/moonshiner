+using System.Globalization;
+using System.Text.Json;
+using System.Text.Json.Serialization;
+
+namespace LaserJob;
+
+/// <summary>One operation in a laser-cutter job file. The wire discriminator
+/// is the leading "op" property.</summary>
+[JsonPolymorphic(TypeDiscriminatorPropertyName = "op")]
+[JsonDerivedType(typeof(CutStep), "cut")]
+[JsonDerivedType(typeof(EngraveStep), "engrave")]
+[JsonDerivedType(typeof(PauseStep), "pause")]
+public abstract record JobStep;
+
+public sealed record CutStep(string Path, Speed Feed, int Passes) : JobStep;
+
+public sealed record EngraveStep(string Path, int Dpi, Speed Feed) : JobStep;
+
+public sealed record PauseStep(string Message) : JobStep;
+
+/// <summary>Head feed rate; travels on the wire as "&lt;decimal&gt;mm/s".</summary>
+[JsonConverter(typeof(SpeedJsonConverter))]
+public readonly record struct Speed(decimal MmPerSecond);
+
+/// <summary>Reads/writes <see cref="Speed"/> as an invariant-culture
+/// "&lt;decimal&gt;mm/s" string regardless of the thread culture.</summary>
+public sealed class SpeedJsonConverter : JsonConverter<Speed>
+{
+    public override Speed Read(ref Utf8JsonReader reader, Type typeToConvert, JsonSerializerOptions options)
+    {
+        if (reader.TokenType != JsonTokenType.String)
+            throw new JsonException("speed must be a string like '120mm/s'");
+        var raw = reader.GetString()!;
+        if (!raw.EndsWith("mm/s", StringComparison.Ordinal)
+            || !decimal.TryParse(raw[..^4], NumberStyles.Number, CultureInfo.InvariantCulture, out var value))
+        {
+            throw new JsonException($"invalid speed '{raw}'");
+        }
+        return new Speed(value);
+    }
+
+    public override void Write(Utf8JsonWriter writer, Speed value, JsonSerializerOptions options)
+        => writer.WriteStringValue(value.MmPerSecond.ToString(CultureInfo.InvariantCulture) + "mm/s");
+}
