index 0000000..657629e
--- /dev/null
+++ b/types.go
@@ -0,0 +1,77 @@
+// Package mbatch is a client for the Cisco Meraki Dashboard API v1
+// organization action-batch resource: it splits bulk changes by the
+// documented per-mode limits, submits them confirmed, polls asynchronous
+// batches to a terminal state, and correlates per-action failures.
+package mbatch
+
+import (
+	"fmt"
+	"strings"
+)
+
+// Action is one entry of an action batch. On the wire an action without a
+// Body omits the key entirely.
+type Action struct {
+	Resource  string         `json:"resource"`
+	Operation string         `json:"operation"`
+	Body      map[string]any `json:"body,omitempty"`
+}
+
+// CreatedResource is one status.createdResources entry.
+type CreatedResource struct {
+	ID  string `json:"id"`
+	URI string `json:"uri"`
+}
+
+// BatchStatus mirrors the documented status object of a batch document.
+type BatchStatus struct {
+	Completed        bool              `json:"completed"`
+	Failed           bool              `json:"failed"`
+	Errors           []string          `json:"errors"`
+	CreatedResources []CreatedResource `json:"createdResources"`
+}
+
+// Batch mirrors the documented action-batch document shared by the create
+// response and the status GET.
+type Batch struct {
+	ID             string      `json:"id"`
+	OrganizationID string      `json:"organizationId"`
+	Confirmed      bool        `json:"confirmed"`
+	Synchronous    bool        `json:"synchronous"`
+	Status         BatchStatus `json:"status"`
+	Actions        []Action    `json:"actions"`
+}
+
+// APIError is a non-success Dashboard API response: the HTTP status plus the
+// messages of the documented {"errors": [...]} envelope. The API key is
+// never included.
+type APIError struct {
+	Status int
+	Errors []string
+}
+
+func (e *APIError) Error() string {
+	return fmt.Sprintf("meraki api error %d: %s", e.Status, strings.Join(e.Errors, "; "))
+}
+
+// ActionError correlates one status error string to the action inside the
+// submitted batch whose resource path the message names.
+type ActionError struct {
+	BatchID     string
+	ActionIndex int
+	Resource    string
+	Message     string
+}
+
+// Report summarizes a Runner.Run invocation, including partial progress when
+// a batch fails or polling is exhausted.
+type Report struct {
+	BatchIDs           []string
+	SubmittedBatches   int
+	CompletedBatches   int
+	Polls              int
+	Throttled          int
+	CreatedResources   []CreatedResource
+	FailedBatchID      string
+	FailedActionErrors []ActionError
+}
