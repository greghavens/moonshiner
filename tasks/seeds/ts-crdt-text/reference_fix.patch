+// The character store: an anchor tree with tombstones and per-character
+// last-writer-wins visibility. Document order = pre-order walk, children of
+// each anchor sorted by id descending (newest hugs the anchor).
+
+import { compareIds, idKey } from './ids.ts';
+import type { OpId, InsertOp, DeleteOp, RestoreOp } from './ids.ts';
+
+type CharNode = {
+  id: OpId;
+  char: string;
+  visible: boolean;
+  writer: OpId;        // id of the op that last decided visibility
+  children: CharNode[]; // kept sorted descending by id
+};
+
+export type SnapshotEntry = { id: string; char: string; visible: boolean };
+
+export class Doc {
+  nodes = new Map<string, CharNode>();
+  roots: CharNode[] = [];
+
+  has(id: OpId): boolean {
+    return this.nodes.has(idKey(id));
+  }
+
+  addChar(op: InsertOp): void {
+    if (this.nodes.has(idKey(op.id))) return;
+    const node: CharNode = {
+      id: op.id,
+      char: op.char,
+      visible: true,
+      writer: op.id,
+      children: [],
+    };
+    this.nodes.set(idKey(op.id), node);
+    const siblings = op.after === null
+      ? this.roots
+      : (this.nodes.get(idKey(op.after)) as CharNode).children;
+    let i = 0;
+    while (i < siblings.length && compareIds(siblings[i].id, node.id) > 0) i++;
+    siblings.splice(i, 0, node);
+  }
+
+  setVisibility(op: DeleteOp | RestoreOp): void {
+    const node = this.nodes.get(idKey(op.target)) as CharNode;
+    if (compareIds(op.id, node.writer) > 0) {
+      node.visible = op.kind === 'restore';
+      node.writer = op.id;
+    }
+  }
+
+  walk(): CharNode[] {
+    const out: CharNode[] = [];
+    const stack: CharNode[] = [];
+    for (let i = this.roots.length - 1; i >= 0; i--) stack.push(this.roots[i]);
+    while (stack.length > 0) {
+      const node = stack.pop() as CharNode;
+      out.push(node);
+      for (let i = node.children.length - 1; i >= 0; i--) stack.push(node.children[i]);
+    }
+    return out;
+  }
+
+  visibleChars(): CharNode[] {
+    return this.walk().filter((n) => n.visible);
+  }
+
+  text(): string {
+    return this.visibleChars().map((n) => n.char).join('');
+  }
+
+  snapshot(): SnapshotEntry[] {
+    return this.walk().map((n) => ({
+      id: idKey(n.id),
+      char: n.char,
+      visible: n.visible,
+    }));
+  }
+}
