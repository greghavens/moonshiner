+// Per-site bookkeeping: which op ids have been seen (applied or buffered),
+// the ops this site generated, and the buffer for ops whose dependencies
+// have not arrived yet.
+
+import { idKey } from './ids.ts';
+import type { Op } from './ids.ts';
+
+export class OpLog {
+  seen = new Set<string>();
+  generated: Op[] = [];
+  buffered: Op[] = [];
+
+  isNew(op: Op): boolean {
+    return !this.seen.has(idKey(op.id));
+  }
+
+  markSeen(op: Op): void {
+    this.seen.add(idKey(op.id));
+  }
+
+  record(op: Op): void {
+    this.generated.push(op);
+  }
+
+  buffer(op: Op): void {
+    this.buffered.push(op);
+  }
+
+  pendingCount(): number {
+    return this.buffered.length;
+  }
+
+  // Repeatedly apply every buffered op whose dependencies are satisfied,
+  // until a full pass makes no progress.
+  drain(ready: (op: Op) => boolean, apply: (op: Op) => void): void {
+    let progress = true;
+    while (progress) {
+      progress = false;
+      for (let i = 0; i < this.buffered.length; i++) {
+        const op = this.buffered[i];
+        if (ready(op)) {
+          this.buffered.splice(i, 1);
+          i--;
+          apply(op);
+          progress = true;
+        }
+      }
+    }
+  }
+}
