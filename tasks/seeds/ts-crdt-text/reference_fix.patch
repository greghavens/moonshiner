@@ -0,0 +1,17 @@
+// Op identity: (clock, site) pairs, totally ordered. Bigger means later.
+
+export type OpId = { clock: number; site: number };
+
+export type InsertOp = { kind: 'insert'; id: OpId; after: OpId | null; char: string };
+export type DeleteOp = { kind: 'delete'; id: OpId; target: OpId };
+export type RestoreOp = { kind: 'restore'; id: OpId; target: OpId };
+export type Op = InsertOp | DeleteOp | RestoreOp;
+
+export function compareIds(a: OpId, b: OpId): number {
+  if (a.clock !== b.clock) return a.clock - b.clock;
+  return a.site - b.site;
+}
+
+export function idKey(id: OpId): string {
+  return `${id.clock}@${id.site}`;
+}
