+// A replication site: local editing, an undo stack over local actions, and
+// apply() as the only way ops ever move between sites.
+
+import { Doc } from './doc.ts';
+import { OpLog } from './oplog.ts';
+import type { Op, OpId, InsertOp, DeleteOp, RestoreOp } from './ids.ts';
+import type { SnapshotEntry } from './doc.ts';
+
+export class Site {
+  siteId: number;
+  clock = 0;
+  doc = new Doc();
+  oplog = new OpLog();
+  undoable: Op[][] = []; // one entry per not-yet-undone local action
+
+  constructor(siteId: number) {
+    if (!Number.isInteger(siteId) || siteId < 1) {
+      throw new RangeError('site id must be a positive integer');
+    }
+    this.siteId = siteId;
+  }
+
+  nextId(): OpId {
+    this.clock += 1;
+    return { clock: this.clock, site: this.siteId };
+  }
+
+  insert(index: number, text: string): Op[] {
+    const visible = this.doc.visibleChars();
+    if (!Number.isInteger(index) || index < 0 || index > visible.length) {
+      throw new RangeError('insert index out of range');
+    }
+    const chars = Array.from(text);
+    if (chars.length === 0) return [];
+    let after: OpId | null = index === 0 ? null : visible[index - 1].id;
+    const ops: Op[] = [];
+    for (const char of chars) {
+      const op: InsertOp = { kind: 'insert', id: this.nextId(), after, char };
+      this.emitLocal(op);
+      ops.push(op);
+      after = op.id;
+    }
+    this.undoable.push(ops);
+    return ops;
+  }
+
+  delete(index: number, count: number = 1): Op[] {
+    const visible = this.doc.visibleChars();
+    if (!Number.isInteger(index) || !Number.isInteger(count) || index < 0 ||
+        count < 0 || index + count > visible.length) {
+      throw new RangeError('delete range out of range');
+    }
+    if (count === 0) return [];
+    const targets = visible.slice(index, index + count).map((n) => n.id);
+    const ops: Op[] = [];
+    for (const target of targets) {
+      const op: DeleteOp = { kind: 'delete', id: this.nextId(), target };
+      this.emitLocal(op);
+      ops.push(op);
+    }
+    this.undoable.push(ops);
+    return ops;
+  }
+
+  undo(): Op[] | null {
+    const action = this.undoable.pop();
+    if (action === undefined) return null;
+    const ops: Op[] = [];
+    for (const original of action) {
+      let op: Op;
+      if (original.kind === 'insert') {
+        op = { kind: 'delete', id: this.nextId(), target: original.id };
+      } else {
+        op = {
+          kind: 'restore',
+          id: this.nextId(),
+          target: (original as DeleteOp).target,
+        };
+      }
+      this.emitLocal(op);
+      ops.push(op);
+    }
+    return ops;
+  }
+
+  apply(ops: Op[]): void {
+    for (const op of ops) {
+      if (!this.oplog.isNew(op)) continue;
+      this.oplog.markSeen(op);
+      this.clock = Math.max(this.clock, op.id.clock);
+      if (this.ready(op)) {
+        this.applyOp(op);
+      } else {
+        this.oplog.buffer(op);
+      }
+    }
+    this.oplog.drain((op) => this.ready(op), (op) => this.applyOp(op));
+  }
+
+  pending(): number {
+    return this.oplog.pendingCount();
+  }
+
+  text(): string {
+    return this.doc.text();
+  }
+
+  snapshot(): SnapshotEntry[] {
+    return this.doc.snapshot();
+  }
+
+  log(): Op[] {
+    return this.oplog.generated.slice();
+  }
+
+  // ---- internals ----------------------------------------------------------
+
+  emitLocal(op: Op): void {
+    this.oplog.markSeen(op);
+    this.oplog.record(op);
+    this.applyOp(op);
+  }
+
+  ready(op: Op): boolean {
+    if (op.kind === 'insert') {
+      return op.after === null || this.doc.has(op.after);
+    }
+    return this.doc.has(op.target);
+  }
+
+  applyOp(op: Op): void {
+    if (op.kind === 'insert') {
+      this.doc.addChar(op);
+    } else {
+      this.doc.setVisibility(op as DeleteOp | RestoreOp);
+    }
+  }
+}
