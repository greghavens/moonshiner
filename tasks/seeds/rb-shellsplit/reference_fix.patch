diff --git a/shell_line.rb b/shell_line.rb
new file mode 100644
index 0000000..93faca6
--- /dev/null
+++ b/shell_line.rb
@@ -0,0 +1,85 @@
+# POSIX-style command-line splitting and quoting for the job-card runner.
+# split turns an operator-pasted line into argv; escape/join render an argv
+# back into a copy-pasteable line. split(join(argv)) == argv always.
+module ShellLine
+  module_function
+
+  SAFE_WORD = /\A[A-Za-z0-9@%+=:,.\/_-]+\z/
+
+  DOUBLE_QUOTE_SPECIALS = ['"', "\\", "$", "`"].freeze
+
+  def split(line)
+    words = []
+    word = nil
+    i = 0
+    while i < line.length
+      case line[i]
+      when " ", "\t", "\n"
+        if word
+          words << word
+          word = nil
+        end
+        i += 1
+      when "'"
+        closing = line.index("'", i + 1)
+        raise ArgumentError, "unterminated single quote" unless closing
+
+        word = (word || "") + line[(i + 1)...closing]
+        i = closing + 1
+      when '"'
+        word = (word || "").dup
+        i = scan_double_quoted(line, i + 1, word)
+      when "\\"
+        nxt = line[i + 1]
+        raise ArgumentError, "line ends with a bare backslash" if nxt.nil?
+
+        word = (word || "") + nxt unless nxt == "\n"
+        i += 2
+      else
+        word = (word || "") + line[i]
+        i += 1
+      end
+    end
+    words << word if word
+    words
+  end
+
+  # Consumes a double-quoted section starting just after the opening quote,
+  # appending decoded characters to word; returns the index after the close.
+  def scan_double_quoted(line, i, word)
+    while i < line.length
+      ch = line[i]
+      case ch
+      when '"'
+        return i + 1
+      when "\\"
+        nxt = line[i + 1]
+        raise ArgumentError, "unterminated double quote" if nxt.nil?
+
+        if nxt == "\n"
+          # line continuation: both characters vanish
+        elsif DOUBLE_QUOTE_SPECIALS.include?(nxt)
+          word << nxt
+        else
+          word << "\\" << nxt
+        end
+        i += 2
+      else
+        word << ch
+        i += 1
+      end
+    end
+    raise ArgumentError, "unterminated double quote"
+  end
+
+  def escape(word)
+    return "''" if word.empty?
+    return word if word.match?(SAFE_WORD)
+
+    "'" + word.gsub("'") { "'\\''" } + "'"
+  end
+
+  def join(argv)
+    argv.map { |word| escape(word) }.join(" ")
+  end
+end
