+// Pure CORS decision engine: compile a policy once, evaluate requests as
+// plain data. No HTTP objects, no side effects.
+
+export interface CorsConfig {
+  origins: string[];
+  methods?: string[];
+  allowHeaders?: string[] | 'reflect';
+  exposeHeaders?: string[];
+  credentials?: boolean;
+  maxAge?: number;
+}
+
+export interface CorsRequest {
+  method: string;
+  headers: Record<string, string>;
+}
+
+export interface CorsDecision {
+  type: 'passthrough' | 'preflight' | 'actual';
+  allowed: boolean;
+  headers: Record<string, string>;
+}
+
+interface OriginRule {
+  kind: 'exact' | 'wildcard';
+  /** exact: full lowercased origin. wildcard: lowercased "scheme://" prefix. */
+  scheme: string;
+  /** wildcard only: lowercased required suffix without the leading "*". */
+  suffix: string;
+  exact: string;
+}
+
+const SIMPLE_METHODS = new Set(['GET', 'HEAD', 'POST']);
+const SAFELISTED_HEADERS = new Set(['accept', 'accept-language', 'content-language', 'content-type']);
+const SIMPLE_CONTENT_TYPES = new Set(['application/x-www-form-urlencoded', 'multipart/form-data', 'text/plain']);
+
+function compileOriginRule(entry: string): OriginRule {
+  const stars = entry.split('*').length - 1;
+  const schemeEnd = entry.indexOf('://');
+  if (entry === 'null') {
+    return { kind: 'exact', scheme: '', suffix: '', exact: 'null' };
+  }
+  if (schemeEnd <= 0) {
+    throw new TypeError(`origin entry ${JSON.stringify(entry)} is missing a scheme`);
+  }
+  const scheme = entry.slice(0, schemeEnd).toLowerCase();
+  const host = entry.slice(schemeEnd + 3);
+  if (stars === 0) {
+    return { kind: 'exact', scheme, suffix: '', exact: entry.toLowerCase() };
+  }
+  if (stars > 1) {
+    throw new TypeError(`origin entry ${JSON.stringify(entry)} has more than one wildcard`);
+  }
+  if (!host.startsWith('*.') || host.length === 2) {
+    throw new TypeError(`origin entry ${JSON.stringify(entry)}: the wildcard must be a full leading label`);
+  }
+  return { kind: 'wildcard', scheme, suffix: host.slice(1).toLowerCase(), exact: '' };
+}
+
+export class CorsPolicy {
+  readonly allowAll: boolean;
+  readonly credentials: boolean;
+  readonly methods: string[];
+  readonly allowHeaders: string[] | 'reflect';
+  readonly exposeHeaders: string[];
+  readonly maxAge: number | undefined;
+  private rules: OriginRule[];
+
+  constructor(config: CorsConfig) {
+    if (!Array.isArray(config.origins)) {
+      throw new TypeError('origins must be an array');
+    }
+    this.allowAll = config.origins.includes('*');
+    if (this.allowAll && config.origins.length > 1) {
+      throw new TypeError('"*" must be the only origin entry when present');
+    }
+    this.credentials = config.credentials === true;
+    if (this.allowAll && this.credentials) {
+      throw new TypeError('credentials cannot be combined with the "*" origin');
+    }
+    this.rules = this.allowAll ? [] : config.origins.map(compileOriginRule);
+    this.methods = (config.methods ?? ['GET', 'HEAD', 'POST']).map((m) => m.toUpperCase());
+    this.allowHeaders = config.allowHeaders ?? [];
+    this.exposeHeaders = config.exposeHeaders ?? [];
+    this.maxAge = config.maxAge;
+  }
+
+  /** Does the policy vary its answers by origin (i.e. anything but pure "*")? */
+  get varies(): boolean {
+    return !this.allowAll;
+  }
+
+  originAllowed(origin: string): boolean {
+    if (this.allowAll) return true;
+    const lower = origin.toLowerCase();
+    for (const rule of this.rules) {
+      if (rule.kind === 'exact') {
+        if (lower === rule.exact) return true;
+        continue;
+      }
+      const prefix = `${rule.scheme}://`;
+      if (!lower.startsWith(prefix)) continue;
+      const host = lower.slice(prefix.length);
+      // host must be <something>.<suffix-without-dot>, dots literal
+      if (host.length > rule.suffix.length && host.endsWith(rule.suffix)) return true;
+    }
+    return false;
+  }
+}
+
+export function compilePolicy(config: CorsConfig): CorsPolicy {
+  return new CorsPolicy(config);
+}
+
+function mediaTypeOf(contentType: string): string {
+  return contentType.split(';')[0].trim().toLowerCase();
+}
+
+export function needsPreflight(req: CorsRequest): boolean {
+  if (!SIMPLE_METHODS.has(req.method.toUpperCase())) return true;
+  for (const [name, value] of Object.entries(req.headers)) {
+    const lower = name.toLowerCase();
+    if (!SAFELISTED_HEADERS.has(lower)) return true;
+    if (lower === 'content-type' && !SIMPLE_CONTENT_TYPES.has(mediaTypeOf(value))) return true;
+  }
+  return false;
+}
+
+function lowerHeaders(headers: Record<string, string>): Record<string, string> {
+  const out: Record<string, string> = {};
+  for (const [name, value] of Object.entries(headers)) {
+    out[name.toLowerCase()] = value;
+  }
+  return out;
+}
+
+export function evaluate(policy: CorsPolicy, req: CorsRequest): CorsDecision {
+  const base: Record<string, string> = {};
+  if (policy.varies) base.vary = 'Origin';
+
+  const headers = lowerHeaders(req.headers);
+  const origin = headers.origin;
+  if (origin === undefined) {
+    return { type: 'passthrough', allowed: true, headers: base };
+  }
+
+  const requestMethod = headers['access-control-request-method'];
+  const isPreflight = req.method.toUpperCase() === 'OPTIONS' && requestMethod !== undefined;
+  const type = isPreflight ? 'preflight' : 'actual';
+
+  const deny = (): CorsDecision => ({ type, allowed: false, headers: base });
+  if (!policy.originAllowed(origin)) return deny();
+
+  const allowOrigin = policy.allowAll && !policy.credentials ? '*' : origin;
+  const grant: Record<string, string> = { ...base, 'access-control-allow-origin': allowOrigin };
+  if (policy.credentials) grant['access-control-allow-credentials'] = 'true';
+
+  if (!isPreflight) {
+    if (policy.exposeHeaders.length > 0) {
+      grant['access-control-expose-headers'] = policy.exposeHeaders.join(', ');
+    }
+    return { type, allowed: true, headers: grant };
+  }
+
+  if (!policy.methods.includes(requestMethod.trim().toUpperCase())) return deny();
+
+  const requestedHeaders = headers['access-control-request-headers'];
+  if (requestedHeaders !== undefined) {
+    if (policy.allowHeaders === 'reflect') {
+      grant['access-control-allow-headers'] = requestedHeaders;
+    } else {
+      const allowSet = new Set(policy.allowHeaders.map((h) => h.toLowerCase()));
+      const wanted = requestedHeaders.split(',').map((h) => h.trim().toLowerCase()).filter((h) => h.length > 0);
+      if (!wanted.every((h) => allowSet.has(h))) return deny();
+      grant['access-control-allow-headers'] = policy.allowHeaders.join(', ');
+    }
+  }
+
+  grant['access-control-allow-methods'] = policy.methods.join(', ');
+  if (policy.maxAge !== undefined) {
+    grant['access-control-max-age'] = String(Math.floor(policy.maxAge));
+  }
+  return { type, allowed: true, headers: grant };
+}
