+export type Clock = () => number;
+
+export interface OAuthOptions {
+  tokenUrl: string;
+  clientId: string;
+  clientSecret: string;
+  scopes: string[];
+  clock: Clock;
+}
+
+// Platform bearer tokens live 300 seconds; refresh this many seconds early
+// so an in-flight request never rides an expiring token.
+const REFRESH_SKEW_SECONDS = 30;
+
+/**
+ * Client-credentials token provider for the Dynatrace SSO
+ * (https://sso.dynatrace.com/sso/oauth2/token in production). Tokens are
+ * cached against the injected clock and re-fetched once inside the skew
+ * window of their expiry.
+ */
+export class OAuthTokenProvider {
+  private readonly opts: OAuthOptions;
+  private cached: { token: string; refreshAt: number } | null = null;
+
+  constructor(opts: OAuthOptions) {
+    this.opts = opts;
+  }
+
+  async getToken(): Promise<string> {
+    const now = this.opts.clock();
+    if (this.cached !== null && now < this.cached.refreshAt) {
+      return this.cached.token;
+    }
+    const form = new URLSearchParams({
+      grant_type: "client_credentials",
+      client_id: this.opts.clientId,
+      client_secret: this.opts.clientSecret,
+      scope: this.opts.scopes.join(" "),
+    });
+    const response = await fetch(this.opts.tokenUrl, {
+      method: "POST",
+      headers: { "content-type": "application/x-www-form-urlencoded" },
+      body: form.toString(),
+    });
+    if (!response.ok) {
+      // Never echo the request body here: it carries the client secret.
+      throw new Error(`token request failed with status ${response.status}`);
+    }
+    const doc = (await response.json()) as { access_token: string; expires_in?: number };
+    const lifetime = doc.expires_in ?? 300;
+    this.cached = {
+      token: doc.access_token,
+      refreshAt: now + (lifetime - REFRESH_SKEW_SECONDS) * 1000,
+    };
+    return doc.access_token;
+  }
+
+  invalidate(): void {
+    this.cached = null;
+  }
+}
diff --git a/src/client.ts b/src/client.ts
