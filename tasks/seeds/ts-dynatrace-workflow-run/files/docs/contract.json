{
  "product": "Dynatrace AutomationEngine (Workflows) platform API",
  "oauth": {
    "token_url_path": "/sso/oauth2/token",
    "production_token_url": "https://sso.dynatrace.com/sso/oauth2/token",
    "grant_type": "client_credentials",
    "body_encoding": "application/x-www-form-urlencoded",
    "body_params": ["grant_type", "client_id", "client_secret", "scope"],
    "scopes": ["automation:workflows:run", "automation:workflows:read"],
    "scope_separator": " ",
    "response": {"access_token": "bearer token", "token_type": "Bearer", "expires_in": 300},
    "token_lifetime_seconds": 300,
    "refresh_skew_seconds": 30,
    "usage": "Authorization: Bearer <access_token> on every platform API request; the token and client secret must never travel in a URL or an error message",
    "fixture_client_id": "dt0s02.FAKECLIENT",
    "fixture_client_secret": "dt0s02.FAKECLIENT.FAKESECRETFAKESECRETFAKESECRETFAKESECRETFAKESECRETFAKESECR",
    "fixture_tokens": ["fake-bearer-token-one", "fake-bearer-token-two"]
  },
  "platform": {
    "base_url_pattern": "https://{environment-id}.apps.dynatrace.com",
    "classic_host_marker": ".live.dynatrace.com",
    "note": "platform APIs are served from the apps.dynatrace.com environment URL; {env}.live.dynatrace.com hosts only the classic environment APIs and must be rejected"
  },
  "endpoints": {
    "run_workflow": {
      "method": "POST",
      "path": "/platform/automation/v1/workflows/{workflowId}/run",
      "body_keys_optional": ["input", "params", "uniqueQualifier"],
      "body_rule": "only the provided keys are sent; input is flat key/value pairs, params may nest, uniqueQualifier deduplicates executions",
      "created_status": 201,
      "duplicate_status": 202,
      "duplicate_meaning": "no execution created - an execution with the provided uniqueQualifier already exists; the response body is the existing execution"
    },
    "get_execution": {
      "method": "GET",
      "path": "/platform/automation/v1/executions/{executionId}",
      "state_enum": ["CANCELLED", "ERROR", "PAUSED", "RUNNING", "SUCCESS", "UNKNOWN"],
      "terminal_states": ["CANCELLED", "ERROR", "SUCCESS"],
      "non_terminal_states": ["RUNNING", "PAUSED", "UNKNOWN"],
      "error_detail_fields": ["state", "stateInfo"]
    },
    "list_executions": {
      "method": "GET",
      "path": "/platform/automation/v1/executions",
      "query_params": {"workflow": "workflow id filter", "state": "multiple values separated by commas in one parameter", "limit": "page size", "offset": "starting index"},
      "response": {"count": "total matching executions", "results": "executions on this page"}
    },
    "get_task_executions": {
      "method": "GET",
      "path": "/platform/automation/v1/executions/{executionId}/tasks",
      "response": "an object mapping task name to its task execution (not an array)",
      "task_state_enum": ["CANCELLED", "DISCARDED", "ERROR", "IDLE", "RUNNING", "AWAITING_APPROVAL", "SKIPPED", "SUCCESS", "WAITING", "UNKNOWN", "POST_PROCESSING"],
      "result_bearing_states": ["SUCCESS", "ERROR"]
    },
    "get_task_result": {
      "method": "GET",
      "path": "/platform/automation/v1/executions/{executionId}/tasks/{taskName}/result",
      "response": "the merged result of the task's action executions"
    }
  },
  "errors": {
    "shape": {"detail": "human-readable platform error detail"},
    "rule": "non-2xx responses surface AutomationApiError with status, parsed detail when present, and the raw body; a 401 invalidates the cached token and the request is retried once with a fresh token"
  },
  "fixtures": {
    "workflow_id": "5e1c5e1c-aaaa-bbbb-cccc-000123456789",
    "execution": {
      "id": "9d1f0e2a-1111-2222-3333-444455556666",
      "workflow": "5e1c5e1c-aaaa-bbbb-cccc-000123456789",
      "state": "RUNNING",
      "stateInfo": null,
      "startedAt": "2026-07-17T11:41:02.113000Z",
      "endedAt": null,
      "runtime": 4,
      "title": "nightly-cache-warmup",
      "triggerType": "Manual",
      "workflowType": "STANDARD"
    },
    "error_state_info": "Task fetch_logs failed: upstream returned 503 (loop iteration 2)",
    "tasks": {
      "cleanup": {"name": "cleanup", "state": "SKIPPED", "predecessors": ["notify"]},
      "fetch_logs": {"name": "fetch_logs", "state": "SUCCESS", "predecessors": []},
      "notify": {"name": "notify", "state": "ERROR", "predecessors": ["fetch_logs"]}
    },
    "task_results": {
      "fetch_logs": {"records": 128, "bucket": "default_logs"},
      "notify": {"error": "webhook returned 410", "attempts": 3}
    },
    "error_404": {"detail": "Not found."}
  }
}
