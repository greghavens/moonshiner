+# stencil.ps1 — {{key}} template expansion for the maintenance notices.
+# Manual scan only: template text is data, never code.
+
+function Get-StencilTokens {
+    # Shared scanner. Emits literal/token pieces left to right and enforces
+    # the escape, unclosed-token, and key-charset rules in one place.
+    param([Parameter(Mandatory)][AllowEmptyString()][string]$Template)
+    $pieces = [System.Collections.Generic.List[object]]::new()
+    $i = 0
+    $lit = [System.Text.StringBuilder]::new()
+    while ($i -lt $Template.Length) {
+        $open = $Template.IndexOf('{{', $i, [System.StringComparison]::Ordinal)
+        if ($open -lt 0) {
+            [void]$lit.Append($Template.Substring($i))
+            break
+        }
+        [void]$lit.Append($Template.Substring($i, $open - $i))
+        if (($open + 4) -le $Template.Length -and $Template.Substring($open + 2, 2) -eq '{{') {
+            [void]$lit.Append('{{')
+            $i = $open + 4
+            continue
+        }
+        $close = $Template.IndexOf('}}', $open + 2, [System.StringComparison]::Ordinal)
+        if ($close -lt 0) {
+            throw "stencil: unclosed token at offset $open"
+        }
+        $key = $Template.Substring($open + 2, $close - $open - 2)
+        if ($key.Length -eq 0 -or -not [regex]::IsMatch($key, '^[A-Za-z0-9_.]+$')) {
+            throw "stencil: invalid key: $key"
+        }
+        if ($lit.Length -gt 0) {
+            $pieces.Add(@{ Kind = 'lit'; Text = $lit.ToString() })
+            [void]$lit.Clear()
+        }
+        $pieces.Add(@{ Kind = 'key'; Key = $key })
+        $i = $close + 2
+    }
+    if ($lit.Length -gt 0) {
+        $pieces.Add(@{ Kind = 'lit'; Text = $lit.ToString() })
+    }
+    return $pieces
+}
+
+function Expand-Stencil {
+    param(
+        [Parameter(Mandatory)][AllowEmptyString()][string]$Template,
+        [Parameter(Mandatory)][hashtable]$Values,
+        [ValidateSet('Error', 'Empty', 'Keep')][string]$OnMissing = 'Error'
+    )
+    $out = [System.Text.StringBuilder]::new()
+    foreach ($piece in Get-StencilTokens -Template $Template) {
+        if ($piece.Kind -eq 'lit') {
+            [void]$out.Append($piece.Text)
+            continue
+        }
+        $key = $piece.Key
+        # @{} lookups are case-insensitive; template keys are not. Scan the
+        # real key set ordinally instead of trusting ContainsKey.
+        $found = $false
+        foreach ($k in $Values.Keys) {
+            if ([string]$k -ceq $key) {
+                [void]$out.Append([string]$Values[$k])
+                $found = $true
+                break
+            }
+        }
+        if ($found) { continue }
+        switch ($OnMissing) {
+            'Error' { throw "stencil: missing key: $key" }
+            'Empty' { }
+            'Keep' { [void]$out.Append('{{' + $key + '}}') }
+        }
+    }
+    return $out.ToString()
+}
+
+function Get-StencilKeys {
+    param([Parameter(Mandatory)][AllowEmptyString()][string]$Template)
+    $keys = [System.Collections.Generic.List[string]]::new()
+    foreach ($piece in Get-StencilTokens -Template $Template) {
+        if ($piece.Kind -eq 'key' -and -not $keys.Contains($piece.Key)) {
+            $keys.Add($piece.Key)
+        }
+    }
+    $sorted = $keys.ToArray()
+    [System.Array]::Sort($sorted, [System.StringComparer]::Ordinal)
+    return $sorted
+}
