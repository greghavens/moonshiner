+"""Normalize editor HTML fragments down to the markup the preview stack supports.
+
+One shared cleanup pass for comment previews and review blurbs: a tag
+allowlist, per-tag attribute allowlists, and a URL-scheme policy for link
+attributes. Built on html.parser, stdlib only.
+"""
+import urllib.parse
+from html.parser import HTMLParser
+
+DEFAULT_TAGS = frozenset({
+    "p", "br", "hr", "b", "i", "em", "strong", "u", "s", "code", "pre",
+    "blockquote", "ul", "ol", "li", "a", "img", "h1", "h2", "h3",
+})
+
+# tag -> attribute names; "*" applies to every supported tag
+DEFAULT_ATTRS = {
+    "a": {"href"},
+    "img": {"src", "alt", "width", "height"},
+    "*": {"class", "title"},
+}
+
+DEFAULT_SCHEMES = frozenset({"http", "https", "mailto"})
+
+_VOID_TAGS = {"br", "hr", "img"}
+_DROP_BODY_TAGS = {"script", "style"}  # code, not prose: never unwrapped
+_URL_ATTRS = {"href", "src"}
+
+
+def _escape_text(text):
+    return text.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
+
+
+def _escape_attr(value):
+    return _escape_text(value).replace('"', "&quot;")
+
+
+def _url_allowed(value, schemes):
+    try:
+        scheme = urllib.parse.urlsplit(value.strip()).scheme
+    except ValueError:
+        return False
+    return scheme == "" or scheme.lower() in schemes
+
+
+class _Cleaner(HTMLParser):
+    """Streams the fragment back out, keeping only policy-approved markup."""
+
+    def __init__(self, tags, attrs, schemes):
+        super().__init__(convert_charrefs=True)
+        self._tags = tags
+        self._attrs = attrs
+        self._schemes = schemes
+        self._out = []
+        self._stack = []      # open non-void supported tags
+        self._drop_body = 0   # > 0 while inside script/style
+
+    # -- tag stream ---------------------------------------------------------
+
+    def handle_starttag(self, tag, attrs):
+        if tag in _DROP_BODY_TAGS:
+            self._drop_body += 1
+            return
+        if self._drop_body or tag not in self._tags:
+            return  # unwrapped: children still render, the tag does not
+        self._out.append(self._render_tag(tag, attrs))
+        if tag not in _VOID_TAGS:
+            self._stack.append(tag)
+
+    def handle_startendtag(self, tag, attrs):
+        if tag in _DROP_BODY_TAGS or self._drop_body or tag not in self._tags:
+            return
+        self._out.append(self._render_tag(tag, attrs))
+        if tag not in _VOID_TAGS:
+            self._out.append("</%s>" % tag)
+
+    def handle_endtag(self, tag):
+        if tag in _DROP_BODY_TAGS:
+            if self._drop_body:
+                self._drop_body -= 1
+            return
+        if self._drop_body or tag not in self._stack:
+            return  # stray or unwrapped close tag: ignored
+        while True:  # a close tag closes everything opened inside it
+            open_tag = self._stack.pop()
+            self._out.append("</%s>" % open_tag)
+            if open_tag == tag:
+                break
+
+    def handle_data(self, data):
+        if not self._drop_body:
+            self._out.append(_escape_text(data))
+
+    # comments, doctype and processing instructions fall through to the
+    # HTMLParser no-op handlers and never reach the output
+
+    # -- rendering ------------------------------------------------------------
+
+    def _render_tag(self, tag, attrs):
+        allowed = self._attrs.get(tag, set()) | self._attrs.get("*", set())
+        parts = ["<" + tag]
+        for name, value in attrs:
+            if name.startswith("on") or name not in allowed:
+                continue  # event-handler attributes are never in the allowlist
+            value = value or ""
+            if name in _URL_ATTRS and not _url_allowed(value, self._schemes):
+                continue  # unsupported scheme: drop the attribute, keep the tag
+            parts.append(' %s="%s"' % (name, _escape_attr(value)))
+        parts.append(">")
+        return "".join(parts)
+
+    def result(self):
+        while self._stack:  # close whatever the fragment left open
+            self._out.append("</%s>" % self._stack.pop())
+        return "".join(self._out)
+
+
+def clean_html(html, tags=None, attrs=None, schemes=None):
+    """Return the fragment reduced to policy-approved markup."""
+    cleaner = _Cleaner(
+        DEFAULT_TAGS if tags is None else tags,
+        DEFAULT_ATTRS if attrs is None else attrs,
+        DEFAULT_SCHEMES if schemes is None else schemes,
+    )
+    cleaner.feed(html)
+    cleaner.close()
+    return cleaner.result()
