+// Package pokereval evaluates Texas hold'em hands: the best five-card poker
+// hand out of seven cards, with full category ranking and kickers, plus
+// multi-way showdown resolution including split pots.
+package pokereval
+
+import (
+	"errors"
+	"fmt"
+	"sort"
+	"strings"
+)
+
+// Card is a playing card. Rank runs 2..14 (11 jack, 12 queen, 13 king,
+// 14 ace); Suit is one of 'c', 'd', 'h', 's'.
+type Card struct {
+	Rank int
+	Suit byte
+}
+
+const rankChars = "23456789TJQKA"
+
+// ParseCard reads the two-character form: rank in "23456789TJQKA", suit in
+// "cdhs" — e.g. "As", "Td", "2c".
+func ParseCard(s string) (Card, error) {
+	if len(s) != 2 {
+		return Card{}, fmt.Errorf("pokereval: bad card %q", s)
+	}
+	r := strings.IndexByte(rankChars, s[0])
+	if r < 0 {
+		return Card{}, fmt.Errorf("pokereval: bad rank in %q", s)
+	}
+	switch s[1] {
+	case 'c', 'd', 'h', 's':
+	default:
+		return Card{}, fmt.Errorf("pokereval: bad suit in %q", s)
+	}
+	return Card{Rank: r + 2, Suit: s[1]}, nil
+}
+
+// ParseCards reads whitespace-separated cards.
+func ParseCards(s string) ([]Card, error) {
+	fields := strings.Fields(s)
+	cards := make([]Card, 0, len(fields))
+	for _, f := range fields {
+		c, err := ParseCard(f)
+		if err != nil {
+			return nil, err
+		}
+		cards = append(cards, c)
+	}
+	return cards, nil
+}
+
+// String returns the canonical two-character form.
+func (c Card) String() string {
+	if c.Rank < 2 || c.Rank > 14 {
+		return "??"
+	}
+	return string([]byte{rankChars[c.Rank-2], c.Suit})
+}
+
+// Category is a poker hand class, ordered weakest to strongest.
+type Category int
+
+const (
+	HighCard Category = iota + 1
+	OnePair
+	TwoPair
+	ThreeOfAKind
+	Straight
+	Flush
+	FullHouse
+	FourOfAKind
+	StraightFlush
+)
+
+var categoryNames = map[Category]string{
+	HighCard:      "high-card",
+	OnePair:       "one-pair",
+	TwoPair:       "two-pair",
+	ThreeOfAKind:  "three-of-a-kind",
+	Straight:      "straight",
+	Flush:         "flush",
+	FullHouse:     "full-house",
+	FourOfAKind:   "four-of-a-kind",
+	StraightFlush: "straight-flush",
+}
+
+func (c Category) String() string {
+	if n, ok := categoryNames[c]; ok {
+		return n
+	}
+	return fmt.Sprintf("category(%d)", int(c))
+}
+
+// Hand is an evaluated five-card hand: the category plus its tiebreak
+// ranks, most significant first.
+type Hand struct {
+	Category Category
+	Ranks    []int
+}
+
+// Compare orders hands: -1 if a loses to b, 0 if they tie exactly, 1 if a
+// beats b.
+func Compare(a, b Hand) int {
+	if a.Category != b.Category {
+		if a.Category < b.Category {
+			return -1
+		}
+		return 1
+	}
+	for i := 0; i < len(a.Ranks) && i < len(b.Ranks); i++ {
+		if a.Ranks[i] != b.Ranks[i] {
+			if a.Ranks[i] < b.Ranks[i] {
+				return -1
+			}
+			return 1
+		}
+	}
+	return 0
+}
+
+// straightHigh returns the high card of a straight formed by exactly the
+// five distinct ranks given (sorted descending), or 0 if none. The wheel
+// A-2-3-4-5 counts with high card 5.
+func straightHigh(desc []int) int {
+	if len(desc) != 5 {
+		return 0
+	}
+	if desc[0]-desc[4] == 4 {
+		return desc[0]
+	}
+	if desc[0] == 14 && desc[1] == 5 && desc[1]-desc[4] == 3 {
+		return 5
+	}
+	return 0
+}
+
+func eval5(cards []Card) Hand {
+	counts := map[int]int{}
+	flush := true
+	for i, c := range cards {
+		counts[c.Rank]++
+		if i > 0 && c.Suit != cards[0].Suit {
+			flush = false
+		}
+	}
+	// Group ranks by multiplicity, then rank, descending.
+	type group struct{ rank, n int }
+	groups := make([]group, 0, len(counts))
+	for r, n := range counts {
+		groups = append(groups, group{r, n})
+	}
+	sort.Slice(groups, func(i, j int) bool {
+		if groups[i].n != groups[j].n {
+			return groups[i].n > groups[j].n
+		}
+		return groups[i].rank > groups[j].rank
+	})
+	ranked := make([]int, 0, 5)
+	for _, g := range groups {
+		for i := 0; i < g.n; i++ {
+			ranked = append(ranked, g.rank)
+		}
+	}
+
+	var high int
+	if len(counts) == 5 {
+		high = straightHigh(ranked)
+	}
+	switch {
+	case flush && high > 0:
+		return Hand{StraightFlush, []int{high}}
+	case groups[0].n == 4:
+		return Hand{FourOfAKind, []int{groups[0].rank, groups[1].rank}}
+	case groups[0].n == 3 && groups[1].n == 2:
+		return Hand{FullHouse, []int{groups[0].rank, groups[1].rank}}
+	case flush:
+		return Hand{Flush, ranked}
+	case high > 0:
+		return Hand{Straight, []int{high}}
+	case groups[0].n == 3:
+		return Hand{ThreeOfAKind, []int{groups[0].rank, groups[1].rank, groups[2].rank}}
+	case groups[0].n == 2 && groups[1].n == 2:
+		return Hand{TwoPair, []int{groups[0].rank, groups[1].rank, groups[2].rank}}
+	case groups[0].n == 2:
+		return Hand{OnePair, []int{groups[0].rank, groups[1].rank, groups[2].rank, groups[3].rank}}
+	default:
+		return Hand{HighCard, ranked}
+	}
+}
+
+func checkDistinct(cards []Card) error {
+	seen := map[Card]bool{}
+	for _, c := range cards {
+		if seen[c] {
+			return fmt.Errorf("pokereval: duplicate card %s", c)
+		}
+		seen[c] = true
+	}
+	return nil
+}
+
+// Eval7 returns the best five-card hand out of exactly seven distinct cards.
+func Eval7(cards []Card) (Hand, error) {
+	if len(cards) != 7 {
+		return Hand{}, fmt.Errorf("pokereval: Eval7 needs 7 cards, got %d", len(cards))
+	}
+	if err := checkDistinct(cards); err != nil {
+		return Hand{}, err
+	}
+	var best Hand
+	pick := make([]Card, 0, 5)
+	// All 21 ways to drop two of the seven.
+	for i := 0; i < len(cards); i++ {
+		for j := i + 1; j < len(cards); j++ {
+			pick = pick[:0]
+			for k, c := range cards {
+				if k != i && k != j {
+					pick = append(pick, c)
+				}
+			}
+			h := eval5(pick)
+			if best.Category == 0 || Compare(h, best) > 0 {
+				best = h
+			}
+		}
+	}
+	return best, nil
+}
+
+// Showdown resolves a hand: five community cards and one two-card hole per
+// player. It returns the ascending indices of the winning (pot-splitting)
+// players and every player's evaluated hand.
+func Showdown(community []Card, holes [][]Card) ([]int, []Hand, error) {
+	if len(community) != 5 {
+		return nil, nil, fmt.Errorf("pokereval: need 5 community cards, got %d", len(community))
+	}
+	if len(holes) == 0 {
+		return nil, nil, errors.New("pokereval: no players")
+	}
+	all := append([]Card(nil), community...)
+	for i, h := range holes {
+		if len(h) != 2 {
+			return nil, nil, fmt.Errorf("pokereval: player %d has %d hole cards, want 2", i, len(h))
+		}
+		all = append(all, h...)
+	}
+	if err := checkDistinct(all); err != nil {
+		return nil, nil, err
+	}
+	hands := make([]Hand, len(holes))
+	for i, h := range holes {
+		seven := append(append([]Card(nil), community...), h...)
+		hand, err := Eval7(seven)
+		if err != nil {
+			return nil, nil, err
+		}
+		hands[i] = hand
+	}
+	winners := []int{0}
+	for i := 1; i < len(hands); i++ {
+		switch Compare(hands[i], hands[winners[0]]) {
+		case 1:
+			winners = []int{i}
+		case 0:
+			winners = append(winners, i)
+		}
+	}
+	return winners, hands, nil
+}
