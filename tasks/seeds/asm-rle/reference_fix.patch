diff --git a/rle.s b/rle.s
new file mode 100644
index 0000000..9341b56
--- /dev/null
+++ b/rle.s
@@ -0,0 +1,78 @@
+# Run-length codec over (count, byte) pairs with a hard capacity contract:
+# nothing is ever stored at dst[cap] or beyond; -1 the moment a write
+# would not fit. System V AMD64: rdi=src, rsi=n, rdx=dst, rcx=cap.
+	.text
+
+	.globl	rle_encode
+	.type	rle_encode, @function
+rle_encode:
+	xorq	%r8, %r8		# read index
+	xorq	%r9, %r9		# write index
+.Lenc:
+	cmpq	%rsi, %r8
+	jge	.Lenc_done
+	movzbl	(%rdi,%r8), %eax	# run value
+	movq	%r8, %r10		# run start
+	incq	%r8
+.Lrun:
+	cmpq	%rsi, %r8		# extend while equal, capped at 255
+	jge	.Lrun_end
+	cmpb	%al, (%rdi,%r8)
+	jne	.Lrun_end
+	movq	%r8, %r11
+	subq	%r10, %r11
+	cmpq	$255, %r11
+	jge	.Lrun_end
+	incq	%r8
+	jmp	.Lrun
+.Lrun_end:
+	movq	%r8, %r11		# run length, 1..255
+	subq	%r10, %r11
+	leaq	2(%r9), %r10		# the pair must fit below cap
+	cmpq	%rcx, %r10
+	jg	.Lenc_fail
+	movb	%r11b, (%rdx,%r9)
+	movb	%al, 1(%rdx,%r9)
+	movq	%r10, %r9
+	jmp	.Lenc
+.Lenc_done:
+	movq	%r9, %rax
+	ret
+.Lenc_fail:
+	movq	$-1, %rax
+	ret
+	.size	rle_encode, .-rle_encode
+
+	.globl	rle_decode
+	.type	rle_decode, @function
+rle_decode:
+	testq	$1, %rsi		# a valid stream is whole pairs
+	jnz	.Ldec_fail
+	xorq	%r8, %r8		# read index
+	xorq	%r9, %r9		# write index
+.Ldec:
+	cmpq	%rsi, %r8
+	jge	.Ldec_done
+	movzbq	(%rdi,%r8), %r10	# count, must be nonzero
+	testq	%r10, %r10
+	jz	.Ldec_fail
+	movzbl	1(%rdi,%r8), %eax	# fill value
+	leaq	(%r9,%r10), %r11	# expanded run must fit below cap
+	cmpq	%rcx, %r11
+	jg	.Ldec_fail
+.Lfill:
+	movb	%al, (%rdx,%r9)
+	incq	%r9
+	decq	%r10
+	jnz	.Lfill
+	addq	$2, %r8
+	jmp	.Ldec
+.Ldec_done:
+	movq	%r9, %rax
+	ret
+.Ldec_fail:
+	movq	$-1, %rax
+	ret
+	.size	rle_decode, .-rle_decode
+
+	.section .note.GNU-stack,"",@progbits
