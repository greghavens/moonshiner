+//! Sudoku toolbox for the puzzle desk: parser, validator, backtracking
+//! solver with a pinned search order, and a solution counter used as a
+//! uniqueness checker.
+
+pub type Grid = [[u8; 9]; 9];
+
+pub fn parse(text: &str) -> Result<Grid, String> {
+    let rows: Vec<&str> = text.lines().map(|l| l.trim_end()).filter(|l| !l.is_empty()).collect();
+    if rows.len() != 9 {
+        return Err(format!("expected 9 rows, got {}", rows.len()));
+    }
+    let mut g: Grid = [[0; 9]; 9];
+    for (r, line) in rows.iter().enumerate() {
+        let cells: Vec<char> = line.chars().collect();
+        if cells.len() != 9 {
+            return Err(format!("row {} must be 9 cells, got {}", r + 1, cells.len()));
+        }
+        for (c, ch) in cells.iter().enumerate() {
+            g[r][c] = match ch {
+                '.' => 0,
+                '1'..='9' => *ch as u8 - b'0',
+                _ => return Err(format!("bad cell at row {} col {}: '{}'", r + 1, c + 1, ch)),
+            };
+        }
+    }
+    Ok(g)
+}
+
+pub fn render(g: &Grid) -> String {
+    g.iter()
+        .map(|row| {
+            row.iter()
+                .map(|&v| if v == 0 { '.' } else { (b'0' + v) as char })
+                .collect::<String>()
+        })
+        .collect::<Vec<_>>()
+        .join("\n")
+}
+
+/// First duplicate wins, scanning all rows top to bottom, then all columns
+/// left to right, then all boxes in row-major box order.
+pub fn validate(g: &Grid) -> Result<(), String> {
+    for r in 0..9 {
+        let mut seen = [false; 10];
+        for c in 0..9 {
+            let v = g[r][c] as usize;
+            if v != 0 {
+                if seen[v] {
+                    return Err(format!("duplicate {} in row {}", v, r + 1));
+                }
+                seen[v] = true;
+            }
+        }
+    }
+    for c in 0..9 {
+        let mut seen = [false; 10];
+        for r in 0..9 {
+            let v = g[r][c] as usize;
+            if v != 0 {
+                if seen[v] {
+                    return Err(format!("duplicate {} in column {}", v, c + 1));
+                }
+                seen[v] = true;
+            }
+        }
+    }
+    for b in 0..9 {
+        let (r0, c0) = (b / 3 * 3, b % 3 * 3);
+        let mut seen = [false; 10];
+        for i in 0..9 {
+            let v = g[r0 + i / 3][c0 + i % 3] as usize;
+            if v != 0 {
+                if seen[v] {
+                    return Err(format!("duplicate {} in box {}", v, b + 1));
+                }
+                seen[v] = true;
+            }
+        }
+    }
+    Ok(())
+}
+
+pub fn is_complete(g: &Grid) -> bool {
+    g.iter().all(|row| row.iter().all(|&v| v != 0)) && validate(g).is_ok()
+}
+
+fn fits(g: &Grid, r: usize, c: usize, v: u8) -> bool {
+    for i in 0..9 {
+        if g[r][i] == v || g[i][c] == v {
+            return false;
+        }
+    }
+    let (r0, c0) = (r / 3 * 3, c / 3 * 3);
+    for i in 0..9 {
+        if g[r0 + i / 3][c0 + i % 3] == v {
+            return false;
+        }
+    }
+    true
+}
+
+fn first_empty(g: &Grid) -> Option<(usize, usize)> {
+    for r in 0..9 {
+        for c in 0..9 {
+            if g[r][c] == 0 {
+                return Some((r, c));
+            }
+        }
+    }
+    None
+}
+
+fn search(g: &mut Grid, cap: u32, found: &mut u32, keep: &mut Option<Grid>) {
+    if *found >= cap {
+        return;
+    }
+    let (r, c) = match first_empty(g) {
+        None => {
+            if keep.is_none() {
+                *keep = Some(*g);
+            }
+            *found += 1;
+            return;
+        }
+        Some(rc) => rc,
+    };
+    for v in 1..=9 {
+        if fits(g, r, c, v) {
+            g[r][c] = v;
+            search(g, cap, found, keep);
+            g[r][c] = 0;
+            if *found >= cap {
+                return;
+            }
+        }
+    }
+}
+
+pub fn solve(g: &Grid) -> Option<Grid> {
+    if validate(g).is_err() {
+        return None;
+    }
+    let mut work = *g;
+    let mut found = 0;
+    let mut keep = None;
+    search(&mut work, 1, &mut found, &mut keep);
+    keep
+}
+
+pub fn count_solutions(g: &Grid, cap: u32) -> u32 {
+    if cap == 0 || validate(g).is_err() {
+        return 0;
+    }
+    let mut work = *g;
+    let mut found = 0;
+    let mut keep = None;
+    search(&mut work, cap, &mut found, &mut keep);
+    found
+}
