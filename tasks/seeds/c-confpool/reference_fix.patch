diff --git a/config.c b/config.c
index 4ae3e60..d5957be 100644
--- a/config.c
+++ b/config.c
@@ -108,6 +108,7 @@ static int reload_pair(config *c, const char *key, const char *val) {
         char *nv = pool_take(c->pool, val);
         if (nv == NULL)
             return -1;
+        pool_drop(c->pool, e->value);
         e->value = nv;
         return 0;
     }
@@ -118,23 +119,23 @@ int cfg_reload(config *c, const char *text) {
     if (c == NULL || text == NULL)
         return -1;
 
-    /* Every setting is presumed gone until the new file mentions it, so
-     * hand the value storage back up front and let the walk below take
-     * whatever it still needs. */
-    for (size_t i = 0; i < c->count; i++) {
+    /* Every setting is presumed gone until the new file mentions it, but
+     * each keeps its storage until we know: the walk below reads the old
+     * values through these pointers, so nothing may be handed back yet. */
+    for (size_t i = 0; i < c->count; i++)
         c->entries[i].live = 0;
-        pool_drop(c->pool, c->entries[i].value);
-    }
 
     if (for_each_pair(c, text, reload_pair) != 0)
         return -1;
 
-    /* Settings the new file never mentioned: their storage was returned
-     * up front already, so just close the gaps in the table. */
+    /* Settings the new file never mentioned: return their storage now
+     * that the walk is done, then close the gaps in the table. */
     size_t w = 0;
     for (size_t i = 0; i < c->count; i++) {
         if (c->entries[i].live)
             c->entries[w++] = c->entries[i];
+        else
+            pool_drop(c->pool, c->entries[i].value);
     }
     c->count = w;
     return 0;
