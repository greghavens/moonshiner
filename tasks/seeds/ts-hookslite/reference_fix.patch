+// hooks_runtime.ts — a miniature React-style hooks runtime.
+//
+// No React, no JSX: a component is any (props) => output function that calls
+// the hooks below while it runs. Hooks are identified by call order — each
+// root keeps an array of slots, and every invocation walks it from the top
+// with a cursor. Runs under node's type stripping: annotations only.
+
+type HookKind = "useState" | "useReducer" | "useMemo";
+
+interface Slot {
+  kind: HookKind;
+  initialized: boolean;
+  state: unknown;
+  queue: unknown[]; // useState: values/updaters, useReducer: actions
+  bound: unknown; // the stable setter/dispatch handed to the component
+  reducer: ((state: unknown, action: unknown) => unknown) | null;
+  memoDeps: unknown[] | null;
+}
+
+interface RootState {
+  slots: Slot[];
+  cursor: number;
+  expected: number | null; // hook count of the previous completed invocation
+}
+
+/** The root currently rendering; hooks are illegal while this is null. */
+let current: RootState | null = null;
+
+function requireCurrent(): RootState {
+  if (current === null) {
+    throw new Error("hooks may only be called while a component is rendering");
+  }
+  return current;
+}
+
+function claimSlot(kind: HookKind): Slot {
+  const root = requireCurrent();
+  const index = root.cursor;
+  root.cursor += 1;
+  const existing = root.slots[index];
+  if (existing !== undefined) {
+    if (existing.kind !== kind) {
+      throw new Error(
+        `hook order changed at slot ${index}: expected ${existing.kind}, got ${kind}`,
+      );
+    }
+    return existing;
+  }
+  const slot: Slot = {
+    kind,
+    initialized: false,
+    state: undefined,
+    queue: [],
+    bound: null,
+    reducer: null,
+    memoDeps: null,
+  };
+  root.slots.push(slot);
+  return slot;
+}
+
+// ---------------------------------------------------------------- hooks
+
+export function useState<T>(
+  initial: T | (() => T),
+): [T, (update: T | ((prev: T) => T)) => void] {
+  const slot = claimSlot("useState");
+  if (!slot.initialized) {
+    slot.initialized = true;
+    slot.state = typeof initial === "function" ? (initial as () => T)() : initial;
+    slot.bound = (update: T | ((prev: T) => T)) => {
+      slot.queue.push(update);
+    };
+  }
+  while (slot.queue.length > 0) {
+    const update = slot.queue.shift();
+    slot.state = typeof update === "function" ? update(slot.state) : update;
+  }
+  return [slot.state as T, slot.bound as (update: T | ((prev: T) => T)) => void];
+}
+
+export function useReducer<S, A>(
+  reducer: (state: S, action: A) => S,
+  initial: S,
+): [S, (action: A) => void] {
+  const slot = claimSlot("useReducer");
+  if (!slot.initialized) {
+    slot.initialized = true;
+    slot.state = initial; // used as-is: never invoked, even when it is a function
+    slot.bound = (action: A) => {
+      slot.queue.push(action);
+    };
+  }
+  slot.reducer = reducer as (state: unknown, action: unknown) => unknown;
+  while (slot.queue.length > 0) {
+    const action = slot.queue.shift();
+    slot.state = slot.reducer(slot.state, action);
+  }
+  return [slot.state as S, slot.bound as (action: A) => void];
+}
+
+export function useMemo<T>(factory: () => T, deps: unknown[]): T {
+  const slot = claimSlot("useMemo");
+  const previous = slot.memoDeps;
+  const fresh =
+    !slot.initialized ||
+    previous === null ||
+    previous.length !== deps.length ||
+    !previous.every((dep, i) => Object.is(dep, deps[i]));
+  if (fresh) {
+    slot.initialized = true;
+    slot.state = factory();
+    slot.memoDeps = deps.slice();
+  }
+  return slot.state as T;
+}
+
+// ----------------------------------------------------------------- root
+
+const RENDER_LIMIT = 25;
+
+export function createRoot<P, O>(component: (props: P) => O): { render(props: P): O } {
+  const root: RootState = { slots: [], cursor: 0, expected: null };
+  return {
+    render(props: P): O {
+      if (current !== null) {
+        throw new Error("render is not reentrant");
+      }
+      let output = undefined as unknown as O;
+      for (let invocation = 1; ; invocation += 1) {
+        if (invocation > RENDER_LIMIT) {
+          throw new Error(`too many re-renders (limit ${RENDER_LIMIT})`);
+        }
+        root.cursor = 0;
+        current = root;
+        let count = 0;
+        try {
+          output = component(props);
+          count = root.cursor;
+        } finally {
+          current = null;
+        }
+        if (root.expected !== null && count !== root.expected) {
+          throw new Error(`hook count changed: expected ${root.expected}, got ${count}`);
+        }
+        root.expected = count;
+        const pending = root.slots.some((slot) => slot.queue.length > 0);
+        if (!pending) {
+          return output;
+        }
+      }
+    },
+  };
+}
