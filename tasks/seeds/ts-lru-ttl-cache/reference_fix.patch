index 0000000..6567373
--- /dev/null
+++ b/cache.ts
@@ -0,0 +1,110 @@
+type EvictReason = 'capacity' | 'expired';
+type OnEvict = (key: unknown, value: unknown, reason: EvictReason) => void;
+
+interface Entry {
+  value: unknown;
+  expiresAt: number | null;
+}
+
+export interface LruCacheOptions {
+  maxSize: number;
+  clock?: () => number;
+  defaultTtlMs?: number;
+  onEvict?: OnEvict;
+}
+
+export class LruCache {
+  private maxSize: number;
+  private clock: () => number;
+  private defaultTtlMs: number | undefined;
+  private onEvict: OnEvict | undefined;
+  private entries: Map<unknown, Entry>;
+
+  constructor(options: LruCacheOptions) {
+    const { maxSize } = options;
+    if (!Number.isInteger(maxSize) || maxSize <= 0) {
+      throw new RangeError(`maxSize must be a positive integer, got ${maxSize}`);
+    }
+    this.maxSize = maxSize;
+    this.clock = options.clock ?? Date.now;
+    this.defaultTtlMs = options.defaultTtlMs;
+    this.onEvict = options.onEvict;
+    this.entries = new Map();
+  }
+
+  private isExpired(entry: Entry): boolean {
+    return entry.expiresAt !== null && this.clock() >= entry.expiresAt;
+  }
+
+  private purgeExpired(): void {
+    for (const [key, entry] of this.entries) {
+      if (this.isExpired(entry)) {
+        this.entries.delete(key);
+        this.onEvict?.(key, entry.value, 'expired');
+      }
+    }
+  }
+
+  set(key: unknown, value: unknown, opts: { ttlMs?: number } = {}): void {
+    const ttlMs = opts.ttlMs ?? this.defaultTtlMs;
+    if (ttlMs !== undefined && ttlMs <= 0) {
+      throw new RangeError(`ttlMs must be positive, got ${ttlMs}`);
+    }
+    const existed = this.entries.delete(key);
+    if (!existed) {
+      this.purgeExpired();
+      if (this.entries.size >= this.maxSize) {
+        const lruKey = this.entries.keys().next().value;
+        const lru = this.entries.get(lruKey)!;
+        this.entries.delete(lruKey);
+        this.onEvict?.(lruKey, lru.value, 'capacity');
+      }
+    }
+    this.entries.set(key, {
+      value,
+      expiresAt: ttlMs === undefined ? null : this.clock() + ttlMs,
+    });
+  }
+
+  get(key: unknown): unknown {
+    const entry = this.entries.get(key);
+    if (entry === undefined) return undefined;
+    if (this.isExpired(entry)) {
+      this.entries.delete(key);
+      this.onEvict?.(key, entry.value, 'expired');
+      return undefined;
+    }
+    // refresh recency: Map iterates in insertion order, so re-insert at the tail
+    this.entries.delete(key);
+    this.entries.set(key, entry);
+    return entry.value;
+  }
+
+  peek(key: unknown): unknown {
+    const entry = this.entries.get(key);
+    if (entry === undefined || this.isExpired(entry)) return undefined;
+    return entry.value;
+  }
+
+  has(key: unknown): boolean {
+    const entry = this.entries.get(key);
+    return entry !== undefined && !this.isExpired(entry);
+  }
+
+  delete(key: unknown): boolean {
+    const entry = this.entries.get(key);
+    if (entry === undefined) return false;
+    this.entries.delete(key);
+    return !this.isExpired(entry) ? true : false;
+  }
+
+  size(): number {
+    this.purgeExpired();
+    return this.entries.size;
+  }
+
+  keys(): unknown[] {
+    this.purgeExpired();
+    return [...this.entries.keys()].reverse();
+  }
+}
