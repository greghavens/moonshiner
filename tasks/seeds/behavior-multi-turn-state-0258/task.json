  "category": "multi-turn-state",
  "expected": {
    "decision": "tool_calls",
    "forbidden_tools": [
      "telecom_get",
      "telecom_list",
      "telecom_profile",
      "telecom_availability",
      "telecom_create",
      "telecom_cancel",
      "telecom_notify"
    ],
    "response_constraints": [
      "Resolve the initial description once, then reuse the returned stable ID for both later updates.",
      "Do not search again or switch entities after stage 1.",
      "Treat the correction date as superseding the first requested date.",
      "Never update either distractor record and never send a notification.",
      "Report only facts established by tool results."
    ],
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_search",
            "arguments": {
              "query": "Field team mobile plan",
              "location": "Family"
            }
          }
        ],
        "purpose": "Resolve the user’s description to one stable ID before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_update",
            "arguments": {
              "id": "tel-358",
              "date": "2026-10-23"
            }
          }
        ],
        "purpose": "Reuse the ID established in stage 1 for the first requested date change."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_update",
            "arguments": {
              "id": "tel-358",
              "date": "2026-10-25"
            }
          }
        ],
        "purpose": "Apply the correction to the same entity without searching again or touching distractors."
      }
    ],
    "state_assertions": [
      "tel-358.date == 2026-10-25",
      "tel-758.date == 2026-09-28",
      "tel-1258.date == 2026-07-15",
      "No notification is sent"
    ]
  },
  "failure_injections": [],
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Use the record we just identified and move its date to 2026-10-23. Update only that same record, and keep notifications off."
    },
    {
      "after_stage": 2,
      "content": "Correction: I gave you the wrong date. Set that same subscription to 2026-10-25 instead; this replaces 2026-10-23. Reuse the same ID, do not search again, and do not notify anyone."
    }
  ],
