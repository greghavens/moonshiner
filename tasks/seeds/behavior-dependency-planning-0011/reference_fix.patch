+#!/usr/bin/env python3
+"""Run the reference dependency plan through the genuine candidate executable."""
+
+from __future__ import annotations
+
+from concurrent.futures import ThreadPoolExecutor
+import json
+from pathlib import Path
+import re
+import subprocess
+import sys
+
+
+ROOT = Path(__file__).resolve().parent
+TOOL = ROOT / "candidate_desk.py"
+TARGETS = (
+    ("Casey Evans - Regional Sales", "Sales"),
+    ("Devon Flores - Research Analyst", "Research"),
+)
+STABLE_ID = re.compile(r"^rec-[0-9]+$")
+REPORT = ROOT / "recruiter-handoff.md"
+
+
+def invoke(arguments: list[str]) -> dict:
+    result = subprocess.run(
+        [sys.executable, str(TOOL), *arguments],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        check=False,
+    )
+    if result.returncode != 0:
+        raise RuntimeError(result.stderr.strip() or "candidate executable failed")
+    return json.loads(result.stdout)
+
+
+def run_parallel(commands: list[list[str]]) -> list[dict]:
+    with ThreadPoolExecutor(max_workers=2) as pool:
+        futures = [pool.submit(invoke, command) for command in commands]
+        return [future.result() for future in futures]
+
+
+def main() -> int:
+    search_results = run_parallel([
+        ["search", "--name", name, "--location", location]
+        for name, location in TARGETS
+    ])
+
+    candidate_ids: list[str] = []
+    for result in search_results:
+        matches = result.get("matches")
+        if result.get("count") != 1 or not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference search did not resolve uniquely")
+        candidate_id = matches[0].get("id")
+        if not isinstance(candidate_id, str) or STABLE_ID.fullmatch(candidate_id) is None:
+            raise RuntimeError("reference search did not return one stable ID")
+        candidate_ids.append(candidate_id)
+
+    records = run_parallel([
+        ["get", "--id", candidate_id] for candidate_id in candidate_ids
+    ])
+    if [record.get("id") for record in records] != candidate_ids:
+        raise RuntimeError("reference retrieval did not return the searched records")
+
+    first, second = records
+    lines = [
+        f"- {record['name']} ({record['location']}) — stable ID {record['id']}; "
+        f"status: {record['status']}."
+        for record in records
+    ]
+    if first["status"] == second["status"]:
+        lines.append(f"- Status comparison: both candidates have status {first['status']}.")
+    else:
+        lines.append(
+            f"- Status comparison: {first['status']} versus {second['status']}; "
+            "the candidate statuses differ."
+        )
+    REPORT.write_text("\n".join(lines) + "\n", encoding="utf-8")
+    print("reference candidate executable flow completed")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
