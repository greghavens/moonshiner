+// Staged multi-action repository commits via POST
+// /projects/:id/repository/commits (see docs/contract.json). Local state —
+// staged actions and tracked file heads — only advances on a successful
+// commit; any rejection leaves the batch exactly as staged so the caller
+// can refresh a head and retry.
+
+import { GitLabApiError, GitLabClient, encodePathComponent } from "./client.ts";
+
+export class GitLabValidationError extends GitLabApiError {
+  constructor(status: number, message: string) {
+    super(status, message);
+    this.name = "GitLabValidationError";
+  }
+}
+
+export class GitLabCommitConflictError extends GitLabValidationError {
+  constructor(status: number, message: string) {
+    super(status, message);
+    this.name = "GitLabCommitConflictError";
+  }
+}
+
+const STALE_EDIT = /changed since you started editing/;
+
+export interface CommitAction {
+  action: "create" | "update" | "move" | "delete" | "chmod";
+  file_path: string;
+  previous_path?: string;
+  content?: string;
+  encoding?: "text" | "base64";
+  last_commit_id?: string;
+  execute_filemode?: boolean;
+}
+
+export interface CommitResult {
+  id: string;
+  short_id: string;
+  title: string;
+  message: string;
+  parent_ids: string[];
+  stats?: { additions: number; deletions: number; total: number };
+  status: string | null;
+  web_url: string;
+}
+
+export class CommitBatch {
+  private staged: CommitAction[] = [];
+  private readonly heads = new Map<string, string>();
+  private readonly client: GitLabClient;
+  private readonly projectPath: string;
+  private readonly branch: string;
+
+  constructor(client: GitLabClient, projectPath: string, branch: string) {
+    this.client = client;
+    this.projectPath = projectPath;
+    this.branch = branch;
+  }
+
+  /** Record the last-known commit of a file for optimistic concurrency. */
+  trackHead(filePath: string, sha: string): void {
+    this.heads.set(filePath, sha);
+  }
+
+  head(filePath: string): string | undefined {
+    return this.heads.get(filePath);
+  }
+
+  pending(): CommitAction[] {
+    return this.staged.map((a) => ({ ...a }));
+  }
+
+  create(
+    filePath: string,
+    content: string,
+    opts?: { encoding?: "text" | "base64" },
+  ): void {
+    const action: CommitAction = { action: "create", file_path: filePath, content };
+    if (opts?.encoding && opts.encoding !== "text") action.encoding = opts.encoding;
+    this.staged.push(action);
+  }
+
+  update(filePath: string, content: string): void {
+    this.staged.push({ action: "update", file_path: filePath, content });
+  }
+
+  /** Omitting content preserves the existing file content per the docs. */
+  move(previousPath: string, filePath: string, content?: string): void {
+    const action: CommitAction = {
+      action: "move",
+      file_path: filePath,
+      previous_path: previousPath,
+    };
+    if (content !== undefined) action.content = content;
+    this.staged.push(action);
+  }
+
+  remove(filePath: string): void {
+    this.staged.push({ action: "delete", file_path: filePath });
+  }
+
+  chmod(filePath: string, executable: boolean): void {
+    this.staged.push({
+      action: "chmod",
+      file_path: filePath,
+      execute_filemode: executable,
+    });
+  }
+
+  async commit(
+    message: string,
+    opts?: { startBranch?: string },
+  ): Promise<CommitResult> {
+    if (this.staged.length === 0) {
+      throw new Error("nothing staged: refusing to create an empty commit");
+    }
+    const body: Record<string, unknown> = {
+      branch: this.branch,
+      commit_message: message,
+      actions: this.staged.map((a) => this.materialize(a)),
+    };
+    if (opts?.startBranch !== undefined) body.start_branch = opts.startBranch;
+
+    let result: CommitResult;
+    try {
+      result = (await this.client.requestJson(
+        "POST",
+        `/api/v4/projects/${encodePathComponent(this.projectPath)}/repository/commits`,
+        body,
+      )) as CommitResult;
+    } catch (err) {
+      if (err instanceof GitLabApiError && err.status === 400) {
+        if (STALE_EDIT.test(err.message)) {
+          throw new GitLabCommitConflictError(err.status, err.message);
+        }
+        throw new GitLabValidationError(err.status, err.message);
+      }
+      throw err;
+    }
+
+    // Only now, with the commit landed, advance local state atomically.
+    const touched = this.staged.map((a) => a.file_path);
+    this.staged = [];
+    for (const path of touched) this.heads.set(path, result.id);
+    return result;
+  }
+
+  /** Resolve the wire action at commit time so refreshed heads apply. */
+  private materialize(action: CommitAction): CommitAction {
+    const wire: CommitAction = { ...action };
+    if (wire.action === "update" || wire.action === "delete") {
+      const head = this.heads.get(wire.file_path);
+      if (head !== undefined) wire.last_commit_id = head;
+    } else if (wire.action === "move" && wire.previous_path !== undefined) {
+      const head = this.heads.get(wire.previous_path);
+      if (head !== undefined) wire.last_commit_id = head;
+    }
+    return wire;
+  }
+}
