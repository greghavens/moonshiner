diff --git a/snapshot.sh b/snapshot.sh
index 8aaba1e..2c86a32 100644
--- a/snapshot.sh
+++ b/snapshot.sh
@@ -31,7 +31,7 @@ mkdir -p "$snap"
 copied=0
 for f in "$src"/*; do
   [ -f "$f" ] || continue
-  if cp -p $f "$snap/"; then
+  if cp -p "$f" "$snap/"; then
     copied=$((copied + 1))
   fi
 done
@@ -42,7 +42,7 @@ manifest="$snap/MANIFEST.tsv"
 for f in "$snap"/*; do
   name=${f##*/}
   [ "$name" = MANIFEST.tsv ] && continue
-  bytes=$(wc -c < $f)
+  bytes=$(wc -c < "$f")
   printf '%s\t%s\n' "$name" "$bytes" >> "$manifest"
 done
 sort -o "$manifest" "$manifest"
@@ -52,7 +52,7 @@ missing=0
 for f in "$src"/*; do
   [ -f "$f" ] || continue
   name=${f##*/}
-  [ -f $snap/$name ] || {
+  [ -f "$snap/$name" ] || {
     echo "snapshot: missing from snapshot: $name" >&2
     missing=$((missing + 1))
   }
