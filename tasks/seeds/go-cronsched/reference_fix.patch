new file mode 100644
index 0000000..cb6700b
--- /dev/null
+++ b/next.go
@@ -0,0 +1,57 @@
+package cronsched
+
+import "time"
+
+// horizonYears bounds the search: schedules with no run inside this window
+// (e.g. "0 0 30 2 *") yield the zero time.
+const horizonYears = 5
+
+// Next returns the earliest time strictly after `after` that matches, with
+// seconds and nanoseconds zeroed, staying in after's location. Dead months
+// and days are skipped whole, so even never-matching expressions give up
+// quickly.
+func (s *Schedule) Next(after time.Time) time.Time {
+	t := after.Truncate(time.Minute).Add(time.Minute)
+	limit := after.AddDate(horizonYears, 0, 0)
+	for !t.After(limit) {
+		if !bit(s.month, int(t.Month())) {
+			// Jump to the first minute of the next month.
+			t = time.Date(t.Year(), t.Month(), 1, 0, 0, 0, 0, t.Location()).AddDate(0, 1, 0)
+			continue
+		}
+		if !s.dayMatches(t) {
+			// Jump to midnight of the next day.
+			t = time.Date(t.Year(), t.Month(), t.Day(), 0, 0, 0, 0, t.Location()).AddDate(0, 0, 1)
+			continue
+		}
+		if !bit(s.hour, t.Hour()) {
+			t = time.Date(t.Year(), t.Month(), t.Day(), t.Hour(), 0, 0, 0, t.Location()).Add(time.Hour)
+			continue
+		}
+		if !bit(s.minute, t.Minute()) {
+			t = t.Add(time.Minute)
+			continue
+		}
+		return t
+	}
+	return time.Time{}
+}
+
+// NextN returns the next n run times, each strictly after the previous.
+// The slice is shorter than n if the schedule runs off the horizon, and
+// empty when n <= 0.
+func (s *Schedule) NextN(after time.Time, n int) []time.Time {
+	if n <= 0 {
+		return nil
+	}
+	out := make([]time.Time, 0, n)
+	t := after
+	for len(out) < n {
+		t = s.Next(t)
+		if t.IsZero() {
+			break
+		}
+		out = append(out, t)
+	}
+	return out
+}
diff --git a/parse.go b/parse.go
new file mode 100644
index 0000000..1acac70
--- /dev/null
+++ b/parse.go
@@ -0,0 +1,128 @@
+package cronsched
+
+import (
+	"fmt"
+	"strconv"
+	"strings"
+)
+
+type fieldSpec struct {
+	name     string
+	min, max int
+}
+
+var fieldSpecs = [5]fieldSpec{
+	{"minute", 0, 59},
+	{"hour", 0, 23},
+	{"day-of-month", 1, 31},
+	{"month", 1, 12},
+	{"day-of-week", 0, 7}, // 7 is folded onto Sunday (0)
+}
+
+// Parse compiles a classic 5-field cron expression. Fields are separated by
+// any run of spaces or tabs; values are numeric only.
+func Parse(expr string) (*Schedule, error) {
+	fields := strings.Fields(expr)
+	if len(fields) != 5 {
+		return nil, fmt.Errorf("cronsched: want 5 fields, got %d in %q", len(fields), expr)
+	}
+	var sets [5]uint64
+	for i, f := range fields {
+		set, err := parseField(f, fieldSpecs[i])
+		if err != nil {
+			return nil, fmt.Errorf("cronsched: %s field %q: %w", fieldSpecs[i].name, f, err)
+		}
+		sets[i] = set
+	}
+	return &Schedule{
+		minute: sets[0],
+		hour:   sets[1],
+		dom:    sets[2],
+		month:  sets[3],
+		dow:    foldSunday(sets[4]),
+		// A day field is "restricted" unless written exactly "*"; this is
+		// what drives the either/or day rule, so */1 still counts.
+		domStar: fields[2] == "*",
+		dowStar: fields[4] == "*",
+	}, nil
+}
+
+// foldSunday maps bit 7 onto bit 0 so both spellings of Sunday coincide.
+func foldSunday(dow uint64) uint64 {
+	if dow&(1<<7) != 0 {
+		dow = (dow &^ (1 << 7)) | 1
+	}
+	return dow
+}
+
+// parseField handles comma lists of *, */n, a, a-b, a-b/n.
+func parseField(f string, spec fieldSpec) (uint64, error) {
+	var set uint64
+	for _, item := range strings.Split(f, ",") {
+		if item == "" {
+			return 0, fmt.Errorf("empty list item")
+		}
+		itemSet, err := parseItem(item, spec)
+		if err != nil {
+			return 0, err
+		}
+		set |= itemSet
+	}
+	return set, nil
+}
+
+func parseItem(item string, spec fieldSpec) (uint64, error) {
+	step := 1
+	rangePart := item
+	if base, stepStr, found := strings.Cut(item, "/"); found {
+		n, err := strconv.Atoi(stepStr)
+		if err != nil || n < 1 {
+			return 0, fmt.Errorf("bad step %q", stepStr)
+		}
+		step = n
+		rangePart = base
+		if base != "*" && !strings.Contains(base, "-") {
+			return 0, fmt.Errorf("a step needs * or a range, got %q", base)
+		}
+	}
+
+	lo, hi := spec.min, spec.max
+	if rangePart != "*" {
+		loStr, hiStr, isRange := strings.Cut(rangePart, "-")
+		a, err := parseValue(loStr, spec)
+		if err != nil {
+			return 0, err
+		}
+		lo, hi = a, a
+		if isRange {
+			b, err := parseValue(hiStr, spec)
+			if err != nil {
+				return 0, err
+			}
+			if b < a {
+				return 0, fmt.Errorf("reversed range %d-%d", a, b)
+			}
+			hi = b
+		}
+	}
+
+	var set uint64
+	for v := lo; v <= hi; v += step {
+		set |= 1 << uint(v)
+	}
+	return set, nil
+}
+
+func parseValue(s string, spec fieldSpec) (int, error) {
+	if s == "" {
+		return 0, fmt.Errorf("missing value")
+	}
+	v, err := strconv.Atoi(s)
+	if err != nil {
+		return 0, fmt.Errorf("not a number: %q", s)
+	}
+	if v < spec.min || v > spec.max {
+		return 0, fmt.Errorf("%d out of range %d-%d", v, spec.min, spec.max)
+	}
+	return v, nil
+}
diff --git a/schedule.go b/schedule.go
new file mode 100644
index 0000000..88299a8
--- /dev/null
+++ b/schedule.go
@@ -0,0 +1,42 @@
+// Package cronsched parses classic 5-field cron expressions and computes
+// run times. It is purely computational: callers inject the clock, so
+// everything is testable without sleeping.
+package cronsched
+
+import "time"
+
+// Schedule is a compiled cron expression. Each field is a bitset of the
+// permitted values; domStar/dowStar record whether the day fields were
+// written exactly "*", which drives the either/or day rule.
+type Schedule struct {
+	minute  uint64 // bits 0-59
+	hour    uint64 // bits 0-23
+	dom     uint64 // bits 1-31
+	month   uint64 // bits 1-12
+	dow     uint64 // bits 0-6, Sunday = 0
+	domStar bool
+	dowStar bool
+}
+
+func bit(set uint64, v int) bool { return set&(1<<uint(v)) != 0 }
+
+// Matches reports whether t (at minute resolution; seconds/nanos ignored)
+// satisfies the schedule.
+func (s *Schedule) Matches(t time.Time) bool {
+	if !bit(s.minute, t.Minute()) || !bit(s.hour, t.Hour()) || !bit(s.month, int(t.Month())) {
+		return false
+	}
+	return s.dayMatches(t)
+}
+
+// dayMatches implements the either/or day rule: if both day fields are
+// restricted, either may match; otherwise both must (a wildcard matches
+// everything anyway).
+func (s *Schedule) dayMatches(t time.Time) bool {
+	domOK := bit(s.dom, t.Day())
+	dowOK := bit(s.dow, int(t.Weekday()))
+	if !s.domStar && !s.dowStar {
+		return domOK || dowOK
+	}
+	return domOK && dowOK
+}
diff --git a/scheduler.go b/scheduler.go
new file mode 100644
index 0000000..840f533
--- /dev/null
+++ b/scheduler.go
@@ -0,0 +1,107 @@
+package cronsched
+
+import (
+	"fmt"
+	"sort"
+	"sync"
+	"time"
+)
+
+// Fire is one scheduled instant owed to a named entry.
+type Fire struct {
+	Name string
+	At   time.Time
+}
+
+type entry struct {
+	sched  *Schedule
+	cursor time.Time // fires strictly after this instant are still owed
+}
+
+// Scheduler tracks named schedules against an injectable clock. It is safe
+// for concurrent use; every owed fire is delivered to exactly one Poll
+// caller.
+type Scheduler struct {
+	now func() time.Time
+
+	mu      sync.Mutex
+	entries map[string]*entry
+}
+
+// NewScheduler builds a scheduler around the given clock; nil means
+// time.Now.
+func NewScheduler(now func() time.Time) *Scheduler {
+	if now == nil {
+		now = time.Now
+	}
+	return &Scheduler{now: now, entries: map[string]*entry{}}
+}
+
+// Add registers a named schedule whose cursor starts at the current clock
+// reading. Empty names, duplicate names and unparsable expressions are
+// errors, and a failed Add registers nothing.
+func (s *Scheduler) Add(name, expr string) error {
+	if name == "" {
+		return fmt.Errorf("cronsched: empty entry name")
+	}
+	sched, err := Parse(expr)
+	if err != nil {
+		return err
+	}
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if _, dup := s.entries[name]; dup {
+		return fmt.Errorf("cronsched: duplicate entry %q", name)
+	}
+	s.entries[name] = &entry{sched: sched, cursor: s.now()}
+	return nil
+}
+
+// Remove drops an entry, reporting whether it existed.
+func (s *Scheduler) Remove(name string) bool {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	_, ok := s.entries[name]
+	delete(s.entries, name)
+	return ok
+}
+
+// NextRun reports the entry's next fire strictly after the current clock
+// reading, without consuming anything Poll owes. ok is false for unknown
+// names; a never-firing entry yields the zero time.
+func (s *Scheduler) NextRun(name string) (time.Time, bool) {
+	s.mu.Lock()
+	e, ok := s.entries[name]
+	s.mu.Unlock()
+	if !ok {
+		return time.Time{}, false
+	}
+	return e.sched.Next(s.now()), true
+}
+
+// Poll reads the clock once and returns every scheduled instant t with
+// cursor < t <= now across all entries, sorted by At then Name, advancing
+// the cursors to now. A clock that has not advanced (or moved backwards)
+// yields nothing; cursors never move backwards.
+func (s *Scheduler) Poll() []Fire {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	now := s.now()
+	var out []Fire
+	for name, e := range s.entries {
+		if !now.After(e.cursor) {
+			continue
+		}
+		for t := e.sched.Next(e.cursor); !t.IsZero() && !t.After(now); t = e.sched.Next(t) {
+			out = append(out, Fire{Name: name, At: t})
+		}
+		e.cursor = now
+	}
+	sort.Slice(out, func(i, j int) bool {
+		if !out[i].At.Equal(out[j].At) {
+			return out[i].At.Before(out[j].At)
+		}
+		return out[i].Name < out[j].Name
+	})
+	return out
+}
