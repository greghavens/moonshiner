-func intersects(a, b Span) bool {
-	return a.Start < a.End && b.Start < b.End && a.Start < b.End && b.Start < a.End
+// activeWin is a window currently crossing the sweep position.
+type activeWin struct {
+	end int64
+	idx int
+}
+
+// endHeap is a min-heap of active windows keyed by End, so windows that
+// can no longer intersect anything are evicted in O(log n).
+type endHeap []activeWin
+
+func (h endHeap) Len() int           { return len(h) }
+func (h endHeap) Less(i, j int) bool { return h[i].end < h[j].end }
+func (h endHeap) Swap(i, j int)      { h[i], h[j] = h[j], h[i] }
+func (h *endHeap) Push(x any)        { *h = append(*h, x.(activeWin)) }
+func (h *endHeap) Pop() any {
+	old := *h
+	n := len(old)
+	it := old[n-1]
+	*h = old[:n-1]
+	return it
 }
 
 // Overlaps reports every overlapping pair of windows in spans.
+//
+// Sweep line over window starts: walking the non-empty windows in Start
+// order, every window still active when window w arrives (End > w.Start)
+// is exactly a window that overlaps w, so each candidate-pair check is a
+// real overlap and the pass costs O((n + K) log n) for K overlaps
+// instead of weighing all n^2/2 pairs.
 func Overlaps(spans []Span, budget *Budget) ([]Pair, error) {
+	type startEv struct {
+		start int64
+		end   int64
+		idx   int
+	}
+	evs := make([]startEv, 0, len(spans))
+	for i, s := range spans {
+		if s.Start < s.End { // empty windows overlap nothing
+			evs = append(evs, startEv{start: s.Start, end: s.End, idx: i})
+		}
+	}
+	sort.Slice(evs, func(i, j int) bool {
+		if evs[i].start != evs[j].start {
+			return evs[i].start < evs[j].start
+		}
+		return evs[i].end < evs[j].end
+	})
+
 	var out []Pair
-	for i := 0; i < len(spans); i++ {
-		for j := i + 1; j < len(spans); j++ {
+	active := &endHeap{}
+	for _, e := range evs {
+		for active.Len() > 0 && (*active)[0].end <= e.start {
+			heap.Pop(active)
+		}
+		for _, a := range *active {
+			// every still-active window overlaps e by construction
 			if !budget.spend() {
 				return nil, ErrBudget
 			}
-			if intersects(spans[i], spans[j]) {
-				out = append(out, Pair{A: i, B: j})
+			lo, hi := a.idx, e.idx
+			if lo > hi {
+				lo, hi = hi, lo
 			}
+			out = append(out, Pair{A: lo, B: hi})
 		}
+		heap.Push(active, activeWin{end: e.end, idx: e.idx})
 	}
+
+	sort.Slice(out, func(i, j int) bool {
+		if out[i].A != out[j].A {
+			return out[i].A < out[j].A
+		}
+		return out[i].B < out[j].B
+	})
 	return out, nil
 }
