+#!/usr/bin/env python3
+"""Reference proof using the genuine course executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Nonprofit Budgeting Workshop", "Civic Center"),
+    ("Oral History Methods", "Library Annex"),
+)
+
+
+def phase_worker() -> int:
+    """Start every client before collecting any response for one phase."""
+    commands = json.loads(sys.stdin.read())
+    if not isinstance(commands, list) or not commands:
+        raise RuntimeError("reference phase has no commands")
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "course operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("course operation returned an invalid payload")
+        payloads.append(payload)
+    print(json.dumps(payloads))
+    return 0
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Use a fresh action parent for each dependency phase."""
+    completed = subprocess.run(
+        [sys.executable, "-B", str(Path(__file__).resolve()), "--phase-worker"],
+        cwd=ROOT,
+        input=json.dumps(commands),
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+        check=False,
+        timeout=30,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "reference phase failed")
+    payloads = json.loads(completed.stdout)
+    if not isinstance(payloads, list) or not all(
+        isinstance(payload, dict) for payload in payloads
+    ):
+        raise RuntimeError("reference phase returned invalid results")
+    return payloads
+
+
+def field(record: dict[str, Any] | None, key: str) -> str:
+    if record is None:
+        return "unknown"
+    value = record.get(key)
+    return value if isinstance(value, str) and value else "unknown"
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./coursectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, ((name, location), response) in enumerate(zip(TARGETS, searches)):
+        matches = response.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        match = matches[0]
+        if not isinstance(match, dict):
+            continue
+        if match.get("name") != name or match.get("location") != location:
+            raise RuntimeError("search returned a different course branch")
+        stable_id = match.get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./coursectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, stable_id), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if not isinstance(record, dict) or record.get("id") != stable_id:
+                raise RuntimeError("get returned a different course record")
+            name, location = TARGETS[index]
+            if record.get("name") != name or record.get("location") != location:
+                raise RuntimeError("get returned a different course branch")
+            retrieved[index] = record
+
+    rows: list[str] = []
+    for index, record in enumerate(retrieved):
+        name = field(record, "name") if record is not None else TARGETS[index][0]
+        rows.append(
+            f"| {name} | {field(record, 'id')} | {field(record, 'date')} | "
+            f"{field(record, 'status')} |"
+        )
+
+    statuses = [field(record, "status") for record in retrieved]
+    if "unknown" in statuses:
+        comparison = "Status comparison: unknown."
+    elif statuses[0] == statuses[1]:
+        comparison = f"Status comparison: both are {statuses[0]}."
+    else:
+        comparison = f"Status comparison: {statuses[0]} differs from {statuses[1]}."
+
+    rendered = (
+        "| Name | ID | Date | Status |\n"
+        "| --- | --- | --- | --- |\n"
+        f"{rows[0]}\n"
+        f"{rows[1]}\n"
+        f"{comparison}\n"
+    )
+    (ROOT / "course-audit.md").write_text(rendered, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    if sys.argv[1:] == ["--phase-worker"]:
+        raise SystemExit(phase_worker())
+    raise SystemExit(main())
