+++ b/merakiinv/errors.py
@@ -0,0 +1,16 @@
+"""Error types for the Meraki Dashboard API v1 client."""
+
+
+class MerakiAPIError(Exception):
+    """A non-success Dashboard API response.
+
+    Carries the HTTP status and the messages from the documented
+    ``{"errors": [...]}`` envelope. The API key is never included.
+    """
+
+    def __init__(self, status, errors):
+        self.status = status
+        self.errors = list(errors)
+        super().__init__(
+            "Meraki API error %d: %s" % (status, "; ".join(self.errors))
+        )
