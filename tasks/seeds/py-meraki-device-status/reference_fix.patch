@@ -0,0 +1,114 @@
+"""HTTP transport for the Cisco Meraki Dashboard API v1.
+
+Implements the documented v1 contract: bearer authorization, regional base
+URLs, the ``name[]`` array query convention, Link-header pagination, the
+429/Retry-After rate-limit dance, and the ``{"errors": [...]}`` envelope.
+"""
+
+import json
+import time
+import urllib.error
+import urllib.request
+from urllib.parse import urlencode
+
+from .errors import MerakiAPIError
+from .pagination import next_link
+
+GLOBAL_BASE_URL = "https://api.meraki.com/api/v1"
+
+_REGION_BASE_URLS = {
+    "global": GLOBAL_BASE_URL,
+    "canada": "https://api.meraki.ca/api/v1",
+    "china": "https://api.meraki.cn/api/v1",
+    "india": "https://api.meraki.in/api/v1",
+    "us-fedramp": "https://api.gov-meraki.com/api/v1",
+}
+
+
+def base_url_for_region(region):
+    """Return the documented versioned base URL for a dashboard region."""
+    try:
+        return _REGION_BASE_URLS[region]
+    except KeyError:
+        raise ValueError("unknown Meraki dashboard region: %r" % (region,))
+
+
+def _encode_query(params, per_page):
+    pairs = []
+    if per_page is not None:
+        pairs.append(("perPage", str(per_page)))
+    for key, value in (params or {}).items():
+        if isinstance(value, (list, tuple)):
+            # Meraki's documented array convention: repeated name[] pairs.
+            pairs.extend(("%s[]" % key, str(item)) for item in value)
+        else:
+            pairs.append((key, str(value)))
+    return urlencode(pairs)
+
+
+class MerakiSession:
+    """A Dashboard API v1 session bound to one API key and base URL."""
+
+    def __init__(self, api_key, base_url=GLOBAL_BASE_URL, sleep=None,
+                 max_retries=3):
+        self._api_key = api_key
+        self.base_url = base_url.rstrip("/")
+        self._sleep = sleep if sleep is not None else time.sleep
+        self.max_retries = max_retries
+
+    def _url(self, path, params=None, per_page=None):
+        url = self.base_url + path
+        query = _encode_query(params, per_page)
+        if query:
+            url += "?" + query
+        return url
+
+    def _request(self, url):
+        """GET a URL, honoring Retry-After on 429 a bounded number of times."""
+        retries = 0
+        while True:
+            request = urllib.request.Request(
+                url,
+                headers={
+                    "Authorization": "Bearer %s" % self._api_key,
+                    "Accept": "application/json",
+                },
+            )
+            try:
+                with urllib.request.urlopen(request) as response:
+                    data = json.loads(response.read().decode("utf-8"))
+                    return data, response.headers
+            except urllib.error.HTTPError as exc:
+                errors = self._decode_errors(exc)
+                if exc.code == 429 and retries < self.max_retries:
+                    retries += 1
+                    retry_after = float(exc.headers.get("Retry-After", "1"))
+                    self._sleep(retry_after)
+                    continue
+                raise MerakiAPIError(exc.code, errors) from None
+
+    @staticmethod
+    def _decode_errors(exc):
+        try:
+            payload = json.loads(exc.read().decode("utf-8"))
+            errors = payload.get("errors")
+            if isinstance(errors, list) and errors:
+                return [str(e) for e in errors]
+        except (ValueError, AttributeError):
+            pass
+        return ["HTTP %d" % exc.code]
+
+    def get_json(self, path, params=None):
+        """GET one resource and return its decoded JSON body."""
+        data, _ = self._request(self._url(path, params))
+        return data
+
+    def get_paginated(self, path, params=None, per_page=None):
+        """GET a collection, following Link rel=next URLs verbatim."""
+        url = self._url(path, params, per_page)
+        items = []
+        while url:
+            data, headers = self._request(url)
+            items.extend(data)
+            url = next_link(headers.get("Link"))
+        return items
