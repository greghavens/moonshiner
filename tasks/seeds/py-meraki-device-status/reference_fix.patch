@@ -0,0 +1,71 @@
+"""Whole-estate Meraki inventory traversal.
+
+Walks organizations -> networks -> device availabilities (the current
+replacement for the deprecated device statuses operation) and produces a
+deterministic, sorted snapshot suitable for diffing.
+"""
+
+
+def _network_entry(network):
+    return {
+        "id": network["id"],
+        "name": network["name"],
+        "productTypes": sorted(network.get("productTypes", [])),
+    }
+
+
+def _device_entry(device):
+    return {
+        "serial": device["serial"],
+        "name": device.get("name"),
+        "mac": device.get("mac"),
+        "productType": device["productType"],
+        "status": device["status"],
+        "networkId": (device.get("network") or {}).get("id"),
+    }
+
+
+def collect_inventory(session, product_types=None, statuses=None,
+                      per_page=None):
+    """Snapshot every API-enabled organization the key can see.
+
+    Organizations are fully paginated first, then traversed in ascending id
+    order; for each org the networks are listed before device availabilities
+    so a partial failure leaves a coherent prefix.
+    """
+    organizations = session.get_paginated("/organizations", per_page=per_page)
+    snapshot = []
+    for org in sorted(organizations, key=lambda o: o["id"]):
+        if not (org.get("api") or {}).get("enabled", False):
+            continue
+        networks = session.get_paginated(
+            "/organizations/%s/networks" % org["id"], per_page=per_page
+        )
+        filters = {}
+        if product_types:
+            filters["productTypes"] = list(product_types)
+        if statuses:
+            filters["statuses"] = list(statuses)
+        devices = session.get_paginated(
+            "/organizations/%s/devices/availabilities" % org["id"],
+            params=filters,
+            per_page=per_page,
+        )
+        snapshot.append(
+            {
+                "id": org["id"],
+                "name": org["name"],
+                "region": ((org.get("cloud") or {}).get("region") or {}).get(
+                    "name"
+                ),
+                "networks": sorted(
+                    (_network_entry(n) for n in networks),
+                    key=lambda n: n["id"],
+                ),
+                "devices": sorted(
+                    (_device_entry(d) for d in devices),
+                    key=lambda d: d["serial"],
+                ),
+            }
+        )
+    return {"organizations": snapshot}
diff --git a/merakiinv/pagination.py b/merakiinv/pagination.py
new file mode 100644
index 0000000..f340714
--- /dev/null
+++ b/merakiinv/pagination.py
@@ -0,0 +1,36 @@
+"""RFC 5988 Link header parsing for Dashboard API pagination.
+
+Meraki answers paginated collections with a Link header carrying up to
+first/prev/next/last relations. The rel parameter appears both quoted and
+unquoted in the wild; both forms are accepted. The relation URLs are meant
+to be followed verbatim.
+"""
+
+
+def parse_link_header(value):
+    """Return a dict of rel -> URL from a Link header value."""
+    links = {}
+    if not value:
+        return links
+    for part in value.split(","):
+        part = part.strip()
+        if ";" not in part:
+            continue
+        target, params = part.split(";", 1)
+        target = target.strip()
+        if not (target.startswith("<") and target.endswith(">")):
+            continue
+        url = target[1:-1]
+        for param in params.split(";"):
+            name, _, raw = param.partition("=")
+            if name.strip().lower() != "rel":
+                continue
+            rel = raw.strip().strip('"').lower()
+            if rel:
+                links[rel] = url
+    return links
+
+
+def next_link(value):
+    """Return the rel=next URL from a Link header, or None."""
+    return parse_link_header(value).get("next")
