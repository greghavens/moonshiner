+// JSON string encoding for the door-controller event feed. Hand-rolled on
+// purpose: the dashboard inlines feed lines into an inline <script> block,
+// so U+2028/U+2029 must come out as backslash-u escapes, and truncated UTF-16
+// from the controllers (lone surrogates) is replaced with U+FFFD so the
+// collector's strict parser keeps accepting the line.
+
+const SHORT: Record<string, string> = {
+  "\b": "\\b",
+  "\t": "\\t",
+  "\n": "\\n",
+  "\f": "\\f",
+  "\r": "\\r",
+  '"': '\\"',
+  "\\": "\\\\",
+};
+
+const REPLACEMENT = "�";
+
+function hex4(code: number): string {
+  return "\\u" + code.toString(16).padStart(4, "0");
+}
+
+export function encodeJsonString(s: string): string {
+  let out = '"';
+  for (let i = 0; i < s.length; i++) {
+    const code = s.charCodeAt(i);
+    const ch = s[i];
+    if (SHORT[ch] !== undefined) {
+      out += SHORT[ch];
+    } else if (code < 0x20) {
+      out += hex4(code);
+    } else if (code === 0x2028 || code === 0x2029) {
+      out += hex4(code);
+    } else if (code >= 0xd800 && code <= 0xdbff) {
+      const next = i + 1 < s.length ? s.charCodeAt(i + 1) : 0;
+      if (next >= 0xdc00 && next <= 0xdfff) {
+        out += ch + s[i + 1]; // well-formed pair, keep it literal
+        i++;
+      } else {
+        out += REPLACEMENT;
+      }
+    } else if (code >= 0xdc00 && code <= 0xdfff) {
+      out += REPLACEMENT; // low surrogate with no high before it
+    } else {
+      out += ch;
+    }
+  }
+  return out + '"';
+}
+
+export function eventLine(fields: Record<string, string>): string {
+  const parts = Object.keys(fields)
+    .sort()
+    .map((key) => encodeJsonString(key) + ":" + encodeJsonString(fields[key]));
+  return "{" + parts.join(",") + "}";
+}
