+import { SqlError } from './errors.ts';
+
+export type TokenType = 'ident' | 'number' | 'string' | 'symbol' | 'eof';
+
+export interface Token {
+  type: TokenType;
+  /** Raw source text of the token; 'end of input' has text ''. */
+  text: string;
+  /** Parsed value for number/string tokens. */
+  value?: number | string;
+  /** 1-based column of the token's first character. */
+  col: number;
+}
+
+const SYMBOLS = new Set([',', '(', ')', '*', '=', '<', '>']);
+
+function isDigit(ch: string): boolean {
+  return ch >= '0' && ch <= '9';
+}
+
+function isIdentStart(ch: string): boolean {
+  return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || ch === '_';
+}
+
+function isIdentPart(ch: string): boolean {
+  return isIdentStart(ch) || isDigit(ch);
+}
+
+/** Tokenizes the whole input up front; the final token is always eof. */
+export function lex(sql: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  while (i < sql.length) {
+    const ch = sql[i];
+    if (ch === ' ' || ch === '\t' || ch === '\n' || ch === '\r') {
+      i++;
+      continue;
+    }
+    const col = i + 1;
+    if (isIdentStart(ch)) {
+      let j = i + 1;
+      while (j < sql.length && isIdentPart(sql[j])) j++;
+      tokens.push({ type: 'ident', text: sql.slice(i, j), col });
+      i = j;
+      continue;
+    }
+    if (isDigit(ch) || (ch === '-' && isDigit(sql[i + 1] ?? ''))) {
+      let j = i + 1;
+      while (j < sql.length && isDigit(sql[j])) j++;
+      if (sql[j] === '.' && isDigit(sql[j + 1] ?? '')) {
+        j += 2;
+        while (j < sql.length && isDigit(sql[j])) j++;
+      }
+      const text = sql.slice(i, j);
+      tokens.push({ type: 'number', text, value: Number(text), col });
+      i = j;
+      continue;
+    }
+    if (ch === "'") {
+      let j = i + 1;
+      let value = '';
+      for (;;) {
+        if (j >= sql.length) {
+          throw new SqlError(`col ${col}: unterminated string`, col);
+        }
+        if (sql[j] === "'") {
+          if (sql[j + 1] === "'") {
+            value += "'"; // '' escapes a quote
+            j += 2;
+            continue;
+          }
+          j++;
+          break;
+        }
+        value += sql[j];
+        j++;
+      }
+      tokens.push({ type: 'string', text: sql.slice(i, j), value, col });
+      i = j;
+      continue;
+    }
+    if (ch === '!' && sql[i + 1] === '=') {
+      tokens.push({ type: 'symbol', text: '!=', col });
+      i += 2;
+      continue;
+    }
+    if ((ch === '<' || ch === '>') && sql[i + 1] === '=') {
+      tokens.push({ type: 'symbol', text: ch + '=', col });
+      i += 2;
+      continue;
+    }
+    if (SYMBOLS.has(ch)) {
+      tokens.push({ type: 'symbol', text: ch, col });
+      i++;
+      continue;
+    }
+    throw new SqlError(`col ${col}: unexpected character "${ch}"`, col);
+  }
+  tokens.push({ type: 'eof', text: '', col: sql.length + 1 });
+  return tokens;
+}
