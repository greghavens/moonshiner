+/**
+ * SqlError covers both halves of the front end: parse/lex errors carry a
+ * 1-based `col`; planner (semantic) errors have no position.
+ */
+export class SqlError extends Error {
+  col?: number;
+
+  constructor(message: string, col?: number) {
+    super(message);
+    this.name = 'SqlError';
+    if (col !== undefined) this.col = col;
+  }
+}
