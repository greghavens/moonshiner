@@ -0,0 +1,200 @@
+import { SqlError } from './errors.ts';
+import { lex, type Token } from './lexer.ts';
+
+export type Literal = string | number | boolean | null;
+
+export type Expr =
+  | { op: 'and'; left: Expr; right: Expr }
+  | { op: '=' | '!=' | '<' | '<=' | '>' | '>='; column: string; value: Literal }
+  | { op: 'in'; column: string; values: Literal[] };
+
+export interface OrderKey {
+  column: string;
+  dir: 'asc' | 'desc';
+}
+
+export interface SelectAst {
+  columns: '*' | string[];
+  table: string;
+  where: Expr | null;
+  orderBy: OrderKey[];
+  limit: number | null;
+  offset: number | null;
+}
+
+const KEYWORDS = new Set([
+  'SELECT', 'FROM', 'WHERE', 'AND', 'IN',
+  'ORDER', 'BY', 'ASC', 'DESC', 'LIMIT', 'OFFSET',
+  'TRUE', 'FALSE', 'NULL',
+]);
+
+const COMPARISONS = new Set(['=', '!=', '<', '<=', '>', '>=']);
+
+/** Parses one SELECT statement; anything left over is an error. */
+export function parse(sql: string): SelectAst {
+  return new Parser(lex(sql)).parseSelect();
+}
+
+class Parser {
+  private readonly tokens: Token[];
+  private pos = 0;
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+  }
+
+  private peek(): Token {
+    return this.tokens[this.pos];
+  }
+
+  private next(): Token {
+    return this.tokens[this.pos++];
+  }
+
+  private fail(expectation: string, tok: Token): never {
+    const found = tok.type === 'eof' ? 'end of input' : `"${tok.text}"`;
+    throw new SqlError(`col ${tok.col}: expected ${expectation}, found ${found}`, tok.col);
+  }
+
+  private isKeyword(tok: Token, word: string): boolean {
+    return tok.type === 'ident' && tok.text.toUpperCase() === word;
+  }
+
+  private takeKeyword(word: string): boolean {
+    if (this.isKeyword(this.peek(), word)) {
+      this.pos++;
+      return true;
+    }
+    return false;
+  }
+
+  private expectKeyword(word: string): void {
+    if (!this.takeKeyword(word)) this.fail(word, this.peek());
+  }
+
+  /** A plain identifier — keywords are reserved and never names. */
+  private name(expectation: string): string {
+    const tok = this.peek();
+    if (tok.type !== 'ident' || KEYWORDS.has(tok.text.toUpperCase())) {
+      this.fail(expectation, tok);
+    }
+    return this.next().text;
+  }
+
+  parseSelect(): SelectAst {
+    this.expectKeyword('SELECT');
+    const columns = this.selectList();
+    this.expectKeyword('FROM');
+    const table = this.name('table name');
+    const where = this.takeKeyword('WHERE') ? this.predicates() : null;
+    const orderBy = this.orderClause();
+    const { limit, offset } = this.limitClause();
+    const tail = this.peek();
+    if (tail.type !== 'eof') this.fail('end of input', tail);
+    return { columns, table, where, orderBy, limit, offset };
+  }
+
+  private selectList(): '*' | string[] {
+    const tok = this.peek();
+    if (tok.type === 'symbol' && tok.text === '*') {
+      this.pos++;
+      return '*';
+    }
+    if (tok.type !== 'ident' || KEYWORDS.has(tok.text.toUpperCase())) {
+      this.fail('column name or *', tok);
+    }
+    const columns = [this.next().text];
+    while (this.takeSymbol(',')) {
+      columns.push(this.name('column name'));
+    }
+    return columns;
+  }
+
+  private takeSymbol(text: string): boolean {
+    const tok = this.peek();
+    if (tok.type === 'symbol' && tok.text === text) {
+      this.pos++;
+      return true;
+    }
+    return false;
+  }
+
+  /** pred (AND pred)*, left-associative. */
+  private predicates(): Expr {
+    let expr = this.predicate();
+    while (this.takeKeyword('AND')) {
+      expr = { op: 'and', left: expr, right: this.predicate() };
+    }
+    return expr;
+  }
+
+  private predicate(): Expr {
+    const column = this.name('column name');
+    const tok = this.peek();
+    if (tok.type === 'symbol' && COMPARISONS.has(tok.text)) {
+      this.pos++;
+      const op = tok.text as '=' | '!=' | '<' | '<=' | '>' | '>=';
+      return { op, column, value: this.literal() };
+    }
+    if (this.takeKeyword('IN')) {
+      if (!this.takeSymbol('(')) this.fail('(', this.peek());
+      const values = [this.literal()];
+      for (;;) {
+        if (this.takeSymbol(')')) break;
+        if (this.takeSymbol(',')) {
+          values.push(this.literal());
+          continue;
+        }
+        this.fail(') or comma', this.peek());
+      }
+      return { op: 'in', column, values };
+    }
+    this.fail('a comparison operator or IN', tok);
+  }
+
+  private literal(): Literal {
+    const tok = this.peek();
+    if (tok.type === 'number') {
+      this.pos++;
+      return tok.value as number;
+    }
+    if (tok.type === 'string') {
+      this.pos++;
+      return tok.value as string;
+    }
+    if (this.takeKeyword('TRUE')) return true;
+    if (this.takeKeyword('FALSE')) return false;
+    if (this.takeKeyword('NULL')) return null;
+    this.fail('a value', tok);
+  }
+
+  private orderClause(): OrderKey[] {
+    if (!this.takeKeyword('ORDER')) return [];
+    this.expectKeyword('BY');
+    const keys: OrderKey[] = [];
+    do {
+      const column = this.name('column name');
+      let dir: 'asc' | 'desc' = 'asc';
+      if (this.takeKeyword('DESC')) dir = 'desc';
+      else if (this.takeKeyword('ASC')) dir = 'asc';
+      keys.push({ column, dir });
+    } while (this.takeSymbol(','));
+    return keys;
+  }
+
+  private limitClause(): { limit: number | null; offset: number | null } {
+    if (!this.takeKeyword('LIMIT')) return { limit: null, offset: null };
+    const limit = this.nonNegativeInt();
+    const offset = this.takeKeyword('OFFSET') ? this.nonNegativeInt() : null;
+    return { limit, offset };
+  }
+
+  private nonNegativeInt(): number {
+    const tok = this.peek();
+    if (tok.type !== 'number' || !Number.isInteger(tok.value) || (tok.value as number) < 0) {
+      this.fail('a non-negative integer', tok);
+    }
+    this.pos++;
+    return tok.value as number;
+  }
+}
diff --git a/planner.ts b/planner.ts
