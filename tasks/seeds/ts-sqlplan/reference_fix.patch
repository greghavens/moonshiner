index 0000000..ffab760
--- /dev/null
+++ b/planner.ts
@@ -0,0 +1,60 @@
+import { SqlError } from './errors.ts';
+import { parse, type Expr, type OrderKey } from './parser.ts';
+
+export interface Catalog {
+  [table: string]: { columns: string[] };
+}
+
+export type PlanNode =
+  | { node: 'scan'; table: string }
+  | { node: 'filter'; input: PlanNode; predicates: Expr[] }
+  | { node: 'sort'; input: PlanNode; keys: OrderKey[] }
+  | { node: 'slice'; input: PlanNode; offset: number; limit: number | null }
+  | { node: 'project'; input: PlanNode; columns: string[] };
+
+/**
+ * plan parses sql and lowers it to a logical plan tree, validating every
+ * table and column name against the catalog. Pure: the catalog is only
+ * read, never mutated, and no execution happens here.
+ */
+export function plan(sql: string, catalog: Catalog): PlanNode {
+  const ast = parse(sql);
+  const table = catalog[ast.table];
+  if (table === undefined) {
+    throw new SqlError(`unknown table "${ast.table}"`);
+  }
+  const known = new Set(table.columns);
+  const check = (column: string): void => {
+    if (!known.has(column)) {
+      throw new SqlError(`unknown column "${column}" in table "${ast.table}"`);
+    }
+  };
+
+  const projected = ast.columns === '*' ? [...table.columns] : [...ast.columns];
+  if (ast.columns !== '*') {
+    for (const column of ast.columns) check(column);
+  }
+  const predicates = ast.where === null ? [] : flattenAnd(ast.where);
+  for (const pred of predicates) check((pred as { column: string }).column);
+  for (const key of ast.orderBy) check(key.column);
+
+  let node: PlanNode = { node: 'scan', table: ast.table };
+  if (predicates.length > 0) {
+    node = { node: 'filter', input: node, predicates };
+  }
+  if (ast.orderBy.length > 0) {
+    node = { node: 'sort', input: node, keys: ast.orderBy.map((k) => ({ ...k })) };
+  }
+  if (ast.limit !== null || ast.offset !== null) {
+    node = { node: 'slice', input: node, offset: ast.offset ?? 0, limit: ast.limit };
+  }
+  return { node: 'project', input: node, columns: projected };
+}
+
+/** Flattens a left-associative AND chain back into source order. */
+function flattenAnd(expr: Expr): Expr[] {
+  if (expr.op === 'and') {
+    return [...flattenAnd(expr.left), expr.right];
+  }
+  return [expr];
+}
