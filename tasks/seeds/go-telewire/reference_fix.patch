+const hexDigits = "0123456789abcdef"
+
+// appendEscaped appends s to dst, escaping the four wire metacharacters
+// byte by byte — no intermediate strings, no allocations beyond growth
+// of dst itself.
+func appendEscaped(dst []byte, s string) []byte {
+	for i := 0; i < len(s); i++ {
+		switch c := s[i]; c {
+		case '\\':
+			dst = append(dst, '\\', '\\')
+		case '|':
+			dst = append(dst, '\\', '|')
+		case '\n':
+			dst = append(dst, '\\', 'n')
+		case '\r':
+			dst = append(dst, '\\', 'r')
+		default:
+			dst = append(dst, c)
+		}
+	}
+	return dst
 }
 
