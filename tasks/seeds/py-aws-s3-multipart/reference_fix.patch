+++ b/s3mpu/planning.py
@@ -0,0 +1,47 @@
+"""Part planning for S3 multipart uploads.
+
+The limits come from the S3 multipart documentation: parts are numbered
+1..10,000, every part except the last must be at least 5 MiB, and AWS
+recommends multipart for objects of 100 MB and larger. Part numbers are kept
+consecutive from 1 because composite checksums require it.
+"""
+
+from dataclasses import dataclass
+
+MIN_PART_SIZE = 5 * 1024 * 1024
+DEFAULT_MULTIPART_THRESHOLD = 100 * 1024 * 1024
+MAX_PARTS = 10_000
+
+
+@dataclass(frozen=True)
+class PartPlan:
+    number: int
+    offset: int
+    size: int
+
+
+def select_strategy(total_size, threshold=DEFAULT_MULTIPART_THRESHOLD):
+    return "multipart" if total_size >= threshold else "single"
+
+
+def plan_parts(total_size, part_size, *, min_part_size=MIN_PART_SIZE, max_parts=MAX_PARTS):
+    if total_size <= 0:
+        raise ValueError("cannot plan parts for an empty object")
+    if part_size < min_part_size:
+        raise ValueError(
+            f"part_size {part_size} is below the {min_part_size}-byte floor"
+        )
+    count = -(-total_size // part_size)
+    if count > max_parts:
+        raise ValueError(
+            f"{count} parts of {part_size} bytes exceed the {max_parts}-part maximum"
+        )
+    plan = []
+    offset = 0
+    number = 1
+    while offset < total_size:
+        size = min(part_size, total_size - offset)
+        plan.append(PartPlan(number=number, offset=offset, size=size))
+        offset += size
+        number += 1
+    return plan
