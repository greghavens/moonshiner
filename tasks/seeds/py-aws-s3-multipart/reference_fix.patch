@@ -0,0 +1,28 @@
+"""Error taxonomy for the uploader.
+
+Retryable codes follow the boto3 standard retry mode's transient/throttling
+set as they apply to S3; anything else (AccessDenied, InvalidPart,
+InvalidPartOrder, EntityTooSmall, NoSuchUpload, ...) is terminal and must not
+burn retry attempts.
+"""
+
+RETRYABLE_ERROR_CODES = frozenset(
+    {
+        "InternalError",
+        "RequestTimeout",
+        "ServiceUnavailable",
+        "SlowDown",
+        "Throttling",
+        "ThrottlingException",
+    }
+)
+
+
+class UploadFailed(Exception):
+    """An upload could not be finished; any started multipart was aborted."""
+
+    def __init__(self, key, upload_id, error_code, message=""):
+        super().__init__(f"upload of {key!r} failed ({error_code}): {message}")
+        self.key = key
+        self.upload_id = upload_id
+        self.error_code = error_code
