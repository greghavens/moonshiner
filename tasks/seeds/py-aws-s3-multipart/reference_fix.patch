@@ -0,0 +1,169 @@
+"""Upload driver: strategy selection, retries with backoff, abort-on-failure."""
+
+import time
+from dataclasses import dataclass
+
+from botocore.exceptions import ClientError
+
+from .errors import RETRYABLE_ERROR_CODES, UploadFailed
+from .planning import (
+    DEFAULT_MULTIPART_THRESHOLD,
+    MIN_PART_SIZE,
+    plan_parts,
+    select_strategy,
+)
+
+CHECKSUM_ALGORITHM = "CRC32"
+
+
+@dataclass(frozen=True)
+class PartResult:
+    number: int
+    etag: str
+    checksum_crc32: str | None
+
+
+@dataclass
+class UploadResult:
+    key: str
+    strategy: str
+    upload_id: str | None
+    etag: str | None
+    checksum_crc32: str | None
+    parts: list
+
+
+def _error_code(err):
+    return err.response.get("Error", {}).get("Code", "")
+
+
+class MultipartUploader:
+    def __init__(
+        self,
+        client,
+        bucket,
+        *,
+        part_size=8 * 1024 * 1024,
+        threshold=DEFAULT_MULTIPART_THRESHOLD,
+        min_part_size=MIN_PART_SIZE,
+        max_attempts=4,
+        base_delay=0.5,
+        max_delay=8.0,
+        sleep=time.sleep,
+    ):
+        self.client = client
+        self.bucket = bucket
+        self.part_size = part_size
+        self.threshold = threshold
+        self.min_part_size = min_part_size
+        self.max_attempts = max_attempts
+        self.base_delay = base_delay
+        self.max_delay = max_delay
+        self._sleep = sleep
+
+    def upload(self, key, data, content_type=None):
+        if select_strategy(len(data), self.threshold) == "single":
+            return self._upload_single(key, data, content_type)
+        return self._upload_multipart(key, data, content_type)
+
+    # -- transport ---------------------------------------------------------
+
+    def _call(self, method, **params):
+        attempt = 1
+        while True:
+            try:
+                return getattr(self.client, method)(**params)
+            except ClientError as err:
+                code = _error_code(err)
+                if code not in RETRYABLE_ERROR_CODES or attempt >= self.max_attempts:
+                    raise
+                self._sleep(min(self.max_delay, self.base_delay * 2 ** (attempt - 1)))
+                attempt += 1
+
+    # -- strategies --------------------------------------------------------
+
+    def _upload_single(self, key, data, content_type):
+        params = {
+            "Bucket": self.bucket,
+            "Key": key,
+            "Body": data,
+            "ChecksumAlgorithm": CHECKSUM_ALGORITHM,
+        }
+        if content_type is not None:
+            params["ContentType"] = content_type
+        try:
+            resp = self._call("put_object", **params)
+        except ClientError as err:
+            raise UploadFailed(key, None, _error_code(err), str(err)) from err
+        return UploadResult(
+            key=key,
+            strategy="single",
+            upload_id=None,
+            etag=resp.get("ETag"),
+            checksum_crc32=resp.get("ChecksumCRC32"),
+            parts=[],
+        )
+
+    def _upload_multipart(self, key, data, content_type):
+        plan = plan_parts(len(data), self.part_size, min_part_size=self.min_part_size)
+        create = {
+            "Bucket": self.bucket,
+            "Key": key,
+            "ChecksumAlgorithm": CHECKSUM_ALGORITHM,
+        }
+        if content_type is not None:
+            create["ContentType"] = content_type
+        try:
+            created = self._call("create_multipart_upload", **create)
+        except ClientError as err:
+            raise UploadFailed(key, None, _error_code(err), str(err)) from err
+        upload_id = created["UploadId"]
+
+        parts = []
+        try:
+            for part in plan:
+                resp = self._call(
+                    "upload_part",
+                    Bucket=self.bucket,
+                    Key=key,
+                    UploadId=upload_id,
+                    PartNumber=part.number,
+                    Body=data[part.offset : part.offset + part.size],
+                )
+                parts.append(
+                    PartResult(part.number, resp["ETag"], resp.get("ChecksumCRC32"))
+                )
+            resp = self._call(
+                "complete_multipart_upload",
+                Bucket=self.bucket,
+                Key=key,
+                UploadId=upload_id,
+                MultipartUpload={"Parts": [self._completed(p) for p in parts]},
+            )
+        except ClientError as err:
+            self._abort(key, upload_id)
+            raise UploadFailed(key, upload_id, _error_code(err), str(err)) from err
+        return UploadResult(
+            key=key,
+            strategy="multipart",
+            upload_id=upload_id,
+            etag=resp.get("ETag"),
+            checksum_crc32=resp.get("ChecksumCRC32"),
+            parts=parts,
+        )
+
+    @staticmethod
+    def _completed(part):
+        entry = {"ETag": part.etag, "PartNumber": part.number}
+        if part.checksum_crc32 is not None:
+            entry["ChecksumCRC32"] = part.checksum_crc32
+        return entry
+
+    def _abort(self, key, upload_id):
+        # Best effort: the original failure must win even if the abort fails.
+        try:
+            self.client.abort_multipart_upload(
+                Bucket=self.bucket, Key=key, UploadId=upload_id
+            )
+        except ClientError:
+            pass
