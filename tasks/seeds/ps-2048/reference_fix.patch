diff --git a/play2048.ps1 b/play2048.ps1
new file mode 100644
index 0000000..82fe595
--- /dev/null
+++ b/play2048.ps1
@@ -0,0 +1,230 @@
+# Replayable 2048: deterministic LCG spawns, transcript output.
+[CmdletBinding()]
+param(
+    [string]$Moves = '',
+    [string]$Seed = '0',
+    [string]$Board = ''
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail([string]$Message) {
+    [Console]::Error.WriteLine($Message)
+    exit 2
+}
+
+if ($Moves -ceq '') {
+    Fail 'usage: play2048.ps1 -Moves <file> [-Seed <n>] [-Board <file>]'
+}
+if ($Seed -cnotmatch '^\d+$') {
+    Fail 'error: seed must be a non-negative integer'
+}
+
+function Read-AllText([string]$Path) {
+    try {
+        return [System.IO.File]::ReadAllText($Path)
+    } catch {
+        Fail "error: cannot read $Path"
+    }
+}
+
+$movesText = Read-AllText $Moves
+$moveList = [System.Collections.Generic.List[char]]::new()
+$lineNo = 0
+foreach ($raw in $movesText.Split("`n")) {
+    $lineNo++
+    $line = $raw.TrimEnd("`r").Trim()
+    if ($line.Length -eq 0 -or $line.StartsWith('#', [System.StringComparison]::Ordinal)) { continue }
+    if ($line -cnotmatch '^[LRUD]$') {
+        Fail "error: bad move line ${lineNo}: $line"
+    }
+    $moveList.Add($line[0])
+}
+# a trailing newline yields one final empty chunk; that's fine, it was skipped
+
+$grid = [int[][]]::new(4)
+for ($r = 0; $r -lt 4; $r++) { $grid[$r] = [int[]]::new(4) }
+
+function Test-PowerOfTwo([long]$n) {
+    return ($n -ge 2) -and (($n -band ($n - 1)) -eq 0)
+}
+
+if ($Board -cne '') {
+    $boardText = Read-AllText $Board
+    $lines = @($boardText.Split("`n") | ForEach-Object { $_.TrimEnd("`r") } | Where-Object { $_.Trim().Length -gt 0 })
+    if ($lines.Count -ne 4) {
+        if ($lines.Count -gt 4) {
+            Fail "error: bad board line 5: $($lines[4])"
+        }
+        Fail "error: bad board line $($lines.Count + 1): "
+    }
+    for ($r = 0; $r -lt 4; $r++) {
+        $tokens = -split $lines[$r]
+        $ok = $tokens.Count -eq 4
+        if ($ok) {
+            for ($c = 0; $c -lt 4; $c++) {
+                $t = $tokens[$c]
+                if ($t -ceq '.') { $grid[$r][$c] = 0; continue }
+                $val = 0L
+                if (-not [long]::TryParse($t, [ref]$val) -or -not (Test-PowerOfTwo $val)) { $ok = $false; break }
+                $grid[$r][$c] = [int]$val
+            }
+        }
+        if (-not $ok) {
+            Fail "error: bad board line $($r + 1): $($lines[$r])"
+        }
+    }
+}
+
+# --- pinned LCG ---
+$script:LcgState = [long][int]$Seed
+function Get-Draw {
+    $script:LcgState = ($script:LcgState * 1103515245 + 12345) % 2147483648
+    return [long][Math]::Floor($script:LcgState / 65536)
+}
+
+function Get-Empties {
+    $cells = [System.Collections.Generic.List[int[]]]::new()
+    for ($r = 0; $r -lt 4; $r++) {
+        for ($c = 0; $c -lt 4; $c++) {
+            if ($grid[$r][$c] -eq 0) { $cells.Add(@($r, $c)) }
+        }
+    }
+    return , $cells
+}
+
+function Add-Spawn {
+    $empties = Get-Empties
+    $idx = [int]((Get-Draw) % $empties.Count)
+    $tile = if (((Get-Draw) % 10) -eq 0) { 4 } else { 2 }
+    $cell = $empties[$idx]
+    $grid[$cell[0]][$cell[1]] = $tile
+    return @($cell[0], $cell[1], $tile)
+}
+
+function Write-Grid {
+    for ($r = 0; $r -lt 4; $r++) {
+        $tokens = for ($c = 0; $c -lt 4; $c++) {
+            if ($grid[$r][$c] -eq 0) { '.' } else { [string]$grid[$r][$c] }
+        }
+        Write-Output ($tokens -join ' ')
+    }
+}
+
+# Slides a 4-vector toward index 0, merging the pair nearest the target edge
+# first; returns @(newVector, gained).
+function Get-Slide([int[]]$Vals) {
+    $tiles = @($Vals | Where-Object { $_ -ne 0 })
+    $res = [int[]]::new(4)
+    $gained = 0
+    $o = 0
+    $i = 0
+    while ($i -lt $tiles.Count) {
+        if ($i + 1 -lt $tiles.Count -and $tiles[$i] -eq $tiles[$i + 1]) {
+            $res[$o] = $tiles[$i] * 2
+            $gained += $res[$o]
+            $i += 2
+        } else {
+            $res[$o] = $tiles[$i]
+            $i++
+        }
+        $o++
+    }
+    return , @($res, $gained)
+}
+
+# Computes the post-move grid without touching $grid; returns @(newGrid, gained).
+function Get-Moved([char]$Dir) {
+    $ng = [int[][]]::new(4)
+    for ($r = 0; $r -lt 4; $r++) { $ng[$r] = [int[]]::new(4) }
+    $gained = 0
+    for ($k = 0; $k -lt 4; $k++) {
+        $vals = [int[]]::new(4)
+        for ($j = 0; $j -lt 4; $j++) {
+            $vals[$j] = switch ($Dir) {
+                'L' { $grid[$k][$j] }
+                'R' { $grid[$k][3 - $j] }
+                'U' { $grid[$j][$k] }
+                'D' { $grid[3 - $j][$k] }
+            }
+        }
+        $slid = Get-Slide $vals
+        $res = $slid[0]
+        $gained += $slid[1]
+        for ($j = 0; $j -lt 4; $j++) {
+            switch ($Dir) {
+                'L' { $ng[$k][$j] = $res[$j] }
+                'R' { $ng[$k][3 - $j] = $res[$j] }
+                'U' { $ng[$j][$k] = $res[$j] }
+                'D' { $ng[3 - $j][$k] = $res[$j] }
+            }
+        }
+    }
+    return , @($ng, $gained)
+}
+
+function Test-SameGrid([int[][]]$A, [int[][]]$B) {
+    for ($r = 0; $r -lt 4; $r++) {
+        for ($c = 0; $c -lt 4; $c++) {
+            if ($A[$r][$c] -ne $B[$r][$c]) { return $false }
+        }
+    }
+    return $true
+}
+
+function Test-AnyMove {
+    foreach ($d in @([char]'L', [char]'R', [char]'U', [char]'D')) {
+        $m = Get-Moved $d
+        if (-not (Test-SameGrid $m[0] $grid)) { return $true }
+    }
+    return $false
+}
+
+$score = 0
+$won = $false
+
+if ($Board -ceq '') {
+    [void](Add-Spawn)
+    [void](Add-Spawn)
+}
+
+Write-Output 'INIT score=0'
+Write-Grid
+
+if (-not (Test-AnyMove)) {
+    Write-Output "GAME OVER score=$score"
+    exit 0
+}
+
+foreach ($d in $moveList) {
+    $m = Get-Moved $d
+    if (Test-SameGrid $m[0] $grid) {
+        Write-Output "MOVE $d rejected"
+        continue
+    }
+    $grid = $m[0]
+    $score += $m[1]
+    $sp = Add-Spawn
+    Write-Output "MOVE $d gained=$($m[1]) score=$score spawn=$($sp[0]),$($sp[1])=$($sp[2])"
+    Write-Grid
+    if (-not $won) {
+        $found = $false
+        for ($r = 0; $r -lt 4; $r++) {
+            for ($c = 0; $c -lt 4; $c++) {
+                if ($grid[$r][$c] -eq 2048) { $found = $true }
+            }
+        }
+        if ($found) {
+            $won = $true
+            Write-Output 'WIN'
+        }
+    }
+    if (-not (Test-AnyMove)) {
+        Write-Output "GAME OVER score=$score"
+        exit 0
+    }
+}
+
+Write-Output "END score=$score"
+exit 0
