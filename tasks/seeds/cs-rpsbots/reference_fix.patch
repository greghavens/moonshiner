@@ -0,0 +1,84 @@
+namespace RpsBots;
+
+public enum Move { Rock, Paper, Scissors }
+
+public static class Rules
+{
+    public static bool Beats(Move a, Move b) =>
+        (a, b) is (Move.Rock, Move.Scissors)
+               or (Move.Scissors, Move.Paper)
+               or (Move.Paper, Move.Rock);
+
+    public static Move Counter(Move m) => m switch
+    {
+        Move.Rock => Move.Paper,
+        Move.Paper => Move.Scissors,
+        _ => Move.Rock,
+    };
+
+    public static string Label(Move m) => m switch
+    {
+        Move.Rock => "ROCK",
+        Move.Paper => "PAPER",
+        _ => "SCISSORS",
+    };
+}
+
+public interface IBot
+{
+    string Name { get; }
+    Move Next(IReadOnlyList<Move> opponentMoves);
+}
+
+public class ConstantBot : IBot
+{
+    private readonly Move _move;
+    public string Name { get; }
+
+    public ConstantBot(string name, Move move) => (Name, _move) = (name, move);
+
+    public Move Next(IReadOnlyList<Move> opponentMoves) => _move;
+}
+
+public class CyclerBot : IBot
+{
+    private readonly IReadOnlyList<Move> _sequence;
+    public string Name { get; }
+
+    public CyclerBot(string name, IReadOnlyList<Move> sequence)
+    {
+        if (sequence.Count == 0)
+            throw new ArgumentException("cycler needs a non-empty sequence");
+        (Name, _sequence) = (name, sequence.ToArray());
+    }
+
+    public Move Next(IReadOnlyList<Move> opponentMoves) =>
+        _sequence[opponentMoves.Count % _sequence.Count];
+}
+
+public class CopyLastBot : IBot
+{
+    public string Name { get; }
+
+    public CopyLastBot(string name) => Name = name;
+
+    public Move Next(IReadOnlyList<Move> opponentMoves) =>
+        opponentMoves.Count == 0 ? Move.Rock : opponentMoves[^1];
+}
+
+public class FrequencyBot : IBot
+{
+    public string Name { get; }
+
+    public FrequencyBot(string name) => Name = name;
+
+    public Move Next(IReadOnlyList<Move> opponentMoves)
+    {
+        var counts = new int[3];
+        foreach (var m in opponentMoves) counts[(int)m]++;
+        var best = Move.Rock;
+        foreach (var m in new[] { Move.Paper, Move.Scissors })
+            if (counts[(int)m] > counts[(int)best]) best = m;
+        return Rules.Counter(best);
+    }
+}
diff --git a/Tournament.cs b/Tournament.cs
new file mode 100644
index 0000000..cb5c713
--- /dev/null
+++ b/Tournament.cs
@@ -0,0 +1,131 @@
+namespace RpsBots;
+
+public class MatchResult
+{
+    public int WinsA { get; init; }
+    public int WinsB { get; init; }
+    public int Draws { get; init; }
+    public IReadOnlyList<string> Transcript { get; init; } = Array.Empty<string>();
+}
+
+public static class Match
+{
+    public static MatchResult Play(IBot a, IBot b, int rounds)
+    {
+        if (rounds < 1)
+            throw new ArgumentOutOfRangeException(nameof(rounds), rounds, "need at least one round");
+        var historyA = new List<Move>();
+        var historyB = new List<Move>();
+        var lines = new List<string>();
+        int winsA = 0, winsB = 0, draws = 0;
+        for (var round = 1; round <= rounds; round++)
+        {
+            var moveA = a.Next(historyB);
+            var moveB = b.Next(historyA);
+            string outcome;
+            if (Rules.Beats(moveA, moveB)) { winsA++; outcome = a.Name; }
+            else if (Rules.Beats(moveB, moveA)) { winsB++; outcome = b.Name; }
+            else { draws++; outcome = "draw"; }
+            lines.Add($"R{round}: {a.Name} {Rules.Label(moveA)} vs {b.Name} {Rules.Label(moveB)} -> {outcome}");
+            historyA.Add(moveA);
+            historyB.Add(moveB);
+        }
+        return new MatchResult { WinsA = winsA, WinsB = winsB, Draws = draws, Transcript = lines };
+    }
+}
+
+public static class Tournament
+{
+    public static string Run(string rosterText, int roundsPerMatch)
+    {
+        var bots = ParseRoster(rosterText);
+        if (bots.Count < 2)
+            throw new ArgumentException("a tournament needs at least two bots");
+
+        var output = new List<string>();
+        var stats = bots.ToDictionary(b => b.Name, _ => new Standing());
+        for (var i = 0; i < bots.Count; i++)
+        {
+            for (var j = i + 1; j < bots.Count; j++)
+            {
+                var (a, b) = (bots[i], bots[j]);
+                var result = Match.Play(a, b, roundsPerMatch);
+                output.Add($"MATCH {a.Name} vs {b.Name}");
+                output.AddRange(result.Transcript);
+                output.Add($"RESULT {a.Name} {result.WinsA} {b.Name} {result.WinsB}");
+                stats[a.Name].Record(result.WinsA, result.WinsB);
+                stats[b.Name].Record(result.WinsB, result.WinsA);
+            }
+        }
+
+        output.Add("STANDINGS");
+        var ranked = stats
+            .OrderByDescending(kv => kv.Value.Points)
+            .ThenByDescending(kv => kv.Value.RoundWins - kv.Value.RoundLosses)
+            .ThenByDescending(kv => kv.Value.RoundWins)
+            .ThenBy(kv => kv.Key, StringComparer.Ordinal)
+            .ToList();
+        for (var pos = 0; pos < ranked.Count; pos++)
+        {
+            var (name, s) = (ranked[pos].Key, ranked[pos].Value);
+            output.Add($"{pos + 1}. {name} pts={s.Points} w={s.Won} d={s.Drawn} l={s.Lost} " +
+                       $"rw={s.RoundWins} rl={s.RoundLosses}");
+        }
+        return string.Join('\n', output);
+    }
+
+    private static List<IBot> ParseRoster(string text)
+    {
+        var bots = new List<IBot>();
+        var names = new HashSet<string>();
+        foreach (var rawLine in text.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            var parts = line.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries);
+            if (parts.Length == 0) continue;
+            var name = parts[0];
+            var kind = parts.Length > 1 ? parts[1] : "";
+            IBot bot = kind switch
+            {
+                "constant" when parts.Length == 3 => new ConstantBot(name, ParseMove(parts[2][0], parts[2].Length == 1)),
+                "cycler" when parts.Length == 3 => new CyclerBot(name, parts[2].Select(c => ParseMove(c, true)).ToArray()),
+                "copylast" when parts.Length == 2 => new CopyLastBot(name),
+                "counter" when parts.Length == 2 => new FrequencyBot(name),
+                _ => throw new FormatException($"bad roster line: {rawLine.Trim()}"),
+            };
+            if (!names.Add(name))
+                throw new ArgumentException($"duplicate bot name: {name}");
+            bots.Add(bot);
+        }
+        return bots;
+    }
+
+    private static Move ParseMove(char letter, bool wellFormed)
+    {
+        if (!wellFormed)
+            throw new FormatException($"bad move token");
+        return letter switch
+        {
+            'R' => Move.Rock,
+            'P' => Move.Paper,
+            'S' => Move.Scissors,
+            _ => throw new FormatException($"bad move letter: {letter}"),
+        };
+    }
+
+    private sealed class Standing
+    {
+        public int Points, Won, Drawn, Lost, RoundWins, RoundLosses;
+
+        public void Record(int mine, int theirs)
+        {
+            RoundWins += mine;
+            RoundLosses += theirs;
+            if (mine > theirs) { Points += 3; Won++; }
+            else if (mine < theirs) { Lost++; }
+            else { Points += 1; Drawn++; }
+        }
+    }
+}
