diff --git a/c4.c b/c4.c
new file mode 100644
index 0000000..5c89b72
--- /dev/null
+++ b/c4.c
@@ -0,0 +1,75 @@
+#include "c4.h"
+
+/* bit = col*7 + row, row 0 at the bottom; bit col*7+6 is the sentinel row */
+
+void c4_init(c4 *p) {
+    p->red = 0;
+    p->yel = 0;
+    p->moves = 0;
+}
+
+int c4_win(uint64_t bb) {
+    static const int dirs[4] = {1, 7, 6, 8};
+    for (int i = 0; i < 4; i++) {
+        uint64_t m = bb & (bb >> dirs[i]);
+        if (m & (m >> (2 * dirs[i]))) return 1;
+    }
+    return 0;
+}
+
+static int col_height(const c4 *p, int col) {
+    uint64_t stones = (p->red | p->yel) >> (col * 7);
+    int h = 0;
+    while (stones & 1) {
+        h++;
+        stones >>= 1;
+    }
+    return h;
+}
+
+static int game_over(const c4 *p) {
+    return p->moves == 42 || c4_win(p->red) || c4_win(p->yel);
+}
+
+int c4_drop(c4 *p, int col) {
+    if (col < 0 || col > 6 || game_over(p)) return -1;
+    int h = col_height(p, col);
+    if (h >= 6) return -1;
+    uint64_t bit = 1ULL << (col * 7 + h);
+    if (p->moves % 2 == 0) p->red |= bit;
+    else p->yel |= bit;
+    p->moves++;
+    return 0;
+}
+
+int c4_encode(c4 *p, const char *moves) {
+    if (!moves) return -1;
+    c4_init(p);
+    for (const char *m = moves; *m; m++) {
+        if (*m < '0' || *m > '6') return -1;
+        if (c4_drop(p, *m - '0') != 0) return -1;
+    }
+    return 0;
+}
+
+uint8_t c4_legal(const c4 *p) {
+    if (game_over(p)) return 0;
+    uint8_t mask = 0;
+    for (int col = 0; col < 7; col++)
+        if (col_height(p, col) < 6) mask |= (uint8_t)(1u << col);
+    return mask;
+}
+
+long c4_perft(const c4 *p, int depth) {
+    if (depth < 0) return 0;
+    if (depth == 0) return 1;
+    uint8_t mask = c4_legal(p);
+    long total = 0;
+    for (int col = 0; col < 7; col++) {
+        if (!(mask & (1u << col))) continue;
+        c4 child = *p;
+        c4_drop(&child, col);
+        total += c4_perft(&child, depth - 1);
+    }
+    return total;
+}
diff --git a/c4.h b/c4.h
new file mode 100644
index 0000000..3e83091
--- /dev/null
+++ b/c4.h
@@ -0,0 +1,15 @@
+#ifndef C4_H
+#define C4_H
+
+#include <stdint.h>
+
+typedef struct { uint64_t red; uint64_t yel; int moves; } c4;
+
+void    c4_init(c4 *p);
+int     c4_drop(c4 *p, int col);
+int     c4_encode(c4 *p, const char *moves);
+int     c4_win(uint64_t bb);
+uint8_t c4_legal(const c4 *p);
+long    c4_perft(const c4 *p, int depth);
+
+#endif /* C4_H */
