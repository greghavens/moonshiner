+export type PathSeg = string | number;
+
+export type DiffOp =
+  | { op: 'change'; path: PathSeg[]; from: unknown; to: unknown }
+  | { op: 'add'; path: PathSeg[]; value: unknown }
+  | { op: 'remove'; path: PathSeg[] };
+
+function isPlainObject(v: unknown): v is Record<string, unknown> {
+  return v !== null && typeof v === 'object' && !Array.isArray(v);
+}
+
+function kindOf(v: unknown): 'array' | 'object' | 'leaf' {
+  if (Array.isArray(v)) return 'array';
+  if (isPlainObject(v)) return 'object';
+  return 'leaf';
+}
+
+export function diff(before: unknown, after: unknown): DiffOp[] {
+  const ops: DiffOp[] = [];
+  walk(before, after, [], ops);
+  return ops;
+}
+
+function walk(before: unknown, after: unknown, path: PathSeg[], ops: DiffOp[]): void {
+  const kb = kindOf(before);
+  const ka = kindOf(after);
+
+  if (kb !== ka) {
+    ops.push({ op: 'change', path, from: before, to: after });
+    return;
+  }
+
+  if (kb === 'leaf') {
+    if (!Object.is(before, after)) {
+      ops.push({ op: 'change', path, from: before, to: after });
+    }
+    return;
+  }
+
+  if (kb === 'array') {
+    const b = before as unknown[];
+    const a = after as unknown[];
+    const shared = Math.min(b.length, a.length);
+    for (let i = 0; i < shared; i++) {
+      walk(b[i], a[i], [...path, i], ops);
+    }
+    for (let i = shared; i < a.length; i++) {
+      ops.push({ op: 'add', path: [...path, i], value: a[i] });
+    }
+    for (let i = b.length - 1; i >= shared; i--) {
+      ops.push({ op: 'remove', path: [...path, i] });
+    }
+    return;
+  }
+
+  const b = before as Record<string, unknown>;
+  const a = after as Record<string, unknown>;
+  const keys = [...new Set([...Object.keys(b), ...Object.keys(a)])].sort();
+  for (const key of keys) {
+    const inB = Object.prototype.hasOwnProperty.call(b, key);
+    const inA = Object.prototype.hasOwnProperty.call(a, key);
+    if (inB && !inA) ops.push({ op: 'remove', path: [...path, key] });
+    else if (!inB && inA) ops.push({ op: 'add', path: [...path, key], value: a[key] });
+    else walk(b[key], a[key], [...path, key], ops);
+  }
+}
+
+function clone<T>(v: T): T {
+  if (Array.isArray(v)) return v.map(clone) as unknown as T;
+  if (isPlainObject(v)) {
+    const out: Record<string, unknown> = {};
+    for (const [k, val] of Object.entries(v)) out[k] = clone(val);
+    return out as unknown as T;
+  }
+  return v;
+}
+
+export function apply(base: unknown, ops: DiffOp[]): unknown {
+  let root = clone(base);
+  for (const op of ops) {
+    if (op.path.length === 0) {
+      if (op.op === 'change') root = clone(op.to);
+      else if (op.op === 'add') root = clone(op.value);
+      else root = undefined;
+      continue;
+    }
+    const parent = resolveParent(root, op.path);
+    const last = op.path[op.path.length - 1];
+    if (Array.isArray(parent)) {
+      const idx = last as number;
+      if (op.op === 'remove') parent.splice(idx, 1);
+      else if (op.op === 'add') parent.splice(idx, 0, clone(op.value));
+      else parent[idx] = clone(op.to);
+    } else {
+      const obj = parent as Record<string, unknown>;
+      const key = String(last);
+      if (op.op === 'remove') delete obj[key];
+      else if (op.op === 'add') obj[key] = clone(op.value);
+      else obj[key] = clone(op.to);
+    }
+  }
+  return root;
+}
+
+function resolveParent(root: unknown, path: PathSeg[]): unknown {
+  let node = root;
+  for (let i = 0; i < path.length - 1; i++) {
+    node = (node as Record<PathSeg, unknown>)[path[i]];
+  }
+  return node;
+}
