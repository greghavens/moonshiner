+//! Decoder for the escaped one-line fixture format used by the CLI
+//! snapshot harness. Errors carry byte-exact spans so the fixture
+//! linter can underline the offending escape.
+
+use std::fmt;
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum EscapeErrorKind {
+    TrailingBackslash,
+    UnknownEscape(char),
+    BareUnicode,
+    UnterminatedUnicode,
+    EmptyUnicode,
+    BadHexDigit(char),
+    OverlongUnicode,
+    OutOfRange(u32),
+    LoneSurrogate(u32),
+    TruncatedByte,
+    ByteOutOfRange(u8),
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct EscapeError {
+    pub kind: EscapeErrorKind,
+    pub start: usize,
+    pub end: usize,
+}
+
+impl fmt::Display for EscapeError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        write!(f, "invalid escape at bytes {}..{}", self.start, self.end)
+    }
+}
+
+impl std::error::Error for EscapeError {}
+
+fn err(kind: EscapeErrorKind, start: usize, end: usize) -> EscapeError {
+    EscapeError { kind, start, end }
+}
+
+/// Decodes one escaped fixture line. Scans left to right; the first
+/// invalid escape wins.
+pub fn unescape(src: &str) -> Result<String, EscapeError> {
+    let mut out = String::new();
+    let mut it = src.char_indices().peekable();
+    while let Some((start, c)) = it.next() {
+        if c != '\\' {
+            out.push(c);
+            continue;
+        }
+        let Some((_, esc)) = it.next() else {
+            return Err(err(EscapeErrorKind::TrailingBackslash, start, src.len()));
+        };
+        match esc {
+            'n' => out.push('\n'),
+            't' => out.push('\t'),
+            'r' => out.push('\r'),
+            '0' => out.push('\0'),
+            '\\' => out.push('\\'),
+            '"' => out.push('"'),
+            '\'' => out.push('\''),
+            'x' => {
+                let mut value: u32 = 0;
+                for _ in 0..2 {
+                    match it.next() {
+                        None => {
+                            return Err(err(EscapeErrorKind::TruncatedByte, start, src.len()))
+                        }
+                        Some((pos, d)) => match d.to_digit(16) {
+                            Some(h) => value = value * 16 + h,
+                            None => {
+                                return Err(err(
+                                    EscapeErrorKind::BadHexDigit(d),
+                                    start,
+                                    pos + d.len_utf8(),
+                                ))
+                            }
+                        },
+                    }
+                }
+                if value > 0x7F {
+                    return Err(err(
+                        EscapeErrorKind::ByteOutOfRange(value as u8),
+                        start,
+                        start + 4,
+                    ));
+                }
+                out.push(value as u8 as char);
+            }
+            'u' => {
+                match it.peek() {
+                    Some(&(_, '{')) => {
+                        it.next();
+                    }
+                    _ => return Err(err(EscapeErrorKind::BareUnicode, start, start + 2)),
+                }
+                let mut value: u32 = 0;
+                let mut digits = 0;
+                loop {
+                    match it.next() {
+                        None => {
+                            return Err(err(EscapeErrorKind::UnterminatedUnicode, start, src.len()))
+                        }
+                        Some((pos, '}')) => {
+                            let end = pos + 1;
+                            if digits == 0 {
+                                return Err(err(EscapeErrorKind::EmptyUnicode, start, end));
+                            }
+                            if value > 0x10FFFF {
+                                return Err(err(EscapeErrorKind::OutOfRange(value), start, end));
+                            }
+                            if (0xD800..=0xDFFF).contains(&value) {
+                                return Err(err(EscapeErrorKind::LoneSurrogate(value), start, end));
+                            }
+                            out.push(char::from_u32(value).expect("range checked above"));
+                            break;
+                        }
+                        Some((pos, d)) => match d.to_digit(16) {
+                            Some(h) => {
+                                digits += 1;
+                                if digits > 6 {
+                                    return Err(err(
+                                        EscapeErrorKind::OverlongUnicode,
+                                        start,
+                                        pos + 1,
+                                    ));
+                                }
+                                value = value * 16 + h;
+                            }
+                            None => {
+                                return Err(err(
+                                    EscapeErrorKind::BadHexDigit(d),
+                                    start,
+                                    pos + d.len_utf8(),
+                                ))
+                            }
+                        },
+                    }
+                }
+            }
+            other => {
+                return Err(err(
+                    EscapeErrorKind::UnknownEscape(other),
+                    start,
+                    start + 1 + other.len_utf8(),
+                ));
+            }
+        }
+    }
+    Ok(out)
+}
