+"""negotiate -- content-negotiation engine for the gateway.
+
+Pure logic, stdlib only: Accept parsing with q-weights, wildcard precedence,
+406 fallback policies and Vary computation.
+"""
+
+_SPECIFICITY = {"exact": 0, "subtype-wildcard": 1, "full-wildcard": 2}
+
+
+def _specificity(item):
+    if item["type"] == "*":
+        return _SPECIFICITY["full-wildcard"]
+    if item["subtype"] == "*":
+        return _SPECIFICITY["subtype-wildcard"]
+    return _SPECIFICITY["exact"]
+
+
+def _parse_item(chunk):
+    """Parse one media-range chunk. Returns an item dict or None if malformed."""
+    parts = [p.strip() for p in chunk.split(";")]
+    media = parts[0]
+    if "/" not in media:
+        return None
+    type_, _, subtype = media.partition("/")
+    type_ = type_.strip().lower()
+    subtype = subtype.strip().lower()
+    if not type_ or not subtype:
+        return None
+    q = 1.0
+    params = {}
+    for raw in parts[1:]:
+        if not raw:
+            continue
+        name, _, value = raw.partition("=")
+        name = name.strip().lower()
+        value = value.strip()
+        if name == "q":
+            try:
+                q = float(value)
+            except ValueError:
+                return None
+        elif name:
+            params[name] = value
+    return {"type": type_, "subtype": subtype, "q": q, "params": params}
+
+
+def parse_accept(value):
+    """Parse an Accept header into item dicts in precedence order."""
+    if value is None:
+        return []
+    items = []
+    for position, chunk in enumerate(value.split(",")):
+        if not chunk.strip():
+            continue
+        item = _parse_item(chunk)
+        if item is not None:
+            items.append((position, item))
+    items.sort(key=lambda pair: (-pair[1]["q"], _specificity(pair[1]), pair[0]))
+    return [item for _, item in items]
+
+
+def _match_quality(items, available_type):
+    """q of the most specific range matching available_type, or None."""
+    type_, _, subtype = available_type.lower().partition("/")
+    best_rank = None
+    best_q = None
+    for item in items:
+        if item["type"] == "*" and item["subtype"] == "*":
+            rank = _SPECIFICITY["full-wildcard"]
+        elif item["type"] == type_ and item["subtype"] == "*":
+            rank = _SPECIFICITY["subtype-wildcard"]
+        elif item["type"] == type_ and item["subtype"] == subtype:
+            rank = _SPECIFICITY["exact"]
+        else:
+            continue
+        if best_rank is None or rank < best_rank:
+            best_rank, best_q = rank, item["q"]
+        elif rank == best_rank and item["q"] > best_q:
+            best_q = item["q"]
+    return best_q
+
+
+def negotiate(value, available):
+    """Pick the best of `available` for the request's Accept header."""
+    if not available:
+        raise ValueError("available must be a non-empty list")
+    if value is None or not value.strip():
+        return available[0]
+    items = parse_accept(value)
+    best_choice = None
+    best_q = 0.0
+    for candidate in available:  # earlier entries win ties: server preference
+        q = _match_quality(items, candidate)
+        if q is None or q <= 0:
+            continue
+        if q > best_q:
+            best_choice, best_q = candidate, q
+    return best_choice
+
+
+def choose(value, available, policy="strict"):
+    """Response shaping: returns (status, content_type, vary)."""
+    if policy not in ("strict", "default"):
+        raise ValueError(f"unknown policy: {policy!r}")
+    vary = "Accept" if len(available) > 1 else None
+    chosen = negotiate(value, available)
+    if chosen is not None:
+        return 200, chosen, vary
+    if policy == "default":
+        return 200, available[0], vary
+    return 406, None, vary
