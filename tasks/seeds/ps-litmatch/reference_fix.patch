diff --git a/litmatch.ps1 b/litmatch.ps1
new file mode 100644
index 0000000..b7af873
--- /dev/null
+++ b/litmatch.ps1
@@ -0,0 +1,48 @@
+# litmatch.ps1 -- pull matching lines from a device journal.
+# literal: plain-text containment; wildcard: whole-line glob; regex: unanchored search.
+# Usage: pwsh -NoProfile -File litmatch.ps1 -Path <file> -Pattern <text> -Mode <mode> [-CaseSensitive]
+param(
+    [Parameter(Mandatory)][string]$Path,
+    [Parameter(Mandatory)][string]$Pattern,
+    [Parameter(Mandatory)][ValidateSet('literal', 'wildcard', 'regex')][string]$Mode,
+    [switch]$CaseSensitive
+)
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if (-not (Test-Path -LiteralPath $Path -PathType Leaf)) {
+    [Console]::Error.WriteLine("litmatch: file not found: $Path")
+    exit 66
+}
+
+$lines = @(Get-Content -LiteralPath $Path)
+
+if ($Mode -eq 'wildcard') {
+    $opts = if ($CaseSensitive) {
+        [System.Management.Automation.WildcardOptions]::None
+    } else {
+        [System.Management.Automation.WildcardOptions]::IgnoreCase
+    }
+    $wp = [System.Management.Automation.WildcardPattern]::new($Pattern, $opts)
+    foreach ($l in $lines) {
+        if ($wp.IsMatch($l)) { Write-Output $l }
+    }
+    exit 0
+}
+
+$rxText = if ($Mode -eq 'literal') { [regex]::Escape($Pattern) } else { $Pattern }
+$rxOpts = if ($CaseSensitive) {
+    [System.Text.RegularExpressions.RegexOptions]::None
+} else {
+    [System.Text.RegularExpressions.RegexOptions]::IgnoreCase
+}
+try {
+    $rx = [regex]::new($rxText, $rxOpts)
+} catch {
+    [Console]::Error.WriteLine("litmatch: invalid regex: $Pattern")
+    exit 65
+}
+foreach ($l in $lines) {
+    if ($rx.IsMatch($l)) { Write-Output $l }
+}
+exit 0
