+#!/usr/bin/env python3
+"""CSV -> sqlite import and reporting.
+
+    python3 csvreport.py import orders.csv --db sales.db
+    python3 csvreport.py report by-region --db sales.db
+"""
+import argparse
+import os
+import sqlite3
+import sys
+
+import csvinfer
+import reports
+
+REPORTS = {
+    "by-region": lambda con, args: reports.by_region(con),
+    "top-products": lambda con, args: reports.top_products(con, args.limit),
+    "monthly": lambda con, args: reports.monthly(con),
+}
+
+
+def main():
+    parser = argparse.ArgumentParser(prog="csvreport.py")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_import = sub.add_parser("import")
+    p_import.add_argument("file")
+    p_import.add_argument("--db", required=True)
+
+    p_report = sub.add_parser("report")
+    p_report.add_argument("name")
+    p_report.add_argument("--db", required=True)
+    p_report.add_argument("--limit", type=int, default=3)
+
+    args = parser.parse_args()
+
+    if args.command == "import":
+        if not os.path.isfile(args.file):
+            print(f"error: no such file: {args.file}", file=sys.stderr)
+            return 1
+        con = sqlite3.connect(args.db)
+        try:
+            table, count = csvinfer.import_csv(con, args.file)
+        finally:
+            con.close()
+        print(f"imported {count} rows into {table}")
+        return 0
+
+    if args.name not in REPORTS:
+        print(f"error: unknown report: {args.name}", file=sys.stderr)
+        return 2
+    con = sqlite3.connect(args.db)
+    try:
+        lines = REPORTS[args.name](con, args)
+    except reports.ReportError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    finally:
+        con.close()
+    for line in lines:
+        print(line)
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
