+"""CSV import with per-column type inference."""
+import csv
+import os
+
+
+def _is_int(value):
+    try:
+        int(value)
+        return True
+    except ValueError:
+        return False
+
+
+def _is_number(value):
+    try:
+        float(value)
+        return True
+    except ValueError:
+        return False
+
+
+def infer_types(headers, rows):
+    """Return a sqlite type ('INTEGER'|'REAL'|'TEXT') per column.
+
+    Blank cells don't vote; a column with no non-blank values is TEXT.
+    """
+    types = []
+    for i in range(len(headers)):
+        values = [row[i] for row in rows if i < len(row) and row[i] != ""]
+        if not values:
+            types.append("TEXT")
+        elif all(_is_int(v) for v in values):
+            types.append("INTEGER")
+        elif all(_is_number(v) for v in values):
+            types.append("REAL")
+        else:
+            types.append("TEXT")
+    return types
+
+
+def convert(value, sql_type):
+    """Convert one CSV cell for storage under the column's type."""
+    if value == "":
+        return None
+    if sql_type == "INTEGER":
+        return int(value)
+    if sql_type == "REAL":
+        return float(value)
+    return value
+
+
+def read_csv(path):
+    """Return (table_name, headers, rows) for a CSV file."""
+    table = os.path.splitext(os.path.basename(path))[0].lower()
+    with open(path, newline="") as f:
+        reader = csv.reader(f)
+        headers = next(reader)
+        rows = list(reader)
+    return table, headers, rows
+
+
+def import_csv(con, path):
+    """(Re)create a table from a CSV file. Returns (table, row_count)."""
+    table, headers, rows = read_csv(path)
+    types = infer_types(headers, rows)
+    quoted = [f'"{h}"' for h in headers]
+    con.execute(f'DROP TABLE IF EXISTS "{table}"')
+    columns = ", ".join(f"{q} {t}" for q, t in zip(quoted, types))
+    con.execute(f'CREATE TABLE "{table}" ({columns})')
+    placeholders = ", ".join("?" for _ in headers)
+    for row in rows:
+        values = [convert(cell, t) for cell, t in zip(row, types)]
+        con.execute(f'INSERT INTO "{table}" VALUES ({placeholders})', values)
+    con.commit()
+    return table, len(rows)
