+"""Canned reports over the imported orders table."""
+
+
+class ReportError(Exception):
+    """A report was asked of a database that can't answer it."""
+
+
+def _require_orders(con):
+    row = con.execute(
+        "SELECT name FROM sqlite_master WHERE type='table' AND name='orders'"
+    ).fetchone()
+    if row is None:
+        raise ReportError("no orders table; run an import first")
+
+
+def by_region(con):
+    _require_orders(con)
+    rows = con.execute(
+        "SELECT region, SUM(quantity * unit_price) AS total, COUNT(*) "
+        "FROM orders GROUP BY region ORDER BY total DESC, region ASC")
+    return [f"{region}\t{total:.2f}\t{count}" for region, total, count in rows]
+
+
+def top_products(con, limit):
+    _require_orders(con)
+    rows = con.execute(
+        "SELECT product, SUM(quantity * unit_price) AS total "
+        "FROM orders GROUP BY product ORDER BY total DESC, product ASC "
+        "LIMIT ?", (limit,))
+    return [f"{product}\t{total:.2f}" for product, total in rows]
+
+
+def monthly(con):
+    _require_orders(con)
+    rows = con.execute(
+        "SELECT substr(order_date, 1, 7) AS month, "
+        "SUM(quantity * unit_price) AS total, COUNT(*) "
+        "FROM orders GROUP BY month ORDER BY month ASC")
+    return [f"{month}\t{total:.2f}\t{count}" for month, total, count in rows]
