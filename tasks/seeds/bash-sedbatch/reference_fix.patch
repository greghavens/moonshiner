diff --git a/fixup.sh b/fixup.sh
new file mode 100644
index 0000000..dac4791
--- /dev/null
+++ b/fixup.sh
@@ -0,0 +1,80 @@
+#!/usr/bin/env bash
+# fixup.sh — batch-apply one sed expression across files matching a glob,
+# with a diff-only dry-run mode and .bak backups on the real run.
+#
+# usage: fixup.sh [--dry-run] <sed-expression> <glob>
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo 'usage: fixup.sh [--dry-run] <sed-expression> <glob>' >&2
+  exit 64
+}
+
+dry=0
+if [ "${1-}" = '--dry-run' ]; then
+  dry=1
+  shift
+fi
+case ${1-} in
+  --*) usage ;;
+esac
+[ "$#" -eq 2 ] || usage
+expr=$1
+pat=$2
+
+# Validate the expression before anything is touched: sed parses its script
+# even on empty input, so an empty probe is a safe syntax check.
+if ! printf '' | sed -e "$expr" > /dev/null 2>&1; then
+  echo "fixup.sh: bad expression: $expr" >&2
+  exit 65
+fi
+
+# Expand the glob ourselves. IFS is cleared so the pattern is one word even
+# if it contains spaces; bash sorts glob results in C byte order (LC_ALL=C).
+shopt -s nullglob
+oldIFS=${IFS-}
+IFS=
+matches=( $pat )
+IFS=$oldIFS
+shopt -u nullglob
+
+files=()
+for f in "${matches[@]}"; do
+  [ -f "$f" ] || continue        # only regular files
+  case $f in
+    *.bak) continue ;;           # never edit our own backups
+  esac
+  files+=( "$f" )
+done
+
+if [ "${#files[@]}" -eq 0 ]; then
+  echo "fixup.sh: no files match: $pat" >&2
+  exit 66
+fi
+
+total=${#files[@]}
+changed=0
+
+for f in "${files[@]}"; do
+  if sed -e "$expr" "$f" | cmp -s "$f" -; then
+    continue                     # applying the expression changes nothing
+  fi
+  changed=$((changed + 1))
+  if [ "$dry" -eq 1 ]; then
+    sed -e "$expr" "$f" | diff -u -L "$f" -L "$f (fixed)" "$f" -
+  else
+    cp "$f" "$f.bak"
+    sed -e "$expr" "$f.bak" > "$f"
+    echo "fixed: $f"
+  fi
+done
+
+if [ "$dry" -eq 1 ]; then
+  printf 'would change %d of %d file(s)\n' "$changed" "$total"
+  [ "$changed" -eq 0 ] && exit 0
+  exit 1
+fi
+printf 'changed %d of %d file(s)\n' "$changed" "$total"
+exit 0
