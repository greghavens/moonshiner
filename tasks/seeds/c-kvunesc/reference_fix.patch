diff --git a/kvunesc.c b/kvunesc.c
new file mode 100644
index 0000000..768d0fe
--- /dev/null
+++ b/kvunesc.c
@@ -0,0 +1,106 @@
+#include "kvunesc.h"
+
+static int hex_digit(char c)
+{
+    if (c >= '0' && c <= '9')
+        return c - '0';
+    if (c >= 'a' && c <= 'f')
+        return c - 'a' + 10;
+    if (c >= 'A' && c <= 'F')
+        return c - 'A' + 10;
+    return -1;
+}
+
+static kv_result fail(kv_status status, size_t line, size_t col,
+                      char *out, size_t outsz)
+{
+    kv_result r = {status, 0, 0, line, col};
+    if (outsz > 0)
+        out[0] = '\0';
+    return r;
+}
+
+kv_result kv_decode_value(const char *src, size_t start_line, size_t start_col,
+                          char *out, size_t outsz)
+{
+    size_t i = 0;
+    size_t line = start_line;
+    size_t col = start_col;
+    size_t n = 0;
+
+    while (src[i] != '\0' && src[i] != '\n') {
+        char c = src[i];
+        char decoded;
+
+        if (c != '\\') {
+            decoded = c;
+            i++;
+            col++;
+        } else {
+            size_t esc_line = line;
+            size_t esc_col = col;
+            char next = src[i + 1];
+
+            if (next == '\0') {
+                return fail(KV_ERR_TRAILING_BACKSLASH, esc_line, esc_col,
+                            out, outsz);
+            }
+            if (next == '\n') {
+                /* Line continuation: drop backslash, newline, and the
+                 * indent of the continued line. */
+                i += 2;
+                line++;
+                col = 1;
+                while (src[i] == ' ' || src[i] == '\t') {
+                    i++;
+                    col++;
+                }
+                continue;
+            }
+            if (next == 'n') {
+                decoded = '\n';
+            } else if (next == 't') {
+                decoded = '\t';
+            } else if (next == '\\') {
+                decoded = '\\';
+            } else if (next == 'x') {
+                char d1 = src[i + 2];
+                if (d1 == '\0' || d1 == '\n')
+                    return fail(KV_ERR_TRUNCATED_HEX, esc_line, esc_col,
+                                out, outsz);
+                int h1 = hex_digit(d1);
+                if (h1 < 0)
+                    return fail(KV_ERR_BAD_HEX, esc_line, esc_col, out, outsz);
+                char d2 = src[i + 3];
+                if (d2 == '\0' || d2 == '\n')
+                    return fail(KV_ERR_TRUNCATED_HEX, esc_line, esc_col,
+                                out, outsz);
+                int h2 = hex_digit(d2);
+                if (h2 < 0)
+                    return fail(KV_ERR_BAD_HEX, esc_line, esc_col, out, outsz);
+                decoded = (char)((h1 << 4) | h2);
+                i += 4;
+                col += 4;
+                if (n + 1 >= outsz || outsz == 0)
+                    return fail(KV_ERR_NOSPACE, 0, 0, out, outsz);
+                out[n++] = decoded;
+                continue;
+            } else {
+                return fail(KV_ERR_UNKNOWN_ESCAPE, esc_line, esc_col,
+                            out, outsz);
+            }
+            i += 2;
+            col += 2;
+        }
+
+        if (n + 1 >= outsz || outsz == 0)
+            return fail(KV_ERR_NOSPACE, 0, 0, out, outsz);
+        out[n++] = decoded;
+    }
+
+    if (outsz == 0)
+        return fail(KV_ERR_NOSPACE, 0, 0, out, outsz);
+    out[n] = '\0';
+    kv_result r = {KV_OK, i, n, 0, 0};
+    return r;
+}
diff --git a/kvunesc.h b/kvunesc.h
new file mode 100644
index 0000000..efe6702
--- /dev/null
+++ b/kvunesc.h
@@ -0,0 +1,30 @@
+#ifndef KVUNESC_H
+#define KVUNESC_H
+
+#include <stddef.h>
+
+typedef enum {
+    KV_OK = 0,
+    KV_ERR_TRAILING_BACKSLASH,
+    KV_ERR_UNKNOWN_ESCAPE,
+    KV_ERR_BAD_HEX,
+    KV_ERR_TRUNCATED_HEX,
+    KV_ERR_NOSPACE
+} kv_status;
+
+typedef struct {
+    kv_status status;
+    size_t consumed;   /* bytes of src examined: offset of the terminator */
+    size_t out_len;    /* decoded bytes written, may include NULs */
+    size_t err_line;   /* on error: 1-based physical line of the bad backslash */
+    size_t err_col;    /* on error: 1-based byte column of that backslash */
+} kv_result;
+
+/* Decode one config value starting at src (the byte after '='), whose
+ * first byte sits at (start_line, start_col) in the file. Scans until an
+ * unescaped '\n' or the terminating NUL. out receives the decoded bytes
+ * plus a NUL terminator. */
+kv_result kv_decode_value(const char *src, size_t start_line, size_t start_col,
+                          char *out, size_t outsz);
+
+#endif /* KVUNESC_H */
