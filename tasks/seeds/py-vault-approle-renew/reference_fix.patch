+"""AppRole-backed Vault session manager: login, threshold renewal, retry of
+standby/overload statuses, and revoke-on-shutdown — with no token material in
+logs, exceptions, or repr."""
+
+from .errors import VaultServerError
+from .session import AppRoleSession
+
+__all__ = ["AppRoleSession", "VaultServerError"]
