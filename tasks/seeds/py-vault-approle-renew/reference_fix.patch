+++ b/vaultsession/transport.py
@@ -0,0 +1,52 @@
+import json
+import urllib.error
+import urllib.request
+
+from .errors import VaultServerError
+
+# Documented transient statuses: 429 standby health, 472 DR secondary,
+# 473 performance standby, 503 sealed/maintenance/overloaded.
+RETRYABLE_STATUSES = frozenset({429, 472, 473, 503})
+
+
+class Transport:
+    """POSTs JSON to Vault, retrying standby/overload statuses on an
+    injected sleep schedule and raising VaultServerError otherwise."""
+
+    def __init__(self, base_url, *, namespace, sleep, retry_delays):
+        self._base = base_url.rstrip("/")
+        self._namespace = namespace
+        self._sleep = sleep
+        self._delays = tuple(retry_delays)
+
+    def post(self, path, body=None, token=None):
+        attempts = len(self._delays) + 1
+        for attempt in range(attempts):
+            status, payload = self._send(path, body, token)
+            if 200 <= status < 300:
+                return payload
+            if status in RETRYABLE_STATUSES and attempt < attempts - 1:
+                self._sleep(self._delays[attempt])
+                continue
+            errors = payload.get("errors", []) if isinstance(payload, dict) else []
+            raise VaultServerError(status, errors)
+
+    def _send(self, path, body, token):
+        data = json.dumps(body).encode() if body is not None else b""
+        request = urllib.request.Request(self._base + path, data=data, method="POST")
+        request.add_header("Content-Type", "application/json")
+        if token is not None:
+            request.add_header("X-Vault-Token", token)
+        if self._namespace:
+            request.add_header("X-Vault-Namespace", self._namespace)
+        try:
+            with urllib.request.urlopen(request) as response:
+                raw = response.read()
+                return response.status, (json.loads(raw) if raw else {})
+        except urllib.error.HTTPError as exc:
+            raw = exc.read()
+            try:
+                payload = json.loads(raw) if raw else {}
+            except ValueError:
+                payload = {}
+            return exc.code, payload
