new file mode 100644
index 0000000..cc5e1ff
--- /dev/null
+++ b/vaultsession/errors.py
@@ -0,0 +1,12 @@
+class VaultServerError(Exception):
+    """A non-2xx Vault response, carrying the decoded errors array.
+
+    The message intentionally names only the HTTP status and Vault's error
+    strings — never token material.
+    """
+
+    def __init__(self, status, errors):
+        self.status = int(status)
+        self.errors = list(errors)
+        detail = "; ".join(self.errors) or "(no error detail)"
+        super().__init__("vault: HTTP %d: %s" % (self.status, detail))
