@@ -0,0 +1,35 @@
+import java.util.ArrayList;
+import java.util.List;
+
+/** Flat snapshot of organization partners with their addresses. */
+public final class BusinessPartnerReport {
+
+    private BusinessPartnerReport() {}
+
+    /**
+     * One paged read of organization partners (category '2') with addresses
+     * expanded; address lists the server left deferred are fetched on demand.
+     * Lines: partnerId|name|City/Country;City/Country sorted by partner id.
+     */
+    public static List<String> wholesaleSnapshot(SapODataClient client) {
+        FetchResult result = client.fetchAll(ODataQuery.entitySet("A_BusinessPartner")
+                .select("BusinessPartner", "BusinessPartnerFullName")
+                .filterEq("BusinessPartnerCategory", "2")
+                .expand("to_BusinessPartnerAddress"));
+        List<String> lines = new ArrayList<>();
+        for (ODataEntity partner : result.entities()) {
+            List<ODataEntity> addresses = partner.hasDeferred("to_BusinessPartnerAddress")
+                    ? client.fetchDeferredCollection(partner.deferredUri("to_BusinessPartnerAddress"))
+                    : partner.inline("to_BusinessPartnerAddress");
+            List<String> places = new ArrayList<>();
+            for (ODataEntity address : addresses) {
+                places.add(address.str("CityName") + "/" + address.str("Country"));
+            }
+            lines.add(partner.str("BusinessPartner") + "|"
+                    + partner.str("BusinessPartnerFullName") + "|"
+                    + String.join(";", places));
+        }
+        lines.sort(null);
+        return lines;
+    }
+}
diff --git a/FetchResult.java b/FetchResult.java
