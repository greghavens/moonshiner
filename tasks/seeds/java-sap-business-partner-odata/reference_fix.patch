+++ b/FetchResult.java
@@ -0,0 +1,17 @@
+import java.util.List;
+
+/** All entities of a paged OData V2 read, plus the optional inline count. */
+public final class FetchResult {
+    private final List<ODataEntity> entities;
+    private final Long inlineCount;
+
+    FetchResult(List<ODataEntity> entities, Long inlineCount) {
+        this.entities = List.copyOf(entities);
+        this.inlineCount = inlineCount;
+    }
+
+    public List<ODataEntity> entities() { return entities; }
+
+    /** The __count of the full set, or null when $inlinecount was not requested. */
+    public Long inlineCount() { return inlineCount; }
+}
diff --git a/JsonValue.java b/JsonValue.java
new file mode 100644
index 0000000..3408f3b
--- /dev/null
+++ b/JsonValue.java
@@ -0,0 +1,99 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** Tiny recursive-descent JSON reader for the OData V2 d-envelope payloads. */
+final class JsonValue {
+    private final String s;
+    private int i;
+
+    private JsonValue(String s) { this.s = s; }
+
+    static Object parse(String text) {
+        JsonValue p = new JsonValue(text);
+        Object v = p.value();
+        p.ws();
+        if (p.i != p.s.length()) throw new IllegalArgumentException("trailing JSON at offset " + p.i);
+        return v;
+    }
+
+    private void ws() { while (i < s.length() && Character.isWhitespace(s.charAt(i))) i++; }
+
+    private Object value() {
+        ws();
+        char c = s.charAt(i);
+        if (c == '{') return object();
+        if (c == '[') return array();
+        if (c == '"') return string();
+        if (s.startsWith("true", i)) { i += 4; return Boolean.TRUE; }
+        if (s.startsWith("false", i)) { i += 5; return Boolean.FALSE; }
+        if (s.startsWith("null", i)) { i += 4; return null; }
+        int j = i;
+        while (j < s.length() && "-+.eE0123456789".indexOf(s.charAt(j)) >= 0) j++;
+        double d = Double.parseDouble(s.substring(i, j));
+        i = j;
+        return d;
+    }
+
+    private Map<String, Object> object() {
+        Map<String, Object> m = new LinkedHashMap<>();
+        i++; ws();
+        if (s.charAt(i) == '}') { i++; return m; }
+        while (true) {
+            ws();
+            String k = string();
+            ws();
+            if (s.charAt(i) != ':') throw new IllegalArgumentException("expected ':' at " + i);
+            i++;
+            m.put(k, value());
+            ws();
+            char c = s.charAt(i++);
+            if (c == '}') return m;
+            if (c != ',') throw new IllegalArgumentException("expected ',' or '}' at " + (i - 1));
+        }
+    }
+
+    private List<Object> array() {
+        List<Object> a = new ArrayList<>();
+        i++; ws();
+        if (s.charAt(i) == ']') { i++; return a; }
+        while (true) {
+            a.add(value());
+            ws();
+            char c = s.charAt(i++);
+            if (c == ']') return a;
+            if (c != ',') throw new IllegalArgumentException("expected ',' or ']' at " + (i - 1));
+        }
+    }
+
+    private String string() {
+        if (s.charAt(i) != '"') throw new IllegalArgumentException("expected string at " + i);
+        StringBuilder b = new StringBuilder();
+        i++;
+        while (true) {
+            char c = s.charAt(i++);
+            if (c == '"') return b.toString();
+            if (c == '\\') {
+                char e = s.charAt(i++);
+                switch (e) {
+                    case '"' -> b.append('"');
+                    case '\\' -> b.append('\\');
+                    case '/' -> b.append('/');
+                    case 'n' -> b.append('\n');
+                    case 't' -> b.append('\t');
+                    case 'r' -> b.append('\r');
+                    case 'b' -> b.append('\b');
+                    case 'f' -> b.append('\f');
+                    case 'u' -> {
+                        b.append((char) Integer.parseInt(s.substring(i, i + 4), 16));
+                        i += 4;
+                    }
+                    default -> throw new IllegalArgumentException("bad escape \\" + e);
+                }
+            } else {
+                b.append(c);
+            }
+        }
+    }
+}
diff --git a/ODataEntity.java b/ODataEntity.java
new file mode 100644
index 0000000..327f296
--- /dev/null
+++ b/ODataEntity.java
@@ -0,0 +1,56 @@
+import java.time.Instant;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+import java.util.regex.Matcher;
+import java.util.regex.Pattern;
+
+/** One entry from an OData V2 feed, with typed access to its properties. */
+public final class ODataEntity {
+    private static final Pattern WIRE_DATE = Pattern.compile("^/Date\\((-?\\d+)\\)/$");
+
+    private final Map<String, Object> props;
+
+    ODataEntity(Map<String, Object> props) { this.props = props; }
+
+    public String str(String name) {
+        Object v = props.get(name);
+        return v == null ? null : String.valueOf(v);
+    }
+
+    /** Decodes the OData V2 wire form /Date(ms)/ into a UTC instant. */
+    public Instant instant(String name) {
+        Object v = props.get(name);
+        if (v == null) return null;
+        Matcher m = WIRE_DATE.matcher(String.valueOf(v));
+        if (!m.matches()) throw new IllegalArgumentException("not an Edm.DateTime wire value: " + v);
+        return Instant.ofEpochMilli(Long.parseLong(m.group(1)));
+    }
+
+    public boolean hasDeferred(String nav) {
+        return props.get(nav) instanceof Map<?, ?> m && m.containsKey("__deferred");
+    }
+
+    public String deferredUri(String nav) {
+        Object v = props.get(nav);
+        if (v instanceof Map<?, ?> m && m.get("__deferred") instanceof Map<?, ?> d) {
+            return String.valueOf(d.get("uri"));
+        }
+        throw new IllegalStateException("navigation property " + nav + " is not deferred");
+    }
+
+    /** An expanded collection navigation property, unwrapped from its results wrapper. */
+    public List<ODataEntity> inline(String nav) {
+        Object v = props.get(nav);
+        if (v instanceof Map<?, ?> m && m.get("results") instanceof List<?> rows) {
+            List<ODataEntity> out = new ArrayList<>(rows.size());
+            for (Object row : rows) {
+                @SuppressWarnings("unchecked")
+                Map<String, Object> asMap = (Map<String, Object>) row;
+                out.add(new ODataEntity(asMap));
+            }
+            return out;
+        }
+        throw new IllegalStateException("navigation property " + nav + " is not expanded inline");
+    }
+}
diff --git a/ODataQuery.java b/ODataQuery.java
new file mode 100644
index 0000000..7388b40
--- /dev/null
+++ b/ODataQuery.java
@@ -0,0 +1,70 @@
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Builds the encoded path+query for one OData V2 entity-set read.
+ * Option order: $format, $select, $filter, $expand, $top, $skip, $inlinecount.
+ */
+public final class ODataQuery {
+    private final String entitySet;
+    private final List<String> selects = new ArrayList<>();
+    private final List<String> filters = new ArrayList<>();
+    private final List<String> expands = new ArrayList<>();
+    private Integer top;
+    private Integer skip;
+    private boolean inlinecount;
+
+    private ODataQuery(String entitySet) { this.entitySet = entitySet; }
+
+    public static ODataQuery entitySet(String name) { return new ODataQuery(name); }
+
+    public ODataQuery select(String... props) {
+        selects.addAll(List.of(props));
+        return this;
+    }
+
+    /**
+     * Adds a `Prop eq 'value'` predicate; predicates join with ` and `.
+     * A single quote inside an OData V2 string literal is escaped by doubling.
+     */
+    public ODataQuery filterEq(String property, String value) {
+        filters.add(property + " eq '" + value.replace("'", "''") + "'");
+        return this;
+    }
+
+    public ODataQuery expand(String... navigationPaths) {
+        expands.addAll(List.of(navigationPaths));
+        return this;
+    }
+
+    public ODataQuery top(int n) { this.top = n; return this; }
+
+    public ODataQuery skip(int n) { this.skip = n; return this; }
+
+    public ODataQuery inlinecountAllPages() { this.inlinecount = true; return this; }
+
+    public String toPath() {
+        StringBuilder b = new StringBuilder("/").append(entitySet).append("?$format=json");
+        if (!selects.isEmpty()) b.append("&$select=").append(String.join(",", selects));
+        if (!filters.isEmpty()) b.append("&$filter=").append(encode(String.join(" and ", filters)));
+        if (!expands.isEmpty()) b.append("&$expand=").append(String.join(",", expands));
+        if (top != null) b.append("&$top=").append(top);
+        if (skip != null) b.append("&$skip=").append(skip);
+        if (inlinecount) b.append("&$inlinecount=allpages");
+        return b.toString();
+    }
+
+    /** Percent-encodes a query value, keeping OData expression punctuation. */
+    private static String encode(String raw) {
+        StringBuilder out = new StringBuilder();
+        for (byte by : raw.getBytes(StandardCharsets.UTF_8)) {
+            char c = (char) (by & 0xff);
+            boolean keep = (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9')
+                    || "-._~'(),/=:$".indexOf(c) >= 0;
+            if (keep) out.append(c);
+            else out.append('%').append(String.format("%02X", by & 0xff));
+        }
+        return out.toString();
+    }
+}
diff --git a/SapODataClient.java b/SapODataClient.java
new file mode 100644
index 0000000..a33ac24
--- /dev/null
+++ b/SapODataClient.java
@@ -0,0 +1,113 @@
+import java.io.IOException;
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.Base64;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Client for the Business Partner (A2X) OData V2 service. Requests JSON,
+ * authenticates every hop, follows __next partial-set links verbatim, and
+ * preserves SAP error documents completely.
+ */
+public final class SapODataClient {
+    private final String serviceRoot;
+    private final String authHeader;
+    private final HttpClient http = HttpClient.newHttpClient();
+
+    public SapODataClient(String serviceRootUrl, String user, String password) {
+        this.serviceRoot = serviceRootUrl.endsWith("/")
+                ? serviceRootUrl.substring(0, serviceRootUrl.length() - 1)
+                : serviceRootUrl;
+        this.authHeader = "Basic " + Base64.getEncoder()
+                .encodeToString((user + ":" + password).getBytes(StandardCharsets.UTF_8));
+    }
+
+    public FetchResult fetchAll(ODataQuery query) {
+        List<ODataEntity> entities = new ArrayList<>();
+        Long inlineCount = null;
+        String url = serviceRoot + query.toPath();
+        boolean first = true;
+        while (url != null) {
+            Map<String, Object> d = envelope(getJson(url));
+            for (ODataEntity e : rows(d)) entities.add(e);
+            if (first && d.get("__count") instanceof String c) inlineCount = Long.parseLong(c);
+            first = false;
+            // The __next URI identifies the next partial set; use it as returned.
+            url = d.get("__next") instanceof String next ? next : null;
+        }
+        return new FetchResult(entities, inlineCount);
+    }
+
+    /** Fetches a collection navigation property that arrived deferred. */
+    public List<ODataEntity> fetchDeferredCollection(String uri) {
+        return rows(envelope(getJson(uri)));
+    }
+
+    // ------------------------------------------------------------------ http
+
+    private Map<String, Object> getJson(String url) {
+        HttpRequest request = HttpRequest.newBuilder(URI.create(url))
+                .header("Authorization", authHeader)
+                .header("Accept", "application/json")
+                .GET()
+                .build();
+        HttpResponse<String> response;
+        try {
+            response = http.send(request, HttpResponse.BodyHandlers.ofString());
+        } catch (IOException e) {
+            throw new SapODataException(0, "TRANSPORT", e.getClass().getSimpleName(), Map.of());
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new SapODataException(0, "INTERRUPTED", "request interrupted", Map.of());
+        }
+        Object parsed = response.body() == null || response.body().isEmpty()
+                ? Map.of() : JsonValue.parse(response.body());
+        if (response.statusCode() >= 400) {
+            throw toError(response.statusCode(), parsed);
+        }
+        @SuppressWarnings("unchecked")
+        Map<String, Object> asMap = (Map<String, Object>) parsed;
+        return asMap;
+    }
+
+    private static SapODataException toError(int status, Object parsed) {
+        if (parsed instanceof Map<?, ?> outer && outer.get("error") instanceof Map<?, ?> err) {
+            @SuppressWarnings("unchecked")
+            Map<String, Object> body = (Map<String, Object>) err;
+            String code = body.get("code") instanceof String c ? c : "UNKNOWN";
+            String value = "";
+            if (body.get("message") instanceof Map<?, ?> msg && msg.get("value") instanceof String v) {
+                value = v;
+            }
+            return new SapODataException(status, code, value, body);
+        }
+        return new SapODataException(status, "HTTP_" + status, "no OData error document", Map.of());
+    }
+
+    private static Map<String, Object> envelope(Map<String, Object> doc) {
+        Object d = doc.get("d");
+        if (d instanceof Map<?, ?> m) {
+            @SuppressWarnings("unchecked")
+            Map<String, Object> asMap = (Map<String, Object>) m;
+            return asMap;
+        }
+        throw new SapODataException(0, "MALFORMED", "response has no d envelope", Map.of());
+    }
+
+    private static List<ODataEntity> rows(Map<String, Object> d) {
+        List<ODataEntity> out = new ArrayList<>();
+        if (d.get("results") instanceof List<?> rows) {
+            for (Object row : rows) {
+                @SuppressWarnings("unchecked")
+                Map<String, Object> asMap = (Map<String, Object>) row;
+                out.add(new ODataEntity(asMap));
+            }
+        }
+        return out;
+    }
+}
diff --git a/SapODataException.java b/SapODataException.java
new file mode 100644
index 0000000..c3d1e3b
--- /dev/null
+++ b/SapODataException.java
@@ -0,0 +1,35 @@
+import java.util.Map;
+
+/**
+ * A non-2xx gateway response. The complete OData error document is kept
+ * navigable so SAP's innererror diagnostics survive into support tickets.
+ * Exception text never contains credentials.
+ */
+public class SapODataException extends RuntimeException {
+    private final int httpStatus;
+    private final String code;
+    private final Map<String, Object> errorBody;
+
+    public SapODataException(int httpStatus, String code, String messageValue, Map<String, Object> errorBody) {
+        super("SAP OData error " + code + " (HTTP " + httpStatus + "): " + messageValue);
+        this.httpStatus = httpStatus;
+        this.code = code;
+        this.errorBody = errorBody;
+    }
+
+    public int httpStatus() { return httpStatus; }
+
+    public String code() { return code; }
+
+    /** Walks the preserved error document, e.g. errorDetail("innererror", "transactionid"). */
+    public Object errorDetail(String... keys) {
+        Object cur = errorBody;
+        for (String key : keys) {
+            if (cur instanceof Map<?, ?> m) cur = m.get(key);
+            else return null;
+        }
+        return cur;
+    }
+
+    public Map<String, Object> errorBody() { return errorBody; }
+}
