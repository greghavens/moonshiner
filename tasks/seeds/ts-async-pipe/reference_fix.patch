@@ -0,0 +1,46 @@
+type Step = (value: never) => unknown;
+type AnyFn = (...args: never[]) => unknown;
+
+function isThenable(value: unknown): value is Promise<unknown> {
+  return (
+    value !== null &&
+    (typeof value === 'object' || typeof value === 'function') &&
+    typeof (value as { then?: unknown }).then === 'function'
+  );
+}
+
+function assertFunctions(fns: unknown[], name: string): void {
+  for (const fn of fns) {
+    if (typeof fn !== 'function') {
+      throw new TypeError(`${name} expects functions, got ${typeof fn}`);
+    }
+  }
+}
+
+export function pipe(...fns: AnyFn[]): (...args: unknown[]) => unknown {
+  assertFunctions(fns, 'pipe');
+  return (...args: unknown[]): unknown => {
+    if (fns.length === 0) return args[0];
+    let acc: unknown = (fns[0] as (...a: unknown[]) => unknown)(...args);
+    for (let i = 1; i < fns.length; i++) {
+      const step = fns[i] as (v: unknown) => unknown;
+      acc = isThenable(acc) ? acc.then(step) : step(acc);
+    }
+    return acc;
+  };
+}
+
+export function compose(...fns: AnyFn[]): (...args: unknown[]) => unknown {
+  assertFunctions(fns, 'compose');
+  return pipe(...[...fns].reverse());
+}
+
+export function tap<T>(fn: (value: T) => unknown): (value: T) => T | Promise<T> {
+  if (typeof fn !== 'function') {
+    throw new TypeError(`tap expects a function, got ${typeof fn}`);
+  }
+  return (value: T): T | Promise<T> => {
+    const result = fn(value);
+    return isThenable(result) ? result.then(() => value) : value;
+  };
+}
