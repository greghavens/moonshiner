diff --git a/flowlint.py b/flowlint.py
new file mode 100644
index 0000000..a948f70
--- /dev/null
+++ b/flowlint.py
@@ -0,0 +1,270 @@
+"""flowlint — structural linter for workflow DSL documents.
+
+lint(text) loads a (well-formed) YAML workflow document and returns a
+sorted list of "path: message" findings; [] means the document is clean.
+"""
+import yaml
+
+TYPE_KEYS = ("call", "run", "set", "switch", "for", "raise", "emit", "wait")
+COMMON_KEYS = {"if", "input", "output", "timeout", "then", "metadata", "with"}
+TOP_KEYS = {"document", "do", "input", "output", "timeout"}
+DOC_KEYS = {"dsl", "namespace", "name", "version", "description"}
+RUN_KEYS = ("script", "shell", "workflow")
+ERROR_KEYS = {"status", "type", "title", "detail"}
+EMIT_KEYS = {"type", "source", "data"}
+FOR_KEYS = {"each", "in", "at", "do"}
+
+
+def _nonempty_str(value):
+    return isinstance(value, str) and value != ""
+
+
+def lint(text):
+    data = yaml.safe_load(text)
+    if not isinstance(data, dict):
+        return ["workflow must be a mapping"]
+    errors = []
+    add = errors.append
+    for key in data:
+        if key not in TOP_KEYS:
+            add(f"{key}: unknown top-level section")
+    if "document" not in data:
+        add("document: required section is missing")
+    else:
+        _check_document(data["document"], add)
+    if "do" not in data:
+        add("do: required section is missing")
+    else:
+        _check_do(data["do"], "do", add)
+    for key in ("input", "output"):
+        if key in data:
+            _check_io(data[key], key, add)
+    if "timeout" in data:
+        _check_timeout(data["timeout"], "timeout", add)
+    return sorted(errors)
+
+
+def _check_document(doc, add):
+    if not isinstance(doc, dict):
+        add("document: must be a mapping")
+        return
+    if "dsl" not in doc:
+        add("document.dsl: required field is missing")
+    elif not (isinstance(doc["dsl"], str) and doc["dsl"] == "1.0"):
+        add('document.dsl: must be the string "1.0"')
+    for key in ("namespace", "name"):
+        if key not in doc:
+            add(f"document.{key}: required field is missing")
+        elif not _nonempty_str(doc[key]):
+            add(f"document.{key}: must be a non-empty string")
+    for key in ("version", "description"):
+        if key in doc and not _nonempty_str(doc[key]):
+            add(f"document.{key}: must be a non-empty string")
+    for key in doc:
+        if key not in DOC_KEYS:
+            add(f"document.{key}: unknown field")
+
+
+def _check_io(value, path, add):
+    if not (isinstance(value, dict) and set(value) == {"from"}):
+        add(f'{path}: must be a mapping with only a "from" key')
+
+
+def _check_timeout(value, path, add):
+    if not (isinstance(value, dict) and set(value) == {"after"}):
+        add(f'{path}: must be a mapping with only an "after" key')
+        return
+    if not _nonempty_str(value["after"]):
+        add(f"{path}.after: must be a non-empty string")
+
+
+def _check_do(block, prefix, add):
+    if not isinstance(block, list):
+        add(f"{prefix}: must be a list")
+        return
+    if not block:
+        add(f"{prefix}: must not be empty")
+        return
+    targets = {"continue", "end"}
+    for entry in block:
+        if isinstance(entry, dict) and len(entry) == 1:
+            name = next(iter(entry))
+            if _nonempty_str(name):
+                targets.add(name)
+    seen = set()
+    for i, entry in enumerate(block):
+        if not (isinstance(entry, dict) and len(entry) == 1):
+            add(f"{prefix}[{i}]: task entry must be a mapping with exactly one key")
+            continue
+        name = next(iter(entry))
+        if not _nonempty_str(name):
+            add(f"{prefix}[{i}]: task name must be a non-empty string")
+            continue
+        path = f"{prefix}[{i}].{name}"
+        if name in seen:
+            add(f"{path}: duplicate task name")
+        seen.add(name)
+        _check_task(entry[name], path, targets, add)
+
+
+def _check_task(body, path, targets, add):
+    if not isinstance(body, dict):
+        add(f"{path}: task must be a mapping")
+        return
+    found = sorted(k for k in body if k in TYPE_KEYS)
+    if len(found) == 0:
+        add(f"{path}: task must declare exactly one task type (found none)")
+    elif len(found) > 1:
+        joined = ", ".join(found)
+        add(f"{path}: task must declare exactly one task type (found {joined})")
+    for key in body:
+        if key not in TYPE_KEYS and key not in COMMON_KEYS:
+            add(f"{path}.{key}: unknown task field")
+    if "with" in body:
+        if found == ["call"]:
+            if not isinstance(body["with"], dict):
+                add(f"{path}.with: must be a mapping")
+        elif len(found) == 1:
+            add(f"{path}.with: only valid on call tasks")
+    if "if" in body and not _nonempty_str(body["if"]):
+        add(f"{path}.if: must be a non-empty string")
+    if "then" in body:
+        _check_then(body["then"], f"{path}.then", targets, add)
+    for key in ("input", "output"):
+        if key in body:
+            _check_io(body[key], f"{path}.{key}", add)
+    if "timeout" in body:
+        _check_timeout(body["timeout"], f"{path}.timeout", add)
+    if "metadata" in body and not isinstance(body["metadata"], dict):
+        add(f"{path}.metadata: must be a mapping")
+    if len(found) != 1:
+        return
+    kind = found[0]
+    value = body[kind]
+    q = f"{path}.{kind}"
+    if kind in ("call", "wait"):
+        if not _nonempty_str(value):
+            add(f"{q}: must be a non-empty string")
+    elif kind == "set":
+        if not (isinstance(value, dict) and value):
+            add(f"{q}: must be a non-empty mapping")
+    elif kind == "run":
+        _check_run(value, q, add)
+    elif kind == "raise":
+        _check_raise(value, q, add)
+    elif kind == "emit":
+        _check_emit(value, q, add)
+    elif kind == "switch":
+        _check_switch(value, q, targets, add)
+    elif kind == "for":
+        _check_for(value, q, add)
+
+
+def _check_then(value, path, targets, add):
+    if not isinstance(value, str):
+        add(f"{path}: must be a string")
+    elif value not in targets:
+        add(f'{path}: unknown jump target "{value}"')
+
+
+def _check_run(value, q, add):
+    if not isinstance(value, dict):
+        add(f"{q}: must be a mapping")
+        return
+    found = sorted(k for k in value if k in RUN_KEYS)
+    if len(found) == 0:
+        add(f"{q}: must declare exactly one of shell, script, workflow (found none)")
+    elif len(found) > 1:
+        joined = ", ".join(found)
+        add(f"{q}: must declare exactly one of shell, script, workflow (found {joined})")
+    for key in value:
+        if key not in RUN_KEYS:
+            add(f"{q}.{key}: unknown field")
+    for key in found:
+        if not isinstance(value[key], dict):
+            add(f"{q}.{key}: must be a mapping")
+
+
+def _check_raise(value, q, add):
+    if not (isinstance(value, dict) and set(value) == {"error"}):
+        add(f'{q}: must be a mapping with only an "error" key')
+        return
+    err = value["error"]
+    if not isinstance(err, dict):
+        add(f"{q}.error: must be a mapping")
+        return
+    if "status" not in err:
+        add(f"{q}.error.status: required field is missing")
+    elif not isinstance(err["status"], int) or isinstance(err["status"], bool):
+        add(f"{q}.error.status: must be an integer")
+    for key in ("type", "title"):
+        if key not in err:
+            add(f"{q}.error.{key}: required field is missing")
+        elif not _nonempty_str(err[key]):
+            add(f"{q}.error.{key}: must be a non-empty string")
+    if "detail" in err and not _nonempty_str(err["detail"]):
+        add(f"{q}.error.detail: must be a non-empty string")
+    for key in err:
+        if key not in ERROR_KEYS:
+            add(f"{q}.error.{key}: unknown field")
+
+
+def _check_emit(value, q, add):
+    if not isinstance(value, dict):
+        add(f"{q}: must be a mapping")
+        return
+    if "type" not in value:
+        add(f"{q}.type: required field is missing")
+    elif not _nonempty_str(value["type"]):
+        add(f"{q}.type: must be a non-empty string")
+    if "source" in value and not _nonempty_str(value["source"]):
+        add(f"{q}.source: must be a non-empty string")
+    for key in value:
+        if key not in EMIT_KEYS:
+            add(f"{q}.{key}: unknown field")
+
+
+def _check_switch(value, q, targets, add):
+    if not (isinstance(value, list) and value):
+        add(f"{q}: must be a non-empty list")
+        return
+    defaults = 0
+    for j, case in enumerate(value):
+        cq = f"{q}[{j}]"
+        if not isinstance(case, dict):
+            add(f"{cq}: case must be a mapping")
+            continue
+        for key in case:
+            if key not in ("when", "then"):
+                add(f"{cq}.{key}: unknown case field")
+        if "then" not in case:
+            add(f"{cq}.then: required field is missing")
+        else:
+            _check_then(case["then"], f"{cq}.then", targets, add)
+        if "when" in case:
+            if not _nonempty_str(case["when"]):
+                add(f"{cq}.when: must be a non-empty expression")
+        else:
+            defaults += 1
+            if defaults > 1:
+                add(f"{cq}: duplicate default case")
+
+
+def _check_for(value, q, add):
+    if not isinstance(value, dict):
+        add(f"{q}: must be a mapping")
+        return
+    for key in ("each", "in"):
+        if key not in value:
+            add(f"{q}.{key}: required field is missing")
+        elif not _nonempty_str(value[key]):
+            add(f"{q}.{key}: must be a non-empty string")
+    if "at" in value and not _nonempty_str(value["at"]):
+        add(f"{q}.at: must be a non-empty string")
+    if "do" not in value:
+        add(f"{q}.do: required field is missing")
+    else:
+        _check_do(value["do"], f"{q}.do", add)
+    for key in value:
+        if key not in FOR_KEYS:
+            add(f"{q}.{key}: unknown field")
