+package cidrkit
+
+import (
+	"fmt"
+	"math/bits"
+	"sort"
+)
+
+// ipRange is an inclusive range of IPv4 addresses, widened to uint64
+// so end+1 arithmetic cannot overflow at 255.255.255.255.
+type ipRange struct {
+	start, end uint64
+}
+
+func (n Net) toRange() ipRange {
+	size := uint64(1) << (32 - uint(n.bits))
+	return ipRange{start: uint64(n.base), end: uint64(n.base) + size - 1}
+}
+
+// mergeRanges sorts ranges and fuses any that overlap or touch.
+func mergeRanges(rs []ipRange) []ipRange {
+	if len(rs) == 0 {
+		return nil
+	}
+	sort.Slice(rs, func(i, j int) bool { return rs[i].start < rs[j].start })
+	out := []ipRange{rs[0]}
+	for _, r := range rs[1:] {
+		last := &out[len(out)-1]
+		if r.start <= last.end+1 {
+			if r.end > last.end {
+				last.end = r.end
+			}
+			continue
+		}
+		out = append(out, r)
+	}
+	return out
+}
+
+// rangeToCIDRs covers an inclusive range with the minimal list of
+// CIDR blocks, in address order.
+func rangeToCIDRs(r ipRange) []Net {
+	var out []Net
+	for start := r.start; start <= r.end; {
+		align := uint(32)
+		if start != 0 {
+			align = uint(bits.TrailingZeros32(uint32(start)))
+		}
+		var host uint
+		for host < align && start+(uint64(1)<<(host+1))-1 <= r.end {
+			host++
+		}
+		out = append(out, Net{base: uint32(start), bits: 32 - int(host)})
+		start += uint64(1) << host
+	}
+	return out
+}
+
+// Merge collapses blocks into the minimal sorted set of CIDRs covering
+// exactly the same addresses: duplicates and contained blocks vanish,
+// adjacent aligned siblings fuse into their parent.
+func Merge(ns []Net) []Net {
+	rs := make([]ipRange, 0, len(ns))
+	for _, n := range ns {
+		rs = append(rs, n.toRange())
+	}
+	var out []Net
+	for _, r := range mergeRanges(rs) {
+		out = append(out, rangeToCIDRs(r)...)
+	}
+	return out
+}
+
+// Split cuts the block into parts equal subnets in address order.
+// parts must be a positive power of two no larger than the block size.
+func (n Net) Split(parts int) ([]Net, error) {
+	if parts < 1 || parts&(parts-1) != 0 {
+		return nil, fmt.Errorf("cidrkit: cannot split %s into %d parts: not a positive power of two", n, parts)
+	}
+	extra := bits.Len(uint(parts)) - 1
+	newBits := n.bits + extra
+	if newBits > 32 {
+		return nil, fmt.Errorf("cidrkit: cannot split %s into %d parts: block too small", n, parts)
+	}
+	step := uint64(1) << (32 - uint(newBits))
+	out := make([]Net, 0, parts)
+	for i := 0; i < parts; i++ {
+		out = append(out, Net{base: n.base + uint32(uint64(i)*step), bits: newBits})
+	}
+	return out, nil
+}
+
+// Exclude returns everything in outer not covered by any of the holes,
+// as the minimal sorted set of CIDRs. Holes may overlap each other or
+// extend beyond outer; only the intersection with outer is removed.
+func Exclude(outer Net, holes []Net) []Net {
+	bounds := outer.toRange()
+	var clipped []ipRange
+	for _, h := range holes {
+		r := h.toRange()
+		if r.end < bounds.start || r.start > bounds.end {
+			continue
+		}
+		if r.start < bounds.start {
+			r.start = bounds.start
+		}
+		if r.end > bounds.end {
+			r.end = bounds.end
+		}
+		clipped = append(clipped, r)
+	}
+	var out []Net
+	cursor := bounds.start
+	for _, h := range mergeRanges(clipped) {
+		if h.start > cursor {
+			out = append(out, rangeToCIDRs(ipRange{cursor, h.start - 1})...)
+		}
+		cursor = h.end + 1
+	}
+	if cursor <= bounds.end {
+		out = append(out, rangeToCIDRs(ipRange{cursor, bounds.end})...)
+	}
+	return out
+}
