+# Lights Out engine + chase-the-lights solver for the museum touch-table.
+module LightsOut
+  SIZE = 5
+
+  # Bottom-row pattern (left to right) -> columns to press in the top row,
+  # straight off the printed help card. 1-indexed columns.
+  BOTTOM_ROW_TABLE = {
+    "10001" => [1, 2],
+    "01010" => [1, 2, 3],
+    "11011" => [3],
+    "10110" => [1, 3],
+    "01101" => [1],
+    "11100" => [2],
+    "00111" => [2, 3],
+    "00000" => [],
+  }.freeze
+
+  module_function
+
+  def parse(text)
+    lines = text.split("\n", -1)
+    lines.pop if lines.last == ""
+    raise ArgumentError, "board must have #{SIZE} rows" unless lines.size == SIZE
+    lines.map do |line|
+      raise ArgumentError, "row must be #{SIZE} cells of 0/1" unless line.match?(/\A[01]{#{SIZE}}\z/)
+      line.chars.map(&:to_i)
+    end
+  end
+
+  def render(board)
+    board.map(&:join).join("\n")
+  end
+
+  def press(board, r, c)
+    unless r.is_a?(Integer) && c.is_a?(Integer) && r.between?(0, SIZE - 1) && c.between?(0, SIZE - 1)
+      raise ArgumentError, "press out of range: #{r},#{c}"
+    end
+    out = board.map(&:dup)
+    [[r, c], [r - 1, c], [r + 1, c], [r, c - 1], [r, c + 1]].each do |rr, cc|
+      next unless rr.between?(0, SIZE - 1) && cc.between?(0, SIZE - 1)
+      out[rr][cc] ^= 1
+    end
+    out
+  end
+
+  def lit_count(board)
+    board.sum(&:sum)
+  end
+
+  def solved?(board)
+    lit_count(board).zero?
+  end
+
+  def solve(board)
+    work = board.map(&:dup)
+    presses = chase(work)
+    top = BOTTOM_ROW_TABLE[work[SIZE - 1].join]
+    return nil if top.nil?
+    top.each do |col|
+      toggle(work, 0, col - 1)
+      presses << [0, col - 1]
+    end
+    presses.concat(chase(work))
+    presses.tally.select { |_, n| n.odd? }.keys.sort
+  end
+
+  # -- internals ------------------------------------------------------------
+
+  def chase(work)
+    presses = []
+    (1...SIZE).each do |r|
+      SIZE.times do |c|
+        next unless work[r - 1][c] == 1
+        toggle(work, r, c)
+        presses << [r, c]
+      end
+    end
+    presses
+  end
+  private_class_method :chase
+
+  def toggle(work, r, c)
+    [[r, c], [r - 1, c], [r + 1, c], [r, c - 1], [r, c + 1]].each do |rr, cc|
+      next unless rr.between?(0, SIZE - 1) && cc.between?(0, SIZE - 1)
+      work[rr][cc] ^= 1
+    end
+  end
+  private_class_method :toggle
+end
