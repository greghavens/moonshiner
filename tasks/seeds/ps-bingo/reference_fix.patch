diff --git a/bingo.ps1 b/bingo.ps1
new file mode 100644
index 0000000..3ef7fbc
--- /dev/null
+++ b/bingo.ps1
@@ -0,0 +1,164 @@
+# Bingo night referee: replays fixture cards against a call sheet.
+[CmdletBinding()]
+param(
+    [string]$Cards = '',
+    [string]$Calls = ''
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail([string]$Message) {
+    [Console]::Error.WriteLine($Message)
+    exit 2
+}
+
+if ($Cards -ceq '' -or $Calls -ceq '') {
+    Fail 'usage: bingo.ps1 -Cards <card,...> -Calls <file>'
+}
+
+function Read-AllText([string]$Path) {
+    try {
+        return [System.IO.File]::ReadAllText($Path)
+    } catch {
+        Fail "error: cannot read $Path"
+    }
+}
+
+# Column ranges, 0-based column index -> inclusive lo/hi.
+$ColLo = @(1, 16, 31, 46, 61)
+$ColHi = @(15, 30, 45, 60, 75)
+$Letters = 'BINGO'
+
+$cardList = [System.Collections.Generic.List[hashtable]]::new()
+foreach ($path in $Cards.Split(',')) {
+    $name = [System.IO.Path]::GetFileNameWithoutExtension($path)
+    $text = Read-AllText $path
+    $rows = @($text.Split("`n") | ForEach-Object { $_.TrimEnd("`r") } | Where-Object { $_.Trim().Length -gt 0 })
+    if ($rows.Count -ne 5) {
+        if ($rows.Count -gt 5) { Fail "error: ${name}: bad card line 6: $($rows[5])" }
+        Fail "error: ${name}: bad card line $($rows.Count + 1): "
+    }
+    $grid = [int[][]]::new(5)
+    $seen = [System.Collections.Generic.HashSet[int]]::new()
+    $dupe = 0
+    for ($r = 0; $r -lt 5; $r++) {
+        $grid[$r] = [int[]]::new(5)
+        $tokens = -split $rows[$r]
+        $ok = $tokens.Count -eq 5
+        if ($ok) {
+            for ($c = 0; $c -lt 5; $c++) {
+                $t = $tokens[$c]
+                $isCenter = ($r -eq 2 -and $c -eq 2)
+                if ($t -ceq '*') {
+                    if (-not $isCenter) { $ok = $false; break }
+                    $grid[$r][$c] = 0
+                    continue
+                }
+                if ($isCenter) { $ok = $false; break }
+                $val = 0
+                if (-not [int]::TryParse($t, [ref]$val) -or $val -lt $ColLo[$c] -or $val -gt $ColHi[$c]) {
+                    $ok = $false; break
+                }
+                $grid[$r][$c] = $val
+                if ($dupe -eq 0 -and -not $seen.Add($val)) { $dupe = $val }
+            }
+        }
+        if (-not $ok) {
+            Fail "error: ${name}: bad card line $($r + 1): $($rows[$r])"
+        }
+    }
+    if ($dupe -ne 0) {
+        Fail "error: ${name}: duplicate number $dupe"
+    }
+    $daubed = [bool[][]]::new(5)
+    for ($r = 0; $r -lt 5; $r++) { $daubed[$r] = [bool[]]::new(5) }
+    $daubed[2][2] = $true
+    $cardList.Add(@{ Name = $name; Grid = $grid; Daubed = $daubed })
+}
+
+$callText = Read-AllText $Calls
+$callTokens = [System.Collections.Generic.List[object[]]]::new()
+$seenCalls = [System.Collections.Generic.HashSet[string]]::new()
+$lineNo = 0
+foreach ($raw in $callText.Split("`n")) {
+    $lineNo++
+    $line = $raw.TrimEnd("`r").Trim()
+    if ($line.Length -eq 0 -or $line.StartsWith('#', [System.StringComparison]::Ordinal)) { continue }
+    $ok = $line -cmatch '^([BINGO])(\d{1,2})$'
+    if ($ok) {
+        $col = $Letters.IndexOf($line[0])
+        $num = [int]$Matches[2]
+        if ($num -lt $ColLo[$col] -or $num -gt $ColHi[$col]) { $ok = $false }
+    }
+    if (-not $ok) {
+        Fail "error: bad call line ${lineNo}: $line"
+    }
+    if (-not $seenCalls.Add($line)) {
+        Fail "error: duplicate call $line"
+    }
+    $callTokens.Add(@($line, $num))
+}
+
+# --- replay ---
+foreach ($card in $cardList) {
+    Write-Output "CARD $($card.Name) ok"
+}
+
+# Pattern list in priority order: name plus the cells it needs.
+$patterns = [System.Collections.Generic.List[object[]]]::new()
+for ($r = 0; $r -lt 5; $r++) {
+    $cells = for ($c = 0; $c -lt 5; $c++) { , @($r, $c) }
+    $patterns.Add(@("R$($r + 1)", $cells))
+}
+for ($c = 0; $c -lt 5; $c++) {
+    $cells = for ($r = 0; $r -lt 5; $r++) { , @($r, $c) }
+    $patterns.Add(@("C$($c + 1)", $cells))
+}
+$patterns.Add(@('D1', (0..4 | ForEach-Object { , @($_, $_) })))
+$patterns.Add(@('D2', (0..4 | ForEach-Object { , @($_, (4 - $_)) })))
+$patterns.Add(@('CORNERS', @(@(0, 0), @(0, 4), @(4, 0), @(4, 4))))
+
+function Get-Win([hashtable]$Card) {
+    foreach ($p in $patterns) {
+        $all = $true
+        foreach ($cell in $p[1]) {
+            if (-not $Card.Daubed[$cell[0]][$cell[1]]) { $all = $false; break }
+        }
+        if ($all) { return $p[0] }
+    }
+    return $null
+}
+
+$k = 0
+foreach ($call in $callTokens) {
+    $k++
+    $token = $call[0]
+    $num = $call[1]
+    Write-Output "CALL $k $token"
+    foreach ($card in $cardList) {
+        for ($r = 0; $r -lt 5; $r++) {
+            for ($c = 0; $c -lt 5; $c++) {
+                if ($card.Grid[$r][$c] -eq $num) {
+                    $card.Daubed[$r][$c] = $true
+                    Write-Output "DAUB $($card.Name) R$($r + 1)C$($c + 1)"
+                }
+            }
+        }
+    }
+    $won = $false
+    foreach ($card in $cardList) {
+        $pattern = Get-Win $card
+        if ($null -ne $pattern) {
+            Write-Output "BINGO $($card.Name) $pattern"
+            $won = $true
+        }
+    }
+    if ($won) {
+        Write-Output "GAME OVER after $k calls"
+        exit 0
+    }
+}
+
+Write-Output "NO BINGO after $k calls"
+exit 0
