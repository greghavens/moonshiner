--- /dev/null
+++ b/sf_errors.ts
@@ -0,0 +1,37 @@
+// Error types for the Snowflake SQL API controller. Messages are built only
+// from response bodies and statuses — never from request headers, so the
+// bearer token cannot leak.
+
+export class SqlApiError extends Error {
+  readonly status?: number;
+
+  constructor(message: string, status?: number) {
+    super(message);
+    this.name = 'SqlApiError';
+    this.status = status;
+  }
+}
+
+export interface FailureIdentity {
+  code: string;
+  sqlState: string;
+  message: string;
+  statementHandle: string;
+}
+
+export class StatementFailedError extends SqlApiError {
+  readonly code: string;
+  readonly sqlState: string;
+  readonly statementHandle: string;
+
+  constructor(identity: FailureIdentity) {
+    super(
+      `statement failed (code ${identity.code}, sqlState ${identity.sqlState}): ${identity.message}`,
+      422,
+    );
+    this.name = 'StatementFailedError';
+    this.code = identity.code;
+    this.sqlState = identity.sqlState;
+    this.statementHandle = identity.statementHandle;
+  }
+}
