diff --git a/justwrap.py b/justwrap.py
new file mode 100644
index 0000000..2a60b4e
--- /dev/null
+++ b/justwrap.py
@@ -0,0 +1,89 @@
+"""Greedy word wrap with full justification and hyphen break opportunities."""
+
+
+def _check_width(width):
+    if not isinstance(width, int) or isinstance(width, bool) or width < 1:
+        raise ValueError(f"width must be a positive integer, got {width!r}")
+
+
+def _hyphen_prefix(word, room):
+    """Longest prefix of word ending in '-' that fits in `room` and leaves a
+    non-empty remainder, or None."""
+    best = None
+    for i, ch in enumerate(word):
+        if ch == "-" and i + 1 < len(word) and i + 1 <= room:
+            best = i + 1
+    if best is None:
+        return None
+    return word[:best], word[best:]
+
+
+def wrap(text, width):
+    _check_width(width)
+    words = text.split()
+    lines = []
+    current = []  # words on the current line
+    used = 0      # visible length of the current line
+
+    def flush():
+        nonlocal current, used
+        if current:
+            lines.append(" ".join(current))
+            current = []
+            used = 0
+
+    for word in words:
+        while True:
+            room = width - used - (1 if current else 0)
+            if len(word) <= room:
+                current.append(word)
+                used += (1 if used else 0) + len(word)
+                break
+            # word does not fit in the remaining room
+            if current:
+                broken = _hyphen_prefix(word, room)
+                if broken is not None:
+                    head, word = broken
+                    current.append(head)
+                flush()
+                continue
+            # fresh line
+            if len(word) <= width:
+                current.append(word)
+                used = len(word)
+                break
+            broken = _hyphen_prefix(word, width)
+            if broken is not None:
+                head, word = broken
+                lines.append(head)
+                continue
+            # unbreakable over-long word: overflow on its own line
+            lines.append(word)
+            break
+    flush()
+    return lines
+
+
+def _pad(words, width):
+    gaps = len(words) - 1
+    total = width - sum(len(w) for w in words)
+    base, extra = divmod(total, gaps)
+    parts = []
+    for i, w in enumerate(words[:-1]):
+        parts.append(w)
+        parts.append(" " * (base + (1 if i < extra else 0)))
+    parts.append(words[-1])
+    return "".join(parts)
+
+
+def justify(text, width):
+    _check_width(width)
+    lines = wrap(text, width)
+    out = []
+    for i, line in enumerate(lines):
+        words = line.split()
+        if i == len(lines) - 1 or len(words) < 2:
+            out.append(line)
+        else:
+            out.append(_pad(words, width))
+    return out
