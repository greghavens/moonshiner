diff --git a/pick.zsh b/pick.zsh
new file mode 100644
index 0000000..6a146f4
--- /dev/null
+++ b/pick.zsh
@@ -0,0 +1,55 @@
+#!/usr/bin/env zsh
+# pick.zsh — answer the recurring "which files" triage questions with zsh
+# glob qualifiers: (.) plain files, (/) dirs, (L+N) size, (om)/(m+N) mtime,
+# and a [1,K] subscript on the glob for "top K". The N qualifier keeps an
+# empty match from aborting the script; an empty result is exit 1, silently.
+emulate -R zsh
+setopt no_unset
+
+usage_line='usage: pick.zsh files|dirs|over|newest|stale <dir> [N]'
+
+die_usage() { # die_usage <message>
+  print -ru2 -- "pick.zsh: $1"
+  print -ru2 -- $usage_line
+  exit 64
+}
+
+if (( $# == 0 )); then
+  print -ru2 -- $usage_line
+  exit 64
+fi
+
+mode=$1
+case $mode in
+  files|dirs)        want=2 ;;
+  over|newest|stale) want=3 ;;
+  *) die_usage "unknown mode: $mode" ;;
+esac
+(( $# == want )) || die_usage 'wrong number of arguments'
+
+dir=$2
+n=0
+if (( want == 3 )); then
+  [[ $3 == <-> ]] || die_usage "not a number: $3"
+  n=$3
+fi
+
+if [[ ! -d $dir ]]; then
+  print -ru2 -- "pick.zsh: not a directory: $dir"
+  exit 66
+fi
+
+# Glob from inside DIR so results come out relative to it.
+cd -- "$dir" || exit 66
+
+typeset -a hits
+case $mode in
+  files)  hits=( **/*(N.on) ) ;;
+  dirs)   hits=( **/*(N/on) ) ;;
+  over)   hits=( **/*(N.L+${n}on) ) ;;
+  newest) hits=( **/*(N.om[1,$n]) ) ;;
+  stale)  hits=( **/*(N.m+${n}on) ) ;;
+esac
+
+(( ${#hits} )) || exit 1
+print -rl -- "${(@)hits}"
