diff --git a/withlock.sh b/withlock.sh
new file mode 100644
index 0000000..314837c
--- /dev/null
+++ b/withlock.sh
@@ -0,0 +1,51 @@
+#!/usr/bin/env bash
+# withlock.sh — run a command under an flock'd lockfile.
+#
+# Protocol: the lockfile is both the flock target and the holder record
+# (holder PID as its only line while held, empty when free). Callers that
+# find the lock busy append themselves to <lockfile>.queue and exit 75.
+# A recorded PID whose process is gone is a leftover from an interrupted
+# run: it gets cleared and the lock taken.
+set -u
+LC_ALL=C
+export LC_ALL
+
+if [[ $# -lt 2 ]]; then
+  echo "usage: withlock.sh <lockfile> <command> [args...]" >&2
+  exit 64
+fi
+lockfile=$1
+shift
+queue="$lockfile.queue"
+
+busy() { # busy <command words...>
+  printf '%s\n' "$*" >> "$queue"
+  echo "withlock.sh: busy: $lockfile" >&2
+  exit 75
+}
+
+# append-mode open: creates the file if needed, never clobbers a holder record
+exec 9>> "$lockfile"
+
+if ! flock -n 9; then
+  # an active run is holding the flock
+  busy "$@"
+fi
+
+holder=''
+IFS= read -r holder < "$lockfile" || true
+if [[ -n "$holder" ]]; then
+  if kill -0 "$holder" 2>/dev/null; then
+    # recorded process is alive even though the flock was free: a holder
+    # from the old pre-flock tooling — not ours to take
+    busy "$@"
+  fi
+  echo "withlock.sh: clearing leftover lock: $lockfile" >&2
+fi
+
+# the lock is ours: record ourselves, and guarantee release on the way out
+printf '%s\n' "$$" > "$lockfile"
+trap ': > "$lockfile"' EXIT
+
+"$@"
+exit "$?"
