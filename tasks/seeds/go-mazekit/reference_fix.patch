+// Package mazekit generates perfect mazes with a reproducible depth-first
+// backtracker, renders them as ASCII, and solves them with breadth-first
+// search.
+package mazekit
+
+import "fmt"
+
+// Maze is a w x h grid of cells. Cell (0,0) is the top-left corner; x grows
+// east and y grows south. The entrance is (0,0) and the exit is (w-1,h-1).
+type Maze struct {
+	w, h  int
+	east  []bool // east[y*(w-1)+x]: passage between (x,y) and (x+1,y)
+	south []bool // south[y*w+x]: passage between (x,y) and (x,y+1)
+}
+
+// lcg is the pinned linear congruential generator:
+// state = (state*1103515245 + 12345) mod 2^31, and each draw takes
+// (state >> 16) % n AFTER updating the state.
+type lcg struct{ state uint64 }
+
+func (l *lcg) next(n int) int {
+	l.state = (l.state*1103515245 + 12345) % (1 << 31)
+	return int((l.state >> 16) % uint64(n))
+}
+
+var dirs = []struct {
+	name   byte
+	dx, dy int
+}{
+	{'N', 0, -1},
+	{'E', 1, 0},
+	{'S', 0, 1},
+	{'W', -1, 0},
+}
+
+// Generate carves a perfect maze using the recursive-backtracker walk
+// described in the package docs, driven by the pinned LCG seeded with seed.
+// Both dimensions must be at least 1 and the seed must be non-negative.
+func Generate(w, h int, seed int64) (*Maze, error) {
+	if w < 1 || h < 1 {
+		return nil, fmt.Errorf("mazekit: bad dimensions %dx%d", w, h)
+	}
+	if seed < 0 {
+		return nil, fmt.Errorf("mazekit: negative seed %d", seed)
+	}
+	m := &Maze{w: w, h: h, east: make([]bool, (w-1)*h), south: make([]bool, w*(h-1))}
+	rng := &lcg{state: uint64(seed) % (1 << 31)}
+	visited := make([]bool, w*h)
+	type cell struct{ x, y int }
+	stack := []cell{{0, 0}}
+	visited[0] = true
+	for len(stack) > 0 {
+		cur := stack[len(stack)-1]
+		var options []int
+		for i, d := range dirs {
+			nx, ny := cur.x+d.dx, cur.y+d.dy
+			if nx >= 0 && nx < w && ny >= 0 && ny < h && !visited[ny*w+nx] {
+				options = append(options, i)
+			}
+		}
+		if len(options) == 0 {
+			stack = stack[:len(stack)-1]
+			continue
+		}
+		d := dirs[options[rng.next(len(options))]]
+		nx, ny := cur.x+d.dx, cur.y+d.dy
+		m.carve(cur.x, cur.y, d.name)
+		visited[ny*w+nx] = true
+		stack = append(stack, cell{nx, ny})
+	}
+	return m, nil
+}
+
+func (m *Maze) carve(x, y int, dir byte) {
+	switch dir {
+	case 'N':
+		m.south[(y-1)*m.w+x] = true
+	case 'S':
+		m.south[y*m.w+x] = true
+	case 'E':
+		m.east[y*(m.w-1)+x] = true
+	case 'W':
+		m.east[y*(m.w-1)+x-1] = true
+	}
+}
+
+// Width returns the maze width in cells.
+func (m *Maze) Width() int { return m.w }
+
+// Height returns the maze height in cells.
+func (m *Maze) Height() int { return m.h }
+
+// Open reports whether the passage from cell (x,y) in direction dir
+// ('N', 'E', 'S' or 'W') is open. Border walls and out-of-range cells are
+// never open, and neither is an unknown direction.
+func (m *Maze) Open(x, y int, dir byte) bool {
+	if x < 0 || x >= m.w || y < 0 || y >= m.h {
+		return false
+	}
+	switch dir {
+	case 'N':
+		return y > 0 && m.south[(y-1)*m.w+x]
+	case 'S':
+		return y < m.h-1 && m.south[y*m.w+x]
+	case 'E':
+		return x < m.w-1 && m.east[y*(m.w-1)+x]
+	case 'W':
+		return x > 0 && m.east[y*(m.w-1)+x-1]
+	}
+	return false
+}
+
+func (m *Maze) grid() [][]byte {
+	rows := make([][]byte, 2*m.h+1)
+	for i := range rows {
+		rows[i] = make([]byte, 2*m.w+1)
+		for j := range rows[i] {
+			rows[i][j] = '#'
+		}
+	}
+	for y := 0; y < m.h; y++ {
+		for x := 0; x < m.w; x++ {
+			rows[2*y+1][2*x+1] = ' '
+			if m.Open(x, y, 'E') {
+				rows[2*y+1][2*x+2] = ' '
+			}
+			if m.Open(x, y, 'S') {
+				rows[2*y+2][2*x+1] = ' '
+			}
+		}
+	}
+	return rows
+}
+
+func joinGrid(rows [][]byte) string {
+	out := make([]byte, 0, len(rows)*(len(rows[0])+1))
+	for i, r := range rows {
+		if i > 0 {
+			out = append(out, '\n')
+		}
+		out = append(out, r...)
+	}
+	return string(out)
+}
+
+// Render draws the maze as a (2h+1)-line ASCII picture, (2w+1) characters
+// per line: '#' for walls and ' ' for carved space, lines joined with \n
+// and no trailing newline. Cell (x,y) sits at line 2y+1, column 2x+1.
+func (m *Maze) Render() string {
+	return joinGrid(m.grid())
+}
+
+// Solve returns the sequence of moves ('N', 'E', 'S', 'W') along the
+// shortest path from (0,0) to (w-1,h-1), found by BFS that expands
+// neighbours in N, E, S, W order. A 1x1 maze solves to the empty string.
+func (m *Maze) Solve() string {
+	type cell struct{ x, y int }
+	prev := make(map[cell]byte)
+	seen := make([]bool, m.w*m.h)
+	seen[0] = true
+	queue := []cell{{0, 0}}
+	for len(queue) > 0 {
+		cur := queue[0]
+		queue = queue[1:]
+		if cur.x == m.w-1 && cur.y == m.h-1 {
+			break
+		}
+		for _, d := range dirs {
+			if !m.Open(cur.x, cur.y, d.name) {
+				continue
+			}
+			nxt := cell{cur.x + d.dx, cur.y + d.dy}
+			if seen[nxt.y*m.w+nxt.x] {
+				continue
+			}
+			seen[nxt.y*m.w+nxt.x] = true
+			prev[nxt] = d.name
+			queue = append(queue, nxt)
+		}
+	}
+	var rev []byte
+	cur := cell{m.w - 1, m.h - 1}
+	for cur != (cell{0, 0}) {
+		d := prev[cur]
+		rev = append(rev, d)
+		for _, dd := range dirs {
+			if dd.name == d {
+				cur = cell{cur.x - dd.dx, cur.y - dd.dy}
+				break
+			}
+		}
+	}
+	for i, j := 0, len(rev)-1; i < j; i, j = i+1, j-1 {
+		rev[i], rev[j] = rev[j], rev[i]
+	}
+	return string(rev)
+}
+
+// RenderWithPath is Render with the shortest path overlaid: every cell on
+// the path, and every opening the path passes through, is drawn as '.'.
+func (m *Maze) RenderWithPath() string {
+	rows := m.grid()
+	x, y := 0, 0
+	rows[1][1] = '.'
+	for _, mv := range []byte(m.Solve()) {
+		for _, d := range dirs {
+			if d.name == mv {
+				rows[2*y+1+d.dy][2*x+1+d.dx] = '.'
+				x, y = x+d.dx, y+d.dy
+				rows[2*y+1][2*x+1] = '.'
+				break
+			}
+		}
+	}
+	return joinGrid(rows)
+}
