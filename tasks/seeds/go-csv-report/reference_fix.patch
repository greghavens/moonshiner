+++ b/stream.go
@@ -0,0 +1,97 @@
+package report
+
+import (
+	"bytes"
+	"encoding/csv"
+	"fmt"
+	"io"
+)
+
+// Stream writes a CSV report incrementally to an io.Writer. The header
+// is written when the stream is created; rows accumulate in memory and
+// are flushed to the writer in batches of flushEvery.
+type Stream struct {
+	out     io.Writer
+	columns []string
+	index   map[string]int
+	every   int
+	pending [][]string
+	closed  bool
+}
+
+// NewStream starts a streaming report over w. The header row is
+// written immediately. flushEvery must be at least 1; columns follow
+// the same rules as New.
+func NewStream(w io.Writer, columns []string, flushEvery int) (*Stream, error) {
+	if flushEvery < 1 {
+		return nil, fmt.Errorf("report: flushEvery %d < 1", flushEvery)
+	}
+	r, err := New(columns...)
+	if err != nil {
+		return nil, err
+	}
+	s := &Stream{out: w, columns: r.columns, index: r.index, every: flushEvery}
+	if err := s.writeRecords([][]string{s.columns}); err != nil {
+		return nil, err
+	}
+	return s, nil
+}
+
+// Add buffers one row, flushing the batch to the writer once
+// flushEvery rows are pending. Row semantics match Report.Add: every
+// key must be a declared column, and missing columns are empty cells.
+func (s *Stream) Add(row map[string]string) error {
+	if s.closed {
+		return fmt.Errorf("report: stream is closed")
+	}
+	cells := make([]string, len(s.columns))
+	for k, v := range row {
+		i, ok := s.index[k]
+		if !ok {
+			return fmt.Errorf("report: %w %q", ErrUnknownColumn, k)
+		}
+		cells[i] = v
+	}
+	s.pending = append(s.pending, cells)
+	if len(s.pending) >= s.every {
+		return s.flush()
+	}
+	return nil
+}
+
+// Close flushes any pending rows. Adding after Close fails; closing an
+// already-closed stream is a no-op.
+func (s *Stream) Close() error {
+	if s.closed {
+		return nil
+	}
+	s.closed = true
+	return s.flush()
+}
+
+func (s *Stream) flush() error {
+	if len(s.pending) == 0 {
+		return nil
+	}
+	rows := s.pending
+	s.pending = nil
+	return s.writeRecords(rows)
+}
+
+// writeRecords encodes rows as CSV and hands them to the underlying
+// writer in a single Write.
+func (s *Stream) writeRecords(rows [][]string) error {
+	var buf bytes.Buffer
+	w := csv.NewWriter(&buf)
+	for _, row := range rows {
+		if err := w.Write(row); err != nil {
+			return err
+		}
+	}
+	w.Flush()
+	if err := w.Error(); err != nil {
+		return err
+	}
+	_, err := s.out.Write(buf.Bytes())
+	return err
+}
