+// Subset returns a new, independent report containing only the given
+// columns, in the given order, with all existing rows projected onto
+// them. Requesting an undeclared column fails with ErrUnknownColumn.
+func (r *Report) Subset(columns ...string) (*Report, error) {
+	sub, err := New(columns...)
+	if err != nil {
+		return nil, err
+	}
+	src := make([]int, len(columns))
+	for i, c := range columns {
+		j, ok := r.index[c]
+		if !ok {
+			return nil, fmt.Errorf("report: %w %q", ErrUnknownColumn, c)
+		}
+		src[i] = j
+	}
+	for _, row := range r.rows {
+		cells := make([]string, len(columns))
+		for i, j := range src {
+			cells[i] = row[j]
+		}
+		sub.rows = append(sub.rows, cells)
+	}
+	return sub, nil
+}
+
 // RowCount reports how many rows have been added.
 func (r *Report) RowCount() int { return len(r.rows) }
 
