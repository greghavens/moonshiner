+// sqlemit.ts — renders the nightly .sql seed files for the analytics team.
+//
+// Literals use standard-conforming strings: the only transformation on
+// string data is doubling embedded single quotes. NULL (the value) and
+// 'NULL' (the four-letter string) must never collide.
+
+import { writeFileSync } from "node:fs";
+
+export type Dialect = "ansi" | "mysql";
+
+export type SqlValue = string | number | boolean | null | Uint8Array;
+
+export interface TableSpec {
+  table: string;
+  columns: string[];
+  rows: SqlValue[][];
+}
+
+export function quoteIdent(name: string, dialect: Dialect): string {
+  if (typeof name !== "string" || name === "") {
+    throw new TypeError("identifier must be a non-empty string");
+  }
+  if (dialect === "mysql") {
+    return "`" + name.replace(/`/g, "``") + "`";
+  }
+  return '"' + name.replace(/"/g, '""') + '"';
+}
+
+export function renderLiteral(value: SqlValue): string {
+  if (value === null) return "NULL";
+  if (typeof value === "string") {
+    return "'" + value.replace(/'/g, "''") + "'";
+  }
+  if (typeof value === "number") {
+    if (!Number.isFinite(value)) {
+      throw new RangeError("numeric literals must be finite");
+    }
+    return String(value);
+  }
+  if (typeof value === "boolean") {
+    return value ? "TRUE" : "FALSE";
+  }
+  if (value instanceof Uint8Array) {
+    let hex = "";
+    for (const byte of value) {
+      hex += byte.toString(16).padStart(2, "0").toUpperCase();
+    }
+    return `X'${hex}'`;
+  }
+  throw new TypeError("unsupported value type for a SQL literal");
+}
+
+export function renderInsert(
+  table: string,
+  columns: string[],
+  rows: SqlValue[][],
+  dialect: Dialect
+): string {
+  if (columns.length === 0) throw new Error("renderInsert: no columns");
+  if (rows.length === 0) throw new Error("renderInsert: no rows");
+
+  const identList = columns.map((c) => quoteIdent(c, dialect)).join(", ");
+  const lines = [`INSERT INTO ${quoteIdent(table, dialect)} (${identList}) VALUES`];
+  rows.forEach((row, i) => {
+    if (row.length !== columns.length) {
+      throw new Error(`renderInsert: row ${i} has ${row.length} values, expected ${columns.length}`);
+    }
+    const items = row.map(renderLiteral).join(", ");
+    const terminator = i === rows.length - 1 ? ";" : ",";
+    lines.push(`  (${items})${terminator}`);
+  });
+  return lines.join("\n");
+}
+
+export function writeReport(path: string, tables: TableSpec[], dialect: Dialect): void {
+  const statements = tables.map((t) => renderInsert(t.table, t.columns, t.rows, dialect));
+  const body = statements.length === 0 ? "" : statements.join("\n\n") + "\n";
+  writeFileSync(path, body, "utf8");
+}
