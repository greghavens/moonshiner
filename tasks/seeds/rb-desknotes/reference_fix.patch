-  # Every tag in use, sorted, no duplicates.
-  def tags
-    @notes.flat_map(&:tags).uniq.sort
+  # Every tag in use on visible notes, sorted, no duplicates.
+  def tags(include_archived: false)
+    visible(include_archived).flat_map(&:tags).uniq.sort
+  end
+
+  # Parks a note out of the default reads without deleting it.
+  def archive(id)
+    note = fetch(id)
+    @archived[note.id] = true
+    note
+  end
+
+  def unarchive(id)
+    note = fetch(id)
+    @archived.delete(note.id)
+    note
+  end
+
+  def archived?(id)
+    fetch(id)
+    @archived.key?(id)
+  end
+
+  # Retags every note carrying +old+ (archived included). Renaming onto an
+  # existing tag merges: tag lists stay unique and sorted. Returns how many
+  # notes actually changed.
+  def rename_tag(old, new)
+    old = old.to_s
+    new = new.to_s
+    carriers = @notes.select { |note| note.tags.include?(old) }
+    raise ArgumentError, "unknown tag #{old.inspect}" if carriers.empty?
+
+    carriers.count do |note|
+      retagged = normalize(note.tags - [old] + [new])
+      next false if retagged == note.tags
+
+      note.tags = retagged
+      true
+    end
+  end
+
+  # Launcher-style fuzzy search over titles: pattern characters must appear
+  # in order (not necessarily adjacent), case-insensitively. Matches are
+  # scored greedily left to right and ranked by tighter span, then earlier
+  # first match, then note id. An empty pattern is no filter at all.
+  def search(pattern, include_archived: false)
+    pool = visible(include_archived)
+    return pool if pattern.empty?
+
+    needle = pattern.downcase
+    pool.filter_map { |note|
+      span, start = subsequence_span(note.title.downcase, needle)
+      [[span, start, note.id], note] if span
+    }.sort_by(&:first).map(&:last)
   end
 
   private
 
+  def visible(include_archived)
+    return @notes.dup if include_archived
+
+    @notes.reject { |note| @archived.key?(note.id) }
+  end
+
+  def fetch(id)
+    find(id) or raise ArgumentError, "no such note: #{id}"
+  end
+
+  # Greedy leftmost subsequence match; returns [span, first_index] or nil.
+  def subsequence_span(title, pattern)
+    first = nil
+    pos = -1
+    pattern.each_char do |ch|
+      pos = title.index(ch, pos + 1)
+      return nil unless pos
+
+      first ||= pos
+    end
+    [pos - first + 1, first]
+  end
+
   def normalize(tags)
     tags.map(&:to_s).uniq.sort
   end
