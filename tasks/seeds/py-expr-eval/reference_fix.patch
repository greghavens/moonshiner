index 0000000..443c6ea
--- /dev/null
+++ b/exprcalc.py
@@ -0,0 +1,227 @@
+"""Hand-rolled formula evaluator: tokenizer + recursive-descent parser.
+
+No eval/exec/compile/ast — expressions come from untrusted user input.
+"""
+
+
+class ExprError(Exception):
+    def __init__(self, message, pos):
+        super().__init__(f"{message} (at position {pos})")
+        self.message = message
+        self.pos = pos
+
+
+_KEYWORDS = {"and", "or", "not"}
+_FUNCTIONS = {
+    "abs": (1, 1),
+    "min": (1, None),
+    "max": (1, None),
+}
+_TWO_CHAR_OPS = ("**", "<=", ">=", "==", "!=")
+_ONE_CHAR_OPS = "+-*/%()<>,"
+
+
+class _Token:
+    __slots__ = ("kind", "value", "pos")
+
+    def __init__(self, kind, value, pos):
+        self.kind = kind      # "num" | "name" | "op" | "end"
+        self.value = value
+        self.pos = pos
+
+
+def _tokenize(source):
+    tokens = []
+    i = 0
+    n = len(source)
+    while i < n:
+        ch = source[i]
+        if ch in " \t":
+            i += 1
+            continue
+        if ch.isdigit():
+            start = i
+            while i < n and source[i].isdigit():
+                i += 1
+            is_float = False
+            if i < n and source[i] == "." and i + 1 < n and source[i + 1].isdigit():
+                is_float = True
+                i += 1
+                while i < n and source[i].isdigit():
+                    i += 1
+            text = source[start:i]
+            tokens.append(_Token("num", float(text) if is_float else int(text), start))
+            continue
+        if ch.isalpha() or ch == "_":
+            start = i
+            while i < n and (source[i].isalnum() or source[i] == "_"):
+                i += 1
+            tokens.append(_Token("name", source[start:i], start))
+            continue
+        if source[i:i + 2] in _TWO_CHAR_OPS:
+            tokens.append(_Token("op", source[i:i + 2], i))
+            i += 2
+            continue
+        if ch in _ONE_CHAR_OPS:
+            tokens.append(_Token("op", ch, i))
+            i += 1
+            continue
+        raise ExprError(f"unexpected character {ch!r}", i)
+    tokens.append(_Token("end", None, n))
+    return tokens
+
+
+class _Parser:
+    def __init__(self, source, variables):
+        self.tokens = _tokenize(source)
+        self.i = 0
+        self.variables = variables
+
+    @property
+    def tok(self):
+        return self.tokens[self.i]
+
+    def _advance(self):
+        tok = self.tok
+        self.i += 1
+        return tok
+
+    def _fail(self, tok):
+        if tok.kind == "end":
+            raise ExprError("unexpected end of input", tok.pos)
+        raise ExprError(f"unexpected {tok.value!r}", tok.pos)
+
+    def _is_op(self, *values):
+        return self.tok.kind == "op" and self.tok.value in values
+
+    def _is_keyword(self, word):
+        return self.tok.kind == "name" and self.tok.value == word
+
+    def parse(self):
+        value = self.or_expr()
+        if self.tok.kind != "end":
+            self._fail(self.tok)
+        return value
+
+    def or_expr(self):
+        value = self.and_expr()
+        while self._is_keyword("or"):
+            self._advance()
+            right = self.and_expr()
+            value = bool(value) or bool(right)
+        return value
+
+    def and_expr(self):
+        value = self.not_expr()
+        while self._is_keyword("and"):
+            self._advance()
+            right = self.not_expr()
+            value = bool(value) and bool(right)
+        return value
+
+    def not_expr(self):
+        if self._is_keyword("not"):
+            self._advance()
+            return not bool(self.not_expr())
+        return self.comparison()
+
+    def comparison(self):
+        left = self.arith()
+        if self._is_op("<", "<=", ">", ">=", "==", "!="):
+            op = self._advance()
+            right = self.arith()
+            return {
+                "<": left < right,
+                "<=": left <= right,
+                ">": left > right,
+                ">=": left >= right,
+                "==": left == right,
+                "!=": left != right,
+            }[op.value]
+        return left
+
+    def arith(self):
+        value = self.term()
+        while self._is_op("+", "-"):
+            op = self._advance()
+            right = self.term()
+            value = value + right if op.value == "+" else value - right
+        return value
+
+    def term(self):
+        value = self.unary()
+        while self._is_op("*", "/", "%"):
+            op = self._advance()
+            right = self.unary()
+            try:
+                if op.value == "*":
+                    value = value * right
+                elif op.value == "/":
+                    value = value / right
+                else:
+                    value = value % right
+            except ZeroDivisionError:
+                raise ExprError("division by zero", op.pos) from None
+        return value
+
+    def unary(self):
+        if self._is_op("-", "+"):
+            op = self._advance()
+            value = self.unary()
+            return -value if op.value == "-" else +value
+        return self.power()
+
+    def power(self):
+        value = self.atom()
+        if self._is_op("**"):
+            self._advance()
+            exponent = self.unary()   # right-assoc; allows 2 ** -2
+            return value ** exponent
+        return value
+
+    def atom(self):
+        tok = self.tok
+        if tok.kind == "num":
+            self._advance()
+            return tok.value
+        if tok.kind == "name" and tok.value not in _KEYWORDS:
+            self._advance()
+            if self._is_op("("):
+                return self.call(tok)
+            if tok.value not in self.variables:
+                raise ExprError(f"unknown variable '{tok.value}'", tok.pos)
+            return self.variables[tok.value]
+        if self._is_op("("):
+            self._advance()
+            value = self.or_expr()
+            if not self._is_op(")"):
+                self._fail(self.tok)
+            self._advance()
+            return value
+        self._fail(tok)
+
+    def call(self, name_tok):
+        name = name_tok.value
+        if name not in _FUNCTIONS:
+            raise ExprError(f"unknown function '{name}'", name_tok.pos)
+        self._advance()  # consume "("
+        args = []
+        if not self._is_op(")"):
+            args.append(self.or_expr())
+            while self._is_op(","):
+                self._advance()
+                args.append(self.or_expr())
+        if not self._is_op(")"):
+            self._fail(self.tok)
+        self._advance()
+        lo, hi = _FUNCTIONS[name]
+        if len(args) < lo or (hi is not None and len(args) > hi):
+            raise ExprError(f"function '{name}' called with {len(args)} "
+                            f"argument(s)", name_tok.pos)
+        if name == "abs":
+            return abs(args[0])
+        return min(args) if name == "min" else max(args)
+
+
+def evaluate(source, variables=None):
+    return _Parser(source, variables or {}).parse()
