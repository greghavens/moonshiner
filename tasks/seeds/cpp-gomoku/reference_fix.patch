diff --git a/gomoku.cpp b/gomoku.cpp
new file mode 100644
index 0000000..657133b
--- /dev/null
+++ b/gomoku.cpp
@@ -0,0 +1,108 @@
+#include "gomoku.h"
+
+#include <cstdlib>
+#include <sstream>
+
+namespace {
+
+const int N = 15;
+const int DIRS[4][2] = {{0, 1}, {1, 0}, {1, 1}, {1, -1}};
+
+bool on_board(int r, int c) { return r >= 0 && r < N && c >= 0 && c < N; }
+
+// Maximal contiguous run of `side` stones through (r, c) in one direction,
+// counting (r, c) as occupied by `side`.
+int run_through(const int cells[15][15], int r, int c, int side, int dr, int dc) {
+    int len = 1;
+    for (int rr = r + dr, cc = c + dc;
+         on_board(rr, cc) && cells[rr][cc] == side; rr += dr, cc += dc)
+        len++;
+    for (int rr = r - dr, cc = c - dc;
+         on_board(rr, cc) && cells[rr][cc] == side; rr -= dr, cc -= dc)
+        len++;
+    return len;
+}
+
+// Would placing `side` at empty (r, c) leave a maximal run of exactly `n`?
+bool makes_exact(const int cells[15][15], int r, int c, int side, int n) {
+    for (int d = 0; d < 4; d++)
+        if (run_through(cells, r, c, side, DIRS[d][0], DIRS[d][1]) == n)
+            return true;
+    return false;
+}
+
+}  // namespace
+
+void gm_init(Gomoku *g) {
+    for (int r = 0; r < N; r++)
+        for (int c = 0; c < N; c++) g->cells[r][c] = 0;
+    g->to_move = 1;
+    g->winner = 0;
+    g->stones = 0;
+}
+
+int gm_at(const Gomoku *g, int r, int c) {
+    if (!on_board(r, c)) return -1;
+    return g->cells[r][c];
+}
+
+int gm_to_move(const Gomoku *g) { return g->to_move; }
+
+int gm_winner(const Gomoku *g) { return g->winner; }
+
+bool gm_play(Gomoku *g, int r, int c) {
+    if (g->winner != 0) return false;
+    if (!on_board(r, c) || g->cells[r][c] != 0) return false;
+    int side = g->to_move;
+    if (makes_exact(g->cells, r, c, side, 5)) g->winner = side;
+    g->cells[r][c] = side;
+    g->stones++;
+    if (g->winner == 0 && g->stones == N * N) g->winner = 3;
+    g->to_move = 3 - side;
+    return true;
+}
+
+int gm_replay(Gomoku *g, const std::string &moves) {
+    gm_init(g);
+    std::istringstream in(moves);
+    std::string tok;
+    int idx = 0;
+    while (in >> tok) {
+        size_t comma = tok.find(',');
+        int r = -1, c = -1;
+        if (comma != std::string::npos) {
+            r = std::atoi(tok.substr(0, comma).c_str());
+            c = std::atoi(tok.substr(comma + 1).c_str());
+        }
+        if (!gm_play(g, r, c)) return idx;
+        idx++;
+    }
+    return -1;
+}
+
+bool gm_bot(const Gomoku *g, int *r, int *c) {
+    if (g->winner != 0 || g->stones == N * N) return false;
+    int me = g->to_move, opp = 3 - me;
+    struct Probe { int side, len; };
+    const Probe tiers[4] = {{me, 5}, {opp, 5}, {me, 4}, {opp, 4}};
+    for (const Probe &t : tiers) {
+        for (int rr = 0; rr < N; rr++)
+            for (int cc = 0; cc < N; cc++)
+                if (g->cells[rr][cc] == 0 &&
+                    makes_exact(g->cells, rr, cc, t.side, t.len)) {
+                    *r = rr;
+                    *c = cc;
+                    return true;
+                }
+    }
+    int bestR = -1, bestC = -1, bestD = N;
+    for (int rr = 0; rr < N; rr++)
+        for (int cc = 0; cc < N; cc++) {
+            if (g->cells[rr][cc] != 0) continue;
+            int d = std::max(std::abs(rr - 7), std::abs(cc - 7));
+            if (d < bestD) { bestD = d; bestR = rr; bestC = cc; }
+        }
+    *r = bestR;
+    *c = bestC;
+    return true;
+}
