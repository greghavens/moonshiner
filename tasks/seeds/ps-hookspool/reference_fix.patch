diff --git a/hookspool.ps1 b/hookspool.ps1
new file mode 100644
index 0000000..5fcf248
--- /dev/null
+++ b/hookspool.ps1
@@ -0,0 +1,106 @@
+# Webhook receiver: spools HMAC-verified vendor events as NDJSON.
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][int]$Port,
+    [Parameter(Mandatory)][string]$Secret,
+    [Parameter(Mandatory)][int]$Count,
+    [Parameter(Mandatory)][string]$SpoolPath,
+    [Parameter(Mandatory)][string]$ManifestPath,
+    [Parameter(Mandatory)][string]$ReadyPath
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Send-Json {
+    param($Context, [int]$Status, [string]$Json)
+    $bytes = [System.Text.Encoding]::UTF8.GetBytes($Json)
+    $Context.Response.StatusCode = $Status
+    $Context.Response.ContentType = 'application/json'
+    $Context.Response.OutputStream.Write($bytes, 0, $bytes.Length)
+    $Context.Response.Close()
+}
+
+$hmac = [System.Security.Cryptography.HMACSHA256]::new(
+    [System.Text.Encoding]::UTF8.GetBytes($Secret))
+$listener = [System.Net.HttpListener]::new()
+$listener.Prefixes.Add("http://127.0.0.1:$Port/")
+
+$received = 0
+$accepted = 0
+$rejected = 0
+$other = 0
+$acceptedIds = [System.Collections.Generic.List[string]]::new()
+$rejectedReasons = [System.Collections.Generic.List[string]]::new()
+
+try {
+    $listener.Start()
+    [System.IO.File]::WriteAllText($ReadyPath, 'ready')
+
+    while ($received -lt $Count) {
+        $ctx = $listener.GetContext()
+        $received++
+        $req = $ctx.Request
+
+        $ms = [System.IO.MemoryStream]::new()
+        $req.InputStream.CopyTo($ms)
+        $body = $ms.ToArray()
+
+        if ($req.Url.AbsolutePath -ne '/hooks') {
+            $other++
+            Send-Json $ctx 404 '{"ok":false,"error":"not found"}'
+            continue
+        }
+        if ($req.HttpMethod -ne 'POST') {
+            $other++
+            Send-Json $ctx 405 '{"ok":false,"error":"method not allowed"}'
+            continue
+        }
+
+        $header = $req.Headers['X-Hook-Signature']
+        if ([string]::IsNullOrEmpty($header)) {
+            $rejected++
+            $rejectedReasons.Add('missing-signature')
+            Send-Json $ctx 401 '{"ok":false,"error":"signature required"}'
+            continue
+        }
+        $expected = -join ($hmac.ComputeHash($body) | ForEach-Object { $_.ToString('x2') })
+        $valid = $header.StartsWith('sha256=', [System.StringComparison]::Ordinal) -and
+            [string]::Equals($header.Substring(7), $expected,
+                [System.StringComparison]::OrdinalIgnoreCase)
+        if (-not $valid) {
+            $rejected++
+            $rejectedReasons.Add('bad-signature')
+            Send-Json $ctx 401 '{"ok":false,"error":"signature mismatch"}'
+            continue
+        }
+
+        # spool the accepted event byte-for-byte as received (UTF-8, no BOM)
+        $fs = [System.IO.File]::Open($SpoolPath, [System.IO.FileMode]::Append)
+        try {
+            $fs.Write($body, 0, $body.Length)
+            $fs.WriteByte(10)
+        } finally {
+            $fs.Dispose()
+        }
+        $accepted++
+        $event = [System.Text.Encoding]::UTF8.GetString($body) | ConvertFrom-Json
+        $acceptedIds.Add([string]$event.id)
+        Send-Json $ctx 200 '{"ok":true}'
+    }
+} finally {
+    $listener.Stop()
+    $listener.Close()
+    $hmac.Dispose()
+}
+
+$manifest = [ordered]@{
+    received        = $received
+    accepted        = $accepted
+    rejected        = $rejected
+    other           = $other
+    acceptedIds     = @($acceptedIds)
+    rejectedReasons = @($rejectedReasons)
+}
+[System.IO.File]::WriteAllText($ManifestPath, ($manifest | ConvertTo-Json -Compress -Depth 4))
+exit 0
