+
+
+class RoleGraph:
+    """Roles with inheritance and deny-overrides.
+
+    A role's closure is itself plus everything it inherits, transitively.
+    A permission is allowed when some role in the closure grants it AND
+    no role anywhere in the closure denies it — deny always wins.
+    """
+
+    def __init__(self):
+        self._roles = {}  # name -> {"grants", "denies", "inherits"}
+
+    def add_role(self, name, grants=(), denies=(), inherits=()):
+        if not name or not name.strip():
+            raise ValueError("role name required")
+        if name in self._roles:
+            raise ValueError("role already defined: %r" % (name,))
+        parents = tuple(inherits)
+        for parent in parents:
+            if parent not in self._roles:
+                raise KeyError(parent)
+        self._roles[name] = {
+            "grants": frozenset(grants),
+            "denies": frozenset(denies),
+            "inherits": parents,
+        }
+
+    def roles(self):
+        return sorted(self._roles)
+
+    def _closure(self, name):
+        """All role names reachable from `name`, including itself."""
+        if name not in self._roles:
+            raise KeyError(name)
+        seen = set()
+        stack = [name]
+        while stack:
+            current = stack.pop()
+            if current in seen:
+                continue
+            seen.add(current)
+            stack.extend(self._roles[current]["inherits"])
+        return seen
+
+    def effective_grants(self, name):
+        """Net permissions of one role: inherited grants minus any denies."""
+        granted, denied = set(), set()
+        for member in self._closure(name):
+            granted |= self._roles[member]["grants"]
+            denied |= self._roles[member]["denies"]
+        return frozenset(granted - denied)
+
+    def allowed(self, role_names, permission):
+        """Deny-overrides check across every role the user carries."""
+        granted, denied = set(), set()
+        for name in role_names:
+            for member in self._closure(name):
+                granted |= self._roles[member]["grants"]
+                denied |= self._roles[member]["denies"]
+        return permission in granted and permission not in denied
+
+    def require(self, role_names, permission):
+        if not self.allowed(role_names, permission):
+            raise PermissionDenied(permission)
