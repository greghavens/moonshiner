+// Cookie wire-format toolkit: Cookie header parsing, Set-Cookie parsing and
+// serialization, and expiry computation. No storage, no HTTP objects.
+
+export type SameSite = 'Strict' | 'Lax' | 'None';
+
+export interface SetCookie {
+  name: string;
+  value: string;
+  domain?: string;
+  path?: string;
+  /** ms since epoch, from a valid Expires attribute. */
+  expires?: number;
+  /** seconds, possibly negative. */
+  maxAge?: number;
+  secure: boolean;
+  httpOnly: boolean;
+  sameSite?: SameSite;
+}
+
+export interface SetCookieInit {
+  name: string;
+  value: string;
+  domain?: string;
+  path?: string;
+  /** ms since epoch. */
+  expires?: number;
+  maxAge?: number;
+  secure?: boolean;
+  httpOnly?: boolean;
+  sameSite?: string;
+}
+
+const TOKEN = /^[!#$%&'*+\-.^_`|~0-9A-Za-z]+$/;
+// cookie-octet set from RFC 6265: printable US-ASCII minus space, ", comma, ; and backslash
+const COOKIE_VALUE = /^[\x21\x23-\x2B\x2D-\x3A\x3C-\x5B\x5D-\x7E]*$/;
+
+function unquote(value: string): string {
+  if (value.length >= 2 && value.startsWith('"') && value.endsWith('"')) {
+    return value.slice(1, -1);
+  }
+  return value;
+}
+
+function normalizeSameSite(value: string): SameSite | undefined {
+  switch (value.toLowerCase()) {
+    case 'strict': return 'Strict';
+    case 'lax': return 'Lax';
+    case 'none': return 'None';
+    default: return undefined;
+  }
+}
+
+export function parseCookieHeader(header: string): Record<string, string> {
+  const out: Record<string, string> = {};
+  for (const segment of header.split(';')) {
+    const eq = segment.indexOf('=');
+    if (eq === -1) continue; // no pair, skip
+    const name = segment.slice(0, eq).trim();
+    if (!name) continue;
+    if (Object.hasOwn(out, name)) continue; // first occurrence wins
+    out[name] = unquote(segment.slice(eq + 1).trim());
+  }
+  return out;
+}
+
+export function parseSetCookie(line: string): SetCookie | null {
+  const segments = line.split(';');
+  const first = segments[0];
+  const eq = first.indexOf('=');
+  if (eq === -1) return null;
+  const name = first.slice(0, eq).trim();
+  if (!name) return null;
+  const cookie: SetCookie = {
+    name,
+    value: unquote(first.slice(eq + 1).trim()),
+    secure: false,
+    httpOnly: false,
+  };
+
+  for (const segment of segments.slice(1)) {
+    const attrEq = segment.indexOf('=');
+    const attrName = (attrEq === -1 ? segment : segment.slice(0, attrEq)).trim().toLowerCase();
+    const attrValue = attrEq === -1 ? '' : segment.slice(attrEq + 1).trim();
+    switch (attrName) {
+      case 'domain':
+        if (attrValue) cookie.domain = attrValue.replace(/^\./, '').toLowerCase();
+        break;
+      case 'path':
+        if (attrValue) cookie.path = attrValue;
+        break;
+      case 'expires': {
+        const t = Date.parse(attrValue);
+        if (!Number.isNaN(t)) cookie.expires = t; // invalid dates: attribute dropped
+        break;
+      }
+      case 'max-age':
+        if (/^-?\d+$/.test(attrValue)) cookie.maxAge = parseInt(attrValue, 10);
+        break;
+      case 'secure':
+        cookie.secure = true;
+        break;
+      case 'httponly':
+        cookie.httpOnly = true;
+        break;
+      case 'samesite': {
+        const normalized = normalizeSameSite(attrValue);
+        if (normalized !== undefined) cookie.sameSite = normalized;
+        break;
+      }
+      default:
+        break; // unknown attributes are ignored
+    }
+  }
+
+  if (cookie.sameSite === 'None' && !cookie.secure) return null;
+  if (name.startsWith('__Secure-') && !cookie.secure) return null;
+  if (name.startsWith('__Host-')) {
+    if (!cookie.secure || cookie.path !== '/' || cookie.domain !== undefined) return null;
+  }
+  return cookie;
+}
+
+export function serializeSetCookie(init: SetCookieInit): string {
+  const { name, value } = init;
+  if (typeof name !== 'string' || !TOKEN.test(name)) {
+    throw new TypeError(`cookie name must be a non-empty token, got ${JSON.stringify(name)}`);
+  }
+  if (typeof value !== 'string' || !COOKIE_VALUE.test(value)) {
+    throw new TypeError(`cookie value contains characters that cannot go on the wire: ${JSON.stringify(value)}`);
+  }
+
+  let sameSite: SameSite | undefined;
+  if (init.sameSite !== undefined) {
+    sameSite = normalizeSameSite(init.sameSite);
+    if (sameSite === undefined) {
+      throw new TypeError(`unknown SameSite value: ${JSON.stringify(init.sameSite)}`);
+    }
+  }
+  const secure = init.secure === true;
+  if (sameSite === 'None' && !secure) {
+    throw new TypeError('SameSite=None requires Secure');
+  }
+
+  let domain: string | undefined;
+  if (init.domain !== undefined) {
+    domain = init.domain.replace(/^\./, '').toLowerCase();
+  }
+  const path = init.path;
+  if (path !== undefined && (!path.startsWith('/') || path.includes(';'))) {
+    throw new TypeError(`cookie path must start with "/" and contain no ";": ${JSON.stringify(path)}`);
+  }
+  if (init.maxAge !== undefined && !Number.isInteger(init.maxAge)) {
+    throw new TypeError(`Max-Age must be an integer, got ${JSON.stringify(init.maxAge)}`);
+  }
+  if (name.startsWith('__Secure-') && !secure) {
+    throw new TypeError('__Secure- cookies must set Secure');
+  }
+  if (name.startsWith('__Host-') && (!secure || path !== '/' || domain !== undefined)) {
+    throw new TypeError('__Host- cookies must set Secure and Path=/ and carry no Domain');
+  }
+
+  const parts = [`${name}=${value}`];
+  if (domain !== undefined) parts.push(`Domain=${domain}`);
+  if (path !== undefined) parts.push(`Path=${path}`);
+  if (init.expires !== undefined) parts.push(`Expires=${new Date(init.expires).toUTCString()}`);
+  if (init.maxAge !== undefined) parts.push(`Max-Age=${init.maxAge}`);
+  if (secure) parts.push('Secure');
+  if (init.httpOnly === true) parts.push('HttpOnly');
+  if (sameSite !== undefined) parts.push(`SameSite=${sameSite}`);
+  return parts.join('; ');
+}
+
+export function cookieExpiresAt(
+  cookie: { maxAge?: number; expires?: number },
+  nowMs: number,
+): number | null {
+  if (cookie.maxAge !== undefined) return nowMs + cookie.maxAge * 1000; // Max-Age beats Expires
+  if (cookie.expires !== undefined) return cookie.expires;
+  return null; // session cookie
+}
+
+export function isExpired(cookie: { maxAge?: number; expires?: number }, nowMs: number): boolean {
+  const at = cookieExpiresAt(cookie, nowMs);
+  return at !== null && at <= nowMs;
+}
