      "content": "Move that same title record to South Branch and set its date to 2026-10-09. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-13. Keep it at South Branch; do not revert any other field."
    }
  ],
  "available_tools": [
    "library_search",
    "library_get",
    "library_list",
    "library_update",
    "library_cancel",
    "library_notify"
  ],
