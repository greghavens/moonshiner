  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "library",
  "prompt": "Find the title record “Borrowed Constellations” at North Branch and report its stable ID, current date, location, and status. Do not make any changes yet. Do not send a notification or message at any point.",
