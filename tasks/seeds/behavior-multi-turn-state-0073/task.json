      {
        "id": "lib-173",
        "name": "Borrowed Constellations",
        "location": "North Branch",
        "date": "2026-08-06",
        "status": "active"
      },
      {
        "id": "lib-573",
        "name": "Archive of Rain",
        "location": "South Branch",
        "date": "2026-09-13",
        "status": "active"
      },
      {
        "id": "lib-873",
        "name": "Borrowed Constellations",
        "location": "Central Branch",
        "date": "2026-09-13",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "library_search",
            "arguments": {
              "query": "Borrowed Constellations",
              "location": "North Branch"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "library_update",
            "arguments": {
              "id": "lib-173",
              "date": "2026-10-09",
              "location": "South Branch"
            }
          }
