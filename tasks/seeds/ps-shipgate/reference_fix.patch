diff --git a/shipgate.ps1 b/shipgate.ps1
new file mode 100644
index 0000000..8a38427
--- /dev/null
+++ b/shipgate.ps1
@@ -0,0 +1,66 @@
+# shipgate.ps1 — pre-release depot gate.
+# Verifies a shipment manifest (lines of '<size> <relpath>') against a depot
+# directory. The interface is the exit code plus at most one stderr line;
+# success is completely silent.
+#
+# Exit codes: 0 gate passes (silent), 64 usage error, 65 manifest malformed,
+# 66 manifest or depot missing, 70 gate check failed.
+param(
+    [string]$Manifest,
+    [string]$Depot
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Deny {
+    param([int]$Code, [string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+$usage = 'shipgate: usage: shipgate.ps1 -Manifest <file> -Depot <dir>'
+if ($args.Count -gt 0) { Deny 64 $usage }
+if ([string]::IsNullOrEmpty($Manifest) -or [string]::IsNullOrEmpty($Depot)) { Deny 64 $usage }
+
+if (-not (Test-Path -LiteralPath $Manifest -PathType Leaf)) {
+    Deny 66 "shipgate: no such manifest: $Manifest"
+}
+if (-not (Test-Path -LiteralPath $Depot -PathType Container)) {
+    Deny 66 "shipgate: no such depot: $Depot"
+}
+
+# Parse the whole manifest before touching the depot: a manifest that does
+# not parse is a data error (65) no matter what state the depot is in.
+$entries = [System.Collections.Generic.List[object]]::new()
+$seen = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::Ordinal)
+$lineNo = 0
+foreach ($raw in [System.IO.File]::ReadAllLines($Manifest)) {
+    $lineNo++
+    $line = $raw.Trim()
+    if ($line.Length -eq 0 -or $line.StartsWith('#')) { continue }
+    $m = [regex]::Match($line, '^([0-9]+) (.+)$')
+    if (-not $m.Success) {
+        Deny 65 "shipgate: manifest line ${lineNo}: expected '<size> <relpath>'"
+    }
+    $size = [long]$m.Groups[1].Value
+    $rel = $m.Groups[2].Value
+    if (-not $seen.Add($rel)) {
+        Deny 65 "shipgate: manifest line ${lineNo}: duplicate entry: $rel"
+    }
+    $entries.Add(@($size, $rel))
+}
+
+foreach ($entry in $entries) {
+    $size, $rel = $entry
+    $full = Join-Path $Depot $rel
+    if (-not (Test-Path -LiteralPath $full -PathType Leaf)) {
+        Deny 70 "shipgate: gate failed: missing $rel"
+    }
+    $actual = (Get-Item -LiteralPath $full).Length
+    if ($actual -ne $size) {
+        Deny 70 "shipgate: gate failed: size $rel expected $size got $actual"
+    }
+}
+
+exit 0
