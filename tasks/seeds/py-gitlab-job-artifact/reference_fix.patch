index 0000000..7f30af1
--- /dev/null
+++ b/glartifacts/downloader.py
@@ -0,0 +1,50 @@
+"""Selects the newest successful pipeline/job and downloads its artifacts."""
+
+from datetime import datetime
+
+from .errors import ArtifactLookupError, ArtifactsExpiredError
+
+
+def _parse_expiry(value):
+    return datetime.fromisoformat(value.replace("Z", "+00:00"))
+
+
+class ArtifactDownloader:
+    def __init__(self, client, now):
+        self._client = client
+        self._now = now
+
+    def fetch_latest(self, project_id, job_name, dest_path):
+        pipelines = self._client.list_pipelines(
+            project_id, status="success", order_by="id", sort="desc"
+        )
+        if not pipelines:
+            raise ArtifactLookupError(
+                "project %s has no successful pipelines" % project_id
+            )
+        newest = pipelines[0]
+        jobs = self._client.list_pipeline_jobs(project_id, newest["id"], per_page=100)
+        match = next(
+            (j for j in jobs if j["name"] == job_name and j["status"] == "success"),
+            None,
+        )
+        if match is None:
+            raise ArtifactLookupError(
+                "no successful job named %r in pipeline %s of project %s"
+                % (job_name, newest["id"], project_id)
+            )
+        expire_at = match.get("artifacts_expire_at")
+        if expire_at is not None and _parse_expiry(expire_at) <= self._now():
+            raise ArtifactsExpiredError(
+                "artifacts of job %s expired at %s and were removed by GitLab"
+                % (match["id"], expire_at)
+            )
+        result = self._client.download_artifacts(project_id, match["id"], dest_path)
+        return {
+            "project_id": project_id,
+            "pipeline_id": newest["id"],
+            "job_id": match["id"],
+            "sha256": result["sha256"],
+            "size": result["size"],
+            "path": dest_path,
+        }
diff --git a/glartifacts/errors.py b/glartifacts/errors.py
new file mode 100644
index 0000000..d4ad249
--- /dev/null
+++ b/glartifacts/errors.py
@@ -0,0 +1,25 @@
+"""Exception types for the GitLab job-artifact downloader."""
+
+
+class GitLabAPIError(Exception):
+    """A GitLab API request failed. Carries the HTTP status, never the token."""
+
+    def __init__(self, status, message):
+        super().__init__(message)
+        self.status = status
+
+
+class NotFoundMaskedError(GitLabAPIError):
+    """GitLab answered 404, which covers both 'missing' and 'no permission'."""
+
+
+class TruncatedDownloadError(Exception):
+    """The artifact body ended before the advertised Content-Length."""
+
+
+class ArtifactLookupError(Exception):
+    """No pipeline or job matched the requested selection."""
+
+
+class ArtifactsExpiredError(Exception):
+    """The selected job's artifacts_expire_at lies in the past."""
