 //! Surcharge definitions and ordered application to a running total:
 //! percent-vs-flat kinds, caps, `requires` flags, and contract waivers.
+
+use std::collections::BTreeSet;
+
+use crate::money::Money;
+
+#[derive(Debug, Clone)]
+pub enum SurchargeKind {
+    /// Basis points of the running total at application time.
+    Percent(u32),
+    Flat(Money),
+}
+
+#[derive(Debug, Clone)]
+pub struct Surcharge {
+    pub code: String,
+    pub label: String,
+    pub kind: SurchargeKind,
+    pub cap: Option<Money>,
+    pub requires: Option<String>,
+}
+
+/// One surcharge application on a quote.
+#[derive(Debug, Clone)]
+pub struct Applied {
+    pub code: String,
+    /// Basis points for a percent surcharge, None for flat.
+    pub percent: Option<u32>,
+    /// The running total a percent was computed on, None for flat.
+    pub base: Option<Money>,
+    pub amount: Money,
+    pub cap: Option<Money>,
+    pub capped: bool,
+    pub waived: bool,
+}
+
+impl Surcharge {
+    /// None: the `requires` flag is absent — the surcharge is skipped
+    /// silently. Some(waived): the code is waived by contract, $0.00.
+    pub fn apply(
+        &self,
+        running: Money,
+        flags: &BTreeSet<String>,
+        waivers: &BTreeSet<String>,
+    ) -> Option<Applied> {
+        if let Some(required) = &self.requires {
+            if !flags.contains(required) {
+                return None;
+            }
+        }
+        if waivers.contains(&self.code) {
+            return Some(Applied {
+                code: self.code.clone(),
+                percent: None,
+                base: None,
+                amount: Money::from_cents(0),
+                cap: self.cap,
+                capped: false,
+                waived: true,
+            });
+        }
+        let (percent, base, mut amount) = match &self.kind {
+            SurchargeKind::Percent(bp) => (Some(*bp), Some(running), running.percent_of(*bp)),
+            SurchargeKind::Flat(m) => (None, None, *m),
+        };
+        let mut capped = false;
+        if let Some(cap) = self.cap {
+            if amount.cents() > cap.cents() {
+                amount = cap;
+                capped = true;
+            }
+        }
+        Some(Applied {
+            code: self.code.clone(),
+            percent,
+            base,
+            amount,
+            cap: self.cap,
+            capped,
+            waived: false,
+        })
+    }
+}
