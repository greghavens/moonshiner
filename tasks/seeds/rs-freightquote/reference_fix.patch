 //! Schema layer: interprets a parsed rate sheet into a `Tariff` (zones,
 //! lanes, rate scales, ordered surcharges), rejecting structural problems
 //! with exact schema error messages. Also owns loading from a file path.
+
+use std::collections::BTreeMap;
+use std::fmt;
+use std::path::Path;
+
+use crate::brackets::RateScale;
+use crate::money::Money;
+use crate::ratefile::{ParseError, RateFile, Value};
+use crate::surcharge::{Surcharge, SurchargeKind};
+use crate::zones::{LaneTable, ZoneMap};
+
+#[derive(Debug)]
+pub enum TariffError {
+    Parse(ParseError),
+    Schema(String),
+    Io(String),
+}
+
+impl fmt::Display for TariffError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            TariffError::Parse(e) => write!(f, "{}", e),
+            TariffError::Schema(m) => write!(f, "schema: {}", m),
+            TariffError::Io(m) => write!(f, "io: {}", m),
+        }
+    }
+}
+
+fn schema(message: String) -> TariffError {
+    TariffError::Schema(message)
+}
+
+/// A validated tariff, ready to rate against. Surcharges keep sheet order.
+#[derive(Debug, Clone)]
+pub struct Tariff {
+    pub name: String,
+    pub zones: ZoneMap,
+    pub lanes: LaneTable,
+    pub scales: BTreeMap<String, RateScale>,
+    pub surcharges: Vec<Surcharge>,
+}
+
+impl Tariff {
+    pub fn load(path: impl AsRef<Path>) -> Result<Tariff, TariffError> {
+        let src =
+            std::fs::read_to_string(path).map_err(|e| TariffError::Io(e.to_string()))?;
+        Tariff::parse(&src)
+    }
+
+    pub fn parse(src: &str) -> Result<Tariff, TariffError> {
+        let file = RateFile::parse(src).map_err(TariffError::Parse)?;
+        Tariff::from_ratefile(&file)
+    }
+
+    fn from_ratefile(file: &RateFile) -> Result<Tariff, TariffError> {
+        let present = file.sections();
+        for required in ["meta", "zones", "lanes"] {
+            if !present.contains(&required) {
+                return Err(schema(format!("missing section [{}]", required)));
+            }
+        }
+
+        let mut name: Option<String> = None;
+        let mut zones = ZoneMap::default();
+        let mut lane_entries: Vec<(String, String)> = Vec::new();
+        let mut scales: BTreeMap<String, RateScale> = BTreeMap::new();
+        let mut surcharges: Vec<Surcharge> = Vec::new();
+
+        for section in file.sections() {
+            match section {
+                "meta" => {
+                    for key in file.keys(section) {
+                        match key {
+                            "name" => match file.get(section, key) {
+                                Some(Value::Str(s)) => name = Some(s.clone()),
+                                _ => return Err(schema("[meta] name: expected string".into())),
+                            },
+                            other => {
+                                return Err(schema(format!("[meta] {}: unknown key", other)))
+                            }
+                        }
+                    }
+                    if name.is_none() {
+                        return Err(schema("[meta]: missing key 'name'".into()));
+                    }
+                }
+                "zones" => {
+                    for key in file.keys(section) {
+                        if key.len() != 3 || !key.chars().all(|c| c.is_ascii_uppercase()) {
+                            return Err(schema(format!("[zones] {}: bad station code", key)));
+                        }
+                        match file.get(section, key) {
+                            Some(Value::Int(z)) if (1..=9).contains(z) => {
+                                zones.insert(key, *z as u8)
+                            }
+                            Some(Value::Int(_)) => {
+                                return Err(schema(format!("[zones] {}: zone must be 1..9", key)))
+                            }
+                            _ => return Err(schema(format!("[zones] {}: expected int", key))),
+                        }
+                    }
+                }
+                "lanes" => {
+                    for key in file.keys(section) {
+                        let b = key.as_bytes();
+                        let well_formed = b.len() == 3
+                            && b[1] == b'-'
+                            && (b'1'..=b'9').contains(&b[0])
+                            && (b'1'..=b'9').contains(&b[2]);
+                        if !well_formed {
+                            return Err(schema(format!("[lanes] {}: bad lane", key)));
+                        }
+                        match file.get(section, key) {
+                            Some(Value::Str(s)) => lane_entries.push((key.to_string(), s.clone())),
+                            _ => return Err(schema(format!("[lanes] {}: expected string", key))),
+                        }
+                    }
+                }
+                s if s.starts_with("scale_") => {
+                    let scale_name = &s["scale_".len()..];
+                    if scale_name.is_empty()
+                        || !scale_name
+                            .chars()
+                            .all(|c| c.is_ascii_uppercase() || c.is_ascii_digit())
+                    {
+                        return Err(schema(format!("[{}]: bad scale name", s)));
+                    }
+                    let mut minimum: Option<Money> = None;
+                    let mut brackets: Vec<(u32, Money)> = Vec::new();
+                    for key in file.keys(s) {
+                        if key == "minimum" {
+                            match file.get(s, key) {
+                                Some(Value::Money(m)) => minimum = Some(*m),
+                                _ => {
+                                    return Err(schema(format!("[{}] {}: expected money", s, key)))
+                                }
+                            }
+                        } else if let Some(digits) = key.strip_prefix("from_") {
+                            let floor: u32 = match digits.parse() {
+                                Ok(n) => n,
+                                Err(_) => {
+                                    return Err(schema(format!(
+                                        "[{}] {}: bad bracket key",
+                                        s, key
+                                    )))
+                                }
+                            };
+                            if floor % 100 != 0 {
+                                return Err(schema(format!(
+                                    "[{}] {}: floor must be a multiple of 100",
+                                    s, key
+                                )));
+                            }
+                            match file.get(s, key) {
+                                Some(Value::Money(m)) => brackets.push((floor, *m)),
+                                _ => {
+                                    return Err(schema(format!("[{}] {}: expected money", s, key)))
+                                }
+                            }
+                        } else {
+                            return Err(schema(format!("[{}] {}: unknown key", s, key)));
+                        }
+                    }
+                    let minimum =
+                        minimum.ok_or_else(|| schema(format!("[{}]: missing key 'minimum'", s)))?;
+                    if !brackets.iter().any(|(floor, _)| *floor == 0) {
+                        return Err(schema(format!("[{}]: missing key 'from_0'", s)));
+                    }
+                    scales.insert(scale_name.to_string(), RateScale::new(minimum, brackets));
+                }
+                s if s.starts_with("surcharge_") => {
+                    let code = &s["surcharge_".len()..];
+                    if code.is_empty()
+                        || !code
+                            .chars()
+                            .all(|c| c.is_ascii_uppercase() || c.is_ascii_digit())
+                    {
+                        return Err(schema(format!("[{}]: bad surcharge code", s)));
+                    }
+                    let mut label: Option<String> = None;
+                    let mut kind_name: Option<String> = None;
+                    let mut amount: Option<&Value> = None;
+                    let mut cap: Option<Money> = None;
+                    let mut requires: Option<String> = None;
+                    for key in file.keys(s) {
+                        match key {
+                            "label" => match file.get(s, key) {
+                                Some(Value::Str(v)) => label = Some(v.clone()),
+                                _ => {
+                                    return Err(schema(format!("[{}] label: expected string", s)))
+                                }
+                            },
+                            "kind" => match file.get(s, key) {
+                                Some(Value::Str(v)) if v == "percent" || v == "flat" => {
+                                    kind_name = Some(v.clone())
+                                }
+                                Some(Value::Str(_)) => {
+                                    return Err(schema(format!(
+                                        "[{}] kind: must be 'percent' or 'flat'",
+                                        s
+                                    )))
+                                }
+                                _ => return Err(schema(format!("[{}] kind: expected string", s))),
+                            },
+                            "amount" => amount = file.get(s, key),
+                            "cap" => match file.get(s, key) {
+                                Some(Value::Money(m)) => cap = Some(*m),
+                                _ => return Err(schema(format!("[{}] cap: expected money", s))),
+                            },
+                            "requires" => match file.get(s, key) {
+                                Some(Value::Str(v)) => requires = Some(v.clone()),
+                                _ => {
+                                    return Err(schema(format!(
+                                        "[{}] requires: expected string",
+                                        s
+                                    )))
+                                }
+                            },
+                            other => return Err(schema(format!("[{}] {}: unknown key", s, other))),
+                        }
+                    }
+                    let label =
+                        label.ok_or_else(|| schema(format!("[{}]: missing key 'label'", s)))?;
+                    let kind_name =
+                        kind_name.ok_or_else(|| schema(format!("[{}]: missing key 'kind'", s)))?;
+                    let amount =
+                        amount.ok_or_else(|| schema(format!("[{}]: missing key 'amount'", s)))?;
+                    let kind = if kind_name == "percent" {
+                        match amount {
+                            Value::Percent(bp) => SurchargeKind::Percent(*bp),
+                            _ => return Err(schema(format!("[{}] amount: expected percent", s))),
+                        }
+                    } else {
+                        match amount {
+                            Value::Money(m) => SurchargeKind::Flat(*m),
+                            _ => return Err(schema(format!("[{}] amount: expected money", s))),
+                        }
+                    };
+                    surcharges.push(Surcharge {
+                        code: code.to_string(),
+                        label,
+                        kind,
+                        cap,
+                        requires,
+                    });
+                }
+                other => return Err(schema(format!("[{}]: unknown section", other))),
+            }
+        }
+
+        // Lanes can reference scales declared later in the sheet, so resolve
+        // them once every section has been walked.
+        let mut lanes = LaneTable::default();
+        for (key, scale_name) in &lane_entries {
+            if !scales.contains_key(scale_name) {
+                return Err(schema(format!(
+                    "[lanes] {}: unknown scale '{}'",
+                    key, scale_name
+                )));
+            }
+            let b = key.as_bytes();
+            lanes.insert(b[0] - b'0', b[2] - b'0', scale_name);
+        }
+
+        Ok(Tariff {
+            name: name.expect("validated above"),
+            zones,
+            lanes,
+            scales,
+            surcharges,
+        })
+    }
+}
