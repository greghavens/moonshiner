+++ b/src/zones.rs
@@ -1,2 +1,35 @@
 //! Station-to-zone map and the directional lane table (origin zone, dest
 //! zone) -> rate scale name.
+
+use std::collections::BTreeMap;
+
+#[derive(Debug, Clone, Default)]
+pub struct ZoneMap {
+    stations: BTreeMap<String, u8>,
+}
+
+impl ZoneMap {
+    pub fn insert(&mut self, station: &str, zone: u8) {
+        self.stations.insert(station.to_string(), zone);
+    }
+
+    pub fn zone(&self, station: &str) -> Option<u8> {
+        self.stations.get(station).copied()
+    }
+}
+
+/// Directional: a 1-2 lane says nothing about 2-1.
+#[derive(Debug, Clone, Default)]
+pub struct LaneTable {
+    lanes: BTreeMap<(u8, u8), String>,
+}
+
+impl LaneTable {
+    pub fn insert(&mut self, origin: u8, dest: u8, scale: &str) {
+        self.lanes.insert((origin, dest), scale.to_string());
+    }
+
+    pub fn scale(&self, origin: u8, dest: u8) -> Option<&str> {
+        self.lanes.get(&(origin, dest)).map(|s| s.as_str())
+    }
+}
