index c97505f..1723d2c 100644
--- a/src/audit.rs
+++ b/src/audit.rs
@@ -1,3 +1,116 @@
 //! Audit-trail export: renders a `Quote` as the fixed plaintext format the
 //! rating desk files with each quote — one line per applied rule, each with
 //! the running total.
+
+use std::fmt::Write;
+
+use crate::quote::Quote;
+
+/// Basis points as the shortest exact decimal: 1250 -> "12.5", 400 -> "4",
+/// 25 -> "0.25".
+fn percent(bp: u32) -> String {
+    let whole = bp / 100;
+    let frac = bp % 100;
+    if frac == 0 {
+        format!("{}", whole)
+    } else if frac % 10 == 0 {
+        format!("{}.{}", whole, frac / 10)
+    } else {
+        format!("{}.{:02}", whole, frac)
+    }
+}
+
+pub fn render(q: &Quote) -> String {
+    let mut out = String::new();
+    let _ = writeln!(
+        out,
+        "quote {} {} -> {} {} lb",
+        q.reference, q.origin, q.dest, q.weight_lbs
+    );
+    let _ = writeln!(
+        out,
+        "lane: zone {} -> zone {}, scale {}",
+        q.origin_zone, q.dest_zone, q.scale
+    );
+
+    let lh = &q.linehaul;
+    let _ = writeln!(
+        out,
+        "linehaul: {} cwt @ {}/cwt = {} | total {}",
+        lh.cwt, lh.rate, lh.base, lh.base
+    );
+    if let Some(r) = &lh.rebill {
+        let _ = writeln!(
+            out,
+            "deficit-weight: rebill at {} lb, {} cwt @ {}/cwt = {} | total {}",
+            r.lbs, r.cwt, r.rate, r.cost, r.cost
+        );
+    }
+    if lh.minimum_applied {
+        let _ = writeln!(
+            out,
+            "minimum-charge: raised to {} | total {}",
+            lh.total, lh.total
+        );
+    }
+
+    let mut running = lh.total;
+    for a in &q.surcharges {
+        if a.waived {
+            let _ = writeln!(
+                out,
+                "surcharge {}: waived by contract | total {}",
+                a.code, running
+            );
+            continue;
+        }
+        running = running.plus(a.amount);
+        match (a.percent, a.base) {
+            (Some(bp), Some(base)) => {
+                if a.capped {
+                    let _ = writeln!(
+                        out,
+                        "surcharge {} ({}% of {}, capped at {}): +{} | total {}",
+                        a.code,
+                        percent(bp),
+                        base,
+                        a.cap.expect("capped implies a cap"),
+                        a.amount,
+                        running
+                    );
+                } else {
+                    let _ = writeln!(
+                        out,
+                        "surcharge {} ({}% of {}): +{} | total {}",
+                        a.code,
+                        percent(bp),
+                        base,
+                        a.amount,
+                        running
+                    );
+                }
+            }
+            _ => {
+                if a.capped {
+                    let _ = writeln!(
+                        out,
+                        "surcharge {} (flat, capped at {}): +{} | total {}",
+                        a.code,
+                        a.cap.expect("capped implies a cap"),
+                        a.amount,
+                        running
+                    );
+                } else {
+                    let _ = writeln!(
+                        out,
+                        "surcharge {} (flat): +{} | total {}",
+                        a.code, a.amount, running
+                    );
+                }
+            }
+        }
+    }
+
+    let _ = writeln!(out, "total: {}", q.total);
+    out
+}
