+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Locale;
+import java.util.Map;
+
+/**
+ * Strict JSON parse / canonical compact write for the webhook gateway.
+ * No dependencies, exact reject positions, byte-stable output.
+ */
+public final class Json {
+
+    private Json() {}
+
+    public static JsonValue parse(String text) {
+        Parser p = new Parser(text);
+        p.skipWs();
+        JsonValue value = p.parseValue();
+        p.skipWs();
+        if (!p.atEnd()) {
+            throw p.errHere("trailing data");
+        }
+        return value;
+    }
+
+    // ------------------------------------------------------------------
+
+    private static final class Parser {
+        private final String text;
+        private int i = 0;
+        private int line = 1;
+        private int lineStart = 0;
+
+        Parser(String text) {
+            this.text = text == null ? "" : text;
+        }
+
+        boolean atEnd() {
+            return i >= text.length();
+        }
+
+        private char peek() {
+            return text.charAt(i);
+        }
+
+        private void advance() {
+            if (text.charAt(i) == '\n') {
+                line++;
+                lineStart = i + 1;
+            }
+            i++;
+        }
+
+        private int col() {
+            return i - lineStart + 1;
+        }
+
+        JsonParseException errHere(String problem) {
+            return new JsonParseException(line, col(), problem);
+        }
+
+        void skipWs() {
+            while (!atEnd()) {
+                char c = peek();
+                if (c == ' ' || c == '\t' || c == '\r' || c == '\n') {
+                    advance();
+                } else {
+                    return;
+                }
+            }
+        }
+
+        JsonValue parseValue() {
+            if (atEnd()) {
+                throw errHere("unexpected end of input");
+            }
+            char c = peek();
+            if (c == '{') {
+                return parseObject();
+            }
+            if (c == '[') {
+                return parseArray();
+            }
+            if (c == '"') {
+                return JsonValue.of(parseString());
+            }
+            if (c == '-' || (c >= '0' && c <= '9')) {
+                return parseNumber();
+            }
+            if (isAsciiLetter(c)) {
+                return parseLiteral();
+            }
+            throw errHere("unexpected character '" + c + "'");
+        }
+
+        private static boolean isAsciiLetter(char c) {
+            return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z');
+        }
+
+        private JsonValue parseLiteral() {
+            int startLine = line;
+            int startCol = col();
+            StringBuilder run = new StringBuilder();
+            while (!atEnd() && isAsciiLetter(peek())) {
+                run.append(peek());
+                advance();
+            }
+            switch (run.toString()) {
+                case "true": return JsonValue.of(true);
+                case "false": return JsonValue.of(false);
+                case "null": return JsonValue.nul();
+                default:
+                    throw new JsonParseException(startLine, startCol,
+                            "bad literal '" + run + "'");
+            }
+        }
+
+        private JsonValue parseNumber() {
+            int startLine = line;
+            int startCol = col();
+            StringBuilder run = new StringBuilder();
+            while (!atEnd()) {
+                char c = peek();
+                if ((c >= '0' && c <= '9') || c == '+' || c == '-' || c == '.'
+                        || c == 'e' || c == 'E') {
+                    run.append(c);
+                    advance();
+                } else {
+                    break;
+                }
+            }
+            String lexeme = run.toString();
+            if (!JsonValue.NUMBER_GRAMMAR.matcher(lexeme).matches()) {
+                throw new JsonParseException(startLine, startCol, "bad number '" + lexeme + "'");
+            }
+            return JsonValue.rawNumber(lexeme);
+        }
+
+        private String parseString() {
+            advance(); // opening quote
+            StringBuilder out = new StringBuilder();
+            while (true) {
+                if (atEnd()) {
+                    throw errHere("unterminated string");
+                }
+                char c = peek();
+                if (c == '"') {
+                    advance();
+                    return out.toString();
+                }
+                if (c < 0x20) {
+                    throw errHere("raw control character in string");
+                }
+                if (c == '\\') {
+                    int escLine = line;
+                    int escCol = col();
+                    advance();
+                    if (atEnd()) {
+                        throw errHere("unterminated string");
+                    }
+                    char e = peek();
+                    switch (e) {
+                        case '"': out.append('"'); advance(); break;
+                        case '\\': out.append('\\'); advance(); break;
+                        case '/': out.append('/'); advance(); break;
+                        case 'b': out.append('\b'); advance(); break;
+                        case 'f': out.append('\f'); advance(); break;
+                        case 'n': out.append('\n'); advance(); break;
+                        case 'r': out.append('\r'); advance(); break;
+                        case 't': out.append('\t'); advance(); break;
+                        case 'u':
+                            advance();
+                            out.append(readHex4(escLine, escCol));
+                            break;
+                        default:
+                            throw new JsonParseException(escLine, escCol,
+                                    "bad escape '\\" + e + "'");
+                    }
+                    continue;
+                }
+                out.append(c);
+                advance();
+            }
+        }
+
+        private char readHex4(int escLine, int escCol) {
+            if (i + 4 > text.length()) {
+                throw new JsonParseException(escLine, escCol, "bad unicode escape");
+            }
+            int code = 0;
+            for (int k = 0; k < 4; k++) {
+                int digit = Character.digit(text.charAt(i + k), 16);
+                if (digit < 0) {
+                    throw new JsonParseException(escLine, escCol, "bad unicode escape");
+                }
+                code = code * 16 + digit;
+            }
+            for (int k = 0; k < 4; k++) {
+                advance();
+            }
+            return (char) code;
+        }
+
+        private JsonValue parseObject() {
+            advance(); // '{'
+            Map<String, JsonValue> fields = new LinkedHashMap<>();
+            skipWs();
+            if (!atEnd() && peek() == '}') {
+                advance();
+                return JsonValue.object(fields);
+            }
+            while (true) {
+                skipWs();
+                if (atEnd()) {
+                    throw errHere("unexpected end of input");
+                }
+                if (peek() != '"') {
+                    throw errHere("expected string key");
+                }
+                int keyLine = line;
+                int keyCol = col();
+                String key = parseString();
+                if (fields.containsKey(key)) {
+                    throw new JsonParseException(keyLine, keyCol, "duplicate key '" + key + "'");
+                }
+                skipWs();
+                if (atEnd()) {
+                    throw errHere("unexpected end of input");
+                }
+                if (peek() != ':') {
+                    throw errHere("expected ':'");
+                }
+                advance();
+                skipWs();
+                fields.put(key, parseValue());
+                skipWs();
+                if (atEnd()) {
+                    throw errHere("unexpected end of input");
+                }
+                char c = peek();
+                if (c == ',') {
+                    advance();
+                    continue;
+                }
+                if (c == '}') {
+                    advance();
+                    return JsonValue.object(fields);
+                }
+                throw errHere("expected ',' or '}'");
+            }
+        }
+
+        private JsonValue parseArray() {
+            advance(); // '['
+            List<JsonValue> items = new ArrayList<>();
+            skipWs();
+            if (!atEnd() && peek() == ']') {
+                advance();
+                return JsonValue.array(items);
+            }
+            while (true) {
+                skipWs();
+                items.add(parseValue());
+                skipWs();
+                if (atEnd()) {
+                    throw errHere("unexpected end of input");
+                }
+                char c = peek();
+                if (c == ',') {
+                    advance();
+                    continue;
+                }
+                if (c == ']') {
+                    advance();
+                    return JsonValue.array(items);
+                }
+                throw errHere("expected ',' or ']'");
+            }
+        }
+    }
+
+    // ------------------------------------------------------------------
+
+    public static String write(JsonValue value) {
+        StringBuilder out = new StringBuilder();
+        writeValue(value, out);
+        return out.toString();
+    }
+
+    private static void writeValue(JsonValue value, StringBuilder out) {
+        switch (value.kind()) {
+            case OBJECT: {
+                out.append('{');
+                boolean first = true;
+                for (Map.Entry<String, JsonValue> e : value.fields().entrySet()) {
+                    if (!first) {
+                        out.append(',');
+                    }
+                    first = false;
+                    writeString(e.getKey(), out);
+                    out.append(':');
+                    writeValue(e.getValue(), out);
+                }
+                out.append('}');
+                break;
+            }
+            case ARRAY: {
+                out.append('[');
+                boolean first = true;
+                for (JsonValue item : value.items()) {
+                    if (!first) {
+                        out.append(',');
+                    }
+                    first = false;
+                    writeValue(item, out);
+                }
+                out.append(']');
+                break;
+            }
+            case STRING:
+                writeString(value.asString(), out);
+                break;
+            case NUMBER:
+                out.append(value.numberLexeme());
+                break;
+            case BOOL:
+                out.append(value.asBool() ? "true" : "false");
+                break;
+            case NULL:
+                out.append("null");
+                break;
+        }
+    }
+
+    private static void writeString(String s, StringBuilder out) {
+        out.append('"');
+        for (int i = 0; i < s.length(); i++) {
+            char c = s.charAt(i);
+            switch (c) {
+                case '"': out.append("\\\""); break;
+                case '\\': out.append("\\\\"); break;
+                case '\b': out.append("\\b"); break;
+                case '\f': out.append("\\f"); break;
+                case '\n': out.append("\\n"); break;
+                case '\r': out.append("\\r"); break;
+                case '\t': out.append("\\t"); break;
+                default:
+                    if (c < 0x20) {
+                        out.append(String.format(Locale.ROOT, "\\u%04x", (int) c));
+                    } else {
+                        out.append(c);
+                    }
+            }
+        }
+        out.append('"');
+    }
+}
diff --git a/JsonParseException.java b/JsonParseException.java
new file mode 100644
index 0000000..2b9c857
--- /dev/null
+++ b/JsonParseException.java
@@ -0,0 +1,22 @@
+/**
+ * A payload rejection: what went wrong and exactly where. line/col are
+ * 1-based; col counts chars from the start of the line.
+ */
+public final class JsonParseException extends RuntimeException {
+    private final int line;
+    private final int col;
+
+    public JsonParseException(int line, int col, String problem) {
+        super("line " + line + " col " + col + ": " + problem);
+        this.line = line;
+        this.col = col;
+    }
+
+    public int line() {
+        return line;
+    }
+
+    public int col() {
+        return col;
+    }
+}
