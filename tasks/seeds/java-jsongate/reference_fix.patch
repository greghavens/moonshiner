new file mode 100644
index 0000000..af78f9a
--- /dev/null
+++ b/JsonValue.java
@@ -0,0 +1,130 @@
+import java.math.BigDecimal;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.Objects;
+import java.util.regex.Pattern;
+
+/**
+ * One JSON value. Numbers carry their exact source lexeme so the writer can
+ * reproduce them byte-for-byte (the audit log is hash-chained; formatting
+ * drift would break the chain).
+ */
+public final class JsonValue {
+    public enum Kind { OBJECT, ARRAY, STRING, NUMBER, BOOL, NULL }
+
+    static final Pattern NUMBER_GRAMMAR =
+            Pattern.compile("-?(0|[1-9][0-9]*)(\\.[0-9]+)?([eE][+-]?[0-9]+)?");
+
+    private static final JsonValue TRUE = new JsonValue(Kind.BOOL, Boolean.TRUE);
+    private static final JsonValue FALSE = new JsonValue(Kind.BOOL, Boolean.FALSE);
+    private static final JsonValue NULL = new JsonValue(Kind.NULL, null);
+
+    private final Kind kind;
+    private final Object payload;
+
+    private JsonValue(Kind kind, Object payload) {
+        this.kind = kind;
+        this.payload = payload;
+    }
+
+    public Kind kind() {
+        return kind;
+    }
+
+    public String asString() {
+        want(Kind.STRING);
+        return (String) payload;
+    }
+
+    public BigDecimal asNumber() {
+        want(Kind.NUMBER);
+        return new BigDecimal((String) payload);
+    }
+
+    /** The number's exact source text. */
+    public String numberLexeme() {
+        want(Kind.NUMBER);
+        return (String) payload;
+    }
+
+    public boolean asBool() {
+        want(Kind.BOOL);
+        return (Boolean) payload;
+    }
+
+    @SuppressWarnings("unchecked")
+    public List<JsonValue> items() {
+        want(Kind.ARRAY);
+        return (List<JsonValue>) payload;
+    }
+
+    @SuppressWarnings("unchecked")
+    public Map<String, JsonValue> fields() {
+        want(Kind.OBJECT);
+        return (Map<String, JsonValue>) payload;
+    }
+
+    /** Object field by key, or null when absent. */
+    public JsonValue get(String key) {
+        want(Kind.OBJECT);
+        return fields().get(key);
+    }
+
+    private void want(Kind wanted) {
+        if (kind != wanted) {
+            throw new IllegalStateException("not " + article(wanted) + " " + wanted + ": " + kind);
+        }
+    }
+
+    private static String article(Kind kind) {
+        switch (kind) {
+            case OBJECT:
+            case ARRAY:
+                return "an";
+            default:
+                return "a";
+        }
+    }
+
+    // ------------------------------------------------------------------
+    // Builders (the gateway constructs audit entries programmatically).
+
+    public static JsonValue of(String value) {
+        return new JsonValue(Kind.STRING, Objects.requireNonNull(value, "value"));
+    }
+
+    public static JsonValue of(boolean value) {
+        return value ? TRUE : FALSE;
+    }
+
+    public static JsonValue of(long value) {
+        return new JsonValue(Kind.NUMBER, Long.toString(value));
+    }
+
+    /** A number from its exact lexeme; the lexeme must be valid JSON. */
+    public static JsonValue number(String lexeme) {
+        Objects.requireNonNull(lexeme, "lexeme");
+        if (!NUMBER_GRAMMAR.matcher(lexeme).matches()) {
+            throw new IllegalArgumentException("bad number lexeme '" + lexeme + "'");
+        }
+        return new JsonValue(Kind.NUMBER, lexeme);
+    }
+
+    public static JsonValue nul() {
+        return NULL;
+    }
+
+    public static JsonValue array(List<JsonValue> items) {
+        return new JsonValue(Kind.ARRAY, List.copyOf(items));
+    }
+
+    public static JsonValue object(Map<String, JsonValue> fields) {
+        return new JsonValue(Kind.OBJECT, new LinkedHashMap<>(fields));
+    }
+
+    /** Internal: parser-built number, already grammar-checked. */
+    static JsonValue rawNumber(String lexeme) {
+        return new JsonValue(Kind.NUMBER, lexeme);
+    }
+}
