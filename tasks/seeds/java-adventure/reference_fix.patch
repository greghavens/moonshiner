@@ -0,0 +1,136 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** A story world parsed from the plain-text room-graph format. */
+public final class World {
+
+    private final Map<String, Room> rooms = new LinkedHashMap<>();
+    private final Map<String, Item> items = new LinkedHashMap<>();
+    private Room start;
+    private Room goal;
+
+    private World() {}
+
+    public Map<String, Room> rooms() {
+        return Map.copyOf(rooms);
+    }
+
+    public Room room(String id) {
+        Room r = rooms.get(id);
+        if (r == null) throw new IllegalArgumentException("no such room: " + id);
+        return r;
+    }
+
+    Item item(String name) {
+        return items.get(name);
+    }
+
+    Map<String, Item> allItems() {
+        return items;
+    }
+
+    Room start() {
+        return start;
+    }
+
+    Room goal() {
+        return goal;
+    }
+
+    public static World parse(String text) {
+        World w = new World();
+        List<String[]> body = new ArrayList<>();
+        // pass 1: declare rooms so references can point forward
+        for (String raw : text.split("\n", -1)) {
+            String line = raw.trim();
+            if (line.isEmpty() || line.startsWith("#")) continue;
+            String[] tok = line.split("\\s+");
+            if (tok[0].equals("room")) {
+                if (tok.length < 3) throw new IllegalArgumentException("bad room line: " + line);
+                if (w.rooms.containsKey(tok[1])) {
+                    throw new IllegalArgumentException("duplicate room: " + tok[1]);
+                }
+                w.rooms.put(tok[1], new Room(tok[1], join(tok, 2)));
+            } else {
+                body.add(tok);
+            }
+        }
+        // pass 2: everything else
+        List<String[]> doors = new ArrayList<>();
+        for (String[] tok : body) {
+            switch (tok[0]) {
+                case "desc" -> {
+                    if (tok.length < 3) throw new IllegalArgumentException("bad desc line");
+                    Room r = w.room(tok[1]);
+                    if (r.description != null) {
+                        throw new IllegalArgumentException("duplicate desc for " + tok[1]);
+                    }
+                    r.description = join(tok, 2);
+                }
+                case "exit" -> {
+                    if (tok.length != 4) throw new IllegalArgumentException("bad exit line");
+                    w.addPassage(tok[1], tok[2], tok[3], null);
+                }
+                case "door" -> {
+                    if (tok.length != 5) throw new IllegalArgumentException("bad door line");
+                    w.addPassage(tok[1], tok[2], tok[3], tok[4]);
+                    doors.add(tok);
+                }
+                case "item" -> {
+                    if (tok.length != 3) throw new IllegalArgumentException("bad item line");
+                    Room r = w.room(tok[1]);
+                    if (w.items.containsKey(tok[2])) {
+                        throw new IllegalArgumentException("duplicate item: " + tok[2]);
+                    }
+                    Item it = new Item(tok[2]);
+                    w.items.put(tok[2], it);
+                    r.items.add(it);
+                }
+                case "start" -> {
+                    if (tok.length != 2 || w.start != null) {
+                        throw new IllegalArgumentException("bad start line");
+                    }
+                    w.start = w.room(tok[1]);
+                }
+                case "goal" -> {
+                    if (tok.length != 2 || w.goal != null) {
+                        throw new IllegalArgumentException("bad goal line");
+                    }
+                    w.goal = w.room(tok[1]);
+                }
+                default -> throw new IllegalArgumentException("unknown line kind: " + tok[0]);
+            }
+        }
+        if (w.start == null) throw new IllegalArgumentException("world has no start");
+        if (w.goal == null) throw new IllegalArgumentException("world has no goal");
+        for (Room r : w.rooms.values()) {
+            if (r.description == null) {
+                throw new IllegalArgumentException("room " + r.id() + " has no desc");
+            }
+        }
+        for (String[] tok : doors) {
+            if (!w.items.containsKey(tok[4])) {
+                throw new IllegalArgumentException("door key does not exist: " + tok[4]);
+            }
+        }
+        return w;
+    }
+
+    private void addPassage(String from, String dir, String to, String key) {
+        if (!Room.COMPASS.contains(dir)) {
+            throw new IllegalArgumentException("bad direction: " + dir);
+        }
+        Room src = room(from);
+        Room dst = room(to);
+        if (src.passages.containsKey(dir)) {
+            throw new IllegalArgumentException(from + " already has a passage " + dir);
+        }
+        src.passages.put(dir, new Room.Passage(dst, key));
+    }
+
+    private static String join(String[] tok, int from) {
+        return String.join(" ", java.util.Arrays.asList(tok).subList(from, tok.length));
+    }
+}
