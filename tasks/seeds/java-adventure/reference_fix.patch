@@ -0,0 +1,25 @@
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+
+/** The reader's avatar: where they stand and what they carry. */
+public final class Player {
+
+    Room location;
+    final List<Item> inventory = new ArrayList<>();
+
+    Player(Room start) {
+        this.location = start;
+    }
+
+    public Room location() {
+        return location;
+    }
+
+    /** Carried items, sorted by name. */
+    public List<Item> inventory() {
+        List<Item> copy = new ArrayList<>(inventory);
+        copy.sort(Comparator.comparing(Item::name));
+        return copy;
+    }
+}
