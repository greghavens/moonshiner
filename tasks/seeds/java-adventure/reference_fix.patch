@@ -0,0 +1,57 @@
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** One location: title, description, portable items and passages out. */
+public final class Room {
+
+    static final List<String> COMPASS = List.of("north", "south", "east", "west");
+
+    /** A passage to another room; {@code key} is null for an open exit. */
+    record Passage(Room destination, String key) {}
+
+    private final String id;
+    private final String title;
+    String description;
+    final Map<String, Passage> passages = new LinkedHashMap<>();
+    final List<Item> items = new ArrayList<>();
+
+    Room(String id, String title) {
+        this.id = id;
+        this.title = title;
+    }
+
+    public String id() {
+        return id;
+    }
+
+    public String title() {
+        return title;
+    }
+
+    public String description() {
+        return description;
+    }
+
+    /** Items currently lying here, sorted by name. */
+    public List<Item> items() {
+        List<Item> copy = new ArrayList<>(items);
+        copy.sort(Comparator.comparing(Item::name));
+        return copy;
+    }
+
+    /** Directions leading out of this room, in compass order (N, S, E, W). */
+    public List<String> exitDirections() {
+        List<String> dirs = new ArrayList<>();
+        for (String d : COMPASS) {
+            if (passages.containsKey(d)) dirs.add(d);
+        }
+        return dirs;
+    }
+
+    Passage passage(String dir) {
+        return passages.get(dir);
+    }
+}
