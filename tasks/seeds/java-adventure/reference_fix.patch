+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.TreeMap;
+import java.util.TreeSet;
+
+/** Runs one reader's session through a story world. */
+public final class Engine {
+
+    private final World world;
+    private final Player player;
+    private final TreeSet<String> opened = new TreeSet<>(); // "room/dir" of unlocked doors
+    private boolean finished;
+
+    public Engine(World world) {
+        this.world = world;
+        this.player = new Player(world.start());
+    }
+
+    public Player player() {
+        return player;
+    }
+
+    public boolean finished() {
+        return finished;
+    }
+
+    /** Executes one command and returns the story's reply. */
+    public String exec(String command) {
+        if (finished) return "The story is over.";
+        String[] tok = command.trim().split("\\s+");
+        if (tok.length == 1 && tok[0].equals("look")) return look(player.location);
+        if (tok.length == 1 && tok[0].equals("inventory")) return inventory();
+        if (tok.length == 2) {
+            switch (tok[0]) {
+                case "go": return go(tok[1]);
+                case "take": return take(tok[1]);
+                case "drop": return drop(tok[1]);
+                case "unlock": return unlock(tok[1]);
+                default: break;
+            }
+        }
+        return "I don't understand.";
+    }
+
+    private String look(Room room) {
+        StringBuilder sb = new StringBuilder();
+        sb.append(room.title()).append('\n').append(room.description());
+        List<Item> here = room.items();
+        if (!here.isEmpty()) {
+            sb.append("\nYou see: ").append(names(here)).append('.');
+        }
+        List<String> exits = new ArrayList<>();
+        for (String dir : room.exitDirections()) {
+            exits.add(locked(room, dir) ? dir + " (locked)" : dir);
+        }
+        sb.append("\nExits: ").append(exits.isEmpty() ? "none" : String.join(", ", exits)).append('.');
+        return sb.toString();
+    }
+
+    private boolean locked(Room room, String dir) {
+        Room.Passage p = room.passage(dir);
+        return p != null && p.key() != null && !opened.contains(room.id() + "/" + dir);
+    }
+
+    private String go(String dir) {
+        Room.Passage p = player.location.passage(dir);
+        if (p == null) return "You can't go " + dir + ".";
+        if (locked(player.location, dir)) return "The door to the " + dir + " is locked.";
+        player.location = p.destination();
+        String block = look(player.location);
+        if (player.location == world.goal()) {
+            finished = true;
+            block += "\n*** You made it! ***";
+        }
+        return block;
+    }
+
+    private String take(String name) {
+        for (Item it : player.location.items) {
+            if (it.name().equals(name)) {
+                player.location.items.remove(it);
+                player.inventory.add(it);
+                return "Taken.";
+            }
+        }
+        return "There is no " + name + " here.";
+    }
+
+    private String drop(String name) {
+        for (Item it : player.inventory) {
+            if (it.name().equals(name)) {
+                player.inventory.remove(it);
+                player.location.items.add(it);
+                return "Dropped.";
+            }
+        }
+        return "You don't have " + name + ".";
+    }
+
+    private String unlock(String dir) {
+        if (!locked(player.location, dir)) {
+            return "There is no locked door to the " + dir + ".";
+        }
+        String key = player.location.passage(dir).key();
+        for (Item it : player.inventory) {
+            if (it.name().equals(key)) {
+                opened.add(player.location.id() + "/" + dir);
+                return "You unlock the door with " + key + ".";
+            }
+        }
+        return "You need " + key + ".";
+    }
+
+    private String inventory() {
+        List<Item> pack = player.inventory();
+        if (pack.isEmpty()) return "You carry nothing.";
+        return "You carry: " + names(pack) + ".";
+    }
+
+    private static String names(List<Item> items) {
+        List<String> n = new ArrayList<>();
+        for (Item it : items) n.add(it.name());
+        return String.join(", ", n);
+    }
+
+    /** Serializes the session to the pinned state string. */
+    public String save() {
+        if (finished) throw new IllegalStateException("the story is over");
+        StringBuilder sb = new StringBuilder();
+        sb.append("loc=").append(player.location.id());
+        List<String> inv = new ArrayList<>();
+        for (Item it : player.inventory()) inv.add(it.name());
+        sb.append(";inv=").append(String.join(",", inv));
+        sb.append(";open=").append(String.join(",", opened));
+        TreeMap<String, Room> sorted = new TreeMap<>(world.rooms());
+        List<String> roomBits = new ArrayList<>();
+        for (Room r : sorted.values()) {
+            List<String> here = new ArrayList<>();
+            for (Item it : r.items()) here.add(it.name());
+            roomBits.add(r.id() + ":" + String.join("+", here));
+        }
+        sb.append(";rooms=").append(String.join(",", roomBits));
+        return sb.toString();
+    }
+
+    /** Rebuilds a session from a state string, validating item conservation. */
+    public static Engine restore(World world, String state) {
+        String[] parts = state.split(";", -1);
+        if (parts.length != 4 || !parts[0].startsWith("loc=") || !parts[1].startsWith("inv=")
+                || !parts[2].startsWith("open=") || !parts[3].startsWith("rooms=")) {
+            throw new IllegalArgumentException("bad state string");
+        }
+        Engine e = new Engine(world);
+        e.player.location = world.room(parts[0].substring(4));
+
+        List<String> seen = new ArrayList<>();
+        e.player.inventory.clear();
+        for (String name : split(parts[1].substring(4), ",")) {
+            Item it = world.item(name);
+            if (it == null) throw new IllegalArgumentException("no such item: " + name);
+            e.player.inventory.add(it);
+            seen.add(name);
+        }
+
+        for (Room r : world.rooms().values()) r.items.clear();
+        String roomsPart = parts[3].substring(6);
+        List<String> covered = new ArrayList<>();
+        for (String bit : split(roomsPart, ",")) {
+            int colon = bit.indexOf(':');
+            if (colon < 0) throw new IllegalArgumentException("bad rooms entry: " + bit);
+            Room r = world.room(bit.substring(0, colon));
+            covered.add(r.id());
+            for (String name : split(bit.substring(colon + 1), "\\+")) {
+                Item it = world.item(name);
+                if (it == null) throw new IllegalArgumentException("no such item: " + name);
+                r.items.add(it);
+                seen.add(name);
+            }
+        }
+        List<String> all = new ArrayList<>(world.rooms().keySet());
+        covered.sort(Comparator.naturalOrder());
+        all.sort(Comparator.naturalOrder());
+        if (!covered.equals(all)) {
+            throw new IllegalArgumentException("rooms list must cover every room exactly once");
+        }
+        seen.sort(Comparator.naturalOrder());
+        List<String> expected = new ArrayList<>(world.allItems().keySet());
+        expected.sort(Comparator.naturalOrder());
+        if (!seen.equals(expected)) {
+            throw new IllegalArgumentException("every item must appear exactly once");
+        }
+
+        for (String entry : split(parts[2].substring(5), ",")) {
+            int slash = entry.indexOf('/');
+            if (slash < 0) throw new IllegalArgumentException("bad open entry: " + entry);
+            Room r = world.room(entry.substring(0, slash));
+            Room.Passage p = r.passage(entry.substring(slash + 1));
+            if (p == null || p.key() == null) {
+                throw new IllegalArgumentException("no door at " + entry);
+            }
+            e.opened.add(entry);
+        }
+        return e;
+    }
+
+    private static List<String> split(String s, String sep) {
+        List<String> out = new ArrayList<>();
+        if (s.isEmpty()) return out;
+        for (String bit : s.split(sep, -1)) {
+            if (bit.isEmpty()) throw new IllegalArgumentException("empty entry in state string");
+            out.add(bit);
+        }
+        return out;
+    }
+}
