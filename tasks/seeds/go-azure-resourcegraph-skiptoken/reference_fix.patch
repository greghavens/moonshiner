+package rgexport
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"time"
+)
+
+// Client executes paginated Resource Graph queries.
+type Client struct {
+	baseURL            string
+	token              string
+	http               *http.Client
+	sleep              func(time.Duration)
+	maxThrottleRetries int
+}
+
+func NewClient(cfg Config) *Client {
+	httpClient := cfg.HTTPClient
+	if httpClient == nil {
+		httpClient = http.DefaultClient
+	}
+	sleep := cfg.Sleep
+	if sleep == nil {
+		sleep = time.Sleep
+	}
+	return &Client{
+		baseURL:            cfg.BaseURL,
+		token:              cfg.Token,
+		http:               httpClient,
+		sleep:              sleep,
+		maxThrottleRetries: cfg.MaxThrottleRetries,
+	}
+}
+
+// QueryAll runs the query and follows $skipToken until the listing is
+// complete. On ErrRepeatedSkipToken the partial Report is returned alongside
+// the error so callers keep what was already fetched.
+func (c *Client) QueryAll(ctx context.Context, q Query) (*Report, error) {
+	report := &Report{}
+	sentToken := ""
+
+	for {
+		request := queryRequest{
+			Query:         q.Query,
+			Subscriptions: q.Subscriptions,
+			Options: queryRequestOptions{
+				Top:          q.PageSize,
+				SkipToken:    sentToken,
+				ResultFormat: resultFormat,
+			},
+		}
+		page, header, err := c.postPage(ctx, request)
+		if err != nil {
+			return nil, err
+		}
+
+		report.Rows = append(report.Rows, page.Data...)
+		report.Pages++
+		report.TotalRecords = page.TotalRecords
+		if page.ResultTruncated == "true" {
+			report.Truncated = true
+		}
+
+		if page.SkipToken == "" {
+			return report, nil
+		}
+		if page.SkipToken == sentToken {
+			return report, fmt.Errorf("after page %d: %w", report.Pages, ErrRepeatedSkipToken)
+		}
+		sentToken = page.SkipToken
+
+		// More pages coming: honor the documented quota headers before the
+		// next call instead of burning the window into a 429.
+		if quotaExhausted(header) {
+			if reset, ok := quotaResetDelay(header); ok {
+				c.sleep(reset)
+				report.QuotaWaits++
+			}
+		}
+	}
+}
+
+func (c *Client) postPage(ctx context.Context, request queryRequest) (*queryResponse, http.Header, error) {
+	body, err := json.Marshal(request)
+	if err != nil {
+		return nil, nil, fmt.Errorf("encoding query request: %w", err)
+	}
+
+	throttleRetries := 0
+	for {
+		status, header, raw, err := c.roundTrip(ctx, body)
+		if err != nil {
+			return nil, nil, err
+		}
+		if status == http.StatusOK {
+			var page queryResponse
+			if err := json.Unmarshal(raw, &page); err != nil {
+				return nil, nil, fmt.Errorf("decoding query response: %w", err)
+			}
+			return &page, header, nil
+		}
+
+		graphErr := parseGraphError(status, raw)
+		if status == http.StatusTooManyRequests && throttleRetries < c.maxThrottleRetries {
+			throttleRetries++
+			c.sleep(throttleDelay(header))
+			continue
+		}
+		return nil, nil, graphErr
+	}
+}
+
+func (c *Client) roundTrip(ctx context.Context, body []byte) (int, http.Header, []byte, error) {
+	url := c.baseURL + resourcePath + "?api-version=" + apiVersion
+	request, err := http.NewRequestWithContext(ctx, http.MethodPost, url, bytes.NewReader(body))
+	if err != nil {
+		return 0, nil, nil, fmt.Errorf("building request: %w", err)
+	}
+	request.Header.Set("Authorization", "Bearer "+c.token)
+	request.Header.Set("Content-Type", "application/json")
+
+	response, err := c.http.Do(request)
+	if err != nil {
+		return 0, nil, nil, fmt.Errorf("calling resource graph: %w", err)
+	}
+	defer response.Body.Close()
+	raw, err := io.ReadAll(response.Body)
+	if err != nil {
+		return 0, nil, nil, fmt.Errorf("reading response: %w", err)
+	}
+	return response.StatusCode, response.Header, raw, nil
+}
