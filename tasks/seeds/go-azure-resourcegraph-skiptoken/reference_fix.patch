new file mode 100644
index 0000000..793e4c6
--- /dev/null
+++ b/types.go
@@ -0,0 +1,57 @@
+// Package rgexport exports Azure Resource Graph query results with full
+// $skipToken pagination, quota-aware pacing, and bounded 429 retries.
+package rgexport
+
+import (
+	"errors"
+	"fmt"
+	"net/http"
+	"time"
+)
+
+// ErrRepeatedSkipToken reports a continuation loop: the service (or something
+// between us and it) handed back the same $skipToken we just sent.
+var ErrRepeatedSkipToken = errors.New("resource graph returned the $skipToken that was just sent")
+
+// Config wires the client. Sleep is injected so tests never really wait.
+type Config struct {
+	BaseURL            string
+	Token              string
+	HTTPClient         *http.Client
+	Sleep              func(time.Duration)
+	MaxThrottleRetries int
+}
+
+// Query is one export request.
+type Query struct {
+	Query         string
+	Subscriptions []string
+	PageSize      int // options.$top per page; 0 leaves the service default
+}
+
+// Report accumulates every page of a query.
+type Report struct {
+	Rows         []map[string]any
+	TotalRecords int64
+	Truncated    bool
+	Pages        int
+	QuotaWaits   int
+}
+
+// GraphErrorDetail is one entry of the documented error details list.
+type GraphErrorDetail struct {
+	Code    string `json:"code"`
+	Message string `json:"message"`
+}
+
+// GraphError is a non-200 Resource Graph response.
+type GraphError struct {
+	StatusCode int
+	Code       string
+	Message    string
+	Details    []GraphErrorDetail
+}
+
+func (e *GraphError) Error() string {
+	return fmt.Sprintf("resource graph request failed with %d %s: %s", e.StatusCode, e.Code, e.Message)
+}
