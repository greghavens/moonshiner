@@ -0,0 +1,94 @@
+package rgexport
+
+import (
+	"encoding/json"
+	"net/http"
+	"strconv"
+	"strings"
+	"time"
+)
+
+const (
+	apiVersion   = "2024-04-01"
+	resourcePath = "/providers/Microsoft.ResourceGraph/resources"
+	resultFormat = "objectArray"
+
+	headerQuotaRemaining  = "x-ms-user-quota-remaining"
+	headerQuotaResetsAfter = "x-ms-user-quota-resets-after"
+)
+
+type queryRequestOptions struct {
+	Top          int    `json:"$top,omitempty"`
+	SkipToken    string `json:"$skipToken,omitempty"`
+	ResultFormat string `json:"resultFormat"`
+}
+
+type queryRequest struct {
+	Query         string              `json:"query"`
+	Subscriptions []string            `json:"subscriptions"`
+	Options       queryRequestOptions `json:"options"`
+}
+
+type queryResponse struct {
+	Count           int64            `json:"count"`
+	TotalRecords    int64            `json:"totalRecords"`
+	Data            []map[string]any `json:"data"`
+	ResultTruncated string           `json:"resultTruncated"` // string enum "true"/"false"
+	SkipToken       string           `json:"$skipToken"`
+}
+
+type errorEnvelope struct {
+	Error struct {
+		Code    string             `json:"code"`
+		Message string             `json:"message"`
+		Details []GraphErrorDetail `json:"details"`
+	} `json:"error"`
+}
+
+func parseGraphError(status int, raw []byte) *GraphError {
+	var envelope errorEnvelope
+	_ = json.Unmarshal(raw, &envelope)
+	return &GraphError{
+		StatusCode: status,
+		Code:       envelope.Error.Code,
+		Message:    envelope.Error.Message,
+		Details:    envelope.Error.Details,
+	}
+}
+
+// quotaExhausted reports whether the response says the caller's query quota
+// for the current window is used up.
+func quotaExhausted(header http.Header) bool {
+	return header.Get(headerQuotaRemaining) == "0"
+}
+
+// quotaResetDelay parses the hh:mm:ss x-ms-user-quota-resets-after header.
+func quotaResetDelay(header http.Header) (time.Duration, bool) {
+	raw := header.Get(headerQuotaResetsAfter)
+	parts := strings.Split(raw, ":")
+	if len(parts) != 3 {
+		return 0, false
+	}
+	var total time.Duration
+	units := []time.Duration{time.Hour, time.Minute, time.Second}
+	for i, part := range parts {
+		n, err := strconv.Atoi(part)
+		if err != nil || n < 0 {
+			return 0, false
+		}
+		total += time.Duration(n) * units[i]
+	}
+	return total, true
+}
+
+// throttleDelay picks the wait before retrying a 429: Retry-After seconds
+// when present, otherwise the quota reset window, otherwise one second.
+func throttleDelay(header http.Header) time.Duration {
+	if seconds, err := strconv.Atoi(header.Get("Retry-After")); err == nil && seconds >= 0 {
+		return time.Duration(seconds) * time.Second
+	}
+	if reset, ok := quotaResetDelay(header); ok {
+		return reset
+	}
+	return time.Second
+}
