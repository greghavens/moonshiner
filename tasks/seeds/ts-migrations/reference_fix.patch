--- /dev/null
+++ b/planner.ts
@@ -0,0 +1,31 @@
+export type Step = { version: number; direction: 'up' | 'down' };
+
+/** The versions a state file may legally point at: 0 or any defined version. */
+export function validateVersions(versions: number[]): Set<number> {
+  const seen = new Set<number>();
+  for (const v of versions) {
+    if (!Number.isInteger(v) || v < 1) {
+      throw new RangeError(`versions must be positive integers, got ${v}`);
+    }
+    if (seen.has(v)) throw new Error(`duplicate version ${v}`);
+    seen.add(v);
+  }
+  return seen;
+}
+
+export function plan(current: number, target: number, versions: number[]): Step[] {
+  const known = validateVersions(versions);
+  for (const v of [current, target]) {
+    if (v !== 0 && !known.has(v)) throw new RangeError(`unknown version ${v}`);
+  }
+  const ordered = [...known].sort((a, b) => a - b);
+  if (target >= current) {
+    return ordered
+      .filter((v) => v > current && v <= target)
+      .map((version) => ({ version, direction: 'up' as const }));
+  }
+  return ordered
+    .filter((v) => v > target && v <= current)
+    .reverse()
+    .map((version) => ({ version, direction: 'down' as const }));
+}
