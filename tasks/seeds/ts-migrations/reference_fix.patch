index 0000000..96d6031
--- /dev/null
+++ b/ops.ts
@@ -0,0 +1,69 @@
+// Data-only migration ops applied to a JSON document. Every op returns a new
+// document; the input is never mutated.
+
+export type Op =
+  | { set: { path: string; value: unknown } }
+  | { unset: { path: string } }
+  | { rename: { from: string; to: string } };
+
+export type Doc = Record<string, unknown>;
+
+function isObject(v: unknown): v is Doc {
+  return typeof v === 'object' && v !== null && !Array.isArray(v);
+}
+
+/** Walk to the parent of the last path segment, creating objects on the way. */
+function ensureParent(doc: Doc, path: string): { parent: Doc; key: string } {
+  const parts = path.split('.');
+  let node: Doc = doc;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const key = parts[i];
+    if (!(key in node)) node[key] = {};
+    const next = node[key];
+    if (!isObject(next)) {
+      throw new Error(`"${parts.slice(0, i + 1).join('.')}" is not an object`);
+    }
+    node = next;
+  }
+  return { parent: node, key: parts[parts.length - 1] };
+}
+
+/** Locate an existing path without creating anything. */
+function locate(doc: Doc, path: string): { parent: Doc; key: string } | null {
+  const parts = path.split('.');
+  let node: Doc = doc;
+  for (let i = 0; i < parts.length - 1; i++) {
+    const next = node[parts[i]];
+    if (!isObject(next)) return null;
+    node = next;
+  }
+  const key = parts[parts.length - 1];
+  return Object.prototype.hasOwnProperty.call(node, key) ? { parent: node, key } : null;
+}
+
+export function applyOp(doc: Doc, op: Op): Doc {
+  const next = structuredClone(doc);
+  if ('set' in op) {
+    const { parent, key } = ensureParent(next, op.set.path);
+    parent[key] = op.set.value;
+    return next;
+  }
+  if ('unset' in op) {
+    const found = locate(next, op.unset.path);
+    if (!found) throw new Error(`no such path "${op.unset.path}"`);
+    delete found.parent[found.key];
+    return next;
+  }
+  if ('rename' in op) {
+    const { from, to } = op.rename;
+    const source = locate(next, from);
+    if (!source) throw new Error(`no such path "${from}"`);
+    if (locate(next, to)) throw new Error(`"${to}" already exists`);
+    const value = source.parent[source.key];
+    delete source.parent[source.key];
+    const { parent, key } = ensureParent(next, to);
+    parent[key] = value;
+    return next;
+  }
+  throw new Error(`unknown op ${JSON.stringify(op)}`);
+}
