@@ -0,0 +1,65 @@
+// File layer: everything lives in the current working directory.
+
+import { existsSync, readFileSync, writeFileSync } from 'node:fs';
+import type { Doc, Op } from './ops.ts';
+import { validateVersions } from './planner.ts';
+
+export type Migration = { version: number; name: string; up: Op[]; down: Op[] };
+export type State = { version: number; dirty: boolean };
+
+export const MIGRATIONS_FILE = 'migrations.json';
+export const DB_FILE = 'db.json';
+export const STATE_FILE = 'migrate-state.json';
+
+/** Thrown for user-facing failures; `exitCode` maps straight to process.exit. */
+export class CliError extends Error {
+  exitCode: number;
+
+  constructor(exitCode: number, message: string) {
+    super(message);
+    this.exitCode = exitCode;
+  }
+}
+
+export function loadMigrations(): Migration[] {
+  if (!existsSync(MIGRATIONS_FILE)) {
+    throw new CliError(2, 'no migrations.json in current directory');
+  }
+  let raw: unknown;
+  try {
+    raw = JSON.parse(readFileSync(MIGRATIONS_FILE, 'utf8'));
+  } catch (e) {
+    throw new CliError(2, `invalid migrations: ${(e as Error).message}`);
+  }
+  if (!Array.isArray(raw)) throw new CliError(2, 'invalid migrations: expected an array');
+  const migrations = raw as Migration[];
+  for (const m of migrations) {
+    if (typeof m.name !== 'string' || !Array.isArray(m.up) || !Array.isArray(m.down)) {
+      throw new CliError(2, `invalid migrations: bad entry ${JSON.stringify(m)}`);
+    }
+  }
+  try {
+    validateVersions(migrations.map((m) => m.version));
+  } catch (e) {
+    throw new CliError(2, `invalid migrations: ${(e as Error).message}`);
+  }
+  return [...migrations].sort((a, b) => a.version - b.version);
+}
+
+export function loadState(): State {
+  if (!existsSync(STATE_FILE)) return { version: 0, dirty: false };
+  return JSON.parse(readFileSync(STATE_FILE, 'utf8')) as State;
+}
+
+export function saveState(state: State): void {
+  writeFileSync(STATE_FILE, JSON.stringify(state, null, 2) + '\n');
+}
+
+export function loadDb(): Doc {
+  if (!existsSync(DB_FILE)) return {};
+  return JSON.parse(readFileSync(DB_FILE, 'utf8')) as Doc;
+}
+
+export function saveDb(db: Doc): void {
+  writeFileSync(DB_FILE, JSON.stringify(db, null, 2) + '\n');
+}
