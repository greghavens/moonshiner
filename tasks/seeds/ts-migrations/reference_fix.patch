+++ b/cli.ts
@@ -0,0 +1,113 @@
+import { applyOp } from './ops.ts';
+import { plan, type Step } from './planner.ts';
+import {
+  CliError,
+  loadDb,
+  loadMigrations,
+  loadState,
+  saveDb,
+  saveState,
+  type Migration,
+} from './store.ts';
+
+const USAGE = 'usage: node cli.ts <status | up | down | to <version> | force <version>>';
+
+function main(argv: string[]): void {
+  const [command, arg] = argv;
+  const migrations = ((): Migration[] => {
+    switch (command) {
+      case 'status':
+      case 'up':
+      case 'down':
+        if (arg !== undefined) throw new CliError(2, USAGE);
+        return loadMigrations();
+      case 'to':
+      case 'force':
+        if (arg === undefined) throw new CliError(2, USAGE);
+        return loadMigrations();
+      default:
+        throw new CliError(2, USAGE);
+    }
+  })();
+
+  const versions = migrations.map((m) => m.version);
+  const state = loadState();
+
+  if (command === 'status') {
+    const pending = versions.filter((v) => v > state.version).length;
+    console.log(`version: ${state.version}${state.dirty ? ' (dirty)' : ''}`);
+    console.log(`pending: ${pending}`);
+    return;
+  }
+
+  if (command === 'force') {
+    const target = parseVersion(arg, versions);
+    saveState({ version: target, dirty: false });
+    console.log(`forced to ${target}`);
+    return;
+  }
+
+  // up / down / to mutate the database: refuse while dirty.
+  if (state.dirty) {
+    throw new CliError(3, `dirty state at version ${state.version}; repair db.json, then run force <version>`);
+  }
+
+  let target: number;
+  if (command === 'up') {
+    target = versions.length > 0 ? Math.max(state.version, ...versions) : state.version;
+  } else if (command === 'down') {
+    target = Math.max(0, ...versions.filter((v) => v < state.version));
+  } else {
+    target = parseVersion(arg, versions);
+  }
+
+  const steps = plan(state.version, target, versions);
+  if (steps.length === 0) {
+    console.log('nothing to do');
+    return;
+  }
+
+  const byVersion = new Map(migrations.map((m) => [m.version, m]));
+  for (const step of steps) {
+    runMigration(byVersion.get(step.version)!, step, versions);
+  }
+}
+
+function parseVersion(arg: string, versions: number[]): number {
+  const n = Number(arg);
+  if (!Number.isInteger(n) || (n !== 0 && !versions.includes(n))) {
+    throw new CliError(2, `unknown version ${arg}`);
+  }
+  return n;
+}
+
+/** Apply one migration op-by-op, persisting after every op (DDL-style). */
+function runMigration(migration: Migration, step: Step, versions: number[]): void {
+  const ops = step.direction === 'up' ? migration.up : migration.down;
+  let db = loadDb();
+  for (const op of ops) {
+    try {
+      db = applyOp(db, op);
+    } catch (e) {
+      saveState({ version: migration.version, dirty: true });
+      throw new CliError(1, `migration ${migration.version} ${migration.name} failed: ${(e as Error).message}`);
+    }
+    saveDb(db);
+  }
+  const landedAt =
+    step.direction === 'up'
+      ? migration.version
+      : Math.max(0, ...versions.filter((v) => v < migration.version));
+  saveState({ version: landedAt, dirty: false });
+  console.log(`${step.direction} ${migration.version} ${migration.name}`);
+}
+
+try {
+  main(process.argv.slice(2));
+} catch (e) {
+  if (e instanceof CliError) {
+    process.stderr.write(e.message + '\n');
+    process.exit(e.exitCode);
+  }
+  throw e;
+}
