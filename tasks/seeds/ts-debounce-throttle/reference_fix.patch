+export interface TimerHost {
+  setTimeout(fn: () => void, ms: number): unknown;
+  clearTimeout(id: unknown): void;
+}
+
+export interface RateOptions {
+  leading?: boolean;
+  trailing?: boolean;
+  timers?: TimerHost;
+}
+
+export interface Limited {
+  (...args: unknown[]): void;
+  cancel(): void;
+  flush(): void;
+  pending(): boolean;
+}
+
+const globalTimers: TimerHost = {
+  setTimeout: (fn, ms) => setTimeout(fn, ms),
+  clearTimeout: (id) => clearTimeout(id as Parameters<typeof clearTimeout>[0]),
+};
+
+type Callback = (...args: unknown[]) => void;
+
+export function debounce(fn: Callback, waitMs: number, opts: RateOptions = {}): Limited {
+  const { leading = false, trailing = true, timers = globalTimers } = opts;
+  let timer: unknown = null;
+  let pendingArgs: unknown[] | null = null;
+
+  const onTimer = (): void => {
+    timer = null;
+    const args = pendingArgs;
+    pendingArgs = null;
+    if (trailing && args) fn(...args);
+  };
+
+  const wrapped = (...args: unknown[]): void => {
+    const burstStart = timer === null;
+    if (timer !== null) timers.clearTimeout(timer);
+    if (burstStart && leading) {
+      pendingArgs = null;
+      fn(...args);
+    } else {
+      pendingArgs = args;
+    }
+    timer = timers.setTimeout(onTimer, waitMs);
+  };
+
+  wrapped.cancel = (): void => {
+    if (timer !== null) timers.clearTimeout(timer);
+    timer = null;
+    pendingArgs = null;
+  };
+
+  wrapped.flush = (): void => {
+    if (timer !== null && trailing && pendingArgs) {
+      timers.clearTimeout(timer);
+      onTimer();
+    }
+  };
+
+  wrapped.pending = (): boolean => timer !== null;
+
+  return wrapped;
+}
+
+export function throttle(fn: Callback, intervalMs: number, opts: RateOptions = {}): Limited {
+  const { leading = true, trailing = true, timers = globalTimers } = opts;
+  let timer: unknown = null;
+  let pendingArgs: unknown[] | null = null;
+
+  const onTimer = (): void => {
+    timer = null;
+    const args = pendingArgs;
+    pendingArgs = null;
+    if (trailing && args) {
+      fn(...args);
+      // A trailing invocation counts against the rate: open a new window.
+      timer = timers.setTimeout(onTimer, intervalMs);
+    }
+  };
+
+  const wrapped = (...args: unknown[]): void => {
+    if (timer === null) {
+      if (leading) {
+        fn(...args);
+      } else {
+        pendingArgs = args;
+      }
+      timer = timers.setTimeout(onTimer, intervalMs);
+    } else {
+      pendingArgs = args;
+    }
+  };
+
+  wrapped.cancel = (): void => {
+    if (timer !== null) timers.clearTimeout(timer);
+    timer = null;
+    pendingArgs = null;
+  };
+
+  wrapped.flush = (): void => {
+    if (trailing && pendingArgs) {
+      if (timer !== null) timers.clearTimeout(timer);
+      timer = null;
+      const args = pendingArgs;
+      pendingArgs = null;
+      fn(...args);
+    }
+  };
+
+  wrapped.pending = (): boolean => timer !== null;
+
+  return wrapped;
+}
