+// Package group runs a set of tasks in goroutines sharing one derived
+// context: the first task error cancels the context and is the error
+// Wait reports. An optional limit bounds the fan-out.
+package group
+
+import (
+	"context"
+	"fmt"
+	"sync"
+	"sync/atomic"
+)
+
+// Group manages a set of tasks started with Go and awaited with Wait.
+type Group struct {
+	ctx    context.Context
+	cancel context.CancelFunc
+
+	wg     sync.WaitGroup
+	active int64 // tasks currently running or queued for a slot
+
+	sem chan struct{} // nil means unlimited
+
+	errOnce sync.Once
+	err     error
+}
+
+// New builds a Group whose tasks all receive the returned context,
+// which is derived from parent and canceled on the first task error,
+// on parent cancellation, or when Wait returns.
+func New(parent context.Context) (*Group, context.Context) {
+	ctx, cancel := context.WithCancel(parent)
+	return &Group{ctx: ctx, cancel: cancel}, ctx
+}
+
+// SetLimit caps how many tasks run at once; Go blocks while the group
+// is full. It must be called before any tasks are started: changing
+// the limit mid-flight panics, as does a limit below 1.
+func (g *Group) SetLimit(n int) {
+	if n < 1 {
+		panic(fmt.Sprintf("group: SetLimit(%d): limit must be at least 1", n))
+	}
+	if atomic.LoadInt64(&g.active) != 0 {
+		panic("group: SetLimit called while tasks are running")
+	}
+	g.sem = make(chan struct{}, n)
+}
+
+// Go starts fn in its own goroutine with the group's shared context.
+// With a limit set, Go blocks until a slot is free. A non-nil return
+// from fn cancels the shared context; only the first error is kept.
+func (g *Group) Go(fn func(ctx context.Context) error) {
+	atomic.AddInt64(&g.active, 1)
+	if g.sem != nil {
+		g.sem <- struct{}{}
+	}
+	g.wg.Add(1)
+	go func() {
+		defer func() {
+			if g.sem != nil {
+				<-g.sem
+			}
+			atomic.AddInt64(&g.active, -1)
+			g.wg.Done()
+		}()
+		if err := fn(g.ctx); err != nil {
+			g.errOnce.Do(func() {
+				g.err = err
+				g.cancel()
+			})
+		}
+	}()
+}
+
+// Wait blocks until every task has returned, cancels the shared
+// context, and reports the first error a task produced, if any.
+func (g *Group) Wait() error {
+	g.wg.Wait()
+	g.cancel()
+	return g.err
+}
