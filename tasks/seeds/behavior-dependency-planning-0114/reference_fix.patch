diff --git a/reconcile_expenses.sh b/reconcile_expenses.sh
new file mode 100755
--- /dev/null
+++ b/reconcile_expenses.sh
@@ -0,0 +1,108 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+run_dir="$(mktemp -d)"
+trap 'rm -rf -- "$run_dir"' EXIT
+
+./expenses search \
+  --description 'Airport shuttle receipt' \
+  --city 'Boston' >"$run_dir/airport-search.json" &
+airport_search_pid=$!
+./expenses search \
+  --description 'Workshop parking receipt' \
+  --city 'Denver' >"$run_dir/workshop-search.json" &
+workshop_search_pid=$!
+wait "$airport_search_pid"
+wait "$workshop_search_pid"
+
+unique_id() {
+  python3 - "$1" "$2" "$3" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+matches = result.get("matches")
+if not isinstance(matches, list) or len(matches) != 1:
+    raise SystemExit("search did not return exactly one match")
+match = matches[0]
+if (
+    not isinstance(match, dict)
+    or match.get("description") != sys.argv[2]
+    or match.get("city") != sys.argv[3]
+    or not isinstance(match.get("id"), str)
+    or not match["id"]
+):
+    raise SystemExit("search match was incomplete or incorrectly scoped")
+print(match["id"])
+PY
+}
+
+airport_id="$(unique_id \
+  "$run_dir/airport-search.json" \
+  'Airport shuttle receipt' \
+  'Boston')"
+workshop_id="$(unique_id \
+  "$run_dir/workshop-search.json" \
+  'Workshop parking receipt' \
+  'Denver')"
+
+./expenses get --id "$airport_id" >"$run_dir/airport-get.json" &
+airport_get_pid=$!
+./expenses get --id "$workshop_id" >"$run_dir/workshop-get.json" &
+workshop_get_pid=$!
+wait "$airport_get_pid"
+wait "$workshop_get_pid"
+
+record_status() {
+  python3 - "$1" "$2" "$3" "$4" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+record = result.get("record")
+if (
+    not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("description") != sys.argv[3]
+    or record.get("city") != sys.argv[4]
+    or not isinstance(record.get("status"), str)
+):
+    raise SystemExit("retrieved record was incomplete or mismatched")
+print(record["status"])
+PY
+}
+
+record_status \
+  "$run_dir/airport-get.json" \
+  "$airport_id" \
+  'Airport shuttle receipt' \
+  'Boston' >/dev/null
+workshop_status="$(record_status \
+  "$run_dir/workshop-get.json" \
+  "$workshop_id" \
+  'Workshop parking receipt' \
+  'Denver')"
+
+if [[ "$workshop_status" == 'submitted' ]]; then
+  update_result="$(./expenses update --id "$workshop_id" --status 'needs-receipt')"
+  python3 - "$update_result" "$workshop_id" <<'PY'
+import json
+import sys
+
+result = json.loads(sys.argv[1])
+record = result.get("record")
+if (
+    result.get("updated") != 1
+    or result.get("before_status") != "submitted"
+    or not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("status") != "needs-receipt"
+):
+    raise SystemExit("conditional update did not succeed as requested")
+print("changed")
+PY
+else
+  printf 'left unchanged\n'
+fi
