+import java.util.ArrayDeque;
+import java.util.ArrayList;
+import java.util.Deque;
+import java.util.List;
+
+/** One-suit Spider solitaire engine: 104 cards, ten columns, five stock rows. */
+public final class Spider {
+
+    private static final String RANKS = "A23456789TJQK"; // index+1 = rank value
+    private static final int COLS = 10;
+
+    private static final class Card {
+        final int rank; // 1..13
+        boolean faceUp;
+        Card(int rank, boolean faceUp) { this.rank = rank; this.faceUp = faceUp; }
+    }
+
+    private final List<List<Card>> cols = new ArrayList<>();
+    private final Deque<int[]> stock = new ArrayDeque<>(); // each row: ten ranks
+    private int removed;
+
+    private Spider() {
+        for (int i = 0; i < COLS; i++) cols.add(new ArrayList<>());
+    }
+
+    private static int rank(String tok) {
+        int r = RANKS.indexOf(tok) + 1;
+        if (tok.length() != 1 || r == 0) throw new IllegalArgumentException("bad rank: " + tok);
+        return r;
+    }
+
+    /** Deals a fresh game from a 104-card deck fixture (whitespace-separated ranks). */
+    public static Spider fromDeck(String text) {
+        String[] toks = text.trim().split("\\s+");
+        if (toks.length != 104) {
+            throw new IllegalArgumentException("deck must hold 104 cards, got " + toks.length);
+        }
+        int[] perRank = new int[14];
+        int[] deck = new int[104];
+        for (int i = 0; i < 104; i++) {
+            deck[i] = rank(toks[i]);
+            perRank[deck[i]]++;
+        }
+        for (int r = 1; r <= 13; r++) {
+            if (perRank[r] != 8) {
+                throw new IllegalArgumentException("deck needs eight " + RANKS.charAt(r - 1)
+                        + "s, got " + perRank[r]);
+            }
+        }
+        Spider g = new Spider();
+        int next = 0;
+        for (int dealt = 0; dealt < 54; dealt++) {
+            g.cols.get(dealt % COLS).add(new Card(deck[next++], false));
+        }
+        for (List<Card> col : g.cols) col.get(col.size() - 1).faceUp = true;
+        for (int row = 0; row < 5; row++) {
+            int[] r = new int[COLS];
+            for (int i = 0; i < COLS; i++) r[i] = deck[next++];
+            g.stock.addLast(r);
+        }
+        return g;
+    }
+
+    /** Restores a saved layout: removed count, future deal rows, ten column lines. */
+    public static Spider fromLayout(String text) {
+        Spider g = new Spider();
+        g.removed = -1;
+        int colAt = 0;
+        for (String raw : text.split("\n", -1)) {
+            String line = raw.trim();
+            if (line.isEmpty()) continue;
+            String[] toks = line.split("\\s+");
+            if (toks[0].equals("removed") && toks.length == 2) {
+                g.removed = Integer.parseInt(toks[1]);
+            } else if (toks[0].equals("deal")) {
+                if (toks.length != COLS + 1) {
+                    throw new IllegalArgumentException("deal row needs ten cards: " + line);
+                }
+                int[] row = new int[COLS];
+                for (int i = 0; i < COLS; i++) row[i] = rank(toks[i + 1]);
+                g.stock.addLast(row);
+            } else if (toks[0].equals("col")) {
+                if (colAt >= COLS) throw new IllegalArgumentException("more than ten columns");
+                int bar = line.indexOf('|');
+                if (bar < 0) throw new IllegalArgumentException("column needs a '|': " + line);
+                List<Card> col = g.cols.get(colAt++);
+                for (String t : line.substring(3, bar).trim().split("\\s+")) {
+                    if (!t.isEmpty()) col.add(new Card(rank(t), false));
+                }
+                for (String t : line.substring(bar + 1).trim().split("\\s+")) {
+                    if (!t.isEmpty()) col.add(new Card(rank(t), true));
+                }
+                if (!col.isEmpty() && !col.get(col.size() - 1).faceUp) {
+                    throw new IllegalArgumentException("a non-empty column must end face up");
+                }
+            } else {
+                throw new IllegalArgumentException("bad layout line: " + line);
+            }
+        }
+        if (g.removed < 0 || g.removed > 8) {
+            throw new IllegalArgumentException("removed must be 0..8");
+        }
+        if (colAt != COLS) throw new IllegalArgumentException("expected ten col lines, got " + colAt);
+        int[] perRank = new int[14];
+        int total = 0;
+        for (List<Card> col : g.cols) {
+            for (Card c : col) { perRank[c.rank]++; total++; }
+        }
+        for (int[] row : g.stock) {
+            for (int r : row) { perRank[r]++; total++; }
+        }
+        if (total + 13 * g.removed != 104) {
+            throw new IllegalArgumentException("card count does not reconcile: " + total);
+        }
+        for (int r = 1; r <= 13; r++) {
+            if (perRank[r] + g.removed != 8) {
+                throw new IllegalArgumentException("rank count off for " + RANKS.charAt(r - 1));
+            }
+        }
+        return g;
+    }
+
+    public int removed() {
+        return removed;
+    }
+
+    public boolean won() {
+        return removed == 8;
+    }
+
+    /** Lifts the top {@code count} cards of {@code src} onto {@code dst}. */
+    public void move(int src, int count, int dst) {
+        if (src < 1 || src > COLS || dst < 1 || dst > COLS || src == dst) {
+            throw new IllegalArgumentException("bad columns: " + src + " -> " + dst);
+        }
+        List<Card> from = cols.get(src - 1), to = cols.get(dst - 1);
+        int faceUp = 0;
+        for (int i = from.size() - 1; i >= 0 && from.get(i).faceUp; i--) faceUp++;
+        if (count < 1 || count > faceUp) {
+            throw new IllegalArgumentException("cannot lift " + count + " cards from column " + src);
+        }
+        int base = from.size() - count;
+        for (int i = base; i < from.size() - 1; i++) {
+            if (from.get(i).rank != from.get(i + 1).rank + 1) {
+                throw new IllegalArgumentException("lifted cards are not a descending run");
+            }
+        }
+        if (!to.isEmpty() && to.get(to.size() - 1).rank != from.get(base).rank + 1) {
+            throw new IllegalArgumentException("landing needs a card one rank higher");
+        }
+        List<Card> block = new ArrayList<>(from.subList(base, from.size()));
+        from.subList(base, from.size()).clear();
+        to.addAll(block);
+        flipTop(from);
+        clearRun(to);
+    }
+
+    /** Deals one stock row, one card per column — never onto a gap. */
+    public void deal() {
+        if (stock.isEmpty()) throw new IllegalStateException("stock is empty");
+        for (int i = 0; i < COLS; i++) {
+            if (cols.get(i).isEmpty()) {
+                throw new IllegalStateException("cannot deal across an empty column");
+            }
+        }
+        int[] row = stock.removeFirst();
+        for (int i = 0; i < COLS; i++) cols.get(i).add(new Card(row[i], true));
+        for (List<Card> col : cols) clearRun(col);
+    }
+
+    private void flipTop(List<Card> col) {
+        if (!col.isEmpty()) col.get(col.size() - 1).faceUp = true;
+    }
+
+    private void clearRun(List<Card> col) {
+        if (col.size() < 13) return;
+        int top = col.size() - 1;
+        for (int i = 0; i < 13; i++) {
+            Card c = col.get(top - i);
+            if (!c.faceUp || c.rank != i + 1) return; // A,2,...,K reading downward
+        }
+        col.subList(col.size() - 13, col.size()).clear();
+        removed++;
+        flipTop(col);
+    }
+
+    public String render() {
+        StringBuilder sb = new StringBuilder();
+        sb.append("stock ").append(stock.size()).append(" removed ").append(removed);
+        for (int i = 0; i < COLS; i++) {
+            sb.append('\n').append(i + 1).append(':');
+            List<Card> col = cols.get(i);
+            if (col.isEmpty()) {
+                sb.append(" -");
+            } else {
+                for (Card c : col) {
+                    sb.append(' ').append(c.faceUp ? RANKS.charAt(c.rank - 1) : '?');
+                }
+            }
+        }
+        return sb.toString();
+    }
+
+    /** Replays "m src count dst" / "d" commands and returns the session transcript. */
+    public static String replay(Spider game, List<String> commands) {
+        StringBuilder sb = new StringBuilder();
+        sb.append("=== start ===\n").append(game.render()).append("\n\n");
+        for (String cmd : commands) {
+            String[] toks = cmd.trim().split("\\s+");
+            if (toks.length == 1 && toks[0].equals("d")) {
+                game.deal();
+            } else if (toks.length == 4 && toks[0].equals("m")) {
+                game.move(Integer.parseInt(toks[1]), Integer.parseInt(toks[2]),
+                        Integer.parseInt(toks[3]));
+            } else {
+                throw new IllegalArgumentException("bad command: " + cmd);
+            }
+            sb.append("> ").append(cmd.trim()).append('\n').append(game.render()).append("\n\n");
+        }
+        sb.append(game.won() ? "result: won\n" : "result: playing\n");
+        return sb.toString();
+    }
+}
