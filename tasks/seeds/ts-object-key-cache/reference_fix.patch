+// Canonical value key: JSON with object keys sorted at every depth, so
+// logically equal params always encode to the same string and distinct
+// values can never collide.
+function canonicalKey(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value);
+  if (Array.isArray(value)) return '[' + value.map(canonicalKey).join(',') + ']';
+  const record = value as Record<string, unknown>;
+  const keys = Object.keys(record)
+    .filter((k) => record[k] !== undefined)
+    .sort();
+  return '{' + keys.map((k) => JSON.stringify(k) + ':' + canonicalKey(record[k])).join(',') + '}';
+}
+
+function snapshotParams(params: ReportParams): ReportParams {
+  return JSON.parse(JSON.stringify(params)) as ReportParams;
+}
