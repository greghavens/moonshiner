+"""Session tracking with an injected logical clock. No file IO here."""
+import datetime as _dt
+
+TS_FORMAT = "%Y-%m-%d %H:%M"
+
+
+class TrackerError(Exception):
+    """User-facing tracker failure (bad state or bad clock)."""
+
+
+def parse_ts(text):
+    try:
+        return _dt.datetime.strptime(text, TS_FORMAT)
+    except (TypeError, ValueError):
+        raise TrackerError(f"bad timestamp {text!r}, expected 'YYYY-MM-DD HH:MM'") from None
+
+
+def format_ts(dt):
+    return dt.strftime(TS_FORMAT)
+
+
+def empty_state():
+    return {"sessions": [], "running": None}
+
+
+def _latest(state):
+    """The latest timestamp recorded anywhere in the state, or None."""
+    times = []
+    for s in state["sessions"]:
+        times.append(parse_ts(s["end"]))
+    if state["running"]:
+        times.append(parse_ts(state["running"]["start"]))
+    return max(times) if times else None
+
+
+def _check_clock(state, ts):
+    latest = _latest(state)
+    if latest is not None and ts < latest:
+        raise TrackerError(
+            f"clock went backwards: {format_ts(ts)} is before {format_ts(latest)}")
+
+
+def start(state, task, ts_text):
+    ts = parse_ts(ts_text)
+    if state["running"]:
+        raise TrackerError(f"already working on {state['running']['task']}; "
+                           "stop or switch first")
+    _check_clock(state, ts)
+    state["running"] = {"task": task, "start": format_ts(ts)}
+
+
+def stop(state, ts_text):
+    ts = parse_ts(ts_text)
+    if not state["running"]:
+        raise TrackerError("nothing is running")
+    _check_clock(state, ts)
+    running = state["running"]
+    state["sessions"].append(
+        {"task": running["task"], "start": running["start"], "end": format_ts(ts)})
+    state["running"] = None
+
+
+def switch(state, task, ts_text):
+    if not state["running"]:
+        raise TrackerError("nothing is running; use start")
+    if state["running"]["task"] == task:
+        raise TrackerError(f"already working on {task}")
+    stop(state, ts_text)
+    start(state, task, ts_text)
+
+
+def completed_sessions(state):
+    """(task, start_dt, end_dt) tuples, chronological by start time."""
+    out = [(s["task"], parse_ts(s["start"]), parse_ts(s["end"]))
+           for s in state["sessions"]]
+    out.sort(key=lambda t: t[1])
+    return out
