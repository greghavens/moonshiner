+"""Time-tracking CLI: start / stop / switch / status / report / export."""
+import argparse
+import datetime as _dt
+import sys
+
+import reports
+import store
+import tracker
+
+
+def _mutate(args, fn):
+    state = store.load(args.db)
+    try:
+        fn(state)
+    except tracker.TrackerError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_start(args):
+    return _mutate(args, lambda s: tracker.start(s, args.task, args.at))
+
+
+def cmd_stop(args):
+    return _mutate(args, lambda s: tracker.stop(s, args.at))
+
+
+def cmd_switch(args):
+    return _mutate(args, lambda s: tracker.switch(s, args.task, args.at))
+
+
+def cmd_status(args):
+    state = store.load(args.db)
+    running = state["running"]
+    if running:
+        print(f"working on {running['task']} since {running['start']}")
+    else:
+        print("idle")
+    return 0
+
+
+def cmd_report(args):
+    try:
+        day = _dt.date.fromisoformat(args.day or args.week)
+    except ValueError:
+        print("error: bad date, expected YYYY-MM-DD", file=sys.stderr)
+        return 1
+    state = store.load(args.db)
+    sessions = tracker.completed_sessions(state)
+    totals = (reports.day_totals(sessions, day) if args.day
+              else reports.week_totals(sessions, day))
+    for line in reports.render_totals(totals):
+        print(line)
+    return 0
+
+
+def cmd_export(args):
+    state = store.load(args.db)
+    reports.write_csv(tracker.completed_sessions(state), args.csv)
+    return 0
+
+
+def build_parser():
+    ap = argparse.ArgumentParser(prog="timeclock")
+    ap.add_argument("--db", required=True)
+    sub = ap.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("start")
+    p.add_argument("task")
+    p.add_argument("--at", required=True)
+    p.set_defaults(func=cmd_start)
+
+    p = sub.add_parser("stop")
+    p.add_argument("--at", required=True)
+    p.set_defaults(func=cmd_stop)
+
+    p = sub.add_parser("switch")
+    p.add_argument("task")
+    p.add_argument("--at", required=True)
+    p.set_defaults(func=cmd_switch)
+
+    p = sub.add_parser("status")
+    p.set_defaults(func=cmd_status)
+
+    p = sub.add_parser("report")
+    g = p.add_mutually_exclusive_group(required=True)
+    g.add_argument("--day")
+    g.add_argument("--week")
+    p.set_defaults(func=cmd_report)
+
+    p = sub.add_parser("export")
+    p.add_argument("--csv", required=True)
+    p.set_defaults(func=cmd_export)
+    return ap
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
