+"""Daily/weekly totals and CSV rendering over completed sessions."""
+import csv
+import datetime as _dt
+
+from tracker import format_ts
+
+
+def _totals_in_range(sessions, lo, hi):
+    """Minutes per task for sessions clipped to [lo, hi).
+
+    A task is listed if any of its sessions overlaps the range, including
+    zero-length sessions sitting inside it.
+    """
+    totals = {}
+    for task, start, end in sessions:
+        clipped_lo = max(start, lo)
+        clipped_hi = min(end, hi)
+        overlaps = clipped_lo < clipped_hi or (
+            start == end and lo <= start < hi)
+        if not overlaps:
+            continue
+        minutes = int((clipped_hi - clipped_lo).total_seconds() // 60)
+        totals[task] = totals.get(task, 0) + max(minutes, 0)
+    return totals
+
+
+def day_totals(sessions, day):
+    lo = _dt.datetime.combine(day, _dt.time.min)
+    return _totals_in_range(sessions, lo, lo + _dt.timedelta(days=1))
+
+
+def week_totals(sessions, anchor_day):
+    monday = anchor_day - _dt.timedelta(days=anchor_day.isoweekday() - 1)
+    lo = _dt.datetime.combine(monday, _dt.time.min)
+    return _totals_in_range(sessions, lo, lo + _dt.timedelta(days=7))
+
+
+def format_minutes(minutes):
+    return f"{minutes // 60}:{minutes % 60:02d}"
+
+
+def render_totals(totals):
+    return [f"{task}\t{format_minutes(totals[task])}" for task in sorted(totals)]
+
+
+def write_csv(sessions, path):
+    with open(path, "w", newline="", encoding="utf-8") as f:
+        w = csv.writer(f)
+        w.writerow(["task", "start", "end", "minutes"])
+        for task, start, end in sessions:
+            minutes = int((end - start).total_seconds() // 60)
+            w.writerow([task, format_ts(start), format_ts(end), minutes])
