diff --git a/duroll.ps1 b/duroll.ps1
new file mode 100644
index 0000000..cd0d756
--- /dev/null
+++ b/duroll.ps1
@@ -0,0 +1,57 @@
+# duroll.ps1 — per-directory recursive disk-usage rollup with IEC sizes.
+# Usage: pwsh -NoProfile -File duroll.ps1 -Root <dir> [-Top <n>]
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Root,
+    [ValidateRange(1, [int]::MaxValue)][int]$Top = 5
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if (-not (Test-Path -LiteralPath $Root -PathType Container)) {
+    [Console]::Error.WriteLine("duroll: root not found: $Root")
+    exit 66
+}
+
+$inv = [System.Globalization.CultureInfo]::InvariantCulture
+
+function Format-Iec {
+    param([long]$Bytes)
+    if ($Bytes -lt 1024) {
+        return "$Bytes B"
+    }
+    if ($Bytes -lt 1048576) {
+        $v = [math]::Round($Bytes / 1024.0, 1, [System.MidpointRounding]::AwayFromZero)
+        return [string]::Format($script:inv, '{0:0.0} KiB', $v)
+    }
+    $v = [math]::Round($Bytes / 1048576.0, 1, [System.MidpointRounding]::AwayFromZero)
+    return [string]::Format($script:inv, '{0:0.0} MiB', $v)
+}
+
+$rootFull = (Get-Item -LiteralPath $Root -Force).FullName
+
+$dirs = [System.Collections.Generic.List[pscustomobject]]::new()
+$dirs.Add([pscustomobject]@{ Rel = '.'; Full = $rootFull })
+foreach ($d in @(Get-ChildItem -LiteralPath $rootFull -Recurse -Force -Directory)) {
+    $rel = $d.FullName.Substring($rootFull.Length + 1) -replace '\\', '/'
+    $dirs.Add([pscustomobject]@{ Rel = $rel; Full = $d.FullName })
+}
+
+# Composite sort key: inverted byte count (zero-padded) puts big first,
+# the relpath suffix breaks ties in ordinal order.
+$lineByKey = [System.Collections.Generic.Dictionary[string, string]]::new([System.StringComparer]::Ordinal)
+foreach ($d in $dirs) {
+    $measured = @(Get-ChildItem -LiteralPath $d.Full -Recurse -Force -File | Measure-Object -Property Length -Sum)
+    $bytes = if ($measured.Count -gt 0 -and $null -ne $measured[0].Sum) { [long]$measured[0].Sum } else { 0L }
+    $key = [string]::Format($inv, '{0:D19}', [long]::MaxValue - $bytes) + '|' + $d.Rel
+    $lineByKey[$key] = "$($d.Rel) $(Format-Iec $bytes)"
+}
+
+$keys = [string[]]@($lineByKey.Keys)
+[Array]::Sort($keys, [System.StringComparer]::Ordinal)
+$count = [math]::Min($Top, $keys.Length)
+for ($i = 0; $i -lt $count; $i++) {
+    Write-Output $lineByKey[$keys[$i]]
+}
+exit 0
