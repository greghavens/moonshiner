diff --git a/bin/keychain-handoff b/bin/keychain-handoff
--- a/bin/keychain-handoff
+++ b/bin/keychain-handoff
@@ -99,7 +99,7 @@ while IFS=$'\t' read -r fingerprint subject not_before not_after key_usage ident
   ((not_after > current_not_after)) || continue
 
   # A replacement must itself be anchored by the simulated trust store.
-  if is_trusted "$current_fingerprint"; then
+  if is_trusted "$fingerprint"; then
     printf '%s\t%s\n' "$not_after" "$fingerprint" >> "$candidate_file"
   fi
 done < "$metadata_file"
