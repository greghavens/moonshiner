+// Package breaker implements a classic three-state circuit breaker
+// (closed / open / half-open) with an injectable clock.
+package breaker
+
+import (
+	"errors"
+	"fmt"
+	"time"
+)
+
+import "sync"
+
+// Clock supplies the current time; injected so tests never sleep.
+type Clock interface {
+	Now() time.Time
+}
+
+// State is the breaker's position in its lifecycle.
+type State string
+
+// Breaker states.
+const (
+	StateClosed   State = "closed"
+	StateOpen     State = "open"
+	StateHalfOpen State = "half-open"
+)
+
+// ErrOpen is returned for calls short-circuited by an open (or busy
+// half-open) breaker; the wrapped fn is not invoked.
+var ErrOpen = errors.New("breaker: circuit open")
+
+// Breaker wraps calls to a flaky dependency and fails fast while it is
+// unhealthy. Safe for concurrent use.
+type Breaker struct {
+	mu        sync.Mutex
+	threshold int
+	cooldown  time.Duration
+	clock     Clock
+
+	state       State
+	consecFails int
+	openedAt    time.Time
+	trialBusy   bool
+}
+
+// New builds a closed breaker that trips after threshold consecutive
+// failures and probes again after cooldown.
+func New(threshold int, cooldown time.Duration, clock Clock) (*Breaker, error) {
+	if threshold < 1 {
+		return nil, fmt.Errorf("breaker: threshold must be at least 1, got %d", threshold)
+	}
+	if cooldown <= 0 {
+		return nil, fmt.Errorf("breaker: cooldown must be positive, got %v", cooldown)
+	}
+	if clock == nil {
+		return nil, errors.New("breaker: clock must not be nil")
+	}
+	return &Breaker{
+		threshold: threshold,
+		cooldown:  cooldown,
+		clock:     clock,
+		state:     StateClosed,
+	}, nil
+}
+
+// cooled reports whether the open cooldown has elapsed. Callers hold b.mu.
+func (b *Breaker) cooled() bool {
+	return b.clock.Now().Sub(b.openedAt) >= b.cooldown
+}
+
+// State reports the state the next call would observe: an open breaker
+// whose cooldown has elapsed already counts as half-open.
+func (b *Breaker) State() State {
+	b.mu.Lock()
+	defer b.mu.Unlock()
+	if b.state == StateOpen && b.cooled() {
+		return StateHalfOpen
+	}
+	return b.state
+}
+
+// Do routes a call through the breaker. Open: fails fast with ErrOpen.
+// Half-open: admits one trial; the outcome decides the next state.
+// Closed: passes through and tracks consecutive failures.
+func (b *Breaker) Do(fn func() error) error {
+	b.mu.Lock()
+	if b.state == StateOpen {
+		if !b.cooled() {
+			b.mu.Unlock()
+			return ErrOpen
+		}
+		b.state = StateHalfOpen
+	}
+
+	if b.state == StateHalfOpen {
+		if b.trialBusy {
+			b.mu.Unlock()
+			return ErrOpen
+		}
+		b.trialBusy = true
+		b.mu.Unlock()
+
+		err := fn()
+
+		b.mu.Lock()
+		b.trialBusy = false
+		if err != nil {
+			b.state = StateOpen
+			b.openedAt = b.clock.Now()
+		} else {
+			b.state = StateClosed
+			b.consecFails = 0
+		}
+		b.mu.Unlock()
+		return err
+	}
+
+	// Closed: run fn without holding the lock.
+	b.mu.Unlock()
+	err := fn()
+
+	b.mu.Lock()
+	if b.state == StateClosed {
+		if err != nil {
+			b.consecFails++
+			if b.consecFails >= b.threshold {
+				b.state = StateOpen
+				b.openedAt = b.clock.Now()
+				b.consecFails = 0
+			}
+		} else {
+			b.consecFails = 0
+		}
+	}
+	b.mu.Unlock()
+	return err
+}
