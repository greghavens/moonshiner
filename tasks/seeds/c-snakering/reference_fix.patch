diff --git a/snake.c b/snake.c
new file mode 100644
index 0000000..24cd5d4
--- /dev/null
+++ b/snake.c
@@ -0,0 +1,136 @@
+#include "snake.h"
+
+static int ring_at(const snake *s, int back) {
+    /* index of the segment `back` places behind the head */
+    return (s->head - back + SNAKE_MAX_BODY) % SNAKE_MAX_BODY;
+}
+
+int snake_init(snake *s, int w, int h, const uint8_t *food, int nfood) {
+    if (!s || w < 4 || w > SNAKE_MAX_W || h < 4 || h > SNAKE_MAX_H) return -1;
+    if (nfood < 0 || nfood > SNAKE_MAX_FOOD) return -1;
+    if (nfood > 0 && !food) return -1;
+    for (int i = 0; i < nfood; i++) {
+        if (food[2 * i] >= w || food[2 * i + 1] >= h) return -1;
+    }
+    s->w = w;
+    s->h = h;
+    int cx = w / 2, cy = h / 2;
+    s->head = 2;
+    s->len = 3;
+    for (int i = 0; i < 3; i++) {
+        s->cell_x[i] = (uint8_t)(cx - 2 + i);
+        s->cell_y[i] = (uint8_t)cy;
+    }
+    s->moved_dir = 'E';
+    s->pending_dir = 'E';
+    s->nfood = nfood;
+    for (int i = 0; i < nfood; i++) {
+        s->food_x[i] = food[2 * i];
+        s->food_y[i] = food[2 * i + 1];
+    }
+    if (nfood > 0) {
+        s->cur_fx = s->food_x[0];
+        s->cur_fy = s->food_y[0];
+        s->next_food = 1;
+    } else {
+        s->cur_fx = -1;
+        s->cur_fy = -1;
+        s->next_food = 0;
+    }
+    s->score = 0;
+    s->alive = 1;
+    return 0;
+}
+
+int snake_turn(snake *s, char dir) {
+    if (!s || !s->alive) return -1;
+    char opposite;
+    switch (dir) {
+    case 'N': opposite = 'S'; break;
+    case 'S': opposite = 'N'; break;
+    case 'E': opposite = 'W'; break;
+    case 'W': opposite = 'E'; break;
+    default: return -1;
+    }
+    if (s->moved_dir == opposite) return -1;
+    s->pending_dir = dir;
+    return 0;
+}
+
+int snake_tick(snake *s) {
+    if (!s) return -1;
+    if (!s->alive) return -1;
+    int dx = 0, dy = 0;
+    switch (s->pending_dir) {
+    case 'N': dy = -1; break;
+    case 'S': dy = 1; break;
+    case 'E': dx = 1; break;
+    case 'W': dx = -1; break;
+    }
+    int nx = s->cell_x[s->head] + dx;
+    int ny = s->cell_y[s->head] + dy;
+    if (nx < 0 || nx >= s->w || ny < 0 || ny >= s->h) {
+        s->alive = 0;
+        return 0;
+    }
+    int eat = (s->cur_fx == nx && s->cur_fy == ny);
+    /* the tail vacates this tick unless we grow, so skip it when checking */
+    int blocked = s->len - (eat ? 0 : 1);
+    for (int i = 0; i < blocked; i++) {
+        int idx = ring_at(s, i);
+        if (s->cell_x[idx] == nx && s->cell_y[idx] == ny) {
+            s->alive = 0;
+            return 0;
+        }
+    }
+    s->moved_dir = s->pending_dir;
+    s->head = (s->head + 1) % SNAKE_MAX_BODY;
+    s->cell_x[s->head] = (uint8_t)nx;
+    s->cell_y[s->head] = (uint8_t)ny;
+    if (eat) {
+        s->len++;
+        s->score++;
+        if (s->next_food < s->nfood) {
+            s->cur_fx = s->food_x[s->next_food];
+            s->cur_fy = s->food_y[s->next_food];
+            s->next_food++;
+        } else {
+            s->cur_fx = -1;
+            s->cur_fy = -1;
+        }
+        return 2;
+    }
+    return 1;
+}
+
+int snake_score(const snake *s) { return s->score; }
+int snake_len(const snake *s) { return s->len; }
+int snake_alive(const snake *s) { return s->alive; }
+
+int snake_render(const snake *s, char *buf, size_t cap) {
+    if (!s || !buf) return -1;
+    size_t need = (size_t)(s->h + 2) * (size_t)(s->w + 3) + 1;
+    if (cap < need) return -1;
+    char *p = buf;
+    for (int row = 0; row < s->h + 2; row++) {
+        for (int col = 0; col < s->w + 2; col++) {
+            char ch;
+            if (row == 0 || row == s->h + 1 || col == 0 || col == s->w + 1)
+                ch = '#';
+            else
+                ch = '.';
+            *p++ = ch;
+        }
+        *p++ = '\n';
+    }
+    int stride = s->w + 3;
+    if (s->cur_fx >= 0)
+        buf[(s->cur_fy + 1) * stride + s->cur_fx + 1] = '*';
+    for (int i = s->len - 1; i >= 0; i--) {
+        int idx = ring_at(s, i);
+        buf[(s->cell_y[idx] + 1) * stride + s->cell_x[idx] + 1] =
+            (i == 0) ? 'O' : 'o';
+    }
+    *p = '\0';
+    return (int)(need - 1);
+}
diff --git a/snake.h b/snake.h
new file mode 100644
index 0000000..893e773
--- /dev/null
+++ b/snake.h
@@ -0,0 +1,39 @@
+#ifndef SNAKE_H
+#define SNAKE_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+#define SNAKE_MAX_W    16
+#define SNAKE_MAX_H    16
+#define SNAKE_MAX_FOOD 32
+#define SNAKE_MAX_BODY (SNAKE_MAX_W * SNAKE_MAX_H)
+
+typedef struct snake {
+    int w, h;
+    /* body ring buffer: cells[head] is the head, older segments follow
+     * backwards (wrapping); len cells are live */
+    uint8_t cell_x[SNAKE_MAX_BODY];
+    uint8_t cell_y[SNAKE_MAX_BODY];
+    int head;
+    int len;
+    char moved_dir;   /* direction of the last actual move */
+    char pending_dir; /* direction the next tick will use */
+    uint8_t food_x[SNAKE_MAX_FOOD];
+    uint8_t food_y[SNAKE_MAX_FOOD];
+    int nfood;
+    int next_food;
+    int cur_fx, cur_fy; /* current food, -1 when none */
+    int score;
+    int alive;
+} snake;
+
+int snake_init(snake *s, int w, int h, const uint8_t *food, int nfood);
+int snake_turn(snake *s, char dir);
+int snake_tick(snake *s);
+int snake_score(const snake *s);
+int snake_len(const snake *s);
+int snake_alive(const snake *s);
+int snake_render(const snake *s, char *buf, size_t cap);
+
+#endif /* SNAKE_H */
