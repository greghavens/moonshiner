+// Package retry runs an operation until it succeeds, a policy says stop,
+// or the context is done.
+package retry
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"time"
+)
+
+// Backoff maps a 1-based attempt number to the delay taken after that
+// attempt fails.
+type Backoff func(attempt int) time.Duration
+
+// Constant returns the same delay for every attempt.
+func Constant(d time.Duration) Backoff {
+	return func(int) time.Duration { return d }
+}
+
+// Exponential doubles the delay each attempt, starting at base and
+// clamped to max.
+func Exponential(base, max time.Duration) Backoff {
+	return func(attempt int) time.Duration {
+		d := base
+		for i := 1; i < attempt; i++ {
+			d *= 2
+			if d >= max {
+				return max
+			}
+		}
+		if d > max {
+			return max
+		}
+		return d
+	}
+}
+
+// Options configures Do.
+type Options struct {
+	// MaxAttempts is the total number of attempts including the first.
+	// Values below 1 are an option error.
+	MaxAttempts int
+	// Backoff yields the delay between attempts; nil retries immediately.
+	Backoff Backoff
+	// Retryable reports whether an error is worth another attempt;
+	// nil treats every error as retryable.
+	Retryable func(error) bool
+	// Sleep waits for d or until ctx is done. Nil uses a real timer.
+	Sleep func(ctx context.Context, d time.Duration) error
+}
+
+func defaultSleep(ctx context.Context, d time.Duration) error {
+	timer := time.NewTimer(d)
+	defer timer.Stop()
+	select {
+	case <-ctx.Done():
+		return ctx.Err()
+	case <-timer.C:
+		return nil
+	}
+}
+
+// Do runs fn up to opts.MaxAttempts times, sleeping opts.Backoff(attempt)
+// between attempts. It stops early on success, on a non-retryable error,
+// or when ctx is done.
+func Do(ctx context.Context, opts Options, fn func(ctx context.Context) error) error {
+	if opts.MaxAttempts < 1 {
+		return fmt.Errorf("retry: MaxAttempts must be at least 1, got %d", opts.MaxAttempts)
+	}
+	if fn == nil {
+		return errors.New("retry: fn must not be nil")
+	}
+	sleep := opts.Sleep
+	if sleep == nil {
+		sleep = defaultSleep
+	}
+	retryable := opts.Retryable
+	if retryable == nil {
+		retryable = func(error) bool { return true }
+	}
+
+	var last error
+	for attempt := 1; attempt <= opts.MaxAttempts; attempt++ {
+		if err := ctx.Err(); err != nil {
+			return err
+		}
+		last = fn(ctx)
+		if last == nil {
+			return nil
+		}
+		if !retryable(last) {
+			return last
+		}
+		if attempt == opts.MaxAttempts {
+			break
+		}
+		if opts.Backoff != nil {
+			if err := sleep(ctx, opts.Backoff(attempt)); err != nil {
+				return err
+			}
+		}
+	}
+	return fmt.Errorf("retry: gave up after %d attempts: %w", opts.MaxAttempts, last)
+}
