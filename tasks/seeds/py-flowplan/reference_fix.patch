+"""flowplan — compiles a validated workflow document into a flat execution plan.
+
+compile_plan(text) -> {"tasks": [...]} with jump targets resolved to indices.
+Raises PlanError for jump cycles and unreachable tasks.
+"""
+import yaml
+
+TYPE_KEYS = ("call", "run", "set", "switch", "for", "raise", "emit", "wait")
+
+
+class PlanError(Exception):
+    pass
+
+
+def compile_plan(text):
+    data = yaml.safe_load(text)
+    return _compile_block(data["do"])
+
+
+def _compile_block(block):
+    entries = []
+    for item in block:
+        name = next(iter(item))
+        body = item[name]
+        kind = next(k for k in TYPE_KEYS if k in body)
+        entries.append((name, kind, body))
+    index_of = {name: i for i, (name, _, _) in enumerate(entries)}
+    count = len(entries)
+
+    def resolve(then, i):
+        if then is None or then == "continue":
+            return i + 1 if i + 1 < count else "end"
+        if then == "end":
+            return "end"
+        return index_of[then]
+
+    tasks = []
+    for i, (name, kind, body) in enumerate(entries):
+        entry = {
+            "index": i,
+            "name": name,
+            "type": kind,
+            "next": resolve(body.get("then"), i),
+        }
+        if kind == "switch":
+            entry["cases"] = [
+                {"when": case.get("when"), "target": resolve(case["then"], i)}
+                for case in body["switch"]
+            ]
+        elif kind == "for":
+            spec = body["for"]
+            entry["each"] = spec["each"]
+            entry["in"] = spec["in"]
+            entry["at"] = spec.get("at")
+            entry["body"] = _compile_block(spec["do"])
+        tasks.append(entry)
+
+    _check_cycles(tasks)
+    _check_reachable(tasks)
+    return {"tasks": tasks}
+
+
+def _unconditional_edge(tasks, i):
+    """The single unconditional out-edge of task i, or None.
+
+    Switch tasks route conditionally and contribute no edge here.
+    """
+    task = tasks[i]
+    if task["type"] == "switch":
+        return None
+    nxt = task["next"]
+    return nxt if isinstance(nxt, int) else None
+
+
+def _check_cycles(tasks):
+    count = len(tasks)
+    for start in range(count):
+        cur = _unconditional_edge(tasks, start)
+        steps = 0
+        while cur is not None and steps <= count:
+            if cur == start:
+                path = [tasks[start]["name"]]
+                node = _unconditional_edge(tasks, start)
+                while node != start:
+                    path.append(tasks[node]["name"])
+                    node = _unconditional_edge(tasks, node)
+                path.append(tasks[start]["name"])
+                raise PlanError("jump cycle detected: " + " -> ".join(path))
+            cur = _unconditional_edge(tasks, cur)
+            steps += 1
+
+
+def _check_reachable(tasks):
+    seen = set()
+    stack = [0]
+    while stack:
+        i = stack.pop()
+        if i in seen:
+            continue
+        seen.add(i)
+        task = tasks[i]
+        if task["type"] == "switch":
+            has_default = any(case["when"] is None for case in task["cases"])
+            for case in task["cases"]:
+                if isinstance(case["target"], int):
+                    stack.append(case["target"])
+            if not has_default and isinstance(task["next"], int):
+                stack.append(task["next"])
+        elif isinstance(task["next"], int):
+            stack.append(task["next"])
+    missing = [task["name"] for task in tasks if task["index"] not in seen]
+    if missing:
+        raise PlanError("unreachable tasks: " + ", ".join(missing))
