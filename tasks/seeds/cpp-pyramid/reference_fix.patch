diff --git a/pyramid.cpp b/pyramid.cpp
new file mode 100644
index 0000000..d6cfc0a
--- /dev/null
+++ b/pyramid.cpp
@@ -0,0 +1,149 @@
+#include "pyramid.h"
+
+#include <set>
+#include <sstream>
+
+namespace {
+
+int rank_value(char r) {
+    switch (r) {
+        case 'A': return 1;
+        case 'T': return 10;
+        case 'J': return 11;
+        case 'Q': return 12;
+        case 'K': return 13;
+        default:
+            if (r >= '2' && r <= '9') return r - '0';
+            return 0;
+    }
+}
+
+bool valid_card(const std::string &c) {
+    if (c.size() != 2) return false;
+    if (rank_value(c[0]) == 0) return false;
+    return c[1] == 'C' || c[1] == 'D' || c[1] == 'H' || c[1] == 'S';
+}
+
+// Resolve a spot to the card it names, or "" when the spot is not playable.
+std::string spot_card(const Pyramid *g, const std::string &spot) {
+    if (spot == "W")
+        return g->waste.empty() ? std::string() : g->waste.back();
+    if (spot.size() == 3 && spot[0] == 'P' &&
+        spot[1] >= '0' && spot[1] <= '6' && spot[2] >= '0' && spot[2] <= '6') {
+        int r = spot[1] - '0', c = spot[2] - '0';
+        if (pyr_exposed(g, r, c)) return g->spots[r][c];
+    }
+    return std::string();
+}
+
+void take_spot(Pyramid *g, const std::string &spot) {
+    if (spot == "W") {
+        g->waste.pop_back();
+    } else {
+        g->spots[spot[1] - '0'][spot[2] - '0'].clear();
+    }
+}
+
+}  // namespace
+
+bool pyr_load(Pyramid *g, const std::string &deal) {
+    *g = Pyramid{};
+    std::istringstream in(deal);
+    std::vector<std::string> cards;
+    std::set<std::string> seen;
+    std::string tok;
+    while (in >> tok) {
+        if (!valid_card(tok) || !seen.insert(tok).second) return false;
+        cards.push_back(tok);
+    }
+    if (cards.size() != 52) return false;
+    int i = 0;
+    for (int r = 0; r < 7; r++)
+        for (int c = 0; c <= r; c++) g->spots[r][c] = cards[i++];
+    g->stock.assign(cards.begin() + 28, cards.end());
+    g->ok = true;
+    return true;
+}
+
+bool pyr_exposed(const Pyramid *g, int row, int col) {
+    if (row < 0 || row > 6 || col < 0 || col > row) return false;
+    if (g->spots[row][col].empty()) return false;
+    if (row == 6) return true;
+    return g->spots[row + 1][col].empty() && g->spots[row + 1][col + 1].empty();
+}
+
+bool pyr_draw(Pyramid *g) {
+    if (g->stock.empty()) return false;
+    g->waste.push_back(g->stock.front());
+    g->stock.erase(g->stock.begin());
+    return true;
+}
+
+bool pyr_recycle(Pyramid *g) {
+    if (!g->stock.empty() || g->waste.empty() || g->recycles >= 2) return false;
+    g->stock = g->waste;   // waste[0] was drawn first, so it is drawn first again
+    g->waste.clear();
+    g->recycles++;
+    return true;
+}
+
+bool pyr_remove(Pyramid *g, const std::string &a, const std::string &b) {
+    if (a == b) return false;
+    std::string ca = spot_card(g, a), cb = spot_card(g, b);
+    if (ca.empty() || cb.empty()) return false;
+    if (rank_value(ca[0]) + rank_value(cb[0]) != 13) return false;
+    take_spot(g, a);
+    take_spot(g, b);
+    return true;
+}
+
+bool pyr_remove_king(Pyramid *g, const std::string &spot) {
+    std::string c = spot_card(g, spot);
+    if (c.empty() || c[0] != 'K') return false;
+    take_spot(g, spot);
+    return true;
+}
+
+int pyr_stock_size(const Pyramid *g) { return static_cast<int>(g->stock.size()); }
+
+int pyr_waste_size(const Pyramid *g) { return static_cast<int>(g->waste.size()); }
+
+std::string pyr_waste_top(const Pyramid *g) {
+    return g->waste.empty() ? std::string() : g->waste.back();
+}
+
+int pyr_state(const Pyramid *g) {
+    bool empty = true;
+    for (int r = 0; r < 7 && empty; r++)
+        for (int c = 0; c <= r; c++)
+            if (!g->spots[r][c].empty()) { empty = false; break; }
+    if (empty) return 1;
+    if (!g->stock.empty()) return 0;
+    if (!g->waste.empty() && g->recycles < 2) return 0;
+
+    std::vector<std::string> avail;
+    for (int r = 0; r < 7; r++)
+        for (int c = 0; c <= r; c++)
+            if (pyr_exposed(g, r, c)) avail.push_back(g->spots[r][c]);
+    if (!g->waste.empty()) avail.push_back(g->waste.back());
+    for (size_t i = 0; i < avail.size(); i++) {
+        if (avail[i][0] == 'K') return 0;
+        for (size_t j = i + 1; j < avail.size(); j++)
+            if (rank_value(avail[i][0]) + rank_value(avail[j][0]) == 13)
+                return 0;
+    }
+    return 2;
+}
+
+std::string pyr_render(const Pyramid *g) {
+    std::string out;
+    for (int r = 0; r < 7; r++) {
+        out += std::string(2 * (6 - r), ' ');
+        for (int c = 0; c <= r; c++) {
+            if (c) out += "  ";
+            out += g->spots[r][c].empty() ? "--" : g->spots[r][c];
+        }
+        out += '\n';
+    }
+    return out;
+}
diff --git a/pyramid.h b/pyramid.h
new file mode 100644
index 0000000..2003ae8
--- /dev/null
+++ b/pyramid.h
@@ -0,0 +1,27 @@
+#ifndef PYRAMID_H
+#define PYRAMID_H
+
+#include <string>
+#include <vector>
+
+struct Pyramid {
+    std::string spots[7][7];      // "" once removed (or never dealt)
+    std::vector<std::string> stock;   // front = next drawn
+    std::vector<std::string> waste;   // back = top
+    int recycles = 0;
+    bool ok = false;
+};
+
+bool pyr_load(Pyramid *g, const std::string &deal);
+bool pyr_exposed(const Pyramid *g, int row, int col);
+bool pyr_draw(Pyramid *g);
+bool pyr_recycle(Pyramid *g);
+bool pyr_remove(Pyramid *g, const std::string &a, const std::string &b);
+bool pyr_remove_king(Pyramid *g, const std::string &spot);
+int  pyr_stock_size(const Pyramid *g);
+int  pyr_waste_size(const Pyramid *g);
+std::string pyr_waste_top(const Pyramid *g);
+int  pyr_state(const Pyramid *g);
+std::string pyr_render(const Pyramid *g);
+
+#endif
