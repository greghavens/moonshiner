{
  "product": "MongoDB Atlas",
  "interface": "Atlas Administration API v2 + Service Account OAuth 2.0 token endpoint",
  "accept_media_type": "application/vnd.atlas.2023-01-01+json",
  "token_endpoint": {
    "method": "POST",
    "production_url": "https://cloud.mongodb.com/api/oauth/token",
    "fixture_path": "/api/oauth/token",
    "headers": {
      "authorization": "Basic base64(clientId:clientSecret) — the ONLY place the client secret may travel",
      "content_type": "application/x-www-form-urlencoded",
      "accept": "application/json"
    },
    "body": "grant_type=client_credentials",
    "success": {
      "access_token": "opaque bearer token string",
      "expires_in": 3600,
      "token_type": "Bearer"
    },
    "error_shape": {
      "error": "OAuth error code, e.g. invalid_client / invalid_request / unsupported_grant_type / rate_limited",
      "error_description": "human-readable description, e.g. \"Invalid credentials provided.\""
    },
    "token_lifetime_seconds": 3600,
    "early_refresh_margin_seconds": 60
  },
  "api_host": {
    "base": "https://cloud.mongodb.com (fixture: the loopback API host)",
    "auth": "Authorization: Bearer <access_token> on every /api/atlas/v2 request; Basic credentials must never reach this host",
    "list_projects": {
      "method": "GET",
      "path": "/api/atlas/v2/groups",
      "accept": "application/vnd.atlas.2023-01-01+json",
      "query_defaults": {
        "pageNum": 1,
        "itemsPerPage": 100,
        "itemsPerPage_max": 500,
        "includeCount": true
      },
      "response": {
        "results": "array of Group objects (required)",
        "links": "array of {href, rel}; rel values: self (always), next (omitted on the last page), previous (omitted on the first page)",
        "totalCount": "int, omitted when includeCount=false; an estimate"
      },
      "group_fields": {
        "id": "24-hex project id",
        "name": "project name",
        "orgId": "24-hex organization id",
        "created": "ISO 8601 UTC timestamp",
        "clusterCount": "int64 (required in responses)"
      }
    },
    "pagination_rule": "follow the rel=next href verbatim; absence of rel=next means last page; hrefs on a different host than the API base must be refused without being fetched",
    "error_envelope": {
      "content_type": "application/json",
      "fields": {
        "detail": "human-readable description",
        "error": "int HTTP status",
        "errorCode": "named constant, e.g. RESOURCE_NOT_FOUND",
        "parameters": "array",
        "reason": "HTTP status definition, e.g. Not Found"
      }
    },
    "wrong_or_missing_version_in_accept": "406 Not Acceptable"
  },
  "fixtures": {
    "client_id": "mdb_sa_id_fixture0123456789abcdef",
    "client_secret": "mdb_sa_sk_fixture_S3CRETdeadbeef42",
    "tokens": ["eyJfixture.access.token-ONE", "eyJfixture.access.token-TWO"],
    "org_id": "64aa11bb22cc33dd44ee55ff"
  }
}
