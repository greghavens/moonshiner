new file mode 100644
index 0000000..2d6988c
--- /dev/null
+++ b/projects.go
@@ -0,0 +1,133 @@
+package atlasadmin
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"net/url"
+)
+
+// Project is one Atlas project (group).
+type Project struct {
+	ID           string
+	Name         string
+	OrgID        string
+	Created      string
+	ClusterCount int64
+}
+
+type wireLink struct {
+	Href string `json:"href"`
+	Rel  string `json:"rel"`
+}
+
+type wireGroup struct {
+	ID           string `json:"id"`
+	Name         string `json:"name"`
+	OrgID        string `json:"orgId"`
+	Created      string `json:"created"`
+	ClusterCount int64  `json:"clusterCount"`
+}
+
+type wireGroupsPage struct {
+	Links      []wireLink  `json:"links"`
+	Results    []wireGroup `json:"results"`
+	TotalCount int64       `json:"totalCount"`
+}
+
+// Projects lists every project visible to the service account, following
+// the documented rel=next pagination links until the last page (which has
+// no rel=next). Server order is preserved.
+func (c *Client) Projects(ctx context.Context) ([]Project, error) {
+	next := c.cfg.BaseURL + "/api/atlas/v2/groups"
+	projects := []Project{}
+	for next != "" {
+		var page wireGroupsPage
+		if err := c.getJSON(ctx, next, groupsMediaType, &page); err != nil {
+			return nil, err
+		}
+		for _, g := range page.Results {
+			projects = append(projects, Project{
+				ID: g.ID, Name: g.Name, OrgID: g.OrgID,
+				Created: g.Created, ClusterCount: g.ClusterCount,
+			})
+		}
+		next = ""
+		for _, l := range page.Links {
+			if l.Rel != "next" {
+				continue
+			}
+			u, err := url.Parse(l.Href)
+			if err != nil {
+				return nil, fmt.Errorf("pagination: invalid rel=next href: %w", err)
+			}
+			// The Bearer token is only ever presented to the API host.
+			if u.Host != c.apiHost {
+				return nil, fmt.Errorf("pagination: refusing rel=next link off the API host %q (link host %q)", c.apiHost, u.Host)
+			}
+			next = l.Href
+			break
+		}
+	}
+	return projects, nil
+}
+
+// getJSON performs an authenticated GET with the given dated Accept media
+// type. On a 401 it discards the cached token, re-exchanges once, and
+// retries the request exactly once.
+func (c *Client) getJSON(ctx context.Context, rawURL, accept string, out any) error {
+	tok, err := c.bearer(ctx)
+	if err != nil {
+		return err
+	}
+	retried := false
+	for {
+		status, body, err := c.doGet(ctx, rawURL, accept, tok)
+		if err != nil {
+			return err
+		}
+		if status == http.StatusUnauthorized && !retried {
+			retried = true
+			c.invalidate(tok)
+			if tok, err = c.bearer(ctx); err != nil {
+				return err
+			}
+			continue
+		}
+		if status < 200 || status >= 300 {
+			return decodeAPIError(status, body)
+		}
+		return json.Unmarshal(body, out)
+	}
+}
+
+func (c *Client) doGet(ctx context.Context, rawURL, accept, tok string) (int, []byte, error) {
+	req, err := http.NewRequestWithContext(ctx, http.MethodGet, rawURL, nil)
+	if err != nil {
+		return 0, nil, err
+	}
+	req.Header.Set("Accept", accept)
+	req.Header.Set("Authorization", "Bearer "+tok)
+	resp, err := c.http.Do(req)
+	if err != nil {
+		return 0, nil, fmt.Errorf("atlas: GET failed: %w", err)
+	}
+	defer resp.Body.Close()
+	body, err := io.ReadAll(io.LimitReader(resp.Body, 8<<20))
+	if err != nil {
+		return 0, nil, fmt.Errorf("atlas: reading response: %w", err)
+	}
+	return resp.StatusCode, body, nil
+}
+
+func decodeAPIError(status int, body []byte) error {
+	var wire struct {
+		Detail    string `json:"detail"`
+		ErrorCode string `json:"errorCode"`
+		Reason    string `json:"reason"`
+	}
+	_ = json.Unmarshal(body, &wire)
+	return &APIError{StatusCode: status, ErrorCode: wire.ErrorCode, Detail: wire.Detail, Reason: wire.Reason}
+}
diff --git a/token.go b/token.go
new file mode 100644
index 0000000..740a71c
--- /dev/null
+++ b/token.go
@@ -0,0 +1,86 @@
+package atlasadmin
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"io"
+	"net/http"
+	"strings"
+	"time"
+)
+
+type tokenResponse struct {
+	AccessToken string `json:"access_token"`
+	ExpiresIn   int64  `json:"expires_in"`
+	TokenType   string `json:"token_type"`
+}
+
+type tokenErrorBody struct {
+	Error            string `json:"error"`
+	ErrorDescription string `json:"error_description"`
+}
+
+// bearer returns a valid cached access token or performs one
+// client-credentials exchange. The mutex is held across the exchange so
+// concurrent callers share a single in-flight request.
+func (c *Client) bearer(ctx context.Context) (string, error) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	if c.token != "" && c.now().Before(c.tokenExp.Add(-refreshMargin)) {
+		return c.token, nil
+	}
+	tok, exp, err := c.exchange(ctx)
+	if err != nil {
+		return "", err
+	}
+	c.token, c.tokenExp = tok, exp
+	return tok, nil
+}
+
+// invalidate drops the cached token if it is still the one that just failed,
+// so exactly one re-exchange happens per stale token.
+func (c *Client) invalidate(tok string) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	if c.token == tok {
+		c.token = ""
+	}
+}
+
+func (c *Client) exchange(ctx context.Context) (string, time.Time, error) {
+	req, err := http.NewRequestWithContext(ctx, http.MethodPost, c.cfg.TokenURL,
+		strings.NewReader("grant_type=client_credentials"))
+	if err != nil {
+		return "", time.Time{}, err
+	}
+	// The Basic credential travels only to the token host.
+	req.SetBasicAuth(c.cfg.ClientID, c.cfg.ClientSecret)
+	req.Header.Set("Content-Type", "application/x-www-form-urlencoded")
+	req.Header.Set("Accept", "application/json")
+
+	resp, err := c.http.Do(req)
+	if err != nil {
+		return "", time.Time{}, fmt.Errorf("token exchange: %w", err)
+	}
+	defer resp.Body.Close()
+	body, err := io.ReadAll(io.LimitReader(resp.Body, 1<<20))
+	if err != nil {
+		return "", time.Time{}, fmt.Errorf("token exchange: reading response: %w", err)
+	}
+	if resp.StatusCode < 200 || resp.StatusCode >= 300 {
+		var oe tokenErrorBody
+		if json.Unmarshal(body, &oe) == nil && oe.Error != "" {
+			return "", time.Time{}, &TokenError{Code: oe.Error, Description: oe.ErrorDescription}
+		}
+		return "", time.Time{}, &TokenError{Code: fmt.Sprintf("http_%d", resp.StatusCode)}
+	}
+	var tr tokenResponse
+	if err := json.Unmarshal(body, &tr); err != nil {
+		return "", time.Time{}, fmt.Errorf("token exchange: decoding response: %w", err)
+	}
+	if tr.AccessToken == "" {
+		return "", time.Time{}, &TokenError{Code: "invalid_response", Description: "missing access_token"}
+	}
+	return tr.AccessToken, c.now().Add(time.Duration(tr.ExpiresIn) * time.Second), nil
+}
