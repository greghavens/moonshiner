index 0000000..da98d1a
--- /dev/null
+++ b/client.go
@@ -0,0 +1,75 @@
+// Package atlasadmin is a minimal client for the MongoDB Atlas
+// Administration API v2 authenticated with an OAuth 2.0 service account.
+//
+// Wire contract researched from the official MongoDB documentation:
+//   - https://www.mongodb.com/docs/atlas/api/service-accounts/generate-oauth2-token/
+//   - https://www.mongodb.com/docs/atlas/api/atlas-admin-api-ref/
+//   - https://www.mongodb.com/docs/api/doc/atlas-admin-api-v2/operation/operation-listprojects
+package atlasadmin
+
+import (
+	"errors"
+	"net/http"
+	"net/url"
+	"sync"
+	"time"
+)
+
+// groupsMediaType is the current stable dated media type for the groups
+// (projects) resource.
+const groupsMediaType = "application/vnd.atlas.2023-01-01+json"
+
+// refreshMargin is how long before expires_in the cached token is
+// considered stale. The token endpoint is rate limited (10/min), so tokens
+// are cached and re-exchanged only near expiry.
+const refreshMargin = 60 * time.Second
+
+type Config struct {
+	// TokenURL is the full URL of the OAuth token endpoint
+	// (production: https://cloud.mongodb.com/api/oauth/token).
+	TokenURL string
+	// BaseURL is the API host base (production: https://cloud.mongodb.com).
+	BaseURL      string
+	ClientID     string
+	ClientSecret string
+	// HTTPClient defaults to http.DefaultClient.
+	HTTPClient *http.Client
+	// Now defaults to time.Now; injected so token expiry is testable.
+	Now func() time.Time
+}
+
+type Client struct {
+	cfg     Config
+	http    *http.Client
+	now     func() time.Time
+	apiHost string // host the Bearer token is allowed to reach
+
+	mu       sync.Mutex
+	token    string
+	tokenExp time.Time
+}
+
+func New(cfg Config) (*Client, error) {
+	switch {
+	case cfg.TokenURL == "":
+		return nil, errors.New("atlasadmin: Config.TokenURL is required")
+	case cfg.BaseURL == "":
+		return nil, errors.New("atlasadmin: Config.BaseURL is required")
+	case cfg.ClientID == "":
+		return nil, errors.New("atlasadmin: Config.ClientID is required")
+	case cfg.ClientSecret == "":
+		return nil, errors.New("atlasadmin: Config.ClientSecret is required")
+	}
+	base, err := url.Parse(cfg.BaseURL)
+	if err != nil || base.Host == "" {
+		return nil, errors.New("atlasadmin: Config.BaseURL is not an absolute URL")
+	}
+	c := &Client{cfg: cfg, http: cfg.HTTPClient, now: cfg.Now, apiHost: base.Host}
+	if c.http == nil {
+		c.http = http.DefaultClient
+	}
+	if c.now == nil {
+		c.now = time.Now
+	}
+	return c, nil
+}
