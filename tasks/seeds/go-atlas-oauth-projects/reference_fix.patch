+package atlasadmin
+
+import "fmt"
+
+// APIError is the documented Atlas Administration API error envelope
+// (application/json: detail, error, errorCode, parameters, reason).
+type APIError struct {
+	StatusCode int
+	ErrorCode  string
+	Detail     string
+	Reason     string
+}
+
+func (e *APIError) Error() string {
+	return fmt.Sprintf("atlas: %d %s (%s): %s", e.StatusCode, e.Reason, e.ErrorCode, e.Detail)
+}
+
+// TokenError is the documented OAuth error body returned by the service
+// account token endpoint ({error, error_description}).
+type TokenError struct {
+	Code        string
+	Description string
+}
+
+func (e *TokenError) Error() string {
+	return fmt.Sprintf("atlas token exchange: %s: %s", e.Code, e.Description)
+}
