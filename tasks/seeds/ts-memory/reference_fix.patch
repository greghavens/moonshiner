+// Two-player concentration (memory) engine. Card layouts are fixtures —
+// a grid of uppercase letters, each appearing exactly twice — and every
+// state transition is a pure function over plain data.
+
+export type Player = 1 | 2;
+
+export interface Game {
+  readonly rows: number;
+  readonly cols: number;
+  readonly cards: ReadonlyArray<ReadonlyArray<string>>;
+  readonly matched: ReadonlyArray<ReadonlyArray<boolean>>;
+  readonly up: readonly [number, number] | null; // first card of the current pair
+  readonly current: Player;
+  readonly scores: readonly [number, number]; // [P1, P2] pairs won
+  readonly pairsDone: number; // completed (second) flips so far
+}
+
+export function newGame(layout: string): Game {
+  const lines = layout.split('\n');
+  while (lines.length > 0 && lines[lines.length - 1] === '') lines.pop();
+  if (lines.length === 0 || lines[0].length === 0) throw new Error('empty layout');
+  const cols = lines[0].length;
+  const seen = new Map<string, number>();
+  const cards = lines.map((line, r) => {
+    if (line.length !== cols) throw new Error(`ragged layout at line ${r + 1}`);
+    return [...line].map((ch) => {
+      if (ch < 'A' || ch > 'Z') throw new Error(`bad card symbol: ${JSON.stringify(ch)}`);
+      seen.set(ch, (seen.get(ch) ?? 0) + 1);
+      return ch;
+    });
+  });
+  for (const [sym, n] of seen) {
+    if (n !== 2) throw new Error(`symbol ${sym} appears ${n} times, want 2`);
+  }
+  return {
+    rows: cards.length,
+    cols,
+    cards,
+    matched: cards.map((row) => row.map(() => false)),
+    up: null,
+    current: 1,
+    scores: [0, 0],
+    pairsDone: 0,
+  };
+}
+
+export function isOver(game: Game): boolean {
+  return game.matched.every((row) => row.every(Boolean));
+}
+
+export function winner(game: Game): Player | 'tie' | null {
+  if (!isOver(game)) return null;
+  if (game.scores[0] > game.scores[1]) return 1;
+  if (game.scores[1] > game.scores[0]) return 2;
+  return 'tie';
+}
+
+export function flip(game: Game, r: number, c: number): Game {
+  if (!Number.isInteger(r) || !Number.isInteger(c) ||
+      r < 0 || r >= game.rows || c < 0 || c >= game.cols) {
+    throw new RangeError(`card out of range: (${r}, ${c})`);
+  }
+  if (isOver(game)) throw new Error('game is over');
+  if (game.matched[r][c]) throw new Error(`card (${r}, ${c}) is already matched`);
+  if (game.up && game.up[0] === r && game.up[1] === c) {
+    throw new Error(`card (${r}, ${c}) is already face up`);
+  }
+  if (game.up === null) {
+    return { ...game, up: [r, c] };
+  }
+  const [ur, uc] = game.up;
+  const match = game.cards[ur][uc] === game.cards[r][c];
+  if (match) {
+    const matched = game.matched.map((row) => row.slice());
+    matched[ur][uc] = true;
+    matched[r][c] = true;
+    const scores: [number, number] = [...game.scores] as [number, number];
+    scores[game.current - 1]++;
+    // a match means the same player goes again
+    return { ...game, matched, up: null, scores, pairsDone: game.pairsDone + 1 };
+  }
+  return {
+    ...game,
+    up: null,
+    current: game.current === 1 ? 2 : 1,
+    pairsDone: game.pairsDone + 1,
+  };
+}
+
+// Table view: '#' face-down, the pending face-up card uppercase, matched
+// pairs lowercase. Rows joined with \n, no trailing newline.
+export function render(game: Game): string {
+  return game.cards
+    .map((row, r) =>
+      row
+        .map((sym, c) => {
+          if (game.matched[r][c]) return sym.toLowerCase();
+          if (game.up && game.up[0] === r && game.up[1] === c) return sym;
+          return '#';
+        })
+        .join(''),
+    )
+    .join('\n');
+}
+
+// Harness peek: every card face visible, matched pairs lowercase.
+export function peek(game: Game): string {
+  return game.cards
+    .map((row, r) =>
+      row.map((sym, c) => (game.matched[r][c] ? sym.toLowerCase() : sym)).join(''),
+    )
+    .join('\n');
+}
+
+// Replay a scripted flip sequence and narrate it. Each flip logs
+// 'P<n> flips (r,c)=S'; a completed pair adds 'P<n> match S -> <score>' or
+// 'no match -> P<other>'; when the last pair falls the transcript closes
+// with 'final P1=<a> P2=<b>' and 'winner: P<n>' (or 'winner: tie').
+export function transcript(layout: string, flips: ReadonlyArray<readonly [number, number]>): string {
+  let game = newGame(layout);
+  const lines: string[] = [];
+  for (const [r, c] of flips) {
+    const mover = game.current;
+    const wasUp = game.up !== null;
+    const next = flip(game, r, c);
+    lines.push(`P${mover} flips (${r},${c})=${game.cards[r][c]}`);
+    if (wasUp) {
+      if (next.scores[mover - 1] > game.scores[mover - 1]) {
+        lines.push(`P${mover} match ${game.cards[r][c]} -> ${next.scores[mover - 1]}`);
+      } else {
+        lines.push(`no match -> P${next.current}`);
+      }
+    }
+    game = next;
+    if (isOver(game)) {
+      lines.push(`final P1=${game.scores[0]} P2=${game.scores[1]}`);
+      const w = winner(game);
+      lines.push(`winner: ${w === 'tie' ? 'tie' : `P${w}`}`);
+      break;
+    }
+  }
+  return lines.join('\n');
+}
