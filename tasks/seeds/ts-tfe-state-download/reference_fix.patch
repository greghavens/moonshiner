+// Hosted-state download: pre-signed URL fetching with a strict cross-origin
+// credential policy, integrity verification, and atomic writes.
+
+import crypto from 'node:crypto';
+import fs from 'node:fs';
+import path from 'node:path';
+
+import { TfeClient } from './client.ts';
+
+export class NoStateError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'NoStateError';
+  }
+}
+
+export class StateNotReadyError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'StateNotReadyError';
+  }
+}
+
+export class IntegrityError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'IntegrityError';
+  }
+}
+
+const MAX_REDIRECTS = 3;
+
+// GET the hosted-state-download-url. The bearer token is attached only when
+// the request origin is exactly the TFE API origin; redirects are followed
+// manually (at most MAX_REDIRECTS) with the auth decision remade per hop, so
+// the token never travels to a foreign origin.
+export async function downloadHostedState(client: TfeClient, url: string): Promise<Buffer> {
+  let current = url;
+  for (let hop = 0; hop <= MAX_REDIRECTS; hop++) {
+    const headers: Record<string, string> = {};
+    if (new URL(current).origin === client.origin) {
+      headers.authorization = `Bearer ${client.token}`;
+    }
+    const resp = await fetch(current, { headers, redirect: 'manual' });
+    if (resp.status >= 300 && resp.status < 400) {
+      const location = resp.headers.get('location');
+      if (location === null) {
+        throw new Error(`redirect response ${resp.status} without a Location header`);
+      }
+      await resp.arrayBuffer().catch(() => undefined);
+      current = new URL(location, current).toString();
+      continue;
+    }
+    if (!resp.ok) {
+      throw new Error(`hosted state download failed: HTTP ${resp.status}`);
+    }
+    return Buffer.from(await resp.arrayBuffer());
+  }
+  throw new Error(`too many redirects (more than ${MAX_REDIRECTS}) downloading hosted state`);
+}
+
+export interface DownloadResult {
+  stateVersionId: string;
+  serial: number;
+  bytesWritten: number;
+  path: string;
+}
+
+// Resolve the workspace's current state version, verify it, and write the
+// raw state atomically to destPath.
+export async function downloadCurrentState(
+  client: TfeClient,
+  org: string,
+  name: string,
+  destPath: string,
+): Promise<DownloadResult> {
+  const ws = await client.resolveWorkspace(org, name);
+  if (ws.currentStateVersionId === null) {
+    throw new NoStateError(`workspace ${org}/${name} has never stored state`);
+  }
+  const sv = await client.getStateVersion(ws.currentStateVersionId);
+  if (sv.status !== 'finalized') {
+    throw new StateNotReadyError(`state version ${sv.id} has status ${sv.status}, not finalized`);
+  }
+
+  const bytes = await downloadHostedState(client, sv.downloadUrl);
+  if (sv.size !== null && bytes.length !== sv.size) {
+    throw new IntegrityError(
+      `size mismatch: downloaded ${bytes.length} bytes but the state version reports ${sv.size}`,
+    );
+  }
+  let payloadSerial: unknown;
+  try {
+    payloadSerial = JSON.parse(bytes.toString('utf8')).serial;
+  } catch {
+    throw new IntegrityError('downloaded state is not valid JSON');
+  }
+  if (payloadSerial !== sv.serial) {
+    throw new IntegrityError(
+      `serial mismatch: payload carries ${String(payloadSerial)} but the state version reports ${sv.serial}`,
+    );
+  }
+
+  const dir = path.dirname(destPath);
+  const tmp = path.join(
+    dir,
+    `.${path.basename(destPath)}.tmp-${crypto.randomBytes(6).toString('hex')}`,
+  );
+  fs.writeFileSync(tmp, bytes);
+  try {
+    fs.renameSync(tmp, destPath);
+  } catch (err) {
+    fs.rmSync(tmp, { force: true });
+    throw err;
+  }
+  return { stateVersionId: sv.id, serial: sv.serial, bytesWritten: bytes.length, path: destPath };
+}
