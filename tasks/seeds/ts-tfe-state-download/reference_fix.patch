+// Terraform Enterprise /api/v2 JSON:API client: workspace resolution and
+// state-version metadata.
+
+export interface JsonApiErrorObject {
+  status: string;
+  title: string;
+  detail: string;
+}
+
+// Any non-2xx /api/v2 response. Note TFE answers 404 both for resources
+// that do not exist and for resources the token is not authorized to see.
+export class ApiError extends Error {
+  statusCode: number;
+  errors: JsonApiErrorObject[];
+
+  constructor(statusCode: number, errors: JsonApiErrorObject[]) {
+    const detail = errors.map((e) => `${e.status} ${e.title}: ${e.detail}`).join('; ')
+      || `HTTP ${statusCode}`;
+    super(`TFE API error: ${detail}`);
+    this.name = 'ApiError';
+    this.statusCode = statusCode;
+    this.errors = errors;
+  }
+}
+
+export interface WorkspaceRef {
+  id: string;
+  currentStateVersionId: string | null;
+}
+
+export interface StateVersion {
+  id: string;
+  status: string;
+  serial: number;
+  size: number | null;
+  resourcesProcessed: boolean;
+  downloadUrl: string;
+  jsonDownloadUrl: string | null;
+}
+
+export class TfeClient {
+  readonly baseUrl: string;
+  readonly token: string;
+
+  constructor(baseUrl: string, token: string) {
+    this.baseUrl = baseUrl.replace(/\/+$/, '');
+    this.token = token;
+  }
+
+  get origin(): string {
+    return new URL(this.baseUrl).origin;
+  }
+
+  async getJson(apiPath: string): Promise<any> {
+    const resp = await fetch(this.baseUrl + apiPath, {
+      headers: { authorization: `Bearer ${this.token}` },
+    });
+    const raw = await resp.text();
+    if (!resp.ok) {
+      let errors: JsonApiErrorObject[] = [];
+      try {
+        errors = JSON.parse(raw).errors ?? [];
+      } catch {
+        // non-JSON error body: keep the empty errors array
+      }
+      throw new ApiError(resp.status, errors);
+    }
+    return JSON.parse(raw);
+  }
+
+  async resolveWorkspace(org: string, name: string): Promise<WorkspaceRef> {
+    const doc = await this.getJson(
+      `/api/v2/organizations/${encodeURIComponent(org)}/workspaces/${encodeURIComponent(name)}`,
+    );
+    const linkage = doc.data?.relationships?.['current-state-version']?.data ?? null;
+    return { id: doc.data.id, currentStateVersionId: linkage === null ? null : linkage.id };
+  }
+
+  async getStateVersion(id: string): Promise<StateVersion> {
+    const doc = await this.getJson(`/api/v2/state-versions/${encodeURIComponent(id)}`);
+    const attrs = doc.data.attributes;
+    return {
+      id: doc.data.id,
+      status: attrs.status,
+      serial: attrs.serial,
+      size: attrs.size ?? null,
+      resourcesProcessed: attrs['resources-processed'] ?? false,
+      downloadUrl: attrs['hosted-state-download-url'],
+      jsonDownloadUrl: attrs['hosted-json-state-download-url'] ?? null,
+    };
+  }
+}
