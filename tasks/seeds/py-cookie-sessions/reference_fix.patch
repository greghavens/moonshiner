+    def _touch(self, record):
+        now = self.clock()
+        record["last_active"] = now
+        record["expires_at"] = now + self.ttl
+
+    def _evict_for_cap(self, user_id, now):
+        live = []
+        for session_id, record in list(self._sessions.items()):
+            if now >= record["expires_at"]:
