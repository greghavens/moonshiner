+    # ------------------------------------------------------------- signed cookies
+
+    def cookie_value(self, session_id):
+        """The value to set in the cookie: '<session_id>.<hex signature>'."""
+        return f"{session_id}.{self._sign(session_id)}"
+
+    def session_from_cookie(self, value):
+        """Session id for a validly signed cookie of a live session, else None."""
+        self._require_secret()
+        if not isinstance(value, str) or "." not in value:
+            return None
+        session_id, _, signature = value.partition(".")
+        if not session_id or not signature:
+            return None
+        if not hmac.compare_digest(self._sign(session_id), signature):
+            return None
+        record = self._live_record(session_id)
+        if record is None:
+            return None
+        self._touch(record)
+        return session_id
+
+    # ------------------------------------------------------------------ internals
+
+    def _require_secret(self):
+        if self.secret is None:
+            raise RuntimeError("SessionStore was built without a secret")
+
+    def _sign(self, session_id):
+        self._require_secret()
+        return hmac.new(self.secret, session_id.encode("utf-8"), hashlib.sha256).hexdigest()
+
+    def _live_record(self, session_id):
