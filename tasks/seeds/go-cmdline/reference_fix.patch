+package cmdline
+
+import (
+	"fmt"
+	"regexp"
+	"sort"
+	"strings"
+)
+
+// bareSafe matches elements that need no quoting for a POSIX shell.
+var bareSafe = regexp.MustCompile(`^[A-Za-z0-9_@%+=:,./-]+$`)
+
+// Quoted renders the command so it can be handed to a POSIX shell
+// verbatim: safe elements pass through bare, everything else is
+// single-quoted with embedded single quotes escaped as '\''. The
+// empty string renders as ''.
+func (c *Command) Quoted() string {
+	parts := make([]string, 0, len(c.args)+1)
+	for _, a := range c.Args() {
+		parts = append(parts, quoteElem(a))
+	}
+	return strings.Join(parts, " ")
+}
+
+func quoteElem(s string) string {
+	if s == "" {
+		return "''"
+	}
+	if bareSafe.MatchString(s) {
+		return s
+	}
+	return "'" + strings.ReplaceAll(s, "'", `'\''`) + "'"
+}
+
+// ExpandMode controls what Expand does with a ${NAME} reference that
+// has no entry in the variable map.
+type ExpandMode int
+
+const (
+	// Strict makes a missing variable an error.
+	Strict ExpandMode = iota
+	// Lenient substitutes the empty string for a missing variable.
+	Lenient
+)
+
+// Expand returns a copy of the command with every ${NAME} reference
+// replaced from vars (never from the process environment). NAME is
+// letters, digits, and underscore, not starting with a digit. An
+// unterminated ${ is an error in both modes; a bare $ is literal.
+// The receiver is not modified.
+func (c *Command) Expand(vars map[string]string, mode ExpandMode) (*Command, error) {
+	return c.rewrite(func(s string) (string, error) {
+		return expandRefs(s, vars, mode)
+	})
+}
+
+func expandRefs(s string, vars map[string]string, mode ExpandMode) (string, error) {
+	var b strings.Builder
+	for i := 0; i < len(s); {
+		if s[i] == '$' && i+1 < len(s) && s[i+1] == '{' {
+			end := strings.IndexByte(s[i+2:], '}')
+			if end < 0 {
+				return "", fmt.Errorf("cmdline: unterminated ${ in %q", s)
+			}
+			name := s[i+2 : i+2+end]
+			if !validVarName(name) {
+				return "", fmt.Errorf("cmdline: invalid variable name %q in %q", name, s)
+			}
+			val, ok := vars[name]
+			if !ok && mode == Strict {
+				return "", fmt.Errorf("cmdline: undefined variable %q in %q", name, s)
+			}
+			b.WriteString(val)
+			i += end + 3
+			continue
+		}
+		b.WriteByte(s[i])
+		i++
+	}
+	return b.String(), nil
+}
+
+func validVarName(name string) bool {
+	if name == "" {
+		return false
+	}
+	for i := 0; i < len(name); i++ {
+		c := name[i]
+		switch {
+		case c == '_', c >= 'a' && c <= 'z', c >= 'A' && c <= 'Z':
+		case c >= '0' && c <= '9':
+			if i == 0 {
+				return false
+			}
+		default:
+			return false
+		}
+	}
+	return true
+}
+
+// placeholder matches {name} template slots: lowercase letters,
+// digits, and underscore, starting with a letter. Anything else in
+// braces is literal text.
+var placeholder = regexp.MustCompile(`\{[a-z][a-z0-9_]*\}`)
+
+// Fill returns a copy of the command with every {name} placeholder
+// replaced from bindings. Validation is two-way: a placeholder with
+// no binding is an error, and a binding that is never used is an
+// error too. The receiver is not modified.
+func (c *Command) Fill(bindings map[string]string) (*Command, error) {
+	used := make(map[string]bool, len(bindings))
+	out, err := c.rewrite(func(s string) (string, error) {
+		var missing error
+		filled := placeholder.ReplaceAllStringFunc(s, func(m string) string {
+			name := m[1 : len(m)-1]
+			val, ok := bindings[name]
+			if !ok {
+				if missing == nil {
+					missing = fmt.Errorf("cmdline: no binding for placeholder {%s} in %q", name, s)
+				}
+				return m
+			}
+			used[name] = true
+			return val
+		})
+		return filled, missing
+	})
+	if err != nil {
+		return nil, err
+	}
+	var unused []string
+	for name := range bindings {
+		if !used[name] {
+			unused = append(unused, name)
+		}
+	}
+	if len(unused) > 0 {
+		sort.Strings(unused)
+		return nil, fmt.Errorf("cmdline: unused bindings: %s", strings.Join(unused, ", "))
+	}
+	return out, nil
+}
+
+// rewrite applies f to the executable name and every argument,
+// producing a new Command.
+func (c *Command) rewrite(f func(string) (string, error)) (*Command, error) {
+	name, err := f(c.name)
+	if err != nil {
+		return nil, err
+	}
+	args := make([]string, len(c.args))
+	for i, a := range c.args {
+		if args[i], err = f(a); err != nil {
+			return nil, err
+		}
+	}
+	return &Command{name: name, args: args}, nil
+}
