+// One shared quoting layer for the filename filter box: a regex escaper
+// that touches exactly the metacharacters and a glob-to-RegExp compiler
+// built on top of it.
+
+const SPECIALS = new Set([
+  ".", "*", "+", "?", "^", "$", "{", "}", "(", ")", "|", "[", "]", "\\",
+]);
+
+export function escapeRegExp(text: string): string {
+  let out = "";
+  for (const ch of text) {
+    out += SPECIALS.has(ch) ? "\\" + ch : ch;
+  }
+  return out;
+}
+
+// Characters that need a backslash when they appear as class members.
+const CLASS_SPECIALS = new Set(["\\", "]", "^", "-"]);
+
+function translateClass(glob: string, start: number): { body: string; end: number } {
+  // start points at the '['. Returns the regex class and the index after ']'.
+  let i = start + 1;
+  let body = "[";
+  if (glob[i] === "!") {
+    body += "^";
+    i++;
+  }
+  let members = 0;
+  while (i < glob.length && glob[i] !== "]") {
+    let ch = glob[i];
+    if (ch === "\\") {
+      if (i + 1 >= glob.length) {
+        throw new Error("trailing backslash in pattern");
+      }
+      const lit = glob[i + 1];
+      body += CLASS_SPECIALS.has(lit) ? "\\" + lit : lit;
+      i += 2;
+    } else {
+      body += ch === "^" || ch === "\\" ? "\\" + ch : ch;
+      i += 1;
+    }
+    members++;
+  }
+  if (i >= glob.length) {
+    throw new Error("unterminated character class");
+  }
+  if (members === 0) {
+    throw new Error("empty character class");
+  }
+  return { body: body + "]", end: i + 1 };
+}
+
+export function globToRegExp(glob: string): RegExp {
+  let source = "^";
+  let i = 0;
+  while (i < glob.length) {
+    const ch = glob[i];
+    if (ch === "*") {
+      source += "[^/]*";
+      i++;
+    } else if (ch === "?") {
+      source += "[^/]";
+      i++;
+    } else if (ch === "\\") {
+      if (i + 1 >= glob.length) {
+        throw new Error("trailing backslash in pattern");
+      }
+      source += escapeRegExp(glob[i + 1]);
+      i += 2;
+    } else if (ch === "[") {
+      const cls = translateClass(glob, i);
+      source += cls.body;
+      i = cls.end;
+    } else {
+      source += escapeRegExp(ch);
+      i++;
+    }
+  }
+  return new RegExp(source + "$");
+}
