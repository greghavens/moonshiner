+// SystemClock is the production Clock: the wall clock.
+type SystemClock struct{}
+
+// Now implements Clock.
+func (SystemClock) Now() time.Time { return time.Now() }
+
+// OSStore is the production Store: one directory of checkpoint files.
+type OSStore struct {
+	dir string
+}
+
+// NewOSStore creates dir if needed and returns a Store over it.
+func NewOSStore(dir string) (*OSStore, error) {
+	if err := os.MkdirAll(dir, 0o755); err != nil {
+		return nil, err
+	}
+	return &OSStore{dir: dir}, nil
+}
+
+// Write implements Store.
+func (s *OSStore) Write(name string, data []byte) error {
+	return os.WriteFile(filepath.Join(s.dir, name), data, 0o644)
+}
+
+// Read implements Store.
+func (s *OSStore) Read(name string) ([]byte, error) {
+	return os.ReadFile(filepath.Join(s.dir, name))
+}
+
+// List implements Store: file names only, subdirectories skipped.
+func (s *OSStore) List() ([]string, error) {
+	entries, err := os.ReadDir(s.dir)
+	if err != nil {
+		return nil, err
+	}
+	var names []string
+	for _, e := range entries {
+		if e.IsDir() {
+			continue
+		}
+		names = append(names, e.Name())
+	}
+	return names, nil
+}
+
+// Remove implements Store.
+func (s *OSStore) Remove(name string) error {
+	return os.Remove(filepath.Join(s.dir, name))
+}
