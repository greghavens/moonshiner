diff --git a/walkplan.ps1 b/walkplan.ps1
new file mode 100644
index 0000000..1e303b9
--- /dev/null
+++ b/walkplan.ps1
@@ -0,0 +1,39 @@
+# walkplan.ps1 — cleanup inventory for a tree full of awkward real-world names.
+# Usage: pwsh -NoProfile -File walkplan.ps1 -Root <dir>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Root
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if (-not (Test-Path -LiteralPath $Root -PathType Container)) {
+    [Console]::Error.WriteLine("walkplan: root not found: $Root")
+    exit 66
+}
+
+$rootFull = (Get-Item -LiteralPath $Root -Force).FullName
+
+$actionByExt = @{
+    '.log'  = 'compress'
+    '.tmp'  = 'delete'
+    '.bak'  = 'delete'
+    '.cfg'  = 'keep'
+    '.conf' = 'keep'
+}
+
+$lineByRel = [System.Collections.Generic.Dictionary[string, string]]::new([System.StringComparer]::Ordinal)
+foreach ($file in @(Get-ChildItem -LiteralPath $rootFull -Recurse -Force -File)) {
+    $rel = $file.FullName.Substring($rootFull.Length + 1) -replace '\\', '/'
+    $ext = $file.Extension.ToLowerInvariant()
+    $action = if ($actionByExt.ContainsKey($ext)) { $actionByExt[$ext] } else { 'review' }
+    $lineByRel[$rel] = "$action $($file.Length) $rel"
+}
+
+$keys = [string[]]@($lineByRel.Keys)
+[Array]::Sort($keys, [System.StringComparer]::Ordinal)
+foreach ($k in $keys) {
+    Write-Output $lineByRel[$k]
+}
+exit 0
