+// Package resumeup provides a resumable-upload client for tus-style offset protocols.
+package resumeup
+
+import (
+	"bytes"
+	"context"
+	"fmt"
+	"io"
+	"net/http"
+	"strconv"
+)
+
+const defaultChunkSize = 4 * 1024 * 1024 // 4 MiB
+
+// Option configures an Uploader.
+type Option func(*Uploader)
+
+// ChunkSize sets the maximum body size (bytes) for each PATCH request.
+func ChunkSize(n int) Option {
+	return func(u *Uploader) { u.chunkSize = n }
+}
+
+// Uploader sends data to a URL that speaks the HEAD+PATCH offset protocol.
+type Uploader struct {
+	client    *http.Client
+	chunkSize int
+}
+
+// New creates an Uploader with the given HTTP client.
+func New(client *http.Client, opts ...Option) *Uploader {
+	u := &Uploader{
+		client:    client,
+		chunkSize: defaultChunkSize,
+	}
+	for _, o := range opts {
+		o(u)
+	}
+	return u
+}
+
+// Upload sends data to url, resuming from the server's authoritative offset.
+func (u *Uploader) Upload(ctx context.Context, url string, data []byte) error {
+	offset, err := u.probe(ctx, url)
+	if err != nil {
+		return err
+	}
+	if offset >= int64(len(data)) {
+		return nil // already complete
+	}
+	return u.send(ctx, url, data, offset)
+}
+
+// probe issues a HEAD and returns the server's current Upload-Offset.
+func (u *Uploader) probe(ctx context.Context, url string) (int64, error) {
+	req, err := http.NewRequestWithContext(ctx, http.MethodHead, url, nil)
+	if err != nil {
+		return 0, err
+	}
+	resp, err := u.client.Do(req)
+	if err != nil {
+		return 0, err
+	}
+	resp.Body.Close()
+	raw := resp.Header.Get("Upload-Offset")
+	if raw == "" {
+		return 0, fmt.Errorf("resumeup: HEAD %s: no Upload-Offset header", url)
+	}
+	off, err := strconv.ParseInt(raw, 10, 64)
+	if err != nil {
+		return 0, fmt.Errorf("resumeup: HEAD %s: bad Upload-Offset %q: %w", url, raw, err)
+	}
+	return off, nil
+}
+
+// send transmits data[offset:] in chunks, handling 409 by re-probing.
+func (u *Uploader) send(ctx context.Context, url string, data []byte, offset int64) error {
+	for offset < int64(len(data)) {
+		end := offset + int64(u.chunkSize)
+		if end > int64(len(data)) {
+			end = int64(len(data))
+		}
+		chunk := data[offset:end]
+
+		req, err := http.NewRequestWithContext(ctx, http.MethodPatch, url,
+			bytes.NewReader(chunk))
+		if err != nil {
+			return err
+		}
+		req.Header.Set("Content-Type", "application/offset+octet-stream")
+		req.Header.Set("Upload-Offset", strconv.FormatInt(offset, 10))
+		req.ContentLength = int64(len(chunk))
+
+		resp, err := u.client.Do(req)
+		if err != nil {
+			return err
+		}
+		body, _ := io.ReadAll(resp.Body)
+		resp.Body.Close()
+
+		switch resp.StatusCode {
+		case http.StatusNoContent: // 204: chunk accepted
+			offset = end
+
+		case http.StatusOK: // 200: check for completion signal
+			if resp.Header.Get("Upload-Complete") == "true" {
+				return nil
+			}
+			offset = end
+
+		case http.StatusConflict: // 409: offset mismatch — re-probe
+			newOffset, err := u.probe(ctx, url)
+			if err != nil {
+				return fmt.Errorf("resumeup: re-probe after 409: %w", err)
+			}
+			if newOffset >= int64(len(data)) {
+				return nil // server already has the full payload
+			}
+			offset = newOffset
+
+		default:
+			return fmt.Errorf("resumeup: PATCH %s at offset %d: HTTP %d: %s",
+				url, offset, resp.StatusCode, body)
+		}
+	}
+	return nil
+}
