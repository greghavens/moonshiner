--- a/CrewBoard.java
+++ b/CrewBoard.java
@@ -1,7 +1,13 @@
+import java.nio.charset.StandardCharsets;
 import java.util.ArrayList;
+import java.util.Base64;
 import java.util.Comparator;
+import java.util.HashMap;
+import java.util.LinkedHashMap;
+import java.util.LinkedHashSet;
 import java.util.List;
 import java.util.Locale;
+import java.util.Map;
 import java.util.Objects;
 
 /**
@@ -71,4 +77,112 @@ public final class CrewBoard {
     List<Posting> postings() {
         return postings;
     }
+
+    private static final List<String> FACET_DIMENSIONS =
+            List.of("vesselType", "rank", "homePort");
+    private static final Comparator<Hit> RANK_ORDER =
+            Comparator.comparingInt(Hit::score).reversed()
+                    .thenComparing(Comparator.comparingInt((Hit h) -> h.posting().postedDay())
+                            .reversed())
+                    .thenComparing(h -> h.posting().id());
+
+    /**
+     * Ranked search: relevance-scored hits, facet counts over the full match
+     * set, and cursor pagination that stays put while new berths land.
+     */
+    public SearchPage find(SearchRequest req) {
+        if (req.pageSize() < 1) {
+            throw new IllegalArgumentException("pageSize must be positive");
+        }
+        LinkedHashSet<String> terms = new LinkedHashSet<>(terms(req.query()));
+        List<Hit> ranked = new ArrayList<>();
+        for (Posting p : postings) {
+            if (matches(p, new ArrayList<>(terms))) {
+                ranked.add(new Hit(p, score(p, terms)));
+            }
+        }
+        ranked.sort(RANK_ORDER);
+
+        int from = 0;
+        if (req.cursor() != null) {
+            Hit position = decodeCursor(req.cursor());
+            while (from < ranked.size() && RANK_ORDER.compare(ranked.get(from), position) <= 0) {
+                from++;
+            }
+        }
+        int to = Math.min(from + req.pageSize(), ranked.size());
+        List<Hit> page = new ArrayList<>(ranked.subList(from, to));
+        String next = to < ranked.size() ? encodeCursor(page.get(page.size() - 1)) : null;
+        return new SearchPage(page, facets(ranked), next);
+    }
+
+    private static int score(Posting p, LinkedHashSet<String> terms) {
+        String title = p.title().toLowerCase(Locale.ROOT);
+        String description = p.description().toLowerCase(Locale.ROOT);
+        String vessel = p.vesselType().toLowerCase(Locale.ROOT);
+        int score = 0;
+        for (String t : terms) {
+            if (title.contains(t)) {
+                score += 3;
+            }
+            if (vessel.equals(t)) {
+                score += 2;
+            }
+            if (description.contains(t)) {
+                score += 1;
+            }
+        }
+        return score;
+    }
+
+    private static Map<String, Map<String, Integer>> facets(List<Hit> matchSet) {
+        Map<String, Map<String, Integer>> out = new LinkedHashMap<>();
+        for (String dim : FACET_DIMENSIONS) {
+            Map<String, Integer> counts = new HashMap<>();
+            for (Hit h : matchSet) {
+                counts.merge(facetValue(h.posting(), dim), 1, Integer::sum);
+            }
+            Map<String, Integer> ordered = new LinkedHashMap<>();
+            counts.entrySet().stream()
+                    .sorted(Map.Entry.<String, Integer>comparingByValue(Comparator.reverseOrder())
+                            .thenComparing(Map.Entry.comparingByKey()))
+                    .forEach(e -> ordered.put(e.getKey(), e.getValue()));
+            out.put(dim, ordered);
+        }
+        return out;
+    }
+
+    private static String facetValue(Posting p, String dim) {
+        switch (dim) {
+            case "vesselType": return p.vesselType();
+            case "rank": return p.rank();
+            case "homePort": return p.homePort();
+            default: throw new IllegalStateException("unknown facet " + dim);
+        }
+    }
+
+    private static String encodeCursor(Hit last) {
+        String payload = "v1|" + last.score() + "|" + last.posting().postedDay()
+                + "|" + last.posting().id();
+        return Base64.getUrlEncoder().withoutPadding()
+                .encodeToString(payload.getBytes(StandardCharsets.UTF_8));
+    }
+
+    /** Rebuilds the sort position a cursor points at, as a synthetic Hit. */
+    private static Hit decodeCursor(String cursor) {
+        try {
+            String payload = new String(Base64.getUrlDecoder().decode(cursor),
+                    StandardCharsets.UTF_8);
+            String[] parts = payload.split("\\|", -1);
+            if (parts.length != 4 || !parts[0].equals("v1")) {
+                throw new IllegalArgumentException("bad cursor");
+            }
+            int score = Integer.parseInt(parts[1]);
+            int postedDay = Integer.parseInt(parts[2]);
+            Posting marker = new Posting(parts[3], "", "", "", "", "", 0, postedDay);
+            return new Hit(marker, score);
+        } catch (IllegalArgumentException e) {
+            throw new IllegalArgumentException("bad cursor");
+        }
+    }
 }
