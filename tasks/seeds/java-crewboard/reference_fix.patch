+++ b/SearchPage.java
@@ -0,0 +1,30 @@
+import java.util.List;
+import java.util.Map;
+
+/**
+ * One page of ranked results plus facet counts over the whole match set and
+ * the cursor for the next page (null when this page ends the list).
+ */
+public final class SearchPage {
+    private final List<Hit> hits;
+    private final Map<String, Map<String, Integer>> facets;
+    private final String nextCursor;
+
+    SearchPage(List<Hit> hits, Map<String, Map<String, Integer>> facets, String nextCursor) {
+        this.hits = List.copyOf(hits);
+        this.facets = facets;
+        this.nextCursor = nextCursor;
+    }
+
+    public List<Hit> hits() {
+        return hits;
+    }
+
+    public Map<String, Map<String, Integer>> facets() {
+        return facets;
+    }
+
+    public String nextCursor() {
+        return nextCursor;
+    }
+}
