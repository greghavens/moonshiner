diff --git a/cardshuf.c b/cardshuf.c
new file mode 100644
index 0000000..094b32a
--- /dev/null
+++ b/cardshuf.c
@@ -0,0 +1,69 @@
+#include "cardshuf.h"
+
+static const char rank_ch[13] = {'2', '3', '4', '5', '6', '7', '8',
+                                 '9', 'T', 'J', 'Q', 'K', 'A'};
+static const char suit_ch[4] = {'C', 'D', 'H', 'S'};
+
+void deck_new(deck *d) {
+    for (int i = 0; i < 52; i++) d->cards[i] = i;
+    d->n = 52;
+}
+
+int card_name(int card, char *out) {
+    if (card < 0 || card > 51) return -1;
+    out[0] = rank_ch[card % 13];
+    out[1] = suit_ch[card / 13];
+    out[2] = '\0';
+    return 0;
+}
+
+uint32_t shuf_next(uint32_t *state) {
+    *state = (*state * 1103515245u + 12345u) & 0x7FFFFFFFu;
+    return *state >> 16;
+}
+
+void deck_shuffle(deck *d, uint32_t seed) {
+    uint32_t state = seed;
+    for (int i = d->n - 1; i >= 1; i--) {
+        uint32_t r = shuf_next(&state);
+        int j = (int)(r % (uint32_t)(i + 1));
+        int tmp = d->cards[i];
+        d->cards[i] = d->cards[j];
+        d->cards[j] = tmp;
+    }
+}
+
+int deck_cut(deck *d, int k) {
+    if (k < 0 || k > d->n) return -1;
+    int tmp[52];
+    for (int i = 0; i < d->n; i++) tmp[i] = d->cards[(i + k) % d->n];
+    for (int i = 0; i < d->n; i++) d->cards[i] = tmp[i];
+    return 0;
+}
+
+int deck_riffle(deck *d) {
+    if (d->n < 2) return 0;
+    int half = (d->n + 1) / 2;
+    int out[52], pos = 0;
+    for (int i = 0; i < half; i++) {
+        out[pos++] = d->cards[i];
+        if (half + i < d->n) out[pos++] = d->cards[half + i];
+    }
+    for (int i = 0; i < d->n; i++) d->cards[i] = out[i];
+    return 0;
+}
+
+int deck_deal(deck *d, int nplayers, int ncards, int burn, int hands[][13]) {
+    if (nplayers < 1 || nplayers > 8 || ncards < 1 || ncards > 13) return -1;
+    int used = nplayers * ncards + (burn ? ncards : 0);
+    if (used > d->n) return -1;
+    int top = 0;
+    for (int round = 0; round < ncards; round++) {
+        if (burn) top++;
+        for (int p = 0; p < nplayers; p++)
+            hands[p][round] = d->cards[top++];
+    }
+    for (int i = top; i < d->n; i++) d->cards[i - top] = d->cards[i];
+    d->n -= top;
+    return 0;
+}
diff --git a/cardshuf.h b/cardshuf.h
new file mode 100644
index 0000000..dc2edec
--- /dev/null
+++ b/cardshuf.h
@@ -0,0 +1,16 @@
+#ifndef CARDSHUF_H
+#define CARDSHUF_H
+
+#include <stdint.h>
+
+typedef struct { int cards[52]; int n; } deck;
+
+void     deck_new(deck *d);
+int      card_name(int card, char *out);
+uint32_t shuf_next(uint32_t *state);
+void     deck_shuffle(deck *d, uint32_t seed);
+int      deck_cut(deck *d, int k);
+int      deck_riffle(deck *d);
+int      deck_deal(deck *d, int nplayers, int ncards, int burn, int hands[][13]);
+
+#endif /* CARDSHUF_H */
