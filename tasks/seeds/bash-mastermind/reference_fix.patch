diff --git a/mastermind.sh b/mastermind.sh
new file mode 100644
index 0000000..1b02698
--- /dev/null
+++ b/mastermind.sh
@@ -0,0 +1,94 @@
+#!/usr/bin/env bash
+# mastermind.sh — Mastermind scorer and game loop.
+set -u
+
+usage() {
+  printf 'usage: mastermind.sh score <secret> <guess> | play <secret-file>\n' >&2
+  exit 2
+}
+
+die() { printf '%s\n' "$1" >&2; exit 2; }
+
+valid_code() { [[ $1 =~ ^[1-6]{4}$ ]]; }
+
+# score <secret> <guess> -> sets black / white
+score_pegs() {
+  local secret=$1 guess=$2 i c sc gc
+  black=0
+  local total=0
+  for ((i = 0; i < 4; i++)); do
+    [[ ${secret:i:1} == "${guess:i:1}" ]] && black=$((black + 1))
+  done
+  for c in 1 2 3 4 5 6; do
+    sc=${secret//[!$c]/}
+    gc=${guess//[!$c]/}
+    if (( ${#sc} < ${#gc} )); then
+      total=$((total + ${#sc}))
+    else
+      total=$((total + ${#gc}))
+    fi
+  done
+  white=$((total - black))
+}
+
+peg_string() { # peg_string <black> <white>
+  local s='' i
+  for ((i = 0; i < $1; i++)); do s+='B'; done
+  for ((i = 0; i < $2; i++)); do s+='W'; done
+  while (( ${#s} < 4 )); do s+='-'; done
+  printf '%s' "$s"
+}
+
+(( $# >= 1 )) || usage
+cmd=$1
+
+case $cmd in
+  score)
+    (( $# == 3 )) || usage
+    valid_code "$2" || die 'error: code must be 4 digits 1-6'
+    valid_code "$3" || die 'error: code must be 4 digits 1-6'
+    score_pegs "$2" "$3"
+    printf 'black=%d white=%d\n' "$black" "$white"
+    ;;
+  play)
+    (( $# == 2 )) || usage
+    file=$2
+    [[ -f $file && -r $file ]] || die "error: cannot read $file"
+    IFS= read -r secret < "$file" || secret=''
+    valid_code "$secret" || die 'error: bad secret file'
+    guesses=()
+    pegs=()
+    while IFS= read -r line; do
+      [[ -z $line ]] && continue
+      if ! valid_code "$line"; then
+        printf 'invalid guess: %s\n' "$line"
+        continue
+      fi
+      score_pegs "$secret" "$line"
+      guesses+=("$line")
+      pegs+=("$(peg_string "$black" "$white")")
+      n=${#guesses[@]}
+      printf 'turn %d/10: %s\n' "$n" "$line"
+      for ((i = 0; i < n; i++)); do
+        printf '  %d: %s  %s\n' "$((i + 1))" "${guesses[i]}" "${pegs[i]}"
+      done
+      if [[ $line == "$secret" ]]; then
+        if (( n == 1 )); then
+          printf 'cracked in 1 guess\n'
+        else
+          printf 'cracked in %d guesses\n' "$n"
+        fi
+        exit 0
+      fi
+      if (( n == 10 )); then
+        printf 'out of guesses -- the code was %s\n' "$secret"
+        exit 1
+      fi
+    done
+    printf 'no more input -- the code was %s\n' "$secret"
+    exit 1
+    ;;
+  *)
+    usage
+    ;;
+esac
