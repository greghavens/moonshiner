+    /// Combine two partial states, where `later` saw the text immediately
+    /// after `self`'s text. Equivalent to one accumulator having fed both
+    /// ranges in order; associative; `TextStats::new()` is the identity.
+    pub fn merge(self, later: TextStats) -> TextStats {
+        if self.chars == 0 {
+            return later;
+        }
+        if later.chars == 0 {
+            return self;
+        }
+        let (l, r) = (self, later);
+        let mut out = TextStats::new();
+        out.bytes = l.bytes + r.bytes;
+        out.chars = l.chars + r.chars;
+        out.words = l.words + r.words - usize::from(l.ends_in_word() && r.starts_in_word());
+        out.newlines = l.newlines + r.newlines;
+
+        // Line segments: glue l's open tail onto r's first segment.
+        match (l.newlines > 0, r.newlines > 0) {
+            (false, false) => {
+                out.last_seg = l.last_seg + r.last_seg;
+            }
+            (false, true) => {
+                out.first_seg = l.last_seg + r.first_seg;
+                out.last_seg = r.last_seg;
+                out.inner_min = r.inner_min;
+                out.inner_max = r.inner_max;
+            }
+            (true, false) => {
+                out.first_seg = l.first_seg;
+                out.last_seg = l.last_seg + r.last_seg;
+                out.inner_min = l.inner_min;
+                out.inner_max = l.inner_max;
+            }
+            (true, true) => {
+                out.first_seg = l.first_seg;
+                out.last_seg = r.last_seg;
+                out.inner_min = l.inner_min;
+                out.inner_max = l.inner_max;
+                if let Some(m) = r.inner_min {
+                    out.fold_inner(m);
+                }
+                if let Some(m) = r.inner_max {
+                    out.fold_inner(m);
+                }
+                // The glued segment is closed by r's first newline and is
+                // interior (l's first newline precedes it).
+                out.fold_inner(l.last_seg + r.first_seg);
+            }
+        }
+
+        // Tokens: glue l's right-edge partial onto r's left-edge partial.
+        match (l.single, r.single) {
+            (true, true) => {
+                out.single = true;
+                out.tail_word = l.tail_word + &r.tail_word;
+            }
+            (true, false) => {
+                out.single = false;
+                out.head_word = l.tail_word + &r.head_word;
+                out.tail_word = r.tail_word;
+                out.mid = r.mid;
+            }
+            (false, true) => {
+                out.single = false;
+                out.head_word = l.head_word;
+                out.tail_word = l.tail_word + &r.tail_word;
+                out.mid = l.mid;
+            }
+            (false, false) => {
+                out.single = false;
+                out.head_word = l.head_word;
+                out.tail_word = r.tail_word;
+                let mut mid = l.mid;
+                for (word, n) in r.mid {
+                    *mid.entry(word).or_insert(0) += n;
+                }
+                let glue = l.tail_word + &r.head_word;
+                if !glue.is_empty() {
+                    *mid.entry(glue).or_insert(0) += 1;
+                }
+                out.mid = mid;
             }
         }
+        out
