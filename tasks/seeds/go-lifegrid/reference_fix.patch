+// Package lifegrid implements Conway's Game of Life on a finite grid with
+// bounded (dead border) and toroidal (wrap-around) neighbourhood modes.
+package lifegrid
+
+import (
+	"errors"
+	"fmt"
+	"strings"
+)
+
+// Mode selects how the grid treats coordinates outside its rectangle.
+type Mode int
+
+const (
+	// Bounded treats everything outside the grid as permanently dead.
+	Bounded Mode = iota
+	// Toroidal wraps both axes, so the right edge borders the left and the
+	// bottom borders the top.
+	Toroidal
+)
+
+// Grid is a Life universe of fixed width and height.
+type Grid struct {
+	w, h  int
+	mode  Mode
+	cells []bool
+}
+
+// Parse reads a pattern in the fixture format: lines beginning with '!' are
+// comments, blank lines are ignored, and every remaining line is one row of
+// '.' (dead) and '#' (alive). All rows must be the same length and there
+// must be at least one row.
+func Parse(data string, mode Mode) (*Grid, error) {
+	if mode != Bounded && mode != Toroidal {
+		return nil, fmt.Errorf("lifegrid: unknown mode %d", int(mode))
+	}
+	var rows []string
+	for _, line := range strings.Split(data, "\n") {
+		line = strings.TrimSuffix(line, "\r")
+		if line == "" || strings.HasPrefix(line, "!") {
+			continue
+		}
+		rows = append(rows, line)
+	}
+	if len(rows) == 0 {
+		return nil, errors.New("lifegrid: pattern has no grid rows")
+	}
+	w := len(rows[0])
+	g := &Grid{w: w, h: len(rows), mode: mode, cells: make([]bool, w*len(rows))}
+	for y, row := range rows {
+		if len(row) != w {
+			return nil, fmt.Errorf("lifegrid: row %d is %d chars, want %d", y, len(row), w)
+		}
+		for x := 0; x < w; x++ {
+			switch row[x] {
+			case '#':
+				g.cells[y*w+x] = true
+			case '.':
+			default:
+				return nil, fmt.Errorf("lifegrid: bad cell %q at row %d col %d", row[x], y, x)
+			}
+		}
+	}
+	return g, nil
+}
+
+// Width returns the grid width in cells.
+func (g *Grid) Width() int { return g.w }
+
+// Height returns the grid height in cells.
+func (g *Grid) Height() int { return g.h }
+
+// Alive reports whether the cell at column x, row y is alive. In Toroidal
+// mode any integer coordinates are valid and wrap; in Bounded mode
+// out-of-range coordinates are dead.
+func (g *Grid) Alive(x, y int) bool {
+	if g.mode == Toroidal {
+		x = ((x % g.w) + g.w) % g.w
+		y = ((y % g.h) + g.h) % g.h
+	} else if x < 0 || x >= g.w || y < 0 || y >= g.h {
+		return false
+	}
+	return g.cells[y*g.w+x]
+}
+
+// Population returns the number of live cells.
+func (g *Grid) Population() int {
+	n := 0
+	for _, c := range g.cells {
+		if c {
+			n++
+		}
+	}
+	return n
+}
+
+func (g *Grid) liveNeighbors(x, y int) int {
+	n := 0
+	for dy := -1; dy <= 1; dy++ {
+		for dx := -1; dx <= 1; dx++ {
+			if dx == 0 && dy == 0 {
+				continue
+			}
+			if g.Alive(x+dx, y+dy) {
+				n++
+			}
+		}
+	}
+	return n
+}
+
+// Step advances the universe by one generation using the standard rules:
+// a live cell survives with 2 or 3 live neighbours, a dead cell becomes
+// alive with exactly 3.
+func (g *Grid) Step() {
+	next := make([]bool, len(g.cells))
+	for y := 0; y < g.h; y++ {
+		for x := 0; x < g.w; x++ {
+			n := g.liveNeighbors(x, y)
+			if g.cells[y*g.w+x] {
+				next[y*g.w+x] = n == 2 || n == 3
+			} else {
+				next[y*g.w+x] = n == 3
+			}
+		}
+	}
+	g.cells = next
+}
+
+// StepN advances by n generations; n <= 0 is a no-op.
+func (g *Grid) StepN(n int) {
+	for i := 0; i < n; i++ {
+		g.Step()
+	}
+}
+
+// Render returns the grid as height rows of '.'/'#' joined by "\n", with no
+// trailing newline.
+func (g *Grid) Render() string {
+	var b strings.Builder
+	for y := 0; y < g.h; y++ {
+		if y > 0 {
+			b.WriteByte('\n')
+		}
+		for x := 0; x < g.w; x++ {
+			if g.cells[y*g.w+x] {
+				b.WriteByte('#')
+			} else {
+				b.WriteByte('.')
+			}
+		}
+	}
+	return b.String()
+}
