+def _occupied(root, target, claimed):
+    """A target slot is taken if it exists on disk or an earlier planned
+    move in this run already promised it."""
+    return target in claimed or os.path.exists(os.path.join(root, target))
+
+
+def _renamed(root, folder, name, claimed):
+    """First ``stem_N.ext`` variant of name that is free under folder."""
+    stem, ext = os.path.splitext(name)
+    n = 1
+    while True:
+        candidate = os.path.join(folder, "%s_%d%s" % (stem, n, ext))
+        if not _occupied(root, candidate, claimed):
+            return candidate
+        n += 1
+
+
+def plan(root, rules, on_collision="rename"):
+    """Compute the action list for a run without touching the disk.
+
+    Returns (action, src_name, dst_relpath) tuples in scan order; action is
+    'move', 'skip' or 'overwrite'.  Renamed moves appear as 'move' with the
+    suffixed destination.  Targets promised by earlier entries of the same
+    plan count as occupied.
+    """
+    if on_collision not in POLICIES:
+        raise ValueError("unknown collision policy: %r" % on_collision)
+    actions = []
+    claimed = set()
+    for name, folder in scan(root, rules):
+        target = os.path.join(folder, name)
+        if not _occupied(root, target, claimed):
+            actions.append(("move", name, target))
+            claimed.add(target)
+        elif on_collision == "skip":
+            actions.append(("skip", name, target))
+        elif on_collision == "overwrite":
+            actions.append(("overwrite", name, target))
+        else:
+            target = _renamed(root, folder, name, claimed)
+            actions.append(("move", name, target))
+            claimed.add(target)
+    return actions
+
