+def undo_last(root):
+    """Reverse the most recent real run recorded in the journal.
+
+    Entries are undone in reverse order; anything whose destination has
+    since disappeared is skipped.  Returns the restored (dst, src) pairs
+    and removes the journal.  Raises ValueError when there is no journal.
+    """
+    journal_path = os.path.join(root, JOURNAL_NAME)
+    if not os.path.exists(journal_path):
+        raise ValueError("nothing to undo: no journal in %s" % root)
+    with open(journal_path) as f:
+        entries = json.load(f)
+    restored = []
+    for entry in reversed(entries):
+        src, dst = entry["src"], entry["dst"]
