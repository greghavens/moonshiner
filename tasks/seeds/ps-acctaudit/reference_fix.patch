diff --git a/acctaudit.ps1 b/acctaudit.ps1
new file mode 100644
index 0000000..7d145f3
--- /dev/null
+++ b/acctaudit.ps1
@@ -0,0 +1,130 @@
+# acctaudit.ps1 — access-review findings from passwd/group-style snapshots.
+# Usage: pwsh -NoProfile -File acctaudit.ps1 -PasswdPath <f> -GroupPath <f> -AllowedShells <f>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$PasswdPath,
+    [Parameter(Mandatory)][string]$GroupPath,
+    [Parameter(Mandatory)][string]$AllowedShells
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message, [int]$Code)
+    [Console]::Error.WriteLine($Message)
+    exit $Code
+}
+
+# Account and group names are case-sensitive; every lookup structure here
+# must use an Ordinal comparer, never the default case-folding one.
+$ordinal = [System.StringComparer]::Ordinal
+
+$accounts = [System.Collections.Generic.List[pscustomobject]]::new()
+$accountNames = [System.Collections.Generic.HashSet[string]]::new($ordinal)
+$passwdLeaf = Split-Path -Leaf $PasswdPath
+$lineNo = 0
+foreach ($line in [System.IO.File]::ReadAllLines($PasswdPath)) {
+    $lineNo++
+    if ($line -eq '') { continue }
+    $f = $line.Split(':')
+    $uid = 0
+    $gid = 0
+    if ($f.Count -ne 7 -or
+        -not [int]::TryParse($f[2], [ref]$uid) -or
+        -not [int]::TryParse($f[3], [ref]$gid)) {
+        Fail "acctaudit: ${passwdLeaf}: malformed line $lineNo" 64
+    }
+    $accounts.Add([pscustomobject]@{ Name = $f[0]; Uid = $uid; Gid = $gid; Shell = $f[6] })
+    $accountNames.Add($f[0]) > $null
+}
+
+$groups = [System.Collections.Generic.List[pscustomobject]]::new()
+$groupGids = [System.Collections.Generic.HashSet[int]]::new()
+$groupLeaf = Split-Path -Leaf $GroupPath
+$lineNo = 0
+foreach ($line in [System.IO.File]::ReadAllLines($GroupPath)) {
+    $lineNo++
+    if ($line -eq '') { continue }
+    $f = $line.Split(':')
+    $gid = 0
+    if ($f.Count -ne 4 -or -not [int]::TryParse($f[2], [ref]$gid)) {
+        Fail "acctaudit: ${groupLeaf}: malformed line $lineNo" 64
+    }
+    $members = if ($f[3] -eq '') { @() } else { @($f[3].Split(',')) }
+    $groups.Add([pscustomobject]@{ Name = $f[0]; Gid = $gid; Members = $members })
+    $groupGids.Add($gid) > $null
+}
+
+$allowed = [System.Collections.Generic.HashSet[string]]::new($ordinal)
+foreach ($line in [System.IO.File]::ReadAllLines($AllowedShells)) {
+    $t = $line.Trim()
+    if ($t -eq '' -or $t.StartsWith('#')) { continue }
+    $allowed.Add($t) > $null
+}
+
+# orphanedMembers, ordinal by group then member
+$orphanKeys = [System.Collections.Generic.Dictionary[string, pscustomobject]]::new($ordinal)
+foreach ($g in $groups) {
+    foreach ($m in $g.Members) {
+        if (-not $accountNames.Contains($m)) {
+            $orphanKeys[$g.Name + [char]1 + $m] = [pscustomobject][ordered]@{ group = $g.Name; member = $m }
+        }
+    }
+}
+$keys = [string[]]@($orphanKeys.Keys)
+[Array]::Sort($keys, $ordinal)
+$orphaned = @(foreach ($k in $keys) { $orphanKeys[$k] })
+
+function Group-Duplicates {
+    param([System.Collections.Generic.List[pscustomobject]]$Rows, [string]$IdProp, [string]$NameProp, [string]$IdKey, [string]$ListKey)
+    $byId = [System.Collections.Generic.Dictionary[int, System.Collections.Generic.List[string]]]::new()
+    foreach ($r in $Rows) {
+        $id = [int]$r.$IdProp
+        if (-not $byId.ContainsKey($id)) {
+            $byId[$id] = [System.Collections.Generic.List[string]]::new()
+        }
+        $byId[$id].Add([string]$r.$NameProp)
+    }
+    $ids = @($byId.Keys | Where-Object { $byId[$_].Count -gt 1 })
+    $ids = @($ids | Sort-Object { [int]$_ })
+    return @(foreach ($id in $ids) {
+        $names = [string[]]@($byId[$id])
+        [Array]::Sort($names, [System.StringComparer]::Ordinal)
+        [pscustomobject][ordered]@{ $IdKey = $id; $ListKey = $names }
+    })
+}
+
+$dupUids = @(Group-Duplicates -Rows $accounts -IdProp 'Uid' -NameProp 'Name' -IdKey 'uid' -ListKey 'users')
+$dupGids = @(Group-Duplicates -Rows $groups -IdProp 'Gid' -NameProp 'Name' -IdKey 'gid' -ListKey 'groups')
+
+$violByUser = [System.Collections.Generic.Dictionary[string, pscustomobject]]::new($ordinal)
+$unknownByUser = [System.Collections.Generic.Dictionary[string, pscustomobject]]::new($ordinal)
+foreach ($a in $accounts) {
+    if (-not $allowed.Contains($a.Shell)) {
+        $violByUser[$a.Name] = [pscustomobject][ordered]@{ user = $a.Name; shell = $a.Shell }
+    }
+    if (-not $groupGids.Contains($a.Gid)) {
+        $unknownByUser[$a.Name] = [pscustomobject][ordered]@{ user = $a.Name; gid = $a.Gid }
+    }
+}
+$violKeys = [string[]]@($violByUser.Keys)
+[Array]::Sort($violKeys, $ordinal)
+$violations = @(foreach ($k in $violKeys) { $violByUser[$k] })
+$unknownKeys = [string[]]@($unknownByUser.Keys)
+[Array]::Sort($unknownKeys, $ordinal)
+$unknown = @(foreach ($k in $unknownKeys) { $unknownByUser[$k] })
+
+$report = [ordered]@{
+    orphanedMembers     = $orphaned
+    duplicateUids       = $dupUids
+    duplicateGids       = $dupGids
+    shellViolations     = $violations
+    unknownPrimaryGroup = $unknown
+}
+
+[pscustomobject]$report | ConvertTo-Json -Depth 6 | Write-Output
+
+$findings = $orphaned.Count + $dupUids.Count + $dupGids.Count + $violations.Count + $unknown.Count
+if ($findings -gt 0) { exit 65 }
+exit 0
