@@ -0,0 +1,86 @@
+namespace ObsRun;
+
+public abstract record ObsState(string TargetId);
+
+public sealed record Drafted(string TargetId, int RequestedMinutes) : ObsState(TargetId);
+
+public sealed record Queued(string TargetId, int RequestedMinutes, int Priority) : ObsState(TargetId);
+
+public sealed record Observing(string TargetId, int RequestedMinutes, int ElapsedMinutes) : ObsState(TargetId);
+
+public sealed record Suspended(string TargetId, int RequestedMinutes, int ElapsedMinutes, string Reason) : ObsState(TargetId);
+
+public sealed record Completed(string TargetId, int TotalMinutes) : ObsState(TargetId);
+
+public sealed record Scrubbed(string TargetId, string Reason) : ObsState(TargetId);
+
+public abstract record ObsEvent;
+
+public sealed record Approve(int Priority) : ObsEvent;
+
+public sealed record StartExposure : ObsEvent;
+
+public sealed record Progress(int Minutes) : ObsEvent;
+
+public sealed record WeatherHold(string Reason) : ObsEvent;
+
+public sealed record Resume : ObsEvent;
+
+public sealed record Scrub(string Reason) : ObsEvent;
+
+public sealed class InvalidTransitionException : InvalidOperationException
+{
+    public InvalidTransitionException(ObsState state, ObsEvent evt)
+        : base($"cannot apply {evt.GetType().Name} in {state.GetType().Name}")
+    {
+        State = state;
+        Event = evt;
+    }
+
+    public ObsState State { get; }
+    public ObsEvent Event { get; }
+}
+
+public static class RunController
+{
+    public static ObsState Apply(ObsState state, ObsEvent evt) => (state, evt) switch
+    {
+        (Drafted d, Approve a) => a.Priority is >= 1 and <= 5
+            ? new Queued(d.TargetId, d.RequestedMinutes, a.Priority)
+            : throw new ArgumentOutOfRangeException(nameof(evt), a.Priority, "priority must be 1..5"),
+
+        (Queued q, StartExposure) => new Observing(q.TargetId, q.RequestedMinutes, 0),
+
+        (Observing o, Progress p) => p.Minutes switch
+        {
+            <= 0 => throw new ArgumentOutOfRangeException(nameof(evt), p.Minutes, "progress minutes must be positive"),
+            _ when o.ElapsedMinutes + p.Minutes >= o.RequestedMinutes
+                => new Completed(o.TargetId, o.RequestedMinutes),
+            _ => o with { ElapsedMinutes = o.ElapsedMinutes + p.Minutes },
+        },
+
+        (Observing o, WeatherHold h) => new Suspended(o.TargetId, o.RequestedMinutes, o.ElapsedMinutes, h.Reason),
+
+        (Suspended s, Resume) => new Observing(s.TargetId, s.RequestedMinutes, s.ElapsedMinutes),
+
+        (Drafted or Queued or Observing or Suspended, Scrub sc) => new Scrubbed(state.TargetId, sc.Reason),
+
+        _ => throw new InvalidTransitionException(state, evt),
+    };
+
+    public static ObsState Replay(ObsState initial, IEnumerable<ObsEvent> events) =>
+        events.Aggregate(initial, Apply);
+
+    public static bool IsTerminal(ObsState state) => state is Completed or Scrubbed;
+
+    public static string Describe(ObsState state) => state switch
+    {
+        Drafted d => $"{d.TargetId}: drafted ({d.RequestedMinutes}m requested)",
+        Queued q => $"{q.TargetId}: queued p{q.Priority} ({q.RequestedMinutes}m)",
+        Observing o => $"{o.TargetId}: observing {o.ElapsedMinutes}/{o.RequestedMinutes}m",
+        Suspended s => $"{s.TargetId}: on hold at {s.ElapsedMinutes}/{s.RequestedMinutes}m ({s.Reason})",
+        Completed c => $"{c.TargetId}: complete ({c.TotalMinutes}m)",
+        Scrubbed s => $"{s.TargetId}: scrubbed ({s.Reason})",
+        _ => throw new ArgumentOutOfRangeException(nameof(state)),
+    };
+}
