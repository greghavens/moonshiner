diff --git a/inidrift.ps1 b/inidrift.ps1
new file mode 100644
index 0000000..0a5c552
--- /dev/null
+++ b/inidrift.ps1
@@ -0,0 +1,109 @@
+# inidrift.ps1 — desired.json vs a snapshot tree of INI-ish files.
+# Usage: pwsh -NoProfile -File inidrift.ps1 -Desired <desired.json> -SnapshotRoot <dir>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Desired,
+    [Parameter(Mandatory)][string]$SnapshotRoot
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if (-not (Test-Path -LiteralPath $Desired -PathType Leaf)) {
+    [Console]::Error.WriteLine("inidrift: desired file not found: $Desired")
+    exit 66
+}
+if (-not (Test-Path -LiteralPath $SnapshotRoot -PathType Container)) {
+    [Console]::Error.WriteLine("inidrift: snapshot root not found: $SnapshotRoot")
+    exit 66
+}
+
+$ordinal = [System.StringComparer]::Ordinal
+$inv = [System.Globalization.CultureInfo]::InvariantCulture
+
+# Section and key names are case-sensitive, so the store must be built on
+# Ordinal comparers — the default hashtable would fold 'Policy' onto 'policy'.
+function Read-IniSections {
+    param([string]$Path)
+    $sections = [System.Collections.Generic.Dictionary[string, System.Collections.Generic.Dictionary[string, string]]]::new($script:ordinal)
+    $current = ''
+    foreach ($line in [System.IO.File]::ReadAllLines($Path)) {
+        $t = $line.Trim()
+        if ($t -eq '' -or $t.StartsWith(';') -or $t.StartsWith('#')) { continue }
+        if ($t.StartsWith('[') -and $t.EndsWith(']')) {
+            $current = $t.Substring(1, $t.Length - 2).Trim()
+            if (-not $sections.ContainsKey($current)) {
+                $sections[$current] = [System.Collections.Generic.Dictionary[string, string]]::new($script:ordinal)
+            }
+            continue
+        }
+        $eq = $t.IndexOf('=')
+        if ($eq -lt 0) { continue }
+        if (-not $sections.ContainsKey($current)) {
+            $sections[$current] = [System.Collections.Generic.Dictionary[string, string]]::new($script:ordinal)
+        }
+        $key = $t.Substring(0, $eq).Trim()
+        $sections[$current][$key] = $t.Substring($eq + 1).Trim()
+    }
+    return $sections
+}
+
+function Get-SortedNames {
+    param($Object)
+    $names = [string[]]@($Object.PSObject.Properties.Name)
+    [Array]::Sort($names, $script:ordinal)
+    return $names
+}
+
+$desiredTree = Get-Content -LiteralPath $Desired -Raw | ConvertFrom-Json
+
+$drift = [System.Collections.Generic.List[string]]::new()
+foreach ($file in Get-SortedNames $desiredTree) {
+    $snapPath = Join-Path $SnapshotRoot $file
+    if (-not (Test-Path -LiteralPath $snapPath -PathType Leaf)) {
+        $drift.Add("missing-file $file")
+        continue
+    }
+    $actualSections = Read-IniSections $snapPath
+    $desiredSections = $desiredTree.$file
+    foreach ($section in Get-SortedNames $desiredSections) {
+        if (-not $actualSections.ContainsKey($section)) {
+            $drift.Add("missing-section $file [$section]")
+            continue
+        }
+        $actualKeys = $actualSections[$section]
+        $desiredKeys = $desiredSections.$section
+        foreach ($key in Get-SortedNames $desiredKeys) {
+            if (-not $actualKeys.ContainsKey($key)) {
+                $drift.Add("missing-key $file [$section] $key")
+                continue
+            }
+            $want = $desiredKeys.$key
+            $raw = $actualKeys[$key]
+            $matches2 = $false
+            $render = ''
+            if ($want -is [bool]) {
+                $render = if ($want) { 'true' } else { 'false' }
+                $matches2 = ($raw -eq 'true' -or $raw -eq 'false') -and ([bool]::Parse($raw) -eq $want)
+            }
+            elseif ($want -is [long] -or $want -is [int]) {
+                $render = [string]::Format($inv, '{0}', $want)
+                $parsed = 0L
+                $matches2 = [long]::TryParse($raw, [System.Globalization.NumberStyles]::Integer, $inv, [ref]$parsed) -and $parsed -eq [long]$want
+            }
+            else {
+                $render = [string]$want
+                $matches2 = [string]::Equals([string]$want, $raw, [System.StringComparison]::Ordinal)
+            }
+            if (-not $matches2) {
+                $drift.Add("mismatch $file [$section] $key expected=$render actual=$raw")
+            }
+        }
+    }
+}
+
+foreach ($line in $drift) {
+    Write-Output $line
+}
+if ($drift.Count -gt 0) { exit 65 }
+exit 0
