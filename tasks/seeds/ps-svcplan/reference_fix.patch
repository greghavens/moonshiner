diff --git a/svcplan.ps1 b/svcplan.ps1
new file mode 100644
index 0000000..b31dd72
--- /dev/null
+++ b/svcplan.ps1
@@ -0,0 +1,116 @@
+# svcplan.ps1 — ordered action plan from desired state vs a collector snapshot.
+# Usage: pwsh -NoProfile -File svcplan.ps1 -Desired <desired.json> -Snapshot <snapshot.json>
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Desired,
+    [Parameter(Mandatory)][string]$Snapshot
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Fail {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit 65
+}
+
+$ordinal = [System.StringComparer]::Ordinal
+
+$desiredDoc = Get-Content -LiteralPath $Desired -Raw | ConvertFrom-Json
+$snapshotDoc = Get-Content -LiteralPath $Snapshot -Raw | ConvertFrom-Json
+
+$want = [System.Collections.Generic.Dictionary[string, pscustomobject]]::new($ordinal)
+foreach ($s in $desiredDoc.services) {
+    $want[$s.name] = $s
+}
+$have = [System.Collections.Generic.Dictionary[string, pscustomobject]]::new($ordinal)
+foreach ($s in $snapshotDoc.services) {
+    $have[$s.name] = $s
+}
+
+$names = [string[]]@($want.Keys)
+[Array]::Sort($names, $ordinal)
+
+foreach ($n in $names) {
+    if (-not $have.ContainsKey($n)) {
+        Fail "svcplan: service not in snapshot: $n"
+    }
+}
+foreach ($n in $names) {
+    foreach ($dep in @($want[$n].dependsOn)) {
+        if (-not $want.ContainsKey($dep)) {
+            Fail "svcplan: unknown dependency '$dep' of '$n'"
+        }
+    }
+}
+
+# One deterministic dependency order over the whole desired set: Kahn's
+# algorithm, always draining the ordinal-first ready node.
+$indegree = [System.Collections.Generic.Dictionary[string, int]]::new($ordinal)
+$dependents = [System.Collections.Generic.Dictionary[string, System.Collections.Generic.List[string]]]::new($ordinal)
+foreach ($n in $names) {
+    $indegree[$n] = 0
+    $dependents[$n] = [System.Collections.Generic.List[string]]::new()
+}
+foreach ($n in $names) {
+    foreach ($dep in @($want[$n].dependsOn)) {
+        $indegree[$n]++
+        $dependents[$dep].Add($n)
+    }
+}
+
+$ready = [System.Collections.Generic.SortedSet[string]]::new($ordinal)
+foreach ($n in $names) {
+    if ($indegree[$n] -eq 0) { $ready.Add($n) > $null }
+}
+$topo = [System.Collections.Generic.List[string]]::new()
+while ($ready.Count -gt 0) {
+    $n = $ready.Min
+    $ready.Remove($n) > $null
+    $topo.Add($n)
+    foreach ($d in $dependents[$n]) {
+        $indegree[$d]--
+        if ($indegree[$d] -eq 0) { $ready.Add($d) > $null }
+    }
+}
+if ($topo.Count -ne $names.Length) {
+    Fail 'svcplan: dependency cycle detected'
+}
+
+$reverseTopo = [System.Collections.Generic.List[string]]::new($topo)
+$reverseTopo.Reverse()
+
+$actions = [System.Collections.Generic.Dictionary[string, System.Collections.Generic.HashSet[string]]]::new($ordinal)
+foreach ($n in $names) {
+    $actions[$n] = [System.Collections.Generic.HashSet[string]]::new($ordinal)
+    $d = $want[$n]
+    $s = $have[$n]
+    if ($d.state -eq 'running' -and $s.state -eq 'stopped') {
+        $actions[$n].Add('start') > $null
+    }
+    elseif ($d.state -eq 'stopped' -and $s.state -eq 'running') {
+        $actions[$n].Add('stop') > $null
+    }
+    elseif ($d.state -eq 'running' -and $s.state -eq 'running' -and $d.configRev -ne $s.configRev) {
+        $actions[$n].Add('restart') > $null
+    }
+    if ($d.enabled -ne $s.enabled) {
+        $actions[$n].Add($(if ($d.enabled) { 'enable' } else { 'disable' })) > $null
+    }
+}
+
+$plan = [System.Collections.Generic.List[string]]::new()
+foreach ($section in @('stop', 'start', 'restart', 'enable', 'disable')) {
+    $order = if ($section -eq 'stop' -or $section -eq 'disable') { $reverseTopo } else { $topo }
+    foreach ($n in $order) {
+        if ($actions[$n].Contains($section)) {
+            $plan.Add("$section $n")
+        }
+    }
+}
+
+foreach ($line in $plan) {
+    Write-Output $line
+}
+exit 0
