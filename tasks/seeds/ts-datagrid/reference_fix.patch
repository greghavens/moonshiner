+// Pure state + view logic for the fleet data grid. No React in here: the
+// reducer drives toolbar interactions and applyView derives what a page of
+// the table should show.
+
+export interface GridState {
+  sortKey: string | null;
+  sortDir: "asc" | "desc";
+  filter: string;
+  page: number;
+  pageSize: number;
+}
+
+export type GridAction =
+  | { type: "sort"; key: string }
+  | { type: "filter"; text: string }
+  | { type: "page"; page: number }
+  | { type: "next" }
+  | { type: "prev" }
+  | { type: "page-size"; size: number };
+
+export interface ColumnSpec {
+  key: string;
+  label: string;
+  kind: "text" | "number";
+}
+
+export type Row = Record<string, string | number>;
+
+export interface GridView {
+  pageRows: Row[];
+  totalMatching: number;
+  pageCount: number;
+  page: number;
+}
+
+export function initGrid(pageSize: number = 10): GridState {
+  return { sortKey: null, sortDir: "asc", filter: "", page: 0, pageSize };
+}
+
+export function gridReducer(state: GridState, action: GridAction): GridState {
+  switch (action.type) {
+    case "sort": {
+      if (state.sortKey === action.key) {
+        return { ...state, sortDir: state.sortDir === "asc" ? "desc" : "asc", page: 0 };
+      }
+      return { ...state, sortKey: action.key, sortDir: "asc", page: 0 };
+    }
+    case "filter":
+      return { ...state, filter: action.text, page: 0 };
+    case "page":
+      return { ...state, page: Math.max(0, action.page) };
+    case "next":
+      return { ...state, page: state.page + 1 };
+    case "prev":
+      return { ...state, page: Math.max(0, state.page - 1) };
+    case "page-size":
+      return { ...state, pageSize: Math.max(1, action.size), page: 0 };
+    default:
+      return state;
+  }
+}
+
+function compareBy(column: ColumnSpec, dir: "asc" | "desc") {
+  const sign = dir === "asc" ? 1 : -1;
+  return (a: Row, b: Row): number => {
+    if (column.kind === "number") {
+      const na = Number(a[column.key] ?? 0);
+      const nb = Number(b[column.key] ?? 0);
+      return na === nb ? 0 : na < nb ? -sign : sign;
+    }
+    const sa = String(a[column.key] ?? "");
+    const sb = String(b[column.key] ?? "");
+    return sa === sb ? 0 : sa < sb ? -sign : sign;
+  };
+}
+
+export function applyView(rows: Row[], columns: ColumnSpec[], state: GridState): GridView {
+  const needle = state.filter.toLowerCase();
+  let matching = rows.filter((row) => {
+    if (needle === "") return true;
+    return columns.some((col) => String(row[col.key] ?? "").toLowerCase().includes(needle));
+  });
+
+  if (state.sortKey !== null) {
+    const column = columns.find((col) => col.key === state.sortKey) ?? {
+      key: state.sortKey,
+      label: state.sortKey,
+      kind: "text" as const,
+    };
+    // Array.prototype.sort is stable, but we sort a copy so callers' row
+    // arrays are never reordered under them.
+    matching = [...matching].sort(compareBy(column, state.sortDir));
+  }
+
+  const totalMatching = matching.length;
+  const pageCount = Math.max(1, Math.ceil(totalMatching / state.pageSize));
+  const page = Math.min(Math.max(0, state.page), pageCount - 1);
+  const pageRows = matching.slice(page * state.pageSize, (page + 1) * state.pageSize);
+  return { pageRows, totalMatching, pageCount, page };
+}
