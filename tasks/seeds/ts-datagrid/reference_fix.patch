+// Fleet data grid: a thin React shell around the pure grid logic. State is
+// held with useReducer so the toolbar can dispatch the same actions later;
+// under server rendering only the initial state is ever visible.
+
+import { useReducer } from "react";
+import {
+  applyView,
+  gridReducer,
+  initGrid,
+  type ColumnSpec,
+  type GridState,
+  type Row,
+} from "./grid_logic.ts";
+
+interface DataGridProps {
+  columns: ColumnSpec[];
+  rows: Row[];
+  caption: string;
+  init?: GridState;
+}
+
+export function DataGrid({ columns, rows, caption, init }: DataGridProps) {
+  const [state] = useReducer(gridReducer, init ?? initGrid());
+  const view = applyView(rows, columns, state);
+
+  const first = view.page * state.pageSize + 1;
+  const last = Math.min(view.totalMatching, (view.page + 1) * state.pageSize);
+  const status = view.totalMatching === 0 ? "Showing 0 of 0" : `Showing ${first}-${last} of ${view.totalMatching}`;
+
+  return (
+    <div className="data-grid">
+      <table>
+        <caption>{caption}</caption>
+        <thead>
+          <tr>
+            {columns.map((col) => (
+              <th
+                key={col.key}
+                scope="col"
+                aria-sort={
+                  state.sortKey === col.key
+                    ? state.sortDir === "asc"
+                      ? "ascending"
+                      : "descending"
+                    : undefined
+                }
+              >
+                <button className="sort-toggle" type="button">
+                  {col.label}
+                </button>
+              </th>
+            ))}
+          </tr>
+        </thead>
+        <tbody>
+          {view.pageRows.length === 0 ? (
+            <tr className="empty-row">
+              <td colSpan={columns.length}>No matching rows</td>
+            </tr>
+          ) : (
+            view.pageRows.map((row, i) => (
+              <tr key={i}>
+                {columns.map((col) => (
+                  <td key={col.key} className={col.kind === "number" ? "num" : undefined}>
+                    {String(row[col.key] ?? "")}
+                  </td>
+                ))}
+              </tr>
+            ))
+          )}
+        </tbody>
+      </table>
+      <p className="grid-status">{status}</p>
+      <p className="grid-page">
+        Page {view.page + 1} of {view.pageCount}
+      </p>
+    </div>
+  );
+}
