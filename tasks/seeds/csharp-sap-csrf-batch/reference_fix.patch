+using System.Text;
+
+namespace SapBatch;
+
+/// <summary>
+/// Submits OData 2.0 batches to the gateway: cached CSRF session, one
+/// refresh-and-retry on token rejection, multipart response decoding.
+/// </summary>
+public sealed class BatchGateway
+{
+    private readonly HttpClient _http;
+    private readonly string _serviceRoot;
+    private readonly CsrfSession _session;
+
+    public BatchGateway(HttpClient http, string serviceRootUrl)
+    {
+        _http = http;
+        _serviceRoot = serviceRootUrl.TrimEnd('/');
+        _session = new CsrfSession(http, _serviceRoot);
+    }
+
+    public async Task<BatchResponse> SubmitAsync(BatchRequestBuilder batch)
+    {
+        string payload = batch.Build();
+        HttpResponseMessage response = await PostAsync(batch, payload);
+        if (IsTokenRejection(response))
+        {
+            response.Dispose();
+            // The gateway invalidated our session: fetch a fresh token once
+            // and retry the identical payload once.
+            _session.Invalidate();
+            response = await PostAsync(batch, payload);
+            if (IsTokenRejection(response))
+            {
+                response.Dispose();
+                throw new SapCsrfException(
+                    "gateway rejected a freshly fetched CSRF token twice; giving up");
+            }
+        }
+        using (response)
+        {
+            string body = await response.Content.ReadAsStringAsync();
+            string contentType = response.Content.Headers.ContentType?.ToString()
+                ?? throw new FormatException("batch response carries no content type");
+            return BatchResponse.Parse(contentType, body);
+        }
+    }
+
+    private async Task<HttpResponseMessage> PostAsync(BatchRequestBuilder batch, string payload)
+    {
+        CsrfToken token = await _session.GetAsync();
+        using var request = new HttpRequestMessage(HttpMethod.Post, _serviceRoot + "/$batch");
+        request.Headers.TryAddWithoutValidation("x-csrf-token", token.Value);
+        if (token.Cookies.Count > 0)
+            request.Headers.TryAddWithoutValidation("Cookie", string.Join("; ", token.Cookies));
+        var content = new StringContent(payload, Encoding.UTF8);
+        content.Headers.ContentType = null;
+        content.Headers.TryAddWithoutValidation(
+            "Content-Type", "multipart/mixed; boundary=" + batch.BatchBoundary);
+        request.Content = content;
+        return await _http.SendAsync(request);
+    }
+
+    private static bool IsTokenRejection(HttpResponseMessage response) =>
+        response.StatusCode == System.Net.HttpStatusCode.Forbidden
+        && response.Headers.TryGetValues("x-csrf-token", out var values)
+        && values.Any(v => v.Equals("required", StringComparison.OrdinalIgnoreCase));
+}
diff --git a/BatchRequestBuilder.cs b/BatchRequestBuilder.cs
