index 0000000..6cfb422
--- /dev/null
+++ b/CsrfSession.cs
@@ -0,0 +1,51 @@
+namespace SapBatch;
+
+/// <summary>The CSRF token plus the session cookies that accompany it.</summary>
+public sealed record CsrfToken(string Value, IReadOnlyList<string> Cookies);
+
+/// <summary>Raised when the gateway keeps rejecting freshly fetched tokens.</summary>
+public sealed class SapCsrfException : Exception
+{
+    public SapCsrfException(string message) : base(message) { }
+}
+
+/// <summary>
+/// Fetches and caches the gateway CSRF session: a HEAD pre-flight with
+/// x-csrf-token: fetch returns the token in the response header and the
+/// session cookies in Set-Cookie — the write needs both.
+/// </summary>
+public sealed class CsrfSession
+{
+    private readonly HttpClient _http;
+    private readonly string _serviceRoot;
+    private CsrfToken? _cached;
+
+    public CsrfSession(HttpClient http, string serviceRootUrl)
+    {
+        _http = http;
+        _serviceRoot = serviceRootUrl.TrimEnd('/');
+    }
+
+    public async Task<CsrfToken> GetAsync()
+    {
+        if (_cached is not null) return _cached;
+        using var request = new HttpRequestMessage(HttpMethod.Head, _serviceRoot + "/");
+        request.Headers.TryAddWithoutValidation("x-csrf-token", "fetch");
+        using HttpResponseMessage response = await _http.SendAsync(request);
+        string? token = response.Headers.TryGetValues("x-csrf-token", out var values)
+            ? values.FirstOrDefault()
+            : null;
+        if (token is null)
+            throw new SapCsrfException("gateway answered the CSRF pre-flight without a token header");
+        var cookies = new List<string>();
+        if (response.Headers.TryGetValues("Set-Cookie", out var setCookies))
+        {
+            foreach (string raw in setCookies)
+                cookies.Add(raw.Split(';', 2)[0].Trim());
+        }
+        _cached = new CsrfToken(token, cookies);
+        return _cached;
+    }
+
+    public void Invalidate() => _cached = null;
+}
