diff --git a/microtap.sh b/microtap.sh
new file mode 100644
index 0000000..4dfcc6a
--- /dev/null
+++ b/microtap.sh
@@ -0,0 +1,79 @@
+#!/usr/bin/env bash
+# microtap.sh — a tiny sourceable test framework with TAP-ish output.
+#
+# Source this file, register tests with mt_test, then call mt_run.
+# Sourcing is silent: nothing here runs or prints until mt_run.
+
+MT_NAMES=()
+MT_FNS=()
+MT_CURRENT_FAILED=0
+
+mt_test() { # mt_test <display-name> <function-name>
+  MT_NAMES+=("$1")
+  MT_FNS+=("$2")
+}
+
+mt__diag() { # mt__diag <message> -- diagnostic line + mark current test failed
+  printf '# %s\n' "$1"
+  MT_CURRENT_FAILED=1
+}
+
+assert_eq() { # assert_eq <expected> <actual>
+  if [[ "$1" == "$2" ]]; then
+    return 0
+  fi
+  mt__diag "assert_eq failed: expected '$1' actual '$2'"
+  return 1
+}
+
+assert_ne() { # assert_ne <unexpected> <actual>
+  if [[ "$1" != "$2" ]]; then
+    return 0
+  fi
+  mt__diag "assert_ne failed: both '$2'"
+  return 1
+}
+
+assert_fail() { # assert_fail <cmd...> -- passes iff the command exits nonzero
+  if "$@"; then
+    mt__diag "assert_fail failed: command succeeded"
+    return 1
+  fi
+  return 0
+}
+
+assert_out() { # assert_out <expected-stdout> <cmd...>
+  local mt__expected=$1 mt__actual
+  shift
+  mt__actual=$("$@")
+  if [[ "$mt__expected" == "$mt__actual" ]]; then
+    return 0
+  fi
+  mt__diag "assert_out failed: expected '$mt__expected' actual '$mt__actual'"
+  return 1
+}
+
+mt_run() { # run every registered test; returns 1 if any failed, else 0
+  local mt__total=${#MT_FNS[@]}
+  local mt__i mt__pass=0 mt__fail=0
+  printf '1..%d\n' "$mt__total"
+  for (( mt__i = 0; mt__i < mt__total; mt__i++ )); do
+    MT_CURRENT_FAILED=0
+    if declare -F setup > /dev/null; then
+      setup
+    fi
+    "${MT_FNS[$mt__i]}"
+    if declare -F teardown > /dev/null; then
+      teardown
+    fi
+    if [[ "$MT_CURRENT_FAILED" -eq 0 ]]; then
+      mt__pass=$((mt__pass + 1))
+      printf 'ok %d - %s\n' "$((mt__i + 1))" "${MT_NAMES[$mt__i]}"
+    else
+      mt__fail=$((mt__fail + 1))
+      printf 'not ok %d - %s\n' "$((mt__i + 1))" "${MT_NAMES[$mt__i]}"
+    fi
+  done
+  printf '# pass %d fail %d\n' "$mt__pass" "$mt__fail"
+  [[ "$mt__fail" -eq 0 ]]
+}
