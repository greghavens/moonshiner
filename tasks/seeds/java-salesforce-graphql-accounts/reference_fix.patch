diff --git a/AccountsExporter.java b/AccountsExporter.java
new file mode 100644
index 0000000..cd52329
--- /dev/null
+++ b/AccountsExporter.java
@@ -0,0 +1,94 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Walks the whole uiapi Account connection with relay pagination
+ * ($first/$after variables against one fixed operation document) and decodes
+ * edges into AccountRecord values. See docs/contract.json.
+ */
+public final class AccountsExporter {
+
+    // One document for every page: cursors travel exclusively in variables.
+    private static final String DOCUMENT = """
+            query AccountScan($first: Int, $after: String) {
+              uiapi {
+                query {
+                  Account(first: $first, after: $after) {
+                    edges {
+                      node {
+                        Id
+                        Name { value }
+                        Industry { value }
+                        AnnualRevenue { value }
+                        Website { value }
+                      }
+                      cursor
+                    }
+                    pageInfo { hasNextPage endCursor }
+                    totalCount
+                  }
+                }
+              }
+            }""";
+
+    private final GraphqlClient client;
+    private final int pageSize;
+
+    public AccountsExporter(String instanceUrl, String apiVersion,
+                            String accessToken, int pageSize) {
+        this.client = new GraphqlClient(instanceUrl, apiVersion, accessToken);
+        this.pageSize = pageSize;
+    }
+
+    @SuppressWarnings("unchecked")
+    public AccountsExport fetchAll() throws GraphqlHttpException, GraphqlQueryException {
+        List<AccountRecord> records = new ArrayList<>();
+        List<GraphqlError> warnings = new ArrayList<>();
+        long totalCount = 0;
+        String after = null;
+
+        while (true) {
+            Map<String, Object> variables = new LinkedHashMap<>();
+            variables.put("first", pageSize);
+            variables.put("after", after);
+
+            Map<String, Object> envelope = client.execute(DOCUMENT, variables);
+            warnings.addAll(GraphqlClient.decodeErrors(envelope));
+
+            Map<String, Object> data = (Map<String, Object>) envelope.get("data");
+            Map<String, Object> uiapi = (Map<String, Object>) data.get("uiapi");
+            Map<String, Object> query = (Map<String, Object>) uiapi.get("query");
+            Map<String, Object> connection = (Map<String, Object>) query.get("Account");
+
+            totalCount = ((Number) connection.get("totalCount")).longValue();
+            for (Object rawEdge : (List<Object>) connection.get("edges")) {
+                Map<String, Object> edge = (Map<String, Object>) rawEdge;
+                records.add(decodeNode((Map<String, Object>) edge.get("node")));
+            }
+
+            Map<String, Object> pageInfo = (Map<String, Object>) connection.get("pageInfo");
+            boolean hasNext = Boolean.TRUE.equals(pageInfo.get("hasNextPage"));
+            if (!hasNext) break;
+            after = (String) pageInfo.get("endCursor");
+        }
+        return new AccountsExport(records, totalCount, warnings);
+    }
+
+    private static AccountRecord decodeNode(Map<String, Object> node) {
+        Object revenue = fieldValue(node, "AnnualRevenue");
+        return new AccountRecord(
+                (String) node.get("Id"),
+                (String) fieldValue(node, "Name"),
+                (String) fieldValue(node, "Industry"),
+                revenue == null ? null : ((Number) revenue).doubleValue(),
+                (String) fieldValue(node, "Website"));
+    }
+
+    private static Object fieldValue(Map<String, Object> node, String field) {
+        Object wrapper = node.get(field);
+        if (!(wrapper instanceof Map<?, ?> m)) return null;
+        return m.get("value");
+    }
+}
diff --git a/GraphqlClient.java b/GraphqlClient.java
new file mode 100644
index 0000000..81a40e7
--- /dev/null
+++ b/GraphqlClient.java
@@ -0,0 +1,102 @@
+import java.io.IOException;
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Thin transport for the Salesforce GraphQL endpoint: POST
+ * {instance}/services/data/{version}/graphql with a query document and a
+ * variables map, per docs/contract.json.
+ */
+public final class GraphqlClient {
+
+    private final String endpoint;
+    private final String accessToken;
+    private final HttpClient http = HttpClient.newHttpClient();
+
+    public GraphqlClient(String instanceUrl, String apiVersion, String accessToken) {
+        String base = instanceUrl.endsWith("/")
+                ? instanceUrl.substring(0, instanceUrl.length() - 1)
+                : instanceUrl;
+        this.endpoint = base + "/services/data/" + apiVersion + "/graphql";
+        this.accessToken = accessToken;
+    }
+
+    /** Execute one operation; returns the parsed response envelope. */
+    @SuppressWarnings("unchecked")
+    public Map<String, Object> execute(String document, Map<String, Object> variables)
+            throws GraphqlHttpException, GraphqlQueryException {
+        Map<String, Object> payload = new LinkedHashMap<>();
+        payload.put("query", document);
+        payload.put("variables", variables);
+
+        HttpRequest request = HttpRequest.newBuilder(URI.create(endpoint))
+                .header("Authorization", "Bearer " + accessToken)
+                .header("Content-Type", "application/json")
+                .header("Accept", "application/json")
+                .POST(HttpRequest.BodyPublishers.ofString(
+                        Json.write(payload), StandardCharsets.UTF_8))
+                .build();
+
+        HttpResponse<String> response;
+        try {
+            response = http.send(request, HttpResponse.BodyHandlers.ofString());
+        } catch (IOException | InterruptedException e) {
+            throw new GraphqlHttpException(0, "TRANSPORT_FAILURE",
+                    "request never completed: " + e.getClass().getSimpleName());
+        }
+
+        if (response.statusCode() != 200) {
+            throw restError(response.statusCode(), response.body());
+        }
+
+        Map<String, Object> envelope = (Map<String, Object>) Json.parse(response.body());
+        Object data = envelope.get("data");
+        if (data == null) {
+            throw new GraphqlQueryException(decodeErrors(envelope));
+        }
+        return envelope;
+    }
+
+    /** Decode the errors section into GraphqlError values (empty if absent). */
+    @SuppressWarnings("unchecked")
+    public static List<GraphqlError> decodeErrors(Map<String, Object> envelope) {
+        List<GraphqlError> out = new ArrayList<>();
+        Object raw = envelope.get("errors");
+        if (!(raw instanceof List<?> entries)) return out;
+        for (Object entry : entries) {
+            Map<String, Object> e = (Map<String, Object>) entry;
+            String errorType = null;
+            if (e.get("extensions") instanceof Map<?, ?> ext) {
+                Object classification = ext.get("classification");
+                if (classification != null) errorType = classification.toString();
+            }
+            List<Object> path = e.get("path") instanceof List<?> p
+                    ? new ArrayList<>(p) : new ArrayList<>();
+            out.add(new GraphqlError(String.valueOf(e.get("message")), errorType, path));
+        }
+        return out;
+    }
+
+    private static GraphqlHttpException restError(int status, String body) {
+        String errorCode = "UNKNOWN";
+        String message = "";
+        try {
+            Object parsed = Json.parse(body);
+            if (parsed instanceof List<?> entries && !entries.isEmpty()
+                    && entries.get(0) instanceof Map<?, ?> first) {
+                errorCode = String.valueOf(first.get("errorCode"));
+                message = String.valueOf(first.get("message"));
+            }
+        } catch (RuntimeException ignored) {
+            // non-JSON error body; keep the defaults
+        }
+        return new GraphqlHttpException(status, errorCode, message);
+    }
+}
diff --git a/GraphqlError.java b/GraphqlError.java
new file mode 100644
index 0000000..57b54a0
--- /dev/null
+++ b/GraphqlError.java
@@ -0,0 +1,20 @@
+import java.util.List;
+
+/** One entry from the errors section of a GraphQL response. */
+public final class GraphqlError {
+
+    public final String message;
+    public final String errorType; // extensions.classification, may be null
+    public final List<Object> path;
+
+    public GraphqlError(String message, String errorType, List<Object> path) {
+        this.message = message;
+        this.errorType = errorType;
+        this.path = path;
+    }
+
+    @Override
+    public String toString() {
+        return "GraphqlError[" + errorType + ": " + message + "]";
+    }
+}
diff --git a/GraphqlHttpException.java b/GraphqlHttpException.java
new file mode 100644
index 0000000..25d6025
--- /dev/null
+++ b/GraphqlHttpException.java
@@ -0,0 +1,15 @@
+/**
+ * A transport-level failure: the endpoint answered a non-200 status with the
+ * standard REST error array. Never carries the access token.
+ */
+public class GraphqlHttpException extends Exception {
+
+    public final int status;
+    public final String errorCode;
+
+    public GraphqlHttpException(int status, String errorCode, String message) {
+        super("GraphQL endpoint answered " + status + " (" + errorCode + "): " + message);
+        this.status = status;
+        this.errorCode = errorCode;
+    }
+}
diff --git a/GraphqlQueryException.java b/GraphqlQueryException.java
new file mode 100644
index 0000000..faa354e
--- /dev/null
+++ b/GraphqlQueryException.java
@@ -0,0 +1,16 @@
+import java.util.List;
+
+/**
+ * The query itself failed: the response carried null data with errors.
+ * Never carries the access token.
+ */
+public class GraphqlQueryException extends Exception {
+
+    public final List<GraphqlError> errors;
+
+    public GraphqlQueryException(List<GraphqlError> errors) {
+        super("GraphQL query failed: "
+                + (errors.isEmpty() ? "no error detail" : errors.get(0).toString()));
+        this.errors = errors;
+    }
+}
