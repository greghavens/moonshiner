+// Package ipq implements an indexed min-priority queue over string keys.
+// Entries can be repositioned or removed by key in O(log n), and equal
+// priorities dispatch FIFO by original arrival.
+package ipq
+
+import (
+	"errors"
+	"fmt"
+)
+
+// Sentinel errors returned by Queue operations.
+var (
+	ErrEmpty        = errors.New("ipq: queue is empty")
+	ErrDuplicateKey = errors.New("ipq: key already enqueued")
+	ErrUnknownKey   = errors.New("ipq: key not enqueued")
+)
+
+type item struct {
+	key      string
+	priority int
+	arrival  uint64 // FIFO tie-break: original Push sequence number
+}
+
+// Queue is an indexed min-priority queue. Construct with New.
+type Queue struct {
+	heap []item
+	pos  map[string]int // key -> index in heap
+	seq  uint64
+}
+
+// New returns an empty queue.
+func New() *Queue {
+	return &Queue{pos: make(map[string]int)}
+}
+
+// Len returns the number of enqueued entries.
+func (q *Queue) Len() int { return len(q.heap) }
+
+// less orders by priority, then by arrival for FIFO tie-breaking.
+func (q *Queue) less(a, b int) bool {
+	if q.heap[a].priority != q.heap[b].priority {
+		return q.heap[a].priority < q.heap[b].priority
+	}
+	return q.heap[a].arrival < q.heap[b].arrival
+}
+
+func (q *Queue) swap(a, b int) {
+	q.heap[a], q.heap[b] = q.heap[b], q.heap[a]
+	q.pos[q.heap[a].key] = a
+	q.pos[q.heap[b].key] = b
+}
+
+func (q *Queue) siftUp(i int) {
+	for i > 0 {
+		parent := (i - 1) / 2
+		if !q.less(i, parent) {
+			return
+		}
+		q.swap(i, parent)
+		i = parent
+	}
+}
+
+func (q *Queue) siftDown(i int) {
+	n := len(q.heap)
+	for {
+		smallest := i
+		if l := 2*i + 1; l < n && q.less(l, smallest) {
+			smallest = l
+		}
+		if r := 2*i + 2; r < n && q.less(r, smallest) {
+			smallest = r
+		}
+		if smallest == i {
+			return
+		}
+		q.swap(i, smallest)
+		i = smallest
+	}
+}
+
+// Push enqueues key at the given priority. A key that is already enqueued
+// is rejected with ErrDuplicateKey and the stored entry is untouched.
+func (q *Queue) Push(key string, priority int) error {
+	if _, ok := q.pos[key]; ok {
+		return fmt.Errorf("%w: %s", ErrDuplicateKey, key)
+	}
+	q.heap = append(q.heap, item{key: key, priority: priority, arrival: q.seq})
+	q.seq++
+	i := len(q.heap) - 1
+	q.pos[key] = i
+	q.siftUp(i)
+	return nil
+}
+
+// Peek returns the front entry without removing it.
+func (q *Queue) Peek() (string, int, error) {
+	if len(q.heap) == 0 {
+		return "", 0, ErrEmpty
+	}
+	return q.heap[0].key, q.heap[0].priority, nil
+}
+
+// Pop removes and returns the entry with the lowest priority, breaking
+// ties by earliest arrival.
+func (q *Queue) Pop() (string, int, error) {
+	if len(q.heap) == 0 {
+		return "", 0, ErrEmpty
+	}
+	front := q.heap[0]
+	q.removeAt(0)
+	return front.key, front.priority, nil
+}
+
+// UpdatePriority repositions an enqueued key at a new priority. The key's
+// original arrival order is preserved for tie-breaking.
+func (q *Queue) UpdatePriority(key string, priority int) error {
+	i, ok := q.pos[key]
+	if !ok {
+		return fmt.Errorf("%w: %s", ErrUnknownKey, key)
+	}
+	q.heap[i].priority = priority
+	q.siftUp(i)
+	q.siftDown(q.pos[key])
+	return nil
+}
+
+// Remove deletes an enqueued key. A subsequent Push of the same key is a
+// fresh arrival.
+func (q *Queue) Remove(key string) error {
+	i, ok := q.pos[key]
+	if !ok {
+		return fmt.Errorf("%w: %s", ErrUnknownKey, key)
+	}
+	q.removeAt(i)
+	return nil
+}
+
+// removeAt deletes the entry at heap index i, restoring heap order.
+func (q *Queue) removeAt(i int) {
+	last := len(q.heap) - 1
+	delete(q.pos, q.heap[i].key)
+	if i != last {
+		q.heap[i] = q.heap[last]
+		q.pos[q.heap[i].key] = i
+	}
+	q.heap = q.heap[:last]
+	if i < last {
+		moved := q.heap[i].key
+		q.siftUp(i)
+		q.siftDown(q.pos[moved])
+	}
+}
