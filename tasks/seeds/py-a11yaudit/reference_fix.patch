+"""Accessibility audit for rendered handbook pages.
+
+Reads one HTML document and returns structured findings — (code, line,
+subject) tuples sorted by (line, code, subject) — so CI can leave actionable,
+line-anchored review comments. Built on html.parser; line numbers come from
+getpos() and point at the line where the offending tag opens.
+"""
+from collections import namedtuple
+from html.parser import HTMLParser
+
+Finding = namedtuple("Finding", ["code", "line", "subject"])
+
+_HEADINGS = {"h1": 1, "h2": 2, "h3": 3, "h4": 4, "h5": 5, "h6": 6}
+_FORM_CONTROLS = {"input", "select", "textarea"}
+
+
+class _Scanner(HTMLParser):
+    """First pass: collect every fact the checks need, in document order."""
+
+    def __init__(self):
+        super().__init__(convert_charrefs=True)
+        self.headings = []      # (line, tag, level)
+        self.images = []        # (line, src, has_alt)
+        self.labels = []        # (line, for_value)
+        self.ids = []           # (line, id_value) for every element
+        self.control_ids = set()  # ids that sit on input/select/textarea
+        self.has_main = False
+
+    def handle_starttag(self, tag, attrs):
+        self._element(tag, attrs)
+
+    def handle_startendtag(self, tag, attrs):
+        # self-closing syntax (<img .../>) arrives here, not handle_starttag
+        self._element(tag, attrs)
+
+    def _element(self, tag, attrs):
+        line = self.getpos()[0]
+        seen = {}
+        for name, value in attrs:
+            seen.setdefault(name, value)
+
+        if tag == "main":
+            self.has_main = True
+        if tag in _HEADINGS:
+            self.headings.append((line, tag, _HEADINGS[tag]))
+        elif tag == "img":
+            self.images.append((line, seen.get("src") or "", "alt" in seen))
+        elif tag == "label":
+            for_value = seen.get("for")
+            if for_value:
+                self.labels.append((line, for_value))
+
+        element_id = seen.get("id")
+        if element_id:
+            self.ids.append((line, element_id))
+            if tag in _FORM_CONTROLS:
+                self.control_ids.add(element_id)
+
+
+def audit(html):
+    """Return the page's accessibility findings, sorted by (line, code, subject)."""
+    scanner = _Scanner()
+    scanner.feed(html)
+    scanner.close()
+
+    findings = []
+
+    # heading-skip: each heading vs. the previous one; document start is level 0
+    previous_level = 0
+    for line, tag, level in scanner.headings:
+        if level > previous_level + 1:
+            findings.append(Finding("heading-skip", line, tag))
+        previous_level = level
+
+    # img-missing-alt: alt="" passes (decorative), a missing attribute does not
+    for line, src, has_alt in scanner.images:
+        if not has_alt:
+            findings.append(Finding("img-missing-alt", line, src))
+
+    # label-orphan: for= must land on a form-control id somewhere in the document
+    for line, for_value in scanner.labels:
+        if for_value not in scanner.control_ids:
+            findings.append(Finding("label-orphan", line, for_value))
+
+    # duplicate-id: flag the second and later uses, first occurrence stays clean
+    first_seen = set()
+    for line, element_id in scanner.ids:
+        if element_id in first_seen:
+            findings.append(Finding("duplicate-id", line, element_id))
+        else:
+            first_seen.add(element_id)
+
+    # landmark-missing: the page needs a <main> element
+    if not scanner.has_main:
+        findings.append(Finding("landmark-missing", 1, "main"))
+
+    findings.sort(key=lambda f: (f.line, f.code, f.subject))
+    return findings
