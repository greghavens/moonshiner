+"""Tic-tac-toe for the terminal: two humans, or one human vs a perfect bot."""
+import sys
+
+LINES = ((0, 1, 2), (3, 4, 5), (6, 7, 8),
+         (0, 3, 6), (1, 4, 7), (2, 5, 8),
+         (0, 4, 8), (2, 4, 6))
+
+_memo = {}
+
+
+def winner(board):
+    """Return 'X' or 'O' if that side has three in a row, else None."""
+    for a, b, c in LINES:
+        if board[a] != "." and board[a] == board[b] == board[c]:
+            return board[a]
+    return None
+
+
+def render(board):
+    """Three rows of cells joined with '|', separated by '-+-+-' lines."""
+    return "\n-+-+-\n".join("|".join(board[r * 3:r * 3 + 3]) for r in range(3))
+
+
+def _other(player):
+    return "O" if player == "X" else "X"
+
+
+def _search(board, player):
+    """Best (score, move) for `player` to move.
+
+    Score is positive if `player` wins with perfect play, negative if the
+    opponent does, 0 for a draw; magnitude shrinks by one per ply so faster
+    wins and slower losses score higher.
+    """
+    key = board + player
+    if key in _memo:
+        return _memo[key]
+    opp = _other(player)
+    best = None
+    for i, cell in enumerate(board):
+        if cell != ".":
+            continue
+        nxt = board[:i] + player + board[i + 1:]
+        if winner(nxt) == player:
+            score = 10
+        elif "." not in nxt:
+            score = 0
+        else:
+            child, _ = _search(nxt, opp)
+            score = -child
+            if score > 0:
+                score -= 1
+            elif score < 0:
+                score += 1
+        if best is None or score > best[0]:
+            best = (score, i)
+    _memo[key] = best
+    return best
+
+
+def best_move(board, player):
+    """The minimax-optimal cell for `player`; ties break to the lowest index."""
+    return _search(board, player)[1]
+
+
+def main(argv=None):
+    argv = sys.argv if argv is None else argv
+    bot = "--bot" in argv[1:]
+    board = "." * 9
+    player = "X"
+    while True:
+        print(render(board))
+        won = winner(board)
+        if won:
+            print(f"{won} wins")
+            return 0
+        if "." not in board:
+            print("draw")
+            return 0
+        if bot and player == "O":
+            move = best_move(board, "O")
+            print(f"O plays {move}")
+            board = board[:move] + "O" + board[move + 1:]
+            player = "X"
+            continue
+        try:
+            line = input(f"{player}> ").strip()
+        except EOFError:
+            return 0
+        if not line.isdigit() or int(line) > 8 or board[int(line)] != ".":
+            print("invalid move")
+            continue
+        move = int(line)
+        board = board[:move] + player + board[move + 1:]
+        player = _other(player)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
