+type Rule = [RegExp, string];
+
+const PLURAL_RULES: Rule[] = [
+  [/(analy|cri)sis$/i, '$1ses'],
+  [/(kni|wi|li)fe$/i, '$1ves'],
+  [/(lea|wol|shel|cal)f$/i, '$1ves'],
+  [/([^aeiou])y$/i, '$1ies'],
+  [/(s|x|z|ch|sh)$/i, '$1es'],
+  [/$/, 's'],
+];
+
+const SINGULAR_RULES: Rule[] = [
+  [/(analy|cri)ses$/i, '$1sis'],
+  [/(kni|wi|li)ves$/i, '$1fe'],
+  [/(lea|wol|shel|cal)ves$/i, '$1f'],
+  [/([^aeiou])ies$/i, '$1y'],
+  [/(s|x|z|ch|sh)es$/i, '$1'],
+  [/s$/i, ''],
+];
+
+const IRREGULARS: Array<[string, string]> = [
+  ['person', 'people'],
+  ['child', 'children'],
+  ['mouse', 'mice'],
+  ['foot', 'feet'],
+  ['tooth', 'teeth'],
+];
+
+const UNCOUNTABLES = ['sheep', 'fish', 'series', 'information', 'equipment'];
+
+function restoreCase(sample: string, word: string): string {
+  if (sample.length > 0 && sample === sample.toUpperCase() && /[A-Za-z]/.test(sample)) {
+    return word.toUpperCase();
+  }
+  if (sample.length > 0 && sample[0] === sample[0].toUpperCase() && sample[0] !== sample[0].toLowerCase()) {
+    return word[0].toUpperCase() + word.slice(1);
+  }
+  return word;
+}
+
+export class Inflector {
+  private pluralRules: Rule[];
+  private singularRules: Rule[];
+  private singularToPlural: Map<string, string>;
+  private pluralToSingular: Map<string, string>;
+  private uncountables: Set<string>;
+
+  constructor() {
+    this.pluralRules = [...PLURAL_RULES];
+    this.singularRules = [...SINGULAR_RULES];
+    this.singularToPlural = new Map();
+    this.pluralToSingular = new Map();
+    for (const [singular, plural] of IRREGULARS) {
+      this.singularToPlural.set(singular, plural);
+      this.pluralToSingular.set(plural, singular);
+    }
+    this.uncountables = new Set(UNCOUNTABLES);
+  }
+
+  addIrregular(singular: string, plural: string): void {
+    this.singularToPlural.set(singular.toLowerCase(), plural.toLowerCase());
+    this.pluralToSingular.set(plural.toLowerCase(), singular.toLowerCase());
+  }
+
+  addUncountable(word: string): void {
+    this.uncountables.add(word.toLowerCase());
+  }
+
+  addPluralRule(pattern: RegExp, replacement: string): void {
+    this.pluralRules.unshift([pattern, replacement]);
+  }
+
+  addSingularRule(pattern: RegExp, replacement: string): void {
+    this.singularRules.unshift([pattern, replacement]);
+  }
+
+  pluralize(word: string, count?: number): string {
+    if (count === 1) return this.singularize(word);
+    return this.inflect(word, this.singularToPlural, this.pluralToSingular, this.pluralRules);
+  }
+
+  singularize(word: string): string {
+    return this.inflect(word, this.pluralToSingular, this.singularToPlural, this.singularRules);
+  }
+
+  private inflect(
+    word: string,
+    forward: Map<string, string>,
+    reverse: Map<string, string>,
+    rules: Rule[],
+  ): string {
+    const lower = word.toLowerCase();
+    if (this.uncountables.has(lower)) return word;
+    const irregular = forward.get(lower);
+    if (irregular !== undefined) return restoreCase(word, irregular);
+    // already in the target form (e.g. pluralizing 'people')
+    if (reverse.has(lower)) return word;
+    for (const [pattern, replacement] of rules) {
+      if (pattern.test(lower)) {
+        return restoreCase(word, lower.replace(pattern, replacement));
+      }
+    }
+    return word;
+  }
+}
+
+export const inflector = new Inflector();
+
+export function pluralize(word: string, count?: number): string {
+  return inflector.pluralize(word, count);
+}
+
+export function singularize(word: string): string {
+  return inflector.singularize(word);
+}
