+#!/usr/bin/env python3
+"""Produce a genuine two-stage lodging trace for reference validation."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import shutil
+import subprocess
+import sys
+
+
+ROOT = Path(__file__).resolve().parent
+TOOL = ROOT / "lodging_desk.py"
+TARGETS = (
+    ("Orchard Room Leadership Retreat", "Austin"),
+    ("Juniper Suite Planning Stay", "Raleigh"),
+)
+
+
+def run_parallel(commands: list[list[str]]) -> list[dict]:
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    results = []
+    for process in processes:
+        stdout, stderr = process.communicate()
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or f"tool exited {process.returncode}")
+        results.append(json.loads(stdout))
+    return results
+
+
+def stage_search() -> int:
+    commands = [
+        [sys.executable, str(TOOL), "search", "--name", name,
+         "--location", location]
+        for name, location in TARGETS
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def stage_get(ids: list[str]) -> int:
+    commands = [
+        [sys.executable, str(TOOL), "get", "--id", reservation_id]
+        for reservation_id in ids
+    ]
+    print(json.dumps(run_parallel(commands), separators=(",", ":")))
+    return 0
+
+
+def orchestrate() -> int:
+    runtime = ROOT / ".lodging-runtime"
+    if runtime.exists():
+        shutil.rmtree(runtime)
+
+    search = subprocess.run(
+        [sys.executable, str(Path(__file__).resolve()), "stage-search"],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    search_results = json.loads(search.stdout)
+    ids = []
+    records = []
+    for result in search_results:
+        matches = result.get("matches", [])
+        if result.get("count") != 1 or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        ids.append(matches[0]["id"])
+
+    get = subprocess.run(
+        [sys.executable, str(Path(__file__).resolve()), "stage-get", *ids],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        check=True,
+    )
+    records.extend(json.loads(get.stdout))
+    lines = ["| Record | ID | Date | Status |", "|---|---|---|---|"]
+    lines.extend(
+        f"| {record['name']} | {record['id']} | {record['date']} | {record['status']} |"
+        for record in records
+    )
+    (ROOT / "lodging-audit.md").write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return 0
+
+
+def main() -> int:
+    if len(sys.argv) == 1:
+        return orchestrate()
+    if sys.argv[1:] == ["stage-search"]:
+        return stage_search()
+    if len(sys.argv) == 4 and sys.argv[1] == "stage-get":
+        return stage_get(sys.argv[2:])
+    raise SystemExit("invalid reference setup invocation")
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
