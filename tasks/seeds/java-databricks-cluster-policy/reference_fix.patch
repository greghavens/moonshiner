@@ -0,0 +1,45 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** Outcome of one reconciliation pass, in desired-input order. */
+public final class ReconcileReport {
+
+    private final List<String> created = new ArrayList<>();
+    private final List<String> edited = new ArrayList<>();
+    private final List<String> skipped = new ArrayList<>();
+    private final Map<String, DbxApiException> failures = new LinkedHashMap<>();
+
+    void addCreated(String name) {
+        created.add(name);
+    }
+
+    void addEdited(String name) {
+        edited.add(name);
+    }
+
+    void addSkipped(String name) {
+        skipped.add(name);
+    }
+
+    void addFailure(String name, DbxApiException error) {
+        failures.put(name, error);
+    }
+
+    public List<String> created() {
+        return List.copyOf(created);
+    }
+
+    public List<String> edited() {
+        return List.copyOf(edited);
+    }
+
+    public List<String> skipped() {
+        return List.copyOf(skipped);
+    }
+
+    public Map<String, DbxApiException> failures() {
+        return Map.copyOf(failures);
+    }
+}
