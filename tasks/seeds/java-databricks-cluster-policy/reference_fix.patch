+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.Objects;
+
+/**
+ * Reconciles a desired set of cluster policies against the workspace.
+ *
+ * Existing policies are listed once and matched by name. Definition and
+ * policy-family override documents are compared as parsed JSON trees, never
+ * as strings. Edits carry over unmanaged settings (description,
+ * max_clusters_per_user, libraries) from the existing policy so nothing
+ * unknown is overwritten, and respect the documented rule that definition
+ * and policy_family_id are mutually exclusive. Databricks-managed default
+ * policies are never written to. Per-policy API failures are recorded and
+ * the run continues.
+ */
+public class PolicyReconciler {
+
+    private final PoliciesClient client;
+
+    public PolicyReconciler(PoliciesClient client) {
+        this.client = client;
+    }
+
+    public ReconcileReport reconcile(List<Map<String, Object>> desired) {
+        ReconcileReport report = new ReconcileReport();
+        Map<String, Map<String, Object>> existingByName = new LinkedHashMap<>();
+        for (Map<String, Object> policy : client.listPolicies()) {
+            existingByName.put((String) policy.get("name"), policy);
+        }
+        for (Map<String, Object> want : desired) {
+            String name = (String) want.get("name");
+            Map<String, Object> existing = existingByName.get(name);
+            try {
+                if (existing == null) {
+                    client.createPolicy(createPayload(want));
+                    report.addCreated(name);
+                } else if (inSync(want, existing)) {
+                    report.addSkipped(name);
+                } else if (Boolean.TRUE.equals(existing.get("is_default"))) {
+                    report.addFailure(name, new DbxApiException(400, "INVALID_PARAMETER_VALUE",
+                            "Policy " + name + " is a Databricks-managed default policy and cannot be edited."));
+                } else {
+                    client.editPolicy(editPayload(want, existing));
+                    report.addEdited(name);
+                }
+            } catch (DbxApiException e) {
+                report.addFailure(name, e);
+            }
+        }
+        return report;
+    }
+
+    private static boolean jsonEquals(Object a, Object b) {
+        if (a == null || b == null) {
+            return a == null && b == null;
+        }
+        return Objects.equals(Json.parse((String) a), Json.parse((String) b));
+    }
+
+    private static boolean inSync(Map<String, Object> want, Map<String, Object> existing) {
+        if (want.containsKey("definition")) {
+            if (!jsonEquals(want.get("definition"), existing.get("definition"))) {
+                return false;
+            }
+        } else {
+            if (!Objects.equals(want.get("policy_family_id"), existing.get("policy_family_id"))) {
+                return false;
+            }
+            if (want.containsKey("policy_family_definition_overrides")
+                    && !jsonEquals(want.get("policy_family_definition_overrides"),
+                            existing.get("policy_family_definition_overrides"))) {
+                return false;
+            }
+        }
+        for (String managed : List.of("description", "max_clusters_per_user")) {
+            if (want.containsKey(managed)
+                    && !Objects.equals(want.get(managed), existing.get(managed))) {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    private static Map<String, Object> createPayload(Map<String, Object> want) {
+        Map<String, Object> payload = new LinkedHashMap<>();
+        payload.put("name", want.get("name"));
+        copyDesired(want, payload);
+        return payload;
+    }
+
+    private static Map<String, Object> editPayload(Map<String, Object> want,
+                                                   Map<String, Object> existing) {
+        Map<String, Object> payload = new LinkedHashMap<>();
+        payload.put("policy_id", existing.get("policy_id"));
+        payload.put("name", want.get("name"));
+        copyDesired(want, payload);
+        // Edit replaces the whole document server-side: carry over every
+        // unmanaged setting so nothing unknown gets dropped.
+        for (String carried : List.of("description", "max_clusters_per_user", "libraries")) {
+            if (!payload.containsKey(carried) && existing.containsKey(carried)) {
+                payload.put(carried, existing.get(carried));
+            }
+        }
+        return payload;
+    }
+
+    private static void copyDesired(Map<String, Object> want, Map<String, Object> payload) {
+        if (want.containsKey("definition")) {
+            payload.put("definition", want.get("definition"));
+        } else {
+            payload.put("policy_family_id", want.get("policy_family_id"));
+            if (want.containsKey("policy_family_definition_overrides")) {
+                payload.put("policy_family_definition_overrides",
+                        want.get("policy_family_definition_overrides"));
+            }
+        }
+        for (String managed : List.of("description", "max_clusters_per_user")) {
+            if (want.containsKey(managed)) {
+                payload.put(managed, want.get(managed));
+            }
+        }
+    }
+}
