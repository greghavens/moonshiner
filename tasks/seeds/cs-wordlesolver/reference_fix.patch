+namespace WordleSolver;
+
+public static class Feedbacks
+{
+    public static string Score(string guess, string answer)
+    {
+        ValidateWord(guess);
+        ValidateWord(answer);
+        var fb = new char[5];
+        var counts = new int[26];
+        for (var i = 0; i < 5; i++)
+        {
+            if (guess[i] == answer[i]) fb[i] = 'G';
+            else counts[answer[i] - 'a']++;
+        }
+        for (var i = 0; i < 5; i++)
+        {
+            if (fb[i] == 'G') continue;
+            var slot = guess[i] - 'a';
+            if (counts[slot] > 0) { fb[i] = 'Y'; counts[slot]--; }
+            else fb[i] = 'B';
+        }
+        return new string(fb);
+    }
+
+    internal static void ValidateWord(string word)
+    {
+        if (word.Length != 5 || !word.All(c => c is >= 'a' and <= 'z'))
+            throw new ArgumentException($"not a five-letter lowercase word: {word}");
+    }
+}
+
+public class Solver
+{
+    private readonly List<string> _full;
+    private List<string> _pool;
+    private readonly string _firstGuess;
+    private bool _observed;
+
+    public Solver(string candidateListText, string firstGuess)
+    {
+        Feedbacks.ValidateWord(firstGuess);
+        _firstGuess = firstGuess;
+        _full = ParseList(candidateListText);
+        _pool = new List<string>(_full);
+    }
+
+    public int Remaining => _pool.Count;
+
+    public IReadOnlyList<string> Candidates => _pool;
+
+    public string NextGuess()
+    {
+        if (!_observed) return _firstGuess;
+        if (_pool.Count == 0)
+            throw new InvalidOperationException("no candidates remain");
+        return _pool[0];
+    }
+
+    public void Observe(string guess, string feedback)
+    {
+        if (feedback.Length != 5 || !feedback.All(c => c is 'G' or 'Y' or 'B'))
+            throw new ArgumentException($"malformed feedback: {feedback}");
+        _pool = _pool.Where(w => Feedbacks.Score(guess, w) == feedback).ToList();
+        _observed = true;
+    }
+
+    public IReadOnlyList<string> Solve(string answer, int maxGuesses = 6)
+    {
+        if (!_full.Contains(answer))
+            throw new ArgumentException($"answer is not in the candidate list: {answer}");
+        var pool = new List<string>(_full);
+        var guesses = new List<string>();
+        var guess = _firstGuess;
+        for (var turn = 0; turn < maxGuesses; turn++)
+        {
+            guesses.Add(guess);
+            var fb = Feedbacks.Score(guess, answer);
+            if (fb == "GGGGG") return guesses;
+            pool = pool.Where(w => Feedbacks.Score(guess, w) == fb).ToList();
+            if (pool.Count == 0) break;
+            guess = pool[0];
+        }
+        throw new InvalidOperationException($"did not reach {answer} in {maxGuesses} guesses");
+    }
+
+    private static List<string> ParseList(string text)
+    {
+        var words = new List<string>();
+        foreach (var rawLine in text.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            line = line.Trim();
+            if (line.Length == 0) continue;
+            if (line.Length != 5 || !line.All(c => c is >= 'a' and <= 'z'))
+                throw new FormatException($"not a five-letter lowercase word: {line}");
+            words.Add(line);
+        }
+        var deduped = new HashSet<string>(words);
+        if (deduped.Count != words.Count)
+            throw new ArgumentException("candidate list contains duplicates");
+        words.Sort(StringComparer.Ordinal);
+        return words;
+    }
+}
