diff --git a/OperationOutcome.java b/OperationOutcome.java
new file mode 100644
index 0000000..7718073
--- /dev/null
+++ b/OperationOutcome.java
@@ -0,0 +1,102 @@
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Terminal state of a google.longrunning.Operation. A done operation carries
+ * exactly one of error (google.rpc.Status) or response (Any); error code 1 is
+ * google.rpc.Code.CANCELLED and means the operation was cancelled, not failed.
+ */
+final class OperationOutcome {
+    enum State { SUCCEEDED, FAILED, CANCELLED }
+
+    private static final long CODE_CANCELLED = 1L;
+
+    private final String name;
+    private final State state;
+    private final String responseType;
+    private final Map<String, Object> response;
+    private final long errorCode;
+    private final String errorMessage;
+    private final List<Object> errorDetails;
+    private final String metadataType;
+    private final int pollCount;
+    private final int transientRetries;
+
+    private OperationOutcome(String name, State state, String responseType, Map<String, Object> response,
+            long errorCode, String errorMessage, List<Object> errorDetails, String metadataType,
+            int pollCount, int transientRetries) {
+        this.name = name;
+        this.state = state;
+        this.responseType = responseType;
+        this.response = response;
+        this.errorCode = errorCode;
+        this.errorMessage = errorMessage;
+        this.errorDetails = errorDetails;
+        this.metadataType = metadataType;
+        this.pollCount = pollCount;
+        this.transientRetries = transientRetries;
+    }
+
+    String name() {
+        return name;
+    }
+
+    State state() {
+        return state;
+    }
+
+    String responseType() {
+        return responseType;
+    }
+
+    Map<String, Object> response() {
+        return response;
+    }
+
+    long errorCode() {
+        return errorCode;
+    }
+
+    String errorMessage() {
+        return errorMessage;
+    }
+
+    List<Object> errorDetails() {
+        return errorDetails;
+    }
+
+    String metadataType() {
+        return metadataType;
+    }
+
+    int pollCount() {
+        return pollCount;
+    }
+
+    int transientRetries() {
+        return transientRetries;
+    }
+
+    static OperationOutcome of(String name, Map<String, Object> operation, String metadataType,
+            int polls, int transientRetries) {
+        Object error = operation.get("error");
+        if (error instanceof Map<?, ?>) {
+            Map<String, Object> status = Json.object(error);
+            long code = status.get("code") instanceof Long l ? l : 0L;
+            String message = status.get("message") == null ? "" : status.get("message").toString();
+            List<Object> details = status.get("details") == null ? List.of() : Json.array(status.get("details"));
+            State state = code == CODE_CANCELLED ? State.CANCELLED : State.FAILED;
+            return new OperationOutcome(name, state, null, Map.of(), code, message, details,
+                    metadataType, polls, transientRetries);
+        }
+        Object response = operation.get("response");
+        if (!(response instanceof Map<?, ?>)) {
+            throw new IllegalStateException(
+                    "operation " + name + " is done but carries neither error nor response");
+        }
+        Map<String, Object> payload = Json.object(response);
+        String type = payload.get("@type") == null ? "" : payload.get("@type").toString();
+        return new OperationOutcome(name, State.SUCCEEDED, type, payload, 0L, "", List.of(),
+                metadataType, polls, transientRetries);
+    }
+}
diff --git a/OperationPoller.java b/OperationPoller.java
new file mode 100644
index 0000000..037a348
--- /dev/null
+++ b/OperationPoller.java
@@ -0,0 +1,78 @@
+import java.util.Map;
+
+/**
+ * Poller for Google-style long-running operations, following the
+ * google.longrunning REST mapping: GET {base}/v1/{name} to poll and
+ * POST {base}/v1/{name}:cancel (empty body) to request cancellation.
+ */
+final class OperationPoller {
+    /** Injected pause between attempts; the poller itself never sleeps. */
+    interface Backoff {
+        void pause(int attempt);
+    }
+
+    record PollPolicy(int maxPolls, int maxTransientRetries, Backoff backoff) {}
+
+    private final ApiHttp http;
+    private final String baseUrl;
+    private final String token;
+    private final PollPolicy policy;
+
+    OperationPoller(ApiHttp http, String baseUrl, String token, PollPolicy policy) {
+        this.http = http;
+        this.baseUrl = baseUrl;
+        this.token = token;
+        this.policy = policy;
+    }
+
+    /**
+     * Polls the operation until it reaches a terminal state. The operation
+     * name is a multi-segment resource path ({name=**{@literal /}operations/*} in the
+     * HTTP binding) and is spliced into the URL verbatim, never escaped.
+     */
+    OperationOutcome poll(String name) {
+        int polls = 0;
+        int transientRetries = 0;
+        String metadataType = null;
+        while (true) {
+            ApiHttp.Response resp = http.get(baseUrl + "/v1/" + name, token);
+            if (resp.status() / 100 != 2) {
+                ApiException failure = ApiException.decode(resp.status(), resp.body());
+                // Per Google's automatic-retry guidance, UNAVAILABLE is the
+                // only status a client should retry on its own.
+                if ("UNAVAILABLE".equals(failure.status()) && transientRetries < policy.maxTransientRetries()) {
+                    transientRetries++;
+                    policy.backoff().pause(transientRetries);
+                    continue;
+                }
+                throw failure;
+            }
+            polls++;
+            Map<String, Object> operation = Json.object(Json.parse(resp.body()));
+            Object metadata = operation.get("metadata");
+            if (metadata instanceof Map<?, ?> m && m.get("@type") != null) {
+                metadataType = m.get("@type").toString();
+            }
+            if (!Boolean.TRUE.equals(operation.get("done"))) {
+                if (polls >= policy.maxPolls()) {
+                    throw new IllegalStateException(
+                            "operation " + name + " still running after " + polls + " polls");
+                }
+                policy.backoff().pause(polls);
+                continue;
+            }
+            return OperationOutcome.of(name, operation, metadataType, polls, transientRetries);
+        }
+    }
+
+    /**
+     * Best-effort cancellation. The response says nothing about the final
+     * state; callers observe cancellation by polling afterwards.
+     */
+    void cancel(String name) {
+        ApiHttp.Response resp = http.post(baseUrl + "/v1/" + name + ":cancel", token, null);
+        if (resp.status() / 100 != 2) {
+            throw ApiException.decode(resp.status(), resp.body());
+        }
+    }
+}
