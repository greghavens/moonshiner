+export interface CsvOptions {
+  delimiter?: string;
+}
+
+export interface ParseOptions extends CsvOptions {
+  header?: boolean;
+}
+
+export function stringify(rows: unknown[][], opts: CsvOptions = {}): string {
+  const delimiter = opts.delimiter ?? ',';
+  const encodeCell = (cell: unknown): string => {
+    const s = String(cell);
+    if (s.includes(delimiter) || s.includes('"') || s.includes('\n') || s.includes('\r')) {
+      return `"${s.replace(/"/g, '""')}"`;
+    }
+    return s;
+  };
+  return rows.map((row) => row.map(encodeCell).join(delimiter)).join('\n');
+}
+
+export function parse(text: string, opts?: ParseOptions & { header?: false }): string[][];
+export function parse(text: string, opts: ParseOptions & { header: true }): Record<string, string>[];
+export function parse(
+  text: string,
+  opts: ParseOptions = {},
+): string[][] | Record<string, string>[] {
+  const delimiter = opts.delimiter ?? ',';
+  const rows: string[][] = [];
+  let fields: string[] = [];
+  let field = '';
+  let rowHasContent = false;
+
+  let i = 0;
+  const n = text.length;
+  while (i < n) {
+    const ch = text[i];
+
+    if (ch === '"' && field === '') {
+      // quoted field
+      i += 1;
+      let closed = false;
+      while (i < n) {
+        const c = text[i];
+        if (c === '"') {
+          if (text[i + 1] === '"') {
+            field += '"';
+            i += 2;
+          } else {
+            i += 1;
+            closed = true;
+            break;
+          }
+        } else {
+          field += c;
+          i += 1;
+        }
+      }
+      if (!closed) throw new SyntaxError('unterminated quoted field');
+      if (i < n) {
+        const after = text[i];
+        const atLineEnd = after === '\n' || (after === '\r' && text[i + 1] === '\n');
+        if (after !== delimiter && !atLineEnd) {
+          throw new SyntaxError(`unexpected character ${JSON.stringify(after)} after closing quote`);
+        }
+      }
+      rowHasContent = true;
+      continue;
+    }
+
+    if (ch === delimiter) {
+      fields.push(field);
+      field = '';
+      rowHasContent = true;
+      i += 1;
+      continue;
+    }
+
+    if (ch === '\n' || (ch === '\r' && text[i + 1] === '\n')) {
+      fields.push(field);
+      rows.push(fields);
+      fields = [];
+      field = '';
+      rowHasContent = false;
+      i += ch === '\r' ? 2 : 1;
+      continue;
+    }
+
+    field += ch;
+    rowHasContent = true;
+    i += 1;
+  }
+
+  if (rowHasContent || fields.length > 0 || field !== '') {
+    fields.push(field);
+    rows.push(fields);
+  }
+
+  if (!opts.header) return rows;
+
+  const [headerRow, ...dataRows] = rows;
+  if (headerRow === undefined) return [];
+  return dataRows.map((row) => {
+    const record: Record<string, string> = {};
+    headerRow.forEach((name, col) => {
+      record[name] = row[col] ?? '';
+    });
+    return record;
+  });
+}
