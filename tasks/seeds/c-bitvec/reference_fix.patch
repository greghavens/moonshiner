diff --git a/bitvec.c b/bitvec.c
new file mode 100644
index 0000000..1b6d322
--- /dev/null
+++ b/bitvec.c
@@ -0,0 +1,144 @@
+#include "bitvec.h"
+
+/* Mask with bits [lo, hi) of one word set, 0 <= lo <= hi <= 64. */
+static uint64_t span_mask(unsigned lo, unsigned hi) {
+    if (lo == hi)
+        return 0;
+    uint64_t all = ~(uint64_t)0;
+    uint64_t high = (hi == 64) ? all : (((uint64_t)1 << hi) - 1);
+    uint64_t low = ((uint64_t)1 << lo) - 1;
+    return high & ~low;
+}
+
+static size_t word_popcount(uint64_t w) {
+    size_t n = 0;
+    while (w != 0) {
+        w &= w - 1;
+        n++;
+    }
+    return n;
+}
+
+int bv_init(bitvec *bv, uint64_t *words, size_t nbits) {
+    if (bv == NULL || words == NULL || nbits == 0)
+        return -1;
+    bv->words = words;
+    bv->nbits = nbits;
+    for (size_t w = 0; w < BV_WORDS(nbits); w++)
+        words[w] = 0;
+    return 0;
+}
+
+int bv_set(bitvec *bv, size_t i) {
+    if (bv == NULL || i >= bv->nbits)
+        return -1;
+    bv->words[i / 64] |= (uint64_t)1 << (i % 64);
+    return 0;
+}
+
+int bv_clear(bitvec *bv, size_t i) {
+    if (bv == NULL || i >= bv->nbits)
+        return -1;
+    bv->words[i / 64] &= ~((uint64_t)1 << (i % 64));
+    return 0;
+}
+
+int bv_flip(bitvec *bv, size_t i) {
+    if (bv == NULL || i >= bv->nbits)
+        return -1;
+    bv->words[i / 64] ^= (uint64_t)1 << (i % 64);
+    return 0;
+}
+
+int bv_test(const bitvec *bv, size_t i) {
+    if (bv == NULL || i >= bv->nbits)
+        return -1;
+    return (bv->words[i / 64] >> (i % 64)) & 1u ? 1 : 0;
+}
+
+/* Walk the words a range touches, applying f(word, mask). */
+static int range_apply(bitvec *bv, size_t lo, size_t hi, int set) {
+    if (bv == NULL || lo > hi || hi > bv->nbits)
+        return -1;
+    size_t w = lo / 64;
+    while (lo < hi) {
+        size_t word_end = (w + 1) * 64;
+        size_t stop = hi < word_end ? hi : word_end;
+        uint64_t m = span_mask((unsigned)(lo % 64),
+                               (unsigned)(stop - w * 64));
+        if (set)
+            bv->words[w] |= m;
+        else
+            bv->words[w] &= ~m;
+        lo = stop;
+        w++;
+    }
+    return 0;
+}
+
+int bv_set_range(bitvec *bv, size_t lo, size_t hi) {
+    return range_apply(bv, lo, hi, 1);
+}
+
+int bv_clear_range(bitvec *bv, size_t lo, size_t hi) {
+    return range_apply(bv, lo, hi, 0);
+}
+
+size_t bv_count(const bitvec *bv) {
+    if (bv == NULL)
+        return 0;
+    size_t n = 0;
+    for (size_t w = 0; w < BV_WORDS(bv->nbits); w++)
+        n += word_popcount(bv->words[w]);
+    return n;
+}
+
+long bv_count_range(const bitvec *bv, size_t lo, size_t hi) {
+    if (bv == NULL || lo > hi || hi > bv->nbits)
+        return -1;
+    size_t n = 0;
+    size_t w = lo / 64;
+    while (lo < hi) {
+        size_t word_end = (w + 1) * 64;
+        size_t stop = hi < word_end ? hi : word_end;
+        uint64_t m = span_mask((unsigned)(lo % 64),
+                               (unsigned)(stop - w * 64));
+        n += word_popcount(bv->words[w] & m);
+        lo = stop;
+        w++;
+    }
+    return (long)n;
+}
+
+/* Scan for the next bit >= from equal to want, skipping uniform words. */
+static long scan(const bitvec *bv, size_t from, int want) {
+    if (bv == NULL || from >= bv->nbits)
+        return -1;
+    size_t w = from / 64;
+    size_t nwords = BV_WORDS(bv->nbits);
+    uint64_t skip = want ? 0 : ~(uint64_t)0;
+    while (w < nwords) {
+        uint64_t bits = bv->words[w];
+        size_t base = w * 64;
+        size_t start = from > base ? from - base : 0;
+        if (bits != skip || start != 0) {
+            for (size_t b = start; b < 64; b++) {
+                size_t i = base + b;
+                if (i >= bv->nbits)
+                    return -1;
+                if ((int)((bits >> b) & 1u) == want)
+                    return (long)i;
+            }
+        }
+        w++;
+    }
+    return -1;
+}
+
+long bv_next_set(const bitvec *bv, size_t from) {
+    return scan(bv, from, 1);
+}
+
+long bv_next_clear(const bitvec *bv, size_t from) {
+    return scan(bv, from, 0);
+}
diff --git a/bitvec.h b/bitvec.h
new file mode 100644
index 0000000..f589ee9
--- /dev/null
+++ b/bitvec.h
@@ -0,0 +1,47 @@
+/* bitvec.h — fixed-size block bitmap over caller-owned words.
+ *
+ * Bit i lives at words[i / 64], bit position i % 64 (LSB first). All
+ * ranges are half-open [lo, hi) with strict bounds: a range outside the
+ * map is an error, never a clamp. No allocation, no globals, no I/O.
+ */
+#ifndef BITVEC_H
+#define BITVEC_H
+
+#include <stddef.h>
+#include <stdint.h>
+
+#define BV_WORDS(nbits) (((nbits) + 63u) / 64u)
+
+typedef struct {
+    uint64_t *words;   /* caller storage, BV_WORDS(nbits) elements */
+    size_t    nbits;
+} bitvec;
+
+/* Bind bv to the caller's words and zero them. -1 on NULL bv/words or
+ * nbits == 0, else 0. */
+int bv_init(bitvec *bv, uint64_t *words, size_t nbits);
+
+/* Single-bit ops. i >= nbits returns -1 and changes nothing. bv_test
+ * returns the bit (0/1) or -1; the mutators return 0 on success. */
+int bv_set(bitvec *bv, size_t i);
+int bv_clear(bitvec *bv, size_t i);
+int bv_flip(bitvec *bv, size_t i);
+int bv_test(const bitvec *bv, size_t i);
+
+/* Range ops over [lo, hi). Require lo <= hi <= nbits, else -1 with the
+ * map untouched. lo == hi is a valid no-op. */
+int bv_set_range(bitvec *bv, size_t lo, size_t hi);
+int bv_clear_range(bitvec *bv, size_t lo, size_t hi);
+
+/* Popcount of the whole map. */
+size_t bv_count(const bitvec *bv);
+
+/* Popcount inside [lo, hi) with the same strict bounds, -1 on a bad
+ * range. */
+long bv_count_range(const bitvec *bv, size_t lo, size_t hi);
+
+/* Smallest index >= from whose bit is set / clear, or -1 when none. */
+long bv_next_set(const bitvec *bv, size_t from);
+long bv_next_clear(const bitvec *bv, size_t from);
+
+#endif /* BITVEC_H */
