+++ b/scheduler.ts
@@ -0,0 +1,98 @@
+interface Task {
+  id: number;
+  time: number;
+  seq: number;
+  fn: () => void;
+  intervalMs: number | null;
+}
+
+export class VirtualScheduler {
+  private current: number;
+  private nextId: number;
+  private nextSeq: number;
+  private tasks: Map<number, Task>;
+
+  constructor() {
+    this.current = 0;
+    this.nextId = 1;
+    this.nextSeq = 1;
+    this.tasks = new Map();
+  }
+
+  now(): number {
+    return this.current;
+  }
+
+  pending(): number {
+    return this.tasks.size;
+  }
+
+  schedule(fn: () => void, delayMs: number): number {
+    if (delayMs < 0) throw new RangeError(`delayMs must be >= 0, got ${delayMs}`);
+    const id = this.nextId++;
+    this.tasks.set(id, {
+      id,
+      time: this.current + delayMs,
+      seq: this.nextSeq++,
+      fn,
+      intervalMs: null,
+    });
+    return id;
+  }
+
+  scheduleRepeating(fn: () => void, intervalMs: number): number {
+    if (intervalMs <= 0) throw new RangeError(`intervalMs must be > 0, got ${intervalMs}`);
+    const id = this.nextId++;
+    this.tasks.set(id, {
+      id,
+      time: this.current + intervalMs,
+      seq: this.nextSeq++,
+      fn,
+      intervalMs,
+    });
+    return id;
+  }
+
+  cancel(id: number): boolean {
+    return this.tasks.delete(id);
+  }
+
+  advance(ms: number): void {
+    this.advanceTo(this.current + ms);
+  }
+
+  advanceTo(target: number): void {
+    if (target < this.current) {
+      throw new RangeError(`cannot advance backwards from ${this.current} to ${target}`);
+    }
+    for (;;) {
+      const task = this.nextDue(target);
+      if (task === null) break;
+      this.current = task.time;
+      if (task.intervalMs !== null) {
+        // reschedule before running so the callback can cancel its own repeat
+        task.time += task.intervalMs;
+        task.seq = this.nextSeq++;
+      } else {
+        this.tasks.delete(task.id);
+      }
+      task.fn(); // an exception propagates; state above is already consistent
+    }
+    this.current = target;
+  }
+
+  private nextDue(target: number): Task | null {
+    let best: Task | null = null;
+    for (const task of this.tasks.values()) {
+      if (task.time > target) continue;
+      if (
+        best === null ||
+        task.time < best.time ||
+        (task.time === best.time && task.seq < best.seq)
+      ) {
+        best = task;
+      }
+    }
+    return best;
+  }
+}
