+namespace SidePots;
+
+public sealed class Pot
+{
+    public int Amount { get; init; }
+    public IReadOnlyList<string> Eligible { get; init; } = Array.Empty<string>();
+}
+
+public sealed class PotReport
+{
+    public IReadOnlyList<Pot> Pots { get; init; } = Array.Empty<Pot>();
+    public IReadOnlyDictionary<string, int> Refunds { get; init; } =
+        new Dictionary<string, int>();
+}
+
+public class Table
+{
+    private sealed class SeatState
+    {
+        public required string Name;
+        public required int Seat;
+        public required int Stack;
+        public int Committed;
+        public bool Folded;
+        public bool AllIn;
+    }
+
+    private readonly List<SeatState> _seats = new();
+    private readonly int _button;
+
+    public Table(IReadOnlyList<(string Name, int Stack)> players, int buttonSeat)
+    {
+        if (players.Count < 2)
+            throw new ArgumentException("need at least two players");
+        if (buttonSeat < 0 || buttonSeat >= players.Count)
+            throw new ArgumentException($"button seat out of range: {buttonSeat}");
+        var names = new HashSet<string>();
+        foreach (var (name, stack) in players)
+        {
+            if (!names.Add(name))
+                throw new ArgumentException($"duplicate player name: {name}");
+            if (stack <= 0)
+                throw new ArgumentException($"stack must be positive: {name}");
+            _seats.Add(new SeatState { Name = name, Seat = _seats.Count, Stack = stack });
+        }
+        _button = buttonSeat;
+    }
+
+    public int CurrentBet => _seats.Max(s => s.Committed);
+
+    public int Committed(string name) => Find(name).Committed;
+
+    public bool IsFolded(string name) => Find(name).Folded;
+
+    public bool IsAllIn(string name) => Find(name).AllIn;
+
+    public void Apply(string script)
+    {
+        foreach (var rawLine in script.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            var parts = line.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries);
+            if (parts.Length == 0) continue;
+            ApplyAction(parts);
+        }
+    }
+
+    private void ApplyAction(string[] parts)
+    {
+        var seat = Find(parts[0]);
+        if (seat.Folded)
+            throw new InvalidOperationException($"{seat.Name} has folded");
+        if (seat.AllIn)
+            throw new InvalidOperationException($"{seat.Name} is already all-in");
+
+        var verb = parts.Length > 1 ? parts[1] : "";
+        switch (verb)
+        {
+            case "raise" when parts.Length == 3:
+                if (!int.TryParse(parts[2], out var target))
+                    throw new FormatException($"bad raise amount: {parts[2]}");
+                if (target <= CurrentBet)
+                    throw new InvalidOperationException(
+                        $"raise to {target} does not exceed the current bet {CurrentBet}");
+                if (target > seat.Stack)
+                    throw new InvalidOperationException(
+                        $"{seat.Name} cannot commit {target} from a {seat.Stack} stack");
+                CommitTo(seat, target);
+                break;
+            case "call" when parts.Length == 2:
+                CommitTo(seat, Math.Min(CurrentBet, seat.Stack));
+                break;
+            case "check" when parts.Length == 2:
+                if (seat.Committed < CurrentBet)
+                    throw new InvalidOperationException($"{seat.Name} cannot check from behind");
+                break;
+            case "fold" when parts.Length == 2:
+                if (seat.Committed == CurrentBet &&
+                    _seats.Count(s => s.Committed == CurrentBet) == 1 && CurrentBet > 0)
+                    throw new InvalidOperationException(
+                        $"{seat.Name} holds the leading bet and cannot fold");
+                seat.Folded = true;
+                break;
+            case "allin" when parts.Length == 2:
+                CommitTo(seat, seat.Stack);
+                break;
+            default:
+                throw new FormatException($"bad action: {string.Join(' ', parts)}");
+        }
+    }
+
+    private static void CommitTo(SeatState seat, int total)
+    {
+        seat.Committed = total;
+        if (seat.Committed == seat.Stack) seat.AllIn = true;
+    }
+
+    public PotReport BuildPots()
+    {
+        var live = _seats.Where(s => !s.Folded).ToList();
+        var refunds = new Dictionary<string, int>();
+        var effective = _seats.ToDictionary(s => s.Name, s => s.Committed);
+
+        // Uncalled top of a raise: sole leader takes back the excess over
+        // the second-highest commitment at the table.
+        var leaders = live.Where(s => s.Committed == CurrentBet).ToList();
+        if (leaders.Count == 1 && CurrentBet > 0)
+        {
+            var second = _seats.Where(s => s != leaders[0]).Max(s => s.Committed);
+            if (CurrentBet - second > 0)
+            {
+                refunds[leaders[0].Name] = CurrentBet - second;
+                effective[leaders[0].Name] = second;
+            }
+        }
+
+        var pots = new List<Pot>();
+        var levels = live.Select(s => effective[s.Name]).Where(c => c > 0)
+            .Distinct().OrderBy(c => c).ToList();
+        var previous = 0;
+        foreach (var level in levels)
+        {
+            var amount = _seats.Sum(s => Math.Min(effective[s.Name], level)
+                                       - Math.Min(effective[s.Name], previous));
+            var eligible = live.Where(s => effective[s.Name] >= level)
+                .OrderBy(s => s.Seat).Select(s => s.Name).ToList();
+            if (amount > 0)
+                pots.Add(new Pot { Amount = amount, Eligible = eligible });
+            previous = level;
+        }
+        return new PotReport { Pots = pots, Refunds = refunds };
+    }
+
+    public IReadOnlyDictionary<string, int> Distribute(IReadOnlyDictionary<string, int> ranks)
+    {
+        var live = _seats.Where(s => !s.Folded).Select(s => s.Name).ToHashSet();
+        if (!live.SetEquals(ranks.Keys))
+            throw new ArgumentException("ranks must cover exactly the non-folded players");
+
+        var payouts = _seats.ToDictionary(s => s.Name, _ => 0);
+        var report = BuildPots();
+        foreach (var (name, refund) in report.Refunds)
+            payouts[name] += refund;
+
+        foreach (var pot in report.Pots)
+        {
+            var best = pot.Eligible.Min(name => ranks[name]);
+            var winners = pot.Eligible.Where(name => ranks[name] == best).ToList();
+            var share = pot.Amount / winners.Count;
+            var odd = pot.Amount % winners.Count;
+            foreach (var name in winners) payouts[name] += share;
+            foreach (var name in ClockwiseFromButton(winners).Take(odd))
+                payouts[name] += 1;
+        }
+        return payouts;
+    }
+
+    private IEnumerable<string> ClockwiseFromButton(IReadOnlyCollection<string> winners)
+    {
+        for (var offset = 1; offset <= _seats.Count; offset++)
+        {
+            var seat = _seats[(_button + offset) % _seats.Count];
+            if (winners.Contains(seat.Name)) yield return seat.Name;
+        }
+    }
+
+    private SeatState Find(string name) =>
+        _seats.FirstOrDefault(s => s.Name == name)
+        ?? throw new ArgumentException($"unknown player: {name}");
+}
