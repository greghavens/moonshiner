+
+class MagicMismatchError(UploadError):
+    """The bytes are a recognized type that contradicts the extension."""
+
+
+class UnknownSignatureError(UploadError):
+    """The bytes match nothing in the sniffing table."""
+
+
+# Magic-byte signatures: (prefix, sniffed type). First match wins.
+MAGIC_SIGNATURES = (
+    (b"\x89PNG\r\n\x1a\n", "png"),
+    (b"\xff\xd8\xff", "jpeg"),
+    (b"GIF87a", "gif"),
+    (b"GIF89a", "gif"),
+    (b"%PDF-", "pdf"),
+    (b"PK\x03\x04", "zip"),
+)
+
+# Extension -> sniffed type we expect. Container formats are zips.
+DEFAULT_EXTENSION_TYPES = {
+    "png": "png",
+    "jpg": "jpeg",
+    "jpeg": "jpeg",
+    "gif": "gif",
+    "pdf": "pdf",
+    "zip": "zip",
+    "docx": "zip",
+}
+
+
+def sniff(data):
+    """Detected type name for `data`, or None if no signature matches."""
+    for prefix, kind in MAGIC_SIGNATURES:
+        if data[:len(prefix)] == prefix:
+            return kind
+    return None
+
+
+class SniffPolicy:
+    """How validate() reconciles sniffed content with the extension."""
+
+    def __init__(self, require_known=True, extension_types=None):
+        self.require_known = require_known
+        self.extension_types = dict(DEFAULT_EXTENSION_TYPES
+                                    if extension_types is None
+                                    else extension_types)
+
+    def check(self, ext, data):
+        """Raise if `data` should not be accepted under extension `ext`."""
+        expected = self.extension_types.get(ext)
+        if expected is None:
+            return  # extensions outside the map are not sniffed
+        detected = sniff(data)
+        if detected is None:
+            if self.require_known:
+                raise UnknownSignatureError(
+                    "content of %r upload matches no known signature" % (ext,))
+            return
+        if detected != expected:
+            raise MagicMismatchError(
+                "extension %r expects %s content but bytes look like %s"
+                % (ext, expected, detected))
