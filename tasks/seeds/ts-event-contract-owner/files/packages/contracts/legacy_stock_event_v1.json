{
  "schemaVersion": 1,
  "type": "stock.adjusted",
  "fields": {
    "id": "non-empty string",
    "timestamp": "ISO-8601 string",
    "warehouse": "non-empty string",
    "sku": "non-empty string",
    "change": "non-zero signed base-10 integer string",
    "cause": "shipment | receiving | cycle_count",
    "operator": "string or null"
  },
  "reasonMappings": {
    "shipment": "sale",
    "receiving": "return",
    "cycle_count": "recount"
  }
}
