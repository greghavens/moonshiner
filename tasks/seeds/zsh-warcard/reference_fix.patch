diff --git a/war.zsh b/war.zsh
new file mode 100644
index 0000000..d012643
--- /dev/null
+++ b/war.zsh
@@ -0,0 +1,99 @@
+#!/usr/bin/env zsh
+# war.zsh <deck-a-file> <deck-b-file> — the card game War over fixture decks.
+emulate -L zsh
+setopt no_unset
+
+die() { print -r -- "$1" >&2; exit 2 }
+
+typeset -A rankval
+typeset -a __order=(2 3 4 5 6 7 8 9 T J Q K A)
+integer __i
+for (( __i = 1; __i <= 13; __i++ )); do
+  rankval[$__order[__i]]=$__i
+done
+
+typeset -a deck_a deck_b
+
+load_deck() { # load_deck <path> a|b
+  local path=$1 which=$2 line
+  [[ -f $path && -r $path ]] || die "error: cannot read $path"
+  local -a cards=()
+  for line in ${(f)"$(<$path)"}; do
+    [[ -z $line ]] && continue
+    [[ $line == [23456789TJQKA][CDHS] ]] || die "error: invalid card: $line"
+    cards+=("$line")
+  done
+  (( $#cards > 0 )) || die "error: empty deck: $path"
+  if [[ $which == a ]]; then
+    deck_a=("$cards[@]")
+  else
+    deck_b=("$cards[@]")
+  fi
+}
+
+rounds_word() { # rounds_word <n>
+  if (( $1 == 1 )); then print -rn -- round; else print -rn -- rounds; fi
+}
+
+main() {
+  (( $# == 2 )) || die 'usage: war.zsh <deck-a-file> <deck-b-file>'
+  load_deck "$1" a
+  load_deck "$2" b
+
+  integer rounds=0 ra rb n burn_a burn_b
+  local prefix
+  local -a pa pb
+
+  while (( $#deck_a && $#deck_b )); do
+    (( rounds++ ))
+    pa=("$deck_a[1]"); deck_a=("${(@)deck_a[2,-1]}")
+    pb=("$deck_b[1]"); deck_b=("${(@)deck_b[2,-1]}")
+    prefix="round $rounds: A $pa[1] vs B $pb[1]"
+    while :; do
+      ra=${rankval[${pa[-1][1]}]}
+      rb=${rankval[${pb[-1][1]}]}
+      if (( ra != rb )); then
+        n=$(( $#pa + $#pb ))
+        if (( ra > rb )); then
+          deck_a+=("$pa[@]" "$pb[@]")
+          print -r -- "$prefix -> A takes $n (A $#deck_a, B $#deck_b)"
+        else
+          deck_b+=("$pa[@]" "$pb[@]")
+          print -r -- "$prefix -> B takes $n (A $#deck_a, B $#deck_b)"
+        fi
+        break
+      fi
+      print -r -- "$prefix -> war"
+      if (( $#deck_a == 0 && $#deck_b == 0 )); then
+        print -r -- '  war: nobody has cards left'
+        print -r -- "draw after $rounds $(rounds_word $rounds)"
+        exit 0
+      elif (( $#deck_a == 0 )); then
+        print -r -- '  war: A has no cards left'
+        print -r -- "B wins in $rounds $(rounds_word $rounds)"
+        exit 0
+      elif (( $#deck_b == 0 )); then
+        print -r -- '  war: B has no cards left'
+        print -r -- "A wins in $rounds $(rounds_word $rounds)"
+        exit 0
+      fi
+      burn_a=$(( $#deck_a - 1 )); (( burn_a > 3 )) && burn_a=3
+      burn_b=$(( $#deck_b - 1 )); (( burn_b > 3 )) && burn_b=3
+      (( burn_a > 0 )) && { pa+=("${(@)deck_a[1,burn_a]}"); deck_a=("${(@)deck_a[burn_a+1,-1]}") }
+      (( burn_b > 0 )) && { pb+=("${(@)deck_b[1,burn_b]}"); deck_b=("${(@)deck_b[burn_b+1,-1]}") }
+      print -r -- "  war: A burns $burn_a, B burns $burn_b"
+      pa+=("$deck_a[1]"); deck_a=("${(@)deck_a[2,-1]}")
+      pb+=("$deck_b[1]"); deck_b=("${(@)deck_b[2,-1]}")
+      prefix="  A $pa[-1] vs B $pb[-1]"
+    done
+  done
+
+  if (( $#deck_a )); then
+    print -r -- "A wins in $rounds $(rounds_word $rounds)"
+  else
+    print -r -- "B wins in $rounds $(rounds_word $rounds)"
+  fi
+  exit 0
+}
+
+main "$@"
