+#!/usr/bin/env ruby
+# Go Fish tournament referee: replays a stacked deck + scripted asks and
+# prints the canonical event log.
+
+RANKS = %w[A 2 3 4 5 6 7 8 9 T J Q K].freeze
+SUITS = %w[C D H S].freeze
+
+def die(msg)
+  warn msg
+  exit 2
+end
+
+def usage
+  die "usage: gofish.rb <deck-file> <script-file> <players> <cards-each>"
+end
+
+class Referee
+  def initialize(deck, players, deal)
+    @stock = deck
+    @players = players
+    @hands = Array.new(players) { [] }
+    @books = Array.new(players) { [] }
+    @deal = deal
+    @turn = 0
+  end
+
+  def seat(i) = "P#{i + 1}"
+
+  def run(script_lines)
+    deal_cards
+    (0...@players).each do |p|
+      lay_books(p)
+      redraw_if_empty(p)
+    end
+    unless game_over?
+      puts "TURN #{seat(@turn)}"
+      script_lines.each do |raw|
+        line = raw.strip
+        next if line.empty? || line.start_with?("#")
+        apply_ask(line)
+        break if game_over?
+      end
+    end
+    puts(game_over? ? "GAME OVER" : "SCRIPT END")
+    (0...@players).each do |p|
+      ranks = @books[p].sort_by { |r| RANKS.index(r) }
+      puts "FINAL #{seat(p)} #{ranks.size} #{ranks.empty? ? '-' : ranks.join(',')}"
+    end
+  end
+
+  private
+
+  def deal_cards
+    (@players * @deal).times do |i|
+      @hands[i % @players] << @stock.shift
+    end
+  end
+
+  def lay_books(p)
+    RANKS.each do |r|
+      next unless @hands[p].count { |c| c.start_with?(r) } == 4
+      @hands[p].reject! { |c| c.start_with?(r) }
+      @books[p] << r
+      puts "BOOK #{seat(p)} #{r}"
+    end
+  end
+
+  def redraw_if_empty(p)
+    return unless @hands[p].empty? && !@stock.empty?
+    card = @stock.shift
+    @hands[p] << card
+    puts "REDRAW #{seat(p)} #{card}"
+  end
+
+  def game_over?
+    @stock.empty? && @hands.all?(&:empty?)
+  end
+
+  def apply_ask(line)
+    asker = @turn
+    tokens = line.split
+    unless tokens.size == 2 && tokens[0].match?(/\AP\d+\z/) && RANKS.include?(tokens[1])
+      puts "ILLEGAL bad line: #{line}"
+      return
+    end
+    target_tok, rank = tokens
+    target = target_tok[1..].to_i - 1
+    if target == asker || target.negative? || target >= @players
+      puts "ILLEGAL #{seat(asker)} cannot ask #{target_tok}"
+      return
+    end
+    if @hands[target].empty?
+      puts "ILLEGAL #{seat(target)} has no cards"
+      return
+    end
+    unless @hands[asker].any? { |c| c.start_with?(rank) }
+      puts "ILLEGAL #{seat(asker)} does not hold #{rank}"
+      return
+    end
+
+    puts "ASK #{seat(asker)} #{target_tok} #{rank}"
+    given = @hands[target].select { |c| c.start_with?(rank) }
+    keep_turn = false
+    if given.any?
+      @hands[target].reject! { |c| c.start_with?(rank) }
+      @hands[asker].concat(given)
+      puts "GIVE #{seat(target)} #{seat(asker)} #{rank} x#{given.size}"
+      redraw_if_empty(target)
+      lay_books(asker)
+      redraw_if_empty(asker)
+      keep_turn = true
+    else
+      puts "GOFISH #{seat(asker)}"
+      if @stock.empty?
+        puts "STOCK EMPTY"
+      else
+        card = @stock.shift
+        @hands[asker] << card
+        puts "DRAW #{seat(asker)} #{card}"
+        lay_books(asker)
+        redraw_if_empty(asker)
+        if card.start_with?(rank)
+          puts "LUCKY #{seat(asker)}"
+          keep_turn = true
+        end
+      end
+    end
+    return if game_over?
+    pass_turn unless keep_turn && !@hands[asker].empty?
+  end
+
+  def pass_turn
+    nxt = (@turn + 1) % @players
+    while @hands[nxt].empty?
+      puts "SKIP #{seat(nxt)}"
+      nxt = (nxt + 1) % @players
+    end
+    @turn = nxt
+    puts "TURN #{seat(@turn)}"
+  end
+end
+
+usage unless ARGV.size == 4
+deck_path, script_path, players_arg, deal_arg = ARGV
+
+die "error: players must be 2-4" unless players_arg.match?(/\A\d+\z/) && (2..4).cover?(players_arg.to_i)
+players = players_arg.to_i
+die "error: cards-each must be >= 1" unless deal_arg.match?(/\A\d+\z/) && deal_arg.to_i >= 1
+deal = deal_arg.to_i
+
+texts = [deck_path, script_path].map do |path|
+  begin
+    File.read(path)
+  rescue SystemCallError
+    die "error: cannot read #{path}"
+  end
+end
+deck_text, script_text = texts
+
+deck = []
+deck_text.each_line.with_index(1) do |raw, n|
+  card = raw.strip
+  next if card.empty?
+  unless card.size == 2 && RANKS.include?(card[0]) && SUITS.include?(card[1])
+    die "error: bad deck line #{n}: #{card}"
+  end
+  die "error: duplicate card #{card}" if deck.include?(card)
+  deck << card
+end
+die "error: not enough cards" if deck.size < players * deal
+
+Referee.new(deck, players, deal).run(script_text.lines)
