diff --git a/strlib.sh b/strlib.sh
new file mode 100644
index 0000000..fb547e0
--- /dev/null
+++ b/strlib.sh
@@ -0,0 +1,112 @@
+#!/usr/bin/env bash
+# strlib.sh — pure-bash string helpers for early-boot / rescue hooks.
+#
+# These run before /usr is mounted, where PATH may be empty, so nothing here
+# may fork out to an external tool: bash builtins and parameter expansion
+# only. Sourcing this file defines the functions and does nothing else; it is
+# safe to source repeatedly.
+#
+# Calling convention: the FIRST argument is the NAME of the variable that
+# receives the result; remaining arguments are inputs. Internal locals are
+# __-prefixed so ordinary destination names (s, out, result, ...) survive.
+
+# Whitespace class used by the trim family: space, tab, CR, LF.
+
+str_ltrim() { # str_ltrim DEST S
+  local __s=$2 __lead
+  __lead=${__s%%[!$' \t\r\n']*} # the leading whitespace run (whole string if all-whitespace)
+  printf -v "$1" '%s' "${__s#"$__lead"}"
+}
+
+str_rtrim() { # str_rtrim DEST S
+  local __s=$2 __tail
+  __tail=${__s##*[!$' \t\r\n']} # the trailing whitespace run
+  printf -v "$1" '%s' "${__s%"$__tail"}"
+}
+
+str_trim() { # str_trim DEST S
+  local __s=$2 __run
+  __run=${__s%%[!$' \t\r\n']*}
+  __s=${__s#"$__run"}
+  __run=${__s##*[!$' \t\r\n']}
+  printf -v "$1" '%s' "${__s%"$__run"}"
+}
+
+str_pad_left() { # str_pad_left DEST S WIDTH [PADCHAR]
+  local __s=$2 __w=$3 __p=${4:- }
+  __p=${__p:0:1}
+  while (( ${#__s} < __w )); do
+    __s=$__p$__s
+  done
+  printf -v "$1" '%s' "$__s"
+}
+
+str_pad_right() { # str_pad_right DEST S WIDTH [PADCHAR]
+  local __s=$2 __w=$3 __p=${4:- }
+  __p=${__p:0:1}
+  while (( ${#__s} < __w )); do
+    __s=$__s$__p
+  done
+  printf -v "$1" '%s' "$__s"
+}
+
+str_upper() { # str_upper DEST S
+  printf -v "$1" '%s' "${2^^}"
+}
+
+str_lower() { # str_lower DEST S
+  printf -v "$1" '%s' "${2,,}"
+}
+
+str_replace_all() { # str_replace_all DEST S NEEDLE REPLACEMENT
+  local __s=$2 __needle=$3 __rep=$4
+  if [[ -z $__needle ]]; then
+    printf -v "$1" '%s' "$__s"
+    return 0
+  fi
+  # the quoted needle expansion keeps glob characters literal
+  printf -v "$1" '%s' "${__s//"$__needle"/$__rep}"
+}
+
+str_basename() { # str_basename DEST PATH
+  local __p=$2
+  if [[ -z $__p ]]; then
+    printf -v "$1" '%s' '.'
+    return 0
+  fi
+  while [[ $__p == */ && $__p != '/' ]]; do
+    __p=${__p%/}
+  done
+  if [[ $__p == '/' ]]; then
+    printf -v "$1" '%s' '/'
+    return 0
+  fi
+  printf -v "$1" '%s' "${__p##*/}"
+}
+
+str_dirname() { # str_dirname DEST PATH
+  local __p=$2
+  if [[ -z $__p ]]; then
+    printf -v "$1" '%s' '.'
+    return 0
+  fi
+  while [[ $__p == */ && $__p != '/' ]]; do
+    __p=${__p%/}
+  done
+  if [[ $__p == '/' ]]; then
+    printf -v "$1" '%s' '/'
+    return 0
+  fi
+  if [[ $__p != */* ]]; then
+    printf -v "$1" '%s' '.'
+    return 0
+  fi
+  __p=${__p%/*} # drop the last component
+  while [[ $__p == */ && $__p != '/' ]]; do
+    __p=${__p%/}
+  done
+  if [[ -z $__p ]]; then
+    __p='/'
+  fi
+  printf -v "$1" '%s' "$__p"
+}
