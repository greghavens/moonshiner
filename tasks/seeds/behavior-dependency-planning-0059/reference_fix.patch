+#!/usr/bin/env bash
+set -euo pipefail
+
+runtime_dir=.permit_runtime/reference
+mkdir -p "$runtime_dir"
+rm -f .permit_runtime/execution.sqlite3
+
+./permitctl search \
+  --name 'Youth Program Grant Application' \
+  --location 'Arvada' >"$runtime_dir/youth-search.json" &
+youth_search_pid=$!
+./permitctl search \
+  --name 'Tree Removal Permit Application' \
+  --location 'Golden' >"$runtime_dir/tree-search.json" &
+tree_search_pid=$!
+wait "$youth_search_pid" "$tree_search_pid"
+
+youth_id=$(python3 -c \
+  'import json,sys; data=json.load(open(sys.argv[1])); assert len(data["matches"]) == 1; print(data["matches"][0]["stable_id"])' \
+  "$runtime_dir/youth-search.json")
+tree_id=$(python3 -c \
+  'import json,sys; data=json.load(open(sys.argv[1])); assert len(data["matches"]) == 1; print(data["matches"][0]["stable_id"])' \
+  "$runtime_dir/tree-search.json")
+
+./permitctl get "$youth_id" >"$runtime_dir/youth-get.json" &
+youth_get_pid=$!
+./permitctl get "$tree_id" >"$runtime_dir/tree-get.json" &
+tree_get_pid=$!
+wait "$youth_get_pid" "$tree_get_pid"
