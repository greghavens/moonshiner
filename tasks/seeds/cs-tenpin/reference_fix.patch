+namespace Tenpin;
+
+public class Game
+{
+    private readonly List<List<int>> _frames = new() { new List<int>() };
+
+    public bool IsComplete => _frames.Count == 10 && FrameIsDone(9, _frames[9]);
+
+    public void Roll(int pins)
+    {
+        if (pins is < 0 or > 10)
+            throw new ArgumentOutOfRangeException(nameof(pins), pins, "pinfall must be 0..10");
+        if (IsComplete)
+            throw new InvalidOperationException("game is complete");
+
+        var frame = _frames[^1];
+        if (FrameIsDone(_frames.Count - 1, frame))
+        {
+            frame = new List<int>();
+            _frames.Add(frame);
+        }
+        if (pins + RackCount(frame) > 10)
+            throw new ArgumentException($"rack overflow: {pins} pins after {RackCount(frame)}");
+        frame.Add(pins);
+    }
+
+    public int Score()
+    {
+        if (!IsComplete)
+            throw new InvalidOperationException("game is not complete");
+        return FrameScores()[9]!.Value;
+    }
+
+    public int?[] FrameScores()
+    {
+        var rolls = _frames.SelectMany(f => f).ToList();
+        var scores = new int?[10];
+        var cumulative = 0;
+        var i = 0; // index of the current frame's first roll
+        for (var f = 0; f < 10; f++)
+        {
+            int? value = null;
+            if (f == 9)
+            {
+                if (_frames.Count == 10 && FrameIsDone(9, _frames[9]))
+                    value = _frames[9].Sum();
+            }
+            else if (i < rolls.Count && rolls[i] == 10)
+            {
+                if (i + 2 < rolls.Count) value = 10 + rolls[i + 1] + rolls[i + 2];
+            }
+            else if (i + 1 < rolls.Count && rolls[i] + rolls[i + 1] == 10)
+            {
+                if (i + 2 < rolls.Count) value = 10 + rolls[i + 2];
+            }
+            else if (i + 1 < rolls.Count)
+            {
+                value = rolls[i] + rolls[i + 1];
+            }
+
+            if (value is null) break;
+            cumulative += value.Value;
+            scores[f] = cumulative;
+            i += i < rolls.Count && rolls[i] == 10 ? 1 : 2;
+        }
+        return scores;
+    }
+
+    public string Scoreboard()
+    {
+        var scores = FrameScores();
+        var lines = new string[10];
+        for (var f = 0; f < 10; f++)
+        {
+            var balls = f < _frames.Count ? _frames[f] : new List<int>();
+            var marks = string.Join(' ', Marks(balls));
+            var cum = scores[f] is int s ? s.ToString() : "?";
+            lines[f] = $"F{f + 1} [{marks}] {cum}";
+        }
+        return string.Join('\n', lines);
+    }
+
+    public static Game Parse(string text)
+    {
+        var game = new Game();
+        foreach (var rawLine in text.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            foreach (var token in line.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries))
+            {
+                if (!int.TryParse(token, out var pins))
+                    throw new FormatException($"bad pinfall token: {token}");
+                game.Roll(pins);
+            }
+        }
+        return game;
+    }
+
+    private static bool FrameIsDone(int index, List<int> frame)
+    {
+        if (index < 9)
+            return frame.Count == 2 || (frame.Count == 1 && frame[0] == 10);
+        if (frame.Count < 2) return false;
+        if (frame.Count == 2) return frame[0] != 10 && frame[0] + frame[1] < 10;
+        return true;
+    }
+
+    // Pins still standing count for the ball about to be thrown in this frame:
+    // returns the pinfall already charged against the current rack.
+    private static int RackCount(List<int> frame)
+    {
+        var rack = 0;
+        foreach (var ball in frame)
+            rack = ball == 10 || rack + ball == 10 ? 0 : rack + ball;
+        return rack;
+    }
+
+    private static IEnumerable<string> Marks(List<int> balls)
+    {
+        var rack = 0;
+        var ballsOnRack = 0;
+        foreach (var ball in balls)
+        {
+            if (ball == 10 && ballsOnRack == 0) yield return "X";
+            else if (rack + ball == 10) yield return "/";
+            else yield return ball == 0 ? "-" : ball.ToString();
+
+            if (ball == 10 || rack + ball == 10) { rack = 0; ballsOnRack = 0; }
+            else { rack += ball; ballsOnRack++; }
+        }
+    }
+}
+
+public static class GameRunner
+{
+    public static string Run(string rollFileText)
+    {
+        var game = Game.Parse(rollFileText);
+        if (!game.IsComplete)
+            throw new InvalidOperationException("roll sheet does not finish the game");
+        return game.Scoreboard() + $"\nTOTAL {game.Score()}";
+    }
+}
