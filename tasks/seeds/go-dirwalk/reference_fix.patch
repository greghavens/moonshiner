+package dirwalk
+
+import (
+	"fmt"
+	"os"
+	"path"
+	"path/filepath"
+	"sort"
+	"strings"
+)
+
+// Options controls WalkFiltered.
+type Options struct {
+	// Excludes holds gitignore-flavored patterns. A pattern without a
+	// slash matches basenames at any depth; a pattern with a slash is
+	// matched against the whole root-relative path. "*" never crosses
+	// a slash. A trailing "/" restricts the pattern to directories.
+	// An excluded directory is pruned: nothing under it is visited.
+	Excludes []string
+	// MaxDepth limits how deep entries are listed: 1 keeps only the
+	// root's children, 2 adds their children, and so on. Zero or
+	// negative means unlimited.
+	MaxDepth int
+}
+
+// WalkFiltered lists everything under root like Walk, but honors
+// Options and returns a tree-shaped deterministic order: depth-first,
+// with each directory's subdirectories first (alphabetical) followed
+// by its files (alphabetical).
+func WalkFiltered(root string, opts Options) ([]Entry, error) {
+	for _, pat := range opts.Excludes {
+		if _, err := path.Match(strings.TrimSuffix(pat, "/"), "probe"); err != nil {
+			return nil, fmt.Errorf("dirwalk: malformed exclude pattern %q: %w", pat, err)
+		}
+	}
+
+	out := []Entry{}
+	var walk func(dir, rel string, depth int) error
+	walk = func(dir, rel string, depth int) error {
+		if opts.MaxDepth > 0 && depth > opts.MaxDepth {
+			return nil
+		}
+		children, err := os.ReadDir(dir)
+		if err != nil {
+			return err
+		}
+		sort.Slice(children, func(i, j int) bool {
+			if children[i].IsDir() != children[j].IsDir() {
+				return children[i].IsDir()
+			}
+			return children[i].Name() < children[j].Name()
+		})
+		for _, c := range children {
+			childRel := path.Join(rel, c.Name())
+			if excludedBy(opts.Excludes, childRel, c.IsDir()) {
+				continue
+			}
+			e := Entry{Path: childRel, IsDir: c.IsDir()}
+			if !c.IsDir() {
+				info, err := c.Info()
+				if err != nil {
+					return err
+				}
+				e.Size = info.Size()
+			}
+			out = append(out, e)
+			if c.IsDir() {
+				if err := walk(filepath.Join(dir, c.Name()), childRel, depth+1); err != nil {
+					return err
+				}
+			}
+		}
+		return nil
+	}
+	if err := walk(root, "", 1); err != nil {
+		return nil, err
+	}
+	return out, nil
+}
+
+// excludedBy reports whether the entry at root-relative path rel
+// matches any exclude pattern. Patterns were validated up front, so
+// match errors cannot occur here.
+func excludedBy(patterns []string, rel string, isDir bool) bool {
+	base := path.Base(rel)
+	for _, pat := range patterns {
+		if strings.HasSuffix(pat, "/") && !isDir {
+			continue
+		}
+		p := strings.TrimSuffix(pat, "/")
+		target := base
+		if strings.Contains(p, "/") {
+			target = rel
+		}
+		if ok, _ := path.Match(p, target); ok {
+			return true
+		}
+	}
+	return false
+}
