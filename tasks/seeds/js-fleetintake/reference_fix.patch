index 0000000..ad53e17
--- /dev/null
+++ b/schemas.mjs
@@ -0,0 +1,97 @@
+// Validation layer for fleet vehicle service-record uploads.
+import { z } from "zod";
+
+const PLATE_RE = /^[A-Z]{1,3}-\d{3,4}$/;
+const SKU_RE = /^P-\d{5}$/;
+
+function isRealDay(s) {
+  const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s);
+  if (!m) return false;
+  const [y, mo, d] = [Number(m[1]), Number(m[2]), Number(m[3])];
+  const dt = new Date(Date.UTC(y, mo - 1, d));
+  return dt.getUTCFullYear() === y && dt.getUTCMonth() === mo - 1 &&
+    dt.getUTCDate() === d;
+}
+
+const vehicleSchema = z.strictObject({
+  plate: z.string()
+    .transform((s) => s.trim().toUpperCase())
+    .refine((s) => PLATE_RE.test(s), "plate must look like ABC-123"),
+  fleet: z.enum(["north", "south", "central"]),
+});
+
+const common = {
+  vehicle: vehicleSchema,
+  odometerKm: z.coerce.number().int().nonnegative(),
+  date: z.string().refine(isRealDay, "date must be a real YYYY-MM-DD day"),
+};
+
+const serviceSchema = z.strictObject({
+  type: z.literal("service"),
+  ...common,
+  intervalKm: z.number().int().positive()
+    .refine((n) => n % 5000 === 0, "intervalKm must be a multiple of 5000"),
+  checklist: z.array(z.string().min(1)).min(1),
+});
+
+const repairSchema = z.strictObject({
+  type: z.literal("repair"),
+  ...common,
+  failureCode: z.enum(["ENG", "BRK", "ELE", "SUS"]),
+  workshop: z.string().refine((s) => s.trim() !== "", "workshop is required"),
+  costCents: z.number().int().nonnegative(),
+  parts: z.array(z.strictObject({
+    sku: z.string().refine((s) => SKU_RE.test(s), "sku must look like P-12345"),
+    qty: z.number().int().min(1),
+  })),
+});
+
+const inspectionSchema = z.strictObject({
+  type: z.literal("inspection"),
+  ...common,
+  passed: z.boolean(),
+  notes: z.string().optional().default(""),
+}).superRefine((rec, ctx) => {
+  if (rec.passed === false && rec.notes.trim() === "") {
+    ctx.addIssue({
+      code: "custom",
+      path: ["notes"],
+      message: "failed inspection needs notes",
+    });
+  }
+});
+
+export const recordSchema = z.discriminatedUnion("type", [
+  serviceSchema,
+  repairSchema,
+  inspectionSchema,
+]);
+
+function dotted(path) {
+  return path.join(".");
+}
+
+export function parseRecord(data) {
+  const result = recordSchema.safeParse(data);
+  if (result.success) {
+    return { ok: true, record: result.data };
+  }
+  const issues = result.error.issues
+    .map((i) => ({ path: dotted(i.path), code: i.code, message: i.message }))
+    .sort((a, b) => a.path.localeCompare(b.path) || a.code.localeCompare(b.code));
+  return { ok: false, issues };
+}
+
+export function parseBatch(list) {
+  if (!Array.isArray(list)) {
+    throw new TypeError("batch must be an array");
+  }
+  const accepted = [];
+  const rejected = [];
+  list.forEach((item, index) => {
+    const r = parseRecord(item);
+    if (r.ok) accepted.push(r.record);
+    else rejected.push({ index, issues: r.issues });
+  });
+  return { accepted, rejected };
+}
