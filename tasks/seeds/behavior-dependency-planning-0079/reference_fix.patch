+#!/usr/bin/env bash
+set -euo pipefail
+
+mkdir -p .pytest_cache
+
+bash -c '
+set -e
+./permitctl search --name "Historic Signage Review Application" --location "Pueblo" > .pytest_cache/historic-search.json &
+historic_pid=$!
+./permitctl search --name "Block Party Permit Application" --location "Fort Collins" > .pytest_cache/block-search.json &
+block_pid=$!
+wait "$historic_pid"
+wait "$block_pid"
+'
+
+historic_id=$(python3 -c 'import json; matches=json.load(open(".pytest_cache/historic-search.json"))["matches"]; assert len(matches) == 1; print(matches[0]["id"])')
+block_id=$(python3 -c 'import json; matches=json.load(open(".pytest_cache/block-search.json"))["matches"]; assert len(matches) == 1; print(matches[0]["id"])')
+export HISTORIC_ID="$historic_id" BLOCK_ID="$block_id"
+
+bash -c '
+set -e
+./permitctl get --id "$HISTORIC_ID" > .pytest_cache/historic-get.json &
+historic_pid=$!
+./permitctl get --id "$BLOCK_ID" > .pytest_cache/block-get.json &
+block_pid=$!
+wait "$historic_pid"
+wait "$block_pid"
+'
+
+python3 - <<'PY'
+import json
+from pathlib import Path
+
+historic = json.loads(Path(".pytest_cache/historic-get.json").read_text())["record"]
+block = json.loads(Path(".pytest_cache/block-get.json").read_text())["record"]
+rows = [historic, block]
+
+lines = [
+    "| Name | ID | Date | Status |",
+    "| --- | --- | --- | --- |",
+]
+for record in rows:
+    lines.append(
+        f'| {record.get("name", "unknown")} | {record.get("id", "unknown")} | '
+        f'{record.get("date", "unknown")} | {record.get("status", "unknown")} |'
+    )
+lines.extend(
+    [
+        "",
+        f'{historic["name"]} is {historic.get("status", "unknown")}, while '
+        f'{block["name"]} is {block.get("status", "unknown")}.'
+    ]
+)
+Path("audit.md").write_text("\n".join(lines) + "\n", encoding="utf-8")
+PY
