diff --git a/costrep.zsh b/costrep.zsh
new file mode 100644
index 0000000..302ff04
--- /dev/null
+++ b/costrep.zsh
@@ -0,0 +1,90 @@
+#!/usr/bin/env zsh
+# costrep.zsh — monthly per-service cost report.
+#
+# Input: one line per billing item, "<service> <amount>", separated by spaces
+# or tabs. Repeated service names accumulate. Lines starting with # and blank
+# lines are padding. Anything else that is not exactly two columns with a
+# plain decimal amount is a bad row: warned, skipped, exit still 0.
+emulate -R zsh
+setopt no_unset extended_glob
+
+# The report prints decimal POINTS no matter what locale the caller runs in;
+# machines diff this output.
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  print -u2 -- 'usage: costrep.zsh <data-file>'
+  exit 64
+}
+
+(( $# == 1 )) || usage
+feed=$1
+if [[ ! -f $feed || ! -r $feed ]]; then
+  print -u2 -- "costrep.zsh: cannot read: $feed"
+  exit 66
+fi
+
+typeset -A sum_by
+typeset -a order
+typeset -F total=0
+typeset -i rows=0 lineno=0
+
+while IFS= read -r line; do
+  (( lineno += 1 ))
+  [[ -z $line || $line == \#* ]] && continue
+  local -a parts
+  parts=( ${=line} )
+  if (( ${#parts} != 2 )) || [[ ${parts[2]} != (-|)<->(|.<->) ]]; then
+    print -u2 -- "costrep.zsh: line $lineno: bad row, skipped"
+    continue
+  fi
+  local name=${parts[1]} v=${parts[2]}
+  if (( ! ${+sum_by[$name]} )); then
+    order+=( "$name" )
+    sum_by[$name]=0
+  fi
+  sum_by[$name]=$(( ${sum_by[$name]} + v ))
+  total=$(( total + v ))
+  (( rows += 1 ))
+done < "$feed"
+
+if (( rows == 0 )); then
+  print -u2 -- 'costrep.zsh: no data rows'
+  exit 65
+fi
+
+typeset -F minv maxv
+local minname=${order[1]} maxname=${order[1]}
+minv=${sum_by[${order[1]}]}
+maxv=${sum_by[${order[1]}]}
+local n
+for n in "${order[@]}"; do
+  typeset -F v=${sum_by[$n]}
+  if (( v < minv )); then
+    minv=$v
+    minname=$n
+  fi
+  if (( v > maxv )); then
+    maxv=$v
+    maxname=$n
+  fi
+done
+
+typeset -F mean
+mean=$(( total / ${#order} ))
+
+printf 'rows\t%d\n' "$rows"
+printf 'services\t%d\n' "${#order}"
+printf 'total\t%.2f\n' "$total"
+printf 'mean\t%.2f\n' "$mean"
+printf 'min\t%s\t%.2f\n' "$minname" "$minv"
+printf 'max\t%s\t%.2f\n' "$maxname" "$maxv"
+print -- 'SHARES'
+for n in "${order[@]}"; do
+  if (( total == 0 )); then
+    printf '%s\t0.00\n' "$n"
+  else
+    printf '%s\t%.2f\n' "$n" "$(( ${sum_by[$n]} * 100.0 / total ))"
+  fi
+done
