+"""Student and assignment report assembly on top of grading.py."""
+import grading
+
+
+class ReportError(Exception):
+    pass
+
+
+def known_students(state):
+    return {s for s, scores in state["scores"].items() if scores}
+
+
+def _student_pairs_by_category(state, student):
+    """category -> [(earned, possible)] with missing work as explicit zeros."""
+    recorded = state["scores"].get(student, {})
+    by_cat = {}
+    for name, a in state["assignments"].items():
+        earned = recorded.get(name, 0)
+        by_cat.setdefault(a["category"], []).append((earned, a["points"]))
+    return by_cat
+
+
+def student_report(state, student):
+    """([(category, percent)] sorted by category, total, letter)."""
+    if student not in known_students(state):
+        raise ReportError(f"unknown student {student!r}")
+    by_cat = _student_pairs_by_category(state, student)
+    rows, weighted = [], []
+    for cat in sorted(by_cat):
+        info = state["categories"][cat]
+        pct = grading.category_percent(by_cat[cat], info["drop_lowest"])
+        rows.append((cat, pct))
+        weighted.append((pct, info["weight"]))
+    total = round(grading.weighted_final(weighted), 1)
+    curve = state["curve"] or grading.DEFAULT_CURVE
+    return rows, total, grading.letter(total, curve)
+
+
+def assignment_report(state, name):
+    """((count, avg, mn, mx) or None, sorted missing students)."""
+    a = state["assignments"].get(name)
+    if a is None:
+        raise ReportError(f"unknown assignment {name!r}")
+    percents, scored = [], set()
+    for student, scores in state["scores"].items():
+        if name in scores:
+            scored.add(student)
+            percents.append(scores[name] * 100 / a["points"])
+    missing = sorted(known_students(state) - scored)
+    stats = None
+    if percents:
+        stats = (len(percents), sum(percents) / len(percents),
+                 min(percents), max(percents))
+    return stats, missing
