+"""JSON persistence for the gradebook.
+
+Shape:
+    {"categories": {name: {"weight": num, "drop_lowest": int}},
+     "assignments": {name: {"category": str, "points": num}},
+     "scores": {student: {assignment: num}},
+     "curve": {letter: min_percent} | null}
+"""
+import json
+import os
+import tempfile
+
+
+def load(path):
+    if not os.path.exists(path):
+        return {"categories": {}, "assignments": {}, "scores": {}, "curve": None}
+    with open(path, "r", encoding="utf-8") as f:
+        data = json.load(f)
+    for key, default in (("categories", {}), ("assignments", {}),
+                         ("scores", {}), ("curve", None)):
+        data.setdefault(key, default)
+    return data
+
+
+def save(path, state):
+    directory = os.path.dirname(os.path.abspath(path))
+    fd, tmp = tempfile.mkstemp(dir=directory, suffix=".tmp")
+    try:
+        with os.fdopen(fd, "w", encoding="utf-8") as f:
+            json.dump(state, f, indent=2, sort_keys=True)
+            f.write("\n")
+        os.replace(tmp, path)
+    except BaseException:
+        if os.path.exists(tmp):
+            os.unlink(tmp)
+        raise
