+"""Gradebook CLI."""
+import argparse
+import sys
+
+import reports
+import store
+
+
+def _fail(msg):
+    print(f"error: {msg}", file=sys.stderr)
+    return 1
+
+
+def cmd_add_category(args):
+    if args.weight <= 0:
+        return _fail("--weight must be positive")
+    if args.drop_lowest < 0:
+        return _fail("--drop-lowest cannot be negative")
+    state = store.load(args.db)
+    if args.name in state["categories"]:
+        return _fail(f"category {args.name!r} already exists")
+    state["categories"][args.name] = {
+        "weight": args.weight, "drop_lowest": args.drop_lowest}
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_add_assignment(args):
+    if args.points <= 0:
+        return _fail("--points must be positive")
+    state = store.load(args.db)
+    if args.category not in state["categories"]:
+        return _fail(f"unknown category {args.category!r}")
+    if args.name in state["assignments"]:
+        return _fail(f"assignment {args.name!r} already exists")
+    state["assignments"][args.name] = {
+        "category": args.category, "points": args.points}
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_record(args):
+    if args.score < 0:
+        return _fail("score cannot be negative")
+    state = store.load(args.db)
+    if args.assignment not in state["assignments"]:
+        return _fail(f"unknown assignment {args.assignment!r}")
+    state["scores"].setdefault(args.student, {})[args.assignment] = args.score
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_curve(args):
+    curve = {}
+    for spec in args.specs:
+        letter_name, sep, threshold = spec.partition("=")
+        if not sep or not letter_name:
+            return _fail(f"bad curve entry {spec!r}, expected LETTER=MIN")
+        try:
+            curve[letter_name] = float(threshold)
+        except ValueError:
+            return _fail(f"bad threshold in {spec!r}")
+    state = store.load(args.db)
+    state["curve"] = curve
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_student(args):
+    state = store.load(args.db)
+    try:
+        rows, total, letter = reports.student_report(state, args.name)
+    except reports.ReportError as e:
+        return _fail(str(e))
+    for cat, pct in rows:
+        print(f"{cat}\t{pct:.1f}%")
+    print(f"total\t{total:.1f}%\t{letter}")
+    return 0
+
+
+def cmd_assignment(args):
+    state = store.load(args.db)
+    try:
+        stats, missing = reports.assignment_report(state, args.name)
+    except reports.ReportError as e:
+        return _fail(str(e))
+    if stats:
+        count, avg, mn, mx = stats
+        print(f"{args.name}\t{count} scored\tavg {avg:.1f}%\t"
+              f"min {mn:.1f}%\tmax {mx:.1f}%")
+    else:
+        print(f"{args.name}\t0 scored")
+    if missing:
+        print("missing\t" + ",".join(missing))
+    return 0
+
+
+def build_parser():
+    ap = argparse.ArgumentParser(prog="gradebook")
+    ap.add_argument("--db", required=True)
+    sub = ap.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add-category")
+    p.add_argument("name")
+    p.add_argument("--weight", required=True, type=float)
+    p.add_argument("--drop-lowest", type=int, default=0)
+    p.set_defaults(func=cmd_add_category)
+
+    p = sub.add_parser("add-assignment")
+    p.add_argument("name")
+    p.add_argument("--category", required=True)
+    p.add_argument("--points", required=True, type=float)
+    p.set_defaults(func=cmd_add_assignment)
+
+    p = sub.add_parser("record")
+    p.add_argument("student")
+    p.add_argument("assignment")
+    p.add_argument("score", type=float)
+    p.set_defaults(func=cmd_record)
+
+    p = sub.add_parser("curve")
+    p.add_argument("specs", nargs="+", metavar="LETTER=MIN")
+    p.set_defaults(func=cmd_curve)
+
+    p = sub.add_parser("student")
+    p.add_argument("name")
+    p.set_defaults(func=cmd_student)
+
+    p = sub.add_parser("assignment")
+    p.add_argument("name")
+    p.set_defaults(func=cmd_assignment)
+    return ap
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
