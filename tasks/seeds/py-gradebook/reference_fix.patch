+"""Grade math. Pure functions, no IO, no CLI knowledge."""
+
+
+def category_percent(pairs, drop_lowest):
+    """Points-weighted category score after the drop-lowest policy.
+
+    pairs: [(earned, possible)]; missing work should already be (0, possible).
+    Drops the `drop_lowest` entries with the lowest earned/possible ratio,
+    but never the last survivor; then returns sum(earned)/sum(possible)*100.
+    """
+    pairs = list(pairs)
+    if not pairs:
+        raise ValueError("category_percent needs at least one pair")
+    keep = max(len(pairs) - max(drop_lowest, 0), 1)
+    survivors = sorted(pairs, key=lambda p: p[0] / p[1], reverse=True)[:keep]
+    earned = sum(p[0] for p in survivors)
+    possible = sum(p[1] for p in survivors)
+    return earned * 100 / possible
+
+
+def weighted_final(items):
+    """Weight-renormalized average of (percent, weight) items."""
+    items = [(p, w) for p, w in items]
+    total_weight = sum(w for _, w in items)
+    if total_weight <= 0:
+        raise ValueError("no weighted categories to average")
+    return sum(p * w for p, w in items) / total_weight
+
+
+def letter(percent, curve):
+    """The letter whose threshold is the highest one <= percent, else 'F'."""
+    best = None
+    for name, threshold in curve.items():
+        if percent >= threshold and (best is None or threshold > best[1]):
+            best = (name, threshold)
+    return best[0] if best else "F"
+
+
+DEFAULT_CURVE = {"A": 90, "B": 80, "C": 70, "D": 60}
