+#!/usr/bin/env python3
+"""Reference proof: exercise permitq, resolve returned IDs, and render the brief."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+
+
+ROOT = Path(__file__).resolve().parent
+WORKER = """
+import subprocess
+import sys
+completed = subprocess.run(sys.argv[1:], capture_output=True, text=True)
+sys.stdout.write(completed.stdout)
+sys.stderr.write(completed.stderr)
+raise SystemExit(completed.returncode)
+"""
+
+
+def parallel(commands: list[list[str]]) -> list[dict[str, object]]:
+    processes = [
+        subprocess.Popen(
+            [sys.executable, "-B", "-c", WORKER, *command],
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "permitq operation failed")
+        payloads.append(json.loads(stdout))
+    return payloads
+
+
+def main() -> int:
+    requested = [
+        ("Pet License Renewal Application", "Aurora"),
+        ("Community Room Permit Application", "Lakewood"),
+    ]
+    searches = parallel([
+        ["./permitq", "search", "--name", name, "--location", location]
+        for name, location in requested
+    ])
+
+    ids = []
+    for result in searches:
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        application_id = matches[0].get("id")
+        if not isinstance(application_id, str) or not application_id:
+            raise RuntimeError("reference branch returned no stable ID")
+        ids.append(application_id)
+
+    gets = parallel([
+        ["./permitq", "get", "--id", application_id]
+        for application_id in ids
+    ])
+    records = [result.get("record") for result in gets]
+    if any(not isinstance(record, dict) for record in records):
+        raise RuntimeError("full-record retrieval failed")
+    first, second = records
+    brief = (
+        "## First record\n"
+        f"Name: {first['name']}\n"
+        f"Location: {first['location']}\n"
+        f"Status: {first['status']}\n\n"
+        "## Second record\n"
+        f"Name: {second['name']}\n"
+        f"Location: {second['location']}\n"
+        f"Status: {second['status']}\n\n"
+        f"The first record is {first['status']}, while the second record is {second['status']}.\n"
+    )
+    (ROOT / "brief.md").write_text(brief, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
