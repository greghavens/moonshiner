+// Package config merges three configuration layers — programmatic
+// defaults, a JSON file, and environment variables — with fixed
+// precedence: env > file > defaults, independent of load order.
+package config
+
+import (
+	"encoding/json"
+	"errors"
+	"fmt"
+	"strconv"
+	"strings"
+)
+
+// Config holds the three layers. Lookups consult env first, then file,
+// then defaults.
+type Config struct {
+	defaults map[string]any
+	file     map[string]any
+	env      map[string]string
+}
+
+// New builds a Config seeded with defaults keyed by dot paths.
+func New(defaults map[string]any) *Config {
+	d := make(map[string]any, len(defaults))
+	for k, v := range defaults {
+		d[k] = v
+	}
+	return &Config{
+		defaults: d,
+		file:     make(map[string]any),
+		env:      make(map[string]string),
+	}
+}
+
+// LoadJSON merges one JSON document into the file layer, flattening
+// nested objects into dot paths.
+func (c *Config) LoadJSON(data []byte) error {
+	var doc map[string]any
+	if err := json.Unmarshal(data, &doc); err != nil {
+		return fmt.Errorf("config: invalid JSON: %w", err)
+	}
+	flatten("", doc, c.file)
+	return nil
+}
+
+func flatten(prefix string, node map[string]any, into map[string]any) {
+	for k, v := range node {
+		key := k
+		if prefix != "" {
+			key = prefix + "." + k
+		}
+		if child, ok := v.(map[string]any); ok {
+			flatten(key, child, into)
+			continue
+		}
+		into[key] = v
+	}
+}
+
+// LoadEnv merges prefixed entries of an os.Environ()-style slice into
+// the env layer. APP_LOG_LEVEL (prefix "APP_") becomes log.level.
+// Entries without '=' are skipped; empty values are real overrides.
+func (c *Config) LoadEnv(prefix string, environ []string) error {
+	if prefix == "" {
+		return errors.New("config: env prefix must not be empty")
+	}
+	for _, entry := range environ {
+		name, value, ok := strings.Cut(entry, "=")
+		if !ok {
+			continue
+		}
+		if !strings.HasPrefix(name, prefix) {
+			continue
+		}
+		key := strings.ToLower(strings.TrimPrefix(name, prefix))
+		key = strings.ReplaceAll(key, "_", ".")
+		c.env[key] = value
+	}
+	return nil
+}
+
+// lookup returns the highest-precedence value for key.
+func (c *Config) lookup(key string) (any, bool) {
+	if v, ok := c.env[key]; ok {
+		return v, true
+	}
+	if v, ok := c.file[key]; ok {
+		return v, true
+	}
+	if v, ok := c.defaults[key]; ok {
+		return v, true
+	}
+	return nil, false
+}
+
+// Has reports whether any layer defines key.
+func (c *Config) Has(key string) bool {
+	_, ok := c.lookup(key)
+	return ok
+}
+
+func (c *Config) missing(key string) error {
+	return fmt.Errorf("config: key %q is not set in any layer", key)
+}
+
+// String returns the string value for key. Non-string values are an
+// error: no silent stringification.
+func (c *Config) String(key string) (string, error) {
+	v, ok := c.lookup(key)
+	if !ok {
+		return "", c.missing(key)
+	}
+	s, ok := v.(string)
+	if !ok {
+		return "", fmt.Errorf("config: key %q holds %T, not a string", key, v)
+	}
+	return s, nil
+}
+
+// Int returns the integer value for key. It accepts ints, integral
+// floats (JSON numbers), and parseable strings (env); it never
+// truncates a fractional value.
+func (c *Config) Int(key string) (int, error) {
+	v, ok := c.lookup(key)
+	if !ok {
+		return 0, c.missing(key)
+	}
+	switch t := v.(type) {
+	case int:
+		return t, nil
+	case float64:
+		if t != float64(int(t)) {
+			return 0, fmt.Errorf("config: key %q holds non-integral number %v", key, t)
+		}
+		return int(t), nil
+	case string:
+		n, err := strconv.Atoi(t)
+		if err != nil {
+			return 0, fmt.Errorf("config: key %q holds %q, not an integer", key, t)
+		}
+		return n, nil
+	default:
+		return 0, fmt.Errorf("config: key %q holds %T, not an integer", key, v)
+	}
+}
+
+// Float returns the float value for key, accepting ints and parseable
+// strings as well.
+func (c *Config) Float(key string) (float64, error) {
+	v, ok := c.lookup(key)
+	if !ok {
+		return 0, c.missing(key)
+	}
+	switch t := v.(type) {
+	case float64:
+		return t, nil
+	case int:
+		return float64(t), nil
+	case string:
+		f, err := strconv.ParseFloat(t, 64)
+		if err != nil {
+			return 0, fmt.Errorf("config: key %q holds %q, not a number", key, t)
+		}
+		return f, nil
+	default:
+		return 0, fmt.Errorf("config: key %q holds %T, not a number", key, v)
+	}
+}
+
+// Bool returns the boolean value for key; strings parse per
+// strconv.ParseBool.
+func (c *Config) Bool(key string) (bool, error) {
+	v, ok := c.lookup(key)
+	if !ok {
+		return false, c.missing(key)
+	}
+	switch t := v.(type) {
+	case bool:
+		return t, nil
+	case string:
+		b, err := strconv.ParseBool(t)
+		if err != nil {
+			return false, fmt.Errorf("config: key %q holds %q, not a boolean", key, t)
+		}
+		return b, nil
+	default:
+		return false, fmt.Errorf("config: key %q holds %T, not a boolean", key, v)
+	}
+}
