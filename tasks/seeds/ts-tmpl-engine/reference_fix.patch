+/** Parsed template nodes. */
+export type FilterCall = { name: string; args: string[] };
+
+export type Node =
+  | { type: "text"; value: string }
+  | { type: "interp"; path: string; filters: FilterCall[]; raw: boolean }
+  | { type: "if"; path: string; then: Node[]; else: Node[] }
+  | { type: "each"; path: string; body: Node[]; empty: Node[] };
