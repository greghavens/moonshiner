+import { TemplateError } from "./errors.ts";
+
+export type Token =
+  | { kind: "text"; value: string }
+  | { kind: "tag"; expr: string; raw: boolean };
+
+/** Split template source into literal text and {{ }} / {{{ }}} tags. */
+export function tokenize(src: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  while (i < src.length) {
+    const open = src.indexOf("{{", i);
+    if (open === -1) {
+      tokens.push({ kind: "text", value: src.slice(i) });
+      break;
+    }
+    if (open > i) tokens.push({ kind: "text", value: src.slice(i, open) });
+    const raw = src.startsWith("{{{", open);
+    const closer = raw ? "}}}" : "}}";
+    const start = open + (raw ? 3 : 2);
+    const close = src.indexOf(closer, start);
+    if (close === -1) {
+      throw new TemplateError(
+        `unclosed ${raw ? "{{{" : "{{"} tag at index ${open}`);
+    }
+    tokens.push({ kind: "tag", expr: src.slice(start, close).trim(), raw });
+    i = close + closer.length;
+  }
+  return tokens;
+}
