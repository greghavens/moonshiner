+export type FilterFn = (value: unknown, ...args: string[]) => unknown;
+export type Filters = Record<string, FilterFn>;
+
+/**
+ * Built-in filters.  Cosmetic filters pass null/undefined through untouched
+ * so a missing value is still "missing" when the policy is applied after
+ * the chain has run; `default` is the one that can rescue it.
+ */
+export const BUILTIN_FILTERS: Filters = {
+  upper: (v) => (v == null ? v : String(v).toUpperCase()),
+  lower: (v) => (v == null ? v : String(v).toLowerCase()),
+  trim: (v) => (v == null ? v : String(v).trim()),
+  json: (v) => JSON.stringify(v),
+  default: (v, fallback = "") => (v == null || v === "" ? fallback : v),
+};
