+const REPLACEMENTS: Array<[RegExp, string]> = [
+  [/&/g, "&amp;"],
+  [/</g, "&lt;"],
+  [/>/g, "&gt;"],
+  [/"/g, "&quot;"],
+  [/'/g, "&#39;"],
+];
+
+/** HTML-escape the five characters that matter in markup context. */
+export function escapeHtml(s: string): string {
+  let out = s;
+  for (const [re, sub] of REPLACEMENTS) out = out.replace(re, sub);
+  return out;
+}
