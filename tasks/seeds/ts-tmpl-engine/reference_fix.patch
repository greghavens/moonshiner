+import { TemplateError } from "./errors.ts";
+import { tokenize } from "./lexer.ts";
+import type { FilterCall, Node } from "./ast.ts";
+
+const PATH_RE = /^(this|@index|[A-Za-z_$][\w$]*)(\.[A-Za-z_$][\w$]*)*$/;
+const FILTER_RE = /^([A-Za-z_$][\w$]*)(?::"([^"]*)")?$/;
+
+/** Split an expression on pipes, ignoring pipes inside quoted filter args. */
+function splitPipes(expr: string): string[] {
+  const parts: string[] = [];
+  let current = "";
+  let quoted = false;
+  for (const ch of expr) {
+    if (ch === '"') {
+      quoted = !quoted;
+      current += ch;
+    } else if (ch === "|" && !quoted) {
+      parts.push(current);
+      current = "";
+    } else {
+      current += ch;
+    }
+  }
+  parts.push(current);
+  return parts.map((p) => p.trim());
+}
+
+export function parseExpression(expr: string): { path: string; filters: FilterCall[] } {
+  const [head, ...rest] = splitPipes(expr);
+  if (!head) throw new TemplateError(`empty expression in {{${expr}}}`);
+  if (!PATH_RE.test(head)) {
+    throw new TemplateError(`invalid path ${JSON.stringify(head)}`);
+  }
+  const filters = rest.map((spec): FilterCall => {
+    const m = FILTER_RE.exec(spec);
+    if (!m) throw new TemplateError(`invalid filter ${JSON.stringify(spec)}`);
+    return { name: m[1], args: m[2] === undefined ? [] : [m[2]] };
+  });
+  return { path: head, filters };
+}
+
+type Frame = {
+  kind: "if" | "each";
+  path: string;
+  primary: Node[];
+  alternate: Node[] | null;
+};
+
+/** Parse template source into an AST, rejecting malformed block structure. */
+export function parse(src: string): Node[] {
+  const root: Node[] = [];
+  const stack: Frame[] = [];
+
+  const bucket = (): Node[] => {
+    const top = stack[stack.length - 1];
+    if (!top) return root;
+    return top.alternate ?? top.primary;
+  };
+
+  for (const token of tokenize(src)) {
+    if (token.kind === "text") {
+      if (token.value) bucket().push({ type: "text", value: token.value });
+      continue;
+    }
+    const { expr, raw } = token;
+    if (expr.startsWith("#")) {
+      const m = /^#([\w$]+)(?:\s+(.*))?$/.exec(expr);
+      const helper = m?.[1] ?? "";
+      if (helper !== "if" && helper !== "each") {
+        throw new TemplateError(`unknown block helper "#${helper}"`);
+      }
+      const arg = m?.[2]?.trim();
+      if (!arg || !PATH_RE.test(arg)) {
+        throw new TemplateError(`#${helper} needs a path argument`);
+      }
+      stack.push({ kind: helper, path: arg, primary: [], alternate: null });
+    } else if (expr.startsWith("/")) {
+      const kind = expr.slice(1).trim();
+      const top = stack[stack.length - 1];
+      if (!top || top.kind !== kind) {
+        throw new TemplateError(`unexpected {{/${kind}}}`);
+      }
+      stack.pop();
+      const node: Node =
+        top.kind === "if"
+          ? { type: "if", path: top.path, then: top.primary, else: top.alternate ?? [] }
+          : { type: "each", path: top.path, body: top.primary, empty: top.alternate ?? [] };
+      bucket().push(node);
+    } else if (expr === "else") {
+      const top = stack[stack.length - 1];
+      if (!top) throw new TemplateError("{{else}} outside of a block");
+      if (top.alternate) throw new TemplateError("duplicate {{else}} in block");
+      top.alternate = [];
+    } else {
+      const { path, filters } = parseExpression(expr);
+      bucket().push({ type: "interp", path, filters, raw });
+    }
+  }
+  const open = stack[stack.length - 1];
+  if (open) throw new TemplateError(`unclosed {{#${open.kind} ${open.path}}}`);
+  return root;
+}
diff --git a/renderer.ts b/renderer.ts
new file mode 100644
index 0000000..7e57a05
--- /dev/null
+++ b/renderer.ts
@@ -0,0 +1,112 @@
+import { TemplateError } from "./errors.ts";
+import { escapeHtml } from "./escape.ts";
+import { BUILTIN_FILTERS, type Filters } from "./filters.ts";
+import type { FilterCall, Node } from "./ast.ts";
+
+export type MissingPolicy = "empty" | "error" | "keep";
+export type RenderOptions = { missing?: MissingPolicy; filters?: Filters };
+
+type Scope = { value: unknown; index: number };
+
+function isIndexable(v: unknown): v is Record<string, unknown> {
+  return typeof v === "object" && v !== null;
+}
+
+function walk(base: unknown, segments: string[]): unknown {
+  let current = base;
+  for (const seg of segments) {
+    if (current == null) return undefined;
+    current = isIndexable(current) ? current[seg] : undefined;
+  }
+  return current;
+}
+
+/** Resolve a dot path against the scope chain: item scopes first, then root. */
+function resolve(path: string, root: unknown, scopes: Scope[]): unknown {
+  if (path === "@index") {
+    const top = scopes[scopes.length - 1];
+    return top ? top.index : undefined;
+  }
+  const segments = path.split(".");
+  if (segments[0] === "this") {
+    const top = scopes[scopes.length - 1];
+    return walk(top ? top.value : root, segments.slice(1));
+  }
+  for (let i = scopes.length - 1; i >= 0; i--) {
+    const v = scopes[i].value;
+    if (isIndexable(v) && segments[0] in v) return walk(v, segments);
+  }
+  return walk(root, segments);
+}
+
+function truthy(v: unknown): boolean {
+  if (v === false || v === 0 || v === "" || v == null) return false;
+  if (Array.isArray(v) && v.length === 0) return false;
+  return true;
+}
+
+function applyFilters(
+  value: unknown, calls: FilterCall[], custom: Filters | undefined,
+): unknown {
+  let current = value;
+  for (const { name, args } of calls) {
+    const fn = custom?.[name] ?? BUILTIN_FILTERS[name];
+    if (!fn) throw new TemplateError(`unknown filter "${name}"`);
+    current = fn(current, ...args);
+  }
+  return current;
+}
+
+export function renderNodes(
+  nodes: Node[], root: unknown, opts: RenderOptions = {},
+): string {
+  const missing: MissingPolicy = opts.missing ?? "empty";
+  const pieces: string[] = [];
+
+  const emit = (list: Node[], scopes: Scope[]): void => {
+    for (const node of list) {
+      switch (node.type) {
+        case "text":
+          pieces.push(node.value);
+          break;
+        case "interp": {
+          const value = applyFilters(
+            resolve(node.path, root, scopes), node.filters, opts.filters);
+          if (value == null) {
+            if (missing === "error") {
+              throw new TemplateError(`missing value for "${node.path}"`);
+            }
+            if (missing === "keep") pieces.push(`{{${node.path}}}`);
+            break;
+          }
+          const text = String(value);
+          pieces.push(node.raw ? text : escapeHtml(text));
+          break;
+        }
+        case "if":
+          emit(truthy(resolve(node.path, root, scopes)) ? node.then : node.else,
+            scopes);
+          break;
+        case "each": {
+          const target = resolve(node.path, root, scopes);
+          if (target != null && !Array.isArray(target)) {
+            throw new TemplateError(
+              `#each target "${node.path}" is not an array`);
+          }
+          const items = target ?? [];
+          if (items.length === 0) {
+            emit(node.empty, scopes);
+            break;
+          }
+          items.forEach((item, index) => {
+            emit(node.body, [...scopes, { value: item, index }]);
+          });
+          break;
+        }
+      }
+    }
+  };
+
+  emit(nodes, []);
+  return pieces.join("");
+}
