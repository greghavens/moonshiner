@@ -0,0 +1,27 @@
+/**
+ * Public entry point for the notification templating engine.
+ *
+ * Language: `{{ path }}` (HTML-escaped) / `{{{ path }}}` (raw) interpolation
+ * with `| filter` chains, `{{#if}}…{{else}}…{{/if}}` conditionals and
+ * `{{#each}}…{{else}}…{{/each}}` loops.  See renderer.ts for the missing-key
+ * policies and filters.ts for the built-in filter set.
+ */
+import { parse } from "./parser.ts";
+import { renderNodes, type RenderOptions } from "./renderer.ts";
+
+export { TemplateError } from "./errors.ts";
+export type { RenderOptions, MissingPolicy } from "./renderer.ts";
+export type { Filters, FilterFn } from "./filters.ts";
+
+export type Template = (data: unknown, opts?: RenderOptions) => string;
+
+/** Parse once (throwing TemplateError on bad syntax), render many times. */
+export function compile(src: string): Template {
+  const ast = parse(src);
+  return (data, opts) => renderNodes(ast, data, opts);
+}
+
+/** One-shot convenience wrapper around compile(). */
+export function render(src: string, data: unknown, opts?: RenderOptions): string {
+  return compile(src)(data, opts);
+}
