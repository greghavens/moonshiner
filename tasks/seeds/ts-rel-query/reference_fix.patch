+++ b/ops.ts
@@ -0,0 +1,55 @@
+import type { Row } from './db.ts';
+
+export type WhereOp = 'eq' | 'ne' | 'lt' | 'lte' | 'gt' | 'gte' | 'in';
+export type AggFn = 'count' | 'sum' | 'avg' | 'min' | 'max';
+
+const WHERE_OPS = new Set<string>(['eq', 'ne', 'lt', 'lte', 'gt', 'gte', 'in']);
+const AGG_FNS = new Set<string>(['count', 'sum', 'avg', 'min', 'max']);
+
+export function requireColumn(columns: string[], field: string): void {
+  if (!columns.includes(field)) throw new Error(`unknown column "${field}"`);
+}
+
+export function matches(value: unknown, op: string, target: unknown): boolean {
+  if (!WHERE_OPS.has(op)) throw new Error(`unknown operator "${op}"`);
+  switch (op) {
+    case 'eq':
+      return value === target;
+    case 'ne':
+      return value !== target;
+    case 'lt':
+      return (value as number) < (target as number);
+    case 'lte':
+      return (value as number) <= (target as number);
+    case 'gt':
+      return (value as number) > (target as number);
+    case 'gte':
+      return (value as number) >= (target as number);
+    case 'in':
+      if (!Array.isArray(target)) throw new Error(`the 'in' operator needs an array of candidates`);
+      return target.includes(value);
+    default:
+      return false;
+  }
+}
+
+export function aggregate(fn: string, field: string | undefined, rows: Row[]): unknown {
+  if (!AGG_FNS.has(fn)) throw new Error(`unknown aggregate function "${fn}"`);
+  if (fn === 'count') return rows.length;
+  if (field === undefined) throw new Error(`aggregate "${fn}" needs a field`);
+  const values = rows.map((r) => r[field]);
+  if (fn === 'sum' || fn === 'avg') {
+    let sum = 0;
+    for (const v of values) {
+      if (typeof v !== 'number') throw new Error(`column "${field}" is not numeric`);
+      sum += v;
+    }
+    return fn === 'sum' ? sum : sum / values.length;
+  }
+  // min / max — numbers or strings, plain < comparison
+  let best = values[0];
+  for (const v of values.slice(1)) {
+    if (fn === 'min' ? (v as number) < (best as number) : (v as number) > (best as number)) best = v;
+  }
+  return best;
+}
