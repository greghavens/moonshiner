+export type Row = Record<string, unknown>;
+
+interface StoredTable {
+  columns: string[];
+  rows: Row[];
+}
+
+export class Database {
+  private byName = new Map<string, StoredTable>();
+
+  table(name: string, columns: string[], rows: Row[]): void {
+    if (this.byName.has(name)) throw new Error(`table "${name}" already exists`);
+    const declared = new Set<string>();
+    for (const col of columns) {
+      if (declared.has(col)) throw new Error(`duplicate column "${col}" in table "${name}"`);
+      declared.add(col);
+    }
+    const copied = rows.map((row, i) => {
+      for (const col of columns) {
+        if (!(col in row)) throw new Error(`row ${i} of "${name}" is missing column "${col}"`);
+      }
+      for (const key of Object.keys(row)) {
+        if (!declared.has(key)) throw new Error(`row ${i} of "${name}" has undeclared column "${key}"`);
+      }
+      return { ...row };
+    });
+    this.byName.set(name, { columns: [...columns], rows: copied });
+  }
+
+  private lookup(name: string): StoredTable {
+    const table = this.byName.get(name);
+    if (!table) throw new Error(`unknown table "${name}"`);
+    return table;
+  }
+
+  tables(): string[] {
+    return [...this.byName.keys()].sort();
+  }
+
+  columns(name: string): string[] {
+    return [...this.lookup(name).columns];
+  }
+
+  rowCount(name: string): number {
+    return this.lookup(name).rows.length;
+  }
+
+  /** Fresh copies for query execution — callers may mutate freely. */
+  snapshot(name: string): { columns: string[]; rows: Row[] } {
+    const table = this.lookup(name);
+    return { columns: [...table.columns], rows: table.rows.map((r) => ({ ...r })) };
+  }
+}
