diff --git a/tttwin.s b/tttwin.s
new file mode 100644
index 0000000..53ae091
--- /dev/null
+++ b/tttwin.s
@@ -0,0 +1,89 @@
+# Tic-tac-toe board evaluator over 9 raw bytes (0 empty, 1 X, 2 O).
+# System V AMD64. The eight lines live in a rodata triple table.
+	.section .rodata
+lines:
+	.byte	0, 1, 2,  3, 4, 5,  6, 7, 8	# rows
+	.byte	0, 3, 6,  1, 4, 7,  2, 5, 8	# columns
+	.byte	0, 4, 8,  2, 4, 6		# diagonals
+
+	.text
+	.globl	ttt_status
+	.type	ttt_status, @function
+# int ttt_status(const unsigned char *board)   rdi=board
+# 1 = X line, else 2 = O line, else 3 = full, else 0 = ongoing.
+ttt_status:
+	movl	$1, %esi		# player under test: X first (pinned)
+.Lplayer:
+	leaq	lines(%rip), %r8
+	movl	$8, %ecx
+.Lline:
+	movzbl	(%r8), %eax
+	movzbl	(%rdi,%rax), %eax
+	cmpl	%esi, %eax
+	jne	.Lline_next
+	movzbl	1(%r8), %eax
+	movzbl	(%rdi,%rax), %eax
+	cmpl	%esi, %eax
+	jne	.Lline_next
+	movzbl	2(%r8), %eax
+	movzbl	(%rdi,%rax), %eax
+	cmpl	%esi, %eax
+	jne	.Lline_next
+	movl	%esi, %eax		# player esi holds this line
+	ret
+.Lline_next:
+	addq	$3, %r8
+	decl	%ecx
+	jnz	.Lline
+	incl	%esi
+	cmpl	$2, %esi
+	jle	.Lplayer
+	xorl	%ecx, %ecx		# no line: full board means draw
+.Lscan:
+	cmpb	$0, (%rdi,%rcx)
+	je	.Longoing
+	incq	%rcx
+	cmpq	$9, %rcx
+	jl	.Lscan
+	movl	$3, %eax
+	ret
+.Longoing:
+	xorl	%eax, %eax
+	ret
+	.size	ttt_status, .-ttt_status
+
+	.globl	ttt_moves
+	.type	ttt_moves, @function
+# long ttt_moves(const unsigned char *board, unsigned char *out)
+# rdi=board, rsi=out. Empty-cell indices ascending; 0 when game over.
+ttt_moves:
+	pushq	%rbx
+	pushq	%r12
+	subq	$8, %rsp		# keep rsp 16-aligned at the call
+	movq	%rdi, %rbx
+	movq	%rsi, %r12
+	call	ttt_status
+	testl	%eax, %eax
+	jne	.Lnone
+	xorl	%eax, %eax		# count
+	xorl	%ecx, %ecx		# cell index
+.Lcell:
+	cmpb	$0, (%rbx,%rcx)
+	jne	.Lcell_next
+	movb	%cl, (%r12,%rax)
+	incq	%rax
+.Lcell_next:
+	incq	%rcx
+	cmpq	$9, %rcx
+	jl	.Lcell
+	jmp	.Lout
+.Lnone:
+	xorl	%eax, %eax
+.Lout:
+	addq	$8, %rsp
+	popq	%r12
+	popq	%rbx
+	ret
+	.size	ttt_moves, .-ttt_moves
+
+	.section .note.GNU-stack,"",@progbits
