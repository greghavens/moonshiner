+// Pong as pure integer physics. No wall clock, no randomness: the game
+// advances one tick() at a time, both paddles are driven by the same
+// deterministic follow-the-ball AI, and every bounce is integer math.
+
+export const WIDTH = 20;  // columns 0..19; goals are x <= 0 and x >= 19
+export const HEIGHT = 9;  // rows 0..8
+export const LEFT_COL = 1;
+export const RIGHT_COL = WIDTH - 2;
+
+export interface State {
+  readonly ball: readonly [number, number]; // [x, y]
+  readonly vel: readonly [number, number];  // [vx, vy], vx always +-1, |vy| <= 1
+  readonly left: number;  // left paddle CENTER row; paddle covers center +-1
+  readonly right: number; // right paddle center row
+  readonly score: readonly [number, number]; // [left, right]
+}
+
+export function newMatch(): State {
+  return {
+    ball: [Math.floor(WIDTH / 2), Math.floor(HEIGHT / 2)],
+    vel: [1, 1],
+    left: Math.floor(HEIGHT / 2),
+    right: Math.floor(HEIGHT / 2),
+    score: [0, 0],
+  };
+}
+
+// One step toward the ball's current row, clamped so the blade stays on
+// the court (center in 1 .. HEIGHT-2).
+function chase(center: number, ballY: number): number {
+  let next = center;
+  if (center < ballY) next = center + 1;
+  else if (center > ballY) next = center - 1;
+  return Math.min(HEIGHT - 2, Math.max(1, next));
+}
+
+function serve(score: readonly [number, number], scorer: 'left' | 'right'): State {
+  return {
+    ball: [Math.floor(WIDTH / 2), Math.floor(HEIGHT / 2)],
+    vel: [scorer === 'right' ? 1 : -1, (score[0] + score[1]) % 2 === 0 ? 1 : -1],
+    left: Math.floor(HEIGHT / 2),
+    right: Math.floor(HEIGHT / 2),
+    score,
+  };
+}
+
+// Tick order is the contract: paddles chase first (using the ball's
+// pre-move row), then the ball advances, then the wall reflects, then a
+// paddle on the ball's column returns it (vx flips outright, vy becomes
+// the hit offset = ball row minus paddle center), and finally a ball on
+// a goal column scores and resets to a centered serve toward the scorer
+// with vy = +1 when the new point total is even, else -1.
+export function tick(state: State): State {
+  const left = chase(state.left, state.ball[1]);
+  const right = chase(state.right, state.ball[1]);
+  let x = state.ball[0] + state.vel[0];
+  let y = state.ball[1] + state.vel[1];
+  let [vx, vy] = state.vel;
+  if (y < 0) {
+    y = -y;
+    vy = -vy;
+  } else if (y > HEIGHT - 1) {
+    y = 2 * (HEIGHT - 1) - y;
+    vy = -vy;
+  }
+  if (x === LEFT_COL && Math.abs(y - left) <= 1) {
+    vx = 1;
+    vy = y - left;
+  } else if (x === RIGHT_COL && Math.abs(y - right) <= 1) {
+    vx = -1;
+    vy = y - right;
+  } else if (x <= 0) {
+    return serve([state.score[0], state.score[1] + 1], 'right');
+  } else if (x >= WIDTH - 1) {
+    return serve([state.score[0] + 1, state.score[1]], 'left');
+  }
+  return { ball: [x, y], vel: [vx, vy], left, right, score: state.score };
+}
+
+export function tickN(state: State, n: number): State {
+  for (let i = 0; i < n; i++) state = tick(state);
+  return state;
+}
+
+// Rally log: one line per tick, 't=<i> ball=(x,y) v=(vx,vy) <l>:<r>'.
+export function trace(state: State, n: number): string {
+  const lines: string[] = [];
+  for (let i = 1; i <= n; i++) {
+    state = tick(state);
+    lines.push(`t=${i} ball=(${state.ball[0]},${state.ball[1]}) v=(${state.vel[0]},${state.vel[1]}) ${state.score[0]}:${state.score[1]}`);
+  }
+  return lines.join('\n');
+}
+
+// Score line '<l> : <r>' then HEIGHT court rows: '|' paddle cells, 'o' the
+// ball (drawn over a paddle cell), '.' everywhere else.
+export function render(state: State): string {
+  const rows: string[] = [`${state.score[0]} : ${state.score[1]}`];
+  for (let y = 0; y < HEIGHT; y++) {
+    let row = '';
+    for (let x = 0; x < WIDTH; x++) {
+      if (x === state.ball[0] && y === state.ball[1]) row += 'o';
+      else if (x === LEFT_COL && Math.abs(y - state.left) <= 1) row += '|';
+      else if (x === RIGHT_COL && Math.abs(y - state.right) <= 1) row += '|';
+      else row += '.';
+    }
+    rows.push(row);
+  }
+  return rows.join('\n');
+}
