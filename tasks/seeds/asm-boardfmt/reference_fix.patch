diff --git a/boardfmt.s b/boardfmt.s
new file mode 100644
index 0000000..ff68438
--- /dev/null
+++ b/boardfmt.s
@@ -0,0 +1,58 @@
+# Render an 8x8 cell-enum board (0..4 -> . w W b B) as a 162-byte ASCII
+# frame with rank digits and a file-letter footer. No libc; every byte is
+# an explicit store. System V AMD64: rdi=cells, rsi=out. Returns 162.
+	.section .rodata
+glyphs:
+	.ascii	".wWbB"
+
+	.text
+	.globl	board_fmt
+	.type	board_fmt, @function
+board_fmt:
+	leaq	glyphs(%rip), %r8
+	xorq	%rcx, %rcx		# write index
+	xorq	%r9, %r9		# board row, 0 = rank 8
+.Lrow:
+	movl	$'8', %eax		# rank digit
+	subl	%r9d, %eax
+	movb	%al, (%rsi,%rcx)
+	incq	%rcx
+	xorq	%r10, %r10		# file
+.Lcell:
+	movb	$' ', (%rsi,%rcx)
+	incq	%rcx
+	movq	%r9, %rax		# glyph for cells[row*8 + file]
+	shlq	$3, %rax
+	addq	%r10, %rax
+	movzbq	(%rdi,%rax), %rax
+	movzbl	(%r8,%rax), %eax
+	movb	%al, (%rsi,%rcx)
+	incq	%rcx
+	incq	%r10
+	cmpq	$8, %r10
+	jl	.Lcell
+	movb	$'\n', (%rsi,%rcx)
+	incq	%rcx
+	incq	%r9
+	cmpq	$8, %r9
+	jl	.Lrow
+	movb	$' ', (%rsi,%rcx)	# footer: "  a b c d e f g h\n"
+	incq	%rcx
+	xorq	%r10, %r10
+.Lfile:
+	movb	$' ', (%rsi,%rcx)
+	incq	%rcx
+	movl	$'a', %eax
+	addl	%r10d, %eax
+	movb	%al, (%rsi,%rcx)
+	incq	%rcx
+	incq	%r10
+	cmpq	$8, %r10
+	jl	.Lfile
+	movb	$'\n', (%rsi,%rcx)
+	incq	%rcx
+	movq	%rcx, %rax		# 162
+	ret
+	.size	board_fmt, .-board_fmt
+
+	.section .note.GNU-stack,"",@progbits
