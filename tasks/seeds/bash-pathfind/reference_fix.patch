diff --git a/pathfind.sh b/pathfind.sh
new file mode 100644
index 0000000..1104dcb
--- /dev/null
+++ b/pathfind.sh
@@ -0,0 +1,57 @@
+#!/usr/bin/env bash
+# pathfind.sh — resolve a command name against $PATH with an honest walk.
+#
+# Builtins only, and no `type`/`command -v`/`hash`/`which`: this runs sourced
+# inside provisioning shells whose lookup tables are routinely out of date,
+# so every answer must come from the live $PATH entries themselves.
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo "usage: pathfind.sh [-a] <name>" >&2
+  exit 64
+}
+
+all=0
+if [[ $# -ge 1 && "$1" == -a ]]; then
+  all=1
+  shift
+fi
+[[ $# -eq 1 ]] || usage
+name=$1
+[[ -n "$name" ]] || usage
+[[ "$name" == -* ]] && usage
+if [[ "$name" == */* ]]; then
+  echo "pathfind.sh: name must not contain '/'" >&2
+  exit 64
+fi
+
+# unset PATH behaves like a zero-length one: a single current-dir segment
+rest=${PATH-}
+found=0
+last=0
+while [[ "$last" -eq 0 ]]; do
+  seg=${rest%%:*}
+  if [[ "$seg" == "$rest" ]]; then
+    last=1
+  else
+    rest=${rest#*:}
+  fi
+  if [[ -z "$seg" ]]; then
+    cand=./$name
+  else
+    cand=$seg/$name
+  fi
+  if [[ -f "$cand" && -x "$cand" ]]; then
+    printf '%s\n' "$cand"
+    found=1
+    [[ "$all" -eq 0 ]] && exit 0
+  fi
+done
+
+if [[ "$found" -eq 0 ]]; then
+  echo "pathfind.sh: $name: not found in PATH" >&2
+  exit 1
+fi
+exit 0
