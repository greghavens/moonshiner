+/**
+ * JSON-RPC 2.0 client over an injectable async transport.
+ * No npm dependencies; pure TypeScript (erasable types, node 26 strip-types).
+ */
+
+export class JsonRpcError extends Error {
+  code: number;
+  data: unknown;
+
+  constructor(code: number, message: string, data?: unknown) {
+    super(message);
+    this.name = 'JsonRpcError';
+    this.code = code;
+    this.data = data;
+  }
+}
+
+type Transport = (req: string) => Promise<string>;
+
+export class JsonRpcClient {
+  private _transport: Transport;
+  private _nextId: number;
+
+  constructor(transport: Transport) {
+    this._transport = transport;
+    this._nextId = 1;
+  }
+
+  private _id(): number {
+    return this._nextId++;
+  }
+
+  async call(method: string, params: object | unknown[] | null): Promise<unknown> {
+    const id = this._id();
+    const req: Record<string, unknown> = { jsonrpc: '2.0', id, method };
+    if (params !== null) req.params = params;
+
+    const raw = await this._transport(JSON.stringify(req));
+    const resp = JSON.parse(raw) as Record<string, unknown>;
+
+    if ('error' in resp && resp.error !== null) {
+      const e = resp.error as Record<string, unknown>;
+      throw new JsonRpcError(
+        e.code as number,
+        e.message as string,
+        'data' in e ? e.data : undefined,
+      );
+    }
+    return resp.result;
+  }
+
+  async notify(method: string, params: object | unknown[] | null): Promise<void> {
+    const req: Record<string, unknown> = { jsonrpc: '2.0', method };
+    if (params !== null) req.params = params;
+    await this._transport(JSON.stringify(req));
+    // return value is intentionally ignored
+  }
+
+  async batch(
+    requests: Array<{ method: string; params: object | unknown[] | null }>,
+  ): Promise<Array<unknown | JsonRpcError>> {
+    const idToIndex = new Map<number | string, number>();
+    const items = requests.map((r, i) => {
+      const id = this._id();
+      idToIndex.set(id, i);
+      const item: Record<string, unknown> = { jsonrpc: '2.0', id, method: r.method };
+      if (r.params !== null) item.params = r.params;
+      return item;
+    });
+
+    const raw = await this._transport(JSON.stringify(items));
+    const resps = JSON.parse(raw) as Array<Record<string, unknown>>;
+
+    const results: Array<unknown | JsonRpcError> = new Array(requests.length).fill(undefined);
+    const filled = new Set<number>();
+
+    for (const resp of resps) {
+      const rid = resp.id as number | string;
+      const idx = idToIndex.get(rid);
+      if (idx === undefined) continue;    // stray id
+      if (filled.has(idx)) continue;      // duplicate id — first wins
+      filled.add(idx);
+
+      if ('error' in resp && resp.error !== null) {
+        const e = resp.error as Record<string, unknown>;
+        results[idx] = new JsonRpcError(
+          e.code as number,
+          e.message as string,
+          'data' in e ? e.data : undefined,
+        );
+      } else {
+        results[idx] = resp.result;
+      }
+    }
+
+    return results;
+  }
+}
