index 0000000..58f2f4d
--- /dev/null
+++ b/mvcc.py
@@ -0,0 +1,128 @@
+"""MVCC transaction layer over an in-memory key-value store.
+
+Model: every commit gets a monotonically increasing commit id. Each key
+holds a chain of (commit_id, value) records, newest last; deletes append a
+tombstone record. A transaction reads through the snapshot it took at
+begin() (the highest commit id at that moment) overlaid with its own write
+set. Commit is first-committer-wins over write sets. vacuum() drops records
+no snapshot can ever observe again.
+"""
+
+_TOMBSTONE = object()
+
+
+class WriteConflict(Exception):
+    """Another transaction committed one of our written keys first."""
+
+
+class TxnClosed(Exception):
+    """The transaction already committed, aborted, or conflicted."""
+
+
+class Transaction:
+    def __init__(self, store, snapshot):
+        self._store = store
+        self._snapshot = snapshot
+        self._writes = {}
+        self._closed = False
+
+    # ---- guards -------------------------------------------------------------
+    def _check(self):
+        if self._closed:
+            raise TxnClosed("transaction is closed")
+
+    def _close(self):
+        self._closed = True
+        self._store._active.discard(self)
+
+    # ---- operations -----------------------------------------------------------
+    def get(self, key):
+        self._check()
+        if key in self._writes:
+            value = self._writes[key]
+            return None if value is _TOMBSTONE else value
+        return self._store._resolve(key, self._snapshot)
+
+    def put(self, key, value):
+        self._check()
+        self._writes[key] = value
+
+    def delete(self, key):
+        self._check()
+        self._writes[key] = _TOMBSTONE
+
+    def commit(self):
+        self._check()
+        store = self._store
+        for key in self._writes:
+            chain = store._chains.get(key)
+            if chain and chain[-1][0] > self._snapshot:
+                self._close()
+                raise WriteConflict(
+                    f"write-write conflict on key {key!r}: "
+                    f"committed after this transaction began")
+        if self._writes:
+            store._commit_seq += 1
+            cid = store._commit_seq
+            for key, value in self._writes.items():
+                store._chains.setdefault(key, []).append((cid, value))
+        self._close()
+
+    def abort(self):
+        self._check()
+        self._writes.clear()
+        self._close()
+
+
+class MVCCStore:
+    def __init__(self):
+        self._commit_seq = 0
+        self._chains = {}   # key -> [(commit_id, value-or-tombstone), ...]
+        self._active = set()
+
+    def begin(self):
+        txn = Transaction(self, self._commit_seq)
+        self._active.add(txn)
+        return txn
+
+    # ---- reads ---------------------------------------------------------------
+    def _resolve(self, key, snapshot):
+        """Latest value of key visible at `snapshot`, None if absent/deleted."""
+        for cid, value in reversed(self._chains.get(key, ())):
+            if cid <= snapshot:
+                return None if value is _TOMBSTONE else value
+        return None
+
+    def read(self, key):
+        return self._resolve(key, self._commit_seq)
+
+    def versions(self, key):
+        return len(self._chains.get(key, ()))
+
+    # ---- garbage collection ----------------------------------------------------
+    def vacuum(self):
+        """Drop version records no snapshot resolves to, keeping each key's
+        newest record — unless that record is a tombstone whose older
+        records are all gone, in which case the key vanishes entirely.
+        Returns the number of records removed."""
+        snapshots = sorted({txn._snapshot for txn in self._active})
+        removed = 0
+        for key in list(self._chains):
+            chain = self._chains[key]
+            keep = set()
+            for snap in snapshots:
+                for i in range(len(chain) - 1, -1, -1):
+                    if chain[i][0] <= snap:
+                        keep.add(i)
+                        break
+            newest = len(chain) - 1
+            _, newest_value = chain[newest]
+            if newest_value is not _TOMBSTONE or any(i < newest for i in keep):
+                keep.add(newest)
+            kept_chain = [rec for i, rec in enumerate(chain) if i in keep]
+            removed += len(chain) - len(kept_chain)
+            if kept_chain:
+                self._chains[key] = kept_chain
+            else:
+                del self._chains[key]
+        return removed
