diff --git a/rpcbatch.ps1 b/rpcbatch.ps1
new file mode 100644
index 0000000..ba7de4e
--- /dev/null
+++ b/rpcbatch.ps1
@@ -0,0 +1,87 @@
+# JSON-RPC 2.0 batching client for the equipment-controller gateway.
+Set-StrictMode -Version Latest
+
+function Invoke-RpcBatch {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][string]$Uri,
+        [Parameter(Mandatory)][AllowEmptyCollection()][object[]]$Calls
+    )
+
+    if ($Calls.Count -eq 0) {
+        throw 'rpcbatch: empty batch'
+    }
+
+    $wire = [System.Collections.Generic.List[object]]::new()
+    $slotById = @{}   # wire id -> index into $Calls
+    $nextId = 1
+    for ($i = 0; $i -lt $Calls.Count; $i++) {
+        $call = $Calls[$i]
+        $entry = [ordered]@{ jsonrpc = '2.0'; method = [string]$call.Method }
+        if ($call.Contains('Params')) {
+            $entry.params = $call.Params
+        }
+        $isNotification = $call.Contains('Notification') -and $call.Notification
+        if (-not $isNotification) {
+            $entry.id = $nextId
+            $slotById[$nextId] = $i
+            $nextId++
+        }
+        $wire.Add($entry)
+    }
+
+    # -InputObject with a wrapped array keeps a one-call batch a JSON array
+    $body = ConvertTo-Json -InputObject @($wire) -Compress -Depth 10
+    $resp = Invoke-WebRequest -Uri $Uri -Method Post -ContentType 'application/json' `
+        -Body $body -SkipHttpErrorCheck
+    $status = [int]$resp.StatusCode
+    if ($status -ne 200 -and $status -ne 204) {
+        throw "rpcbatch: transport error $status"
+    }
+
+    $results = @($null) * $Calls.Count
+    for ($i = 0; $i -lt $Calls.Count; $i++) {
+        $call = $Calls[$i]
+        if ($call.Contains('Notification') -and $call.Notification) {
+            $results[$i] = @{ Kind = 'notification' }
+        }
+    }
+
+    $responses = @()
+    if ($status -eq 200 -and $resp.Content) {
+        $responses = @($resp.Content | ConvertFrom-Json)
+    }
+
+    $seen = @{}
+    foreach ($r in $responses) {
+        if (-not $r.PSObject.Properties['id']) {
+            throw 'rpcbatch: response without id'
+        }
+        $id = [int]$r.id
+        if (-not $slotById.ContainsKey($id)) {
+            throw "rpcbatch: unexpected response id $id"
+        }
+        if ($seen.ContainsKey($id)) {
+            throw "rpcbatch: duplicate response id $id"
+        }
+        $seen[$id] = $true
+        $slot = $slotById[$id]
+        if ($r.PSObject.Properties['error']) {
+            $results[$slot] = @{
+                Kind    = 'error'
+                Code    = [int]$r.error.code
+                Message = [string]$r.error.message
+            }
+        } else {
+            $results[$slot] = @{ Kind = 'ok'; Value = $r.result }
+        }
+    }
+
+    foreach ($id in ($slotById.Keys | Sort-Object)) {
+        if (-not $seen.ContainsKey($id)) {
+            throw "rpcbatch: missing response for id $id"
+        }
+    }
+
+    return ,$results
+}
