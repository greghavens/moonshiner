+// Package checkers is an English-draughts engine: legality with forced
+// captures and multi-jump chains, kinging, no-moves loss, and deterministic
+// move enumeration for scripted transcripts.
+package checkers
+
+import (
+	"fmt"
+	"strings"
+)
+
+// Game holds a position: an 8x8 board and the side to move.
+// board[0] is rank 8 (the top line of the fixture), board[7] is rank 1.
+type Game struct {
+	board [8][8]byte
+	turn  byte // 'b' or 'w'
+}
+
+// dark reports whether the square at file index f (0='a') and rank number
+// r (1..8) is a playable dark square: (f + r) must be odd.
+func dark(f, r int) bool { return (f+r)%2 == 1 }
+
+func rankOf(row int) int { return 8 - row }
+
+func squareName(row, col int) string {
+	return string([]byte{byte('a' + col), byte('0' + rankOf(row))})
+}
+
+// Load parses a position fixture: a "turn: b" or "turn: w" line followed by
+// eight lines of eight characters, rank 8 first — '.' empty, 'w'/'b' men,
+// 'W'/'B' kings. Pieces must sit on dark squares and men may not sit on
+// their crowning rank.
+func Load(fixture string) (*Game, error) {
+	var lines []string
+	for _, l := range strings.Split(fixture, "\n") {
+		l = strings.TrimRight(l, "\r")
+		if strings.TrimSpace(l) != "" {
+			lines = append(lines, l)
+		}
+	}
+	if len(lines) != 9 {
+		return nil, fmt.Errorf("checkers: fixture needs a turn line plus 8 board lines, got %d lines", len(lines))
+	}
+	g := &Game{}
+	switch lines[0] {
+	case "turn: b":
+		g.turn = 'b'
+	case "turn: w":
+		g.turn = 'w'
+	default:
+		return nil, fmt.Errorf("checkers: bad turn line %q", lines[0])
+	}
+	for row, line := range lines[1:] {
+		if len(line) != 8 {
+			return nil, fmt.Errorf("checkers: rank %d line is %d chars, want 8", rankOf(row), len(line))
+		}
+		for col := 0; col < 8; col++ {
+			c := line[col]
+			switch c {
+			case '.':
+				continue
+			case 'w', 'b', 'W', 'B':
+			default:
+				return nil, fmt.Errorf("checkers: bad square %q at %s", c, squareName(row, col))
+			}
+			if !dark(col, rankOf(row)) {
+				return nil, fmt.Errorf("checkers: piece on light square %s", squareName(row, col))
+			}
+			if c == 'w' && rankOf(row) == 8 || c == 'b' && rankOf(row) == 1 {
+				return nil, fmt.Errorf("checkers: uncrowned man on crowning rank at %s", squareName(row, col))
+			}
+			g.board[row][col] = c
+		}
+	}
+	return g, nil
+}
+
+// Turn returns the side to move: 'b' or 'w'.
+func (g *Game) Turn() byte { return g.turn }
+
+// Render returns the eight board lines (rank 8 first) joined with \n, no
+// trailing newline.
+func (g *Game) Render() string {
+	var b strings.Builder
+	for row := 0; row < 8; row++ {
+		if row > 0 {
+			b.WriteByte('\n')
+		}
+		for col := 0; col < 8; col++ {
+			c := g.board[row][col]
+			if c == 0 {
+				c = '.'
+			}
+			b.WriteByte(c)
+		}
+	}
+	return b.String()
+}
+
+func owner(c byte) byte {
+	switch c {
+	case 'w', 'W':
+		return 'w'
+	case 'b', 'B':
+		return 'b'
+	}
+	return 0
+}
+
+func isKing(c byte) bool { return c == 'W' || c == 'B' }
+
+// Direction order is pinned: up-left, up-right, down-left, down-right,
+// where "up" means toward rank 8 (row 0) and "left" toward file a.
+var dirTable = [4][2]int{{-1, -1}, {-1, 1}, {1, -1}, {1, 1}} // {dRow, dCol}
+
+// canUse reports whether piece c may move in direction d: kings any way,
+// white men up (toward rank 8), black men down (toward rank 1).
+func canUse(c byte, d [2]int) bool {
+	if isKing(c) {
+		return true
+	}
+	if c == 'w' {
+		return d[0] < 0
+	}
+	return d[0] > 0
+}
+
+func onBoard(row, col int) bool {
+	return row >= 0 && row < 8 && col >= 0 && col < 8
+}
+
+func crowningRow(side byte) int {
+	if side == 'w' {
+		return 0
+	}
+	return 7
+}
+
+// jumpChains extends a capture chain from (row,col) depth-first in pinned
+// direction order and appends every complete chain to out.
+func (g *Game) jumpChains(piece byte, row, col int, path []string, captured map[[2]int]bool, out *[]string) {
+	side := owner(piece)
+	extended := false
+	// A man that just reached its crowning rank is kinged and the move ends.
+	if !isKing(piece) && row == crowningRow(side) {
+		*out = append(*out, strings.Join(path, "x"))
+		return
+	}
+	for _, d := range dirTable {
+		if !canUse(piece, d) {
+			continue
+		}
+		mr, mc := row+d[0], col+d[1]
+		lr, lc := row+2*d[0], col+2*d[1]
+		if !onBoard(lr, lc) {
+			continue
+		}
+		mid := g.board[mr][mc]
+		if owner(mid) == 0 || owner(mid) == side || captured[[2]int{mr, mc}] {
+			continue
+		}
+		if g.board[lr][lc] != 0 {
+			continue
+		}
+		extended = true
+		captured[[2]int{mr, mc}] = true
+		g.jumpChains(piece, lr, lc, append(path, squareName(lr, lc)), captured, out)
+		delete(captured, [2]int{mr, mc})
+	}
+	if !extended && len(path) > 1 {
+		*out = append(*out, strings.Join(path, "x"))
+	}
+}
+
+// LegalMoves lists the side to move's legal moves in the pinned order:
+// origin squares scanned rank 8 to rank 1 and file a to h, directions
+// up-left, up-right, down-left, down-right, capture chains depth-first.
+// If any capture exists, only captures are listed (forced capture).
+func (g *Game) LegalMoves() []string {
+	var captures, quiet []string
+	for row := 0; row < 8; row++ {
+		for col := 0; col < 8; col++ {
+			piece := g.board[row][col]
+			if owner(piece) != g.turn {
+				continue
+			}
+			g.board[row][col] = 0 // the jumper vacates its origin square
+			g.jumpChains(piece, row, col, []string{squareName(row, col)}, map[[2]int]bool{}, &captures)
+			g.board[row][col] = piece
+			if len(captures) > 0 {
+				continue
+			}
+			for _, d := range dirTable {
+				if !canUse(piece, d) {
+					continue
+				}
+				nr, nc := row+d[0], col+d[1]
+				if onBoard(nr, nc) && g.board[nr][nc] == 0 {
+					quiet = append(quiet, squareName(row, col)+"-"+squareName(nr, nc))
+				}
+			}
+		}
+	}
+	if len(captures) > 0 {
+		return captures
+	}
+	return quiet
+}
+
+func parseSquare(s string) (int, int, bool) {
+	if len(s) != 2 || s[0] < 'a' || s[0] > 'h' || s[1] < '1' || s[1] > '8' {
+		return 0, 0, false
+	}
+	return 8 - int(s[1]-'0'), int(s[0] - 'a'), true
+}
+
+// Apply plays one move, given exactly as LegalMoves prints it. The board is
+// updated (captured pieces removed, men crowned on their back rank) and the
+// turn passes to the opponent.
+func (g *Game) Apply(move string) error {
+	legal := false
+	for _, m := range g.LegalMoves() {
+		if m == move {
+			legal = true
+			break
+		}
+	}
+	if !legal {
+		return fmt.Errorf("checkers: illegal move %q", move)
+	}
+	squares := strings.Split(move, "-")
+	capture := false
+	if strings.Contains(move, "x") {
+		squares = strings.Split(move, "x")
+		capture = true
+	}
+	row, col, _ := parseSquare(squares[0])
+	piece := g.board[row][col]
+	g.board[row][col] = 0
+	for _, sq := range squares[1:] {
+		nr, nc, _ := parseSquare(sq)
+		if capture {
+			g.board[(row+nr)/2][(col+nc)/2] = 0
+		}
+		row, col = nr, nc
+	}
+	if !isKing(piece) && row == crowningRow(owner(piece)) {
+		piece -= 'a' - 'A' // crown: 'w' -> 'W', 'b' -> 'B'
+	}
+	g.board[row][col] = piece
+	if g.turn == 'w' {
+		g.turn = 'b'
+	} else {
+		g.turn = 'w'
+	}
+	return nil
+}
+
+// Winner reports whether the game is over. The side to move loses when it
+// has no legal moves — no pieces left or everything blocked.
+func (g *Game) Winner() (byte, bool) {
+	if len(g.LegalMoves()) > 0 {
+		return 0, false
+	}
+	if g.turn == 'w' {
+		return 'b', true
+	}
+	return 'w', true
+}
+
+// Transcript loads a fixture, applies the move list, and returns the
+// blank-line-separated blocks: "start" plus the initial render, then
+// "move N (side): move" plus the render after it, ending with either
+// "winner: side" or "next: side". Every line ends with \n.
+func Transcript(fixture string, moves []string) (string, error) {
+	g, err := Load(fixture)
+	if err != nil {
+		return "", err
+	}
+	var b strings.Builder
+	fmt.Fprintf(&b, "start\n%s\n\n", g.Render())
+	for i, m := range moves {
+		mover := g.turn
+		if err := g.Apply(m); err != nil {
+			return "", fmt.Errorf("move %d: %w", i+1, err)
+		}
+		fmt.Fprintf(&b, "move %d (%c): %s\n%s\n\n", i+1, mover, m, g.Render())
+	}
+	if side, over := g.Winner(); over {
+		fmt.Fprintf(&b, "winner: %c\n", side)
+	} else {
+		fmt.Fprintf(&b, "next: %c\n", g.turn)
+	}
+	return b.String(), nil
+}
