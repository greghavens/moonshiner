--- a/schedule.mjs
+++ b/schedule.mjs
@@ -4,7 +4,7 @@
 // an IANA timezone and all "what day/week is it for the site" questions are
 // answered in that zone via TZDate.
 import { TZDate } from "@date-fns/tz";
-import { addDays, format, isSameDay } from "date-fns";
+import { addDays, format, isSameDay, startOfWeek } from "date-fns";
 
 /** Wall-clock rendering of a UTC instant at the site, "yyyy-MM-dd HH:mm". */
 export function fmtLocal(instantIso, tz) {
@@ -23,3 +23,112 @@ export function nextVisitDue(lastVisitIso, cadenceDays) {
   }
   return addDays(new Date(lastVisitIso), cadenceDays).toISOString();
 }
+
+const DAY_CODES = { SU: 0, MO: 1, TU: 2, WE: 3, TH: 4, FR: 5, SA: 6 };
+
+function utcIso(dateLike) {
+  return new Date(dateLike.getTime()).toISOString();
+}
+
+/**
+ * The site-local week containing an instant, as half-open UTC instants
+ * [start, end): local midnight opening the week and local midnight opening
+ * the next one. DST weeks are naturally 167/169 hours long.
+ */
+export function weekWindow(instantIso, tz, weekStartsOn = 1) {
+  const local = new TZDate(instantIso, tz);
+  const start = startOfWeek(local, { weekStartsOn });
+  const end = addDays(start, 7);
+  return { start: utcIso(start), end: utcIso(end) };
+}
+
+function parseTimeOfDay(time) {
+  const m = /^(\d{2}):(\d{2})$/.exec(String(time ?? ""));
+  if (!m) throw new Error(`invalid time: ${time}`);
+  const hh = Number(m[1]);
+  const mm = Number(m[2]);
+  if (hh > 23 || mm > 59) throw new Error(`invalid time: ${time}`);
+  return [hh, mm];
+}
+
+function occurrenceAt(localDay, hh, mm) {
+  const at = new TZDate(localDay.getTime(), localDay.timeZone);
+  at.setHours(hh, mm, 0, 0);
+  return at.getTime();
+}
+
+function nthWeekdayOfMonth(year, month, dow, nth, tz) {
+  if (nth === -1) {
+    const last = addDays(new TZDate(year, month + 1, 1, tz), -1);
+    const back = (last.getDay() - dow + 7) % 7;
+    return addDays(last, -back);
+  }
+  const first = new TZDate(year, month, 1, tz);
+  const forward = (dow - first.getDay() + 7) % 7;
+  const day = addDays(first, forward + (nth - 1) * 7);
+  return day.getMonth() === month ? day : null;
+}
+
+/**
+ * Expand a recurrence rule into the sorted UTC instants inside the half-open
+ * window [windowStart, windowEnd). Rules carry site wall-clock time "HH:MM"
+ * plus tz; weekly rules list byDay codes, monthly rules pick the nth weekday
+ * (1..5, or -1 for the last one).
+ */
+export function expandRecurrence(rule, windowStartIso, windowEndIso) {
+  const startMs = Date.parse(windowStartIso);
+  const endMs = Date.parse(windowEndIso);
+  if (!Number.isFinite(startMs) || !Number.isFinite(endMs) || endMs <= startMs) {
+    throw new Error("invalid window");
+  }
+  const { freq, time, tz } = rule;
+  const [hh, mm] = parseTimeOfDay(time);
+  const hits = [];
+
+  if (freq === "weekly") {
+    const byDay = rule.byDay ?? [];
+    const wanted = new Set();
+    for (const code of byDay) {
+      if (!(code in DAY_CODES)) throw new Error(`unknown weekday: ${code}`);
+      wanted.add(DAY_CODES[code]);
+    }
+    if (wanted.size === 0) throw new Error("byDay must not be empty");
+    let day = new TZDate(startMs, tz);
+    day.setHours(0, 0, 0, 0);
+    while (day.getTime() < endMs) {
+      if (wanted.has(day.getDay())) {
+        const t = occurrenceAt(day, hh, mm);
+        if (t >= startMs && t < endMs) hits.push(t);
+      }
+      day = addDays(day, 1);
+    }
+  } else if (freq === "monthly") {
+    const { nth, day: code } = rule;
+    if (!(code in DAY_CODES)) throw new Error(`unknown weekday: ${code}`);
+    if (nth !== -1 && !(Number.isInteger(nth) && nth >= 1 && nth <= 5)) {
+      throw new Error(`invalid nth: ${nth}`);
+    }
+    const dow = DAY_CODES[code];
+    const cursor = new TZDate(startMs, tz);
+    let year = cursor.getFullYear();
+    let month = cursor.getMonth();
+    while (true) {
+      const monthStart = new TZDate(year, month, 1, tz);
+      if (monthStart.getTime() >= endMs) break;
+      const localDay = nthWeekdayOfMonth(year, month, dow, nth, tz);
+      if (localDay !== null) {
+        const t = occurrenceAt(localDay, hh, mm);
+        if (t >= startMs && t < endMs) hits.push(t);
+      }
+      month += 1;
+      if (month === 12) {
+        month = 0;
+        year += 1;
+      }
+    }
+  } else {
+    throw new Error(`unsupported freq: ${freq}`);
+  }
+
+  return hits.sort((a, b) => a - b).map((t) => new Date(t).toISOString());
+}
