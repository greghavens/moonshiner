+// Meeting-room booking API — express application factory.
+//
+// Each createApp() call builds an independent app with its own in-memory
+// booking store; nothing listens at import time (tests drive it in-process).
+import express from "express";
+
+export function createApp({ rooms = [] } = {}) {
+  const app = express();
+  const known = new Set(rooms);
+  const store = { bookings: new Map(), nextId: 1 };
+
+  app.use(express.json());
+
+  const router = express.Router();
+
+  router.get("/bookings", (req, res) => {
+    const { room } = req.query;
+    if (room !== undefined && !known.has(room)) {
+      return res.status(400).json({ error: "unknown room" });
+    }
+    const bookings = [...store.bookings.values()]
+      .filter((b) => room === undefined || b.room === room)
+      .sort((a, b) =>
+        Date.parse(a.start) - Date.parse(b.start) || a.id - b.id);
+    res.json({ bookings });
+  });
+
+  router.post("/bookings", (req, res) => {
+    const body = req.body;
+    if (typeof body !== "object" || body === null || Array.isArray(body)) {
+      return res.status(400).json({ error: "json body required" });
+    }
+    const { room, title, start, end } = body;
+    if (!known.has(room)) {
+      return res.status(400).json({ error: "unknown room" });
+    }
+    if (typeof title !== "string" || !title.trim()) {
+      return res.status(400).json({ error: "title is required" });
+    }
+    const startMs = typeof start === "string" ? Date.parse(start) : NaN;
+    const endMs = typeof end === "string" ? Date.parse(end) : NaN;
+    if (!Number.isFinite(startMs) || !Number.isFinite(endMs) || endMs <= startMs) {
+      return res.status(400).json({ error: "invalid time range" });
+    }
+    // Half-open [start, end): touching endpoints do not conflict.
+    for (const b of store.bookings.values()) {
+      if (b.room !== room) continue;
+      if (startMs < Date.parse(b.end) && Date.parse(b.start) < endMs) {
+        return res.status(409).json({ error: "time conflict", with: b.id });
+      }
+    }
+    const booking = { id: store.nextId++, room, title, start, end };
+    store.bookings.set(booking.id, booking);
+    res.status(201).json(booking);
+  });
+
+  router.get("/bookings/:id", (req, res) => {
+    const booking = store.bookings.get(Number(req.params.id));
+    if (!booking) {
+      return res.status(404).json({ error: "not found" });
+    }
+    res.json(booking);
+  });
+
+  router.delete("/bookings/:id", (req, res) => {
+    if (!store.bookings.delete(Number(req.params.id))) {
+      return res.status(404).json({ error: "not found" });
+    }
+    res.status(204).end();
+  });
+
+  app.use("/api", router);
+
+  // Everything unmatched is a JSON 404 — the dashboard parses error bodies.
+  app.use((req, res) => {
+    res.status(404).json({ error: "not found" });
+  });
+
+  // Body-parse failures (broken JSON) must never surface as HTML error pages.
+  app.use((err, req, res, next) => {
+    if (err.type === "entity.parse.failed" || err instanceof SyntaxError) {
+      return res.status(400).json({ error: "invalid json" });
+    }
+    next(err);
+  });
+
+  return app;
+}
