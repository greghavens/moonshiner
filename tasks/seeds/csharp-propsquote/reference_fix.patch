+using System.Text;
+
+namespace PropsQuote;
+
+/// <summary>
+/// Value encoding for the .props-style config files: bare form for plain
+/// tokens, quoted form with escapes for everything else. The contract is
+/// Unquote(Quote(v)) == v for every string v.
+/// </summary>
+public static class PropsValue
+{
+    static bool IsBareChar(char c) =>
+        c is (>= 'A' and <= 'Z') or (>= 'a' and <= 'z') or (>= '0' and <= '9')
+          or '.' or '_' or '-' or '/' or ':' or '+';
+
+    static bool IsBare(string value)
+    {
+        if (value.Length == 0)
+        {
+            return false;
+        }
+        foreach (var c in value)
+        {
+            if (!IsBareChar(c))
+            {
+                return false;
+            }
+        }
+        return true;
+    }
+
+    public static string Quote(string value)
+    {
+        ArgumentNullException.ThrowIfNull(value);
+        if (IsBare(value))
+        {
+            return value;
+        }
+        var sb = new StringBuilder("\"");
+        foreach (var c in value)
+        {
+            switch (c)
+            {
+                case '\\': sb.Append("\\\\"); break;
+                case '"': sb.Append("\\\""); break;
+                case '\n': sb.Append("\\n"); break;
+                case '\t': sb.Append("\\t"); break;
+                case '\r': sb.Append("\\r"); break;
+                default:
+                    if (c < ' ' || c == '\u007F')
+                    {
+                        sb.Append("\\u").Append(((int)c).ToString("X4"));
+                    }
+                    else
+                    {
+                        sb.Append(c);
+                    }
+                    break;
+            }
+        }
+        return sb.Append('"').ToString();
+    }
+
+    public static string Unquote(string text)
+    {
+        ArgumentNullException.ThrowIfNull(text);
+        if (text.Length == 0)
+        {
+            throw new FormatException("empty text; an empty value is written as \"\"");
+        }
+        if (text[0] != '"')
+        {
+            if (!IsBare(text))
+            {
+                throw new FormatException("bare value contains characters that require quoting");
+            }
+            return text;
+        }
+
+        var sb = new StringBuilder();
+        var i = 1;
+        while (i < text.Length)
+        {
+            var c = text[i];
+            if (c == '"')
+            {
+                if (i != text.Length - 1)
+                {
+                    throw new FormatException("content after the closing quote");
+                }
+                return sb.ToString();
+            }
+            if (c < ' ')
+            {
+                throw new FormatException($"raw control character U+{(int)c:X4} inside quotes");
+            }
+            if (c != '\\')
+            {
+                sb.Append(c);
+                i++;
+                continue;
+            }
+            if (i + 1 >= text.Length)
+            {
+                throw new FormatException("backslash at end of input");
+            }
+            var escape = text[i + 1];
+            switch (escape)
+            {
+                case '\\': sb.Append('\\'); i += 2; break;
+                case '"': sb.Append('"'); i += 2; break;
+                case 'n': sb.Append('\n'); i += 2; break;
+                case 't': sb.Append('\t'); i += 2; break;
+                case 'r': sb.Append('\r'); i += 2; break;
+                case 'u':
+                    sb.Append(ReadHex4(text, i + 2));
+                    i += 6;
+                    break;
+                default:
+                    throw new FormatException($"unknown escape \\{escape}");
+            }
+        }
+        throw new FormatException("unterminated quoted value");
+    }
+
+    static char ReadHex4(string text, int start)
+    {
+        if (start + 4 > text.Length)
+        {
+            throw new FormatException("\\u escape cut short");
+        }
+        var code = 0;
+        for (var i = start; i < start + 4; i++)
+        {
+            var c = text[i];
+            var digit = c switch
+            {
+                >= '0' and <= '9' => c - '0',
+                >= 'a' and <= 'f' => c - 'a' + 10,
+                >= 'A' and <= 'F' => c - 'A' + 10,
+                _ => throw new FormatException($"non-hex digit '{c}' in \\u escape"),
+            };
+            code = code * 16 + digit;
+        }
+        return (char)code;
+    }
+}
