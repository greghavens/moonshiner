+"""Branching (vim-style) undo tree with copy-owned states."""
+
+import copy
+
+
+class _Node:
+    __slots__ = ("id", "state", "parent", "children")
+
+    def __init__(self, node_id, state, parent):
+        self.id = node_id
+        self.state = state
+        self.parent = parent
+        self.children = []       # creation order
+
+
+class UndoTree:
+    def __init__(self, initial_state):
+        root = _Node(0, copy.deepcopy(initial_state), None)
+        self._nodes = {0: root}
+        self._cursor = root
+        self._next_id = 1
+
+    def commit(self, state):
+        node = _Node(self._next_id, copy.deepcopy(state), self._cursor)
+        self._next_id += 1
+        self._cursor.children.append(node)
+        self._nodes[node.id] = node
+        self._cursor = node
+        return node.id
+
+    def head(self):
+        return self._cursor.id
+
+    def current(self):
+        return copy.deepcopy(self._cursor.state)
+
+    def undo(self):
+        if self._cursor.parent is None:
+            raise IndexError("nothing to undo")
+        self._cursor = self._cursor.parent
+        return self.current()
+
+    def redo(self, branch=None):
+        children = self._cursor.children
+        if branch is None:
+            if not children:
+                raise IndexError("nothing to redo")
+            self._cursor = children[-1]      # most recently created
+            return self.current()
+        for child in children:
+            if child.id == branch:
+                self._cursor = child
+                return self.current()
+        raise ValueError("%r is not a direct child of node %d"
+                         % (branch, self._cursor.id))
+
+    def branches(self):
+        return [child.id for child in self._cursor.children]
+
+    def checkout(self, node_id):
+        node = self._nodes.get(node_id)
+        if node is None:
+            raise KeyError("no node %r" % (node_id,))
+        self._cursor = node
+        return self.current()
+
+    def path(self):
+        ids = []
+        node = self._cursor
+        while node is not None:
+            ids.append(node.id)
+            node = node.parent
+        return ids[::-1]
