+"""CSV building/parsing per the Bulk API 2.0 CSV preparation rules.
+
+Files are UTF-8; the job's declared line ending terminates every record
+including the last; nulls are written as #N/A; embedded delimiters, quotes and
+line endings are escaped with double quotes (values are never trimmed).
+"""
+
+import csv
+import io
+
+NULL_TOKEN = "#N/A"
+_LINE_ENDINGS = {"LF": "\n", "CRLF": "\r\n"}
+
+
+def line_terminator(line_ending):
+    try:
+        return _LINE_ENDINGS[line_ending]
+    except KeyError:
+        raise ValueError("lineEnding must be LF or CRLF, not %r" % (line_ending,))
+
+
+def build_csv(fieldnames, rows, line_ending="LF"):
+    """Render rows (dicts) to UTF-8 CSV bytes for a Bulk API 2.0 upload."""
+    out = io.StringIO()
+    writer = csv.writer(out, lineterminator=line_terminator(line_ending))
+    writer.writerow(fieldnames)
+    for row in rows:
+        writer.writerow(
+            NULL_TOKEN if row.get(name) is None else row[name]
+            for name in fieldnames
+        )
+    return out.getvalue().encode("utf-8")
+
+
+def parse_csv(text):
+    """Parse a result CSV (failedResults / unprocessedrecords) to dicts."""
+    return list(csv.DictReader(io.StringIO(text)))
