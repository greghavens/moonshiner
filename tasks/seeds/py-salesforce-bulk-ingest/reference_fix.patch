+"""End-to-end Bulk API 2.0 ingest workflow: create, upload, close, poll,
+collect results — with idempotent recovery when the close PATCH is ambiguous.
+"""
+
+import time
+from dataclasses import dataclass, field
+
+from .errors import PollTimeout, TransportError
+
+TERMINAL_STATES = frozenset({"JobComplete", "Failed", "Aborted"})
+
+
+@dataclass
+class IngestReport:
+    job_id: str
+    state: str
+    records_processed: int = 0
+    records_failed: int = 0
+    error_message: str = ""
+    failed: list = field(default_factory=list)
+    unprocessed: list = field(default_factory=list)
+
+
+def _close_with_recovery(client, job_id):
+    """Close the job, surviving an ambiguous transport failure.
+
+    The close PATCH is a non-idempotent state change: repeating it after it
+    landed fails with INVALIDJOBSTATE. On a transport failure we therefore
+    re-read the job info — any state other than Open means the close was
+    applied; only a still-Open job gets the PATCH again.
+    """
+    try:
+        client.close_job(job_id)
+        return
+    except TransportError:
+        pass
+    info = client.get_job_info(job_id)
+    if info["state"] == "Open":
+        client.close_job(job_id)
+
+
+def run_ingest(client, sobject, fieldnames, rows, operation="insert",
+               line_ending="LF", poll_interval=2.0, max_polls=20,
+               sleep=time.sleep):
+    job = client.create_ingest_job(sobject, operation, line_ending=line_ending)
+    job_id = job["id"]
+    client.upload_job_data(job, fieldnames, rows)
+    _close_with_recovery(client, job_id)
+
+    info = None
+    for poll in range(max_polls):
+        if poll:
+            sleep(poll_interval)
+        info = client.get_job_info(job_id)
+        if info["state"] in TERMINAL_STATES:
+            break
+    else:
+        raise PollTimeout(
+            "job %s not terminal after %d polls (last state %s)"
+            % (job_id, max_polls, info["state"] if info else "unknown"))
+
+    state = info["state"]
+    records_failed = int(info.get("numberRecordsFailed") or 0)
+    report = IngestReport(
+        job_id=job_id,
+        state=state,
+        records_processed=int(info.get("numberRecordsProcessed") or 0),
+        records_failed=records_failed,
+        error_message=info.get("errorMessage") or "",
+    )
+    if state == "Failed" or records_failed > 0:
+        report.failed = client.get_failed_results(job_id)
+    if state in ("Failed", "Aborted"):
+        report.unprocessed = client.get_unprocessed_records(job_id)
+    return report
