@@ -0,0 +1,26 @@
+"""Errors raised by the sf_bulk package.
+
+Exception text never includes the access token: messages are built only from
+status codes and the errorCode/message fields of Salesforce's error envelope.
+"""
+
+
+class BulkApiError(Exception):
+    """A Salesforce REST error envelope: [{"errorCode": ..., "message": ...}]."""
+
+    def __init__(self, status_code, error_code, message):
+        super().__init__(
+            "Salesforce Bulk API error %s (%s): %s"
+            % (status_code, error_code, message)
+        )
+        self.status_code = status_code
+        self.error_code = error_code
+        self.message = message
+
+
+class TransportError(Exception):
+    """A connection-level failure: no HTTP status line was read."""
+
+
+class PollTimeout(Exception):
+    """The job never reached a terminal state within max_polls polls."""
