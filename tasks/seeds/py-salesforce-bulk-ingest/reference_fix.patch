+"""HTTP client for the Salesforce Bulk API 2.0 ingest resources.
+
+Contract researched from the official Bulk API 2.0 developer guide (see
+docs/official_sources.json) and pinned in docs/contract.json:
+
+- POST   /services/data/v67.0/jobs/ingest                 create a job
+- PUT    <job contentUrl>            (Content-Type: text/csv) upload data
+- PATCH  /services/data/v67.0/jobs/ingest/{id}            close/abort
+- GET    /services/data/v67.0/jobs/ingest/{id}            job info
+- GET    .../{id}/failedResults/  and  .../{id}/unprocessedrecords/
+
+Salesforce returns contentUrl WITHOUT a leading slash; it is resolved against
+the instance origin and used verbatim. Redirects are never followed with the
+Authorization header across origins.
+"""
+
+import json
+import urllib.error
+import urllib.request
+from urllib.parse import urlsplit
+
+from .csvio import build_csv, parse_csv
+from .errors import BulkApiError, TransportError
+
+
+class _NoRedirect(urllib.request.HTTPRedirectHandler):
+    def redirect_request(self, req, fp, code, msg, headers, newurl):
+        return None  # surface 3xx as HTTPError; BulkClient decides what to do
+
+
+class BulkClient:
+    def __init__(self, instance_url, access_token, api_version="v67.0"):
+        self.instance_url = instance_url.rstrip("/")
+        self.api_version = api_version
+        self._token = access_token
+        self._opener = urllib.request.build_opener(_NoRedirect())
+
+    # ------------------------------------------------------------ plumbing
+
+    @property
+    def _base(self):
+        return "%s/services/data/%s/jobs/ingest" % (
+            self.instance_url, self.api_version)
+
+    def _request(self, method, url, body=None, content_type=None,
+                 accept="application/json", send_auth=True):
+        headers = {"Accept": accept}
+        if send_auth:
+            headers["Authorization"] = "Bearer " + self._token
+        if content_type is not None:
+            headers["Content-Type"] = content_type
+        req = urllib.request.Request(url, data=body, headers=headers,
+                                     method=method)
+        try:
+            resp = self._opener.open(req)
+        except urllib.error.HTTPError as err:
+            payload = err.read()
+            if 300 <= err.code < 400:
+                return self._follow_redirect(err)
+            raise self._api_error(err.code, payload)
+        except OSError as err:
+            # URLError, RemoteDisconnected, ConnectionResetError, ...
+            raise TransportError(
+                "connection failed before a status line was read: %s"
+                % type(err).__name__)
+        with resp:
+            return resp.status, resp.read()
+
+    def _follow_redirect(self, err):
+        location = err.headers.get("Location")
+        if not location:
+            raise self._api_error(err.code, b"")
+        here = urlsplit(err.url)
+        there = urlsplit(location)
+        same_origin = (there.scheme, there.netloc) in (
+            ("", ""), (here.scheme, here.netloc))
+        # Never carry the Bearer token to a different origin.
+        return self._request("GET", location, accept="text/csv",
+                             send_auth=same_origin)
+
+    @staticmethod
+    def _api_error(status, payload):
+        error_code, message = "UNKNOWN", ""
+        try:
+            envelope = json.loads(payload.decode("utf-8"))
+            if isinstance(envelope, list) and envelope:
+                error_code = envelope[0].get("errorCode", "UNKNOWN")
+                message = envelope[0].get("message", "")
+        except (ValueError, UnicodeDecodeError):
+            pass
+        return BulkApiError(status, error_code, message)
+
+    def _json(self, method, url, payload=None):
+        body = None if payload is None else json.dumps(payload).encode("utf-8")
+        ctype = None if payload is None else "application/json; charset=UTF-8"
+        _, raw = self._request(method, url, body=body, content_type=ctype)
+        return json.loads(raw.decode("utf-8")) if raw else None
+
+    # ------------------------------------------------------------ resources
+
+    def create_ingest_job(self, sobject, operation, line_ending="LF"):
+        return self._json("POST", self._base, {
+            "object": sobject,
+            "operation": operation,
+            "contentType": "CSV",
+            "lineEnding": line_ending,
+        })
+
+    def upload_job_data(self, job, fieldnames, rows):
+        # contentUrl comes back without a leading slash; use it verbatim
+        # against the instance origin — never rebuild the path locally.
+        url = "%s/%s" % (self.instance_url, job["contentUrl"].lstrip("/"))
+        payload = build_csv(fieldnames, rows, job.get("lineEnding", "LF"))
+        status, _ = self._request("PUT", url, body=payload,
+                                  content_type="text/csv")
+        if status != 201:
+            raise BulkApiError(status, "UNEXPECTED_STATUS",
+                               "job data upload expected 201")
+
+    def close_job(self, job_id):
+        return self._set_state(job_id, "UploadComplete")
+
+    def abort_job(self, job_id):
+        return self._set_state(job_id, "Aborted")
+
+    def _set_state(self, job_id, state):
+        return self._json("PATCH", "%s/%s" % (self._base, job_id),
+                          {"state": state})
+
+    def get_job_info(self, job_id):
+        return self._json("GET", "%s/%s" % (self._base, job_id))
+
+    def get_failed_results(self, job_id):
+        return self._result_csv(job_id, "failedResults")
+
+    def get_unprocessed_records(self, job_id):
+        return self._result_csv(job_id, "unprocessedrecords")
+
+    def _result_csv(self, job_id, resource):
+        url = "%s/%s/%s/" % (self._base, job_id, resource)
+        _, raw = self._request("GET", url, accept="text/csv")
+        return parse_csv(raw.decode("utf-8"))
