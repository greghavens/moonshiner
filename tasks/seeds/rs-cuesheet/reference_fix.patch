 //! Wire types for lighting cue sheets exchanged with the console exporter.
 //!
-//! The serialization layer is not built yet — tests/wire.rs pins the wire
-//! contract the console vendor documented.
+//! The console vendor's format is camelCase and strict: stray keys are a
+//! hard error on their importer, so we reject them here too. Colors travel
+//! as `"#rrggbb"` strings even though we keep them as bytes internally.
+
+use serde::{Deserialize, Serialize};
+
+#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
+#[serde(rename_all = "camelCase", deny_unknown_fields)]
+pub struct CueSheet {
+    pub show_name: String,
+    pub cues: Vec<Cue>,
+}
+
+#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
+#[serde(rename_all = "camelCase", deny_unknown_fields)]
+pub struct Cue {
+    pub label: String,
+    pub fade_ms: u32,
+    #[serde(with = "hex_color")]
+    pub color: Rgb,
+    #[serde(default, skip_serializing_if = "String::is_empty")]
+    pub notes: String,
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct Rgb {
+    pub r: u8,
+    pub g: u8,
+    pub b: u8,
+}
+
+/// `Rgb` <-> `"#rrggbb"` (lowercase) for `#[serde(with = "hex_color")]`.
+mod hex_color {
+    use super::Rgb;
+    use serde::de::Error as _;
+    use serde::{Deserialize, Deserializer, Serializer};
+
+    pub fn serialize<S: Serializer>(color: &Rgb, ser: S) -> Result<S::Ok, S::Error> {
+        ser.serialize_str(&format!("#{:02x}{:02x}{:02x}", color.r, color.g, color.b))
+    }
+
+    pub fn deserialize<'de, D: Deserializer<'de>>(de: D) -> Result<Rgb, D::Error> {
+        let raw = String::deserialize(de)?;
+        parse(&raw).ok_or_else(|| {
+            D::Error::custom(format!("invalid color {raw:?}: expected \"#rrggbb\""))
+        })
+    }
+
+    fn parse(raw: &str) -> Option<Rgb> {
+        let hex = raw.strip_prefix('#')?;
+        if hex.len() != 6 || !hex.bytes().all(|b| b.is_ascii_hexdigit()) {
+            return None;
+        }
+        let byte = |i: usize| u8::from_str_radix(&hex[i..i + 2], 16).ok();
+        Some(Rgb {
+            r: byte(0)?,
+            g: byte(2)?,
+            b: byte(4)?,
+        })
+    }
+}
