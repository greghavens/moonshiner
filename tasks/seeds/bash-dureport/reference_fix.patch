diff --git a/dureport.sh b/dureport.sh
new file mode 100644
index 0000000..17de6ab
--- /dev/null
+++ b/dureport.sh
@@ -0,0 +1,136 @@
+#!/usr/bin/env bash
+# dureport.sh — storage report from a captured `du -k` dump (never live du).
+# Usage: dureport.sh [--top N] [--depth D] <dufile|->
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  printf 'usage: dureport.sh [--top N] [--depth D] <dufile|->\n' >&2
+  exit 64
+}
+
+is_posint() {
+  case $1 in
+    ''|*[!0-9]*) return 1 ;;
+  esac
+  [ "$1" -ge 1 ]
+}
+
+top=5
+depth=2
+dufile=''
+have_file=no
+
+while [ "$#" -gt 0 ]; do
+  case $1 in
+    --top)
+      [ "$#" -ge 2 ] || usage
+      is_posint "$2" || usage
+      top=$2
+      shift 2
+      ;;
+    --depth)
+      [ "$#" -ge 2 ] || usage
+      is_posint "$2" || usage
+      depth=$2
+      shift 2
+      ;;
+    -)
+      [ "$have_file" = no ] || usage
+      dufile=-
+      have_file=yes
+      shift
+      ;;
+    --*)
+      usage
+      ;;
+    *)
+      [ "$have_file" = no ] || usage
+      dufile=$1
+      have_file=yes
+      shift
+      ;;
+  esac
+done
+[ "$have_file" = yes ] || usage
+
+if [ "$dufile" != - ] && [ ! -r "$dufile" ]; then
+  printf 'dureport.sh: cannot read: %s\n' "$dufile" >&2
+  exit 66
+fi
+
+report() {
+  awk -v top="$top" -v depth="$depth" '
+  function human(kb,    v, r) {
+    if (kb < 1024) return kb "K"
+    if (kb < 1048576) {
+      v = kb / 1024
+      r = int(v * 10 + 0.5) / 10
+      return sprintf("%.1fM", r)
+    }
+    v = kb / 1048576
+    r = int(v * 10 + 0.5) / 10
+    return sprintf("%.1fG", r)
+  }
+  # order a before b in the TOP table: exact KiB desc, then path asc
+  function topless(a, b) {
+    if (size[a] != size[b]) return size[a] > size[b]
+    return name[a] < name[b]
+  }
+  {
+    t = index($0, "\t")
+    kb = substr($0, 1, t - 1)
+    path = substr($0, t + 1)
+    if (t == 0 || kb !~ /^[0-9]+$/ || path == "") { badline = NR; exit }
+    n++
+    size[n] = kb + 0
+    name[n] = path
+  }
+  END {
+    if (badline) {
+      printf "dureport.sh: bad du record at line %d\n", badline | "cat 1>&2"
+      exit 65
+    }
+    if (n == 0) {
+      printf "dureport.sh: empty du dump\n" | "cat 1>&2"
+      exit 65
+    }
+    root = name[n]
+    rootlen = length(root)
+    printf "TOTAL\t%s\n", human(size[n])
+
+    printf "DIRS (depth<=%d)\n", depth
+    m = 0
+    for (i = 1; i < n; i++) {
+      rest = substr(name[i], rootlen + 2)
+      d = 1
+      for (j = 1; j <= length(rest); j++)
+        if (substr(rest, j, 1) == "/") d++
+      if (d <= depth) dl[++m] = i
+    }
+    for (i = 2; i <= m; i++) {          # insertion sort: path ascending
+      v = dl[i]
+      for (j = i - 1; j >= 1 && name[dl[j]] > name[v]; j--) dl[j + 1] = dl[j]
+      dl[j + 1] = v
+    }
+    for (i = 1; i <= m; i++) printf "%s\t%s\n", name[dl[i]], human(size[dl[i]])
+
+    printf "TOP %d\n", top
+    k = n - 1
+    for (i = 1; i <= k; i++) tl[i] = i
+    for (i = 2; i <= k; i++) {          # insertion sort: KiB desc, path asc
+      v = tl[i]
+      for (j = i - 1; j >= 1 && topless(v, tl[j]); j--) tl[j + 1] = tl[j]
+      tl[j + 1] = v
+    }
+    lim = (top < k) ? top : k
+    for (i = 1; i <= lim; i++) printf "%s\t%s\n", name[tl[i]], human(size[tl[i]])
+  }'
+}
+
+if [ "$dufile" = - ]; then
+  report
+else
+  report < "$dufile"
+fi
