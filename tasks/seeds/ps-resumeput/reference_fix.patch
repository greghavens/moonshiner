diff --git a/resumeput.ps1 b/resumeput.ps1
new file mode 100644
index 0000000..7a2f4fb
--- /dev/null
+++ b/resumeput.ps1
@@ -0,0 +1,65 @@
+# Resumable chunked uploader for the artifact depot.
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$BaseUrl,
+    [Parameter(Mandatory)][string]$Path,
+    [Parameter(Mandatory)][int]$ChunkSize
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+try {
+    $bytes = [System.IO.File]::ReadAllBytes($Path)
+    $sha = [System.Security.Cryptography.SHA256]::Create()
+    try {
+        $digest = -join ($sha.ComputeHash($bytes) | ForEach-Object { $_.ToString('x2') })
+    } finally {
+        $sha.Dispose()
+    }
+
+    $created = Invoke-RestMethod -Uri "$BaseUrl/uploads" -Method Post
+    $id = [string]$created.id
+
+    $puts = 0
+    $probes = 0
+    $offset = 0
+    while ($offset -lt $bytes.Length) {
+        $end = [math]::Min($offset + $ChunkSize, $bytes.Length)
+        $chunk = $bytes[$offset..($end - 1)]
+        $resp = Invoke-WebRequest -Uri "$BaseUrl/uploads/$id`?offset=$offset" -Method Put `
+            -Body ([byte[]]$chunk) -ContentType 'application/octet-stream' -SkipHttpErrorCheck
+        $puts++
+        $status = [int]$resp.StatusCode
+        if ($status -eq 200) {
+            $offset = [int]($resp.Content | ConvertFrom-Json).committed
+        } elseif ($status -eq 500) {
+            # the depot may or may not have kept the bytes — ask it
+            $probes++
+            $offset = [int](Invoke-RestMethod -Uri "$BaseUrl/uploads/$id").committed
+        } elseif ($status -eq 409) {
+            $offset = [int]($resp.Content | ConvertFrom-Json).committed
+        } else {
+            throw "resumeput: upload failed with status $status at offset $offset"
+        }
+    }
+
+    $payload = [ordered]@{ sha256 = $digest; bytes = $bytes.Length } | ConvertTo-Json -Compress
+    $done = Invoke-WebRequest -Uri "$BaseUrl/uploads/$id/complete" -Method Post `
+        -ContentType 'application/json' -Body $payload -SkipHttpErrorCheck
+    if ([int]$done.StatusCode -ne 200) {
+        throw "resumeput: depot rejected completion with status $($done.StatusCode)"
+    }
+
+    $summary = [ordered]@{
+        id     = $id
+        bytes  = $bytes.Length
+        puts   = $puts
+        probes = $probes
+        sha256 = $digest
+    }
+    Write-Output ($summary | ConvertTo-Json -Compress)
+} catch {
+    [Console]::Error.WriteLine($_.Exception.Message)
+    exit 1
+}
