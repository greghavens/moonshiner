+"""Sorting and rendering of todo listings."""
+
+
+def sort_key(todo):
+    # dated first (ascending), undated last, ties by id
+    return (todo["due"] is None, todo["due"] or "", todo["id"])
+
+
+def render(todo, with_marker=False):
+    marker = ""
+    if with_marker:
+        marker = "[x] " if todo["done"] else "[ ] "
+    line = f"{todo['id']}. {marker}{todo['title']}"
+    if todo["due"]:
+        line += f" (due {todo['due']})"
+    return line
+
+
+def listing(store, show_all=False):
+    todos = store["todos"]
+    if not show_all:
+        todos = [t for t in todos if not t["done"]]
+    todos = sorted(todos, key=sort_key)
+    if not todos:
+        return "no todos"
+    return "\n".join(render(t, with_marker=show_all) for t in todos)
