+"""JSON-backed persistence for todos."""
+import json
+import os
+
+
+def load(path):
+    """Return the store dict; a missing file is an empty store (not created)."""
+    if not os.path.exists(path):
+        return {"next_id": 1, "todos": []}
+    with open(path, encoding="utf-8") as f:
+        return json.load(f)
+
+
+def save(path, store):
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(store, f, indent=2)
+        f.write("\n")
+
+
+def add(store, title, due):
+    todo = {"id": store["next_id"], "title": title, "due": due, "done": False}
+    store["next_id"] += 1
+    store["todos"].append(todo)
+    return todo["id"]
+
+
+def find(store, todo_id):
+    for todo in store["todos"]:
+        if todo["id"] == todo_id:
+            return todo
+    return None
+
+
+def remove(store, todo_id):
+    todo = find(store, todo_id)
+    if todo is None:
+        return False
+    store["todos"].remove(todo)
+    return True
