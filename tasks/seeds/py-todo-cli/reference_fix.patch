+#!/usr/bin/env python3
+"""Team todo tracker CLI.
+
+Exit codes: 0 success, 1 domain errors (unknown id, already done),
+2 usage errors (bad date, non-integer id, unknown subcommand).
+"""
+import argparse
+import sys
+from datetime import date
+
+import todoformat
+import todostore
+
+
+def iso_date(text):
+    try:
+        return date.fromisoformat(text).isoformat()
+    except ValueError:
+        raise argparse.ArgumentTypeError(f"not a YYYY-MM-DD date: {text!r}")
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="todo.py")
+    parser.add_argument("--file", default="todos.json", help="data file (JSON)")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_add = sub.add_parser("add")
+    p_add.add_argument("title")
+    p_add.add_argument("--due", type=iso_date, default=None)
+
+    p_list = sub.add_parser("list")
+    p_list.add_argument("--all", action="store_true", dest="show_all")
+
+    for name in ("done", "rm"):
+        p = sub.add_parser(name)
+        p.add_argument("id", type=int)
+    return parser
+
+
+def fail(message):
+    print(message, file=sys.stderr)
+    return 1
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    store = todostore.load(args.file)
+
+    if args.command == "add":
+        new_id = todostore.add(store, args.title, args.due)
+        todostore.save(args.file, store)
+        print(f"added {new_id}")
+        return 0
+
+    if args.command == "list":
+        print(todoformat.listing(store, show_all=args.show_all))
+        return 0
+
+    if args.command == "done":
+        todo = todostore.find(store, args.id)
+        if todo is None:
+            return fail(f"no todo with id {args.id}")
+        if todo["done"]:
+            return fail(f"todo {args.id} is already done")
+        todo["done"] = True
+        todostore.save(args.file, store)
+        return 0
+
+    if args.command == "rm":
+        if not todostore.remove(store, args.id):
+            return fail(f"no todo with id {args.id}")
+        todostore.save(args.file, store)
+        return 0
+
+    return 2  # unreachable
+
+
+if __name__ == "__main__":
+    sys.exit(main())
