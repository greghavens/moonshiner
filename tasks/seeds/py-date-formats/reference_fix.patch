+"""Multi-format date parsing and formatting with pinned ambiguity rules.
+
+Slash = US month-first, dot = EU day-first, 2-digit years use the POSIX
+pivot (00-68 -> 20xx, 69-99 -> 19xx). Fixed UTC offsets only; no tz data.
+"""
+import re
+from datetime import datetime, timedelta, timezone
+
+_MONTHS = ["january", "february", "march", "april", "may", "june", "july",
+           "august", "september", "october", "november", "december"]
+_MONTH_BY_NAME = {}
+for _i, _name in enumerate(_MONTHS, start=1):
+    _MONTH_BY_NAME[_name] = _i
+    _MONTH_BY_NAME[_name[:3]] = _i
+
+_ISO_RE = re.compile(
+    r"^(\d{4})-(\d{2})-(\d{2})"
+    r"(?:[T ](\d{2}):(\d{2})(?::(\d{2}))?"
+    r"(Z|[+-]\d{2}:\d{2})?)?$"
+)
+_US_RE = re.compile(r"^(\d{1,2})/(\d{1,2})/(\d{2}|\d{4})$")
+_EU_RE = re.compile(r"^(\d{1,2})\.(\d{1,2})\.(\d{2}|\d{4})$")
+_NAME_FIRST_RE = re.compile(r"^([A-Za-z]+) (\d{1,2}),? (\d{4})$")
+_DAY_FIRST_RE = re.compile(r"^(\d{1,2}) ([A-Za-z]+) (\d{4})$")
+
+
+def _pivot_year(text):
+    year = int(text)
+    if len(text) == 4:
+        return year
+    return 2000 + year if year <= 68 else 1900 + year
+
+
+def _month_from_name(word, original):
+    month = _MONTH_BY_NAME.get(word.lower())
+    if month is None:
+        raise ValueError(f"unrecognized month name in {original!r}")
+    return month
+
+
+def _build(original, year, month, day, hour=0, minute=0, second=0, tz=None):
+    try:
+        return datetime(year, month, day, hour, minute, second, tzinfo=tz)
+    except ValueError:
+        raise ValueError(f"impossible date/time: {original!r}") from None
+
+
+def _offset(text, original):
+    if text == "Z":
+        return timezone.utc
+    sign = 1 if text[0] == "+" else -1
+    hours, minutes = int(text[1:3]), int(text[4:6])
+    if hours > 23 or minutes > 59:
+        raise ValueError(f"UTC offset out of range in {original!r}")
+    return timezone(sign * timedelta(hours=hours, minutes=minutes))
+
+
+def parse_date(s):
+    if not isinstance(s, str):
+        raise ValueError(f"expected a string, got {type(s).__name__}")
+    text = " ".join(s.split())
+    if not text:
+        raise ValueError("empty date string")
+
+    m = _ISO_RE.match(text)
+    if m:
+        year, month, day = int(m[1]), int(m[2]), int(m[3])
+        hour = int(m[4]) if m[4] else 0
+        minute = int(m[5]) if m[5] else 0
+        second = int(m[6]) if m[6] else 0
+        if m[4] and (hour > 23 or minute > 59 or second > 59):
+            raise ValueError(f"impossible date/time: {s!r}")
+        tz = _offset(m[7], s) if m[7] else None
+        return _build(s, year, month, day, hour, minute, second, tz)
+
+    m = _US_RE.match(text)
+    if m:  # slash is always month-first
+        return _build(s, _pivot_year(m[3]), int(m[1]), int(m[2]))
+
+    m = _EU_RE.match(text)
+    if m:  # dot is always day-first
+        return _build(s, _pivot_year(m[3]), int(m[2]), int(m[1]))
+
+    m = _NAME_FIRST_RE.match(text)
+    if m:
+        return _build(s, int(m[3]), _month_from_name(m[1], s), int(m[2]))
+
+    m = _DAY_FIRST_RE.match(text)
+    if m:
+        return _build(s, int(m[3]), _month_from_name(m[2], s), int(m[1]))
+
+    raise ValueError(f"unrecognized date format: {s!r}")
+
+
+def _render_offset(dt):
+    delta = dt.utcoffset()
+    if delta == timedelta(0):
+        return "Z"
+    sign = "+"
+    if delta < timedelta(0):
+        sign = "-"
+        delta = -delta
+    total = delta.days * 1440 + delta.seconds // 60
+    return f"{sign}{total // 60:02d}:{total % 60:02d}"
+
+
+def format_date(dt, style):
+    if style == "iso":
+        return f"{dt.year:04d}-{dt.month:02d}-{dt.day:02d}"
+    if style == "us":
+        return f"{dt.month}/{dt.day}/{dt.year}"
+    if style == "eu":
+        return f"{dt.day:02d}.{dt.month:02d}.{dt.year:04d}"
+    if style == "long":
+        return f"{_MONTHS[dt.month - 1].capitalize()} {dt.day}, {dt.year}"
+    if style == "iso-full":
+        base = (f"{dt.year:04d}-{dt.month:02d}-{dt.day:02d}"
+                f"T{dt.hour:02d}:{dt.minute:02d}:{dt.second:02d}")
+        if dt.tzinfo is not None:
+            base += _render_offset(dt)
+        return base
+    raise ValueError(f"unknown format style: {style!r}")
