{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0068",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "shipping",
  "prompt": "Find the shipment “Clinic Cooler Return” at Cedar Clinic and report its stable ID, current date, location, and status. Do not make any changes yet. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same shipment to Dale Clinic and set its date to 2026-10-22. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-08. Keep it at Dale Clinic; do not revert any other field."
    }
  ],
  "available_tools": [
    "shipping_search",
    "shipping_get",
    "shipping_list",
    "shipping_update",
    "shipping_cancel",
    "shipping_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "shi-168",
        "name": "Clinic Cooler Return",
        "location": "Cedar Clinic",
        "date": "2026-08-19",
        "status": "active"
      },
      {
        "id": "shi-568",
        "name": "Lab Sample Return",
        "location": "Dale Clinic",
        "date": "2026-09-08",
        "status": "active"
      },
      {
        "id": "shi-868",
        "name": "Clinic Cooler Return",
        "location": "Lakewood Depot",
        "date": "2026-09-08",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_search",
            "arguments": {
              "query": "Clinic Cooler Return",
              "location": "Cedar Clinic"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-168",
              "date": "2026-10-22",
              "location": "Dale Clinic"
            }
          }
        ],
        "purpose": "Apply the requested date and location together to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-168",
              "date": "2026-11-08"
            }
          }
        ],
        "purpose": "Correct only the date while retaining the location set by the preceding update."
      }
    ],
    "state_assertions": [
      "shi-168.date == 2026-11-08",
      "shi-168.location == Dale Clinic",
      "shi-168.status == active",
      "shi-568.date == 2026-09-08",
      "shi-868.date == 2026-09-08",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "shipping_notify",
      "shipping_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "The final date-only update must retain the location established by the preceding turn.",
      "Do not modify either distractor."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
