diff --git a/flagcard.ps1 b/flagcard.ps1
new file mode 100644
index 0000000..a4a86b2
--- /dev/null
+++ b/flagcard.ps1
@@ -0,0 +1,31 @@
+# flagcard.ps1 — audit shim for the nightly maintenance runner.
+# Prints what was actually on the command line, so an omitted switch and
+# an explicit -Switch:$false stop looking identical in the logs.
+[CmdletBinding()]
+param(
+    [switch]$Archive,
+    [switch]$DryRun,
+    [switch]$FollowSymlinks,
+    [switch]$Purge,
+    [switch]$Rescan
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+$flagNames = [string[]]@('Archive', 'DryRun', 'FollowSymlinks', 'Purge', 'Rescan')
+[Array]::Sort($flagNames, [System.StringComparer]::Ordinal)
+
+$lines = @(foreach ($name in $flagNames) {
+    $value = [bool](Get-Variable -Name $name -ValueOnly)
+    $source = if ($PSBoundParameters.ContainsKey($name)) { 'explicit' } else { 'default' }
+    'flag {0} value={1} int={2} source={3}' -f $name, $value, [int]$value, $source
+})
+
+$bound = [string[]]@($flagNames | Where-Object { $PSBoundParameters.ContainsKey($_) })
+$boundLabel = if ($bound.Count -gt 0) { $bound -join ',' } else { '(none)' }
+$lines += "bound: $boundLabel"
+$lines += "explicit: $($bound.Count) of 5"
+
+Write-Output ($lines -join "`n")
+exit 0
