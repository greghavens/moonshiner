diff --git a/iniconf.py b/iniconf.py
new file mode 100644
index 0000000..86efef0
--- /dev/null
+++ b/iniconf.py
@@ -0,0 +1,76 @@
+"""INI config loader with ${ref} interpolation and cycle detection."""
+
+
+class IniError(ValueError):
+    """Any parse or interpolation failure."""
+
+
+def _parse_raw(text):
+    sections = {}
+    current = None
+    for lineno, line in enumerate(text.splitlines(), 1):
+        stripped = line.strip()
+        if not stripped or stripped[0] in ";#":
+            continue
+        if stripped.startswith("["):
+            if not stripped.endswith("]") or len(stripped) < 3:
+                raise IniError(f"line {lineno}: malformed section header {stripped!r}")
+            current = sections.setdefault(stripped[1:-1].strip(), {})
+            continue
+        if current is None:
+            raise IniError(f"line {lineno}: key outside any [section]")
+        if "=" not in stripped:
+            raise IniError(f"line {lineno}: expected 'key = value', got {stripped!r}")
+        key, _, value = stripped.partition("=")
+        current[key.strip()] = value.strip()
+    return sections
+
+
+def _resolve(sections, section, key, stack, cache):
+    qual = f"{section}.{key}"
+    if qual in cache:
+        return cache[qual]
+    if qual in stack:
+        chain = stack[stack.index(qual):] + [qual]
+        raise IniError("interpolation cycle: " + " -> ".join(chain))
+    if section not in sections or key not in sections[section]:
+        raise IniError(f"unknown reference: {qual}")
+    raw = sections[section][key]
+    stack.append(qual)
+    out = []
+    i = 0
+    while i < len(raw):
+        if raw.startswith("$$", i):
+            out.append("$")
+            i += 2
+        elif raw.startswith("${", i):
+            end = raw.find("}", i + 2)
+            if end < 0:
+                raise IniError(f"unterminated reference in {qual}: {raw[i:]!r}")
+            ref = raw[i + 2:end]
+            if not ref:
+                raise IniError(f"empty reference in {qual}")
+            if "." in ref:
+                ref_section, _, ref_key = ref.partition(".")
+            else:
+                ref_section, ref_key = section, ref
+            out.append(_resolve(sections, ref_section, ref_key, stack, cache))
+            i = end + 1
+        else:
+            out.append(raw[i])
+            i += 1
+    stack.pop()
+    cache[qual] = "".join(out)
+    return cache[qual]
+
+
+def load_ini(text):
+    """Parse INI text, resolve every interpolation, return {section: {key: value}}."""
+    sections = _parse_raw(text)
+    cache = {}
+    resolved = {}
+    for section, keys in sections.items():
+        resolved[section] = {}
+        for key in keys:
+            resolved[section][key] = _resolve(sections, section, key, [], cache)
+    return resolved
