From 4529f39c64dfe6a7f8d2aaeb09f4052a18bdf320 Mon Sep 17 00:00:00 2001
From: StreamSeal Maintainers <maintainers@example.invalid>
Date: Thu, 9 Jul 2026 10:00:00 +0000
Subject: [PATCH] prefix embedded ByteShield symbol

Keep ByteShield's implementation private to StreamSeal and avoid collisions
when an application also links a standalone ByteShield.
---
 include/byteshield/byteshield.h | 2 +-
 src/byteshield.c                 | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/include/byteshield/byteshield.h b/include/byteshield/byteshield.h
index ae5c911..dd880ab 100644
--- a/include/byteshield/byteshield.h
+++ b/include/byteshield/byteshield.h
@@ -10,7 +10,7 @@
 extern "C" {
 #endif
 
-uint32_t byteshield_mix(
+uint32_t streamseal_vendor_byteshield_mix(
     const uint8_t *data, size_t size, uint32_t seed);
 
 #ifdef __cplusplus
diff --git a/src/byteshield.c b/src/byteshield.c
index d83ac8e..e95cc4f 100644
--- a/src/byteshield.c
+++ b/src/byteshield.c
@@ -5,7 +5,7 @@ static uint32_t rotate_left_5(uint32_t value) {
     return (value << 5u) | (value >> 27u);
 }
 
-uint32_t byteshield_mix(
+uint32_t streamseal_vendor_byteshield_mix(
     const uint8_t *data, size_t size, uint32_t seed) {
     uint32_t state = seed ^ UINT32_C(0x9e3779b9);
-- 
2.45.2
