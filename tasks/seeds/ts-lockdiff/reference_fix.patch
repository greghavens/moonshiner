+// Lockfile differ: strict semver compare/classify plus dependency-tree
+// diffing and a duplicate-version report. Everything operates on in-memory
+// values — no file I/O.
+
+export type DepNode = { version: string; deps?: DepTree };
+export type DepTree = Record<string, DepNode>;
+
+export type Level = 'major' | 'minor' | 'patch' | 'prerelease' | 'none';
+export type Direction = 'upgrade' | 'downgrade' | 'none';
+
+export type Change = {
+  path: string;
+  name: string;
+  from: string;
+  to: string;
+  level: Exclude<Level, 'none'>;
+  direction: Exclude<Direction, 'none'>;
+};
+
+export type Presence = { path: string; name: string; version: string };
+
+export type DiffReport = {
+  added: Presence[];
+  removed: Presence[];
+  changed: Change[];
+  summary: {
+    added: number;
+    removed: number;
+    changed: { major: number; minor: number; patch: number; prerelease: number };
+  };
+};
+
+export type DedupeEntry = {
+  name: string;
+  versions: { version: string; paths: string[] }[];
+};
+
+// --------------------------------------------------------------------------
+// semver parsing and comparison
+// --------------------------------------------------------------------------
+
+type Parsed = {
+  major: number;
+  minor: number;
+  patch: number;
+  prerelease: string[]; // empty for a release
+};
+
+// Strict semver 2.0.0: numeric triple without leading zeros, optional
+// dot-separated prerelease identifiers (numeric ones without leading zeros),
+// optional build metadata.
+const SEMVER =
+  /^(0|[1-9]\d*)\.(0|[1-9]\d*)\.(0|[1-9]\d*)(?:-((?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\.(?:0|[1-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\+[0-9a-zA-Z-]+(?:\.[0-9a-zA-Z-]+)*)?$/;
+
+function parse(version: string): Parsed {
+  const m = SEMVER.exec(version);
+  if (m === null) {
+    throw new TypeError(`invalid semver version: "${version}"`);
+  }
+  return {
+    major: Number(m[1]),
+    minor: Number(m[2]),
+    patch: Number(m[3]),
+    prerelease: m[4] === undefined ? [] : m[4].split('.'),
+  };
+}
+
+function cmp(a: number | string, b: number | string): -1 | 0 | 1 {
+  return a < b ? -1 : a > b ? 1 : 0;
+}
+
+// Semver 2.0.0 prerelease precedence: identifier by identifier; numeric
+// identifiers compare numerically and rank below alphanumeric ones; a
+// shorter list that is a prefix of a longer one ranks lower.
+function cmpPrerelease(a: string[], b: string[]): -1 | 0 | 1 {
+  if (a.length === 0 && b.length === 0) return 0;
+  if (a.length === 0) return 1; // release outranks any prerelease
+  if (b.length === 0) return -1;
+  for (let i = 0; i < a.length && i < b.length; i++) {
+    const x = a[i];
+    const y = b[i];
+    const xNum = /^\d+$/.test(x);
+    const yNum = /^\d+$/.test(y);
+    if (xNum && yNum) {
+      const c = cmp(Number(x), Number(y));
+      if (c !== 0) return c;
+    } else if (xNum !== yNum) {
+      return xNum ? -1 : 1;
+    } else {
+      const c = cmp(x, y);
+      if (c !== 0) return c;
+    }
+  }
+  return cmp(a.length, b.length);
+}
+
+/**
+ * Compare two exact semver versions. Returns -1, 0 or 1. Build metadata is
+ * ignored. Throws TypeError (naming the offender) on a malformed version.
+ */
+export function compareVersions(a: string, b: string): -1 | 0 | 1 {
+  const pa = parse(a);
+  const pb = parse(b);
+  return (
+    cmp(pa.major, pb.major) ||
+    cmp(pa.minor, pb.minor) ||
+    cmp(pa.patch, pb.patch) ||
+    cmpPrerelease(pa.prerelease, pb.prerelease)
+  );
+}
+
+/**
+ * Classify the move from one exact version to another: the highest-precedence
+ * position that differs gives the level; equal precedence (including a
+ * build-metadata-only difference) is { level: 'none', direction: 'none' }.
+ */
+export function classifyChange(
+  from: string,
+  to: string,
+): { level: Level; direction: Direction } {
+  const pf = parse(from);
+  const pt = parse(to);
+  const order = compareVersions(from, to);
+  if (order === 0) return { level: 'none', direction: 'none' };
+  const direction: Direction = order < 0 ? 'upgrade' : 'downgrade';
+  let level: Level;
+  if (pf.major !== pt.major) level = 'major';
+  else if (pf.minor !== pt.minor) level = 'minor';
+  else if (pf.patch !== pt.patch) level = 'patch';
+  else level = 'prerelease';
+  return { level, direction };
+}
+
+// --------------------------------------------------------------------------
+// tree diffing
+// --------------------------------------------------------------------------
+
+const byPath = <T extends { path: string }>(a: T, b: T) => cmp(a.path, b.path);
+
+function joinPath(prefix: string, name: string): string {
+  return prefix === '' ? name : `${prefix} > ${name}`;
+}
+
+function collectSubtree(tree: DepTree, prefix: string, into: Presence[]): void {
+  for (const name of Object.keys(tree)) {
+    const node = tree[name];
+    const path = joinPath(prefix, name);
+    into.push({ path, name, version: node.version });
+    collectSubtree(node.deps ?? {}, path, into);
+  }
+}
+
+/**
+ * Diff two dependency trees. Nodes are identified by their path (names joined
+ * with " > "); an added or removed node lists its entire subtree. A version
+ * difference in build metadata only is not a change, but children are still
+ * compared. All result arrays are sorted by path.
+ */
+export function diffTrees(before: DepTree, after: DepTree): DiffReport {
+  const added: Presence[] = [];
+  const removed: Presence[] = [];
+  const changed: Change[] = [];
+
+  const walk = (b: DepTree, a: DepTree, prefix: string): void => {
+    const names = new Set([...Object.keys(b), ...Object.keys(a)]);
+    for (const name of names) {
+      const path = joinPath(prefix, name);
+      const inB = Object.hasOwn(b, name);
+      const inA = Object.hasOwn(a, name);
+      if (inB && !inA) {
+        removed.push({ path, name, version: b[name].version });
+        collectSubtree(b[name].deps ?? {}, path, removed);
+        continue;
+      }
+      if (!inB && inA) {
+        added.push({ path, name, version: a[name].version });
+        collectSubtree(a[name].deps ?? {}, path, added);
+        continue;
+      }
+      const from = b[name].version;
+      const to = a[name].version;
+      const { level, direction } = classifyChange(from, to);
+      if (level !== 'none' && direction !== 'none') {
+        changed.push({ path, name, from, to, level, direction });
+      }
+      walk(b[name].deps ?? {}, a[name].deps ?? {}, path);
+    }
+  };
+  walk(before, after, '');
+
+  added.sort(byPath);
+  removed.sort(byPath);
+  changed.sort(byPath);
+  const summary = {
+    added: added.length,
+    removed: removed.length,
+    changed: { major: 0, minor: 0, patch: 0, prerelease: 0 },
+  };
+  for (const c of changed) summary.changed[c.level]++;
+  return { added, removed, changed, summary };
+}
+
+// --------------------------------------------------------------------------
+// dedupe report
+// --------------------------------------------------------------------------
+
+/**
+ * Report every package that a tree resolves at more than one distinct
+ * version. Entries are sorted by name; each entry's versions ascend in
+ * semver order (so prereleases come before their release) and list the
+ * paths where that version occurs, sorted.
+ */
+export function dedupeReport(tree: DepTree): DedupeEntry[] {
+  const byName = new Map<string, Map<string, string[]>>();
+  const visit = (t: DepTree, prefix: string): void => {
+    for (const name of Object.keys(t)) {
+      const node = t[name];
+      const path = joinPath(prefix, name);
+      let versions = byName.get(name);
+      if (versions === undefined) {
+        versions = new Map();
+        byName.set(name, versions);
+      }
+      const paths = versions.get(node.version);
+      if (paths === undefined) versions.set(node.version, [path]);
+      else paths.push(path);
+      visit(node.deps ?? {}, path);
+    }
+  };
+  visit(tree, '');
+
+  const report: DedupeEntry[] = [];
+  for (const [name, versions] of byName) {
+    if (versions.size < 2) continue;
+    const entries = [...versions]
+      .sort(([a], [b]) => compareVersions(a, b))
+      .map(([version, paths]) => ({ version, paths: [...paths].sort(cmp) }));
+    report.push({ name, versions: entries });
+  }
+  report.sort((a, b) => cmp(a.name, b.name));
+  return report;
+}
