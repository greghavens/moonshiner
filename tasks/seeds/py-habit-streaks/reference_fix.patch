+"""Habit tracker CLI: add / done / report."""
+import argparse
+import sys
+
+import habits
+import store
+
+
+def cmd_add(args):
+    state = store.load(args.db)
+    if args.name in state["habits"]:
+        print(f"error: habit {args.name!r} already exists", file=sys.stderr)
+        return 1
+    state["habits"][args.name] = {"schedule": args.schedule, "done": []}
+    store.save(args.db, state)
+    print(f"added {args.name} ({args.schedule})")
+    return 0
+
+
+def cmd_done(args):
+    try:
+        habits.parse_date(args.date)
+    except ValueError:
+        print(f"error: bad date {args.date!r}, expected YYYY-MM-DD", file=sys.stderr)
+        return 1
+    state = store.load(args.db)
+    habit = state["habits"].get(args.name)
+    if habit is None:
+        print(f"error: no such habit {args.name!r}", file=sys.stderr)
+        return 1
+    if args.date not in habit["done"]:
+        habit["done"].append(args.date)
+        habit["done"].sort()
+        store.save(args.db, state)
+    return 0
+
+
+def cmd_report(args):
+    try:
+        habits.parse_date(args.today)
+    except ValueError:
+        print(f"error: bad date {args.today!r}, expected YYYY-MM-DD", file=sys.stderr)
+        return 1
+    state = store.load(args.db)
+    for name in sorted(state["habits"]):
+        habit = state["habits"][name]
+        sched, done = habit["schedule"], habit["done"]
+        cur = habits.current_streak(done, sched, args.today)
+        best = habits.best_streak(done, sched)
+        status = "done" if habits.is_satisfied(done, sched, args.today) else "due"
+        print(f"{name}\t{sched}\tstreak={cur}\tbest={best}\t{status}")
+    return 0
+
+
+def build_parser():
+    ap = argparse.ArgumentParser(prog="habits", description="Tiny habit tracker.")
+    ap.add_argument("--db", required=True, help="path to the JSON state file")
+    sub = ap.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add", help="register a habit")
+    p.add_argument("name")
+    p.add_argument("--schedule", required=True, choices=habits.SCHEDULES)
+    p.set_defaults(func=cmd_add)
+
+    p = sub.add_parser("done", help="record a completion")
+    p.add_argument("name")
+    p.add_argument("--date", required=True, help="YYYY-MM-DD")
+    p.set_defaults(func=cmd_done)
+
+    p = sub.add_parser("report", help="streak report")
+    p.add_argument("--today", required=True, help="YYYY-MM-DD")
+    p.set_defaults(func=cmd_report)
+    return ap
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
