+"""Streak math for the habit tracker. Pure functions, no file IO."""
+import datetime as _dt
+
+SCHEDULES = ("daily", "weekly")
+
+
+def parse_date(text):
+    """Strict YYYY-MM-DD parse; raises ValueError on anything else."""
+    return _dt.date.fromisoformat(text)
+
+
+def _period_index(date, schedule):
+    """Map a date to an integer period ordinal (consecutive periods differ by 1)."""
+    if schedule == "daily":
+        return date.toordinal()
+    if schedule == "weekly":
+        # Monday of the ISO week, in weeks-since-epoch, so consecutive ISO
+        # weeks (including across year boundaries) differ by exactly 1.
+        monday = date - _dt.timedelta(days=date.isoweekday() - 1)
+        return monday.toordinal() // 7
+    raise ValueError(f"unknown schedule: {schedule!r}")
+
+
+def _periods(dates, schedule):
+    return sorted({_period_index(parse_date(d), schedule) for d in dates})
+
+
+def current_streak(dates, schedule, today):
+    """Consecutive periods ending at the current period (or the one before,
+    if the current period isn't satisfied yet). 0 once a full period is missed."""
+    done = set(_periods(dates, schedule))
+    if not done:
+        return 0
+    now = _period_index(parse_date(today), schedule)
+    end = now if now in done else now - 1
+    if end not in done:
+        return 0
+    n = 0
+    while end - n in done:
+        n += 1
+    return n
+
+
+def best_streak(dates, schedule):
+    """Longest run of consecutive satisfied periods anywhere in history."""
+    periods = _periods(dates, schedule)
+    best = run = 0
+    prev = None
+    for p in periods:
+        run = run + 1 if prev is not None and p == prev + 1 else 1
+        best = max(best, run)
+        prev = p
+    return best
+
+
+def is_satisfied(dates, schedule, today):
+    """True if the habit is already done for the current period."""
+    now = _period_index(parse_date(today), schedule)
+    return any(_period_index(parse_date(d), schedule) == now for d in dates)
