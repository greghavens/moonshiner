+#!/usr/bin/env python3
+"""Reference workflow used only to prove the seed is solvable."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import subprocess
+
+
+ROOT = Path(__file__).resolve().parent
+TOOL = ROOT / "calendarctl"
+REPORT = ROOT / "regional-brief.md"
+TRACE = ROOT / ".calendar" / "audit.json"
+SESSION = ROOT / ".calendar" / ".search-session"
+
+
+def terminal_action(arguments: list[str]) -> dict[str, object]:
+    # Keep a shell alive after the executable exits so each invocation has a
+    # distinct parent-shell identity, just as separate Pi terminal actions do.
+    command = [
+        "sh",
+        "-c",
+        '"$@"; action_status=$?; :; exit "$action_status"',
+        "reference-action",
+        str(TOOL),
+        *arguments,
+    ]
+    completed = subprocess.run(
+        command,
+        cwd=ROOT,
+        check=True,
+        capture_output=True,
+        text=True,
+    )
+    return json.loads(completed.stdout)
+
+
+def render(records: list[dict[str, str]]) -> str:
+    table = (
+        "| Name | Stable ID | Location | Date | Status |\n"
+        "|---|---|---|---|---|\n"
+        + "".join(
+            f"| {row['name']} | {row['id']} | {row['location']} | {row['date']} | {row['status']} |\n"
+            for row in records
+        )
+    )
+    if records[0]["status"] == records[1]["status"]:
+        comparison = f"Both meetings have status {records[0]['status']}."
+    else:
+        comparison = (
+            f"The statuses differ: {records[0]['name']} is {records[0]['status']}, "
+            f"while {records[1]['name']} is {records[1]['status']}."
+        )
+    return table + "\n" + comparison + "\n"
+
+
+def main() -> None:
+    TRACE.unlink(missing_ok=True)
+    SESSION.unlink(missing_ok=True)
+    search = terminal_action(
+        [
+            "search",
+            "--name",
+            "East Region Staffing Review",
+            "--location",
+            "New York Office",
+            "--name",
+            "West Region Staffing Review",
+            "--location",
+            "Seattle Office",
+        ]
+    )
+    stable_ids = []
+    for branch in search["searches"]:
+        if len(branch["matches"]) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        stable_ids.append(branch["matches"][0]["id"])
+    retrieved = terminal_action(
+        ["get", *[argument for stable_id in stable_ids for argument in ("--id", stable_id)]]
+    )
+    REPORT.write_text(render(retrieved["records"]), encoding="utf-8")
+
+
+if __name__ == "__main__":
+    main()
