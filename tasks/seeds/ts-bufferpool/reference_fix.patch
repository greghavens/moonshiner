@@ -0,0 +1,15 @@
+/** Base error for every disk and pool misuse. */
+export class PageError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'PageError';
+  }
+}
+
+/** Thrown when a frame is needed but every frame is pinned. */
+export class PoolFullError extends PageError {
+  constructor(capacity: number) {
+    super(`pool is full: all ${capacity} frames are pinned`);
+    this.name = 'PoolFullError';
+  }
+}
