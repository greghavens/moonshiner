index 0000000..1c46985
--- /dev/null
+++ b/replacer.ts
@@ -0,0 +1,80 @@
+/**
+ * LRU-2 replacement policy with a correlated-reference period.
+ *
+ * Time is a global tick the POOL advances (one per successful access).
+ * Per tracked page the replacer keeps:
+ *   last — tick of the most recent access of any kind, and
+ *   hist — ticks of the most recent DISTINCT references, newest first,
+ *          at most two.
+ * An access within `period` ticks of `last` is correlated: it extends the
+ * burst (last = t) without touching hist. Bursts chain — each access only
+ * has to be close to the previous one, not to the burst's start.
+ *
+ * Victim order (unpinned pages only, pinning is the pool's business):
+ *   1. pages with fewer than two distinct references, oldest hist[0] first
+ *      (their backward 2-distance is infinite);
+ *   2. then the page with the smallest hist[1].
+ * Ticks are unique, so selection is total and deterministic.
+ */
+
+interface History {
+  last: number;
+  hist: number[]; // newest first, length <= 2
+}
+
+export class Lru2Replacer {
+  private readonly period: number;
+  private readonly entries = new Map<number, History>();
+
+  constructor(period: number) {
+    this.period = period;
+  }
+
+  /** Records an access to id at the given tick. */
+  access(id: number, tick: number): void {
+    const entry = this.entries.get(id);
+    if (entry === undefined) {
+      this.entries.set(id, { last: tick, hist: [tick] });
+      return;
+    }
+    if (tick - entry.last <= this.period) {
+      entry.last = tick; // correlated: the burst absorbs it
+      return;
+    }
+    entry.hist.unshift(tick);
+    if (entry.hist.length > 2) entry.hist.length = 2;
+    entry.last = tick;
+  }
+
+  /** Forgets a page entirely (called on eviction). */
+  drop(id: number): void {
+    this.entries.delete(id);
+  }
+
+  /**
+   * Picks the victim among the given candidate ids, or undefined when the
+   * candidate list is empty. Candidates must all be tracked.
+   */
+  victim(candidates: number[]): number | undefined {
+    let best: number | undefined;
+    let bestEntry: History | undefined;
+    for (const id of candidates) {
+      const entry = this.entries.get(id);
+      if (entry === undefined) continue;
+      if (bestEntry === undefined || Lru2Replacer.worse(entry, bestEntry)) {
+        best = id;
+        bestEntry = entry;
+      }
+    }
+    return best;
+  }
+
+  /** Returns true when a is a better eviction victim than b. */
+  private static worse(a: History, b: History): boolean {
+    const aInf = a.hist.length < 2;
+    const bInf = b.hist.length < 2;
+    if (aInf !== bInf) return aInf; // infinite distance evicts first
+    if (aInf) return a.hist[0] < b.hist[0]; // oldest first touch loses
+    return a.hist[1] < b.hist[1]; // oldest second-most-recent reference loses
+  }
+}
