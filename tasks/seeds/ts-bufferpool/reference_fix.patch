index 0000000..fb83c44
--- /dev/null
+++ b/pool.ts
@@ -0,0 +1,166 @@
+import { MemoryDisk } from './disk.ts';
+import { PageError, PoolFullError } from './errors.ts';
+import { Lru2Replacer } from './replacer.ts';
+
+export { MemoryDisk } from './disk.ts';
+export { PageError, PoolFullError } from './errors.ts';
+
+export interface BufferPoolOptions {
+  capacity: number;
+  /** Accesses within this many ticks of a page's previous access are
+   *  correlated (one burst, one distinct reference). Default 0. */
+  correlatedPeriod?: number;
+}
+
+export interface PoolStats {
+  capacity: number;
+  resident: number;
+  pinned: number;
+  dirty: number;
+  hits: number;
+  misses: number;
+  evictions: number;
+}
+
+interface Frame {
+  buffer: Uint8Array;
+  pins: number;
+  dirty: boolean;
+}
+
+/**
+ * BufferPool caches disk pages in a bounded set of frames with pin
+ * counting, dirty tracking, and LRU-2 eviction (see replacer.ts for the
+ * policy). All ordering-sensitive I/O goes through the disk journal:
+ * dirty evictions write back before the replacement read; clean evictions
+ * never write.
+ */
+export class BufferPool {
+  private readonly disk: MemoryDisk;
+  private readonly capacity: number;
+  private readonly replacer: Lru2Replacer;
+  private readonly frames = new Map<number, Frame>();
+  private tick = 0;
+  private hits = 0;
+  private misses = 0;
+  private evictions = 0;
+
+  constructor(disk: MemoryDisk, options: BufferPoolOptions) {
+    if (!Number.isInteger(options.capacity) || options.capacity < 1) {
+      throw new PageError('capacity must be a positive integer');
+    }
+    this.disk = disk;
+    this.capacity = options.capacity;
+    this.replacer = new Lru2Replacer(options.correlatedPeriod ?? 0);
+  }
+
+  /**
+   * Allocates a fresh zero-filled page, pinned. Frame space is secured
+   * BEFORE the disk allocation so a full pool burns no page id.
+   */
+  newPage(): { id: number; buffer: Uint8Array } {
+    this.ensureFrame();
+    const id = this.disk.allocate();
+    this.replacer.access(id, ++this.tick);
+    const frame: Frame = { buffer: new Uint8Array(this.disk.pageSize), pins: 1, dirty: false };
+    this.frames.set(id, frame);
+    return { id, buffer: frame.buffer };
+  }
+
+  /** Pins and returns the page's frame buffer, loading it on a miss. */
+  fetch(id: number): Uint8Array {
+    const resident = this.frames.get(id);
+    if (resident !== undefined) {
+      this.replacer.access(id, ++this.tick);
+      this.hits++;
+      resident.pins++;
+      return resident.buffer;
+    }
+    this.ensureFrame();
+    // The read may throw (unknown page); nothing is registered yet, so a
+    // failed fetch leaks no frame, consumes no tick, records no history.
+    const buffer = this.disk.read(id);
+    this.replacer.access(id, ++this.tick);
+    this.misses++;
+    this.frames.set(id, { buffer, pins: 1, dirty: false });
+    return buffer;
+  }
+
+  /** Drops one pin; dirty=true marks the page for write-back. */
+  unpin(id: number, dirty: boolean): void {
+    const frame = this.frames.get(id);
+    if (frame === undefined) {
+      throw new PageError(`unpin: page ${id} is not resident`);
+    }
+    if (frame.pins === 0) {
+      throw new PageError(`unpin: page ${id} is not pinned`);
+    }
+    frame.pins--;
+    frame.dirty = frame.dirty || dirty;
+  }
+
+  /** Pure observer: no pin, no tick, no history effect. */
+  contains(id: number): boolean {
+    return this.frames.has(id);
+  }
+
+  /** Writes the page back if dirty and clears the flag; no-op when clean. */
+  flush(id: number): void {
+    const frame = this.frames.get(id);
+    if (frame === undefined) {
+      throw new PageError(`flush: page ${id} is not resident`);
+    }
+    if (frame.dirty) {
+      this.disk.write(id, frame.buffer);
+      frame.dirty = false;
+    }
+  }
+
+  /** Flushes every dirty page in ascending page-id order. */
+  flushAll(): void {
+    const dirtyIds: number[] = [];
+    for (const [id, frame] of this.frames) {
+      if (frame.dirty) dirtyIds.push(id);
+    }
+    dirtyIds.sort((a, b) => a - b);
+    for (const id of dirtyIds) this.flush(id);
+  }
+
+  stats(): PoolStats {
+    let pinned = 0;
+    let dirty = 0;
+    for (const frame of this.frames.values()) {
+      if (frame.pins > 0) pinned++;
+      if (frame.dirty) dirty++;
+    }
+    return {
+      capacity: this.capacity,
+      resident: this.frames.size,
+      pinned,
+      dirty,
+      hits: this.hits,
+      misses: this.misses,
+      evictions: this.evictions,
+    };
+  }
+
+  /** Guarantees a free frame, evicting the LRU-2 victim if needed. */
+  private ensureFrame(): void {
+    if (this.frames.size < this.capacity) return;
+    const candidates: number[] = [];
+    for (const [id, frame] of this.frames) {
+      if (frame.pins === 0) candidates.push(id);
+    }
+    const victim = this.replacer.victim(candidates);
+    if (victim === undefined) {
+      throw new PoolFullError(this.capacity);
+    }
+    const frame = this.frames.get(victim)!;
+    if (frame.dirty) {
+      this.disk.write(victim, frame.buffer); // write-back precedes any reload
+    }
+    this.frames.delete(victim);
+    this.replacer.drop(victim);
+    this.evictions++;
+  }
+}
diff --git a/replacer.ts b/replacer.ts
