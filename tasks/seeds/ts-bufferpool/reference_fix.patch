@@ -0,0 +1,50 @@
+import { PageError } from './errors.ts';
+
+/**
+ * MemoryDisk is the fake backing store: fixed-size pages addressed by
+ * sequential ids, with a journal of every read/write so tests (and the
+ * pool's callers) can audit I/O ordering. Allocation is not I/O.
+ */
+export class MemoryDisk {
+  readonly pageSize: number;
+  readonly journal: string[] = [];
+  private readonly pages = new Map<number, Uint8Array>();
+  private nextId = 1;
+
+  constructor(pageSize: number) {
+    if (!Number.isInteger(pageSize) || pageSize < 1) {
+      throw new PageError('pageSize must be a positive integer');
+    }
+    this.pageSize = pageSize;
+  }
+
+  /** Allocates a fresh zero-filled page and returns its id. */
+  allocate(): number {
+    const id = this.nextId++;
+    this.pages.set(id, new Uint8Array(this.pageSize));
+    return id;
+  }
+
+  /** Returns a copy of the page's bytes. */
+  read(id: number): Uint8Array {
+    const page = this.pages.get(id);
+    if (page === undefined) {
+      throw new PageError(`read: unknown page ${id}`);
+    }
+    this.journal.push(`read ${id}`);
+    return page.slice();
+  }
+
+  /** Stores a copy of exactly pageSize bytes. */
+  write(id: number, bytes: Uint8Array): void {
+    const page = this.pages.get(id);
+    if (page === undefined) {
+      throw new PageError(`write: unknown page ${id}`);
+    }
+    if (bytes.length !== this.pageSize) {
+      throw new PageError(`write: page ${id} expects ${this.pageSize} bytes, got ${bytes.length}`);
+    }
+    this.journal.push(`write ${id}`);
+    this.pages.set(id, bytes.slice());
+  }
+}
