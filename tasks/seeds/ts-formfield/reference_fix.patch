+// Accessible form kit: renders a field-spec-driven form from reducer state.
+// Server-render friendly — pure function of props, no effects, no refs.
+
+import type { FieldSpec, FieldState, FormState } from "./form_reducer.ts";
+
+interface AccessibleFormProps {
+  specs: FieldSpec[];
+  state: FormState;
+  legend: string;
+}
+
+function describedBy(spec: FieldSpec, showError: boolean): string | undefined {
+  const ids: string[] = [];
+  if (spec.hint) ids.push(`field-${spec.name}-hint`);
+  if (showError) ids.push(`field-${spec.name}-error`);
+  return ids.length > 0 ? ids.join(" ") : undefined;
+}
+
+function Field({
+  spec,
+  field,
+  submitAttempted,
+}: {
+  spec: FieldSpec;
+  field: FieldState;
+  submitAttempted: boolean;
+}) {
+  const id = `field-${spec.name}`;
+  const showError = field.error !== null && (field.touched || submitAttempted);
+  const shared = {
+    id,
+    name: spec.name,
+    "aria-invalid": showError ? ("true" as const) : undefined,
+    "aria-describedby": describedBy(spec, showError),
+  };
+  return (
+    <div className="form-field">
+      <label htmlFor={id}>{spec.label}</label>
+      {spec.hint ? (
+        <p className="field-hint" id={`${id}-hint`}>
+          {spec.hint}
+        </p>
+      ) : null}
+      {spec.kind === "multiline" ? (
+        <textarea {...shared} value={field.value} />
+      ) : (
+        <input {...shared} type={spec.kind === "email" ? "email" : "text"} value={field.value} />
+      )}
+      {showError ? (
+        <p className="field-error" id={`${id}-error`}>
+          {field.error}
+        </p>
+      ) : null}
+    </div>
+  );
+}
+
+function ErrorSummary({ specs, state }: { specs: FieldSpec[]; state: FormState }) {
+  const erroring = specs.filter((spec) => state.fields[spec.name].error !== null);
+  if (!state.submitAttempted || erroring.length === 0) return null;
+  return (
+    <div className="error-summary" role="alert" aria-labelledby="error-summary-heading">
+      <h2 id="error-summary-heading">There is a problem</h2>
+      <ul>
+        {erroring.map((spec) => (
+          <li key={spec.name}>
+            <a href={`#field-${spec.name}`}>{state.fields[spec.name].error}</a>
+          </li>
+        ))}
+      </ul>
+    </div>
+  );
+}
+
+export function AccessibleForm({ specs, state, legend }: AccessibleFormProps) {
+  return (
+    <form className="acc-form" noValidate>
+      <fieldset>
+        <legend>{legend}</legend>
+        <ErrorSummary specs={specs} state={state} />
+        {specs.map((spec) => (
+          <Field
+            key={spec.name}
+            spec={spec}
+            field={state.fields[spec.name]}
+            submitAttempted={state.submitAttempted}
+          />
+        ))}
+        <button type="submit">Submit</button>
+      </fieldset>
+      {state.status === "submitted" ? (
+        <p className="form-success" role="status">
+          Thanks, your details were submitted.
+        </p>
+      ) : null}
+    </form>
+  );
+}
