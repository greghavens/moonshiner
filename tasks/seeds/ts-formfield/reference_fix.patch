+// Validation state machine for the accessible form kit. Pure data in, pure
+// data out — no React here, so the logic is unit-testable on its own.
+
+export type FieldKind = "text" | "email" | "multiline";
+
+export interface FieldSpec {
+  name: string;
+  label: string;
+  kind: FieldKind;
+  required?: boolean;
+  maxLength?: number;
+  hint?: string;
+}
+
+export interface FieldState {
+  value: string;
+  touched: boolean;
+  error: string | null;
+}
+
+export interface FormState {
+  fields: Record<string, FieldState>;
+  submitAttempted: boolean;
+  status: "editing" | "submitted";
+}
+
+export type FormAction =
+  | { type: "change"; name: string; value: string }
+  | { type: "blur"; name: string }
+  | { type: "submit" }
+  | { type: "reset" };
+
+const EMAIL_SHAPE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
+
+export function validateField(spec: FieldSpec, value: string): string | null {
+  const trimmed = value.trim();
+  if (spec.required && trimmed === "") {
+    return `${spec.label} is required.`;
+  }
+  if (trimmed !== "" && spec.kind === "email" && !EMAIL_SHAPE.test(trimmed)) {
+    return `${spec.label} must be a valid email address.`;
+  }
+  if (spec.maxLength != null && trimmed.length > spec.maxLength) {
+    return `${spec.label} must be ${spec.maxLength} characters or fewer.`;
+  }
+  return null;
+}
+
+export function initForm(specs: FieldSpec[]): FormState {
+  const fields: Record<string, FieldState> = {};
+  for (const spec of specs) {
+    fields[spec.name] = { value: "", touched: false, error: null };
+  }
+  return { fields, submitAttempted: false, status: "editing" };
+}
+
+export function createFormReducer(specs: FieldSpec[]) {
+  const byName = new Map(specs.map((spec) => [spec.name, spec]));
+
+  function specFor(name: string): FieldSpec {
+    const spec = byName.get(name);
+    if (!spec) throw new RangeError(`unknown field: ${name}`);
+    return spec;
+  }
+
+  return function formReducer(state: FormState, action: FormAction): FormState {
+    switch (action.type) {
+      case "change": {
+        const spec = specFor(action.name);
+        const field = state.fields[action.name];
+        const live = field.touched || state.submitAttempted;
+        const next: FieldState = {
+          ...field,
+          value: action.value,
+          error: live ? validateField(spec, action.value) : field.error,
+        };
+        return {
+          ...state,
+          fields: { ...state.fields, [action.name]: next },
+          status: "editing",
+        };
+      }
+      case "blur": {
+        const spec = specFor(action.name);
+        const field = state.fields[action.name];
+        const next: FieldState = {
+          ...field,
+          touched: true,
+          error: validateField(spec, field.value),
+        };
+        return { ...state, fields: { ...state.fields, [action.name]: next } };
+      }
+      case "submit": {
+        const fields: Record<string, FieldState> = {};
+        let allValid = true;
+        for (const spec of specs) {
+          const field = state.fields[spec.name];
+          const error = validateField(spec, field.value);
+          if (error !== null) allValid = false;
+          fields[spec.name] = { ...field, touched: true, error };
+        }
+        return {
+          fields,
+          submitAttempted: true,
+          status: allValid ? "submitted" : "editing",
+        };
+      }
+      case "reset":
+        return initForm(specs);
+      default:
+        return state;
+    }
+  };
+}
