+++ b/audit.md
@@ -0,0 +1,7 @@
+## First record
+Harbor Signals Atlas at Coastal Branch has stable ID `lib-153` and retrieved status `in-transit`.
+
+## Second record
+The Small Museum Handbook at University Branch has stable ID `lib-553` and retrieved status `available`.
+
+The first status is `in-transit` and the second is `available`; the statuses are different.
diff --git a/reference_solution.sh b/reference_solution.sh
new file mode 100755
--- /dev/null
+++ b/reference_solution.sh
@@ -0,0 +1,64 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+stage=${1:-main}
+scratch=${2:-__pycache__/reference_solution}
+mkdir -p "$scratch"
+
+if [[ "$stage" == search ]]; then
+  python3 libraryctl search \
+    --name 'Harbor Signals Atlas' \
+    --location 'Coastal Branch' > "$scratch/first-search.json" &
+  first_search_pid=$!
+  python3 libraryctl search \
+    --name 'The Small Museum Handbook' \
+    --location 'University Branch' > "$scratch/second-search.json" &
+  second_search_pid=$!
+  wait "$first_search_pid"
+  wait "$second_search_pid"
+  exit
+fi
+
+if [[ "$stage" == get ]]; then
+  first_id=$3
+  second_id=$4
+  python3 libraryctl get --id "$first_id" > "$scratch/first-get.json" &
+  first_get_pid=$!
+  python3 libraryctl get --id "$second_id" > "$scratch/second-get.json" &
+  second_get_pid=$!
+  wait "$first_get_pid"
+  wait "$second_get_pid"
+  exit
+fi
+
+bash "$0" search "$scratch"
+
+first_id=$(python3 -c \
+  'import json,sys; matches=json.load(open(sys.argv[1]))["matches"]; assert len(matches) == 1; print(matches[0]["id"])' \
+  "$scratch/first-search.json")
+second_id=$(python3 -c \
+  'import json,sys; matches=json.load(open(sys.argv[1]))["matches"]; assert len(matches) == 1; print(matches[0]["id"])' \
+  "$scratch/second-search.json")
+
+bash "$0" get "$scratch" "$first_id" "$second_id"
+
+python3 - "$scratch/first-get.json" "$scratch/second-get.json" <<'PY'
+import json
+from pathlib import Path
+import sys
+
+first = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
+second = json.loads(Path(sys.argv[2]).read_text(encoding="utf-8"))
+relation = "the same" if first["status"] == second["status"] else "different"
+report = (
+    "## First record\n"
+    f"{first['name']} at {first['location']} has stable ID `{first['id']}` "
+    f"and retrieved status `{first['status']}`.\n\n"
+    "## Second record\n"
+    f"{second['name']} at {second['location']} has stable ID `{second['id']}` "
+    f"and retrieved status `{second['status']}`.\n\n"
+    f"The first status is `{first['status']}` and the second is `{second['status']}`; "
+    f"the statuses are {relation}.\n"
+)
+Path("audit.md").write_text(report, encoding="utf-8")
+PY
