+"""Write-side of worker assignments: date-effective corrections and updates.
+
+A change is applied as GET (capture the ETag) then PATCH conditioned on that
+ETag with If-Match. The Effective-Of header selects the documented range
+mode: CORRECTION rewrites the physical row in place, UPDATE inserts a new
+date-effective row from range_start. A 412 means someone changed the row
+between our read and write — refresh once and retry; a second 412 raises
+ConcurrencyError. A 400 carries the pod's full validation verdict and is
+never retried.
+"""
+
+from dataclasses import dataclass
+
+from assignment_reader import assignment_path, read_assignment
+
+PATCH_MEDIA_TYPE = "application/vnd.oracle.adf.resourceitem+json"
+
+
+class ValidationError(Exception):
+    def __init__(self, title, status, messages):
+        self.title = title
+        self.status = status
+        self.messages = list(messages)
+        lines = [f"{title} (HTTP {status})"]
+        for code, path, detail in self.messages:
+            where = f" at {path}" if path else ""
+            lines.append(f"  [{code}]{where}: {detail}")
+        super().__init__("\n".join(lines))
+
+
+class ConcurrencyError(Exception):
+    def __init__(self, attempts, path):
+        self.attempts = attempts
+        super().__init__(
+            f"assignment was modified concurrently; gave up after "
+            f"{attempts} conditional attempts on {path}"
+        )
+
+
+@dataclass
+class UpdateResult:
+    mode: str
+    item: dict
+    retried: bool
+
+
+def _effective_of(mode, range_start, range_end):
+    if mode == "correction":
+        header = "RangeMode=CORRECTION"
+    elif mode == "update":
+        if not range_start:
+            raise ValueError("update mode requires range_start (the new row's effective start date)")
+        header = "RangeMode=UPDATE"
+    else:
+        raise ValueError(f"unknown assignment change mode: {mode!r}")
+    if range_start:
+        header += f";RangeStartDate={range_start}"
+    if range_end:
+        header += f";RangeEndDate={range_end}"
+    return header
+
+
+def _validation_error(body):
+    body = body or {}
+    messages = [
+        (
+            entry.get("o:errorCode", ""),
+            entry.get("o:errorPath", ""),
+            entry.get("detail", ""),
+        )
+        for entry in body.get("o:errorDetails", [])
+    ]
+    return ValidationError(body.get("title", "Bad Request"), body.get("status", "400"), messages)
+
+
+def apply_assignment_change(
+    session,
+    worker_uid,
+    period_of_service_id,
+    assignment_uid,
+    changes,
+    mode,
+    range_start=None,
+    range_end=None,
+):
+    effective_of = _effective_of(mode, range_start, range_end)
+    path = assignment_path(worker_uid, period_of_service_id, assignment_uid)
+    body = dict(changes)
+
+    retried = False
+    for attempt in range(2):
+        snapshot = read_assignment(session, worker_uid, period_of_service_id, assignment_uid)
+        resp = session.request(
+            "PATCH",
+            path,
+            headers={
+                "Content-Type": PATCH_MEDIA_TYPE,
+                "If-Match": snapshot.etag,
+                "Effective-Of": effective_of,
+            },
+            body=body,
+        )
+        if resp.status == 412:
+            retried = True
+            continue
+        if resp.status == 400:
+            raise _validation_error(resp.body)
+        if resp.status // 100 != 2:
+            raise RuntimeError(f"assignment change failed with HTTP {resp.status}")
+        item = dict(resp.body)
+        item.pop("links", None)
+        return UpdateResult(mode=mode, item=item, retried=retried)
+
+    raise ConcurrencyError(attempts=2, path=path)
