diff --git a/exec.go b/exec.go
new file mode 100644
index 0000000..3a6d976
--- /dev/null
+++ b/exec.go
@@ -0,0 +1,202 @@
+package buildgraph
+
+import (
+	"fmt"
+	"os"
+	"path/filepath"
+	"sort"
+)
+
+// ActionFunc builds one target. It must create tc.OutPath.
+type ActionFunc func(tc *TaskContext) error
+
+// TaskContext is everything an action gets to look at.
+type TaskContext struct {
+	Label      string   // the target being built
+	Inputs     []string // absolute input paths, declaration order
+	DepOutputs []string // absolute dep output paths, sorted by dep label
+	OutPath    string   // where the action must write its output
+}
+
+// Options configures an Executor.
+type Options struct {
+	Workers int                   // max actions in flight; at least 1
+	Actions map[string]ActionFunc // action name -> implementation
+}
+
+// Executor runs targets with content-hash incrementality and early cutoff.
+type Executor struct {
+	ws   *Workspace
+	opts Options
+}
+
+// Report says what one Execute call did. Both lists are sorted.
+type Report struct {
+	Ran      []string // targets whose action ran
+	UpToDate []string // targets skipped because their records still match
+}
+
+// NewExecutor validates opts against ws up front: Workers must be at least 1
+// and every action referenced by any target must be registered.
+func NewExecutor(ws *Workspace, opts Options) (*Executor, error) {
+	if opts.Workers < 1 {
+		return nil, fmt.Errorf("workers must be at least 1, got %d", opts.Workers)
+	}
+	for _, label := range ws.labels {
+		t := ws.targets[label]
+		if _, ok := opts.Actions[t.Action]; !ok {
+			return nil, fmt.Errorf("target %s: no action %q registered", label, t.Action)
+		}
+	}
+	return &Executor{ws: ws, opts: opts}, nil
+}
+
+// taskResult is what one worker hands back to the scheduling loop.
+type taskResult struct {
+	label   string
+	ran     bool   // action executed (vs. skipped as up to date)
+	outHash string // current output hash either way
+	newRec  record // replacement state record when ran
+	err     error
+}
+
+// Execute brings label and everything it depends on up to date, running at
+// most Workers actions concurrently. The report is non-nil even on error,
+// and state is saved even on error so the next run resumes past survivors.
+func (e *Executor) Execute(label string) (*Report, error) {
+	rep := &Report{}
+	order, err := e.ws.cone(label)
+	if err != nil {
+		return rep, err
+	}
+	state := loadState(e.ws.statePath())
+	outHash := make(map[string]string, len(order)) // finished label -> hash
+
+	remaining := make(map[string]int, len(order))
+	dependents := map[string][]string{}
+	var ready []string
+	for _, l := range order {
+		remaining[l] = len(e.ws.targets[l].Deps)
+		for _, dep := range e.ws.targets[l].Deps {
+			dependents[dep] = append(dependents[dep], l)
+		}
+		if remaining[l] == 0 {
+			ready = append(ready, l)
+		}
+	}
+	sort.Strings(ready)
+
+	results := make(chan taskResult)
+	active := 0
+	var firstErr error
+
+	// launch snapshots everything a worker needs while still on the
+	// scheduler goroutine, so workers never share mutable state.
+	launch := func(l string) {
+		t := e.ws.targets[l]
+		rec, hasRec := state[l]
+		depHashes := make(map[string]string, len(t.Deps))
+		for _, dep := range t.Deps {
+			depHashes[dep] = outHash[dep]
+		}
+		go func() {
+			results <- e.runOne(l, t, rec, hasRec, depHashes)
+		}()
+	}
+
+	for {
+		for firstErr == nil && active < e.opts.Workers && len(ready) > 0 {
+			launch(ready[0])
+			ready = ready[1:]
+			active++
+		}
+		if active == 0 {
+			break
+		}
+		r := <-results
+		active--
+		if r.err != nil {
+			if firstErr == nil {
+				firstErr = r.err
+			}
+			continue
+		}
+		outHash[r.label] = r.outHash
+		if r.ran {
+			state[r.label] = r.newRec
+			rep.Ran = append(rep.Ran, r.label)
+		} else {
+			rep.UpToDate = append(rep.UpToDate, r.label)
+		}
+		grew := false
+		for _, dep := range dependents[r.label] {
+			remaining[dep]--
+			if remaining[dep] == 0 {
+				ready = append(ready, dep)
+				grew = true
+			}
+		}
+		if grew {
+			sort.Strings(ready)
+		}
+	}
+
+	sort.Strings(rep.Ran)
+	sort.Strings(rep.UpToDate)
+	if err := saveState(e.ws.statePath(), state); err != nil && firstErr == nil {
+		firstErr = err
+	}
+	return rep, firstErr
+}
+
+// runOne decides skip-vs-run for one target and runs its action if needed.
+// Everything it touches arrived as a snapshot, so concurrent calls are
+// independent. Freshness is content hashes only; mtimes never matter, and
+// depHashes holds the deps' post-run hashes, which is what makes early
+// cutoff work: a dep that reran but reproduced identical bytes still counts
+// as unchanged here.
+func (e *Executor) runOne(label string, t *Target, rec record, hasRec bool, depHashes map[string]string) taskResult {
+	inputs, err := e.ws.hashInputs(label, t)
+	if err != nil {
+		return taskResult{label: label, err: err}
+	}
+	outPath := e.ws.OutPath(label)
+	if hasRec && sameHashes(inputs, rec.Inputs) && sameHashes(depHashes, rec.Deps) {
+		h, ok, err := hashFile(outPath)
+		if err != nil {
+			return taskResult{label: label, err: fmt.Errorf("target %s: %w", label, err)}
+		}
+		if ok && h == rec.Out {
+			return taskResult{label: label, outHash: h}
+		}
+	}
+
+	if err := os.MkdirAll(filepath.Dir(outPath), 0o755); err != nil {
+		return taskResult{label: label, err: fmt.Errorf("target %s: %w", label, err)}
+	}
+	tc := &TaskContext{Label: label, OutPath: outPath}
+	for _, in := range t.Inputs {
+		tc.Inputs = append(tc.Inputs, e.ws.inputPath(t, in))
+	}
+	depLabels := append([]string(nil), t.Deps...)
+	sort.Strings(depLabels)
+	for _, dep := range depLabels {
+		tc.DepOutputs = append(tc.DepOutputs, e.ws.OutPath(dep))
+	}
+	if err := e.opts.Actions[t.Action](tc); err != nil {
+		return taskResult{label: label, err: fmt.Errorf("target %s: %w", label, err)}
+	}
+	h, ok, err := hashFile(outPath)
+	if err != nil {
+		return taskResult{label: label, err: fmt.Errorf("target %s: %w", label, err)}
+	}
+	if !ok {
+		return taskResult{label: label, err: fmt.Errorf("target %s: action %q wrote no output at %s", label, t.Action, outPath)}
+	}
+	return taskResult{
+		label:   label,
+		ran:     true,
+		outHash: h,
+		newRec:  record{Inputs: inputs, Deps: depHashes, Out: h},
+	}
+}
diff --git a/graph.go b/graph.go
new file mode 100644
index 0000000..6a8b0d9
--- /dev/null
+++ b/graph.go
@@ -0,0 +1,135 @@
+package buildgraph
+
+import (
+	"fmt"
+	"sort"
+	"strings"
+)
+
+// checkDeps verifies every dependency names a declared target.
+func (w *Workspace) checkDeps() error {
+	for _, label := range w.labels {
+		for _, dep := range w.targets[label].Deps {
+			if _, ok := w.targets[dep]; !ok {
+				return fmt.Errorf("target %s depends on unknown target %s", label, dep)
+			}
+		}
+	}
+	return nil
+}
+
+// checkAcyclic rejects dependency cycles. The reported cycle lists its
+// members in edge order starting from the lexicographically smallest one,
+// with the first label repeated at the end.
+func (w *Workspace) checkAcyclic() error {
+	const (
+		white = iota // untouched
+		grey         // on the current DFS stack
+		black        // fully explored
+	)
+	color := make(map[string]int, len(w.labels))
+	var stack, cycle []string
+
+	var visit func(label string) bool // reports "cycle found"
+	visit = func(label string) bool {
+		color[label] = grey
+		stack = append(stack, label)
+		deps := append([]string(nil), w.targets[label].Deps...)
+		sort.Strings(deps)
+		for _, dep := range deps {
+			switch color[dep] {
+			case white:
+				if visit(dep) {
+					return true
+				}
+			case grey:
+				for i, on := range stack {
+					if on == dep {
+						cycle = append(cycle, stack[i:]...)
+						break
+					}
+				}
+				return true
+			}
+		}
+		stack = stack[:len(stack)-1]
+		color[label] = black
+		return false
+	}
+
+	for _, label := range w.labels {
+		if color[label] == white && visit(label) {
+			return fmt.Errorf("dependency cycle: %s", formatCycle(cycle))
+		}
+	}
+	return nil
+}
+
+// formatCycle rotates the cycle to start at its smallest member and closes
+// the loop: "a:one -> b:two -> a:one".
+func formatCycle(cycle []string) string {
+	min := 0
+	for i, label := range cycle {
+		if label < cycle[min] {
+			min = i
+		}
+	}
+	rotated := append(append([]string(nil), cycle[min:]...), cycle[:min]...)
+	rotated = append(rotated, rotated[0])
+	return strings.Join(rotated, " -> ")
+}
+
+// cone returns label plus everything it depends on, in execution order:
+// dependencies before dependents, lexicographic among the ready set.
+func (w *Workspace) cone(label string) ([]string, error) {
+	if _, ok := w.targets[label]; !ok {
+		return nil, fmt.Errorf("unknown target %s", label)
+	}
+	inCone := map[string]bool{}
+	var collect func(string)
+	collect = func(l string) {
+		if inCone[l] {
+			return
+		}
+		inCone[l] = true
+		for _, dep := range w.targets[l].Deps {
+			collect(dep)
+		}
+	}
+	collect(label)
+
+	remaining := make(map[string]int, len(inCone))
+	dependents := map[string][]string{}
+	var ready []string
+	for l := range inCone {
+		remaining[l] = len(w.targets[l].Deps)
+		for _, dep := range w.targets[l].Deps {
+			dependents[dep] = append(dependents[dep], l)
+		}
+	}
+	for l := range inCone {
+		if remaining[l] == 0 {
+			ready = append(ready, l)
+		}
+	}
+	sort.Strings(ready)
+
+	order := make([]string, 0, len(inCone))
+	for len(ready) > 0 {
+		l := ready[0]
+		ready = ready[1:]
+		order = append(order, l)
+		grew := false
+		for _, dep := range dependents[l] {
+			remaining[dep]--
+			if remaining[dep] == 0 {
+				ready = append(ready, dep)
+				grew = true
+			}
+		}
+		if grew {
+			sort.Strings(ready)
+		}
+	}
+	return order, nil
+}
diff --git a/manifest.go b/manifest.go
new file mode 100644
index 0000000..2c36712
--- /dev/null
+++ b/manifest.go
@@ -0,0 +1,78 @@
+package buildgraph
+
+import (
+	"bytes"
+	"encoding/json"
+	"fmt"
+	"os"
+	"path"
+	"strings"
+)
+
+const manifestName = "build.json"
+
+// manifestTarget is one entry in a build.json "targets" list.
+type manifestTarget struct {
+	Name   string   `json:"name"`
+	Action string   `json:"action"`
+	Inputs []string `json:"inputs"`
+	Deps   []string `json:"deps"`
+}
+
+type manifest struct {
+	Targets []manifestTarget `json:"targets"`
+}
+
+// readManifest parses and validates one build.json. rel is the manifest's
+// path relative to the workspace root and prefixes every error it reports.
+func readManifest(absPath, rel string) (*manifest, error) {
+	raw, err := os.ReadFile(absPath)
+	if err != nil {
+		return nil, fmt.Errorf("%s: %w", rel, err)
+	}
+	dec := json.NewDecoder(bytes.NewReader(raw))
+	dec.DisallowUnknownFields()
+	var m manifest
+	if err := dec.Decode(&m); err != nil {
+		return nil, fmt.Errorf("%s: %w", rel, err)
+	}
+	seen := make(map[string]bool, len(m.Targets))
+	for _, t := range m.Targets {
+		if t.Name == "" || strings.ContainsAny(t.Name, ":/") {
+			return nil, fmt.Errorf("%s: invalid target name %q", rel, t.Name)
+		}
+		if seen[t.Name] {
+			return nil, fmt.Errorf("%s: duplicate target %q", rel, t.Name)
+		}
+		seen[t.Name] = true
+		if t.Action == "" {
+			return nil, fmt.Errorf("%s: target %q: missing action", rel, t.Name)
+		}
+		for _, in := range t.Inputs {
+			if !inputOK(in) {
+				return nil, fmt.Errorf("%s: target %q: invalid input %q", rel, t.Name, in)
+			}
+		}
+	}
+	return &m, nil
+}
+
+// inputOK reports whether a declared input path is relative and stays inside
+// its package directory.
+func inputOK(in string) bool {
+	if in == "" || path.IsAbs(in) {
+		return false
+	}
+	clean := path.Clean(in)
+	return clean != ".." && !strings.HasPrefix(clean, "../")
+}
+
+// canonicalLabel resolves a dependency reference written in pkg's manifest:
+// a bare "name" belongs to pkg itself, anything with a colon (":name" for the
+// root package, "pkg/path:name" fully qualified) is already a label.
+func canonicalLabel(pkg, dep string) string {
+	if !strings.Contains(dep, ":") {
+		return pkg + ":" + dep
+	}
+	return dep
+}
