new file mode 100644
index 0000000..1b13be5
--- /dev/null
+++ b/plan.go
@@ -0,0 +1,92 @@
+package buildgraph
+
+import "strings"
+
+// Step is one entry in a dry-run plan.
+type Step struct {
+	Label string
+	Run   bool
+}
+
+// Plan reports, in execution order, what Execute(label) would do right now.
+// It is read-only: no actions run, nothing is written, out/ is not created.
+//
+// Planning is pessimistic about propagation: a target whose dependency is
+// planned to run is planned to run too, even though Execute's fresh-output
+// comparison may later prove the rebuild unnecessary (early cutoff).
+func (e *Executor) Plan(label string) ([]Step, error) {
+	order, err := e.ws.cone(label)
+	if err != nil {
+		return nil, err
+	}
+	state := loadState(e.ws.statePath())
+	willRun := make(map[string]bool, len(order))
+	steps := make([]Step, 0, len(order))
+	for _, l := range order {
+		t := e.ws.targets[l]
+		inputs, err := e.ws.hashInputs(l, t)
+		if err != nil {
+			return nil, err
+		}
+		run := false
+		for _, dep := range t.Deps {
+			if willRun[dep] {
+				run = true
+				break
+			}
+		}
+		if !run {
+			fresh, err := e.recordCurrent(l, t, inputs, state)
+			if err != nil {
+				return nil, err
+			}
+			run = !fresh
+		}
+		willRun[l] = run
+		steps = append(steps, Step{Label: l, Run: run})
+	}
+	return steps, nil
+}
+
+// recordCurrent reports whether l's state record still matches the tree:
+// same input hashes, same dep-output hashes, own output present and intact.
+func (e *Executor) recordCurrent(l string, t *Target, inputs map[string]string, state map[string]record) (bool, error) {
+	rec, ok := state[l]
+	if !ok || !sameHashes(inputs, rec.Inputs) {
+		return false, nil
+	}
+	depHashes := make(map[string]string, len(t.Deps))
+	for _, dep := range t.Deps {
+		h, ok, err := hashFile(e.ws.OutPath(dep))
+		if err != nil {
+			return false, err
+		}
+		if !ok {
+			return false, nil
+		}
+		depHashes[dep] = h
+	}
+	if !sameHashes(depHashes, rec.Deps) {
+		return false, nil
+	}
+	h, ok, err := hashFile(e.ws.OutPath(l))
+	if err != nil {
+		return false, err
+	}
+	return ok && h == rec.Out, nil
+}
+
+// FormatPlan renders steps one per line: "run <label>" or "skip <label>".
+func FormatPlan(steps []Step) string {
+	var b strings.Builder
+	for _, s := range steps {
+		if s.Run {
+			b.WriteString("run ")
+		} else {
+			b.WriteString("skip ")
+		}
+		b.WriteString(s.Label)
+		b.WriteByte('\n')
+	}
+	return b.String()
+}
diff --git a/state.go b/state.go
new file mode 100644
index 0000000..b9d6171
--- /dev/null
+++ b/state.go
@@ -0,0 +1,93 @@
+package buildgraph
+
+import (
+	"crypto/sha256"
+	"encoding/hex"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io/fs"
+	"os"
+	"path/filepath"
+)
+
+// record captures the content hashes a target was last built against. A
+// target whose record still matches the tree is up to date.
+type record struct {
+	Inputs map[string]string `json:"inputs"` // declared input -> content hash
+	Deps   map[string]string `json:"deps"`   // dep label -> its output hash
+	Out    string            `json:"out"`    // own output hash
+}
+
+type stateDoc struct {
+	Targets map[string]record `json:"targets"`
+}
+
+// loadState reads out/state.json. Any problem — missing file, junk bytes —
+// just means "no prior state": the cost is a full rebuild, never an error.
+func loadState(path string) map[string]record {
+	raw, err := os.ReadFile(path)
+	if err != nil {
+		return map[string]record{}
+	}
+	var doc stateDoc
+	if err := json.Unmarshal(raw, &doc); err != nil || doc.Targets == nil {
+		return map[string]record{}
+	}
+	return doc.Targets
+}
+
+func saveState(path string, targets map[string]record) error {
+	if err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {
+		return err
+	}
+	raw, err := json.MarshalIndent(stateDoc{Targets: targets}, "", "  ")
+	if err != nil {
+		return err
+	}
+	return os.WriteFile(path, raw, 0o644)
+}
+
+// hashFile returns the content hash of path; ok is false when the file does
+// not exist (which is a freshness miss, not an error).
+func hashFile(path string) (hash string, ok bool, err error) {
+	raw, err := os.ReadFile(path)
+	if errors.Is(err, fs.ErrNotExist) {
+		return "", false, nil
+	}
+	if err != nil {
+		return "", false, err
+	}
+	sum := sha256.Sum256(raw)
+	return hex.EncodeToString(sum[:]), true, nil
+}
+
+// hashInputs hashes every declared input of t. A missing input is a hard
+// error naming the target and the path.
+func (w *Workspace) hashInputs(label string, t *Target) (map[string]string, error) {
+	hashes := make(map[string]string, len(t.Inputs))
+	for _, in := range t.Inputs {
+		p := w.inputPath(t, in)
+		h, ok, err := hashFile(p)
+		if err != nil {
+			return nil, fmt.Errorf("target %s: reading input %s: %w", label, p, err)
+		}
+		if !ok {
+			return nil, fmt.Errorf("target %s: missing input %s", label, p)
+		}
+		hashes[in] = h
+	}
+	return hashes, nil
+}
+
+func sameHashes(a, b map[string]string) bool {
+	if len(a) != len(b) {
+		return false
+	}
+	for k, v := range a {
+		if b[k] != v {
+			return false
+		}
+	}
+	return true
+}
diff --git a/workspace.go b/workspace.go
new file mode 100644
index 0000000..6e627c2
--- /dev/null
+++ b/workspace.go
@@ -0,0 +1,133 @@
+// Package buildgraph loads target graphs from build.json manifests and runs
+// them with content-hash incrementality and a bounded worker pool.
+package buildgraph
+
+import (
+	"io/fs"
+	"path/filepath"
+	"sort"
+	"strings"
+)
+
+// Target is one buildable unit declared in a manifest.
+type Target struct {
+	Name   string   // manifest-local name
+	Action string   // registered action that builds it
+	Inputs []string // source files, exactly as declared (package-relative)
+	Deps   []string // dependencies, canonicalized to full labels
+
+	pkg string // package this target belongs to ("" for the root)
+}
+
+// Workspace is a validated, acyclic target graph loaded from a source tree.
+type Workspace struct {
+	root    string
+	targets map[string]*Target
+	labels  []string // every label, sorted
+}
+
+// LoadWorkspace walks root for build.json manifests (skipping root's out/
+// directory, which holds build products), validates them, canonicalizes
+// dependency labels, and rejects unknown deps and cycles.
+func LoadWorkspace(root string) (*Workspace, error) {
+	abs, err := filepath.Abs(root)
+	if err != nil {
+		return nil, err
+	}
+	ws := &Workspace{root: abs, targets: map[string]*Target{}}
+	outDir := filepath.Join(abs, "out")
+	err = filepath.WalkDir(abs, func(p string, d fs.DirEntry, err error) error {
+		if err != nil {
+			return err
+		}
+		if d.IsDir() {
+			if p == outDir {
+				return filepath.SkipDir
+			}
+			return nil
+		}
+		if d.Name() != manifestName {
+			return nil
+		}
+		rel, err := filepath.Rel(abs, p)
+		if err != nil {
+			return err
+		}
+		return ws.addManifest(p, filepath.ToSlash(rel))
+	})
+	if err != nil {
+		return nil, err
+	}
+	for label := range ws.targets {
+		ws.labels = append(ws.labels, label)
+	}
+	sort.Strings(ws.labels)
+	if err := ws.checkDeps(); err != nil {
+		return nil, err
+	}
+	if err := ws.checkAcyclic(); err != nil {
+		return nil, err
+	}
+	return ws, nil
+}
+
+// addManifest reads one manifest (rel is root-relative, slash-separated) and
+// registers its targets.
+func (w *Workspace) addManifest(absPath, rel string) error {
+	m, err := readManifest(absPath, rel)
+	if err != nil {
+		return err
+	}
+	pkg := strings.TrimSuffix(rel, manifestName)
+	pkg = strings.TrimSuffix(pkg, "/")
+	for _, mt := range m.Targets {
+		t := &Target{Name: mt.Name, Action: mt.Action, Inputs: mt.Inputs, pkg: pkg}
+		seen := make(map[string]bool, len(mt.Deps))
+		for _, dep := range mt.Deps {
+			label := canonicalLabel(pkg, dep)
+			if !seen[label] {
+				seen[label] = true
+				t.Deps = append(t.Deps, label)
+			}
+		}
+		w.targets[pkg+":"+mt.Name] = t
+	}
+	return nil
+}
+
+// Targets returns every label in the workspace, sorted.
+func (w *Workspace) Targets() []string {
+	out := make([]string, len(w.labels))
+	copy(out, w.labels)
+	return out
+}
+
+// Target looks up one target by label.
+func (w *Workspace) Target(label string) (*Target, bool) {
+	t, ok := w.targets[label]
+	return t, ok
+}
+
+// OutPath is where label's build output lives: <root>/out/<package>/<name>.
+func (w *Workspace) OutPath(label string) string {
+	pkg, name := splitLabel(label)
+	return filepath.Join(w.root, "out", filepath.FromSlash(pkg), name)
+}
+
+func splitLabel(label string) (pkg, name string) {
+	i := strings.LastIndex(label, ":")
+	if i < 0 {
+		return "", label
+	}
+	return label[:i], label[i+1:]
+}
+
+// inputPath resolves one of t's declared inputs to an absolute path.
+func (w *Workspace) inputPath(t *Target, in string) string {
+	return filepath.Join(w.root, filepath.FromSlash(t.pkg), filepath.FromSlash(in))
+}
+
+// statePath is where Execute persists its incremental-build records.
+func (w *Workspace) statePath() string {
+	return filepath.Join(w.root, "out", "state.json")
+}
