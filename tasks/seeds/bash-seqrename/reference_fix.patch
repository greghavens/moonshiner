diff --git a/renum.sh b/renum.sh
new file mode 100644
index 0000000..28c2863
--- /dev/null
+++ b/renum.sh
@@ -0,0 +1,147 @@
+#!/usr/bin/env bash
+# renum.sh — renumber a scan batch into <prefix><NN>[.<ext>] names.
+# Usage: renum.sh [--dry-run] [--start N] [--width W] <dir> <prefix>
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  printf 'usage: renum.sh [--dry-run] [--start N] [--width W] <dir> <prefix>\n' >&2
+  exit 64
+}
+
+is_posint() {
+  case $1 in
+    ''|*[!0-9]*) return 1 ;;
+  esac
+  [ "$1" -ge 1 ]
+}
+
+dry=no
+start=1
+width=''
+pos=()
+
+while [ "$#" -gt 0 ]; do
+  case $1 in
+    --dry-run)
+      dry=yes
+      shift
+      ;;
+    --start)
+      [ "$#" -ge 2 ] || usage
+      is_posint "$2" || usage
+      start=$2
+      shift 2
+      ;;
+    --width)
+      [ "$#" -ge 2 ] || usage
+      is_posint "$2" || usage
+      width=$2
+      shift 2
+      ;;
+    --*)
+      usage
+      ;;
+    *)
+      pos+=("$1")
+      shift
+      ;;
+  esac
+done
+
+[ "${#pos[@]}" -eq 2 ] || usage
+dir=${pos[0]}
+prefix=${pos[1]}
+[ -n "$prefix" ] || usage
+[ -d "$dir" ] || { printf 'renum.sh: not a directory: %s\n' "$dir" >&2; exit 66; }
+
+# the batch: regular files directly in <dir>, dotfiles excluded,
+# C byte order (the glob is already sorted under LC_ALL=C)
+names=()
+for p in "$dir"/*; do
+  [ -f "$p" ] || continue
+  names+=("${p##*/}")
+done
+count=${#names[@]}
+if [ "$count" -eq 0 ]; then
+  printf 'renum.sh: no regular files in: %s\n' "$dir" >&2
+  exit 65
+fi
+
+last=$((start + count - 1))
+need=${#last}
+if [ -z "$width" ]; then
+  width=$need
+  [ "$width" -lt 2 ] && width=2
+elif [ "$width" -lt "$need" ]; then
+  printf 'renum.sh: --width too small: need %s digit(s)\n' "$need" >&2
+  exit 65
+fi
+
+in_batch() { # in_batch <name> -- is <name> one of the batch files?
+  local b
+  for b in "${names[@]}"; do
+    [ "$b" = "$1" ] && return 0
+  done
+  return 1
+}
+
+# plan first: compute every target, refuse conflicts before touching anything
+targets=()
+moves=0
+kept=0
+i=0
+for name in "${names[@]}"; do
+  num=$((start + i))
+  i=$((i + 1))
+  printf -v newname '%s%0*d' "$prefix" "$width" "$num"
+  case $name in
+    *.*) newname="$newname.${name##*.}" ;;
+  esac
+  targets+=("$newname")
+  if [ "$newname" = "$name" ]; then
+    kept=$((kept + 1))
+    continue
+  fi
+  moves=$((moves + 1))
+  if { [ -e "$dir/$newname" ] || [ -L "$dir/$newname" ]; } && ! in_batch "$newname"; then
+    printf 'renum.sh: target exists outside the batch: %s\n' "$newname" >&2
+    exit 65
+  fi
+done
+
+if [ "$dry" = yes ]; then
+  i=0
+  for name in "${names[@]}"; do
+    new=${targets[$i]}
+    i=$((i + 1))
+    [ "$new" = "$name" ] && continue
+    printf '%s -> %s\n' "$name" "$new"
+  done
+  printf 'plan: %s rename(s), %s unchanged\n' "$moves" "$kept"
+  exit 0
+fi
+
+# phase 1: park everything that moves under a temp name, so overlapping
+# old/new names can never clobber each other
+i=0
+for name in "${names[@]}"; do
+  new=${targets[$i]}
+  if [ "$new" != "$name" ]; then
+    mv -- "$dir/$name" "$dir/.renum-tmp.$$.$i"
+  fi
+  i=$((i + 1))
+done
+
+# phase 2: settle temp names onto their finals
+i=0
+for name in "${names[@]}"; do
+  new=${targets[$i]}
+  if [ "$new" != "$name" ]; then
+    mv -- "$dir/.renum-tmp.$$.$i" "$dir/$new"
+  fi
+  i=$((i + 1))
+done
+
+printf 'renamed: %s file(s), %s unchanged\n' "$moves" "$kept"
