index 0000000..ac25352
--- /dev/null
+++ b/sheet.ts
@@ -0,0 +1,141 @@
+import { expandRange, formatRef, normalizeRef, parseRef } from './refs.ts';
+import { parseFormula, type Arg, type Node } from './formula.ts';
+
+type Err = { error: '#CYCLE!' | '#DIV/0!' | '#VALUE!' };
+
+/** null = empty cell, string = text, number = number, Err = evaluation error. */
+type CellValue = number | string | null | Err;
+
+type CellContent =
+  | { kind: 'number'; value: number; raw: number | string }
+  | { kind: 'text'; value: string; raw: string }
+  | { kind: 'formula'; ast: Node; raw: string };
+
+function isErr(v: CellValue | number[]): v is Err {
+  return typeof v === 'object' && v !== null && 'error' in v;
+}
+
+export class Sheet {
+  private grid = new Map<string, CellContent>();
+
+  set(ref: string, input: string | number): void {
+    const key = normalizeRef(ref);
+    if (typeof input === 'number') {
+      this.grid.set(key, { kind: 'number', value: input, raw: input });
+      return;
+    }
+    if (input.startsWith('=')) {
+      const ast = parseFormula(input.slice(1)); // throws before the cell is touched
+      this.grid.set(key, { kind: 'formula', ast, raw: input });
+      return;
+    }
+    if (input === '') {
+      this.grid.delete(key);
+      return;
+    }
+    const trimmed = input.trim();
+    if (trimmed !== '' && Number.isFinite(Number(trimmed))) {
+      this.grid.set(key, { kind: 'number', value: Number(trimmed), raw: input });
+      return;
+    }
+    this.grid.set(key, { kind: 'text', value: input, raw: input });
+  }
+
+  get(ref: string): number | string {
+    const value = this.valueOf(normalizeRef(ref), new Set());
+    if (value === null) return '';
+    if (isErr(value)) return value.error;
+    return value;
+  }
+
+  raw(ref: string): number | string {
+    return this.grid.get(normalizeRef(ref))?.raw ?? '';
+  }
+
+  clear(ref: string): void {
+    this.grid.delete(normalizeRef(ref));
+  }
+
+  cells(): string[] {
+    return [...this.grid.keys()]
+      .map(parseRef)
+      .sort((a, b) => (a.row - b.row) || (a.col - b.col))
+      .map(formatRef);
+  }
+
+  /** Evaluate one cell; `visiting` carries the in-progress evaluation stack for cycle detection. */
+  private valueOf(key: string, visiting: Set<string>): CellValue {
+    const cell = this.grid.get(key);
+    if (!cell) return null;
+    if (cell.kind === 'number') return cell.value;
+    if (cell.kind === 'text') return cell.value;
+    if (visiting.has(key)) return { error: '#CYCLE!' };
+    visiting.add(key);
+    try {
+      return this.evalNode(cell.ast, visiting);
+    } finally {
+      visiting.delete(key);
+    }
+  }
+
+  /** Value of a directly referenced cell inside arithmetic: empty = 0, text = #VALUE!. */
+  private refOperand(key: string, visiting: Set<string>): number | Err {
+    const value = this.valueOf(key, visiting);
+    if (value === null) return 0;
+    if (typeof value === 'string') return { error: '#VALUE!' };
+    return value;
+  }
+
+  private evalNode(node: Node, visiting: Set<string>): number | Err {
+    switch (node.type) {
+      case 'num':
+        return node.value;
+      case 'ref':
+        return this.refOperand(node.ref, visiting);
+      case 'neg': {
+        const operand = this.evalNode(node.operand, visiting);
+        return isErr(operand) ? operand : -operand;
+      }
+      case 'bin': {
+        const left = this.evalNode(node.left, visiting);
+        if (isErr(left)) return left;
+        const right = this.evalNode(node.right, visiting);
+        if (isErr(right)) return right;
+        switch (node.op) {
+          case '+': return left + right;
+          case '-': return left - right;
+          case '*': return left * right;
+          case '/': return right === 0 ? { error: '#DIV/0!' } : left / right;
+        }
+      }
+      case 'call': {
+        const collected = this.collectArgs(node.args, visiting);
+        if (isErr(collected)) return collected;
+        if (node.fn === 'SUM') {
+          return collected.reduce((s, v) => s + v, 0);
+        }
+        if (collected.length === 0) return { error: '#DIV/0!' };
+        return collected.reduce((s, v) => s + v, 0) / collected.length;
+      }
+    }
+  }
+
+  /** Flatten function arguments to numbers. Ranges skip text/empty cells but surface errors. */
+  private collectArgs(args: Arg[], visiting: Set<string>): number[] | Err {
+    const values: number[] = [];
+    for (const arg of args) {
+      if ('type' in arg && arg.type === 'range') {
+        for (const ref of expandRange(`${arg.from}:${arg.to}`)) {
+          const value = this.valueOf(ref, visiting);
+          if (isErr(value)) return value;
+          if (typeof value === 'number') values.push(value);
+        }
+      } else {
+        const value = this.evalNode(arg as Node, visiting);
+        if (isErr(value)) return value;
+        values.push(value);
+      }
+    }
+    return values;
+  }
+}
