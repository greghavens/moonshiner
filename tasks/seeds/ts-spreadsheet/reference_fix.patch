+// Recursive-descent parser for the formula language:
+//   expr   := term (('+'|'-') term)*
+//   term   := unary (('*'|'/') unary)*
+//   unary  := '-' unary | primary
+//   primary:= number | ref | func '(' arg (',' arg)* ')' | '(' expr ')'
+//   arg    := ref ':' ref | expr
+// Ranges are only legal as function arguments.
+
+import { normalizeRef } from './refs.ts';
+
+export type Node =
+  | { type: 'num'; value: number }
+  | { type: 'ref'; ref: string }
+  | { type: 'neg'; operand: Node }
+  | { type: 'bin'; op: '+' | '-' | '*' | '/'; left: Node; right: Node }
+  | { type: 'call'; fn: 'SUM' | 'AVG'; args: Arg[] };
+
+export type Arg = Node | { type: 'range'; from: string; to: string };
+
+type Token =
+  | { kind: 'num'; value: number }
+  | { kind: 'ident'; text: string }
+  | { kind: 'op'; text: string };
+
+const FUNCTIONS = new Set(['SUM', 'AVG']);
+
+function tokenize(src: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  while (i < src.length) {
+    const ch = src[i];
+    if (/\s/.test(ch)) { i++; continue; }
+    if (/[0-9]/.test(ch)) {
+      let j = i;
+      while (j < src.length && /[0-9.]/.test(src[j])) j++;
+      const text = src.slice(i, j);
+      const value = Number(text);
+      if (!Number.isFinite(value)) throw new SyntaxError(`bad number "${text}" in formula`);
+      tokens.push({ kind: 'num', value });
+      i = j;
+      continue;
+    }
+    if (/[A-Za-z]/.test(ch)) {
+      let j = i;
+      while (j < src.length && /[A-Za-z0-9]/.test(src[j])) j++;
+      tokens.push({ kind: 'ident', text: src.slice(i, j) });
+      i = j;
+      continue;
+    }
+    if ('+-*/(),:'.includes(ch)) {
+      tokens.push({ kind: 'op', text: ch });
+      i++;
+      continue;
+    }
+    throw new SyntaxError(`unexpected character "${ch}" in formula`);
+  }
+  return tokens;
+}
+
+class Parser {
+  private pos = 0;
+  private tokens: Token[];
+
+  constructor(tokens: Token[]) {
+    this.tokens = tokens;
+  }
+
+  parse(): Node {
+    const node = this.expr();
+    if (this.pos !== this.tokens.length) {
+      throw new SyntaxError(`unexpected trailing input in formula`);
+    }
+    return node;
+  }
+
+  private peek(): Token | undefined {
+    return this.tokens[this.pos];
+  }
+
+  private takeOp(text: string): boolean {
+    const t = this.peek();
+    if (t && t.kind === 'op' && t.text === text) {
+      this.pos++;
+      return true;
+    }
+    return false;
+  }
+
+  private expr(): Node {
+    let left = this.term();
+    for (;;) {
+      if (this.takeOp('+')) left = { type: 'bin', op: '+', left, right: this.term() };
+      else if (this.takeOp('-')) left = { type: 'bin', op: '-', left, right: this.term() };
+      else return left;
+    }
+  }
+
+  private term(): Node {
+    let left = this.unary();
+    for (;;) {
+      if (this.takeOp('*')) left = { type: 'bin', op: '*', left, right: this.unary() };
+      else if (this.takeOp('/')) left = { type: 'bin', op: '/', left, right: this.unary() };
+      else return left;
+    }
+  }
+
+  private unary(): Node {
+    if (this.takeOp('-')) return { type: 'neg', operand: this.unary() };
+    return this.primary();
+  }
+
+  private primary(): Node {
+    const t = this.peek();
+    if (!t) throw new SyntaxError('formula ended unexpectedly');
+    if (t.kind === 'num') {
+      this.pos++;
+      return { type: 'num', value: t.value };
+    }
+    if (t.kind === 'ident') {
+      this.pos++;
+      if (/^[A-Za-z]+[0-9]+$/.test(t.text)) {
+        return { type: 'ref', ref: normalizeRef(t.text) };
+      }
+      const fn = t.text.toUpperCase();
+      if (!FUNCTIONS.has(fn)) throw new SyntaxError(`unknown function ${t.text}`);
+      if (!this.takeOp('(')) throw new SyntaxError(`expected ( after ${t.text}`);
+      const args: Arg[] = [this.arg()];
+      while (this.takeOp(',')) args.push(this.arg());
+      if (!this.takeOp(')')) throw new SyntaxError(`unclosed argument list for ${t.text}`);
+      return { type: 'call', fn: fn as 'SUM' | 'AVG', args };
+    }
+    if (t.kind === 'op' && t.text === '(') {
+      this.pos++;
+      const inner = this.expr();
+      if (!this.takeOp(')')) throw new SyntaxError('unclosed parenthesis in formula');
+      return inner;
+    }
+    throw new SyntaxError(`unexpected "${t.kind === 'op' ? t.text : ''}" in formula`);
+  }
+
+  private arg(): Arg {
+    const t = this.peek();
+    const next = this.tokens[this.pos + 1];
+    if (
+      t && t.kind === 'ident' && /^[A-Za-z]+[0-9]+$/.test(t.text) &&
+      next && next.kind === 'op' && next.text === ':'
+    ) {
+      this.pos += 2;
+      const end = this.peek();
+      if (!end || end.kind !== 'ident' || !/^[A-Za-z]+[0-9]+$/.test(end.text)) {
+        throw new SyntaxError('expected a cell reference after : in range');
+      }
+      this.pos++;
+      return { type: 'range', from: normalizeRef(t.text), to: normalizeRef(end.text) };
+    }
+    return this.expr();
+  }
+}
+
+export function parseFormula(src: string): Node {
+  return new Parser(tokenize(src)).parse();
+}
