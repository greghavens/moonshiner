+export type CellCoord = { col: number; row: number };
+
+const REF_RE = /^([A-Za-z]+)([0-9]+)$/;
+
+export function parseRef(ref: string): CellCoord {
+  const m = typeof ref === 'string' ? ref.match(REF_RE) : null;
+  if (!m) throw new SyntaxError(`invalid cell reference "${ref}"`);
+  let col = 0;
+  for (const ch of m[1].toUpperCase()) {
+    col = col * 26 + (ch.charCodeAt(0) - 64); // A=1 .. Z=26
+  }
+  const row = Number(m[2]);
+  if (row < 1) throw new SyntaxError(`invalid cell reference "${ref}"`);
+  return { col, row };
+}
+
+export function formatRef(coord: CellCoord): string {
+  const { col, row } = coord;
+  if (!Number.isInteger(col) || col < 1 || !Number.isInteger(row) || row < 1) {
+    throw new RangeError(`invalid coordinates col=${col} row=${row}`);
+  }
+  let letters = '';
+  let c = col;
+  while (c > 0) {
+    const rem = (c - 1) % 26;
+    letters = String.fromCharCode(65 + rem) + letters;
+    c = Math.floor((c - 1) / 26);
+  }
+  return `${letters}${row}`;
+}
+
+/** Normalize a ref to canonical uppercase form. */
+export function normalizeRef(ref: string): string {
+  return formatRef(parseRef(ref));
+}
+
+export function expandRange(range: string): string[] {
+  const parts = typeof range === 'string' ? range.split(':') : [];
+  if (parts.length !== 2) throw new SyntaxError(`invalid range "${range}"`);
+  const a = parseRef(parts[0]);
+  const b = parseRef(parts[1]);
+  const top = Math.min(a.row, b.row);
+  const bottom = Math.max(a.row, b.row);
+  const left = Math.min(a.col, b.col);
+  const right = Math.max(a.col, b.col);
+  const refs: string[] = [];
+  for (let row = top; row <= bottom; row++) {
+    for (let col = left; col <= right; col++) {
+      refs.push(formatRef({ col, row }));
+    }
+  }
+  return refs;
+}
