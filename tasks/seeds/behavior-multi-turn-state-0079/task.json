{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0079",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "public-services",
  "prompt": "Find the application “Residential Parking Permit” at Central Service Center and report its stable ID, current date, location, and status. Do not make any changes yet. Include the stable record ID whenever you report or confirm a date.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same application to West Service Center and set its date to 2026-10-15. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-19. Keep it at West Service Center; do not revert any other field."
    }
  ],
  "available_tools": [
    "public-services_search",
    "public-services_get",
    "public-services_list",
    "public-services_update",
    "public-services_cancel",
    "public-services_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "pub-179",
        "name": "Residential Parking Permit",
        "location": "Central Service Center",
        "date": "2026-08-12",
        "status": "active"
      },
      {
        "id": "pub-579",
        "name": "Visitor Parking Permit",
        "location": "West Service Center",
        "date": "2026-09-19",
        "status": "active"
      },
      {
        "id": "pub-879",
        "name": "Residential Parking Permit",
        "location": "South District Office",
        "date": "2026-09-19",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_search",
            "arguments": {
              "query": "Residential Parking Permit",
              "location": "Central Service Center"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-179",
              "date": "2026-10-15",
              "location": "West Service Center"
            }
          }
        ],
        "purpose": "Apply the requested date and location together to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-179",
              "date": "2026-11-19"
            }
          }
        ],
        "purpose": "Correct only the date while retaining the location set by the preceding update."
      }
    ],
    "state_assertions": [
      "pub-179.date == 2026-11-19",
      "pub-179.location == West Service Center",
      "pub-179.status == active",
      "pub-579.date == 2026-09-19",
      "pub-879.date == 2026-09-19",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "public-services_notify",
      "public-services_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Include the stable record ID whenever you report or confirm a date.",
      "The final date-only update must retain the location established by the preceding turn.",
      "Do not modify either distractor."
    ]
  },
  "training_tags": [
