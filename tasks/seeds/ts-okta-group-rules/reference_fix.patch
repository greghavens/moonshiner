index 0000000..5ef9bb2
--- /dev/null
+++ b/okta/reconcile.ts
@@ -0,0 +1,134 @@
+// Desired-state reconciler for Okta group rules.
+//
+// The wire contract forces a specific choreography (see docs/contract.json):
+// rules are created INACTIVE, PUT only works on INACTIVE rules and cannot
+// touch the actions section, and status moves exclusively through the
+// lifecycle endpoints. Assignment (actions) changes therefore require a
+// delete + recreate. Specs using anything the current API reference doesn't
+// support are rejected before any traffic is generated.
+
+import type { GroupRule, GroupRulesClient } from "./client.ts";
+
+export const EXPRESSION_TYPE = "urn:okta:expression:1.0";
+
+export interface ReconcileReport {
+  created: string[];
+  updated: string[];
+  recreated: string[];
+  statusChanged: string[];
+  unchanged: string[];
+  rejected: { name: string; reason: string }[];
+}
+
+function validate(spec: GroupRule): string | null {
+  const exprType = spec.conditions.expression.type;
+  if (exprType !== undefined && exprType !== EXPRESSION_TYPE) {
+    return `conditions.expression.type must be ${EXPRESSION_TYPE} (got ${exprType})`;
+  }
+  const groupsExclude = spec.conditions.people?.groups?.exclude;
+  if (groupsExclude !== undefined && groupsExclude.length > 0) {
+    return "conditions.people.groups.exclude is not supported by the current Group Rules API";
+  }
+  if (spec.status !== "ACTIVE" && spec.status !== "INACTIVE") {
+    return `status must be ACTIVE or INACTIVE (got ${spec.status})`;
+  }
+  return null;
+}
+
+function sameIdSet(a: string[], b: string[]): boolean {
+  if (a.length !== b.length) return false;
+  const set = new Set(a);
+  return b.every((id) => set.has(id));
+}
+
+function sameExpression(current: GroupRule, spec: GroupRule): boolean {
+  const cur = current.conditions.expression;
+  const want = spec.conditions.expression;
+  return cur.value === want.value && (cur.type ?? EXPRESSION_TYPE) === (want.type ?? EXPRESSION_TYPE);
+}
+
+/** The writable projection of a rule: everything server-owned stripped. */
+function writableBody(spec: GroupRule, actions: GroupRule["actions"]): GroupRule {
+  return {
+    type: "group_rule",
+    name: spec.name,
+    conditions: spec.conditions,
+    actions,
+  };
+}
+
+async function createAndMaybeActivate(
+  client: GroupRulesClient,
+  spec: GroupRule,
+): Promise<void> {
+  const created = await client.createRule(writableBody(spec, spec.actions));
+  if (spec.status === "ACTIVE") await client.activateRule(created.id!);
+}
+
+export async function reconcileGroupRules(
+  client: GroupRulesClient,
+  desired: GroupRule[],
+): Promise<ReconcileReport> {
+  const report: ReconcileReport = {
+    created: [],
+    updated: [],
+    recreated: [],
+    statusChanged: [],
+    unchanged: [],
+    rejected: [],
+  };
+
+  const existing = new Map<string, GroupRule>();
+  for (const rule of await client.listAllRules()) existing.set(rule.name, rule);
+
+  for (const spec of desired) {
+    const problem = validate(spec);
+    if (problem !== null) {
+      report.rejected.push({ name: spec.name, reason: problem });
+      continue;
+    }
+
+    const current = existing.get(spec.name);
+    if (current === undefined) {
+      await createAndMaybeActivate(client, spec);
+      report.created.push(spec.name);
+      continue;
+    }
+
+    const actionsMatch = sameIdSet(
+      current.actions.assignUserToGroups.groupIds,
+      spec.actions.assignUserToGroups.groupIds,
+    );
+    const expressionMatches = sameExpression(current, spec);
+    const statusMatches = current.status === spec.status;
+
+    if (!actionsMatch) {
+      // Actions can't be edited through PUT; replace the rule wholesale.
+      if (current.status === "ACTIVE") await client.deactivateRule(current.id!);
+      await client.deleteRule(current.id!);
+      await createAndMaybeActivate(client, spec);
+      report.recreated.push(spec.name);
+      continue;
+    }
+
+    if (!expressionMatches) {
+      // PUT is INACTIVE-only and must carry the actions section unchanged.
+      if (current.status === "ACTIVE") await client.deactivateRule(current.id!);
+      await client.replaceRule(current.id!, writableBody(spec, current.actions));
+      if (spec.status === "ACTIVE") await client.activateRule(current.id!);
+      report.updated.push(spec.name);
+      continue;
+    }
+
+    if (!statusMatches) {
+      if (spec.status === "ACTIVE") await client.activateRule(current.id!);
+      else await client.deactivateRule(current.id!);
+      report.statusChanged.push(spec.name);
+      continue;
+    }
+
+    report.unchanged.push(spec.name);
+  }
+
+  return report;
+}
