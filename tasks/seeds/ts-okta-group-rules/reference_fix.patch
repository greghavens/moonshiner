+    return json as GroupRule;
+  }
+
+  /** PUT /api/v1/groups/rules/{id} — only legal while the rule is INACTIVE. */
+  async replaceRule(ruleId: string, rule: GroupRule): Promise<GroupRule> {
+    const { json } = await this.request("PUT", `/api/v1/groups/rules/${encodeURIComponent(ruleId)}`, rule);
+    return json as GroupRule;
+  }
+
+  async deleteRule(ruleId: string): Promise<void> {
