+/** Extracts the rel="next" href from a (possibly comma-combined) Link header. */
+export function nextLinkOf(linkHeader: string | null): string | null {
+  if (linkHeader === null) return null;
+  for (const segment of linkHeader.split(",")) {
+    const open = segment.indexOf("<");
+    const close = segment.indexOf(">");
+    if (open < 0 || close < open) continue;
+    if (/rel="next"/i.test(segment.slice(close + 1))) return segment.slice(open + 1, close);
+  }
+  return null;
+}
