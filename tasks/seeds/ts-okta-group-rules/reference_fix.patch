+
+  /**
+   * Every group rule in the org. Follows the Link rel="next" URLs verbatim,
+   * per the Core API pagination contract — the server owns the cursor and
+   * query format, so rebuilding URLs client-side is off the table.
+   */
+  async listAllRules(limit = 50): Promise<GroupRule[]> {
+    const rules: GroupRule[] = [];
+    let { json, headers } = await this.request("GET", `/api/v1/groups/rules?limit=${limit}`);
+    rules.push(...(json as GroupRule[]));
+    let next = nextLinkOf(headers.get("link"));
+    while (next !== null) {
+      ({ json, headers } = await this.request("GET", next));
+      rules.push(...(json as GroupRule[]));
+      next = nextLinkOf(headers.get("link"));
+    }
+    return rules;
+  }
+
+  /** POST /api/v1/groups/rules — the rule is created INACTIVE. */
+  async createRule(rule: GroupRule): Promise<GroupRule> {
