diff --git a/logtop.sh b/logtop.sh
new file mode 100644
index 0000000..371daf0
--- /dev/null
+++ b/logtop.sh
@@ -0,0 +1,87 @@
+#!/usr/bin/env bash
+# logtop.sh — summarize an edge access feed: status classes + busiest paths.
+#
+# usage: logtop.sh [--from TS] [--to TS] [--top N] <logfile>
+#
+# Feed format (guaranteed by the collector): one request per line,
+#   <ts> <method> <path> <status> <bytes>
+# five fields, single spaces, integer logical ts, status always 2xx-5xx.
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo 'usage: logtop.sh [--from TS] [--to TS] [--top N] <logfile>' >&2
+  exit 64
+}
+
+from=''
+to=''
+top=3
+log=''
+
+while [ "$#" -gt 0 ]; do
+  case $1 in
+    --from)
+      [ "$#" -ge 2 ] || usage
+      from=$2
+      shift 2
+      ;;
+    --to)
+      [ "$#" -ge 2 ] || usage
+      to=$2
+      shift 2
+      ;;
+    --top)
+      [ "$#" -ge 2 ] || usage
+      top=$2
+      shift 2
+      ;;
+    --*)
+      usage
+      ;;
+    *)
+      [ -n "$log" ] && usage
+      log=$1
+      shift
+      ;;
+  esac
+done
+
+[ -n "$log" ] || usage
+case $top in
+  *[!0-9]* | '' | 0) usage ;;
+esac
+
+if [ ! -f "$log" ] || [ ! -r "$log" ]; then
+  echo "logtop.sh: cannot read: $log" >&2
+  exit 66
+fi
+
+# Status-class rollup over the selected window.
+awk -v from="$from" -v to="$to" '
+  (from != "" && $1 + 0 < from + 0) { next }
+  (to   != "" && $1 + 0 > to   + 0) { next }
+  { class[substr($4, 1, 1)]++ }
+  END {
+    print "CLASSES"
+    printf "2xx\t%d\n", class["2"] + 0
+    printf "3xx\t%d\n", class["3"] + 0
+    printf "4xx\t%d\n", class["4"] + 0
+    printf "5xx\t%d\n", class["5"] + 0
+  }
+' "$log"
+
+# Busiest paths: hits descending, ties by path ascending (C byte order).
+echo 'TOP PATHS'
+awk -v from="$from" -v to="$to" '
+  (from != "" && $1 + 0 < from + 0) { next }
+  (to   != "" && $1 + 0 > to   + 0) { next }
+  { hits[$3]++ }
+  END {
+    for (p in hits) printf "%d\t%s\n", hits[p], p
+  }
+' "$log" |
+  sort -t "$(printf '\t')" -k1,1nr -k2,2 |
+  head -n "$top" |
+  awk -F '\t' '{ printf "%s\t%s\n", $2, $1 }'
