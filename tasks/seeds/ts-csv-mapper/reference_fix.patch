+const BOOLEAN_WORDS: Record<string, boolean> = {
+  true: true,
+  yes: true,
+  '1': true,
+  false: false,
+  no: false,
+  '0': false,
+};
+
+function coerce(raw: string, type: ColumnType): { ok: true; value: unknown } | { ok: false; message: string } {
+  const trimmed = raw.trim();
+  switch (type) {
+    case 'number': {
+      const value = Number(trimmed);
+      if (trimmed === '' || !Number.isFinite(value)) {
+        return { ok: false, message: `"${raw}" is not a number` };
+      }
+      return { ok: true, value };
+    }
+    case 'boolean': {
+      const value = BOOLEAN_WORDS[trimmed.toLowerCase()];
+      if (value === undefined) {
+        return { ok: false, message: `"${raw}" is not a boolean` };
+      }
+      return { ok: true, value };
+    }
+    case 'date': {
+      if (!/^\d{4}-\d{2}-\d{2}$/.test(trimmed)) {
+        return { ok: false, message: `"${raw}" is not a YYYY-MM-DD date` };
+      }
+      const value = new Date(trimmed);
+      if (Number.isNaN(value.getTime()) || value.toISOString().slice(0, 10) !== trimmed) {
+        return { ok: false, message: `"${raw}" is not a real calendar date` };
+      }
+      return { ok: true, value };
+    }
+  }
+}
+
+export function mapRowsSafe(rows: string[][], specs: ColumnSpec[]): SafeResult {
+  if (rows.length === 0) throw new Error('missing header row');
+  const indices = resolveColumns(rows[0], specs);
+
+  const result: SafeResult = { rows: [], errors: [] };
+  for (let r = 1; r < rows.length; r++) {
+    const row = rows[r];
+    const line = r + 1;
+    const record: Record<string, unknown> = {};
+    const rowErrors: RowError[] = [];
+
+    for (let s = 0; s < specs.length; s++) {
+      const spec = specs[s];
+      const index = indices[s];
+      if (index === -1) continue;
+      const raw = row[index] ?? '';
+
+      if (raw.trim() === '') {
+        if (spec.required) {
+          rowErrors.push({ line, column: spec.header, message: `missing required value` });
+        } else if (spec.type === undefined) {
+          record[spec.key] = '';
+        }
+        continue;
+      }
+
+      if (spec.type === undefined) {
+        record[spec.key] = raw;
+        continue;
+      }
+      const coerced = coerce(raw, spec.type);
+      if (coerced.ok) {
+        record[spec.key] = coerced.value;
+      } else {
+        rowErrors.push({ line, column: spec.header, message: coerced.message });
+      }
+    }
+
+    if (rowErrors.length > 0) {
+      result.errors.push(...rowErrors);
+    } else {
+      result.rows.push(record);
+    }
+  }
+  return result;
+}
