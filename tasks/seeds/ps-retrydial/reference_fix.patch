new file mode 100644
index 0000000..decfed7
--- /dev/null
+++ b/retrydial.ps1
@@ -0,0 +1,42 @@
+# Shared retry helper for scripts that talk to the billing gateway.
+Set-StrictMode -Version Latest
+
+function Invoke-ResilientRequest {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][string]$Uri,
+        [Parameter(Mandatory)][int]$MaxAttempts,
+        [Parameter(Mandatory)][double]$BaseDelaySeconds,
+        [scriptblock]$SleepHook = { param($seconds) Start-Sleep -Seconds $seconds }
+    )
+
+    $retries = 0
+    while ($true) {
+        $resp = Invoke-WebRequest -Uri $Uri -Method Get -SkipHttpErrorCheck
+        $status = [int]$resp.StatusCode
+        $attempts = $retries + 1
+
+        if ($status -ge 200 -and $status -lt 300) {
+            return [pscustomobject]@{
+                Status   = $status
+                Attempts = $attempts
+                Body     = $resp.Content
+            }
+        }
+
+        $transient = ($status -ge 500) -or ($status -eq 429)
+        if (-not $transient) {
+            throw "retrydial: client error $status, not retrying"
+        }
+        if ($attempts -ge $MaxAttempts) {
+            throw "retrydial: gave up after $MaxAttempts attempts (last status $status)"
+        }
+
+        $retries++
+        $delay = $BaseDelaySeconds * [math]::Pow(2, $retries - 1)
+        if ($resp.Headers.ContainsKey('Retry-After')) {
+            $delay = [double][string]$resp.Headers['Retry-After'][0]
+        }
+        & $SleepHook $delay
+    }
+}
