+"""REST Proxy v2 consumer lifecycle: create, subscribe, fetch, commit, delete.
+
+Built on restproxy.Transport. Offsets are committed only after the batch
+handler succeeds, and the consumer instance is always deleted when it was
+created — on success, handler failure, proxy failure, and cancellation.
+See docs/contract.json for the pinned v2 contract.
+"""
+
+from restproxy import (RestProxyError, V2, V2_JSON_EMBEDDED, origin_of)
+
+
+class SessionResult:
+    def __init__(self):
+        self.outcome = None
+        self.failure = None
+        self.batches = []
+        self.committed = {}
+        self.deleted = False
+
+
+def _commit(transport, base, records, result):
+    latest = {}
+    for record in records:
+        key = (record["topic"], record["partition"])
+        offset = record["offset"]
+        if key not in latest or offset > latest[key]:
+            latest[key] = offset
+    offsets = [{"topic": t, "partition": p, "offset": o}
+               for (t, p), o in sorted(latest.items())]
+    transport.request("POST", base + "/offsets", body={"offsets": offsets},
+                      content_type=V2)
+    result.committed.update(latest)
+
+
+def run_session(transport, group, instance_name, topics, handler, *,
+                max_batches, timeout_ms=1000, max_bytes=65536,
+                cancelled=None):
+    result = SessionResult()
+    try:
+        created = transport.request(
+            "POST", f"/consumers/{group}",
+            body={"name": instance_name, "format": "json",
+                  "auto.offset.reset": "earliest",
+                  "auto.commit.enable": "false"},
+            content_type=V2)
+    except RestProxyError as err:
+        result.outcome = "PROXY_ERROR"
+        result.failure = str(err)
+        return result
+
+    instance_id = created.body["instance_id"]
+    base = created.body["base_uri"]
+    trusted_base = f"/consumers/{group}/instances/{instance_id}"
+    if origin_of(base) != transport.origin:
+        result.outcome = "PROXY_ERROR"
+        result.failure = "UNTRUSTED_BASE_URI"
+        base = trusted_base
+    else:
+        try:
+            transport.request("POST", base + "/subscription",
+                              body={"topics": list(topics)}, content_type=V2)
+            _consume_loop(transport, base, handler, result, max_batches,
+                          timeout_ms, max_bytes, cancelled)
+        except RestProxyError as err:
+            result.outcome = "PROXY_ERROR"
+            result.failure = str(err)
+
+    try:
+        deleted = transport.request("DELETE", base)
+        result.deleted = deleted.status == 204
+    except RestProxyError:
+        result.deleted = False
+    return result
+
+
+def _consume_loop(transport, base, handler, result, max_batches,
+                  timeout_ms, max_bytes, cancelled):
+    for _ in range(max_batches):
+        if cancelled is not None and cancelled():
+            result.outcome = "CANCELLED"
+            return
+        resp = transport.request(
+            "GET", f"{base}/records?timeout={timeout_ms}&max_bytes={max_bytes}",
+            accept=V2_JSON_EMBEDDED)
+        if 300 <= resp.status < 400:
+            result.outcome = "PROXY_ERROR"
+            result.failure = "REDIRECT_BLOCKED"
+            return
+        records = resp.body or []
+        if not records:
+            result.outcome = "COMPLETED"
+            return
+        try:
+            handler(records)
+        except Exception as err:  # the handler is caller code: contain it
+            result.outcome = "HANDLER_ERROR"
+            result.failure = str(err)
+            return
+        result.batches.append(records)
+        _commit(transport, base, records, result)
+    result.outcome = "COMPLETED"
