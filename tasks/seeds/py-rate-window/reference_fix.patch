+"""Per-key sliding-window hit counter with explicit timestamps."""
+
+import bisect
+
+
+class SlidingWindow:
+    def __init__(self, window):
+        if (not isinstance(window, (int, float)) or isinstance(window, bool)
+                or window <= 0):
+            raise ValueError("window must be a positive number: %r" % (window,))
+        self._window = window
+        self._hits = {}          # key -> sorted list of (timestamp, units)
+
+    def hit(self, key, at, count=1):
+        if not isinstance(key, str) or not key:
+            raise ValueError("key must be a non-empty string: %r" % (key,))
+        if not isinstance(count, int) or isinstance(count, bool) or count < 1:
+            raise ValueError("count must be a positive int: %r" % (count,))
+        records = self._hits.setdefault(key, [])
+        bisect.insort(records, (at, count))
+        return self.count(key, at)
+
+    def count(self, key, at):
+        records = self._hits.get(key, [])
+        floor = at - self._window
+        return sum(units for t, units in records if floor < t <= at)
+
+    def prune(self, at):
+        cutoff = at - self._window
+        dropped = 0
+        for key in list(self._hits):
+            records = self._hits[key]
+            keep = [(t, units) for t, units in records if t > cutoff]
+            dropped += sum(units for t, units in records if t <= cutoff)
+            if keep:
+                self._hits[key] = keep
+            else:
+                del self._hits[key]
+        return dropped
+
+    def tracked(self):
+        return sorted(self._hits)
+
+    def top(self, n, at):
+        totals = []
+        for key in self._hits:
+            units = self.count(key, at)
+            if units > 0:
+                totals.append((-units, key))
+        totals.sort()
+        return [(key, -neg) for neg, key in totals[:n]]
