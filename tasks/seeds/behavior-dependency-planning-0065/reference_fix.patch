--- /dev/null
+++ b/reference_driver.py
@@ -0,0 +1,138 @@
+#!/usr/bin/env python3
+"""Reference proof using the genuine case executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import shlex
+import subprocess
+import tempfile
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Mobile Check-In Failure", "Grove Clinics"),
+    ("Address Validation Rejection", "Harbor Books"),
+)
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Run one dependency phase as direct, overlapping shell children."""
+    if not commands:
+        return []
+    with tempfile.TemporaryDirectory(prefix="case-reference-") as directory:
+        output_paths = [
+            Path(directory) / f"result-{index}.json"
+            for index in range(len(commands))
+        ]
+        launches = [
+            f"{shlex.join(command)} > {shlex.quote(str(output_path))} & job_{index}=$!"
+            for index, (command, output_path) in enumerate(
+                zip(commands, output_paths, strict=True)
+            )
+        ]
+        waits = [
+            f'wait "$job_{index}"; status_{index}=$?'
+            for index in range(len(commands))
+        ]
+        check = " && ".join(
+            f'test "$status_{index}" -eq 0' for index in range(len(commands))
+        )
+        action = "; ".join(launches + waits + [check])
+        completed = subprocess.run(
+            ["/bin/bash", "-lc", action],
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+            check=False,
+            timeout=30,
+        )
+        if completed.returncode != 0:
+            raise RuntimeError(completed.stderr.strip() or "case phase failed")
+        payloads = [
+            json.loads(path.read_text(encoding="utf-8")) for path in output_paths
+        ]
+    if not all(isinstance(payload, dict) for payload in payloads):
+        raise RuntimeError("case phase returned invalid results")
+    return payloads
+
+
+def main() -> int:
+    subprocess.run(
+        ["./casectl", "--help"],
+        cwd=ROOT,
+        stdout=subprocess.DEVNULL,
+        check=True,
+    )
+    searches = run_phase(
+        [
+            ["./casectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        match = matches[0]
+        if not isinstance(match, dict):
+            continue
+        stable_id = match.get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./casectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    lines: list[str] = []
+    statuses: list[str | None] = []
+    for index, record in enumerate(retrieved):
+        requested_name, requested_location = TARGETS[index]
+        if record is None:
+            lines.append(
+                f"{requested_name} at {requested_location} [UNRESOLVED] is unresolved."
+            )
+            statuses.append(None)
+            continue
+        name = record.get("name")
+        location = record.get("location")
+        stable_id = record.get("id")
+        status = record.get("status")
+        if not all(
+            isinstance(value, str) and value
+            for value in (name, location, stable_id, status)
+        ):
+            raise RuntimeError("full record omitted a required value")
+        lines.append(
+            f"{name} at {location} [{stable_id}] has retrieved status {status}."
+        )
+        statuses.append(status)
+
+    if statuses[0] is None or statuses[1] is None:
+        lines.append("The status comparison is unavailable.")
+    elif statuses[0] == statuses[1]:
+        lines.append(f"The retrieved statuses match: {statuses[0]}.")
+    else:
+        lines.append(
+            f"The retrieved statuses differ: {statuses[0]} versus {statuses[1]}."
+        )
+    lines.append("No changes made.")
+
+    (ROOT / "case-audit.txt").write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
