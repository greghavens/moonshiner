+"""Inventory API — Flask application factory.
+
+Each create_app() call builds an independent app with its own in-memory
+item store; there is deliberately no module-level app object.
+"""
+from flask import Blueprint, Flask, current_app, jsonify, request
+
+api = Blueprint("api", __name__)
+
+
+def _store():
+    return current_app.extensions["inventory_store"]
+
+
+@api.get("/items")
+def list_items():
+    store = _store()
+    items = sorted(store["items"].values(), key=lambda item: item["id"])
+    return jsonify({"items": items})
+
+
+@api.post("/items")
+def create_item():
+    data = request.get_json(silent=True)
+    name = data.get("name") if isinstance(data, dict) else None
+    if not isinstance(name, str) or not name.strip():
+        return jsonify({"error": "name is required"}), 400
+    store = _store()
+    item = {"id": store["next_id"], "name": name}
+    store["items"][item["id"]] = item
+    store["next_id"] += 1
+    return jsonify(item), 201
+
+
+@api.get("/items/<int:item_id>")
+def get_item(item_id):
+    item = _store()["items"].get(item_id)
+    if item is None:
+        return jsonify({"error": "not found"}), 404
+    return jsonify(item)
+
+
+def create_app():
+    flask_app = Flask(__name__)
+    flask_app.extensions["inventory_store"] = {"items": {}, "next_id": 1}
+    flask_app.register_blueprint(api, url_prefix="/api")
+
+    @flask_app.errorhandler(404)
+    def not_found(exc):
+        return jsonify({"error": "not found"}), 404
+
+    @flask_app.errorhandler(405)
+    def method_not_allowed(exc):
+        return jsonify({"error": "method not allowed"}), 405
+
+    return flask_app
