 /// The "1+9"-style dilution label the bottles are marked with.
-fn dilution(batch: &Batch) -> String {
+pub fn dilution(batch: &Batch) -> String {
     let d = gcd(batch.stock_ml.max(1), batch.water_ml.max(1));
