diff --git a/minesolver.c b/minesolver.c
new file mode 100644
index 0000000..5da2cc3
--- /dev/null
+++ b/minesolver.c
@@ -0,0 +1,156 @@
+#include "minesolver.h"
+
+#include <string.h>
+
+#define MAXDIM 16
+#define MAXCELLS (MAXDIM * MAXDIM)
+
+/* one constraint per digit cell: `need` mines among the cells in `mask` */
+typedef struct {
+    int need;
+    unsigned char mask[MAXCELLS]; /* 1 = still-undecided member cell */
+    int size;
+} constraint;
+
+typedef struct {
+    constraint cons[MAXCELLS];
+    int ncons;
+    unsigned char mine[MAXCELLS]; /* deduced this run */
+    unsigned char safe[MAXCELLS];
+} solver;
+
+static int con_contradicts(const constraint *c) {
+    return c->need < 0 || c->need > c->size;
+}
+
+static void mark_mine(solver *sv, int cell) {
+    if (sv->mine[cell]) return;
+    sv->mine[cell] = 1;
+    for (int i = 0; i < sv->ncons; i++) {
+        constraint *c = &sv->cons[i];
+        if (c->mask[cell]) {
+            c->mask[cell] = 0;
+            c->size--;
+            c->need--;
+        }
+    }
+}
+
+static void mark_safe(solver *sv, int cell) {
+    if (sv->safe[cell]) return;
+    sv->safe[cell] = 1;
+    for (int i = 0; i < sv->ncons; i++) {
+        constraint *c = &sv->cons[i];
+        if (c->mask[cell]) {
+            c->mask[cell] = 0;
+            c->size--;
+        }
+    }
+}
+
+/* is a's undecided set a proper subset of b's? */
+static int proper_subset(const constraint *a, const constraint *b, int ncells) {
+    if (a->size == 0 || a->size >= b->size) return 0;
+    for (int i = 0; i < ncells; i++)
+        if (a->mask[i] && !b->mask[i]) return 0;
+    return 1;
+}
+
+int mines_solve(const char *const *rows, int nrows, int ncols,
+                int *mines_out, int *nmines,
+                int *safe_out, int *nsafe) {
+    if (!rows || !mines_out || !nmines || !safe_out || !nsafe) return -1;
+    if (nrows < 1 || nrows > MAXDIM || ncols < 1 || ncols > MAXDIM) return -1;
+    for (int r = 0; r < nrows; r++) {
+        if (!rows[r] || strlen(rows[r]) != (size_t)ncols) return -1;
+        for (int c = 0; c < ncols; c++) {
+            char ch = rows[r][c];
+            if (ch != '?' && ch != 'M' && (ch < '0' || ch > '8')) return -1;
+        }
+    }
+
+    static solver sv;
+    memset(&sv, 0, sizeof sv);
+    int ncells = nrows * ncols;
+
+    for (int r = 0; r < nrows; r++) {
+        for (int c = 0; c < ncols; c++) {
+            char ch = rows[r][c];
+            if (ch < '0' || ch > '8') continue;
+            constraint *con = &sv.cons[sv.ncons];
+            con->need = ch - '0';
+            con->size = 0;
+            for (int dr = -1; dr <= 1; dr++) {
+                for (int dc = -1; dc <= 1; dc++) {
+                    if (!dr && !dc) continue;
+                    int nr = r + dr, nc = c + dc;
+                    if (nr < 0 || nr >= nrows || nc < 0 || nc >= ncols)
+                        continue;
+                    char nch = rows[nr][nc];
+                    if (nch == 'M') {
+                        con->need--;
+                    } else if (nch == '?') {
+                        con->mask[nr * ncols + nc] = 1;
+                        con->size++;
+                    }
+                }
+            }
+            sv.ncons++;
+        }
+    }
+
+    int changed = 1;
+    while (changed) {
+        for (int i = 0; i < sv.ncons; i++)
+            if (con_contradicts(&sv.cons[i])) return -1;
+        changed = 0;
+
+        /* single-square rule */
+        for (int i = 0; i < sv.ncons; i++) {
+            constraint *c = &sv.cons[i];
+            if (c->size == 0) continue;
+            if (c->need == 0) {
+                for (int j = 0; j < ncells; j++)
+                    if (c->mask[j]) { mark_safe(&sv, j); changed = 1; }
+            } else if (c->need == c->size) {
+                for (int j = 0; j < ncells; j++)
+                    if (c->mask[j]) { mark_mine(&sv, j); changed = 1; }
+            }
+        }
+
+        /* subset rule */
+        for (int a = 0; a < sv.ncons; a++) {
+            for (int b = 0; b < sv.ncons; b++) {
+                if (a == b) continue;
+                constraint *ca = &sv.cons[a], *cb = &sv.cons[b];
+                if (!proper_subset(ca, cb, ncells)) continue;
+                int diff = cb->size - ca->size;
+                int extra = cb->need - ca->need;
+                if (extra == diff) {
+                    for (int j = 0; j < ncells; j++)
+                        if (cb->mask[j] && !ca->mask[j]) {
+                            mark_mine(&sv, j);
+                            changed = 1;
+                        }
+                } else if (extra == 0) {
+                    for (int j = 0; j < ncells; j++)
+                        if (cb->mask[j] && !ca->mask[j]) {
+                            mark_safe(&sv, j);
+                            changed = 1;
+                        }
+                }
+            }
+        }
+    }
+    for (int i = 0; i < sv.ncons; i++)
+        if (con_contradicts(&sv.cons[i])) return -1;
+
+    int nm = 0, ns = 0;
+    for (int j = 0; j < ncells; j++) {
+        if (sv.mine[j]) mines_out[nm++] = j;
+        if (sv.safe[j]) safe_out[ns++] = j;
+    }
+    *nmines = nm;
+    *nsafe = ns;
+    return 0;
+}
