+// Stable block-id scheme. Resume only works when every run generates the
+// identical ids, and the service requires every id of a blob to be valid
+// base64 of the same pre-encoded length (max 64 bytes before encoding).
+export function makeBlockId(index: number): string {
+  const raw = `block-${String(index).padStart(8, "0")}`;
+  return Buffer.from(raw, "utf8").toString("base64");
+}
