+// Minimal XML helpers for the three payloads this integration touches.
+
+export function blockListXml(ids: string[]): string {
+  const entries = ids.map((id) => `<Latest>${id}</Latest>`).join("");
+  return `<?xml version="1.0" encoding="utf-8"?><BlockList>${entries}</BlockList>`;
+}
+
+export function parseErrorCode(xml: string): string {
+  const match = /<Code>([^<]+)<\/Code>/.exec(xml);
+  return match === null ? "" : match[1];
+}
+
+export interface ListedBlock {
+  name: string;
+  size: number;
+}
+
+export function parseUncommittedBlocks(xml: string): ListedBlock[] {
+  const section = /<UncommittedBlocks>([\s\S]*?)<\/UncommittedBlocks>/.exec(xml);
+  if (section === null) return [];
+  const blocks: ListedBlock[] = [];
+  for (const match of section[1].matchAll(/<Block><Name>([^<]+)<\/Name><Size>(\d+)<\/Size><\/Block>/g)) {
+    blocks.push({ name: match[1], size: Number(match[2]) });
+  }
+  return blocks;
+}
