+export type ShapeHandlers<T> = {
+  rect: (s: Rect) => T;
+  circle: (s: Circle) => T;
+  segment: (s: Segment) => T;
+  label: (s: Label) => T;
+};
+
+// Exhaustive dispatch on the discriminant. The compiler forces a handler
+// per kind; the default path rejects anything that sneaks past the types
+// at runtime (deserialized junk, messages from stale workers).
+export function matchShape<T>(shape: Shape, handlers: ShapeHandlers<T>): T {
+  switch (shape.kind) {
+    case 'rect':
+      return handlers.rect(shape);
+    case 'circle':
+      return handlers.circle(shape);
+    case 'segment':
+      return handlers.segment(shape);
+    case 'label':
+      return handlers.label(shape);
+    default: {
+      const impossible: never = shape;
+      throw new Error(`unknown shape kind: ${(impossible as any).kind}`);
+    }
   }
 }
 
+export function area(s: Shape): number {
+  return matchShape(s, {
+    rect: (r) => r.width * r.height,
+    circle: (c) => Math.PI * c.r * c.r,
+    segment: () => 0,
+    label: () => 0,
+  });
+}
+
+export function bounds(s: Shape): Box {
+  return matchShape<Box>(s, {
+    rect: (r) => ({ x: r.x, y: r.y, width: r.width, height: r.height }),
+    circle: (c) => ({ x: c.cx - c.r, y: c.cy - c.r, width: 2 * c.r, height: 2 * c.r }),
+    segment: (g) => ({
+      x: Math.min(g.x1, g.x2),
+      y: Math.min(g.y1, g.y2),
+      width: Math.abs(g.x2 - g.x1),
+      height: Math.abs(g.y2 - g.y1),
+    }),
+    label: (l) => ({ x: l.x, y: l.y, width: l.text.length * LABEL_CHAR_W, height: LABEL_LINE_H }),
+  });
+}
