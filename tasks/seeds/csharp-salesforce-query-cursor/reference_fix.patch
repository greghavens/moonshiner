+namespace SoqlExport;
+
+/// <summary>
+/// A Salesforce REST error envelope: a JSON array of message/errorCode
+/// objects. Exception text never includes the access token.
+/// </summary>
+public class SalesforceApiException : Exception
+{
+    public int StatusCode { get; }
+
+    public string ErrorCode { get; }
+
+    public SalesforceApiException(int statusCode, string errorCode, string message)
+        : base($"Salesforce request failed with {statusCode} ({errorCode}): {message}")
+    {
+        StatusCode = statusCode;
+        ErrorCode = errorCode;
+    }
+}
+
+/// <summary>The session was still invalid after the one allowed refresh.</summary>
+public sealed class SalesforceSessionException : SalesforceApiException
+{
+    public SalesforceSessionException(int statusCode, string errorCode, string message)
+        : base(statusCode, errorCode, message)
+    {
+    }
+}
