+namespace SoqlExport;
+
+/// <summary>One record from a query batch, attributes metadata retained.</summary>
+public sealed class ExportedRecord
+{
+    public string Type { get; }
+
+    public string Url { get; }
+
+    public string Id { get; }
+
+    public IReadOnlyDictionary<string, string?> Fields { get; }
+
+    public ExportedRecord(string type, string url,
+        IReadOnlyDictionary<string, string?> fields)
+    {
+        Type = type;
+        Url = url;
+        Fields = fields;
+        Id = fields.TryGetValue("Id", out var id) && id != null ? id : "";
+    }
+}
+
+/// <summary>The result of a complete cursor scan.</summary>
+public sealed class QueryExport
+{
+    public int TotalSize { get; }
+
+    public int Pages { get; }
+
+    public bool SessionRefreshed { get; }
+
+    public IReadOnlyList<ExportedRecord> Records { get; }
+
+    public QueryExport(int totalSize, int pages, bool sessionRefreshed,
+        IReadOnlyList<ExportedRecord> records)
+    {
+        TotalSize = totalSize;
+        Pages = pages;
+        SessionRefreshed = sessionRefreshed;
+        Records = records;
+    }
+}
