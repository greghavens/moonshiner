+namespace SoqlExport;
+
+/// <summary>
+/// Supplies and refreshes the Salesforce access token. Implemented by the
+/// caller's token broker; the exporter refreshes at most once per run.
+/// </summary>
+public interface ISessionSource
+{
+    Task<string> GetTokenAsync();
+
+    Task<string> RefreshTokenAsync();
+}
