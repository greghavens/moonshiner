diff --git a/quote_args.sh b/quote_args.sh
new file mode 100644
index 0000000..7a7e2d6
--- /dev/null
+++ b/quote_args.sh
@@ -0,0 +1,38 @@
+# quote_args.sh -- render argv words back into a copy-pasteable command line.
+#
+# Convention: every function's FIRST argument is the NAME of the destination
+# variable (printf -v style); the remaining arguments are inputs.
+
+# qa_word DEST WORD -- render one word so pasting it into bash reproduces WORD.
+qa_word() {
+  local __dest=$1 __w=$2
+  case $__w in
+    '')
+      # the empty word would vanish entirely if left bare
+      printf -v "$__dest" "''"
+      ;;
+    *[![:alnum:]_%+,./:=@-]*)
+      # something outside the bare-safe set: let the shell's own quoting
+      # transform pick between the '...' and $'...' forms
+      printf -v "$__dest" '%s' "${__w@Q}"
+      ;;
+    *)
+      printf -v "$__dest" '%s' "$__w"
+      ;;
+  esac
+}
+
+# qa_line DEST [ARG...] -- render every argument and join with single spaces.
+qa_line() {
+  local __dest=$1 __line='' __word __a
+  shift
+  for __a in "$@"; do
+    qa_word __word "$__a"
+    if [ -z "$__line" ]; then
+      __line=$__word
+    else
+      __line+=" $__word"
+    fi
+  done
+  printf -v "$__dest" '%s' "$__line"
+}
