diff --git a/coalesce.py b/coalesce.py
new file mode 100644
index 0000000..bd01e54
--- /dev/null
+++ b/coalesce.py
@@ -0,0 +1,68 @@
+"""Notification coalescer: per-key windows with a max-batch cap."""
+
+
+def _check_time(value):
+    if isinstance(value, bool) or not isinstance(value, (int, float)):
+        raise ValueError("timestamp must be a number: %r" % (value,))
+    return value
+
+
+class Coalescer:
+    def __init__(self, window, max_batch):
+        if isinstance(window, bool) or not isinstance(window, (int, float)) \
+                or window <= 0:
+            raise ValueError("window must be a positive number: %r"
+                             % (window,))
+        if not isinstance(max_batch, int) or isinstance(max_batch, bool) \
+                or max_batch < 1:
+            raise ValueError("max_batch must be a positive int: %r"
+                             % (max_batch,))
+        self._window = window
+        self._max_batch = max_batch
+        self._open = {}          # key -> {"opened_at":, "payloads": []}
+        self._clock = None
+
+    def _advance(self, at):
+        at = _check_time(at)
+        if self._clock is not None and at < self._clock:
+            raise ValueError("time went backwards: %r < %r"
+                             % (at, self._clock))
+        self._clock = at
+        return at
+
+    def _emit(self, key, reason):
+        batch = self._open.pop(key)
+        return {"key": key, "payloads": batch["payloads"],
+                "opened_at": batch["opened_at"], "reason": reason}
+
+    def _expire(self, at):
+        stale = [key for key, batch in self._open.items()
+                 if batch["opened_at"] + self._window <= at]
+        stale.sort(key=lambda k: (self._open[k]["opened_at"], k))
+        return [self._emit(key, "window") for key in stale]
+
+    def add(self, key, payload, at):
+        if not isinstance(key, str) or not key:
+            raise ValueError("key must be a non-empty string: %r" % (key,))
+        at = self._advance(at)
+        flushed = self._expire(at)
+        batch = self._open.get(key)
+        if batch is None:
+            batch = self._open[key] = {"opened_at": at, "payloads": []}
+        batch["payloads"].append(payload)
+        if len(batch["payloads"]) >= self._max_batch:
+            flushed.append(self._emit(key, "size"))
+        return flushed
+
+    def drain(self, at):
+        return self._expire(self._advance(at))
+
+    def flush_all(self, at):
+        at = self._advance(at)
+        keys = sorted(self._open,
+                      key=lambda k: (self._open[k]["opened_at"], k))
+        return [self._emit(key, "forced") for key in keys]
+
+    def pending(self):
+        return {key: len(batch["payloads"])
+                for key, batch in self._open.items()}
