diff --git a/reference_solution.sh b/reference_solution.sh
new file mode 100644
index 0000000..893d8f5
--- /dev/null
+++ b/reference_solution.sh
@@ -0,0 +1,82 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+run_dir=.pytest_cache/reference_run
+mkdir -p "$run_dir"
+./projectsctl --help >"$run_dir/help.txt"
+
+./projectsctl search \
+  --query 'Policy handbook review' \
+  --location 'Beacon Program' >"$run_dir/policy-search.json" &
+policy_search_pid=$!
+./projectsctl search \
+  --query 'Autumn newsletter draft' \
+  --location 'Clover Program' >"$run_dir/newsletter-search.json" &
+newsletter_search_pid=$!
+wait "$policy_search_pid"
+wait "$newsletter_search_pid"
+
+unique_id() {
+  python3 -c 'import json,sys
+matches=json.load(open(sys.argv[1], encoding="utf-8")).get("matches", [])
+if len(matches) != 1 or not matches[0].get("id"):
+    raise SystemExit("search did not return one unique ID")
+print(matches[0]["id"])' "$1"
+}
+
+policy_id=$(unique_id "$run_dir/policy-search.json")
+newsletter_id=$(unique_id "$run_dir/newsletter-search.json")
+
+./projectsctl get --id "$policy_id" >"$run_dir/policy-get.json" &
+policy_get_pid=$!
+./projectsctl get --id "$newsletter_id" >"$run_dir/newsletter-get.json" &
+newsletter_get_pid=$!
+wait "$policy_get_pid"
+wait "$newsletter_get_pid"
+
+python3 - "$run_dir/policy-get.json" "$run_dir/newsletter-get.json" <<'PY'
+import json
+import sys
+from pathlib import Path
+
+records = [json.loads(Path(name).read_text()) for name in sys.argv[1:]]
+
+def value(record, field):
+    item = record.get(field)
+    return "unknown" if item is None or item == "" else str(item)
+
+first, second = records
+first_status = value(first, "status")
+second_status = value(second, "status")
+relation = "match" if first_status == second_status else "differ"
+lines = [
+    "# Project status audit",
+    "",
+    "| ID | Name | Location | Status |",
+    "|---|---|---|---|",
+]
+for record in records:
+    lines.append(
+        "| {id} | {name} | {location} | {status} |".format(
+            id=value(record, "id"),
+            name=value(record, "name"),
+            location=value(record, "location"),
+            status=value(record, "status"),
+        )
+    )
+lines.extend(
+    [
+        "",
+        "Comparison: `{first_name}` is `{first_status}`; "
+        "`{second_name}` is `{second_status}`; the returned statuses {relation}.".format(
+            first_name=value(first, "name"),
+            first_status=first_status,
+            second_name=value(second, "name"),
+            second_status=second_status,
+            relation=relation,
+        ),
+        "",
+    ]
+)
+Path("status_audit.md").write_text("\n".join(lines))
+PY
