diff --git a/dots.sh b/dots.sh
new file mode 100644
index 0000000..ef1f15e
--- /dev/null
+++ b/dots.sh
@@ -0,0 +1,105 @@
+#!/usr/bin/env bash
+# dots.sh — install/uninstall the team dotfile kit as absolute symlinks.
+# Usage: dots.sh install|uninstall <srcdir> <targetdir>
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  printf 'usage: dots.sh install|uninstall <srcdir> <targetdir>\n' >&2
+  exit 64
+}
+
+[ "$#" -eq 3 ] || usage
+cmd=$1
+src=$2
+tgt=$3
+case $cmd in
+  install|uninstall) ;;
+  *) usage ;;
+esac
+[ -d "$src" ] || { printf 'dots.sh: not a directory: %s\n' "$src" >&2; exit 66; }
+[ -d "$tgt" ] || { printf 'dots.sh: not a directory: %s\n' "$tgt" >&2; exit 66; }
+
+srcabs=$(cd "$src" && pwd)
+bak="$tgt/dotbackup"
+
+# the kit: top-level regular files, dotfiles included, C byte order
+names=()
+while IFS= read -r n; do
+  names+=("$n")
+done < <(
+  for p in "$src"/* "$src"/.[!.]* "$src"/..?*; do
+    [ -f "$p" ] && printf '%s\n' "${p##*/}"
+  done | sort
+)
+if [ "${#names[@]}" -eq 0 ]; then
+  printf 'dots.sh: nothing to manage in: %s\n' "$src" >&2
+  exit 65
+fi
+
+owned_link() { # owned_link <path> <name> -- is <path> our symlink for <name>?
+  [ -L "$1" ] && [ "$(readlink "$1")" = "$srcabs/$2" ]
+}
+
+if [ "$cmd" = install ]; then
+  # preflight: refuse the whole run before touching anything
+  for n in "${names[@]}"; do
+    t="$tgt/$n"
+    if [ -d "$t" ] && [ ! -L "$t" ]; then
+      printf 'dots.sh: target is a directory: %s\n' "$n" >&2
+      exit 73
+    fi
+    if [ -f "$t" ] && [ ! -L "$t" ] && { [ -e "$bak/$n" ] || [ -L "$bak/$n" ]; }; then
+      printf 'dots.sh: backup already exists: %s\n' "$n" >&2
+      exit 73
+    fi
+  done
+
+  changed=0
+  ok=0
+  for n in "${names[@]}"; do
+    t="$tgt/$n"
+    if owned_link "$t" "$n"; then
+      printf 'ok %s\n' "$n"
+      ok=$((ok + 1))
+    elif [ -L "$t" ]; then
+      rm -- "$t"
+      ln -s "$srcabs/$n" "$t"
+      printf 'relink %s\n' "$n"
+      changed=$((changed + 1))
+    elif [ -f "$t" ]; then
+      mkdir -p "$bak"
+      mv -- "$t" "$bak/$n"
+      ln -s "$srcabs/$n" "$t"
+      printf 'backup+link %s\n' "$n"
+      changed=$((changed + 1))
+    else
+      ln -s "$srcabs/$n" "$t"
+      printf 'link %s\n' "$n"
+      changed=$((changed + 1))
+    fi
+  done
+  printf 'done: %s changed, %s ok\n' "$changed" "$ok"
+else
+  changed=0
+  skipped=0
+  for n in "${names[@]}"; do
+    t="$tgt/$n"
+    if owned_link "$t" "$n"; then
+      rm -- "$t"
+      if [ -f "$bak/$n" ]; then
+        mv -- "$bak/$n" "$t"
+        printf 'restore %s\n' "$n"
+      else
+        printf 'unlink %s\n' "$n"
+      fi
+      changed=$((changed + 1))
+    else
+      printf 'skip %s\n' "$n"
+      skipped=$((skipped + 1))
+    fi
+  done
+  rmdir -- "$bak" 2>/dev/null || true
+  printf 'done: %s changed, %s skipped\n' "$changed" "$skipped"
+fi
