+namespace Microfiche;
+
+public sealed record FrameRecord(string FrameId, string Reel);
+
+public interface IReelStore
+{
+    /// <summary>Up to pageSize frames beginning at the 0-based offset, in
+    /// frame-id order. A short batch marks the end of the archive.</summary>
+    IReadOnlyList<FrameRecord> ScanBatch(int offset, int pageSize);
+}
+
+public static class ReelScanner
+{
+    public static IEnumerable<FrameRecord> Stream(IReelStore store, int pageSize)
+    {
+        ValidatePageSize(pageSize);
+        return StreamCore(store, pageSize);
+    }
+
+    private static IEnumerable<FrameRecord> StreamCore(IReelStore store, int pageSize)
+    {
+        foreach (var page in PagesCore(store, pageSize))
+        {
+            foreach (var record in page)
+                yield return record;
+        }
+    }
+
+    public static IEnumerable<IReadOnlyList<FrameRecord>> Pages(IReelStore store, int pageSize)
+    {
+        ValidatePageSize(pageSize);
+        return PagesCore(store, pageSize);
+    }
+
+    private static IEnumerable<IReadOnlyList<FrameRecord>> PagesCore(IReelStore store, int pageSize)
+    {
+        var offset = 0;
+        while (true)
+        {
+            var page = store.ScanBatch(offset, pageSize);
+            if (page.Count > 0)
+                yield return page;
+            if (page.Count < pageSize)
+                yield break;               // short (or empty) batch: the end
+            offset += pageSize;
+        }
+    }
+
+    public static FrameRecord? FirstMatch(
+        IReelStore store, int pageSize, Func<FrameRecord, bool> predicate)
+    {
+        ValidatePageSize(pageSize);
+        foreach (var record in StreamCore(store, pageSize))
+        {
+            if (predicate(record))
+                return record;
+        }
+        return null;
+    }
+
+    private static void ValidatePageSize(int pageSize)
+    {
+        if (pageSize < 1)
+            throw new ArgumentOutOfRangeException(nameof(pageSize), pageSize,
+                "page size must be at least 1");
+    }
+}
