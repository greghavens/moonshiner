+// HTTP layer for the bookmarks service. Routing, body intake, status
+// mapping, and — because this sits behind a keep-alive-heavy proxy —
+// explicit connection discipline on every error path.
+
+import * as http from 'node:http';
+import { BookmarkStore, ValidationError, DuplicateUrlError } from './store.ts';
+import { readBody, PayloadTooLarge } from './body.ts';
+
+export interface AppOptions {
+  store?: BookmarkStore;
+  maxBodyBytes?: number;
+}
+
+const DEFAULT_MAX_BODY_BYTES = 65536;
+
+const COLLECTION = /^\/bookmarks$/;
+const MEMBER = /^\/bookmarks\/([^/]+)$/;
+
+interface Ctx {
+  store: BookmarkStore;
+  limit: number;
+}
+
+function sendJson(
+  res: http.ServerResponse,
+  status: number,
+  payload: unknown,
+  extraHeaders: Record<string, string> = {},
+): void {
+  const body = Buffer.from(JSON.stringify(payload));
+  res.writeHead(status, {
+    'content-type': 'application/json',
+    'content-length': body.length,
+    ...extraHeaders,
+  });
+  res.end(body);
+}
+
+function sendEmpty(res: http.ServerResponse, status: number): void {
+  res.writeHead(status);
+  res.end();
+}
+
+/**
+ * Read and parse a JSON object body. Returns undefined when a response has
+ * already been written (the caller just returns). Connection rules:
+ * - declared or streamed body over the cap → 413 + Connection: close;
+ * - anything found wrong AFTER a full in-cap read (415 with the body
+ *   drained, bad JSON, non-object) answers normally and keeps the socket.
+ */
+async function readJsonObject(
+  req: http.IncomingMessage,
+  res: http.ServerResponse,
+  limit: number,
+): Promise<Record<string, unknown> | undefined> {
+  let raw: Buffer;
+  try {
+    raw = await readBody(req, limit);
+  } catch (err) {
+    if (err instanceof PayloadTooLarge) {
+      sendJson(res, 413, { error: 'payload_too_large', limit }, { connection: 'close' });
+      return undefined;
+    }
+    throw err;
+  }
+  const contentType = req.headers['content-type'];
+  const mediaType = typeof contentType === 'string' ? contentType.split(';')[0].trim().toLowerCase() : '';
+  if (mediaType !== 'application/json') {
+    sendJson(res, 415, { error: 'unsupported_media_type' });
+    return undefined;
+  }
+  let parsed: unknown;
+  try {
+    parsed = JSON.parse(raw.toString('utf8'));
+  } catch {
+    sendJson(res, 400, { error: 'invalid_json' });
+    return undefined;
+  }
+  if (parsed === null || typeof parsed !== 'object' || Array.isArray(parsed)) {
+    sendJson(res, 400, { error: 'invalid_body' });
+    return undefined;
+  }
+  return parsed as Record<string, unknown>;
+}
+
+function sendStoreError(res: http.ServerResponse, err: unknown): void {
+  if (err instanceof ValidationError) {
+    sendJson(res, 400, { error: 'validation', fields: err.fields });
+    return;
+  }
+  if (err instanceof DuplicateUrlError) {
+    sendJson(res, 409, { error: 'duplicate_url', url: err.url });
+    return;
+  }
+  throw err;
+}
+
+async function handleList(ctx: Ctx, url: URL, res: http.ServerResponse): Promise<void> {
+  const tag = url.searchParams.get('tag');
+  const items = ctx.store.list(tag !== null && tag !== '' ? { tag } : {});
+  sendJson(res, 200, { items, count: items.length });
+}
+
+async function handleCreate(ctx: Ctx, req: http.IncomingMessage, res: http.ServerResponse): Promise<void> {
+  const body = await readJsonObject(req, res, ctx.limit);
+  if (!body) return;
+  try {
+    const record = ctx.store.create(body);
+    sendJson(res, 201, record, { location: `/bookmarks/${record.id}` });
+  } catch (err) {
+    sendStoreError(res, err);
+  }
+}
+
+async function handleGet(ctx: Ctx, id: string, res: http.ServerResponse): Promise<void> {
+  const record = ctx.store.get(id);
+  if (!record) {
+    sendJson(res, 404, { error: 'not_found' });
+    return;
+  }
+  sendJson(res, 200, record);
+}
+
+async function handlePatch(ctx: Ctx, id: string, req: http.IncomingMessage, res: http.ServerResponse): Promise<void> {
+  const body = await readJsonObject(req, res, ctx.limit);
+  if (!body) return;
+  try {
+    const updated = ctx.store.update(id, body); // checks existence before validating
+    if (!updated) {
+      sendJson(res, 404, { error: 'not_found' });
+      return;
+    }
+    sendJson(res, 200, updated);
+  } catch (err) {
+    sendStoreError(res, err);
+  }
+}
+
+async function handleDelete(ctx: Ctx, id: string, res: http.ServerResponse): Promise<void> {
+  if (!ctx.store.remove(id)) {
+    sendJson(res, 404, { error: 'not_found' });
+    return;
+  }
+  sendEmpty(res, 204);
+}
+
+async function dispatch(ctx: Ctx, req: http.IncomingMessage, res: http.ServerResponse): Promise<void> {
+  const url = new URL(req.url ?? '/', 'http://bookmarks.local');
+  const path = url.pathname;
+
+  if (COLLECTION.test(path)) {
+    if (req.method === 'GET') return handleList(ctx, url, res);
+    if (req.method === 'POST') return handleCreate(ctx, req, res);
+    sendJson(res, 405, { error: 'method_not_allowed' }, { allow: 'GET, POST' });
+    return;
+  }
+
+  const member = MEMBER.exec(path);
+  if (member) {
+    const id = member[1];
+    if (req.method === 'GET') return handleGet(ctx, id, res);
+    if (req.method === 'PATCH') return handlePatch(ctx, id, req, res);
+    if (req.method === 'DELETE') return handleDelete(ctx, id, res);
+    sendJson(res, 405, { error: 'method_not_allowed' }, { allow: 'GET, PATCH, DELETE' });
+    return;
+  }
+
+  sendJson(res, 404, { error: 'not_found' });
+}
+
+export function createApp(options: AppOptions = {}): http.Server {
+  const ctx: Ctx = {
+    store: options.store ?? new BookmarkStore(),
+    limit: options.maxBodyBytes ?? DEFAULT_MAX_BODY_BYTES,
+  };
+  return http.createServer((req, res) => {
+    dispatch(ctx, req, res).catch(() => {
+      if (res.headersSent) {
+        res.destroy();
+        return;
+      }
+      sendJson(res, 500, { error: 'internal' }, { connection: 'close' });
+    });
+  });
+}
