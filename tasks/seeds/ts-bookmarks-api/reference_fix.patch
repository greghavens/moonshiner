+// In-memory bookmark store: validation, duplicate-url policy, and defensive
+// copies on every lookup. No HTTP concerns in this module.
+
+export interface Bookmark {
+  id: string;
+  url: string;
+  title: string;
+  tags: string[];
+}
+
+export class ValidationError extends Error {
+  fields: Record<string, string>;
+  constructor(fields: Record<string, string>) {
+    super(`invalid bookmark: ${Object.keys(fields).sort().join(', ')}`);
+    this.name = 'ValidationError';
+    this.fields = fields;
+  }
+}
+
+export class DuplicateUrlError extends Error {
+  url: string;
+  constructor(url: string) {
+    super(`a bookmark for ${url} already exists`);
+    this.name = 'DuplicateUrlError';
+    this.url = url;
+  }
+}
+
+const KNOWN_FIELDS = new Set(['url', 'title', 'tags']);
+
+function isHttpUrl(value: string): boolean {
+  let parsed: URL;
+  try {
+    parsed = new URL(value);
+  } catch {
+    return false;
+  }
+  return parsed.protocol === 'http:' || parsed.protocol === 'https:';
+}
+
+function normalizeTag(tag: string): string {
+  return tag.trim().toLowerCase();
+}
+
+interface Cleaned {
+  url?: string;
+  title?: string;
+  tags?: string[];
+}
+
+/** Validate an input object, collecting EVERY problem before throwing. */
+function validate(input: Record<string, unknown>, partial: boolean): Cleaned {
+  const fields: Record<string, string> = {};
+  const cleaned: Cleaned = {};
+
+  for (const key of Object.keys(input)) {
+    if (!KNOWN_FIELDS.has(key)) fields[key] = 'unknown field';
+  }
+
+  const url = input.url;
+  if (url === undefined) {
+    if (!partial) fields.url = 'url is required';
+  } else if (typeof url !== 'string' || !isHttpUrl(url.trim())) {
+    fields.url = 'url must be an absolute http(s) url';
+  } else {
+    cleaned.url = url.trim();
+  }
+
+  const title = input.title;
+  if (title === undefined) {
+    if (!partial) fields.title = 'title is required';
+  } else if (typeof title !== 'string' || title.trim() === '') {
+    fields.title = 'title must be a non-blank string';
+  } else {
+    cleaned.title = title.trim();
+  }
+
+  const tags = input.tags;
+  if (tags !== undefined) {
+    if (!Array.isArray(tags) || tags.some((t) => typeof t !== 'string' || t.trim() === '')) {
+      fields.tags = 'tags must be an array of non-blank strings';
+    } else {
+      const seen = new Set<string>();
+      const normalized: string[] = [];
+      for (const tag of tags as string[]) {
+        const norm = normalizeTag(tag);
+        if (!seen.has(norm)) {
+          seen.add(norm);
+          normalized.push(norm);
+        }
+      }
+      cleaned.tags = normalized;
+    }
+  }
+
+  if (Object.keys(fields).length > 0) throw new ValidationError(fields);
+  return cleaned;
+}
+
+function copyOf(record: Bookmark): Bookmark {
+  return { id: record.id, url: record.url, title: record.title, tags: [...record.tags] };
+}
+
+export class BookmarkStore {
+  private records = new Map<string, Bookmark>();
+  private nextId = 1;
+
+  create(input: object): Bookmark {
+    const cleaned = validate(input as Record<string, unknown>, false);
+    this.assertUrlFree(cleaned.url as string, null);
+    const record: Bookmark = {
+      id: `bm-${this.nextId++}`,
+      url: cleaned.url as string,
+      title: cleaned.title as string,
+      tags: cleaned.tags ?? [],
+    };
+    this.records.set(record.id, record);
+    return copyOf(record);
+  }
+
+  get(id: string): Bookmark | undefined {
+    const record = this.records.get(id);
+    return record ? copyOf(record) : undefined;
+  }
+
+  list(filter: { tag?: string } = {}): Bookmark[] {
+    let records = [...this.records.values()];
+    if (filter.tag !== undefined) {
+      const tag = normalizeTag(filter.tag);
+      records = records.filter((r) => r.tags.includes(tag));
+    }
+    return records.map(copyOf);
+  }
+
+  /** Patch only the provided fields. Missing id → undefined, no validation. */
+  update(id: string, patch: object): Bookmark | undefined {
+    const existing = this.records.get(id);
+    if (!existing) return undefined;
+    const cleaned = validate(patch as Record<string, unknown>, true);
+    if (cleaned.url !== undefined) this.assertUrlFree(cleaned.url, id);
+    const next: Bookmark = { ...existing, ...cleaned, tags: cleaned.tags ?? existing.tags };
+    this.records.set(id, next);
+    return copyOf(next);
+  }
+
+  remove(id: string): boolean {
+    return this.records.delete(id);
+  }
+
+  private assertUrlFree(url: string, selfId: string | null): void {
+    for (const record of this.records.values()) {
+      if (record.url === url && record.id !== selfId) {
+        throw new DuplicateUrlError(url);
+      }
+    }
+  }
+}
