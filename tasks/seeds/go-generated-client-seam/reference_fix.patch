 	return &Client{raw: raw, maxAttempts: maxAttempts, sleep: sleep}
 }
 
+func busyDelay(err error) (time.Duration, bool) {
+	if errors.Is(err, fleetapi.ErrServiceBusy) {
+		return 10 * time.Millisecond, true
+	}
+	var problem *fleetapi.Problem
+	if errors.As(err, &problem) && problem.Status == 503 && problem.Code == "fleet_busy" {
+		delay := time.Duration(problem.RetryAfterMillis) * time.Millisecond
+		if delay <= 0 {
+			delay = 10 * time.Millisecond
+		}
+		return delay, true
+	}
+	return 0, false
+}
