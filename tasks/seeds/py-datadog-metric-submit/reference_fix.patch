new file mode 100644
index 0000000..b06739e
--- /dev/null
+++ b/ddmetrics/batch.py
@@ -0,0 +1,66 @@
+"""Payload batching against the documented intake limits.
+
+A payload on the wire may be at most 500KB (512000 bytes); a compressed
+payload must additionally decompress to less than 5MB (5242880 bytes).
+"""
+
+import json
+
+MAX_PAYLOAD_BYTES = 512000
+MAX_DECOMPRESSED_BYTES = 5242880
+
+
+def encode_payload(payload):
+    """Compact wire serialization; byte limits apply to exactly these bytes."""
+    return json.dumps(payload, separators=(",", ":")).encode("utf-8")
+
+
+def split_series(series, max_bytes=MAX_PAYLOAD_BYTES):
+    """Pack series, in order, into as few payloads as fit uncompressed."""
+    batches = []
+    current = []
+    for doc in series:
+        candidate = current + [doc]
+        if len(encode_payload({"series": candidate})) <= max_bytes:
+            current = candidate
+            continue
+        if not current:
+            raise ValueError("series %r alone exceeds the %d byte payload "
+                             "limit" % (doc.get("metric"), max_bytes))
+        batches.append({"series": current})
+        current = [doc]
+        if len(encode_payload({"series": current})) > max_bytes:
+            raise ValueError("series %r alone exceeds the %d byte payload "
+                             "limit" % (doc.get("metric"), max_bytes))
+    if current:
+        batches.append({"series": current})
+    return batches
+
+
+def split_series_compressed(series, compress, max_bytes=MAX_PAYLOAD_BYTES,
+                            max_decompressed=MAX_DECOMPRESSED_BYTES):
+    """Pack series for compressed submission.
+
+    Each payload's decompressed JSON must stay under max_decompressed and
+    its compressed bytes within max_bytes.
+    """
+    batches = []
+    current = []
+    for doc in series:
+        candidate = current + [doc]
+        raw = encode_payload({"series": candidate})
+        if len(raw) < max_decompressed and len(compress(raw)) <= max_bytes:
+            current = candidate
+            continue
+        if not current:
+            raise ValueError("series %r alone exceeds the compressed payload "
+                             "limits" % (doc.get("metric"),))
+        batches.append({"series": current})
+        current = [doc]
+        raw = encode_payload({"series": current})
+        if not (len(raw) < max_decompressed and len(compress(raw)) <= max_bytes):
+            raise ValueError("series %r alone exceeds the compressed payload "
+                             "limits" % (doc.get("metric"),))
+    if current:
+        batches.append({"series": current})
+    return batches
