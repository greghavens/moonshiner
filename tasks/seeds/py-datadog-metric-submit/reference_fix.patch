@@ -0,0 +1,136 @@
+"""Datadog Metrics API v2 client (POST /api/v2/series)."""
+
+import gzip
+import json
+import time
+import urllib.error
+import urllib.request
+import zlib
+
+from . import batch as batching
+from .sites import resolve_api_base
+
+SERIES_PATH = "/api/v2/series"
+
+# Documented point freshness window relative to submission time.
+MAX_PAST_SECONDS = 3600
+MAX_FUTURE_SECONDS = 600
+
+# The API documents deflate, gzip, and zstd1; the stdlib gives us the
+# first two, so zstd1 is refused rather than silently mis-encoded.
+_COMPRESSORS = {
+    "deflate": zlib.compress,
+    "gzip": gzip.compress,
+}
+
+
+class MetricsClient:
+    def __init__(self, api_key, site="datadoghq.com", base_url=None,
+                 compression=None, now=None, sleep=None, max_retries=2):
+        if not api_key:
+            raise ValueError("api_key is required")
+        if compression is not None and compression not in _COMPRESSORS:
+            raise ValueError(
+                "unsupported Content-Encoding %r: this client implements "
+                "deflate and gzip; the API also documents zstd1, which the "
+                "Python stdlib cannot produce portably" % (compression,)
+            )
+        self._api_key = api_key
+        self._base = (base_url or resolve_api_base(site)).rstrip("/")
+        self._compression = compression
+        self._now = now if now is not None else time.time
+        self._sleep = sleep if sleep is not None else time.sleep
+        self._max_retries = int(max_retries)
+
+    def submit(self, series):
+        """Submit series in documented-limit batches; one outcome per payload."""
+        series = list(series)
+        self._check_freshness(series)
+        if self._compression:
+            compress = _COMPRESSORS[self._compression]
+            payloads = batching.split_series_compressed(series, compress)
+        else:
+            compress = None
+            payloads = batching.split_series(series)
+
+        batches = []
+        accepted = 0
+        for payload in payloads:
+            body = batching.encode_payload(payload)
+            if compress:
+                body = compress(body)
+            outcome = self._post(body)
+            outcome["series_count"] = len(payload["series"])
+            if outcome["status"] == 202 and not outcome["errors"]:
+                accepted += outcome["series_count"]
+            batches.append({
+                "status": outcome["status"],
+                "series_count": outcome["series_count"],
+                "errors": outcome["errors"],
+                "attempts": outcome["attempts"],
+            })
+        return {
+            "submitted": len(series),
+            "accepted": accepted,
+            "ok": all(b["status"] == 202 and not b["errors"] for b in batches),
+            "batches": batches,
+        }
+
+    def _check_freshness(self, series):
+        now = float(self._now())
+        for doc in series:
+            for point in doc.get("points", ()):
+                ts = point["timestamp"]
+                if ts < now - MAX_PAST_SECONDS or ts > now + MAX_FUTURE_SECONDS:
+                    raise ValueError(
+                        "point for metric %r at %d is outside the accepted "
+                        "window (at most 1h past, 10min future)"
+                        % (doc.get("metric"), ts)
+                    )
+
+    def _post(self, body):
+        headers = {
+            "DD-API-KEY": self._api_key,
+            "Content-Type": "application/json",
+            "Accept": "application/json",
+        }
+        if self._compression:
+            headers["Content-Encoding"] = self._compression
+
+        attempts = 0
+        while True:
+            attempts += 1
+            request = urllib.request.Request(
+                self._base + SERIES_PATH, data=body, headers=headers,
+                method="POST",
+            )
+            retry_after = None
+            try:
+                with urllib.request.urlopen(request) as response:
+                    status = response.getcode()
+                    raw = response.read()
+            except urllib.error.HTTPError as err:
+                status = err.code
+                raw = err.read()
+                retry_after = err.headers.get("Retry-After")
+            except urllib.error.URLError as err:
+                # Never let the request object (which holds the key header)
+                # escape through the exception chain.
+                raise RuntimeError("Datadog intake request failed: %s"
+                                   % (getattr(err, "reason", err),)) from None
+
+            errors = self._decode_errors(raw)
+            if status == 429 and attempts <= self._max_retries:
+                wait = float(retry_after) if retry_after is not None else 1.0
+                self._sleep(wait)
+                continue
+            return {"status": status, "errors": errors, "attempts": attempts}
+
+    @staticmethod
+    def _decode_errors(raw):
+        try:
+            doc = json.loads(raw.decode("utf-8"))
+        except (ValueError, UnicodeDecodeError):
+            return []
+        errors = doc.get("errors", [])
+        return list(errors) if isinstance(errors, list) else [str(errors)]
