+"""v2 series construction and validation.
+
+The v2 schema types metrics with an integer enum and carries points as
+{timestamp, value} objects; resources replace the old v1 host string.
+"""
+
+UNSPECIFIED = 0
+COUNT = 1
+RATE = 2
+GAUGE = 3
+
+_VALID_TYPES = frozenset({UNSPECIFIED, COUNT, RATE, GAUGE})
+_NEEDS_INTERVAL = frozenset({COUNT, RATE})
+
+
+def _normalize_point(point):
+    if isinstance(point, dict):
+        if "timestamp" not in point or "value" not in point:
+            raise ValueError("a point dict needs 'timestamp' and 'value'")
+        ts, value = point["timestamp"], point["value"]
+    else:
+        try:
+            ts, value = point
+        except (TypeError, ValueError):
+            raise ValueError("a point must be a (timestamp, value) pair "
+                             "or a {'timestamp', 'value'} dict")
+    return {"timestamp": int(ts), "value": float(value)}
+
+
+def make_series(metric, mtype, points, tags=None, resources=None, unit=None,
+                interval=None, source_type_name=None):
+    """Build one series dict in the documented v2 shape.
+
+    Unset optional fields are omitted entirely rather than sent as null.
+    """
+    if not isinstance(metric, str) or not metric:
+        raise ValueError("metric must be a non-empty string")
+    if isinstance(mtype, bool) or not isinstance(mtype, int) \
+            or mtype not in _VALID_TYPES:
+        raise ValueError(
+            "metric type must be one of the v2 integer enum values "
+            "0 (unspecified), 1 (count), 2 (rate), 3 (gauge); got %r" % (mtype,)
+        )
+    normalized = [_normalize_point(p) for p in points]
+    if not normalized:
+        raise ValueError("a series needs at least one point")
+    if mtype in _NEEDS_INTERVAL and interval is None:
+        raise ValueError("count and rate series need the corresponding "
+                         "interval in seconds")
+    if interval is not None:
+        if isinstance(interval, bool) or not isinstance(interval, int) \
+                or interval <= 0:
+            raise ValueError("interval must be a positive number of seconds")
+
+    doc = {"metric": metric, "type": mtype, "points": normalized}
+    if interval is not None:
+        doc["interval"] = interval
+    if tags is not None:
+        if not all(isinstance(t, str) for t in tags):
+            raise ValueError("tags must be strings")
+        doc["tags"] = list(tags)
+    if resources is not None:
+        cleaned = []
+        for res in resources:
+            if not isinstance(res, dict) or "name" not in res or "type" not in res:
+                raise ValueError("each resource needs 'name' and 'type'")
+            cleaned.append({"name": res["name"], "type": res["type"]})
+        doc["resources"] = cleaned
+    if unit is not None:
+        doc["unit"] = unit
+    if source_type_name is not None:
+        doc["source_type_name"] = source_type_name
+    return doc
