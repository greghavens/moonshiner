+"""Datadog site selection.
+
+Each Datadog site is a fully independent instance; data cannot be shared
+across sites. The API host for a site parameter is https://api.<site>.
+"""
+
+KNOWN_SITES = frozenset({
+    "datadoghq.com",       # US1
+    "us3.datadoghq.com",   # US3
+    "us5.datadoghq.com",   # US5
+    "datadoghq.eu",        # EU1
+    "ap1.datadoghq.com",   # AP1
+    "ap2.datadoghq.com",   # AP2
+    "ddog-gov.com",        # US1-FED
+})
+
+
+def resolve_api_base(site):
+    """Map a documented site parameter to its API base URL."""
+    if site not in KNOWN_SITES:
+        raise ValueError(
+            "unknown Datadog site %r; expected one of the documented site "
+            "parameters such as datadoghq.com or datadoghq.eu" % (site,)
+        )
+    return "https://api." + site
