+"""Datadog Metrics API v2 submitter (stdlib only).
+
+Implements the documented POST /api/v2/series contract: site-aware base
+URLs, DD-API-KEY header auth, v2 series schema, payload-limit batching,
+optional deflate/gzip compression, per-payload error reporting, and
+Retry-After driven 429 retries with injected time.
+"""
+
+from . import batch, client, series, sites  # noqa: F401
