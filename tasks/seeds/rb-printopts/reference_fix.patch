+# Declarative validation for print-job options: required/optional keys,
+# type coercion, accumulated errors, and did-you-mean for unknown keys.
+module PrintOptions
+  class Error < ArgumentError
+    attr_reader :problems
+
+    def initialize(problems)
+      @problems = problems
+      super("invalid print options:\n  - #{problems.join("\n  - ")}")
+    end
+  end
+
+  class Schema
+    TYPES = %i[integer boolean string].freeze
+    NO_DEFAULT = Object.new
+    Option = Data.define(:name, :type, :required, :default, :has_default)
+
+    def initialize(&block)
+      @options = {}
+      instance_eval(&block) if block
+    end
+
+    def required(name, type, **extra)
+      if extra.key?(:default)
+        raise ArgumentError, "required option #{name.inspect} cannot have a default"
+      end
+      declare(name, type, required: true, default: NO_DEFAULT)
+    end
+
+    def optional(name, type, default: NO_DEFAULT)
+      declare(name, type, required: false, default: default)
+    end
+
+    def validate(**given)
+      problems = given.keys.reject { |k| @options.key?(k) }.map { |k| unknown_problem(k) }
+      result = {}
+      @options.each_value do |opt|
+        if given.key?(opt.name)
+          value, problem = coerce(opt, given[opt.name])
+          problem ? problems << problem : result[opt.name] = value
+        elsif opt.required
+          problems << "#{opt.name} is required"
+        elsif opt.has_default
+          result[opt.name] = opt.default
+        end
+      end
+      raise Error, problems unless problems.empty?
+      result
+    end
+
+    private
+
+    def declare(name, type, required:, default:)
+      name = name.to_sym
+      raise ArgumentError, "duplicate option #{name.inspect}" if @options.key?(name)
+      raise ArgumentError, "unknown type #{type.inspect} for #{name.inspect}" unless TYPES.include?(type)
+      @options[name] = Option.new(name: name, type: type, required: required,
+                                  default: default, has_default: !default.equal?(NO_DEFAULT))
+    end
+
+    def coerce(opt, value)
+      case opt.type
+      when :integer
+        return [value, nil] if value.is_a?(Integer)
+        return [Integer(value, 10), nil] if value.is_a?(String) && value.match?(/\A-?\d+\z/)
+      when :boolean
+        return [value, nil] if value.equal?(true) || value.equal?(false)
+        return [true, nil] if value == "true"
+        return [false, nil] if value == "false"
+      when :string
+        return [value, nil] if value.is_a?(String)
+      end
+      [nil, "#{opt.name} must be #{ARTICLES[opt.type]} #{opt.type}, got #{value.inspect}"]
+    end
+
+    ARTICLES = { integer: "an", boolean: "a", string: "a" }.freeze
+
+    def unknown_problem(key)
+      best = nil
+      best_distance = nil
+      @options.each_key do |name|
+        d = levenshtein(key.to_s, name.to_s)
+        if best_distance.nil? || d < best_distance
+          best = name
+          best_distance = d
+        end
+      end
+      if best && best_distance <= 3
+        "unknown option #{key.inspect} (did you mean #{best.inspect}?)"
+      else
+        "unknown option #{key.inspect}"
+      end
+    end
+
+    def levenshtein(a, b)
+      previous = (0..b.length).to_a
+      a.each_char.with_index(1) do |ca, i|
+        current = [i]
+        b.each_char.with_index(1) do |cb, j|
+          current << [previous[j] + 1,                          # deletion
+                      current[j - 1] + 1,                       # insertion
+                      previous[j - 1] + (ca == cb ? 0 : 1)].min # substitution
+        end
+        previous = current
+      end
+      previous[b.length]
+    end
+  end
+end
