-//! rs-slabarena: generation-indexed slab arena for the editor's entity
-//! registry. Implementation pending — see tests/slabarena.rs for the
-//! acceptance contract.
+//! rs-slabarena: a generation-indexed slab arena.
+//!
+//! Slots are recycled (most-recently-freed first) but every tenancy of a
+//! slot carries a generation counter, so handles minted for an earlier
+//! tenant are *detected* as stale instead of silently reading the new one.
+
+/// Opaque reference to one tenancy of one slot.
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
+pub struct Handle {
+    index: u32,
+    generation: u32,
+}
+
+impl Handle {
+    /// Slot number inside the arena.
+    pub fn index(&self) -> u32 {
+        self.index
+    }
+
+    /// How many times the slot had been freed before this tenancy.
+    pub fn generation(&self) -> u32 {
+        self.generation
+    }
+}
+
+struct Slot<T> {
+    generation: u32,
+    state: SlotState<T>,
+}
+
+enum SlotState<T> {
+    Vacant,
+    Occupied(T),
+}
+
+/// Generation-indexed slab arena.
+pub struct Arena<T> {
+    slots: Vec<Slot<T>>,
+    free: Vec<u32>, // LIFO free list: most recently freed on top
+    len: usize,
+}
+
+impl<T> Arena<T> {
+    pub fn new() -> Self {
+        Arena {
+            slots: Vec::new(),
+            free: Vec::new(),
+            len: 0,
+        }
+    }
+
+    /// Occupied slots.
+    pub fn len(&self) -> usize {
+        self.len
+    }
+
+    pub fn is_empty(&self) -> bool {
+        self.len == 0
+    }
+
+    /// Slots ever materialized (occupied + vacant). Never shrinks.
+    pub fn capacity(&self) -> usize {
+        self.slots.len()
+    }
+
+    /// Store a value, recycling the most recently freed slot if one exists.
+    pub fn insert(&mut self, value: T) -> Handle {
+        self.len += 1;
+        match self.free.pop() {
+            Some(index) => {
+                let slot = &mut self.slots[index as usize];
+                slot.state = SlotState::Occupied(value);
+                Handle {
+                    index,
+                    generation: slot.generation,
+                }
+            }
+            None => {
+                let index = self.slots.len() as u32;
+                self.slots.push(Slot {
+                    generation: 0,
+                    state: SlotState::Occupied(value),
+                });
+                Handle {
+                    index,
+                    generation: 0,
+                }
+            }
+        }
+    }
+
+    fn slot_for(&self, h: Handle) -> Option<&Slot<T>> {
+        self.slots
+            .get(h.index as usize)
+            .filter(|s| s.generation == h.generation)
+    }
+
+    pub fn get(&self, h: Handle) -> Option<&T> {
+        match self.slot_for(h) {
+            Some(Slot {
+                state: SlotState::Occupied(v),
+                ..
+            }) => Some(v),
+            _ => None,
+        }
+    }
+
+    pub fn get_mut(&mut self, h: Handle) -> Option<&mut T> {
+        match self.slots.get_mut(h.index as usize) {
+            Some(slot) if slot.generation == h.generation => match &mut slot.state {
+                SlotState::Occupied(v) => Some(v),
+                SlotState::Vacant => None,
+            },
+            _ => None,
+        }
+    }
+
+    pub fn contains(&self, h: Handle) -> bool {
+        self.get(h).is_some()
+    }
+
+    /// Remove the value behind a live handle. Frees the slot, bumps its
+    /// generation (killing every handle of the old tenancy), and puts the
+    /// slot on top of the free list. Stale handles are a no-op `None`.
+    pub fn remove(&mut self, h: Handle) -> Option<T> {
+        let slot = self.slots.get_mut(h.index as usize)?;
+        if slot.generation != h.generation || matches!(slot.state, SlotState::Vacant) {
+            return None;
+        }
+        let state = std::mem::replace(&mut slot.state, SlotState::Vacant);
+        slot.generation += 1;
+        self.free.push(h.index);
+        self.len -= 1;
+        match state {
+            SlotState::Occupied(v) => Some(v),
+            SlotState::Vacant => unreachable!("checked occupied above"),
+        }
+    }
+
+    /// Visit occupied slots in index order, with each tenant's live handle.
+    pub fn iter(&self) -> impl Iterator<Item = (Handle, &T)> {
+        self.slots.iter().enumerate().filter_map(|(i, slot)| {
+            if let SlotState::Occupied(v) = &slot.state {
+                Some((
+                    Handle {
+                        index: i as u32,
+                        generation: slot.generation,
+                    },
+                    v,
+                ))
+            } else {
+                None
+            }
+        })
+    }
+}
+
+impl<T> Default for Arena<T> {
+    fn default() -> Self {
+        Arena::new()
+    }
+}
