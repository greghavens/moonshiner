+"""Bank-statement reconciliation: exact, fuzzy-date, and split matching."""
+
+import itertools
+from datetime import date
+
+
+def _parse_date(text):
+    if not isinstance(text, str):
+        raise ValueError("date must be a YYYY-MM-DD string: %r" % (text,))
+    try:
+        return date.fromisoformat(text)
+    except ValueError:
+        raise ValueError("bad date %r" % (text,))
+
+
+def _check_amount(value, owner):
+    if not isinstance(value, int) or isinstance(value, bool):
+        raise ValueError("amount for %s must be int cents: %r" % (owner, value))
+
+
+def reconcile(ledger, statement, tolerance=3):
+    if not isinstance(tolerance, int) or isinstance(tolerance, bool) \
+            or tolerance < 0:
+        raise ValueError("tolerance must be a non-negative int: %r"
+                         % (tolerance,))
+
+    entries, seen_ids = [], set()
+    for raw in ledger:
+        if raw["id"] in seen_ids:
+            raise ValueError("duplicate ledger id %r" % (raw["id"],))
+        seen_ids.add(raw["id"])
+        _check_amount(raw["amount"], "ledger %r" % raw["id"])
+        entries.append({"id": raw["id"], "date": _parse_date(raw["date"]),
+                        "amount": raw["amount"]})
+
+    lines, seen_refs = [], set()
+    for raw in statement:
+        if raw["ref"] in seen_refs:
+            raise ValueError("duplicate statement ref %r" % (raw["ref"],))
+        seen_refs.add(raw["ref"])
+        _check_amount(raw["amount"], "statement %r" % raw["ref"])
+        lines.append({"ref": raw["ref"], "date": _parse_date(raw["date"]),
+                      "amount": raw["amount"]})
+
+    entries.sort(key=lambda e: (e["date"], e["id"]))
+    lines.sort(key=lambda s: (s["date"], s["ref"]))
+    free_entries = list(entries)
+    free_lines = list(lines)
+    matches = []
+
+    def take(line, chosen, kind):
+        chosen = sorted(chosen, key=lambda e: (e["date"], e["id"]))
+        matches.append({"ref": line["ref"],
+                        "entry_ids": [e["id"] for e in chosen],
+                        "kind": kind})
+        free_lines.remove(line)
+        for e in chosen:
+            free_entries.remove(e)
+
+    # pass 1: exact ------------------------------------------------------
+    for line in list(free_lines):
+        for e in free_entries:
+            if e["amount"] == line["amount"] and e["date"] == line["date"]:
+                take(line, [e], "exact")
+                break
+
+    # pass 2: fuzzy date -------------------------------------------------
+    for line in list(free_lines):
+        best = None
+        for e in free_entries:
+            if e["amount"] != line["amount"]:
+                continue
+            diff = abs((e["date"] - line["date"]).days)
+            if diff > tolerance:
+                continue
+            key = (diff, e["date"], e["id"])
+            if best is None or key < best[0]:
+                best = (key, e)
+        if best is not None:
+            take(line, [best[1]], "date")
+
+    # pass 3: splits (pairs, then triples) -------------------------------
+    for line in list(free_lines):
+        candidates = [e for e in free_entries
+                      if abs((e["date"] - line["date"]).days) <= tolerance]
+        found = None
+        for size in (2, 3):
+            for combo in itertools.combinations(candidates, size):
+                if sum(e["amount"] for e in combo) == line["amount"]:
+                    found = combo
+                    break
+            if found:
+                break
+        if found:
+            take(line, list(found), "split")
+
+    order = {"exact": 0, "date": 1, "split": 2}
+    matches.sort(key=lambda m: order[m["kind"]])
+    return {
+        "matches": matches,
+        "unmatched_ledger": [e["id"] for e in free_entries],
+        "unmatched_statement": [s["ref"] for s in free_lines],
+    }
