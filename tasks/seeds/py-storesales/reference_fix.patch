+"""Weekly regional sales rollup for the housewares chain.
+
+Money is integer cents end to end; region/category are ordered categoricals
+over the canonical business orderings so reports keep their walk order and
+zero-sales combinations never drop out of the rollup.
+"""
+from pathlib import Path
+
+import pandas as pd
+from pandas.api.types import CategoricalDtype
+
+REGIONS = ["north", "central", "south"]
+CATEGORIES = ["kitchen", "bath", "garden", "seasonal"]
+
+_REGION_DTYPE = CategoricalDtype(REGIONS, ordered=True)
+_CATEGORY_DTYPE = CategoricalDtype(CATEGORIES, ordered=True)
+
+
+def load_tables(data_dir):
+    """Read the three source CSVs with the dtype discipline finance expects."""
+    d = Path(data_dir)
+    stores = pd.read_csv(
+        d / "stores.csv",
+        dtype={"store_id": "int64", "region": _REGION_DTYPE})
+    products = pd.read_csv(
+        d / "products.csv",
+        dtype={"unit_cents": "int64", "category": _CATEGORY_DTYPE})
+    sales = pd.read_csv(
+        d / "sales.csv",
+        dtype={"store_id": "int64", "qty": "int64"})
+    return {"stores": stores, "products": products, "sales": sales}
+
+
+def _check_refs(used, known, label):
+    unknown = sorted(set(used) - set(known))
+    if unknown:
+        listing = ", ".join(str(v) for v in unknown)
+        raise ValueError(f"sales references unknown {label}: {listing}")
+
+
+def build_fact(tables):
+    """One row per sales line, joined to both lookups, plus line_cents."""
+    stores = tables["stores"]
+    products = tables["products"]
+    sales = tables["sales"]
+    _check_refs(sales["store_id"], stores["store_id"], "store_id")
+    _check_refs(sales["sku"], products["sku"], "sku")
+    fact = (
+        sales
+        .merge(stores, on="store_id", validate="many_to_one")
+        .merge(products, on="sku", validate="many_to_one"))
+    fact["line_cents"] = (fact["qty"] * fact["unit_cents"]).astype("int64")
+    return fact
+
+
+def weekly_report(fact):
+    """Aggregate to one row per region x category pair, zeros included."""
+    rep = (
+        fact.groupby(["region", "category"], observed=False)
+        .agg(units=("qty", "sum"), revenue_cents=("line_cents", "sum"))
+        .reset_index())
+    rep["units"] = rep["units"].astype("int64")
+    rep["revenue_cents"] = rep["revenue_cents"].astype("int64")
+    return rep
+
+
+def write_report(report, path):
+    """Plain CSV, no index column."""
+    report.to_csv(path, index=False)
