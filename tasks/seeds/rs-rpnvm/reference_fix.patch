+//! RPN stack machine for alert threshold formulas.
+//!
+//! Programs are whitespace-separated token streams evaluated left to right
+//! against a value stack with a hard depth limit. Variables live in the
+//! [`Vm`] and persist across `eval` calls; the stack does not. A program
+//! must finish with exactly one value — the result.
+//!
+//! All arithmetic is checked: overflow, division by zero, underflow, and
+//! depth-limit violations surface as typed [`VmError`]s carrying the
+//! 0-based index of the offending token.
+
+use std::collections::BTreeMap;
+use std::fmt;
+
+/// Evaluation failure. `index` is the 0-based position of the offending
+/// token in the whitespace-split program.
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum VmError {
+    /// The token is not a literal, operator, variable, or store.
+    UnknownToken { index: usize, token: String },
+    /// The token starts like an integer literal but is not a valid i64.
+    BadLiteral { index: usize, token: String },
+    /// A variable load referenced a name that was never bound.
+    UndefinedVar { index: usize, name: String },
+    /// An operation needed more operands than the stack holds.
+    StackUnderflow { index: usize, token: String },
+    /// A push was refused because it would exceed the configured depth.
+    StackOverflow { index: usize, depth: usize },
+    /// `/` or `%` with a zero divisor.
+    DivideByZero { index: usize },
+    /// Checked i64 arithmetic overflowed (e.g. i64::MIN / -1).
+    ArithmeticOverflow { index: usize },
+    /// The program ended with a stack depth other than one.
+    BadResult { depth: usize },
+}
+
+impl fmt::Display for VmError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            VmError::UnknownToken { index, token } => {
+                write!(f, "token {index}: unknown token \"{token}\"")
+            }
+            VmError::BadLiteral { index, token } => {
+                write!(f, "token {index}: bad integer literal \"{token}\"")
+            }
+            VmError::UndefinedVar { index, name } => {
+                write!(f, "token {index}: undefined variable \"{name}\"")
+            }
+            VmError::StackUnderflow { index, token } => {
+                write!(f, "token {index}: stack underflow at \"{token}\"")
+            }
+            VmError::StackOverflow { index, depth } => {
+                write!(f, "token {index}: stack overflow (depth {depth})")
+            }
+            VmError::DivideByZero { index } => {
+                write!(f, "token {index}: division by zero")
+            }
+            VmError::ArithmeticOverflow { index } => {
+                write!(f, "token {index}: arithmetic overflow")
+            }
+            VmError::BadResult { depth } => {
+                write!(
+                    f,
+                    "program left {depth} values on the stack (expected exactly 1)"
+                )
+            }
+        }
+    }
+}
+
+impl std::error::Error for VmError {}
+
+/// The formula machine: a variable environment plus a stack depth limit.
+pub struct Vm {
+    max_depth: usize,
+    vars: BTreeMap<String, i64>,
+}
+
+fn is_identifier(s: &str) -> bool {
+    let mut chars = s.chars();
+    match chars.next() {
+        Some(c) if c.is_ascii_lowercase() || c == '_' => {}
+        _ => return false,
+    }
+    chars.all(|c| c.is_ascii_lowercase() || c.is_ascii_digit() || c == '_')
+}
+
+/// Does the token *look like* an integer literal (so parse failures are
+/// [`VmError::BadLiteral`] rather than [`VmError::UnknownToken`])?
+fn looks_numeric(s: &str) -> bool {
+    let body = s.strip_prefix('-').unwrap_or(s);
+    body.starts_with(|c: char| c.is_ascii_digit())
+}
+
+fn pop(stack: &mut Vec<i64>, index: usize, token: &str) -> Result<i64, VmError> {
+    stack.pop().ok_or_else(|| VmError::StackUnderflow {
+        index,
+        token: token.to_string(),
+    })
+}
+
+impl Vm {
+    /// A machine whose value stack may hold at most `max_depth` entries.
+    pub fn new(max_depth: usize) -> Vm {
+        Vm {
+            max_depth,
+            vars: BTreeMap::new(),
+        }
+    }
+
+    /// Bind (or rebind) a variable.
+    pub fn set_var(&mut self, name: &str, value: i64) {
+        self.vars.insert(name.to_string(), value);
+    }
+
+    /// Current value of a variable, if bound.
+    pub fn get_var(&self, name: &str) -> Option<i64> {
+        self.vars.get(name).copied()
+    }
+
+    /// Evaluate one program. The stack starts empty; variables persist.
+    /// Side effects performed before an error stick.
+    pub fn eval(&mut self, program: &str) -> Result<i64, VmError> {
+        let mut stack: Vec<i64> = Vec::new();
+        let push = |stack: &mut Vec<i64>, index: usize, value: i64, max: usize| {
+            if stack.len() >= max {
+                return Err(VmError::StackOverflow {
+                    index,
+                    depth: stack.len(),
+                });
+            }
+            stack.push(value);
+            Ok(())
+        };
+
+        for (index, token) in program.split_whitespace().enumerate() {
+            match token {
+                "+" | "-" | "*" | "/" | "%" => {
+                    let rhs = pop(&mut stack, index, token)?;
+                    let lhs = pop(&mut stack, index, token)?;
+                    let result = match token {
+                        "+" => lhs.checked_add(rhs),
+                        "-" => lhs.checked_sub(rhs),
+                        "*" => lhs.checked_mul(rhs),
+                        "/" | "%" => {
+                            if rhs == 0 {
+                                return Err(VmError::DivideByZero { index });
+                            }
+                            if token == "/" {
+                                lhs.checked_div(rhs)
+                            } else {
+                                lhs.checked_rem(rhs)
+                            }
+                        }
+                        _ => unreachable!(),
+                    };
+                    let value = result.ok_or(VmError::ArithmeticOverflow { index })?;
+                    // net effect of a binary op is -1, so this cannot overflow,
+                    // but route through the guard for uniformity
+                    push(&mut stack, index, value, self.max_depth)?;
+                }
+                "neg" => {
+                    let v = pop(&mut stack, index, token)?;
+                    let value = v.checked_neg().ok_or(VmError::ArithmeticOverflow { index })?;
+                    push(&mut stack, index, value, self.max_depth)?;
+                }
+                "dup" => {
+                    let top = *stack.last().ok_or_else(|| VmError::StackUnderflow {
+                        index,
+                        token: token.to_string(),
+                    })?;
+                    push(&mut stack, index, top, self.max_depth)?;
+                }
+                "swap" => {
+                    let b = pop(&mut stack, index, token)?;
+                    let a = pop(&mut stack, index, token)?;
+                    stack.push(b);
+                    stack.push(a);
+                }
+                "drop" => {
+                    pop(&mut stack, index, token)?;
+                }
+                _ => {
+                    if looks_numeric(token) {
+                        let value: i64 =
+                            token.parse().map_err(|_| VmError::BadLiteral {
+                                index,
+                                token: token.to_string(),
+                            })?;
+                        push(&mut stack, index, value, self.max_depth)?;
+                    } else if let Some(name) = token.strip_prefix('!') {
+                        if !is_identifier(name) {
+                            return Err(VmError::UnknownToken {
+                                index,
+                                token: token.to_string(),
+                            });
+                        }
+                        let value = pop(&mut stack, index, token)?;
+                        self.vars.insert(name.to_string(), value);
+                    } else if is_identifier(token) {
+                        let value = *self.vars.get(token).ok_or_else(|| {
+                            VmError::UndefinedVar {
+                                index,
+                                name: token.to_string(),
+                            }
+                        })?;
+                        push(&mut stack, index, value, self.max_depth)?;
+                    } else {
+                        return Err(VmError::UnknownToken {
+                            index,
+                            token: token.to_string(),
+                        });
+                    }
+                }
+            }
+        }
+
+        if stack.len() != 1 {
+            return Err(VmError::BadResult { depth: stack.len() });
+        }
+        Ok(stack[0])
+    }
+}
