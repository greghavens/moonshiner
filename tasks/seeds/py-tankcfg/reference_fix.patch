+"""Escape handling for TankCfg display strings.
+
+The config format supports exactly five escape forms: \\\\, \\n, \\t,
+\\xHH (two hex digits) and \\uHHHH (four hex digits, UTF-16 surrogate
+pairs combining into one astral character). Files on disk are UTF-8 read
+and written with errors="surrogateescape" so bytes that are not valid
+UTF-8 survive a load/save round trip.
+"""
+
+_HEX = set("0123456789abcdefABCDEF")
+
+_SIMPLE_DECODE = {"\\": "\\", "n": "\n", "t": "\t"}
+
+
+class EscapeError(ValueError):
+    """A malformed escape sequence; .pos is the index of its backslash."""
+
+    def __init__(self, message, pos):
+        super().__init__("%s (position %d)" % (message, pos))
+        self.pos = pos
+
+
+def _hex_field(text, start, count, pos):
+    digits = text[start : start + count]
+    if len(digits) < count or any(d not in _HEX for d in digits):
+        raise EscapeError("expected %d hex digits" % count, pos)
+    return int(digits, 16)
+
+
+def _decode_u(text, pos):
+    """Decode one \\uHHHH escape at text[pos], pairing surrogates."""
+    value = _hex_field(text, pos + 2, 4, pos)
+    end = pos + 6
+    if 0xDC00 <= value <= 0xDFFF:
+        raise EscapeError("low surrogate without a leading high surrogate", pos)
+    if 0xD800 <= value <= 0xDBFF:
+        if not text.startswith("\\u", end):
+            raise EscapeError("high surrogate without a trailing low surrogate", pos)
+        low = _hex_field(text, end + 2, 4, pos)
+        if not 0xDC00 <= low <= 0xDFFF:
+            raise EscapeError("high surrogate without a trailing low surrogate", pos)
+        value = 0x10000 + ((value - 0xD800) << 10) + (low - 0xDC00)
+        end += 6
+    return chr(value), end
+
+
+def decode(text):
+    """Resolve TankCfg escapes in `text`, left to right."""
+    out = []
+    i = 0
+    while i < len(text):
+        ch = text[i]
+        if ch != "\\":
+            out.append(ch)
+            i += 1
+            continue
+        if i + 1 >= len(text):
+            raise EscapeError("trailing backslash", i)
+        marker = text[i + 1]
+        if marker in _SIMPLE_DECODE:
+            out.append(_SIMPLE_DECODE[marker])
+            i += 2
+        elif marker == "x":
+            out.append(chr(_hex_field(text, i + 2, 2, i)))
+            i += 4
+        elif marker == "u":
+            decoded, i = _decode_u(text, i)
+            out.append(decoded)
+        else:
+            raise EscapeError("unknown escape \\%s" % marker, i)
+    return "".join(out)
+
+
+def encode(text, ascii_only=False):
+    """Inverse of decode; with ascii_only, escape everything above U+007F."""
+    out = []
+    for ch in text:
+        cp = ord(ch)
+        if ch == "\\":
+            out.append("\\\\")
+        elif ch == "\n":
+            out.append("\\n")
+        elif ch == "\t":
+            out.append("\\t")
+        elif cp < 0x20 or cp == 0x7F:
+            out.append("\\x%02x" % cp)
+        elif ascii_only and cp > 0x7F:
+            if 0xD800 <= cp <= 0xDFFF:
+                raise ValueError(
+                    "lone surrogate U+%04X cannot be represented in ascii_only mode" % cp
+                )
+            if cp > 0xFFFF:
+                offset = cp - 0x10000
+                out.append("\\u%04x" % (0xD800 + (offset >> 10)))
+                out.append("\\u%04x" % (0xDC00 + (offset & 0x3FF)))
+            else:
+                out.append("\\u%04x" % cp)
+        else:
+            out.append(ch)
+    return "".join(out)
+
+
+def load_bytes(data):
+    """Escape-decode a raw config value read as bytes."""
+    return decode(data.decode("utf-8", errors="surrogateescape"))
+
+
+def dump_bytes(value):
+    """Encode a value back to the bytes that belong in the file."""
+    return encode(value).encode("utf-8", errors="surrogateescape")
