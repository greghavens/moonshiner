+++ b/fsm.ts
@@ -0,0 +1,98 @@
+export interface TransitionInfo {
+  from: string;
+  to: string;
+  event: string;
+  payload: unknown;
+  context: unknown;
+}
+
+type Hook = (info: TransitionInfo) => void;
+type Guard = (context: never, payload: never) => boolean;
+
+interface TransitionTarget {
+  target: string;
+  guard?: (context: unknown, payload: unknown) => boolean;
+}
+
+interface StateConfig {
+  on?: Record<string, string | TransitionTarget>;
+  onEnter?: (info: never) => void;
+  onExit?: (info: never) => void;
+}
+
+export interface MachineConfig {
+  initial: string;
+  context?: unknown;
+  states: Record<string, StateConfig>;
+  onTransition?: (info: never) => void;
+}
+
+export class InvalidTransitionError extends Error {
+  from: string;
+  event: string;
+
+  constructor(from: string, event: string) {
+    super(`no transition for event ${JSON.stringify(event)} from state ${JSON.stringify(from)}`);
+    this.name = 'InvalidTransitionError';
+    this.from = from;
+    this.event = event;
+  }
+}
+
+export class StateMachine {
+  context: unknown;
+  private current: string;
+  private config: MachineConfig;
+
+  constructor(config: MachineConfig) {
+    if (!Object.prototype.hasOwnProperty.call(config.states, config.initial)) {
+      throw new Error(`initial state ${JSON.stringify(config.initial)} is not a declared state`);
+    }
+    for (const [name, state] of Object.entries(config.states)) {
+      for (const [event, spec] of Object.entries(state.on ?? {})) {
+        const target = typeof spec === 'string' ? spec : spec.target;
+        if (!Object.prototype.hasOwnProperty.call(config.states, target)) {
+          throw new Error(
+            `transition ${name}:${event} targets unknown state ${JSON.stringify(target)}`,
+          );
+        }
+      }
+    }
+    this.config = config;
+    this.context = config.context;
+    this.current = config.initial;
+  }
+
+  get state(): string {
+    return this.current;
+  }
+
+  private resolve(event: string): TransitionTarget | null {
+    const spec = this.config.states[this.current].on?.[event];
+    if (spec === undefined) return null;
+    return typeof spec === 'string' ? { target: spec } : spec;
+  }
+
+  can(event: string, payload?: unknown): boolean {
+    const spec = this.resolve(event);
+    if (spec === null) return false;
+    if (spec.guard && !spec.guard(this.context, payload)) return false;
+    return true;
+  }
+
+  send(event: string, payload?: unknown): string {
+    const spec = this.resolve(event);
+    if (spec === null) throw new InvalidTransitionError(this.current, event);
+    if (spec.guard && !spec.guard(this.context, payload)) return this.current;
+
+    const from = this.current;
+    const to = spec.target;
+    const info: TransitionInfo = { from, to, event, payload, context: this.context };
+
+    (this.config.states[from].onExit as Hook | undefined)?.(info);
+    (this.config.onTransition as Hook | undefined)?.(info);
+    this.current = to;
+    (this.config.states[to].onEnter as Hook | undefined)?.(info);
+    return this.current;
+  }
+}
