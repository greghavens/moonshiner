diff --git a/arrlib.zsh b/arrlib.zsh
new file mode 100644
index 0000000..7d8f10b
--- /dev/null
+++ b/arrlib.zsh
@@ -0,0 +1,62 @@
+# arrlib.zsh — 1-indexed array operations, pure zsh.
+#
+# Sourceable; defines functions only. No external commands — these helpers
+# run in scripts where PATH may be empty. Convention: the first argument is
+# the NAME of an existing destination variable; internal locals are
+# __-prefixed so caller names like `out` or `cut` stay usable. Every
+# function pins its own options with `emulate -L zsh`, so callers running
+# under ksh_arrays / sh_word_split / glob_subst see identical results.
+
+arr_len() { # arr_len DEST NAME -- element count
+  emulate -L zsh
+  local -a __s=( "${(@P)2}" )
+  : ${(P)1::=${#__s}}
+}
+
+arr_slice() { # arr_slice DEST NAME FROM TO -- 1-indexed inclusive slice
+  emulate -L zsh
+  local -a __s=( "${(@P)2}" )
+  integer __len=${#__s} __from=$3 __to=$4
+  (( __from < 0 )) && (( __from += __len + 1 ))
+  (( __to < 0 ))   && (( __to += __len + 1 ))
+  (( __from < 1 ))     && __from=1
+  (( __to > __len ))   && __to=__len
+  if (( __from > __to )); then
+    set -A "$1"
+  else
+    set -A "$1" "${(@)__s[__from,__to]}"
+  fi
+}
+
+arr_rotate() { # arr_rotate DEST NAME N -- rotate left by N, wrapping
+  emulate -L zsh
+  local -a __s=( "${(@P)2}" )
+  integer __len=${#__s} __n=0
+  (( __len )) && (( __n = $3 % __len ))
+  set -A "$1" "${(@)__s[__n+1,-1]}" "${(@)__s[1,__n]}"
+}
+
+arr_unique() { # arr_unique DEST NAME -- first occurrence of each element
+  emulate -L zsh
+  local -a __s=( "${(@P)2}" )
+  set -A "$1" "${(@u)__s}"
+}
+
+arr_zip() { # arr_zip DEST A_NAME B_NAME -- interleave to the shorter length
+  emulate -L zsh
+  local -a __a=( "${(@P)2}" ) __b=( "${(@P)3}" ) __out
+  integer __n=${#__a} __i
+  (( ${#__b} < __n )) && __n=${#__b}
+  for (( __i = 1; __i <= __n; __i++ )); do
+    __out+=( "${__a[__i]}" "${__b[__i]}" )
+  done
+  set -A "$1" "${(@)__out}"
+}
+
+arr_index_of() { # arr_index_of DEST NAME NEEDLE -- first exact match or 0
+  emulate -L zsh
+  local -a __s=( "${(@P)2}" )
+  integer __i=${__s[(ie)$3]}
+  (( __i > ${#__s} )) && __i=0
+  : ${(P)1::=$__i}
+}
