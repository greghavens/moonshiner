@@ -0,0 +1,25 @@
+"""Errors for the Atlas cluster reconciler."""
+
+
+class AtlasApiError(Exception):
+    """Documented Atlas Administration API error envelope
+    (application/json: detail, error, errorCode, parameters, reason)."""
+
+    def __init__(self, status, error_code, detail="", parameters=None, reason=""):
+        self.status = status
+        self.error_code = error_code
+        self.detail = detail
+        self.parameters = list(parameters or [])
+        self.reason = reason
+        super().__init__(f"atlas: {status} {reason} ({error_code}): {detail}")
+
+
+class ClusterStateError(Exception):
+    """A watched cluster reached a state the reconcile can never recover
+    from (DELETING, or the cluster vanished mid-poll)."""
+
+    def __init__(self, cluster_name, state_name):
+        self.cluster_name = cluster_name
+        self.state_name = state_name
+        what = state_name if state_name is not None else "gone (404)"
+        super().__init__(f"cluster {cluster_name!r} reached terminal state: {what}")
