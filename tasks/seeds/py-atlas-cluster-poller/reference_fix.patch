+++ b/atlas_clusters/reconcile.py
@@ -0,0 +1,75 @@
+"""Create-or-update reconciliation with asynchronous state polling.
+
+stateName lifecycle per the official docs: IDLE means every requested
+change has been applied; CREATING/UPDATING/REPAIRING are in-flight;
+DELETING can never converge back to a present cluster, so it is terminal
+for this reconciler.
+"""
+from .errors import AtlasApiError, ClusterStateError
+
+_DONE = "IDLE"
+_TERMINAL = "DELETING"
+
+# The slice of the cluster document this reconciler owns and compares.
+_OWNED_TOP = ("clusterType", "mongoDBMajorVersion")
+_OWNED_REGION = ("providerName", "regionName", "priority")
+_OWNED_HARDWARE = ("instanceSize", "nodeCount", "diskSizeGB")
+
+
+class ClusterReconciler:
+    def __init__(self, client, sleep, poll_interval=2.0):
+        self._client = client
+        self._sleep = sleep
+        self._poll_interval = poll_interval
+
+    def reconcile(self, group_id, desired):
+        name = desired["name"]
+        try:
+            current = self._client.get_cluster(group_id, name)
+        except AtlasApiError as exc:
+            if exc.status != 404:
+                raise
+            created = self._client.create_cluster(group_id, desired)
+            final = self._await_idle(group_id, name, created)
+            return {"action": "created", "final": final}
+
+        if _projection(desired) == _projection(current):
+            return {"action": "unchanged", "final": current}
+
+        patched = self._client.update_cluster(
+            group_id, name, {"replicationSpecs": desired["replicationSpecs"]}
+        )
+        final = self._await_idle(group_id, name, patched)
+        return {"action": "updated", "final": final}
+
+    def _await_idle(self, group_id, name, cluster):
+        while True:
+            state = cluster.get("stateName")
+            if state == _DONE:
+                return cluster
+            if state == _TERMINAL:
+                raise ClusterStateError(name, state)
+            self._sleep(self._poll_interval)
+            try:
+                cluster = self._client.get_cluster(group_id, name)
+            except AtlasApiError as exc:
+                if exc.status == 404:
+                    # Vanished out from under us — terminal.
+                    raise ClusterStateError(name, None) from None
+                raise
+
+
+def _projection(cluster):
+    """The owned fields only — server-added ids/state/links are ignored."""
+    specs = []
+    for spec in cluster.get("replicationSpecs") or []:
+        regions = []
+        for rc in spec.get("regionConfigs") or []:
+            hw = rc.get("electableSpecs") or {}
+            regions.append((
+                tuple((k, rc.get(k)) for k in _OWNED_REGION),
+                tuple((k, hw.get(k)) for k in _OWNED_HARDWARE),
+            ))
+        specs.append((spec.get("zoneName"), tuple(regions)))
+    top = tuple((k, cluster.get(k)) for k in _OWNED_TOP)
+    return top, tuple(specs)
