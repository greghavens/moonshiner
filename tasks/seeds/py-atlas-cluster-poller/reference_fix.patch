+"""Minimal Atlas Administration API v2 client for the clusters resource.
+
+Wire contract researched from the official MongoDB documentation:
+  - https://www.mongodb.com/docs/api/doc/atlas-admin-api-v2/operation/operation-createcluster
+  - https://www.mongodb.com/docs/api/doc/atlas-admin-api-v2/operation/operation-getcluster
+  - https://www.mongodb.com/docs/atlas/api/versioned-api-overview/
+
+Atlas versions operations independently: the current GET media type for a
+cluster is 2024-08-05 while create/update use 2024-10-23.
+"""
+import json
+import urllib.error
+import urllib.request
+
+from .errors import AtlasApiError
+
+GET_MEDIA = "application/vnd.atlas.2024-08-05+json"
+WRITE_MEDIA = "application/vnd.atlas.2024-10-23+json"
+
+
+class AtlasClient:
+    def __init__(self, base_url, token):
+        if not base_url or not token:
+            raise ValueError("base_url and token are required")
+        self._base = base_url.rstrip("/")
+        self._token = token
+
+    # -- clusters resource -------------------------------------------------
+
+    def get_cluster(self, group_id, name):
+        return self._request("GET", self._cluster_path(group_id, name), accept=GET_MEDIA)
+
+    def create_cluster(self, group_id, spec):
+        return self._request(
+            "POST", f"/api/atlas/v2/groups/{group_id}/clusters",
+            accept=WRITE_MEDIA, body=spec,
+        )
+
+    def update_cluster(self, group_id, name, patch):
+        return self._request(
+            "PATCH", self._cluster_path(group_id, name),
+            accept=WRITE_MEDIA, body=patch,
+        )
+
+    # -- plumbing ----------------------------------------------------------
+
+    @staticmethod
+    def _cluster_path(group_id, name):
+        return f"/api/atlas/v2/groups/{group_id}/clusters/{name}"
+
+    def _request(self, method, path, accept, body=None):
+        data = json.dumps(body).encode() if body is not None else None
+        req = urllib.request.Request(self._base + path, data=data, method=method)
+        req.add_header("Authorization", "Bearer " + self._token)
+        req.add_header("Accept", accept)
+        if data is not None:
+            # Writes carry the dated media type as Content-Type too.
+            req.add_header("Content-Type", accept)
+        try:
+            with urllib.request.urlopen(req) as resp:
+                return json.loads(resp.read().decode() or "null")
+        except urllib.error.HTTPError as exc:
+            raise self._decode_error(exc) from None
+
+    @staticmethod
+    def _decode_error(exc):
+        try:
+            doc = json.loads(exc.read().decode())
+        except (ValueError, OSError):
+            doc = {}
+        return AtlasApiError(
+            status=exc.code,
+            error_code=doc.get("errorCode", ""),
+            detail=doc.get("detail", ""),
+            parameters=doc.get("parameters"),
+            reason=doc.get("reason", ""),
+        )
