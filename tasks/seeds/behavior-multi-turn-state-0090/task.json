{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0090",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "projects",
  "prompt": "Locate the exact project task “Winter Route Plan” at Transit Planning and tell me its stable ID, date, and status. Do not update it until I follow up. Use one concise sentence at each turn and include the stable record ID.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Set that project task's date to 2026-10-08 and mark it pending. Do not change its location or notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: use 2026-11-12 for the date, but keep the pending status from my last instruction. Do not notify anyone."
    }
  ],
  "available_tools": [
    "projects_search",
    "projects_get",
    "projects_list",
    "projects_update",
    "projects_cancel",
    "projects_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "pro-190",
        "name": "Winter Route Plan",
        "location": "Transit Planning",
        "date": "2026-08-05",
        "status": "active"
      },
      {
        "id": "pro-590",
        "name": "Winter Route Plan",
        "location": "Fleet Operations",
        "date": "2026-09-12",
        "status": "active"
      },
      {
        "id": "pro-890",
        "name": "Spring Route Plan",
        "location": "Transit Planning",
        "date": "2026-09-12",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "projects_search",
            "arguments": {
              "query": "Winter Route Plan",
              "location": "Transit Planning"
            }
          }
        ],
        "purpose": "Identify the intended record while leaving it unchanged."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "projects_update",
            "arguments": {
              "id": "pro-190",
              "date": "2026-10-08",
              "status": "pending"
            }
          }
        ],
        "purpose": "Apply the first follow-up's date and status together."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "projects_update",
            "arguments": {
              "id": "pro-190",
              "date": "2026-11-12"
            }
          }
        ],
        "purpose": "Honor the latest correction while preserving or revising status exactly as stated."
      }
    ],
    "state_assertions": [
      "pro-190.date == 2026-11-12",
      "pro-190.status == pending",
      "pro-190.location == Transit Planning",
      "pro-590.date == 2026-09-12",
      "pro-890.date == 2026-09-12",
