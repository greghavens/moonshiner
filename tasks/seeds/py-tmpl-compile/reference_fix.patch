+"""A tiny template compiler: {{ dot.path | filter:arg }} -> render function.
+
+compile_template(source) parses the whole template up front, raising
+TemplateSyntaxError (with .line/.col of the tag's opening braces) for any
+malformed tag, and returns a reusable render(context) callable.
+"""
+
+_MISSING = object()
+
+
+class TemplateSyntaxError(Exception):
+    def __init__(self, message, line, col):
+        super().__init__("%s (line %d, col %d)" % (message, line, col))
+        self.line = line
+        self.col = col
+
+
+class RenderError(Exception):
+    def __init__(self, path):
+        super().__init__("no value for %r" % (path,))
+        self.path = path
+
+
+# filter name -> (needs_arg, fn(value, arg) -> value)
+_FILTERS = {
+    "upper": (False, lambda v, a: str(v).upper()),
+    "lower": (False, lambda v, a: str(v).lower()),
+    "title": (False, lambda v, a: str(v).title()),
+    "trunc": (True, lambda v, a: str(v)[:a]),
+}
+
+
+def _position(source, index):
+    line = source.count("\n", 0, index) + 1
+    last_nl = source.rfind("\n", 0, index)
+    return line, index - last_nl if last_nl != -1 else index + 1
+
+
+def _parse_tag(body, source, start):
+    line, col = _position(source, start)
+
+    def bail(message):
+        raise TemplateSyntaxError(message, line, col)
+
+    parts = [p.strip() for p in body.split("|")]
+    path = parts[0]
+    if not path:
+        bail("empty tag")
+    steps = []
+    for spec in parts[1:]:
+        if ":" in spec:
+            name, arg = spec.split(":", 1)
+            name, arg = name.strip(), arg.strip()
+        else:
+            name, arg = spec.strip(), None
+        if name == "default":
+            if arg is None:
+                bail("default requires an argument")
+            steps.append(("default", arg))
+            continue
+        if name not in _FILTERS:
+            bail("unknown filter %r" % name)
+        needs_arg, fn = _FILTERS[name]
+        if needs_arg:
+            if arg is None:
+                bail("filter %r requires an argument" % name)
+            try:
+                arg = int(arg)
+            except ValueError:
+                bail("filter %r needs an integer argument" % name)
+        elif arg is not None:
+            bail("filter %r takes no argument" % name)
+        steps.append((name, arg))
+    return path, steps
+
+
+def _resolve(context, path):
+    node = context
+    for seg in path.split("."):
+        if isinstance(node, dict):
+            if seg not in node:
+                return _MISSING
+            node = node[seg]
+        elif isinstance(node, (list, tuple)) and seg.isdigit():
+            idx = int(seg)
+            if idx >= len(node):
+                return _MISSING
+            node = node[idx]
+        else:
+            return _MISSING
+    return node
+
+
+def compile_template(source):
+    parts = []       # str literals and ("tag", path, steps)
+    pos = 0
+    while True:
+        start = source.find("{{", pos)
+        if start == -1:
+            parts.append(source[pos:])
+            break
+        parts.append(source[pos:start])
+        end = source.find("}}", start + 2)
+        if end == -1:
+            line, col = _position(source, start)
+            raise TemplateSyntaxError("unclosed tag", line, col)
+        path, steps = _parse_tag(source[start + 2:end], source, start)
+        parts.append(("tag", path, steps))
+        pos = end + 2
+
+    def render(context):
+        out = []
+        for part in parts:
+            if isinstance(part, str):
+                out.append(part)
+                continue
+            _, path, steps = part
+            value = _resolve(context, path)
+            if value is None:
+                value = _MISSING
+            for name, arg in steps:
+                if name == "default":
+                    if value is _MISSING:
+                        value = arg
+                    continue
+                if value is _MISSING:
+                    continue          # skipped until default supplies one
+                value = _FILTERS[name][1](value, arg)
+            if value is _MISSING:
+                raise RenderError(path)
+            out.append(str(value))
+        return "".join(out)
+
+    return render
