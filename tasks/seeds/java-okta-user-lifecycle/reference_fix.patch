diff --git a/MiniJson.java b/MiniJson.java
new file mode 100644
index 0000000..07de655
--- /dev/null
+++ b/MiniJson.java
@@ -0,0 +1,156 @@
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/** Minimal JSON reader/writer for the Okta wire format (objects, arrays,
+ *  strings, numbers, booleans, null). */
+final class MiniJson {
+
+    private final String s;
+    private int i;
+
+    private MiniJson(String s) { this.s = s; }
+
+    static Object parse(String text) {
+        MiniJson p = new MiniJson(text);
+        Object v = p.value();
+        p.ws();
+        if (p.i != p.s.length()) throw new IllegalArgumentException("trailing JSON at offset " + p.i);
+        return v;
+    }
+
+    @SuppressWarnings("unchecked")
+    static Map<String, Object> parseObject(String text) {
+        return (Map<String, Object>) parse(text);
+    }
+
+    private void ws() { while (i < s.length() && Character.isWhitespace(s.charAt(i))) i++; }
+
+    private Object value() {
+        ws();
+        char c = s.charAt(i);
+        if (c == '{') return object();
+        if (c == '[') return array();
+        if (c == '"') return string();
+        if (s.startsWith("true", i)) { i += 4; return Boolean.TRUE; }
+        if (s.startsWith("false", i)) { i += 5; return Boolean.FALSE; }
+        if (s.startsWith("null", i)) { i += 4; return null; }
+        int j = i;
+        while (j < s.length() && "-+.eE0123456789".indexOf(s.charAt(j)) >= 0) j++;
+        double d = Double.parseDouble(s.substring(i, j));
+        i = j;
+        return d;
+    }
+
+    private Map<String, Object> object() {
+        Map<String, Object> m = new LinkedHashMap<>();
+        i++; ws();
+        if (s.charAt(i) == '}') { i++; return m; }
+        while (true) {
+            ws();
+            String k = string();
+            ws();
+            if (s.charAt(i++) != ':') throw new IllegalArgumentException("expected ':' at offset " + (i - 1));
+            m.put(k, value());
+            ws();
+            char c = s.charAt(i++);
+            if (c == '}') return m;
+            if (c != ',') throw new IllegalArgumentException("expected ',' or '}' at offset " + (i - 1));
+        }
+    }
+
+    private List<Object> array() {
+        List<Object> a = new ArrayList<>();
+        i++; ws();
+        if (s.charAt(i) == ']') { i++; return a; }
+        while (true) {
+            a.add(value());
+            ws();
+            char c = s.charAt(i++);
+            if (c == ']') return a;
+            if (c != ',') throw new IllegalArgumentException("expected ',' or ']' at offset " + (i - 1));
+        }
+    }
+
+    private String string() {
+        if (s.charAt(i) != '"') throw new IllegalArgumentException("expected string at offset " + i);
+        StringBuilder b = new StringBuilder();
+        i++;
+        while (true) {
+            char c = s.charAt(i++);
+            if (c == '"') return b.toString();
+            if (c == '\\') {
+                char e = s.charAt(i++);
+                switch (e) {
+                    case '"' -> b.append('"');
+                    case '\\' -> b.append('\\');
+                    case '/' -> b.append('/');
+                    case 'n' -> b.append('\n');
+                    case 't' -> b.append('\t');
+                    case 'r' -> b.append('\r');
+                    case 'b' -> b.append('\b');
+                    case 'f' -> b.append('\f');
+                    case 'u' -> {
+                        b.append((char) Integer.parseInt(s.substring(i, i + 4), 16));
+                        i += 4;
+                    }
+                    default -> throw new IllegalArgumentException("bad escape \\" + e);
+                }
+            } else {
+                b.append(c);
+            }
+        }
+    }
+
+    static String write(Object v) {
+        StringBuilder b = new StringBuilder();
+        writeTo(b, v);
+        return b.toString();
+    }
+
+    private static void writeTo(StringBuilder b, Object v) {
+        if (v == null) {
+            b.append("null");
+        } else if (v instanceof String str) {
+            b.append('"');
+            for (int k = 0; k < str.length(); k++) {
+                char c = str.charAt(k);
+                switch (c) {
+                    case '"' -> b.append("\\\"");
+                    case '\\' -> b.append("\\\\");
+                    case '\n' -> b.append("\\n");
+                    case '\r' -> b.append("\\r");
+                    case '\t' -> b.append("\\t");
+                    default -> {
+                        if (c < 0x20) b.append(String.format("\\u%04x", (int) c));
+                        else b.append(c);
+                    }
+                }
+            }
+            b.append('"');
+        } else if (v instanceof Map<?, ?> m) {
+            b.append('{');
+            boolean first = true;
+            for (Map.Entry<?, ?> e : m.entrySet()) {
+                if (!first) b.append(',');
+                first = false;
+                writeTo(b, String.valueOf(e.getKey()));
+                b.append(':');
+                writeTo(b, e.getValue());
+            }
+            b.append('}');
+        } else if (v instanceof List<?> a) {
+            b.append('[');
+            for (int k = 0; k < a.size(); k++) {
+                if (k > 0) b.append(',');
+                writeTo(b, a.get(k));
+            }
+            b.append(']');
+        } else if (v instanceof Boolean || v instanceof Number) {
+            b.append(v);
+        } else {
+            throw new IllegalArgumentException("cannot serialize " + v.getClass());
+        }
+    }
+}
diff --git a/OktaApiException.java b/OktaApiException.java
new file mode 100644
index 0000000..12ea1e9
--- /dev/null
+++ b/OktaApiException.java
@@ -0,0 +1,58 @@
+import java.util.List;
+import java.util.Map;
+
+/** Okta API error envelope. Okta reports every failure with the same JSON
+ *  shape; the errorCode — not the HTTP status — identifies the failure class
+ *  (E0000006 and E0000016 are both 403s). Messages carry the envelope fields
+ *  only, never credentials. */
+public class OktaApiException extends RuntimeException {
+
+    private final int status;
+    private final String errorCode;
+    private final String errorSummary;
+    private final String errorId;
+    private final List<String> errorCauses;
+
+    OktaApiException(int status, String errorCode, String errorSummary, String errorId,
+                     List<String> errorCauses) {
+        super("Okta API error " + errorCode + " (HTTP " + status + "): " + errorSummary);
+        this.status = status;
+        this.errorCode = errorCode;
+        this.errorSummary = errorSummary;
+        this.errorId = errorId;
+        this.errorCauses = List.copyOf(errorCauses);
+    }
+
+    public int status() { return status; }
+
+    public String errorCode() { return errorCode; }
+
+    public String errorSummary() { return errorSummary; }
+
+    public String errorId() { return errorId; }
+
+    public List<String> errorCauses() { return errorCauses; }
+
+    /** Builds the taxonomy-correct exception from an Okta error envelope. */
+    static OktaApiException from(int status, Map<String, Object> body) {
+        String code = str(body.get("errorCode"));
+        String summary = str(body.get("errorSummary"));
+        String id = str(body.get("errorId"));
+        List<String> causes = new java.util.ArrayList<>();
+        if (body.get("errorCauses") instanceof List<?> raw) {
+            for (Object c : raw) {
+                if (c instanceof Map<?, ?> m && m.get("errorSummary") != null) {
+                    causes.add(String.valueOf(m.get("errorSummary")));
+                }
+            }
+        }
+        return switch (code == null ? "" : code) {
+            case "E0000001" -> new OktaValidationException(status, code, summary, id, causes);
+            case "E0000006" -> new OktaPermissionException(status, code, summary, id, causes);
+            case "E0000016" -> new OktaTransitionException(status, code, summary, id, causes);
+            default -> new OktaApiException(status, code, summary, id, causes);
+        };
+    }
+
+    private static String str(Object o) { return o == null ? null : String.valueOf(o); }
+}
