+
+/** 400 E0000001 — the request payload failed Okta schema validation; the
+ *  errorCauses list carries the per-field problems in order. */
+public class OktaValidationException extends OktaApiException {
+    OktaValidationException(int status, String errorCode, String errorSummary, String errorId,
+                            List<String> errorCauses) {
+        super(status, errorCode, errorSummary, errorId, errorCauses);
+    }
+}
diff --git a/UserLifecycleClient.java b/UserLifecycleClient.java
new file mode 100644
index 0000000..d4666e7
--- /dev/null
+++ b/UserLifecycleClient.java
@@ -0,0 +1,101 @@
+import java.io.IOException;
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.util.Map;
+import java.util.function.IntConsumer;
+
+/**
+ * Client for the Okta Users API lifecycle flow used by contractor onboarding:
+ * stage a user ahead of the start date, activate on day one, and poll the
+ * asynchronous transition to its terminal status.
+ *
+ * Wire contract per the Okta management API reference (/api/v1): SSWS auth,
+ * application/json both ways, profile fields nested under "profile", and
+ * lifecycle operations as POST sub-resources of the user.
+ */
+public final class UserLifecycleClient {
+
+    private final String base;
+    private final String apiToken;
+    private final HttpClient http;
+
+    public UserLifecycleClient(String orgBaseUrl, String apiToken) {
+        this.base = orgBaseUrl.endsWith("/")
+                ? orgBaseUrl.substring(0, orgBaseUrl.length() - 1)
+                : orgBaseUrl;
+        this.apiToken = apiToken;
+        this.http = HttpClient.newHttpClient();
+    }
+
+    /**
+     * Creates the user in STAGED status. Okta's create operation defaults to
+     * activate=true, which would kick off activation (and email) immediately,
+     * so staging must send activate=false explicitly.
+     */
+    public OktaUser createStaged(Map<String, String> profileFields) {
+        String body = MiniJson.write(Map.of("profile", profileFields));
+        return OktaUser.fromJson(exchange("POST", "/api/v1/users?activate=false", body));
+    }
+
+    /**
+     * Runs the activate lifecycle operation. Only legal from STAGED or
+     * DEPROVISIONED; Okta answers 403 E0000016 otherwise, which surfaces as
+     * OktaTransitionException. With sendEmail=false the response carries the
+     * activation token and welcome URL for our own delivery channel.
+     */
+    public ActivationResult activate(String userId, boolean sendEmail) {
+        Map<String, Object> doc = exchange(
+                "POST", "/api/v1/users/" + userId + "/lifecycle/activate?sendEmail=" + sendEmail, "");
+        return new ActivationResult(
+                doc.get("activationToken") == null ? null : String.valueOf(doc.get("activationToken")),
+                doc.get("activationUrl") == null ? null : String.valueOf(doc.get("activationUrl")));
+    }
+
+    public OktaUser getUser(String userId) {
+        return OktaUser.fromJson(exchange("GET", "/api/v1/users/" + userId, null));
+    }
+
+    /**
+     * Polls the user until its status reaches {@code targetStatus}.
+     * Activation is asynchronous (the document reports transitioningToStatus
+     * while in flight), so callers poll; {@code pacer} is invoked between
+     * consecutive polls with the 1-based count of polls performed so far and
+     * owns all delay decisions — this method never sleeps.
+     */
+    public OktaUser waitForStatus(String userId, String targetStatus, int maxPolls, IntConsumer pacer) {
+        for (int attempt = 1; attempt <= maxPolls; attempt++) {
+            OktaUser user = getUser(userId);
+            if (targetStatus.equals(user.status())) return user;
+            if (attempt < maxPolls) pacer.accept(attempt);
+        }
+        throw new OktaTransitionTimeout(
+                "user " + userId + " did not reach status " + targetStatus + " within " + maxPolls + " polls");
+    }
+
+    private Map<String, Object> exchange(String method, String pathAndQuery, String body) {
+        HttpRequest.Builder builder = HttpRequest.newBuilder(URI.create(base + pathAndQuery))
+                .header("Authorization", "SSWS " + apiToken)
+                .header("Accept", "application/json");
+        if (body != null) {
+            builder.header("Content-Type", "application/json")
+                    .method(method, HttpRequest.BodyPublishers.ofString(body));
+        } else {
+            builder.method(method, HttpRequest.BodyPublishers.noBody());
+        }
+        HttpResponse<String> response;
+        try {
+            response = http.send(builder.build(), HttpResponse.BodyHandlers.ofString());
+        } catch (IOException e) {
+            throw new RuntimeException("Okta request failed: " + method + " " + pathAndQuery, e);
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new RuntimeException("Okta request interrupted", e);
+        }
+        if (response.statusCode() / 100 != 2) {
+            throw OktaApiException.from(response.statusCode(), MiniJson.parseObject(response.body()));
+        }
+        return MiniJson.parseObject(response.body());
+    }
+}
