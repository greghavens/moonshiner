@@ -0,0 +1,11 @@
+import java.util.List;
+
+/** 403 E0000016 — the lifecycle operation is illegal from the user's current
+ *  status (e.g. activating an already-active user). Same HTTP status as a
+ *  permission failure, different remediation entirely. */
+public class OktaTransitionException extends OktaApiException {
+    OktaTransitionException(int status, String errorCode, String errorSummary, String errorId,
+                            List<String> errorCauses) {
+        super(status, errorCode, errorSummary, errorId, errorCauses);
+    }
+}
