diff --git a/OktaUser.java b/OktaUser.java
new file mode 100644
index 0000000..27170a9
--- /dev/null
+++ b/OktaUser.java
@@ -0,0 +1,75 @@
+import java.util.Collections;
+import java.util.LinkedHashMap;
+import java.util.Map;
+
+/** A user document as returned by the Okta Users API. Field and link data are
+ *  kept verbatim from the wire; the set of HAL relations changes as the user
+ *  moves through the lifecycle. */
+final class OktaUser {
+
+    private final String id;
+    private final String status;
+    private final String transitioningToStatus;
+    private final String created;
+    private final String activated;
+    private final String statusChanged;
+    private final Map<String, String> profile;
+    private final Map<String, String> links;
+
+    private OktaUser(String id, String status, String transitioningToStatus, String created,
+                     String activated, String statusChanged, Map<String, String> profile,
+                     Map<String, String> links) {
+        this.id = id;
+        this.status = status;
+        this.transitioningToStatus = transitioningToStatus;
+        this.created = created;
+        this.activated = activated;
+        this.statusChanged = statusChanged;
+        this.profile = Collections.unmodifiableMap(profile);
+        this.links = Collections.unmodifiableMap(links);
+    }
+
+    static OktaUser fromJson(Map<String, Object> doc) {
+        Map<String, String> profile = new LinkedHashMap<>();
+        if (doc.get("profile") instanceof Map<?, ?> p) {
+            for (Map.Entry<?, ?> e : p.entrySet()) {
+                if (e.getValue() != null) profile.put(String.valueOf(e.getKey()), String.valueOf(e.getValue()));
+            }
+        }
+        Map<String, String> links = new LinkedHashMap<>();
+        if (doc.get("_links") instanceof Map<?, ?> l) {
+            for (Map.Entry<?, ?> e : l.entrySet()) {
+                if (e.getValue() instanceof Map<?, ?> rel && rel.get("href") != null) {
+                    links.put(String.valueOf(e.getKey()), String.valueOf(rel.get("href")));
+                }
+            }
+        }
+        return new OktaUser(
+                str(doc.get("id")),
+                str(doc.get("status")),
+                str(doc.get("transitioningToStatus")),
+                str(doc.get("created")),
+                str(doc.get("activated")),
+                str(doc.get("statusChanged")),
+                profile,
+                links);
+    }
+
+    private static String str(Object o) { return o == null ? null : String.valueOf(o); }
+
+    public String id() { return id; }
+
+    public String status() { return status; }
+
+    public String transitioningToStatus() { return transitioningToStatus; }
+
+    public String created() { return created; }
+
+    public String activated() { return activated; }
+
+    public String statusChanged() { return statusChanged; }
+
+    public Map<String, String> profile() { return profile; }
+
+    public Map<String, String> links() { return links; }
+}
