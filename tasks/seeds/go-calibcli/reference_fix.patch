@@ -0,0 +1,60 @@
+package calibcli
+
+import (
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io/fs"
+	"os"
+	"sort"
+)
+
+// instrument is one tracked bench instrument. Last is the date of the most
+// recent calibration in YYYY-MM-DD form, empty when never calibrated.
+type instrument struct {
+	Name         string `json:"name"`
+	IntervalDays int    `json:"interval_days"`
+	Last         string `json:"last,omitempty"`
+}
+
+type registry struct {
+	Instruments map[string]instrument `json:"instruments"`
+}
+
+// loadRegistry reads the state file. A missing file is an empty registry:
+// first use creates it on the next save.
+func loadRegistry(path string) (registry, error) {
+	data, err := os.ReadFile(path)
+	if errors.Is(err, fs.ErrNotExist) {
+		return registry{Instruments: map[string]instrument{}}, nil
+	}
+	if err != nil {
+		return registry{}, fmt.Errorf("reading state file: %w", err)
+	}
+	var reg registry
+	if err := json.Unmarshal(data, &reg); err != nil {
+		return registry{}, fmt.Errorf("parsing state file %s: %w", path, err)
+	}
+	if reg.Instruments == nil {
+		reg.Instruments = map[string]instrument{}
+	}
+	return reg, nil
+}
+
+func saveRegistry(path string, reg registry) error {
+	data, err := json.MarshalIndent(reg, "", "  ")
+	if err != nil {
+		return err
+	}
+	return os.WriteFile(path, append(data, '\n'), 0o644)
+}
+
+// sortedIDs returns the instrument IDs in ascending order for stable output.
+func (r registry) sortedIDs() []string {
+	ids := make([]string, 0, len(r.Instruments))
+	for id := range r.Instruments {
+		ids = append(ids, id)
+	}
+	sort.Strings(ids)
+	return ids
+}
