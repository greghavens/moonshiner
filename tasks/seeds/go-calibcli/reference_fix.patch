@@ -0,0 +1,43 @@
+// Package calibcli is the instrument-calibration tracker command tree. It is
+// deliberately library-shaped: NewRootCmd builds a fresh, self-contained tree
+// per call so the ops multitool can mount it and tests can drive it
+// in-process.
+package calibcli
+
+import (
+	"fmt"
+	"time"
+
+	"github.com/spf13/cobra"
+)
+
+// NewRootCmd builds the calib command tree. No package-level state: every
+// invocation reads and writes the JSON file named by --db.
+func NewRootCmd() *cobra.Command {
+	root := &cobra.Command{
+		Use:           "calib",
+		Short:         "track bench-instrument calibrations",
+		SilenceUsage:  true,
+		SilenceErrors: true,
+	}
+	root.PersistentFlags().String("db", "", "path to the JSON state file")
+	if err := root.MarkPersistentFlagRequired("db"); err != nil {
+		panic(err)
+	}
+	root.AddCommand(newAddCmd(), newLogCmd(), newDueCmd(), newListCmd())
+	return root
+}
+
+const dateLayout = "2006-01-02"
+
+func parseDate(raw string) (time.Time, error) {
+	t, err := time.Parse(dateLayout, raw)
+	if err != nil {
+		return time.Time{}, fmt.Errorf("invalid date %q: expected YYYY-MM-DD", raw)
+	}
+	return t, nil
+}
+
+func stateFile(cmd *cobra.Command) (string, error) {
+	return cmd.Flags().GetString("db")
+}
