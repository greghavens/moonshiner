+package calibcli
+
+import (
+	"errors"
+	"fmt"
+	"sort"
+	"time"
+
+	"github.com/spf13/cobra"
+)
+
+func newAddCmd() *cobra.Command {
+	cmd := &cobra.Command{
+		Use:   "add ID",
+		Short: "register an instrument",
+		Args:  cobra.ExactArgs(1),
+		RunE: func(cmd *cobra.Command, args []string) error {
+			id := args[0]
+			name, _ := cmd.Flags().GetString("name")
+			interval, _ := cmd.Flags().GetInt("interval-days")
+			if interval <= 0 {
+				return errors.New("interval-days must be positive")
+			}
+			path, err := stateFile(cmd)
+			if err != nil {
+				return err
+			}
+			reg, err := loadRegistry(path)
+			if err != nil {
+				return err
+			}
+			if _, exists := reg.Instruments[id]; exists {
+				return fmt.Errorf("instrument %q already registered", id)
+			}
+			reg.Instruments[id] = instrument{Name: name, IntervalDays: interval}
+			if err := saveRegistry(path, reg); err != nil {
+				return err
+			}
+			fmt.Fprintf(cmd.OutOrStdout(), "registered %s (every %dd)\n", id, interval)
+			return nil
+		},
+	}
+	cmd.Flags().String("name", "", "human-readable instrument name")
+	cmd.Flags().Int("interval-days", 0, "calibration interval in days")
+	for _, f := range []string{"name", "interval-days"} {
+		if err := cmd.MarkFlagRequired(f); err != nil {
+			panic(err)
+		}
+	}
+	return cmd
+}
+
+func newLogCmd() *cobra.Command {
+	cmd := &cobra.Command{
+		Use:   "log ID",
+		Short: "record a calibration",
+		Args:  cobra.ExactArgs(1),
+		RunE: func(cmd *cobra.Command, args []string) error {
+			id := args[0]
+			raw, _ := cmd.Flags().GetString("date")
+			when, err := parseDate(raw)
+			if err != nil {
+				return err
+			}
+			path, err := stateFile(cmd)
+			if err != nil {
+				return err
+			}
+			reg, err := loadRegistry(path)
+			if err != nil {
+				return err
+			}
+			inst, exists := reg.Instruments[id]
+			if !exists {
+				return fmt.Errorf("unknown instrument %q", id)
+			}
+			inst.Last = when.Format(dateLayout)
+			reg.Instruments[id] = inst
+			if err := saveRegistry(path, reg); err != nil {
+				return err
+			}
+			fmt.Fprintf(cmd.OutOrStdout(), "logged %s at %s\n", id, inst.Last)
+			return nil
+		},
+	}
+	cmd.Flags().String("date", "", "calibration date (YYYY-MM-DD)")
+	if err := cmd.MarkFlagRequired("date"); err != nil {
+		panic(err)
+	}
+	return cmd
+}
+
+func newDueCmd() *cobra.Command {
+	cmd := &cobra.Command{
+		Use:   "due",
+		Short: "list instruments due for calibration",
+		Args:  cobra.NoArgs,
+		RunE: func(cmd *cobra.Command, args []string) error {
+			raw, _ := cmd.Flags().GetString("as-of")
+			asOf, err := parseDate(raw)
+			if err != nil {
+				return err
+			}
+			path, err := stateFile(cmd)
+			if err != nil {
+				return err
+			}
+			reg, err := loadRegistry(path)
+			if err != nil {
+				return err
+			}
+
+			var never []string
+			type dueEntry struct {
+				id  string
+				due time.Time
+			}
+			var dated []dueEntry
+			for _, id := range reg.sortedIDs() {
+				inst := reg.Instruments[id]
+				if inst.Last == "" {
+					never = append(never, id)
+					continue
+				}
+				last, err := parseDate(inst.Last)
+				if err != nil {
+					return err
+				}
+				due := last.AddDate(0, 0, inst.IntervalDays)
+				if !due.After(asOf) {
+					dated = append(dated, dueEntry{id: id, due: due})
+				}
+			}
+			sort.SliceStable(dated, func(i, j int) bool {
+				if !dated[i].due.Equal(dated[j].due) {
+					return dated[i].due.Before(dated[j].due)
+				}
+				return dated[i].id < dated[j].id
+			})
+
+			out := cmd.OutOrStdout()
+			if len(never) == 0 && len(dated) == 0 {
+				fmt.Fprintln(out, "nothing due")
+				return nil
+			}
+			for _, id := range never {
+				fmt.Fprintf(out, "%s never calibrated\n", id)
+			}
+			for _, e := range dated {
+				overdue := int(asOf.Sub(e.due).Hours() / 24)
+				fmt.Fprintf(out, "%s due %s (%dd overdue)\n", e.id, e.due.Format(dateLayout), overdue)
+			}
+			return nil
+		},
+	}
+	cmd.Flags().String("as-of", "", "report date (YYYY-MM-DD)")
+	if err := cmd.MarkFlagRequired("as-of"); err != nil {
+		panic(err)
+	}
+	return cmd
+}
+
+func newListCmd() *cobra.Command {
+	return &cobra.Command{
+		Use:   "list",
+		Short: "list every registered instrument",
+		Args:  cobra.NoArgs,
+		RunE: func(cmd *cobra.Command, args []string) error {
+			path, err := stateFile(cmd)
+			if err != nil {
+				return err
+			}
+			reg, err := loadRegistry(path)
+			if err != nil {
+				return err
+			}
+			out := cmd.OutOrStdout()
+			if len(reg.Instruments) == 0 {
+				fmt.Fprintln(out, "no instruments")
+				return nil
+			}
+			for _, id := range reg.sortedIDs() {
+				inst := reg.Instruments[id]
+				last := inst.Last
+				if last == "" {
+					last = "never"
+				}
+				fmt.Fprintf(out, "%s  %s  every %dd  last %s\n", id, inst.Name, inst.IntervalDays, last)
+			}
+			return nil
+		},
+	}
+}
