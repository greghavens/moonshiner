+// Command calib is the standalone binary wrapper around the calibcli tree.
+package main
+
+import (
+	"os"
+
+	calibcli "go-calibcli"
+)
+
+func main() {
+	if err := calibcli.NewRootCmd().Execute(); err != nil {
+		os.Exit(1)
+	}
+}
