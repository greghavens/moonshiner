+// classkit — class-name composition for the design system.
+//
+// cx() flattens/dedupes class inputs; variants() builds component recipes
+// (base + axes + compound rules) that render through cx.
+
+function collect(input, out) {
+  if (typeof input === "string") {
+    for (const token of input.split(/\s+/)) {
+      if (token) out.push(token);
+    }
+    return;
+  }
+  if (Array.isArray(input)) {
+    for (const item of input) collect(item, out);
+    return;
+  }
+  if (input !== null && typeof input === "object") {
+    for (const [key, value] of Object.entries(input)) {
+      if (value) collect(key, out);
+    }
+  }
+  // numbers, booleans, null, undefined: nothing to contribute
+}
+
+/** Compose class names: strings, nested arrays, {token: truthy} objects. */
+export function cx(...inputs) {
+  const tokens = [];
+  collect(inputs, tokens);
+  const seen = new Set();
+  const kept = [];
+  for (const token of tokens) {
+    if (!seen.has(token)) {
+      seen.add(token);
+      kept.push(token);
+    }
+  }
+  return kept.join(" ");
+}
+
+/** Build a render function for a component recipe. */
+export function variants(config = {}) {
+  const axes = config.variants ?? {};
+  const defaults = config.defaults ?? {};
+  const compound = config.compound ?? [];
+
+  return function render(opts = {}, ...extras) {
+    for (const [axis, value] of Object.entries(opts)) {
+      if (value === undefined) continue;
+      if (!Object.hasOwn(axes, axis)) {
+        throw new Error(`unknown variant: ${axis}`);
+      }
+      if (!Object.hasOwn(axes[axis], value)) {
+        throw new Error(`unknown ${axis}: ${value}`);
+      }
+    }
+
+    const chosen = {};
+    for (const axis of Object.keys(axes)) {
+      const value = opts[axis] !== undefined ? opts[axis] : defaults[axis];
+      if (value !== undefined) chosen[axis] = value;
+    }
+
+    const parts = [config.base];
+    for (const axis of Object.keys(axes)) {
+      if (axis in chosen) parts.push(axes[axis][chosen[axis]]);
+    }
+    for (const rule of compound) {
+      const hit = Object.entries(rule.when ?? {})
+        .every(([axis, value]) => chosen[axis] === value);
+      if (hit) parts.push(rule.use);
+    }
+    return cx(parts, extras);
+  };
+}
