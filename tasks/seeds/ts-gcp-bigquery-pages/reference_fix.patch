index 0000000..c3d4419
--- /dev/null
+++ b/bq/params.ts
@@ -0,0 +1,70 @@
+// Named query parameter encoding for BigQuery REST v2 (jobs.query
+// queryParameters). Every value crosses the wire as a string; arrays carry
+// their element type in parameterType.arrayType.
+
+export type ScalarParam = string | number | bigint | boolean;
+export type ParamValue = ScalarParam | ScalarParam[];
+
+export interface QueryParameter {
+  name: string;
+  parameterType: { type: string; arrayType?: { type: string } };
+  parameterValue: { value?: string; arrayValues?: Array<{ value: string }> };
+}
+
+function scalarType(name: string, value: ScalarParam): string {
+  switch (typeof value) {
+    case "string":
+      return "STRING";
+    case "bigint":
+      return "INT64";
+    case "number":
+      // A JS number can't prove it is an integer that survives int64
+      // round-tripping, so numbers are always FLOAT64; use bigint for INT64.
+      return "FLOAT64";
+    case "boolean":
+      return "BOOL";
+    default:
+      throw new TypeError(`query parameter ${name}: unsupported value type ${typeof value}`);
+  }
+}
+
+function scalarValue(value: ScalarParam): string {
+  if (typeof value === "boolean") {
+    return value ? "true" : "false";
+  }
+  return String(value);
+}
+
+export function encodeParam(name: string, value: ParamValue): QueryParameter {
+  if (value === null || value === undefined) {
+    throw new TypeError(`query parameter ${name}: a query parameter value can't be NULL`);
+  }
+  if (Array.isArray(value)) {
+    if (value.length === 0) {
+      throw new TypeError(`query parameter ${name}: an empty array carries no element type for arrayType`);
+    }
+    const elementType = scalarType(name, value[0]);
+    for (const element of value) {
+      if (element === null || element === undefined || Array.isArray(element)) {
+        throw new TypeError(`query parameter ${name}: array elements must be non-null scalars`);
+      }
+      if (scalarType(name, element) !== elementType) {
+        throw new TypeError(`query parameter ${name}: mixed element types in array`);
+      }
+    }
+    return {
+      name,
+      parameterType: { type: "ARRAY", arrayType: { type: elementType } },
+      parameterValue: { arrayValues: value.map((element) => ({ value: scalarValue(element) })) },
+    };
+  }
+  return {
+    name,
+    parameterType: { type: scalarType(name, value) },
+    parameterValue: { value: scalarValue(value) },
+  };
+}
+
+export function encodeParams(params: Record<string, ParamValue>): QueryParameter[] {
+  return Object.entries(params).map(([name, value]) => encodeParam(name, value));
+}
