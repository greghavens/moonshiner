index 0000000..0a8b673
--- /dev/null
+++ b/bq/decode.ts
@@ -0,0 +1,54 @@
+// Schema-aware decoding of BigQuery's f/v row encoding. Cells arrive as
+// strings on the wire; the schema decides what they become. 64-bit integers
+// must survive exactly, so INTEGER cells decode to bigint, never Number().
+
+export interface SchemaField {
+  name: string;
+  type: string;
+  mode?: string;
+  fields?: SchemaField[];
+}
+
+type WireCell = { v: unknown };
+export interface WireRow {
+  f: WireCell[];
+}
+
+function decodeScalar(field: SchemaField, value: unknown): unknown {
+  const text = String(value);
+  switch (field.type) {
+    case "INTEGER":
+    case "INT64":
+      return BigInt(text);
+    case "FLOAT":
+    case "FLOAT64":
+      return Number(text);
+    case "BOOLEAN":
+    case "BOOL":
+      return text === "true";
+    default:
+      // STRING, TIMESTAMP, NUMERIC, … stay in their wire string form.
+      return value;
+  }
+}
+
+function decodeCell(field: SchemaField, value: unknown): unknown {
+  if (field.mode === "REPEATED") {
+    const elements = (value ?? []) as WireCell[];
+    return elements.map((element) => decodeScalar(field, element.v));
+  }
+  if (value === null || value === undefined) {
+    return null;
+  }
+  return decodeScalar(field, value);
+}
+
+export function decodeRows(schema: SchemaField[], rows: WireRow[]): Array<Record<string, unknown>> {
+  return rows.map((row) => {
+    const record: Record<string, unknown> = {};
+    schema.forEach((field, index) => {
+      record[field.name] = decodeCell(field, row.f[index]?.v);
+    });
+    return record;
+  });
+}
