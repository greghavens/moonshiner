+++ b/bq/client.ts
@@ -0,0 +1,150 @@
+// BigQuery REST v2 query runner: jobs.query submission, jobs.getQueryResults
+// polling for incomplete jobs, and pageToken-driven row pagination.
+
+import { encodeParams } from "./params.ts";
+import type { ParamValue } from "./params.ts";
+import { decodeRows } from "./decode.ts";
+import type { SchemaField, WireRow } from "./decode.ts";
+import { BigQueryHttpError, BigQueryJobError } from "./errors.ts";
+import type { JobErrorProto } from "./errors.ts";
+
+export { BigQueryHttpError, BigQueryJobError };
+
+export interface BQConfig {
+  baseUrl: string;
+  projectId: string;
+  token: string;
+  location?: string;
+  pollTimeoutMs?: number;
+  maxPolls?: number;
+}
+
+export interface RunOptions {
+  pageSize?: number;
+}
+
+export interface QueryResult {
+  rows: Array<Record<string, unknown>>;
+  schema: SchemaField[];
+  totalRows: bigint;
+  pageCount: number;
+  jobId?: string;
+  cacheHit?: boolean;
+}
+
+interface WireResponse {
+  jobReference?: { projectId?: string; jobId?: string; location?: string };
+  jobComplete?: boolean;
+  schema?: { fields?: SchemaField[] };
+  rows?: WireRow[];
+  pageToken?: string;
+  totalRows?: string;
+  errors?: JobErrorProto[];
+  cacheHit?: boolean;
+}
+
+async function call(cfg: BQConfig, method: string, url: string, body?: unknown): Promise<WireResponse> {
+  const headers: Record<string, string> = { authorization: `Bearer ${cfg.token}` };
+  if (body !== undefined) {
+    headers["content-type"] = "application/json";
+  }
+  const response = await fetch(url, {
+    method,
+    headers,
+    body: body === undefined ? undefined : JSON.stringify(body),
+  });
+  const payload: any = await response.json().catch(() => ({}));
+  if (!response.ok) {
+    const detail = payload?.error ?? {};
+    throw new BigQueryHttpError(
+      response.status,
+      detail.message ?? "request failed",
+      detail.status,
+    );
+  }
+  return payload as WireResponse;
+}
+
+function raiseJobErrors(resp: WireResponse, jobId: string | undefined): void {
+  if (resp.errors && resp.errors.length > 0) {
+    throw new BigQueryJobError(jobId, resp.errors);
+  }
+}
+
+export async function runQuery(
+  cfg: BQConfig,
+  sql: string,
+  params?: Record<string, ParamValue>,
+  opts?: RunOptions,
+): Promise<QueryResult> {
+  const base = cfg.baseUrl.replace(/\/+$/, "");
+  const project = encodeURIComponent(cfg.projectId);
+
+  const body: Record<string, unknown> = { query: sql, useLegacySql: false };
+  if (cfg.location) {
+    body.location = cfg.location;
+  }
+  if (opts?.pageSize) {
+    body.maxResults = opts.pageSize;
+  }
+  if (cfg.pollTimeoutMs) {
+    body.timeoutMs = cfg.pollTimeoutMs;
+  }
+  if (params && Object.keys(params).length > 0) {
+    body.parameterMode = "NAMED";
+    body.queryParameters = encodeParams(params);
+  }
+
+  let resp = await call(cfg, "POST", `${base}/bigquery/v2/projects/${project}/queries`, body);
+  const jobId = resp.jobReference?.jobId;
+  const jobLocation = resp.jobReference?.location ?? cfg.location;
+  raiseJobErrors(resp, jobId);
+
+  const resultsUrl = (extra: Record<string, string>): string => {
+    const query = new URLSearchParams();
+    if (jobLocation) {
+      query.set("location", jobLocation);
+    }
+    if (opts?.pageSize) {
+      query.set("maxResults", String(opts.pageSize));
+    }
+    for (const [key, value] of Object.entries(extra)) {
+      query.set(key, value);
+    }
+    return `${base}/bigquery/v2/projects/${project}/queries/${encodeURIComponent(jobId ?? "")}?${query}`;
+  };
+
+  // While the job is incomplete the response has no schema and no rows;
+  // keep asking jobs.getQueryResults, bounded so a stuck job can't spin.
+  const maxPolls = cfg.maxPolls ?? 10;
+  let polls = 0;
+  while (!resp.jobComplete) {
+    polls++;
+    if (polls > maxPolls) {
+      throw new Error(`BigQuery job ${jobId ?? "(unknown)"} is still incomplete after ${maxPolls} polls`);
+    }
+    resp = await call(cfg, "GET", resultsUrl(cfg.pollTimeoutMs ? { timeoutMs: String(cfg.pollTimeoutMs) } : {}));
+    raiseJobErrors(resp, jobId);
+  }
+
+  const schema = resp.schema?.fields ?? [];
+  let rows = decodeRows(schema, resp.rows ?? []);
+  let pageCount = 1;
+  let token = resp.pageToken;
+  while (token) {
+    const page = await call(cfg, "GET", resultsUrl({ pageToken: token }));
+    raiseJobErrors(page, jobId);
+    rows = rows.concat(decodeRows(schema, page.rows ?? []));
+    pageCount++;
+    token = page.pageToken;
+  }
+
+  return {
+    rows,
+    schema,
+    totalRows: BigInt(resp.totalRows ?? "0"),
+    pageCount,
+    jobId,
+    cacheHit: resp.cacheHit,
+  };
+}
