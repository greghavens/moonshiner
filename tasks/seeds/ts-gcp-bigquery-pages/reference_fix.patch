@@ -0,0 +1,36 @@
+// Error types for the bq runner. Job-level errors (the job ran and failed)
+// and HTTP-level errors (the API call itself was rejected) are distinct
+// failure modes and callers handle them differently.
+
+export interface JobErrorProto {
+  reason?: string;
+  location?: string;
+  message?: string;
+}
+
+export class BigQueryJobError extends Error {
+  readonly errors: JobErrorProto[];
+  readonly jobId?: string;
+
+  constructor(jobId: string | undefined, errors: JobErrorProto[]) {
+    const first = errors[0] ?? {};
+    super(
+      `BigQuery job ${jobId ?? "(unknown)"} failed: ${first.reason ?? "error"}: ${first.message ?? "no message"}`,
+    );
+    this.name = "BigQueryJobError";
+    this.jobId = jobId;
+    this.errors = errors;
+  }
+}
+
+export class BigQueryHttpError extends Error {
+  readonly status: number;
+  readonly apiStatus?: string;
+
+  constructor(status: number, message: string, apiStatus?: string) {
+    super(`BigQuery HTTP ${status}: ${message}`);
+    this.name = "BigQueryHttpError";
+    this.status = status;
+    this.apiStatus = apiStatus;
+  }
+}
