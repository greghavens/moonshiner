+package snapprune
+
+import (
+	"fmt"
+	"strings"
+	"time"
+)
+
+// Policy is a grandfather-father-son retention policy: keep the newest
+// snapshot of each of the last Daily calendar days, Weekly ISO weeks,
+// and Monthly calendar months (each window includes the current one).
+type Policy struct {
+	Daily   int
+	Weekly  int
+	Monthly int
+}
+
+// Decision is one kept snapshot and why it survived.
+type Decision struct {
+	Name   string
+	Reason string // "daily", "weekly", "monthly", or "guard"
+}
+
+// Plan is a dry-runnable pruning plan. Keep and Delete are both
+// ordered newest-first (name-ascending on timestamp ties).
+type Plan struct {
+	Keep   []Decision
+	Delete []string
+}
+
+// PlanGFS applies the policy to names as of now (interpreted in UTC).
+// Buckets claim their newest snapshot in daily, weekly, monthly order;
+// a bucket whose newest snapshot is already kept contributes nothing.
+// If nothing is claimed at all, the newest snapshot is kept with
+// reason "guard" so a plan can never delete every snapshot.
+func PlanGFS(names []string, p Policy, now time.Time) (Plan, error) {
+	sorted, err := sortNewestFirst(names)
+	if err != nil {
+		return Plan{}, err
+	}
+	stamps := make([]time.Time, len(sorted))
+	for i, n := range sorted {
+		if stamps[i], err = Timestamp(n); err != nil {
+			return Plan{}, err
+		}
+	}
+	now = now.UTC()
+
+	reasons := map[string]string{}
+	// claim keeps the newest snapshot matching the bucket, unless some
+	// earlier bucket already kept it.
+	claim := func(match func(time.Time) bool, reason string) {
+		for i, ts := range stamps {
+			if match(ts) {
+				if _, kept := reasons[sorted[i]]; !kept {
+					reasons[sorted[i]] = reason
+				}
+				return
+			}
+		}
+	}
+
+	for d := 0; d < p.Daily; d++ {
+		wy, wm, wd := now.AddDate(0, 0, -d).Date()
+		claim(func(ts time.Time) bool {
+			y, m, dd := ts.Date()
+			return y == wy && m == wm && dd == wd
+		}, "daily")
+	}
+	for w := 0; w < p.Weekly; w++ {
+		wy, wk := now.AddDate(0, 0, -7*w).ISOWeek()
+		claim(func(ts time.Time) bool {
+			y, k := ts.ISOWeek()
+			return y == wy && k == wk
+		}, "weekly")
+	}
+	year, month := now.Year(), int(now.Month())
+	for m := 0; m < p.Monthly; m++ {
+		wy, wm := year, month
+		claim(func(ts time.Time) bool {
+			return ts.Year() == wy && int(ts.Month()) == wm
+		}, "monthly")
+		month--
+		if month == 0 {
+			month = 12
+			year--
+		}
+	}
+
+	if len(reasons) == 0 && len(sorted) > 0 {
+		reasons[sorted[0]] = "guard"
+	}
+
+	var plan Plan
+	for _, n := range sorted {
+		if r, kept := reasons[n]; kept {
+			plan.Keep = append(plan.Keep, Decision{Name: n, Reason: r})
+		} else {
+			plan.Delete = append(plan.Delete, n)
+		}
+	}
+	return plan, nil
+}
+
+// Render formats the plan for a dry run: "keep <name> (<reason>)"
+// lines followed by "delete <name>" lines, each newline-terminated.
+// An empty plan renders as the empty string.
+func (pl Plan) Render() string {
+	var b strings.Builder
+	for _, d := range pl.Keep {
+		fmt.Fprintf(&b, "keep %s (%s)\n", d.Name, d.Reason)
+	}
+	for _, n := range pl.Delete {
+		fmt.Fprintf(&b, "delete %s\n", n)
+	}
+	return b.String()
+}
