diff --git a/offload.sh b/offload.sh
index f20875e..841ea67 100644
--- a/offload.sh
+++ b/offload.sh
@@ -31,34 +31,35 @@ skip_val=${skip_val#skip=}
 labels_val=$(grep '^labels=' "$conf")
 labels_val=${labels_val#labels=}
 
-# copy pass: everything on the card except the conf and the skip extensions
+# comma-split the conf values with IFS scoped to the read alone, so default
+# word splitting (and "$*"-style joins) stay intact for the rest of the run
+IFS=, read -r -a skips <<< "$skip_val"
+IFS=, read -r -a labels <<< "$labels_val"
+
+# copy pass: everything on the card except the conf and the skip extensions;
+# the glob keeps names with spaces/dashes whole and is C-sorted under LC_ALL=C
 copied=()
-for clip in $(find "$card" -maxdepth 1 -type f); do
+for clip in "$card"/*; do
+  [ -f "$clip" ] || continue
   name=${clip##*/}
   [ "$name" = offload.conf ] && continue
   ext=${name##*.}
   skipit=no
-  IFS=,
-  for s in $skip_val; do
+  for s in "${skips[@]}"; do
     [ "$ext" = "$s" ] && skipit=yes
   done
   [ "$skipit" = yes ] && continue
-  cp $clip "$vault/$name"
+  cp -- "$clip" "$vault/$name"
   copied+=("$name")
 done
 
 # index pass: session labels, one line per clip, byte total
-labels=()
-for l in $labels_val; do
-  labels+=("$l")
-done
-
 index="$vault/index.txt"
 total=0
 {
   printf 'labels: %s\n' "${labels[*]}"
   for name in "${copied[@]}"; do
-    bytes=$(wc -c < "$vault/$name" 2>/dev/null)
+    bytes=$(wc -c < "$vault/$name")
     bytes=$((bytes + 0))
     total=$((total + bytes))
     printf '%s\t%s\n' "$name" "$bytes"
