diff --git a/jobcard.zsh b/jobcard.zsh
new file mode 100644
index 0000000..dae61cb
--- /dev/null
+++ b/jobcard.zsh
@@ -0,0 +1,91 @@
+#!/usr/bin/env zsh
+# jobcard.zsh — normalize a batch-job request into a printable job card.
+#
+# Parsing is a single zparseopts call (-D -E): recognized options are removed
+# from $@, everything else stays put in order. The repeatable --tag spec uses
+# `+` so every occurrence lands in tag_opts as alternating name/value pairs.
+emulate -R zsh
+setopt no_unset
+
+usage_line='usage: jobcard.zsh [-q] [-o FILE] [-r N] [-t TAG]... <job> [arg...]'
+
+print_help() {
+  print -r -- $usage_line
+  print -r -- '  -t, --tag TAG      add a label to the card (repeatable, order kept)'
+  print -r -- '  -r, --retries N    retry budget, a non-negative integer (default 2)'
+  print -r -- '  -o, --out FILE     log destination shown on the card (default out.log)'
+  print -r -- '  -q, --quiet        mark the card quiet'
+  print -r -- '  -h, --help         show this help'
+}
+
+die_usage() { # die_usage <message>
+  print -ru2 -- "jobcard.zsh: $1"
+  print -ru2 -- $usage_line
+  exit 64
+}
+
+typeset -a tag_opts retry_opt out_opt quiet_opt help_opt
+if ! zparseopts -D -E -- {t,-tag}+:=tag_opts {r,-retries}:=retry_opt \
+    {o,-out}:=out_opt {q,-quiet}=quiet_opt {h,-help}=help_opt 2>/dev/null; then
+  die_usage 'an option is missing its value'
+fi
+
+if (( ${#help_opt} )); then
+  print_help
+  exit 0
+fi
+
+# What zparseopts left behind: positionals, a possible `--`, and any word it
+# did not recognize. Before the first `--`, a word that still looks like an
+# option is unknown; the `--` itself is dropped.
+typeset -a pos
+typeset -i seen_ddash=0
+for w in "$@"; do
+  if (( ! seen_ddash )); then
+    if [[ $w == -- ]]; then
+      seen_ddash=1
+      continue
+    fi
+    [[ $w == -?* ]] && die_usage "unknown option: $w"
+  fi
+  pos+=( "$w" )
+done
+(( ${#pos} )) || die_usage 'missing job name'
+
+job=${pos[1]}
+typeset -a args=( "${(@)pos[2,-1]}" )
+
+out=out.log
+retries=2
+(( ${#out_opt} )) && out=${out_opt[-1]#=}
+(( ${#retry_opt} )) && retries=${retry_opt[-1]#=}
+if [[ $retries != <-> ]]; then
+  print -ru2 -- "jobcard.zsh: retries must be a non-negative integer, got: $retries"
+  exit 65
+fi
+
+# tag_opts alternates option-name/value; the values are the even slots.
+typeset -a tags
+typeset -i i
+for (( i = 2; i <= ${#tag_opts}; i += 2 )); do
+  tags+=( "${tag_opts[i]#=}" )
+done
+
+print -r -- "job: $job"
+if (( ${#args} )); then
+  print -r -- "args: ${(j: :)args}"
+else
+  print -r -- 'args: (none)'
+fi
+print -r -- "out: $out"
+print -r -- "retries: $(( retries ))"
+if (( ${#quiet_opt} )); then
+  print -r -- 'quiet: yes'
+else
+  print -r -- 'quiet: no'
+fi
+if (( ${#tags} )); then
+  print -r -- "tags: ${(j:,:)tags}"
+else
+  print -r -- 'tags: (none)'
+fi
