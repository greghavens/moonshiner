index 0000000..105836d
--- /dev/null
+++ b/inlinevec.hpp
@@ -0,0 +1,128 @@
+#pragma once
+
+/* InlineVec<T, N>: fixed-capacity vector with inline element storage.
+ * No allocation ever happens; elements are placement-constructed into an
+ * aligned byte buffer inside the object and destroyed individually. T only
+ * needs to be copy/move-constructible and destructible. */
+
+#include <cstddef>
+#include <new>
+#include <type_traits>
+#include <utility>
+
+template <class T, std::size_t N>
+class InlineVec {
+public:
+    InlineVec() noexcept = default;
+
+    ~InlineVec() { clear(); }
+
+    InlineVec(const InlineVec &other) {
+        try {
+            for (std::size_t i = 0; i < other.n_; i++) {
+                ::new (raw(n_)) T(other[i]);
+                ++n_;
+            }
+        } catch (...) {
+            clear();
+            throw;
+        }
+    }
+
+    InlineVec &operator=(const InlineVec &other) {
+        if (this == &other)
+            return *this;
+        InlineVec tmp(other); /* may throw; *this still untouched */
+        clear();
+        steal_from(tmp);
+        return *this;
+    }
+
+    InlineVec(InlineVec &&other) noexcept(std::is_nothrow_move_constructible_v<T>) {
+        steal_from(other);
+    }
+
+    InlineVec &operator=(InlineVec &&other)
+        noexcept(std::is_nothrow_move_constructible_v<T>) {
+        if (this == &other)
+            return *this;
+        clear();
+        steal_from(other);
+        return *this;
+    }
+
+    bool push_back(const T &v) {
+        if (n_ == N)
+            return false;
+        ::new (raw(n_)) T(v);
+        ++n_;
+        return true;
+    }
+
+    bool push_back(T &&v) {
+        if (n_ == N)
+            return false;
+        ::new (raw(n_)) T(std::move(v));
+        ++n_;
+        return true;
+    }
+
+    template <class... Args>
+    bool emplace_back(Args &&...args) {
+        if (n_ == N)
+            return false;
+        ::new (raw(n_)) T(std::forward<Args>(args)...);
+        ++n_;
+        return true;
+    }
+
+    void pop_back() {
+        --n_;
+        slot(n_)->~T();
+    }
+
+    void clear() noexcept {
+        while (n_ > 0)
+            pop_back();
+    }
+
+    T &operator[](std::size_t i) { return *slot(i); }
+    const T &operator[](std::size_t i) const { return *slot(i); }
+
+    T *data() noexcept { return slot(0); }
+    const T *data() const noexcept { return slot(0); }
+
+    T *begin() { return slot(0); }
+    T *end() { return slot(0) + n_; }
+    const T *begin() const { return slot(0); }
+    const T *end() const { return slot(0) + n_; }
+
+    std::size_t size() const noexcept { return n_; }
+    bool empty() const noexcept { return n_ == 0; }
+    static constexpr std::size_t capacity() noexcept { return N; }
+
+private:
+    void *raw(std::size_t i) noexcept { return buf_ + i * sizeof(T); }
+
+    T *slot(std::size_t i) noexcept {
+        return std::launder(reinterpret_cast<T *>(buf_ + i * sizeof(T)));
+    }
+    const T *slot(std::size_t i) const noexcept {
+        return std::launder(reinterpret_cast<const T *>(buf_ + i * sizeof(T)));
+    }
+
+    /* Move every element out of `other` into our (empty) storage, then
+     * leave `other` empty. Used by both move operations and the tail end
+     * of copy assignment. */
+    void steal_from(InlineVec &other)
+        noexcept(std::is_nothrow_move_constructible_v<T>) {
+        for (std::size_t i = 0; i < other.n_; i++) {
+            ::new (raw(i)) T(std::move(*other.slot(i)));
+            ++n_;
+        }
+        other.clear();
+    }
+
+    alignas(T) unsigned char buf_[N * sizeof(T)];
+    std::size_t n_ = 0;
+};
