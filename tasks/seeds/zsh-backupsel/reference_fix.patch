@@ -1,12 +1,17 @@
 #!/usr/bin/env zsh
 # backup.zsh — copy every plain file in a source tree into a backup drop.
 #
-#   zsh backup.zsh <src-dir> <dest-dir>
+#   zsh backup.zsh [--include <pat>]... [--exclude <pat>]... [--dry-run] <src-dir> <dest-dir>
 #
 # Walks the source with zsh globbing (no find), copies each plain file to the
 # same relative path under the destination, and writes manifest.txt there —
 # one relative path per line, byte order — so two drops can be diffed.
 # Dotfiles and dot-directories stay behind on purpose.
+#
+# Selection: --include/--exclude take zsh extended globs matched against the
+# relative path as one string (* crosses /). With includes, a file must match
+# at least one; excludes always win. --dry-run prints the plan — one
+# 'copy<TAB><relative path>' line per selected file — and touches nothing.
 emulate -R zsh
 setopt no_unset extended_glob
 
@@ -15,10 +20,48 @@ LC_ALL=C
 export LC_ALL
 
 usage() {
-  print -u2 -- 'usage: backup.zsh <src-dir> <dest-dir>'
+  print -u2 -- 'usage: backup.zsh [--include <pat>]... [--exclude <pat>]... [--dry-run] <src-dir> <dest-dir>'
   exit 64
 }
 
+matches_any() { # matches_any <relpath> <pattern>...
+  emulate -L zsh
+  setopt extended_glob
+  local rel=$1 pat
+  shift
+  for pat in "$@"; do
+    [[ $rel == ${~pat} ]] && return 0
+  done
+  return 1
+}
+
+typeset -a includes excludes
+typeset -i dry_run=0
+while (( $# > 0 )); do
+  case $1 in
+    --include)
+      (( $# >= 2 )) || usage
+      includes+=( "$2" )
+      shift 2
+      ;;
+    --exclude)
+      (( $# >= 2 )) || usage
+      excludes+=( "$2" )
+      shift 2
+      ;;
+    --dry-run)
+      dry_run=1
+      shift
+      ;;
+    -*)
+      usage
+      ;;
+    *)
+      break
+      ;;
+  esac
+done
+
 (( $# == 2 )) || usage
 src=$1
 dest=$2
@@ -28,14 +71,27 @@ if [[ ! -d $src ]]; then
 fi
 
 typeset -a rels
-typeset f
+typeset f rel
 for f in $src/**/*(.N); do
-  rels+=( "${f#$src/}" )
+  rel=${f#$src/}
+  if (( ${#includes} > 0 )) && ! matches_any "$rel" "${includes[@]}"; then
+    continue
+  fi
+  if (( ${#excludes} > 0 )) && matches_any "$rel" "${excludes[@]}"; then
+    continue
+  fi
+  rels+=( "$rel" )
 done
 rels=( "${(o)rels[@]}" )
 
+if (( dry_run )); then
+  for rel in "${rels[@]}"; do
+    printf 'copy\t%s\n' "$rel"
+  done
+  exit 0
+fi
+
