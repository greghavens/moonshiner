{
  "product": "Dynatrace SLO Management API (latest service-level objectives)",
  "url_families": {
    "latest": {
      "base_url_pattern": "https://{environment-id}.apps.dynatrace.com",
      "base_path": "/platform/slo/v1/slos",
      "auth": "OAuth bearer token (Authorization: Bearer ...)"
    },
    "classic": {
      "base_url_pattern": "https://{environment-id}.live.dynatrace.com",
      "base_path": "/api/v2/slo",
      "auth": "Api-Token, scope slo.read",
      "note": "classic SLOs are a separate, older API; a client configured with a live.dynatrace.com host or an /api/v2/slo path must be rejected with an error pointing at /platform/slo/v1/slos"
    }
  },
  "auth": {
    "header": "Authorization",
    "scheme": "Bearer",
    "fixture_token": "fake-platform-bearer-token-for-tests",
    "token_in_url_forbidden": true
  },
  "endpoints": {
    "list": {
      "method": "GET",
      "path": "/platform/slo/v1/slos",
      "first_page_params": {"page-size": "200"},
      "subsequent_pages": "the page-key cursor from nextPageKey is the only query parameter",
      "response_fields": ["slos", "totalCount", "nextPageKey"]
    },
    "create": {
      "method": "POST",
      "path": "/platform/slo/v1/slos",
      "content_type": "application/json",
      "created_status": 201,
      "body_fields": ["name", "description?", "customSli.indicator", "criteria[].timeframeFrom", "criteria[].timeframeTo?", "criteria[].target", "criteria[].warning?", "tags?", "externalId?"],
      "body_rule": "optional fields that are null are omitted entirely, never sent as null"
    },
    "get": {
      "method": "GET",
      "path": "/platform/slo/v1/slos/{id}",
      "response_includes": ["id", "name", "version"]
    },
    "update": {
      "method": "PUT",
      "path": "/platform/slo/v1/slos/{id}",
      "query": "optimistic-locking-version=<version from the immediately preceding GET>",
      "conflict_status": 409,
      "conflict_rule": "on 409, refetch the SLO for a fresh version and retry the PUT exactly once; a second 409 raises SloConflictException"
    },
    "evaluate_start": {
      "method": "POST",
      "path": "/platform/slo/v1/slos/evaluation:start",
      "content_type": "application/json",
      "body": {"id": "<slo id>"},
      "response_fields": ["definition?", "evaluationResults?", "evaluationToken?", "ttlSeconds?"]
    },
    "evaluate_poll": {
      "method": "GET",
      "path": "/platform/slo/v1/slos/evaluation:poll",
      "query_params": {"evaluation-token": "token from evaluation:start"},
      "rule": "poll only while any result is PENDING; the injected delay runs before every poll; more than maxPolls pending polls raises SloEvaluationTimeoutException carrying the token"
    }
  },
  "evaluation_result_fields": ["criteria", "status", "value?", "errorBudget?", "message?"],
  "status_enum": ["SUCCESS", "FAILURE", "WARNING", "PENDING"],
  "criteria_string_format": "now-7d -> now",
  "normalization": {
    "entries": "sorted by criteria string, ordinal",
    "status": "SUCCESS->Success, WARNING->Warning, FAILURE->Failure, PENDING->Pending",
    "overall": "worst status wins: Failure > Warning > Pending > Success",
    "metrics": "value and errorBudget stay nullable doubles, preserved exactly"
  },
  "error_envelope": {"error": {"code": "int", "message": "string"}},
  "fixtures": {
    "environment_id": "abc12345",
    "slo_id": "0f52f2f8-3f83-4a9b-8f6e-0d5a7f1c2b3a",
    "existing_slo": {
      "id": "0f52f2f8-3f83-4a9b-8f6e-0d5a7f1c2b3a",
      "name": "checkout-availability",
      "description": "Checkout service availability",
      "customSli": {"indicator": "timeseries sli=avg(dt.service.request.success_rate), by:{dt.entity.service}"},
      "criteria": [
        {"timeframeFrom": "now-7d", "timeframeTo": "now", "target": 99.5, "warning": 99.8}
      ],
      "tags": ["team:checkout"],
      "version": "5"
    },
    "unrelated_slo": {
      "id": "77aa88bb-1111-2222-3333-444455556666",
      "name": "search-latency",
      "version": "2"
    },
    "evaluation_token": "eval-tok-a1b2c3d4",
    "final_results": [
      {"criteria": "now-7d -> now", "status": "SUCCESS", "value": 99.92, "errorBudget": 0.42},
      {"criteria": "now-30d -> now", "status": "FAILURE", "value": 99.1, "errorBudget": -0.3, "message": "error budget exhausted"}
    ],
    "warning_results": [
      {"criteria": "now-7d -> now", "status": "WARNING", "value": 99.65, "errorBudget": 0.15},
      {"criteria": "now-30d -> now", "status": "SUCCESS", "value": 99.9, "errorBudget": 0.4}
    ],
    "pending_result": [
      {"criteria": "now-7d -> now", "status": "PENDING"}
    ],
    "error_404": {"error": {"code": 404, "message": "SLO not found"}}
  }
}
