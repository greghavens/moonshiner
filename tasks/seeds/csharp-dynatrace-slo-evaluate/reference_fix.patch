+++ b/src/SloExceptions.cs
@@ -0,0 +1,39 @@
+namespace Acme.Dynatrace.Slo;
+
+/// <summary>A non-2xx platform response, decoded from the error envelope.</summary>
+public class SloApiException : Exception
+{
+    public int Status { get; }
+
+    public SloApiException(int status, string message)
+        : base($"Dynatrace SLO API error {status}: {message}")
+    {
+        Status = status;
+    }
+}
+
+/// <summary>
+/// The optimistic-locking retry also hit a concurrent modification.
+/// </summary>
+public sealed class SloConflictException : Exception
+{
+    public string SloId { get; }
+
+    public SloConflictException(string sloId)
+        : base($"SLO {sloId} was modified concurrently twice; giving up after one retry")
+    {
+        SloId = sloId;
+    }
+}
+
+/// <summary>An evaluation stayed pending past maxPolls.</summary>
+public sealed class SloEvaluationTimeoutException : Exception
+{
+    public string EvaluationToken { get; }
+
+    public SloEvaluationTimeoutException(string evaluationToken, int polls)
+        : base($"SLO evaluation still pending after {polls} polls")
+    {
+        EvaluationToken = evaluationToken;
+    }
+}
