+def _matches(event_type, patterns):
+    """Does an event type pass a subscriber's filter list? None = everything."""
+    if patterns is None:
+        return True
+    for pattern in patterns:
+        if pattern == "*" or pattern == event_type:
+            return True
+        if pattern.endswith(".*") and event_type.startswith(pattern[:-1]):
+            return True
+    return False
+
+
+def _shape(payload, mapping):
+    """Apply a {field: dotted.path} mapping; None means the payload as-is."""
+    if mapping is None:
+        return payload
+    shaped = {}
+    for field, path in mapping.items():
+        found, value = _resolve(payload, path)
+        if found:
+            shaped[field] = value
+    return shaped
+
+
+def _resolve(payload, dotted):
+    node = payload
+    for part in dotted.split("."):
+        if not isinstance(node, dict) or part not in node:
+            return False, None
+        node = node[part]
+    return True, node
