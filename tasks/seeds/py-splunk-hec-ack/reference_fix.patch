@@ -0,0 +1,73 @@
+"""Envelope building and validation for the HEC JSON event protocol.
+
+Reference: "Format events for HTTP Event Collector" (help.splunk.com).
+An envelope may carry exactly the documented keys; ``event`` is required,
+``time`` is epoch seconds with millisecond precision, and ``fields`` must
+be a flat object of index-time fields (scalars or arrays of scalars).
+"""
+
+import json
+import re
+
+ALLOWED_KEYS = {"event", "time", "host", "source", "sourcetype", "index", "fields"}
+
+# Channels must be GUID-shaped (8-4-4-4-12 hex); they may be random.
+CHANNEL_RE = re.compile(
+    r"^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}"
+    r"-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
+)
+
+_SCALARS = (str, int, float, bool)
+
+
+def validate_channel(channel):
+    if not isinstance(channel, str) or not CHANNEL_RE.match(channel):
+        raise ValueError(
+            "HEC request channels must be GUID-shaped, got %r" % (channel,))
+    return channel
+
+
+def _validate_fields(fields):
+    if not isinstance(fields, dict):
+        raise ValueError("fields must be a flat JSON object")
+    for name, value in fields.items():
+        if isinstance(value, _SCALARS) or value is None:
+            continue
+        if isinstance(value, list):
+            if all(isinstance(v, _SCALARS) for v in value):
+                continue
+            raise ValueError(
+                "fields.%s: multivalue entries must be scalars" % name)
+        raise ValueError(
+            "fields.%s: nested objects are not indexable at index time" % name)
+
+
+def validate_envelope(envelope):
+    if not isinstance(envelope, dict):
+        raise ValueError("each event must be a dict envelope")
+    unknown = set(envelope) - ALLOWED_KEYS
+    if unknown:
+        raise ValueError("unknown envelope keys: %s" % ", ".join(sorted(unknown)))
+    if "event" not in envelope:
+        raise ValueError("the event key is required in every envelope")
+    if "time" in envelope and (
+            isinstance(envelope["time"], bool)
+            or not isinstance(envelope["time"], (int, float))):
+        raise ValueError("time must be epoch seconds (int or float)")
+    if "fields" in envelope:
+        _validate_fields(envelope["fields"])
+
+
+def serialize_batch(events):
+    """One compact JSON object per event, newline-separated."""
+    if not events:
+        raise ValueError("refusing to send an empty batch")
+    lines = []
+    for envelope in events:
+        validate_envelope(envelope)
+        out = dict(envelope)
+        if "time" in out:
+            # epoch seconds at millisecond precision, per the format docs
+            out["time"] = round(float(out["time"]), 3)
+        lines.append(json.dumps(out, separators=(",", ":")))
+    return "\n".join(lines).encode("utf-8")
