@@ -0,0 +1,103 @@
+"""HecSender: batched HEC sends with indexer acknowledgment.
+
+Flow (per the official indexer-acknowledgment docs): send a batch with a
+request channel, keep the returned ackId, then poll /services/collector/ack
+until it reports true. Once an ackId reports true HEC deletes its status —
+querying it again always returns false — so acked ids are dropped from
+every later poll.
+"""
+
+import json
+import urllib.parse
+
+from .envelope import serialize_batch, validate_channel
+from .transport import HecServerError, Transport
+
+EVENT_PATH = "/services/collector/event"
+RAW_PATH = "/services/collector/raw"
+ACK_PATH = "/services/collector/ack"
+HEALTH_PATH = "/services/collector/health"
+
+CHANNEL_HEADER = "X-Splunk-Request-Channel"
+
+
+class HecAckTimeout(Exception):
+    """Raised when ackIds stay unacknowledged after max_polls polls."""
+
+    def __init__(self, unacked):
+        self.unacked = frozenset(unacked)
+        super().__init__(
+            "no acknowledgment after polling for ackIds: %s"
+            % ", ".join(str(i) for i in sorted(self.unacked)))
+
+
+class HecSender:
+    def __init__(self, base_url, token, channel, sleeper, gzip=False):
+        self.channel = validate_channel(channel)
+        self._transport = Transport(base_url, token, use_gzip=gzip)
+        self._sleeper = sleeper
+
+    # -- sending ---------------------------------------------------------
+
+    def _ack_id(self, resp):
+        ack_id = resp.doc.get("ackId")
+        if ack_id is None:
+            raise HecServerError(
+                resp.status, resp.doc.get("code", -1),
+                "response carried no ackId - indexer acknowledgment is not "
+                "enabled for this token")
+        return int(ack_id)
+
+    def send_events(self, events):
+        body = serialize_batch(events)
+        resp = self._transport.request(
+            "POST", EVENT_PATH, body=body,
+            headers={CHANNEL_HEADER: self.channel}, compress=True)
+        return self._ack_id(resp)
+
+    def send_events_with_retry(self, events, max_attempts, backoff):
+        body = serialize_batch(events)
+        resp = self._transport.request_with_retry(
+            "POST", EVENT_PATH, body,
+            {CHANNEL_HEADER: self.channel},
+            self._sleeper, max_attempts, backoff, compress=True)
+        return self._ack_id(resp)
+
+    def send_raw(self, text):
+        path = RAW_PATH + "?" + urllib.parse.urlencode({"channel": self.channel})
+        resp = self._transport.request(
+            "POST", path, body=text.encode("utf-8"), compress=True)
+        return self._ack_id(resp)
+
+    # -- acknowledgment --------------------------------------------------
+
+    def poll_acks(self, ack_ids):
+        body = json.dumps({"acks": list(ack_ids)}).encode("utf-8")
+        resp = self._transport.request(
+            "POST", ACK_PATH, body=body,
+            headers={CHANNEL_HEADER: self.channel})
+        return {int(k): bool(v) for k, v in resp.doc.get("acks", {}).items()}
+
+    def wait_until_acked(self, ack_ids, poll_interval, max_polls):
+        pending = set(ack_ids)
+        for poll in range(max_polls):
+            if poll:
+                self._sleeper(poll_interval)
+            statuses = self.poll_acks(sorted(pending))
+            # drop confirmed ids: HEC deletes a status after reporting
+            # true, so a re-query would falsely read as unacked
+            pending -= {ack_id for ack_id, done in statuses.items() if done}
+            if not pending:
+                return
+        raise HecAckTimeout(pending)
+
+    # -- health ----------------------------------------------------------
+
+    def health(self):
+        try:
+            self._transport.request("GET", HEALTH_PATH)
+            return True
+        except HecServerError as err:
+            if err.status == 503:
+                return False
+            raise
