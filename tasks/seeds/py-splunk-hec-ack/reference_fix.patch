+++ b/splunk_hec/transport.py
@@ -0,0 +1,102 @@
+"""HTTP transport for HEC with token auth, gzip and retry policy.
+
+Auth is the ``Authorization: Splunk <token>`` header — never a URL
+parameter. Retryable outcomes are transport failures (no readable
+response) and the 429/500/503 statuses from the official HEC response
+code table; other 4xx are terminal.
+"""
+
+import gzip
+import json
+import urllib.error
+import urllib.request
+
+RETRYABLE_STATUSES = {429, 500, 503}
+
+
+class HecServerError(Exception):
+    """A decoded HEC error body: {"text": ..., "code": ...}."""
+
+    def __init__(self, status, code, text):
+        super().__init__("HEC %d (code %s): %s" % (status, code, text))
+        self.status = status
+        self.code = code
+        self.text = text
+
+
+class Response:
+    def __init__(self, status, doc):
+        self.status = status
+        self.doc = doc
+
+
+class Transport:
+    def __init__(self, base_url, token, use_gzip=False):
+        self.base_url = base_url.rstrip("/")
+        self._token = token
+        self.use_gzip = use_gzip
+
+    def _request(self, method, path, body=None, headers=None, compress=False):
+        url = self.base_url + path
+        all_headers = {"Authorization": "Splunk " + self._token}
+        if headers:
+            all_headers.update(headers)
+        if body is not None and compress and self.use_gzip:
+            body = gzip.compress(body)
+            all_headers["Content-Encoding"] = "gzip"
+        req = urllib.request.Request(url, data=body, method=method,
+                                     headers=all_headers)
+        try:
+            with urllib.request.urlopen(req) as resp:
+                return Response(resp.status, self._decode(resp.read()))
+        except urllib.error.HTTPError as err:
+            return Response(err.code, self._decode(err.read()))
+
+    @staticmethod
+    def _decode(raw):
+        if not raw:
+            return {}
+        try:
+            return json.loads(raw.decode("utf-8"))
+        except ValueError:
+            return {}
+
+    def request(self, method, path, body=None, headers=None, compress=False):
+        """Single attempt; raises HecServerError on any non-2xx."""
+        resp = self._request(method, path, body, headers, compress)
+        if resp.status // 100 != 2:
+            raise self._error(resp)
+        return resp
+
+    def request_with_retry(self, method, path, body, headers, sleeper,
+                           max_attempts, backoff, compress=False):
+        """Retry ambiguous transport failures and retryable statuses.
+
+        The body is resent byte-identical: with indexer acknowledgment the
+        worst case is a duplicate the ack poll confirms (at-least-once).
+        """
+        last_transport_error = None
+        for attempt in range(max_attempts):
+            if attempt:
+                sleeper(backoff)
+            try:
+                resp = self._request(method, path, body, headers, compress)
+            except OSError as err:
+                last_transport_error = err
+                continue
+            if resp.status // 100 == 2:
+                return resp
+            if resp.status in RETRYABLE_STATUSES:
+                last_transport_error = None
+                last_response = resp
+                continue
+            raise self._error(resp)
+        if last_transport_error is not None:
+            raise last_transport_error
+        raise self._error(last_response)
+
+    @staticmethod
+    def _error(resp):
+        return HecServerError(resp.status,
+                              resp.doc.get("code", -1),
+                              resp.doc.get("text", "unknown HEC failure"))
