+"""JSON persistence for the garage db. store owns the on-disk format."""
+import json
+import os
+
+
+def exists(path):
+    return os.path.exists(path)
+
+
+def load(path):
+    """Load the db. Raises FileNotFoundError if it doesn't exist."""
+    with open(path, encoding="utf-8") as fh:
+        return json.load(fh)
+
+
+def save(path, state):
+    tmp = path + ".tmp"
+    with open(tmp, "w", encoding="utf-8") as fh:
+        json.dump(state, fh, indent=2, sort_keys=True)
+        fh.write("\n")
+    os.replace(tmp, path)
