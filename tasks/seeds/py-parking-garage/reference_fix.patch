+"""Spot inventory and ticket logic. Operates on the plain-dict db state."""
+import pricing
+
+CLASS_ORDER = ["compact", "standard", "oversize"]
+CLASS_LETTER = {"compact": "C", "standard": "S", "oversize": "O"}
+
+
+class GarageError(Exception):
+    """A rule violation the CLI reports as a nonzero exit."""
+
+
+def new_state(compact, standard, oversize):
+    counts = {"compact": compact, "standard": standard, "oversize": oversize}
+    if any(n < 0 for n in counts.values()):
+        raise GarageError("spot counts cannot be negative")
+    if not any(counts.values()):
+        raise GarageError("a garage needs at least one spot")
+    spots = {}
+    for cls in CLASS_ORDER:
+        for i in range(1, counts[cls] + 1):
+            spots[f"{CLASS_LETTER[cls]}{i:02d}"] = cls
+    return {"spots": spots, "tickets": {}, "revenue_cents": 0}
+
+
+def _free_spot(state, cls):
+    """Lowest-numbered free spot of class cls, or None."""
+    taken = {t["spot"] for t in state["tickets"].values()}
+    candidates = [sid for sid, c in state["spots"].items()
+                  if c == cls and sid not in taken]
+    return min(candidates, key=lambda sid: int(sid[1:])) if candidates else None
+
+
+def enter(state, plate, size, time):
+    if size not in CLASS_ORDER:
+        raise GarageError(f"unknown size class: {size!r}")
+    pricing.parse_time(time)  # validate before mutating anything
+    if plate in state["tickets"]:
+        raise GarageError(f"plate {plate} is already inside")
+    for cls in CLASS_ORDER[CLASS_ORDER.index(size):]:
+        spot = _free_spot(state, cls)
+        if spot is not None:
+            state["tickets"][plate] = {"spot": spot, "size": size, "since": time}
+            return spot
+    raise GarageError(f"no spot available for a {size} vehicle")
+
+
+def exit_(state, plate, time):
+    ticket = state["tickets"].get(plate)
+    if ticket is None:
+        raise GarageError(f"plate {plate} is not in the garage")
+    try:
+        fee = pricing.fee_cents(ticket["since"], time, ticket["size"])
+    except ValueError as exc:
+        raise GarageError(str(exc)) from exc
+    del state["tickets"][plate]
+    state["revenue_cents"] += fee
+    return fee
+
+
+def find(state, plate):
+    ticket = state["tickets"].get(plate)
+    if ticket is None:
+        raise GarageError(f"plate {plate} is not in the garage")
+    return ticket
+
+
+def report_lines(state):
+    used = {cls: 0 for cls in CLASS_ORDER}
+    total = {cls: 0 for cls in CLASS_ORDER}
+    for cls in state["spots"].values():
+        total[cls] += 1
+    for ticket in state["tickets"].values():
+        used[state["spots"][ticket["spot"]]] += 1
+    lines = [f"{cls}\tused={used[cls]}/{total[cls]}" for cls in CLASS_ORDER]
+    lines.append(f"revenue={pricing.format_dollars(state['revenue_cents'])}")
+    return lines
