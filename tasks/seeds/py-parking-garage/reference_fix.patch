+"""Garage kiosk CLI. Usage: python3 cli.py --db PATH <command> ..."""
+import argparse
+import sys
+
+import garage
+import pricing
+import store
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="cli.py")
+    parser.add_argument("--db", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("init")
+    p.add_argument("--compact", type=int, required=True)
+    p.add_argument("--standard", type=int, required=True)
+    p.add_argument("--oversize", type=int, required=True)
+
+    p = sub.add_parser("enter")
+    p.add_argument("plate")
+    p.add_argument("--size", required=True)
+    p.add_argument("--time", required=True)
+
+    p = sub.add_parser("exit")
+    p.add_argument("plate")
+    p.add_argument("--time", required=True)
+
+    p = sub.add_parser("find")
+    p.add_argument("plate")
+
+    sub.add_parser("report")
+    return parser
+
+
+def load_db(path):
+    if not store.exists(path):
+        raise garage.GarageError(f"no garage db at {path}; run init first")
+    return store.load(path)
+
+
+def run(args):
+    if args.command == "init":
+        if store.exists(args.db):
+            raise garage.GarageError(
+                f"db {args.db} already exists; refusing to re-init over live tickets")
+        state = garage.new_state(args.compact, args.standard, args.oversize)
+        store.save(args.db, state)
+        return
+
+    state = load_db(args.db)
+    if args.command == "enter":
+        spot = garage.enter(state, args.plate, args.size, args.time)
+        store.save(args.db, state)
+        print(f"spot {spot}")
+    elif args.command == "exit":
+        fee = garage.exit_(state, args.plate, args.time)
+        store.save(args.db, state)
+        print(f"fee {pricing.format_dollars(fee)}")
+    elif args.command == "find":
+        ticket = garage.find(state, args.plate)
+        print(f"spot={ticket['spot']}\tsince={ticket['since']}")
+    elif args.command == "report":
+        print("\n".join(garage.report_lines(state)))
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    try:
+        run(args)
+    except (garage.GarageError, ValueError) as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
