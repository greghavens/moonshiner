+"""Fee math for the garage. Pure functions, integer cents, no file IO."""
+from datetime import datetime
+
+TIME_FMT = "%Y-%m-%dT%H:%M"
+GRACE_MINUTES = 15
+MINUTES_PER_DAY = 24 * 60
+
+HOURLY_CENTS = {"compact": 200, "standard": 300, "oversize": 500}
+DAILY_MAX_CENTS = {"compact": 1200, "standard": 1800, "oversize": 3000}
+
+SIZES = tuple(HOURLY_CENTS)
+
+
+def parse_time(text):
+    """Parse a kiosk timestamp; raises ValueError on anything malformed."""
+    return datetime.strptime(text, TIME_FMT)
+
+
+def fee_cents(entry, exit_, size):
+    """Fee in integer cents for a stay from entry to exit_ (YYYY-MM-DDTHH:MM).
+
+    Raises ValueError for unknown sizes, malformed times, or exit before entry.
+    """
+    if size not in HOURLY_CENTS:
+        raise ValueError(f"unknown size class: {size!r}")
+    start = parse_time(entry)
+    end = parse_time(exit_)
+    if end < start:
+        raise ValueError("exit time is before entry time")
+
+    minutes = int((end - start).total_seconds()) // 60
+    if minutes <= GRACE_MINUTES:
+        return 0
+
+    rate = HOURLY_CENTS[size]
+    daily_max = DAILY_MAX_CENTS[size]
+    full_days, remainder = divmod(minutes, MINUTES_PER_DAY)
+    total = full_days * daily_max
+    if remainder:
+        hours = -(-remainder // 60)  # ceil division: fractions bill a full hour
+        total += min(daily_max, hours * rate)
+    return total
+
+
+def format_dollars(cents):
+    return f"${cents // 100}.{cents % 100:02d}"
