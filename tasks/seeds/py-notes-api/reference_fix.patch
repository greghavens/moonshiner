+"""Note storage with JSON persistence."""
+import json
+import os
+
+
+class NoteStore:
+    def __init__(self, path):
+        self.path = path
+        self.notes = {}
+        self.next_id = 1
+        self._load()
+
+    def _load(self):
+        if not os.path.exists(self.path):
+            return
+        with open(self.path) as f:
+            data = json.load(f)
+        self.notes = {int(k): v for k, v in data.get("notes", {}).items()}
+        self.next_id = data.get("next_id", 1)
+
+    def _save(self):
+        tmp = self.path + ".tmp"
+        with open(tmp, "w") as f:
+            json.dump({"next_id": self.next_id,
+                       "notes": {str(k): v for k, v in self.notes.items()}},
+                      f, indent=2)
+        os.replace(tmp, self.path)
+
+    def list(self, query=None):
+        notes = [self.notes[i] for i in sorted(self.notes)]
+        if query:
+            q = query.lower()
+            notes = [n for n in notes
+                     if q in n["title"].lower() or q in n["body"].lower()]
+        return notes
+
+    def get(self, note_id):
+        return self.notes.get(note_id)
+
+    def create(self, title, body):
+        note = {"id": self.next_id, "title": title, "body": body, "version": 1}
+        self.notes[note["id"]] = note
+        self.next_id += 1
+        self._save()
+        return note
+
+    def update(self, note_id, title, body):
+        note = self.notes[note_id]
+        note["title"] = title
+        note["body"] = body
+        note["version"] += 1
+        self._save()
+        return note
+
+    def delete(self, note_id):
+        del self.notes[note_id]
+        self._save()
