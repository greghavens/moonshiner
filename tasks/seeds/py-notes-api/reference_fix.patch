+"""HTTP request handling for the notes API."""
+import json
+import re
+from http.server import BaseHTTPRequestHandler
+from urllib.parse import urlparse, parse_qs
+
+NOTE_PATH = re.compile(r"^/notes/(\d+)$")
+
+
+def validate_payload(payload):
+    """Return an error string for a bad create/update body, else None."""
+    if not isinstance(payload, dict):
+        return "body must be a JSON object"
+    title = payload.get("title")
+    if not isinstance(title, str) or not title:
+        return "title is required and must be a non-empty string"
+    body = payload.get("body")
+    if not isinstance(body, str):
+        return "body is required and must be a string"
+    return None
+
+
+def make_handler(store):
+    class NotesHandler(BaseHTTPRequestHandler):
+        def log_message(self, fmt, *args):  # keep stdout/stderr quiet
+            pass
+
+        # ---- helpers -------------------------------------------------
+        def send_json(self, status, payload, etag=None):
+            body = json.dumps(payload).encode()
+            self.send_response(status)
+            self.send_header("Content-Type", "application/json")
+            self.send_header("Content-Length", str(len(body)))
+            if etag is not None:
+                self.send_header("ETag", f'"{etag}"')
+            self.end_headers()
+            self.wfile.write(body)
+
+        def send_error_json(self, status, message):
+            self.send_json(status, {"error": message})
+
+        def read_payload(self):
+            length = int(self.headers.get("Content-Length") or 0)
+            raw = self.rfile.read(length) if length else b""
+            try:
+                return json.loads(raw)
+            except ValueError:
+                return None
+
+        def note_id_from_path(self, path):
+            m = NOTE_PATH.match(path)
+            return int(m.group(1)) if m else None
+
+        # ---- verbs ---------------------------------------------------
+        def do_GET(self):
+            url = urlparse(self.path)
+            if url.path == "/notes":
+                q = parse_qs(url.query).get("q", [None])[0]
+                self.send_json(200, store.list(q))
+                return
+            note_id = self.note_id_from_path(url.path)
+            if note_id is not None:
+                note = store.get(note_id)
+                if note is None:
+                    self.send_error_json(404, f"no note {note_id}")
+                    return
+                self.send_json(200, note, etag=note["version"])
+                return
+            self.send_error_json(404, "not found")
+
+        def do_POST(self):
+            if urlparse(self.path).path != "/notes":
+                self.send_error_json(404, "not found")
+                return
+            payload = self.read_payload()
+            if payload is None:
+                self.send_error_json(400, "request body is not valid JSON")
+                return
+            problem = validate_payload(payload)
+            if problem:
+                self.send_error_json(400, problem)
+                return
+            note = store.create(payload["title"], payload["body"])
+            self.send_json(201, note, etag=note["version"])
+
+        def do_PUT(self):
+            note_id = self.note_id_from_path(urlparse(self.path).path)
+            if note_id is None:
+                self.send_error_json(404, "not found")
+                return
+            note = store.get(note_id)
+            if note is None:
+                self.send_error_json(404, f"no note {note_id}")
+                return
+            if_match = self.headers.get("If-Match")
+            if if_match is None:
+                self.send_error_json(428, "If-Match header required")
+                return
+            if if_match.strip() != f'"{note["version"]}"':
+                self.send_error_json(412, "version mismatch")
+                return
+            payload = self.read_payload()
+            if payload is None:
+                self.send_error_json(400, "request body is not valid JSON")
+                return
+            problem = validate_payload(payload)
+            if problem:
+                self.send_error_json(400, problem)
+                return
+            updated = store.update(note_id, payload["title"], payload["body"])
+            self.send_json(200, updated, etag=updated["version"])
+
+        def do_DELETE(self):
+            note_id = self.note_id_from_path(urlparse(self.path).path)
+            if note_id is None or store.get(note_id) is None:
+                self.send_error_json(404, "not found")
+                return
+            store.delete(note_id)
+            self.send_response(204)
+            self.send_header("Content-Length", "0")
+            self.end_headers()
+
+    return NotesHandler
