+    private async Task RunRefreshAsync(RefreshFlight flight)
+    {
+        try
+        {
+            // No single request owns the shared operation. Individual request tokens
+            // only cancel their WaitAsync call above.
+            var refreshed = await _endpoint.RefreshAsync(CancellationToken.None).ConfigureAwait(false);
+            var participants = FinishFlight(flight, refreshed);
+            RecordSafely(new RefreshEvent(
+                RefreshEventKind.Succeeded,
+                flight.RefreshId,
+                participants,
+                Stopwatch.GetElapsedTime(flight.StartedAt)));
+            flight.Completion.TrySetResult(refreshed);
+        }
+        catch (OperationCanceledException exception)
+        {
+            var participants = FinishFlight(flight);
+            RecordSafely(new RefreshEvent(
+                RefreshEventKind.Canceled,
+                flight.RefreshId,
+                participants,
+                Stopwatch.GetElapsedTime(flight.StartedAt)));
+            flight.Completion.TrySetCanceled(exception.CancellationToken);
+        }
+        catch (Exception exception)
+        {
+            var participants = FinishFlight(flight);
+            RecordSafely(new RefreshEvent(
+                RefreshEventKind.Failed,
+                flight.RefreshId,
+                participants,
+                Stopwatch.GetElapsedTime(flight.StartedAt),
+                exception.GetType().FullName));
+            flight.Completion.TrySetException(exception);
+        }
