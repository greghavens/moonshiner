+    private int FinishFlight(RefreshFlight flight, AccessToken? refreshed = null)
+    {
+        lock (_refreshGate)
+        {
+            if (refreshed is not null)
+            {
+                Volatile.Write(ref _cachedToken, refreshed);
+            }
+
+            if (ReferenceEquals(_inFlight, flight))
+            {
+                _inFlight = null;
+            }
+
+            return flight.Participants;
+        }
+    }
