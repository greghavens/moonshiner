     /// Fraction of inspected parts that were rejected in the window.
+    /// A station that inspected nothing has a rate of 0.0: idle, not broken.
     pub fn reject_rate(&self) -> f64 {
+        if self.inspected == 0 {
+            return 0.0;
+        }
         self.rejected as f64 / self.inspected as f64
     }
