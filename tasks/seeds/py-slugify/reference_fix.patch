+"""URL slug generation and collision-free assignment."""
+import unicodedata
+
+# Letters unicodedata NFKD cannot decompose to ascii.
+_TRANSLITERATIONS = {
+    "ß": "ss",  # ß
+    "æ": "ae",  # æ
+    "œ": "oe",  # œ
+    "ø": "o",   # ø
+}
+
+
+def _fold_to_ascii(text):
+    text = text.casefold()
+    for char, replacement in _TRANSLITERATIONS.items():
+        text = text.replace(char, replacement)
+    decomposed = unicodedata.normalize("NFKD", text)
+    return "".join(c for c in decomposed if not unicodedata.combining(c))
+
+
+def slugify(text, max_length=None):
+    """Lowercase ascii slug: word chars survive, separator runs become '-'."""
+    if max_length is not None and max_length < 1:
+        raise ValueError(f"max_length must be >= 1, got {max_length}")
+    folded = _fold_to_ascii(text)
+    pieces = []
+    in_word = False
+    for c in folded:
+        if c.isascii() and (c.isalpha() or c.isdigit()):
+            pieces.append(c)
+            in_word = True
+        elif in_word:
+            pieces.append("-")
+            in_word = False
+    slug = "".join(pieces).strip("-")
+    if max_length is not None and len(slug) > max_length:
+        if slug[max_length] != "-":
+            # mid-word cut: back up to the previous word boundary if any
+            head = slug[:max_length]
+            boundary = head.rfind("-")
+            slug = head[:boundary] if boundary != -1 else head
+        else:
+            slug = slug[:max_length]
+        slug = slug.rstrip("-")
+    return slug
+
+
+class SlugRegistry:
+    """Hands out unique slugs; reserved words are never given out bare."""
+
+    FALLBACK = "untitled"
+
+    def __init__(self, reserved=()):
+        self._taken = {slugify(word) for word in reserved}
+        self._next_suffix = {}
+
+    def assign(self, title):
+        base = slugify(title) or self.FALLBACK
+        if base not in self._taken:
+            self._taken.add(base)
+            return base
+        n = self._next_suffix.get(base, 2)
+        while f"{base}-{n}" in self._taken:
+            n += 1
+        slug = f"{base}-{n}"
+        self._taken.add(slug)
+        self._next_suffix[base] = n + 1
+        return slug
