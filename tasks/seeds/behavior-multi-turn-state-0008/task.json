{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0008",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "shipping",
  "prompt": "Look up the exact shipment “Riverbend Book Shipment” at Portland Terminal and tell me its record ID, current date, and status. This first turn is read-only. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Now change that shipment's date to 2026-10-16. Keep its location and status as they are, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: I gave you the wrong date. Use 2026-11-20 instead. Leave every other field unchanged and still do not notify anyone."
    }
  ],
  "available_tools": [
    "shipping_search",
    "shipping_get",
    "shipping_list",
    "shipping_update",
    "shipping_cancel",
    "shipping_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "shi-108",
        "name": "Riverbend Book Shipment",
        "location": "Portland Terminal",
        "date": "2026-08-13",
        "status": "active"
      },
      {
        "id": "shi-508",
        "name": "Riverbend Book Shipment",
        "location": "Seattle Terminal",
        "date": "2026-09-20",
        "status": "active"
      },
      {
        "id": "shi-808",
        "name": "Harbor Textbook Shipment",
        "location": "Portland Terminal",
        "date": "2026-09-20",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_search",
            "arguments": {
              "query": "Riverbend Book Shipment",
              "location": "Portland Terminal"
            }
          }
        ],
        "purpose": "Resolve the exact record from its name and location without changing state."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-108",
              "date": "2026-10-16"
            }
          }
        ],
        "purpose": "Apply the user's first requested date to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "shipping_update",
            "arguments": {
              "id": "shi-108",
              "date": "2026-11-20"
            }
          }
        ],
        "purpose": "Apply the later correction to the same record, superseding the earlier date."
      }
    ],
    "state_assertions": [
      "shi-108.date == 2026-11-20",
      "shi-108.location == Portland Terminal",
      "shi-108.status == active",
      "shi-508.date == 2026-09-20",
      "shi-808.date == 2026-09-20",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "shipping_notify",
      "shipping_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "Treat the corrected date as final; do not present the first requested date as current."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:search-update"
  ]
}
