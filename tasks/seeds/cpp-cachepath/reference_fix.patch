diff --git a/src/cache_path.cpp b/src/cache_path.cpp
--- a/src/cache_path.cpp
+++ b/src/cache_path.cpp
@@ -4,6 +4,36 @@
 
 namespace cachepath {
 
+namespace {
+
+bool IsPortableKeyByte(char value) {
+  const unsigned char byte = static_cast<unsigned char>(value);
+  return (byte >= static_cast<unsigned char>('a') &&
+          byte <= static_cast<unsigned char>('z')) ||
+         (byte >= static_cast<unsigned char>('A') &&
+          byte <= static_cast<unsigned char>('Z')) ||
+         (byte >= static_cast<unsigned char>('0') &&
+          byte <= static_cast<unsigned char>('9')) ||
+         byte == static_cast<unsigned char>('-') ||
+         byte == static_cast<unsigned char>('_') ||
+         byte == static_cast<unsigned char>('.');
+}
+
+bool IsDotComponent(std::string_view component) {
+  return component == "." || component == "..";
+}
+
+bool IsSafeKey(std::string_view key) {
+  for (const char value : key) {
+    if (!IsPortableKeyByte(value)) {
+      return false;
+    }
+  }
+  return !IsDotComponent(key.substr(0, 2)) && !IsDotComponent(key.substr(2));
+}
+
+}  // namespace
+
 MapResult MapCacheKey(const std::filesystem::path& root, std::string_view key) {
   if (root.empty()) {
     return {{}, MapError::kInvalidRoot};
@@ -14,6 +44,9 @@ MapResult MapCacheKey(const std::filesystem::path& root, std::string_view key) {
   if (key.size() > kMaxKeyLength) {
     return {{}, MapError::kKeyTooLong};
   }
+  if (!IsSafeKey(key)) {
+    return {{}, MapError::kInvalidKey};
+  }
   if (root.generic_string().size() > kMaxPathLength) {
     return {{}, MapError::kPathTooLong};
   }
