@@ -0,0 +1,22 @@
+"""JSONL exporter over the enhanced JQL search."""
+
+import json
+
+
+def export_jsonl(client, jql, fields, path, page_size=50):
+    """Stream a JQL search into ``path`` as JSONL and return the row count.
+
+    Each line is one issue as {"id", "key", "fields"}; values are written with
+    ensure_ascii=False so the file round-trips Jira's typed JSON exactly.
+    """
+    count = 0
+    with open(path, "w", encoding="utf-8") as fh:
+        for issue in client.search_all(jql, fields, page_size=page_size):
+            row = {
+                "id": issue.get("id"),
+                "key": issue.get("key"),
+                "fields": issue.get("fields") or {},
+            }
+            fh.write(json.dumps(row, ensure_ascii=False) + "\n")
+            count += 1
+    return count
