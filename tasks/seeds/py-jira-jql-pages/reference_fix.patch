+"""Client for the Jira Cloud enhanced JQL search (POST /rest/api/3/search/jql)."""
+
+import base64
+import json
+import urllib.error
+import urllib.request
+
+SEARCH_PATH = "/rest/api/3/search/jql"
+DEFAULT_PAGE_SIZE = 50  # documented maxResults default
+
+
+class JiraApiError(Exception):
+    """A non-2xx answer from the Jira Cloud REST API."""
+
+    def __init__(self, status, error_messages):
+        self.status = status
+        self.error_messages = [str(m) for m in error_messages]
+        detail = "; ".join(self.error_messages) or "(no error messages)"
+        super().__init__("Jira returned HTTP %d: %s" % (status, detail))
+
+
+class JiraSearchClient:
+    def __init__(self, base_url, email, api_token):
+        self._base = base_url.rstrip("/")
+        raw = ("%s:%s" % (email, api_token)).encode("utf-8")
+        self._authorization = "Basic " + base64.b64encode(raw).decode("ascii")
+
+    def search_all(self, jql, fields, page_size=DEFAULT_PAGE_SIZE, expand=None):
+        """Yield every issue matched by ``jql``, following nextPageToken.
+
+        Continuation is token-driven: the first request carries no token, each
+        following request echoes the previous response's token verbatim, and
+        the scan ends only when a response omits the token. Pages may be short
+        or even empty while more pages remain.
+        """
+        token = None
+        while True:
+            body = {"jql": jql, "maxResults": page_size, "fields": list(fields)}
+            if expand is not None:
+                body["expand"] = expand
+            if token is not None:
+                body["nextPageToken"] = token
+            page = self._post_json(SEARCH_PATH, body)
+            for issue in page.get("issues") or []:
+                yield issue
+            token = page.get("nextPageToken")
+            if not token:
+                return
+
+    def _post_json(self, path, body):
+        data = json.dumps(body).encode("utf-8")
+        request = urllib.request.Request(self._base + path, data=data, method="POST")
+        request.add_header("Authorization", self._authorization)
+        request.add_header("Content-Type", "application/json")
+        request.add_header("Accept", "application/json")
+        try:
+            with urllib.request.urlopen(request) as response:
+                return json.load(response)
+        except urllib.error.HTTPError as err:
+            raise JiraApiError(err.code, _error_messages(err)) from None
+
+
+def _error_messages(err):
+    try:
+        parsed = json.load(err)
+    except (ValueError, OSError):
+        return []
+    messages = parsed.get("errorMessages")
+    return messages if isinstance(messages, list) else []
