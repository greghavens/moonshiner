diff --git a/scratchprune.sh b/scratchprune.sh
index 24ea956..e0170b8 100644
--- a/scratchprune.sh
+++ b/scratchprune.sh
@@ -24,13 +24,13 @@ read_conf() {
 }
 
 line_count() {
-  local n=$(wc -l < "$1")
+  local n
+  n=$(wc -l < "$1")
   printf '%s' "${n// /}"
 }
 
 is_kept() {
-  grep -qx "$1" "$keep_file" 2>/dev/null
-  if [ $? -eq 0 ]; then
+  if grep -qx "$1" "$keep_file" 2>/dev/null; then
     return 0
   fi
