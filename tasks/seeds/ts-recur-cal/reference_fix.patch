@@ -0,0 +1,88 @@
+import { MINUTE, formatStamp, parseStamp, parseWindow } from './time.ts';
+
+export type Freq = 'daily' | 'weekly' | 'monthly';
+
+export interface Rule {
+  freq: Freq;
+  interval?: number;
+  count?: number;
+  until?: string;
+}
+
+const DAY = 1440 * MINUTE;
+const FREQS: readonly Freq[] = ['daily', 'weekly', 'monthly'];
+
+interface Checked {
+  freq: Freq;
+  interval: number;
+  count: number | null;
+  untilMs: number | null;
+}
+
+function checkRule(rule: Rule): Checked {
+  if (!FREQS.includes(rule.freq)) {
+    throw new Error(`unknown freq: ${String(rule.freq)}`);
+  }
+  const interval = rule.interval ?? 1;
+  if (!Number.isInteger(interval) || interval < 1) {
+    throw new Error(`interval must be a positive integer, got ${interval}`);
+  }
+  if (rule.count !== undefined && rule.until !== undefined) {
+    throw new Error('rule cannot have both count and until');
+  }
+  let count: number | null = null;
+  if (rule.count !== undefined) {
+    if (!Number.isInteger(rule.count) || rule.count < 1) {
+      throw new Error(`count must be a positive integer, got ${rule.count}`);
+    }
+    count = rule.count;
+  }
+  const untilMs = rule.until !== undefined ? parseStamp(rule.until) : null;
+  return { freq: rule.freq, interval, count, untilMs };
+}
+
+/** Infinite ascending series of occurrence times, invalid month days skipped. */
+function* series(dtstartMs: number, freq: Freq, interval: number): Generator<number> {
+  if (freq === 'monthly') {
+    const d = new Date(dtstartMs);
+    const y = d.getUTCFullYear();
+    const mo = d.getUTCMonth();
+    const day = d.getUTCDate();
+    const hh = d.getUTCHours();
+    const mm = d.getUTCMinutes();
+    for (let k = 0; ; k += interval) {
+      const t = Date.UTC(y, mo + k, day, hh, mm);
+      if (new Date(t).getUTCDate() !== day) continue; // month has no such day
+      yield t;
+    }
+  } else {
+    const step = interval * (freq === 'weekly' ? 7 : 1) * DAY;
+    for (let t = dtstartMs; ; t += step) yield t;
+  }
+}
+
+export function expand(
+  dtstart: string,
+  rule: Rule | null | undefined,
+  from: string,
+  to: string,
+): string[] {
+  const startMs = parseStamp(dtstart);
+  const [fromMs, toMs] = parseWindow(from, to);
+
+  if (rule === null || rule === undefined) {
+    return startMs >= fromMs && startMs < toMs ? [formatStamp(startMs)] : [];
+  }
+
+  const { freq, interval, count, untilMs } = checkRule(rule);
+  const out: string[] = [];
+  let generated = 0;
+  for (const t of series(startMs, freq, interval)) {
+    if (untilMs !== null && t > untilMs) break;
+    if (t >= toMs) break;
+    generated += 1;
+    if (t >= fromMs) out.push(formatStamp(t));
+    if (count !== null && generated >= count) break;
+  }
+  return out;
+}
