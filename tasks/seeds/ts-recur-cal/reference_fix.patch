+import type { Calendar } from './calendar.ts';
+import { MINUTE, formatStamp, parseStamp, parseWindow } from './time.ts';
+
+export interface SlotQuery {
+  from: string;
+  to: string;
+  durationMinutes: number;
+}
+
+export interface Slot {
+  start: string;
+  end: string;
+}
+
+export function freeSlots(calendar: Calendar, query: SlotQuery): Slot[] {
+  const [fromMs, toMs] = parseWindow(query.from, query.to);
+  if (!Number.isInteger(query.durationMinutes) || query.durationMinutes < 1) {
+    throw new Error(
+      `durationMinutes must be a positive integer, got ${query.durationMinutes}`,
+    );
+  }
+  const needed = query.durationMinutes * MINUTE;
+
+  // Busy intervals, clipped to the window and merged (touching runs collapse).
+  const busy = calendar
+    .occurrences(query.from, query.to)
+    .map((o) => ({
+      start: Math.max(parseStamp(o.start), fromMs),
+      end: Math.min(parseStamp(o.end), toMs),
+    }))
+    .filter((b) => b.end > b.start)
+    .sort((a, b) => a.start - b.start || a.end - b.end);
+
+  const merged: { start: number; end: number }[] = [];
+  for (const b of busy) {
+    const last = merged[merged.length - 1];
+    if (last && b.start <= last.end) {
+      last.end = Math.max(last.end, b.end);
+    } else {
+      merged.push({ ...b });
+    }
+  }
+
+  const slots: Slot[] = [];
+  let cursor = fromMs;
+  for (const b of [...merged, { start: toMs, end: toMs }]) {
+    if (b.start - cursor >= needed) {
+      slots.push({ start: formatStamp(cursor), end: formatStamp(b.start) });
+    }
+    cursor = Math.max(cursor, b.end);
+  }
+  return slots;
+}
