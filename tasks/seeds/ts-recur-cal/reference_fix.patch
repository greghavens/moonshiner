+import { expand } from './recur.ts';
+import type { Rule } from './recur.ts';
+import { MINUTE, formatStamp, parseStamp } from './time.ts';
+
+export interface EventInput {
+  id: string;
+  title: string;
+  start: string;
+  durationMinutes: number;
+  rule?: Rule | null;
+}
+
+export interface Occurrence {
+  id: string;
+  title: string;
+  start: string;
+  end: string;
+}
+
+interface StoredEvent {
+  id: string;
+  title: string;
+  start: string;
+  durationMinutes: number;
+  rule: Rule | null;
+}
+
+export class Calendar {
+  private events = new Map<string, StoredEvent>();
+
+  add(input: EventInput): void {
+    if (this.events.has(input.id)) {
+      throw new Error(`duplicate event id: ${input.id}`);
+    }
+    if (!Number.isInteger(input.durationMinutes) || input.durationMinutes < 1) {
+      throw new Error(
+        `durationMinutes must be a positive integer, got ${input.durationMinutes}`,
+      );
+    }
+    parseStamp(input.start); // validate eagerly
+    this.events.set(input.id, {
+      id: input.id,
+      title: input.title,
+      start: input.start,
+      durationMinutes: input.durationMinutes,
+      rule: input.rule ?? null,
+    });
+  }
+
+  remove(id: string): void {
+    if (!this.events.delete(id)) {
+      throw new Error(`unknown event id: ${id}`);
+    }
+  }
+
+  occurrences(from: string, to: string): Occurrence[] {
+    const out: Occurrence[] = [];
+    for (const ev of this.events.values()) {
+      for (const start of expand(ev.start, ev.rule, from, to)) {
+        const end = formatStamp(parseStamp(start) + ev.durationMinutes * MINUTE);
+        out.push({ id: ev.id, title: ev.title, start, end });
+      }
+    }
+    out.sort((a, b) =>
+      a.start !== b.start ? a.start.localeCompare(b.start) : a.id.localeCompare(b.id),
+    );
+    return out;
+  }
+
+  conflicts(from: string, to: string): [Occurrence, Occurrence][] {
+    const occs = this.occurrences(from, to);
+    const pairs: [Occurrence, Occurrence][] = [];
+    for (let i = 0; i < occs.length; i += 1) {
+      for (let j = i + 1; j < occs.length; j += 1) {
+        const a = occs[i];
+        const b = occs[j];
+        if (a.start < b.end && b.start < a.end) {
+          pairs.push([{ ...a }, { ...b }]);
+        }
+      }
+    }
+    return pairs;
+  }
+}
