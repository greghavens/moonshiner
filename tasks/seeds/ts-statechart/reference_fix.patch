+// Two-level hierarchical statechart engine.
+//
+// States nest at most two levels deep. Compound states declare an initial
+// substate; transitions may target any state; exit/entry ordering is
+// computed from the active path and the target path (deepest-first exits,
+// outermost-first entries, then initial-substate descent). Events bubble
+// from the active leaf toward the root until a handler matches; internal
+// transitions consume an event without touching the configuration.
+//
+// Deliberately no guards, hooks, actions or context: send() returns a
+// report of exactly what happened, and that report is the API.
+
+export type TransitionDef = string | { target?: string; internal?: boolean };
+
+export type StateDef = {
+  initial?: string;
+  children?: Record<string, StateDef>;
+  on?: Record<string, TransitionDef>;
+};
+
+export type ChartDef = {
+  initial: string;
+  states: Record<string, StateDef>;
+};
+
+export type SendResult = {
+  event: string;
+  handled: boolean;
+  by: string | null;
+  internal: boolean;
+  from: string;
+  to: string;
+  exited: string[];
+  entered: string[];
+};
+
+export class ChartError extends Error {
+  constructor(message: string) {
+    super(message);
+    this.name = 'ChartError';
+  }
+}
+
+type Node = {
+  id: string;
+  parent: string | null;
+  initial: string | null;
+  on: Map<string, TransitionDef>;
+};
+
+export class Statechart {
+  #nodes = new Map<string, Node>();
+  #path: string[];
+
+  constructor(def: ChartDef) {
+    for (const [id, state] of Object.entries(def.states)) {
+      this.#register(id, state, null);
+    }
+
+    const start = this.#nodes.get(def.initial);
+    if (!start) {
+      throw new ChartError(`chart initial "${def.initial}" is not a declared state`);
+    }
+    if (start.parent !== null) {
+      throw new ChartError(`chart initial "${def.initial}" must be a top-level state`);
+    }
+
+    for (const node of this.#nodes.values()) {
+      for (const [event, t] of node.on) {
+        this.#checkTransition(node, event, t);
+      }
+    }
+
+    this.#path = this.#descend([def.initial]);
+  }
+
+  #register(id: string, state: StateDef, parent: string | null): void {
+    if (this.#nodes.has(id)) {
+      throw new ChartError(`duplicate state id "${id}" — ids share one namespace`);
+    }
+    const childIds = state.children ? Object.keys(state.children) : [];
+    if (childIds.length > 0) {
+      if (parent !== null) {
+        throw new ChartError(
+          `state "${id}" nests deeper than two levels`);
+      }
+      if (state.initial === undefined) {
+        throw new ChartError(`compound state "${id}" must declare an initial substate`);
+      }
+      if (!childIds.includes(state.initial)) {
+        throw new ChartError(
+          `initial "${state.initial}" of "${id}" is not one of its children`);
+      }
+    } else if (state.initial !== undefined) {
+      throw new ChartError(`leaf state "${id}" must not declare an initial substate`);
+    }
+    this.#nodes.set(id, {
+      id,
+      parent,
+      initial: childIds.length > 0 ? (state.initial as string) : null,
+      on: new Map(Object.entries(state.on ?? {})),
+    });
+    if (state.children) {
+      for (const [childId, child] of Object.entries(state.children)) {
+        this.#register(childId, child, id);
+      }
+    }
+  }
+
+  #checkTransition(node: Node, event: string, t: TransitionDef): void {
+    if (typeof t === 'string') {
+      if (!this.#nodes.has(t)) {
+        throw new ChartError(
+          `transition "${event}" on "${node.id}" targets unknown state "${t}"`);
+      }
+      return;
+    }
+    if (t.internal === true) {
+      if (t.target !== undefined && t.target !== node.id) {
+        throw new ChartError(
+          `internal transition "${event}" on "${node.id}" may not target "${t.target}"`);
+      }
+      return;
+    }
+    if (t.target === undefined) {
+      throw new ChartError(
+        `transition "${event}" on "${node.id}" needs a target or internal: true`);
+    }
+    if (!this.#nodes.has(t.target)) {
+      throw new ChartError(
+        `transition "${event}" on "${node.id}" targets unknown state "${t.target}"`);
+    }
+  }
+
+  /** Root-to-state path for a state id. */
+  #pathOf(id: string): string[] {
+    const node = this.#nodes.get(id) as Node;
+    return node.parent === null ? [id] : [node.parent, id];
+  }
+
+  /** Extend a path through initial substates until it ends at a leaf. */
+  #descend(path: string[]): string[] {
+    const out = [...path];
+    let leaf = this.#nodes.get(out[out.length - 1]) as Node;
+    while (leaf.initial !== null) {
+      out.push(leaf.initial);
+      leaf = this.#nodes.get(leaf.initial) as Node;
+    }
+    return out;
+  }
+
+  current(): string[] {
+    return [...this.#path];
+  }
+
+  send(event: string): SendResult {
+    const from = this.#path[this.#path.length - 1];
+
+    // Bubble from the active leaf toward the root; deepest handler wins.
+    let handler: Node | null = null;
+    let transition: TransitionDef | null = null;
+    for (let i = this.#path.length - 1; i >= 0; i--) {
+      const node = this.#nodes.get(this.#path[i]) as Node;
+      const candidate = node.on.get(event);
+      if (candidate !== undefined) {
+        handler = node;
+        transition = candidate;
+        break;
+      }
+    }
+
+    if (handler === null || transition === null) {
+      return {
+        event, handled: false, by: null, internal: false,
+        from, to: from, exited: [], entered: [],
+      };
+    }
+
+    if (typeof transition === 'object' && transition.internal === true) {
+      return {
+        event, handled: true, by: handler.id, internal: true,
+        from, to: from, exited: [], entered: [],
+      };
+    }
+
+    const target = typeof transition === 'string'
+      ? transition
+      : (transition.target as string);
+    const targetPath = this.#pathOf(target);
+
+    // keep = length of the common prefix of active and target paths that
+    // stays active. If the target is an ancestor-or-equal of the active
+    // leaf, only what is strictly above the target survives: an external
+    // self-transition exits its own subtree.
+    let keep = 0;
+    while (
+      keep < this.#path.length &&
+      keep < targetPath.length &&
+      this.#path[keep] === targetPath[keep]
+    ) {
+      keep++;
+    }
+    if (targetPath.length <= keep) {
+      keep = targetPath.length - 1;
+    }
+
+    const exited = this.#path.slice(keep).reverse();
+    const nextPath = this.#descend(targetPath);
+    const entered = nextPath.slice(keep);
+    this.#path = nextPath;
+
+    return {
+      event, handled: true, by: handler.id, internal: false,
+      from, to: nextPath[nextPath.length - 1], exited, entered,
+    };
+  }
+}
