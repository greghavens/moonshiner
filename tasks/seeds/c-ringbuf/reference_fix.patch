diff --git a/ringbuf.c b/ringbuf.c
new file mode 100644
index 0000000..360c251
--- /dev/null
+++ b/ringbuf.c
@@ -0,0 +1,85 @@
+#include "ringbuf.h"
+
+#include <string.h>
+
+int rb_init(ringbuf *rb, void *storage, size_t cap) {
+    if (storage == NULL || cap == 0)
+        return -1;
+    rb->buf = storage;
+    rb->cap = cap;
+    rb->head = 0;
+    rb->count = 0;
+    rb->high = 0;
+    return 0;
+}
+
+/* Copy n bytes out of the ring starting at logical offset 0 (the
+ * oldest byte), splitting the copy at the wrap seam if needed.
+ * Does not touch head or count. */
+static void copy_out(const ringbuf *rb, unsigned char *dst, size_t n) {
+    size_t start = rb->head;
+    size_t first = rb->cap - start; /* contiguous bytes up to the end */
+    if (first > n)
+        first = n;
+    memcpy(dst, rb->buf + start, first);
+    if (n > first)
+        memcpy(dst + first, rb->buf, n - first);
+}
+
+size_t rb_write(ringbuf *rb, const void *src, size_t n) {
+    size_t space = rb->cap - rb->count;
+    if (n > space)
+        n = space; /* accept the front, drop the tail */
+    if (n == 0)
+        return 0;
+
+    size_t tail = (rb->head + rb->count) % rb->cap;
+    size_t first = rb->cap - tail; /* contiguous room up to the end */
+    if (first > n)
+        first = n;
+    memcpy(rb->buf + tail, src, first);
+    if (n > first)
+        memcpy(rb->buf, (const unsigned char *)src + first, n - first);
+
+    rb->count += n;
+    if (rb->count > rb->high)
+        rb->high = rb->count;
+    return n;
+}
+
+size_t rb_read(ringbuf *rb, void *dst, size_t n) {
+    if (n > rb->count)
+        n = rb->count;
+    if (n == 0)
+        return 0;
+    copy_out(rb, dst, n);
+    rb->head = (rb->head + n) % rb->cap;
+    rb->count -= n;
+    return n;
+}
+
+size_t rb_peek(const ringbuf *rb, void *dst, size_t n) {
+    if (n > rb->count)
+        n = rb->count;
+    if (n == 0)
+        return 0;
+    copy_out(rb, dst, n);
+    return n;
+}
+
+size_t rb_len(const ringbuf *rb) {
+    return rb->count;
+}
+
+size_t rb_avail(const ringbuf *rb) {
+    return rb->cap - rb->count;
+}
+
+size_t rb_high(const ringbuf *rb) {
+    return rb->high;
+}
+
+void rb_clear(ringbuf *rb) {
+    rb->head = 0;
+    rb->count = 0;
+}
diff --git a/ringbuf.h b/ringbuf.h
new file mode 100644
index 0000000..05f7ee6
--- /dev/null
+++ b/ringbuf.h
@@ -0,0 +1,40 @@
+#ifndef RINGBUF_H
+#define RINGBUF_H
+
+#include <stddef.h>
+
+/* Fixed-capacity byte queue over caller-provided storage.
+ * Full vs empty is tracked with the count field, so all cap bytes
+ * are usable. The struct never owns memory. */
+typedef struct {
+    unsigned char *buf;   /* caller's storage, cap bytes */
+    size_t cap;
+    size_t head;          /* index of the oldest byte */
+    size_t count;         /* bytes currently stored */
+    size_t high;          /* largest count ever seen */
+} ringbuf;
+
+/* 0 on success; -1 if storage is NULL or cap is 0. */
+int    rb_init(ringbuf *rb, void *storage, size_t cap);
+
+/* Append up to n bytes from src; returns bytes accepted =
+ * min(n, free space). Partial writes keep the front of src. */
+size_t rb_write(ringbuf *rb, const void *src, size_t n);
+
+/* Remove up to n of the oldest bytes into dst; returns bytes
+ * removed = min(n, count). */
+size_t rb_read(ringbuf *rb, void *dst, size_t n);
+
+/* Same as rb_read but does not consume. */
+size_t rb_peek(const ringbuf *rb, void *dst, size_t n);
+
+size_t rb_len(const ringbuf *rb);
+size_t rb_avail(const ringbuf *rb);
+
+/* High-water mark: largest count ever reached. Never decreases. */
+size_t rb_high(const ringbuf *rb);
+
+/* Empty the ring (count = 0). Keeps the high-water mark. */
+void   rb_clear(ringbuf *rb);
+
+#endif /* RINGBUF_H */
