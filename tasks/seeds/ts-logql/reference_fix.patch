+import { tokenize } from './lexer.ts';
+import type { Token } from './lexer.ts';
+import { ParseError } from './errors.ts';
+
+export { ParseError };
+
+export type Literal = string | number | boolean;
+export type CmpOp = '=' | '!=' | '>' | '>=' | '<' | '<=' | '~';
+
+export type Expr =
+  | { kind: 'cmp'; field: string; op: CmpOp; value: Literal }
+  | { kind: 'and'; left: Expr; right: Expr }
+  | { kind: 'or'; left: Expr; right: Expr }
+  | { kind: 'not'; expr: Expr };
+
+export type AggFn = 'count' | 'sum' | 'avg' | 'min' | 'max';
+
+export interface Stats {
+  fn: AggFn;
+  field?: string;
+  by?: string;
+}
+
+export interface Query {
+  where: Expr;
+  stats?: Stats;
+}
+
+const AGG_FNS: readonly AggFn[] = ['count', 'sum', 'avg', 'min', 'max'];
+
+class Parser {
+  private tokens: Token[];
+  private idx = 0;
+
+  constructor(text: string) {
+    this.tokens = tokenize(text);
+  }
+
+  private peek(): Token {
+    return this.tokens[this.idx];
+  }
+
+  private advance(): Token {
+    const tok = this.tokens[this.idx];
+    if (tok.type !== 'eof') this.idx += 1;
+    return tok;
+  }
+
+  private fail(what: string, tok: Token): never {
+    throw new ParseError(`${what} at position ${tok.pos}`, tok.pos);
+  }
+
+  query(): Query {
+    const where = this.or();
+    let stats: Stats | undefined;
+    if (this.peek().type === 'pipe') {
+      this.advance();
+      stats = this.stats();
+    }
+    const tail = this.peek();
+    if (tail.type !== 'eof') {
+      this.fail(`unexpected token '${tail.text}'`, tail);
+    }
+    return stats ? { where, stats } : { where };
+  }
+
+  private or(): Expr {
+    let left = this.and();
+    while (this.isKeyword('OR')) {
+      this.advance();
+      left = { kind: 'or', left, right: this.and() };
+    }
+    return left;
+  }
+
+  private and(): Expr {
+    let left = this.not();
+    while (this.isKeyword('AND')) {
+      this.advance();
+      left = { kind: 'and', left, right: this.not() };
+    }
+    return left;
+  }
+
+  private not(): Expr {
+    if (this.isKeyword('NOT')) {
+      this.advance();
+      return { kind: 'not', expr: this.not() };
+    }
+    return this.primary();
+  }
+
+  private primary(): Expr {
+    const tok = this.peek();
+    if (tok.type === 'lparen') {
+      this.advance();
+      const inner = this.or();
+      const close = this.peek();
+      if (close.type !== 'rparen') this.fail("expected ')'", close);
+      this.advance();
+      return inner;
+    }
+    if (tok.type === 'ident') {
+      const field = this.advance().text;
+      const op = this.peek();
+      if (op.type !== 'op') this.fail('expected a comparison operator', op);
+      this.advance();
+      const value = this.value();
+      return { kind: 'cmp', field, op: op.text as CmpOp, value };
+    }
+    this.fail(`unexpected token '${tok.text === '' ? 'end of input' : tok.text}'`, tok);
+  }
+
+  private value(): Literal {
+    const tok = this.peek();
+    if (tok.type === 'string' || tok.type === 'number') {
+      this.advance();
+      return tok.value as Literal;
+    }
+    if (tok.type === 'ident' && (tok.text === 'true' || tok.text === 'false')) {
+      this.advance();
+      return tok.text === 'true';
+    }
+    this.fail('expected a value', tok);
+  }
+
+  private stats(): Stats {
+    const kw = this.peek();
+    if (kw.type !== 'ident' || kw.text !== 'stats') {
+      this.fail("expected 'stats' after '|'", kw);
+    }
+    this.advance();
+    const fnTok = this.peek();
+    if (fnTok.type !== 'ident') this.fail('expected an aggregate function', fnTok);
+    if (!AGG_FNS.includes(fnTok.text as AggFn)) {
+      this.fail(`unknown aggregate function '${fnTok.text}'`, fnTok);
+    }
+    this.advance();
+    const fn = fnTok.text as AggFn;
+    const out: Stats = { fn };
+    if (fn !== 'count') {
+      const open = this.peek();
+      if (open.type !== 'lparen') this.fail("expected '('", open);
+      this.advance();
+      const fieldTok = this.peek();
+      if (fieldTok.type !== 'ident') this.fail('expected a field name', fieldTok);
+      this.advance();
+      out.field = fieldTok.text;
+      const close = this.peek();
+      if (close.type !== 'rparen') this.fail("expected ')'", close);
+      this.advance();
+    }
+    if (this.isKeyword('by')) {
+      this.advance();
+      const byTok = this.peek();
+      if (byTok.type !== 'ident') this.fail("expected a field after 'by'", byTok);
+      this.advance();
+      out.by = byTok.text;
+    }
+    return out;
+  }
+
+  private isKeyword(word: string): boolean {
+    const tok = this.peek();
+    return tok.type === 'ident' && tok.text === word;
+  }
+}
+
+export function parse(text: string): Query {
+  return new Parser(text).query();
+}
