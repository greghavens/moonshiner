+import { ParseError } from './errors.ts';
+
+export type TokenType =
+  | 'ident'
+  | 'string'
+  | 'number'
+  | 'op'
+  | 'lparen'
+  | 'rparen'
+  | 'pipe'
+  | 'eof';
+
+export interface Token {
+  type: TokenType;
+  text: string;
+  value?: string | number;
+  pos: number; // 1-based
+}
+
+const IDENT_START = /[A-Za-z_]/;
+const IDENT_PART = /[A-Za-z0-9_]/;
+const DIGIT = /[0-9]/;
+
+export function tokenize(text: string): Token[] {
+  const tokens: Token[] = [];
+  let i = 0;
+  while (i < text.length) {
+    const ch = text[i];
+    const pos = i + 1;
+    if (ch === ' ' || ch === '\t' || ch === '\n' || ch === '\r') {
+      i += 1;
+      continue;
+    }
+    if (ch === '(') {
+      tokens.push({ type: 'lparen', text: '(', pos });
+      i += 1;
+    } else if (ch === ')') {
+      tokens.push({ type: 'rparen', text: ')', pos });
+      i += 1;
+    } else if (ch === '|') {
+      tokens.push({ type: 'pipe', text: '|', pos });
+      i += 1;
+    } else if (ch === '=' || ch === '~') {
+      tokens.push({ type: 'op', text: ch, pos });
+      i += 1;
+    } else if (ch === '>' || ch === '<') {
+      if (text[i + 1] === '=') {
+        tokens.push({ type: 'op', text: ch + '=', pos });
+        i += 2;
+      } else {
+        tokens.push({ type: 'op', text: ch, pos });
+        i += 1;
+      }
+    } else if (ch === '!') {
+      if (text[i + 1] !== '=') {
+        throw new ParseError(`unexpected character '!' at position ${pos}`, pos);
+      }
+      tokens.push({ type: 'op', text: '!=', pos });
+      i += 2;
+    } else if (ch === '"') {
+      let j = i + 1;
+      let value = '';
+      let closed = false;
+      while (j < text.length) {
+        const c = text[j];
+        if (c === '\\' && (text[j + 1] === '"' || text[j + 1] === '\\')) {
+          value += text[j + 1];
+          j += 2;
+        } else if (c === '"') {
+          closed = true;
+          j += 1;
+          break;
+        } else {
+          value += c;
+          j += 1;
+        }
+      }
+      if (!closed) {
+        throw new ParseError(`unterminated string at position ${pos}`, pos);
+      }
+      tokens.push({ type: 'string', text: text.slice(i, j), value, pos });
+      i = j;
+    } else if (DIGIT.test(ch) || (ch === '-' && DIGIT.test(text[i + 1] ?? ''))) {
+      let j = i + 1;
+      while (j < text.length && DIGIT.test(text[j])) j += 1;
+      if (text[j] === '.' && DIGIT.test(text[j + 1] ?? '')) {
+        j += 1;
+        while (j < text.length && DIGIT.test(text[j])) j += 1;
+      }
+      const raw = text.slice(i, j);
+      tokens.push({ type: 'number', text: raw, value: Number(raw), pos });
+      i = j;
+    } else if (IDENT_START.test(ch)) {
+      let j = i + 1;
+      while (j < text.length && IDENT_PART.test(text[j])) j += 1;
+      const raw = text.slice(i, j);
+      tokens.push({ type: 'ident', text: raw, value: raw, pos });
+      i = j;
+    } else {
+      throw new ParseError(`unexpected character '${ch}' at position ${pos}`, pos);
+    }
+  }
+  tokens.push({ type: 'eof', text: '', pos: text.length + 1 });
+  return tokens;
+}
