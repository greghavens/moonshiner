+import { parse } from './parse.ts';
+import type { Expr, Literal, Stats } from './parse.ts';
+
+export type LogRecord = Record<string, unknown>;
+
+export interface StatsRow {
+  group?: unknown;
+  value: number | null;
+}
+
+function compare(field: unknown, op: string, literal: Literal): boolean {
+  if (field === undefined) return false; // a missing field fails every comparison
+  switch (op) {
+    case '=':
+      return field === literal;
+    case '!=':
+      return field !== literal;
+    case '~':
+      return (
+        typeof field === 'string' &&
+        typeof literal === 'string' &&
+        field.toLowerCase().includes(literal.toLowerCase())
+      );
+    default: {
+      if (typeof field !== 'number' || typeof literal !== 'number') return false;
+      if (Number.isNaN(field)) return false;
+      if (op === '>') return field > literal;
+      if (op === '>=') return field >= literal;
+      if (op === '<') return field < literal;
+      return field <= literal;
+    }
+  }
+}
+
+function matches(expr: Expr, record: LogRecord): boolean {
+  switch (expr.kind) {
+    case 'cmp':
+      return compare(record[expr.field], expr.op, expr.value);
+    case 'and':
+      return matches(expr.left, record) && matches(expr.right, record);
+    case 'or':
+      return matches(expr.left, record) || matches(expr.right, record);
+    case 'not':
+      return !matches(expr.expr, record);
+  }
+}
+
+function fold(fn: Stats['fn'], values: number[], recordCount: number): number | null {
+  switch (fn) {
+    case 'count':
+      return recordCount;
+    case 'sum':
+      return values.reduce((a, b) => a + b, 0);
+    case 'avg':
+      return values.length === 0 ? null : values.reduce((a, b) => a + b, 0) / values.length;
+    case 'min':
+      return values.length === 0 ? null : Math.min(...values);
+    case 'max':
+      return values.length === 0 ? null : Math.max(...values);
+  }
+}
+
+function numericValues(records: LogRecord[], field: string): number[] {
+  const out: number[] = [];
+  for (const r of records) {
+    const v = r[field];
+    if (typeof v === 'number' && !Number.isNaN(v)) out.push(v);
+  }
+  return out;
+}
+
+function aggregate(stats: Stats, records: LogRecord[]): StatsRow[] {
+  if (stats.by === undefined) {
+    const values = stats.field === undefined ? [] : numericValues(records, stats.field);
+    return [{ value: fold(stats.fn, values, records.length) }];
+  }
+  const groups = new Map<unknown, LogRecord[]>();
+  for (const r of records) {
+    const key = r[stats.by];
+    if (key === undefined) continue; // no group, no row
+    let bucket = groups.get(key);
+    if (!bucket) {
+      bucket = [];
+      groups.set(key, bucket);
+    }
+    bucket.push(r);
+  }
+  const rows: StatsRow[] = [];
+  for (const [group, bucket] of groups) {
+    const values = stats.field === undefined ? [] : numericValues(bucket, stats.field);
+    rows.push({ group, value: fold(stats.fn, values, bucket.length) });
+  }
+  rows.sort((a, b) => {
+    const ga = String(a.group);
+    const gb = String(b.group);
+    return ga < gb ? -1 : ga > gb ? 1 : 0;
+  });
+  return rows;
+}
+
+export function run(text: string, records: LogRecord[]): LogRecord[] | StatsRow[] {
+  const query = parse(text);
+  const matching = records.filter((r) => matches(query.where, r));
+  if (!query.stats) return matching;
+  return aggregate(query.stats, matching);
+}
