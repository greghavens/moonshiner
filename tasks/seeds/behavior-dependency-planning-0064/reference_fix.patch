+#!/usr/bin/env python3
+"""Reference proof using the genuine message executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import shlex
+import subprocess
+import tempfile
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Donor Reception Follow-Up", "Advancement"),
+    ("Exhibit Opening Invitation", "Museum Members"),
+)
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Run one dependency phase as direct, overlapping shell children."""
+    if not commands:
+        return []
+    with tempfile.TemporaryDirectory(prefix="message-reference-") as directory:
+        output_paths = [Path(directory) / f"result-{index}.json" for index in range(len(commands))]
+        launches = [
+            f"{shlex.join(command)} > {shlex.quote(str(output_path))} & job_{index}=$!"
+            for index, (command, output_path) in enumerate(zip(commands, output_paths, strict=True))
+        ]
+        waits = [
+            f"wait \"$job_{index}\"; status_{index}=$?"
+            for index in range(len(commands))
+        ]
+        check = " && ".join(
+            f"test \"$status_{index}\" -eq 0" for index in range(len(commands))
+        )
+        action = "; ".join(launches + waits + [check])
+        completed = subprocess.run(
+            ["/bin/bash", "-lc", action],
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+            check=False,
+            timeout=30,
+        )
+        if completed.returncode != 0:
+            raise RuntimeError(completed.stderr.strip() or "message phase failed")
+        payloads = [json.loads(path.read_text(encoding="utf-8")) for path in output_paths]
+    if not all(isinstance(payload, dict) for payload in payloads):
+        raise RuntimeError("message phase returned an invalid payload")
+    return payloads
+
+
+def main() -> int:
+    subprocess.run(
+        ["./messagectl", "--help"],
+        cwd=ROOT,
+        stdout=subprocess.DEVNULL,
+        check=True,
+    )
+    searches = run_phase(
+        [
+            ["./messagectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        match = matches[0]
+        if not isinstance(match, dict):
+            continue
+        stable_id = match.get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./messagectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    lines = ["| Record | ID | Date | Status |", "|---|---|---|---|"]
+    for index, record in enumerate(retrieved):
+        if record is None:
+            lines.append(f"| {TARGETS[index][0]} | UNRESOLVED | UNRESOLVED | UNRESOLVED |")
+            continue
+        values = [record.get(field) for field in ("name", "id", "date", "status")]
+        if not all(isinstance(value, str) and value for value in values):
+            raise RuntimeError("full message record omitted a required value")
+        lines.append(f"| {values[0]} | {values[1]} | {values[2]} | {values[3]} |")
+    (ROOT / "message-audit.md").write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
