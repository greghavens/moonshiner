+namespace Uno;
+
+public static class Rules
+{
+    public static bool IsPlayable(string card, string top, string activeColor)
+    {
+        if (card == "W") return true;
+        if (card[..1] == activeColor) return true;
+        if (IsNumber(card) && IsNumber(top) && card[1] == top[1]) return true;
+        if (IsAction(card) && IsAction(top) && card[1] == top[1]) return true;
+        return false;
+    }
+
+    internal static bool IsNumber(string card) =>
+        card.Length == 2 && card[1] is >= '0' and <= '9';
+
+    internal static bool IsAction(string card) =>
+        card.Length == 2 && card[1] is 'S' or 'R' or 'D';
+
+    internal static void ValidateCard(string card)
+    {
+        if (card == "W") return;
+        if (card.Length == 2 && card[0] is 'R' or 'G' or 'B' or 'Y' &&
+            (IsNumber(card) || IsAction(card)))
+            return;
+        throw new FormatException($"not a card: {card}");
+    }
+}
+
+public class Game
+{
+    private readonly List<List<string>> _hands = new();
+    private readonly List<string> _pile;
+    private int _current;
+    private bool _clockwise = true;
+
+    public string TopCard { get; private set; }
+    public string ActiveColor { get; private set; }
+    public bool IsOver { get; private set; }
+    public string? Winner { get; private set; }
+
+    public string CurrentPlayer => Name(_current);
+    public bool DirectionClockwise => _clockwise;
+    public int PileCount => _pile.Count;
+
+    private Game(List<List<string>> hands, string flip, List<string> pile)
+    {
+        _hands = hands;
+        TopCard = flip;
+        ActiveColor = flip[..1];
+        _pile = pile;
+    }
+
+    public static Game Start(string deckText, int playerCount, int handSize = 7)
+    {
+        if (playerCount is < 2 or > 4)
+            throw new ArgumentException($"player count must be 2-4: {playerCount}");
+        if (handSize is < 1 or > 10)
+            throw new ArgumentException($"hand size must be 1-10: {handSize}");
+
+        var deck = new List<string>();
+        foreach (var rawLine in deckText.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            foreach (var token in line.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries))
+            {
+                Rules.ValidateCard(token);
+                deck.Add(token);
+            }
+        }
+        if (deck.Count < playerCount * handSize + 1)
+            throw new ArgumentException("deck is too short to deal and flip");
+
+        var hands = Enumerable.Range(0, playerCount).Select(_ => new List<string>()).ToList();
+        var next = 0;
+        for (var round = 0; round < handSize; round++)
+            foreach (var hand in hands)
+                hand.Add(deck[next++]);
+        var flip = deck[next++];
+        if (!Rules.IsNumber(flip))
+            throw new ArgumentException($"the flip must be a number card: {flip}");
+        return new Game(hands, flip, deck.Skip(next).ToList());
+    }
+
+    public IReadOnlyList<string> Hand(string player) => _hands[IndexOf(player)];
+
+    public string RunScript(string scriptText)
+    {
+        var lines = new List<string>();
+        foreach (var rawLine in scriptText.Split('\n'))
+        {
+            var line = rawLine;
+            var hash = line.IndexOf('#');
+            if (hash >= 0) line = line[..hash];
+            if (line.Trim().Length == 0) continue;
+            lines.AddRange(Execute(line));
+        }
+        return string.Join('\n', lines);
+    }
+
+    public IReadOnlyList<string> Execute(string command)
+    {
+        if (IsOver)
+            throw new InvalidOperationException("the game is over");
+        var parts = command.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries);
+        return parts switch
+        {
+            ["play", var card] => Play(card, null),
+            ["play", var card, var color] => Play(card, ValidColor(color)),
+            ["draw"] => Draw(null),
+            ["draw", var color] => Draw(ValidColor(color)),
+            _ => throw new FormatException($"bad command: {command}"),
+        };
+    }
+
+    private IReadOnlyList<string> Play(string card, string? color)
+    {
+        Rules.ValidateCard(card);
+        RequireColorIff(card == "W", color);
+        var hand = _hands[_current];
+        if (!hand.Contains(card))
+            throw new InvalidOperationException($"{CurrentPlayer} does not hold {card}");
+        if (!Rules.IsPlayable(card, TopCard, ActiveColor))
+            throw new InvalidOperationException($"{card} is not playable");
+
+        var lines = new List<string>
+        {
+            card == "W" ? $"{CurrentPlayer} plays W and picks {color}"
+                        : $"{CurrentPlayer} plays {card}",
+        };
+        hand.Remove(card);
+        Settle(card, color, lines);
+        return lines;
+    }
+
+    private IReadOnlyList<string> Draw(string? color)
+    {
+        if (_pile.Count == 0)
+            throw new InvalidOperationException("the draw pile is empty");
+        var card = _pile[0];
+        if (Rules.IsPlayable(card, TopCard, ActiveColor))
+        {
+            RequireColorIff(card == "W", color);
+            _pile.RemoveAt(0);
+            var lines = new List<string>
+            {
+                card == "W" ? $"{CurrentPlayer} draws W and plays it and picks {color}"
+                            : $"{CurrentPlayer} draws {card} and plays it",
+            };
+            Settle(card, color, lines);
+            return lines;
+        }
+        if (color is not null)
+            throw new InvalidOperationException("no color choice expected");
+        _pile.RemoveAt(0);
+        _hands[_current].Add(card);
+        var kept = new List<string> { $"{CurrentPlayer} draws {card} and keeps it" };
+        Advance(1);
+        return kept;
+    }
+
+    // The played card is already out of the hand: set top/color, then either
+    // declare the win or apply the card's effect and move the turn on.
+    private void Settle(string card, string? color, List<string> lines)
+    {
+        TopCard = card;
+        ActiveColor = card == "W" ? color! : card[..1];
+        if (_hands[_current].Count == 0)
+        {
+            IsOver = true;
+            Winner = CurrentPlayer;
+            lines.Add($"{CurrentPlayer} wins");
+            return;
+        }
+
+        if (!Rules.IsAction(card))
+        {
+            Advance(1);
+            return;
+        }
+        switch (card[1])
+        {
+            case 'S':
+                lines.Add($"{Name(Neighbor())} is skipped");
+                Advance(2);
+                break;
+            case 'R':
+                _clockwise = !_clockwise;
+                lines.Add($"direction is now {(_clockwise ? "clockwise" : "counter-clockwise")}");
+                if (_hands.Count == 2)
+                {
+                    lines.Add($"{Name(Neighbor())} is skipped");
+                    Advance(2);
+                }
+                else
+                {
+                    Advance(1);
+                }
+                break;
+            case 'D':
+                var victim = Neighbor();
+                if (_pile.Count < 2)
+                    throw new InvalidOperationException("the draw pile is empty");
+                _hands[victim].Add(_pile[0]);
+                _hands[victim].Add(_pile[1]);
+                _pile.RemoveRange(0, 2);
+                lines.Add($"{Name(victim)} draws 2 and is skipped");
+                Advance(2);
+                break;
+        }
+    }
+
+    private static void RequireColorIff(bool isWild, string? color)
+    {
+        if (isWild && color is null)
+            throw new InvalidOperationException("a wild needs a color choice");
+        if (!isWild && color is not null)
+            throw new InvalidOperationException("no color choice expected");
+    }
+
+    private static string ValidColor(string color)
+    {
+        if (color is "R" or "G" or "B" or "Y") return color;
+        throw new FormatException($"not a color: {color}");
+    }
+
+    private int Neighbor() =>
+        (((_current + (_clockwise ? 1 : -1)) % _hands.Count) + _hands.Count) % _hands.Count;
+
+    private void Advance(int steps)
+    {
+        var delta = (_clockwise ? 1 : -1) * steps;
+        _current = (((_current + delta) % _hands.Count) + _hands.Count) % _hands.Count;
+    }
+
+    private static string Name(int index) => $"P{index + 1}";
+
+    private int IndexOf(string player)
+    {
+        for (var i = 0; i < _hands.Count; i++)
+            if (Name(i) == player) return i;
+        throw new ArgumentException($"unknown player: {player}");
+    }
+}
