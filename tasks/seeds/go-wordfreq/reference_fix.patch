diff --git a/topk.go b/topk.go
new file mode 100644
index 0000000..da4816d
--- /dev/null
+++ b/topk.go
@@ -0,0 +1,50 @@
+package wordfreq
+
+import (
+	"sort"
+	"strings"
+)
+
+// Entry is one row of a frequency report.
+type Entry struct {
+	Word  string
+	Count int
+}
+
+// SetStopwords replaces the counter's stopword set. Stopwords are
+// matched case-insensitively and are hidden from TopK reports only;
+// the raw tally (Count, Total, Distinct) is unaffected. Passing an
+// empty or nil slice clears the set.
+func (c *Counter) SetStopwords(words []string) {
+	c.stop = make(map[string]bool, len(words))
+	for _, w := range words {
+		c.stop[strings.ToLower(w)] = true
+	}
+}
+
+// TopK returns the k most frequent non-stopword entries, ordered by
+// descending count with alphabetical order breaking ties, so the
+// result is deterministic run to run. k larger than the vocabulary
+// returns every entry; k <= 0 returns an empty slice.
+func (c *Counter) TopK(k int) []Entry {
+	entries := make([]Entry, 0, len(c.counts))
+	for w, n := range c.counts {
+		if c.stop[w] {
+			continue
+		}
+		entries = append(entries, Entry{Word: w, Count: n})
+	}
+	sort.Slice(entries, func(i, j int) bool {
+		if entries[i].Count != entries[j].Count {
+			return entries[i].Count > entries[j].Count
+		}
+		return entries[i].Word < entries[j].Word
+	})
+	if k < 0 {
+		k = 0
+	}
+	if k > len(entries) {
+		k = len(entries)
+	}
+	return entries[:k]
+}
