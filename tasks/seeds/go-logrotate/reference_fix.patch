+// Package logrotate provides an io.Writer that appends to a log file and
+// rotates it in-line on the write path once a size threshold would be
+// exceeded, keeping a bounded chain of numbered backups.
+package logrotate
+
+import (
+	"errors"
+	"fmt"
+	"os"
+	"path/filepath"
+	"sync"
+)
+
+// Writer is a size-rotating log file writer. It is safe for concurrent use
+// by multiple goroutines.
+type Writer struct {
+	path    string
+	maxSize int64
+	backups int
+
+	mu     sync.Mutex
+	f      *os.File
+	size   int64
+	closed bool
+}
+
+// New opens (or creates) the log file at path. The parent directory must
+// already exist. An existing file's size counts toward the rotation
+// threshold immediately.
+func New(path string, maxSize int64, backups int) (*Writer, error) {
+	if maxSize <= 0 {
+		return nil, fmt.Errorf("logrotate: maxSize must be positive, got %d", maxSize)
+	}
+	if backups < 0 {
+		return nil, fmt.Errorf("logrotate: backups must be >= 0, got %d", backups)
+	}
+	if _, err := os.Stat(filepath.Dir(path)); err != nil {
+		return nil, fmt.Errorf("logrotate: parent directory: %w", err)
+	}
+	f, err := os.OpenFile(path, os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0o644)
+	if err != nil {
+		return nil, fmt.Errorf("logrotate: open log: %w", err)
+	}
+	st, err := f.Stat()
+	if err != nil {
+		f.Close()
+		return nil, fmt.Errorf("logrotate: stat log: %w", err)
+	}
+	return &Writer{path: path, maxSize: maxSize, backups: backups, f: f, size: st.Size()}, nil
+}
+
+// Close flushes nothing (writes are unbuffered) and releases the file.
+// Subsequent Writes fail.
+func (w *Writer) Close() error {
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	if w.closed {
+		return errors.New("logrotate: already closed")
+	}
+	w.closed = true
+	return w.f.Close()
+}
diff --git a/rotate.go b/rotate.go
new file mode 100644
index 0000000..a49d1a1
--- /dev/null
+++ b/rotate.go
@@ -0,0 +1,45 @@
+package logrotate
+
+import (
+	"fmt"
+	"os"
+	"strconv"
+)
+
+// rotate shifts the backup chain and reopens a fresh, empty current file.
+// Caller must hold w.mu.
+func (w *Writer) rotate() error {
+	if err := w.f.Close(); err != nil {
+		return fmt.Errorf("logrotate: close before rotate: %w", err)
+	}
+	if w.backups == 0 {
+		if err := os.Remove(w.path); err != nil && !os.IsNotExist(err) {
+			return fmt.Errorf("logrotate: drop old log: %w", err)
+		}
+	} else {
+		// Shift path.(n) -> path.(n+1) from the top down; the entry at
+		// the retention limit is overwritten by the rename below it.
+		if err := os.Remove(w.backup(w.backups)); err != nil && !os.IsNotExist(err) {
+			return fmt.Errorf("logrotate: prune oldest backup: %w", err)
+		}
+		for i := w.backups - 1; i >= 1; i-- {
+			if err := os.Rename(w.backup(i), w.backup(i+1)); err != nil && !os.IsNotExist(err) {
+				return fmt.Errorf("logrotate: shift backup %d: %w", i, err)
+			}
+		}
+		if err := os.Rename(w.path, w.backup(1)); err != nil {
+			return fmt.Errorf("logrotate: archive current log: %w", err)
+		}
+	}
+	f, err := os.OpenFile(w.path, os.O_CREATE|os.O_WRONLY|os.O_APPEND|os.O_EXCL, 0o644)
+	if err != nil {
+		return fmt.Errorf("logrotate: open fresh log: %w", err)
+	}
+	w.f = f
+	w.size = 0
+	return nil
+}
+
+func (w *Writer) backup(n int) string {
+	return w.path + "." + strconv.Itoa(n)
+}
diff --git a/write.go b/write.go
new file mode 100644
index 0000000..cbb44fd
--- /dev/null
+++ b/write.go
@@ -0,0 +1,22 @@
+package logrotate
+
+import "errors"
+
+// Write appends p to the current log file, rotating first if the write
+// would push the file past maxSize. A single Write is never split across
+// files, so oversized payloads land whole in a fresh file.
+func (w *Writer) Write(p []byte) (int, error) {
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	if w.closed {
+		return 0, errors.New("logrotate: write on closed writer")
+	}
+	if w.size+int64(len(p)) > w.maxSize && w.size > 0 {
+		if err := w.rotate(); err != nil {
+			return 0, err
+		}
+	}
+	n, err := w.f.Write(p)
+	w.size += int64(n)
+	return n, err
+}
