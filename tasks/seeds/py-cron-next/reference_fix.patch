+"""cronex — 5-field cron expression parsing and next-run computation.
+
+No wall clock is consulted; callers pass naive datetimes in.
+"""
+from datetime import datetime, timedelta
+
+_MONTHS = ["jan", "feb", "mar", "apr", "may", "jun",
+           "jul", "aug", "sep", "oct", "nov", "dec"]
+_DOWS = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"]
+
+_MONTH_NAMES = {name: i + 1 for i, name in enumerate(_MONTHS)}
+_DOW_NAMES = {name: i for i, name in enumerate(_DOWS)}
+
+
+def _atom(token, lo, hi, names, field):
+    """Resolve a single number-or-name to an int (unvalidated range)."""
+    t = token.lower()
+    if names and t in names:
+        return names[t]
+    if not token or not all(c.isdigit() for c in token):
+        raise ValueError(f"bad value {token!r} in {field} field")
+    return int(token)
+
+
+def _parse_field(text, lo, hi, names, field):
+    """Parse one cron field into a sorted set of allowed values."""
+    allowed = set()
+    if text == "":
+        raise ValueError(f"empty {field} field")
+    for item in text.split(","):
+        if item == "":
+            raise ValueError(f"empty list item in {field} field")
+        step = 1
+        base = item
+        if "/" in item:
+            base, _, step_s = item.partition("/")
+            if not step_s.isdigit() or int(step_s) == 0:
+                raise ValueError(f"bad step {step_s!r} in {field} field")
+            step = int(step_s)
+        if base == "*":
+            start, end = lo, hi
+        elif "-" in base and not base.isdigit():
+            a, _, b = base.partition("-")
+            start = _atom(a, lo, hi, names, field)
+            end = _atom(b, lo, hi, names, field)
+            if start > end:
+                raise ValueError(f"reversed range {base!r} in {field} field")
+        else:
+            start = end = _atom(base, lo, hi, names, field)
+        if start < lo or end > hi:
+            raise ValueError(
+                f"value out of range ({lo}-{hi}) in {field} field: {item!r}")
+        allowed.update(range(start, end + 1, step))
+    return allowed
+
+
+class CronSchedule:
+    def __init__(self, minutes, hours, doms, months, dows, dom_star, dow_star):
+        self.minutes = minutes
+        self.hours = hours
+        self.doms = doms
+        self.months = months
+        self.dows = dows          # 0..6, Sunday == 0
+        self._dom_star = dom_star
+        self._dow_star = dow_star
+
+    def _day_matches(self, dt):
+        dom_ok = dt.day in self.doms
+        dow_ok = ((dt.weekday() + 1) % 7) in self.dows
+        if self._dom_star and self._dow_star:
+            return True
+        if self._dom_star:
+            return dow_ok
+        if self._dow_star:
+            return dom_ok
+        return dom_ok or dow_ok   # both restricted: classic cron OR
+
+    def matches(self, dt):
+        return (dt.minute in self.minutes
+                and dt.hour in self.hours
+                and dt.month in self.months
+                and self._day_matches(dt))
+
+    def next_run(self, after):
+        t = after.replace(second=0, microsecond=0) + timedelta(minutes=1)
+        # scan day by day; within a matching day, pick from the hour/minute sets
+        limit = t + timedelta(days=366 * 5)
+        day = t.replace(hour=0, minute=0)
+        first = True
+        hours = sorted(self.hours)
+        minutes = sorted(self.minutes)
+        while day < limit:
+            if day.month in self.months and self._day_matches(day):
+                for h in hours:
+                    for m in minutes:
+                        cand = day.replace(hour=h, minute=m)
+                        if not first or cand >= t:
+                            return cand
+            day += timedelta(days=1)
+            first = False
+        raise ValueError("no matching time within five years")
+
+
+def parse(expr):
+    fields = expr.split()
+    if len(fields) != 5:
+        raise ValueError(f"expected 5 fields, got {len(fields)}")
+    minutes = _parse_field(fields[0], 0, 59, None, "minute")
+    hours = _parse_field(fields[1], 0, 23, None, "hour")
+    doms = _parse_field(fields[2], 1, 31, None, "day-of-month")
+    months = _parse_field(fields[3], 1, 12, _MONTH_NAMES, "month")
+    dows_raw = _parse_field(fields[4], 0, 7, _DOW_NAMES, "day-of-week")
+    dows = {d % 7 for d in dows_raw}
+    return CronSchedule(minutes, hours, doms, months, dows,
+                        dom_star=(fields[2] == "*"),
+                        dow_star=(fields[4] == "*"))
