@@ -0,0 +1,125 @@
+// Thin Kubernetes client for ConfigMap reads and server-side apply.
+// Speaks the documented contract: PATCH with application/apply-patch+yaml,
+// fieldManager (+ optional force) on the query string, Status error bodies.
+
+export class KubeApiError extends Error {
+  code: number;
+  reason: string;
+
+  constructor(code: number, reason: string, message: string) {
+    super(`kubernetes API error ${code} ${reason}: ${message}`);
+    this.code = code;
+    this.reason = reason;
+  }
+}
+
+export interface FieldConflict {
+  field: string;
+  manager: string;
+}
+
+export class FieldConflictError extends KubeApiError {
+  conflicts: FieldConflict[];
+
+  constructor(code: number, reason: string, message: string, conflicts: FieldConflict[]) {
+    super(code, reason, message);
+    this.conflicts = conflicts;
+  }
+}
+
+export interface ApplyOptions {
+  fieldManager: string;
+  force?: boolean;
+}
+
+export interface ApplyResult {
+  object: any;
+  created: boolean;
+}
+
+function conflictsFrom(status: any): FieldConflict[] {
+  const causes: any[] = status?.details?.causes ?? [];
+  const out: FieldConflict[] = [];
+  for (const cause of causes) {
+    if (cause?.reason !== 'FieldManagerConflict') continue;
+    const match = /conflict with "([^"]+)"/.exec(String(cause.message ?? ''));
+    out.push({ field: String(cause.field ?? ''), manager: match ? match[1] : '' });
+  }
+  return out;
+}
+
+export class KubeClient {
+  private baseUrl: string;
+  private token: string;
+
+  constructor(baseUrl: string, token: string) {
+    this.baseUrl = baseUrl.replace(/\/+$/, '');
+    this.token = token;
+  }
+
+  private configMapUrl(namespace: string, name: string): string {
+    return `${this.baseUrl}/api/v1/namespaces/${encodeURIComponent(namespace)}` +
+      `/configmaps/${encodeURIComponent(name)}`;
+  }
+
+  private async raise(res: Response): Promise<never> {
+    let status: any = {};
+    try {
+      status = await res.json();
+    } catch {
+      status = {};
+    }
+    const code = typeof status.code === 'number' ? status.code : res.status;
+    const reason = status.reason ?? 'Unknown';
+    const message = status.message ?? '(no Status body)';
+    const conflicts = conflictsFrom(status);
+    if (res.status === 409 && conflicts.length > 0) {
+      throw new FieldConflictError(code, reason, message, conflicts);
+    }
+    throw new KubeApiError(code, reason, message);
+  }
+
+  private checkRedirect(res: Response): void {
+    if (res.status >= 300 && res.status < 400) {
+      throw new KubeApiError(res.status, 'Redirect',
+        'refusing to follow a redirect issued by the API server');
+    }
+  }
+
+  async getConfigMap(namespace: string, name: string): Promise<any | null> {
+    const res = await fetch(this.configMapUrl(namespace, name), {
+      method: 'GET',
+      redirect: 'manual',
+      headers: {
+        Authorization: `Bearer ${this.token}`,
+        Accept: 'application/json',
+      },
+    });
+    this.checkRedirect(res);
+    if (res.status === 404) {
+      await res.arrayBuffer();
+      return null;
+    }
+    if (!res.ok) await this.raise(res);
+    return res.json();
+  }
+
+  async applyConfigMap(namespace: string, name: string, yamlBody: string,
+    opts: ApplyOptions): Promise<ApplyResult> {
+    let query = `fieldManager=${encodeURIComponent(opts.fieldManager)}`;
+    if (opts.force) query += '&force=true';
+    const res = await fetch(`${this.configMapUrl(namespace, name)}?${query}`, {
+      method: 'PATCH',
+      redirect: 'manual',
+      headers: {
+        Authorization: `Bearer ${this.token}`,
+        Accept: 'application/json',
+        'Content-Type': 'application/apply-patch+yaml',
+      },
+      body: yamlBody,
+    });
+    this.checkRedirect(res);
+    if (!res.ok) await this.raise(res);
+    return { object: await res.json(), created: res.status === 201 };
+  }
+}
