+// Renders the server-side-apply configuration for a ConfigMap.
+// Deterministic on purpose: sorted keys, JSON-style double quoting, so the
+// projection is byte-stable and YAML cannot retype values like "true"/"007".
+
+export interface DesiredConfigMap {
+  namespace: string;
+  name: string;
+  labels?: Record<string, string>;
+  data: Record<string, string>;
+}
+
+const DATA_KEY = /^[A-Za-z0-9._-]+$/;
+
+function quoted(value: string): string {
+  return JSON.stringify(value);
+}
+
+export function applyYaml(desired: DesiredConfigMap): string {
+  const lines: string[] = [
+    'apiVersion: v1',
+    'kind: ConfigMap',
+    'metadata:',
+    `  name: ${desired.name}`,
+    `  namespace: ${desired.namespace}`,
+  ];
+  const labels = desired.labels ?? {};
+  const labelKeys = Object.keys(labels).sort();
+  if (labelKeys.length > 0) {
+    lines.push('  labels:');
+    for (const key of labelKeys) lines.push(`    ${key}: ${quoted(labels[key])}`);
+  }
+  const dataKeys = Object.keys(desired.data).sort();
+  for (const key of dataKeys) {
+    if (!DATA_KEY.test(key)) {
+      throw new Error(`invalid ConfigMap data key ${JSON.stringify(key)}: ` +
+        'keys must consist of alphanumerics, "-", "_" or "."');
+    }
+  }
+  if (dataKeys.length === 0) {
+    lines.push('data: {}');
+  } else {
+    lines.push('data:');
+    for (const key of dataKeys) lines.push(`  ${key}: ${quoted(desired.data[key])}`);
+  }
+  return lines.join('\n') + '\n';
+}
