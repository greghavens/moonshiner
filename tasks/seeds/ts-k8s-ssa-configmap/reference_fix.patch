+// ConfigMap reconciler: read, compare the desired projection, apply only
+// when something we own actually differs, and surface apply conflicts.
+
+import { FieldConflictError, KubeClient } from './client.ts';
+import type { ApplyOptions, FieldConflict } from './client.ts';
+import { applyYaml } from './yaml.ts';
+import type { DesiredConfigMap } from './yaml.ts';
+
+export interface Outcome {
+  action: 'unchanged' | 'configured' | 'created' | 'conflict';
+  object?: any;
+  conflicts?: FieldConflict[];
+}
+
+function projectionSatisfied(current: any, desired: DesiredConfigMap): boolean {
+  const data = current?.data ?? {};
+  for (const [key, value] of Object.entries(desired.data)) {
+    if (data[key] !== value) return false;
+  }
+  const labels = current?.metadata?.labels ?? {};
+  for (const [key, value] of Object.entries(desired.labels ?? {})) {
+    if (labels[key] !== value) return false;
+  }
+  return true;
+}
+
+export async function reconcileConfigMap(client: KubeClient, desired: DesiredConfigMap,
+  opts: ApplyOptions): Promise<Outcome> {
+  const current = await client.getConfigMap(desired.namespace, desired.name);
+  if (current !== null && projectionSatisfied(current, desired)) {
+    return { action: 'unchanged' };
+  }
+  try {
+    const { object, created } = await client.applyConfigMap(
+      desired.namespace, desired.name, applyYaml(desired), opts);
+    return { action: created ? 'created' : 'configured', object };
+  } catch (err) {
+    if (err instanceof FieldConflictError && !opts.force) {
+      return { action: 'conflict', conflicts: err.conflicts };
+    }
+    throw err;
+  }
+}
