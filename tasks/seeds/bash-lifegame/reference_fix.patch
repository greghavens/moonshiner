diff --git a/lifegame.sh b/lifegame.sh
new file mode 100644
index 0000000..9556a53
--- /dev/null
+++ b/lifegame.sh
@@ -0,0 +1,81 @@
+#!/usr/bin/env bash
+# lifegame.sh <pattern-file> <generations> — bounded Conway's Life, pure bash.
+set -u
+
+die() { printf '%s\n' "$1" >&2; exit 2; }
+
+(( $# == 2 )) || die 'usage: lifegame.sh <pattern-file> <generations>'
+file=$1
+gens=$2
+
+[[ -f $file && -r $file ]] || die "error: cannot read $file"
+[[ $gens =~ ^[0-9]+$ ]] || die 'error: generations must be a non-negative integer'
+gens=$((10#$gens))
+
+rows=()
+while IFS= read -r line || [[ -n $line ]]; do
+  [[ $line == '!'* || -z $line ]] && continue
+  rows+=("$line")
+done < "$file"
+
+(( ${#rows[@]} > 0 )) || die 'error: empty pattern'
+h=${#rows[@]}
+w=${#rows[0]}
+
+declare -A cell=()
+for ((y = 0; y < h; y++)); do
+  row=${rows[y]}
+  (( ${#row} == w )) || die 'error: ragged pattern'
+  for ((x = 0; x < w; x++)); do
+    ch=${row:x:1}
+    case $ch in
+      '#') cell[$y,$x]=1 ;;
+      '.') ;;
+      *) die "error: invalid character: $ch" ;;
+    esac
+  done
+done
+
+render() {
+  local y x line
+  for ((y = 0; y < h; y++)); do
+    line=''
+    for ((x = 0; x < w; x++)); do
+      if [[ -n ${cell[$y,$x]:-} ]]; then line+='#'; else line+='.'; fi
+    done
+    printf '%s\n' "$line"
+  done
+}
+
+step() {
+  local -A next=()
+  local y x yy xx dy dx n k
+  for ((y = 0; y < h; y++)); do
+    for ((x = 0; x < w; x++)); do
+      n=0
+      for dy in -1 0 1; do
+        for dx in -1 0 1; do
+          (( dy == 0 && dx == 0 )) && continue
+          yy=$((y + dy)); xx=$((x + dx))
+          (( yy >= 0 && yy < h && xx >= 0 && xx < w )) || continue
+          [[ -n ${cell[$yy,$xx]:-} ]] && n=$((n + 1))
+        done
+      done
+      if [[ -n ${cell[$y,$x]:-} ]]; then
+        (( n == 2 || n == 3 )) && next[$y,$x]=1
+      else
+        (( n == 3 )) && next[$y,$x]=1
+      fi
+    done
+  done
+  cell=()
+  for k in "${!next[@]}"; do cell[$k]=1; done
+}
+
+for ((g = 0; g <= gens; g++)); do
+  (( g > 0 )) && printf '\n'
+  printf 'gen %d pop %d\n' "$g" "${#cell[@]}"
+  render
+  (( g < gens )) && step
+done
+exit 0
