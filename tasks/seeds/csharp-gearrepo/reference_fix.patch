+using System.Diagnostics.CodeAnalysis;
+
+namespace GearRepo;
+
+public interface IEntity<TKey> where TKey : notnull, IEquatable<TKey>
+{
+    TKey Id { get; }
+}
+
+public sealed class DuplicateKeyException : InvalidOperationException
+{
+    public DuplicateKeyException(object id) : base($"id '{id}' already present")
+    {
+    }
+}
+
+public interface IRepository<T, TKey>
+    where T : class, IEntity<TKey>
+    where TKey : notnull, IEquatable<TKey>
+{
+    int Count { get; }
+
+    void Add(T item);
+
+    bool TryGet(TKey id, [MaybeNullWhen(false)] out T item);
+
+    bool Remove(TKey id);
+
+    /// <summary>Copy of the current contents in insertion order.</summary>
+    IReadOnlyList<T> Snapshot();
+
+    // --- convenience layer: default implementations, free for every backend ---
+
+    bool Exists(TKey id) => TryGet(id, out _);
+
+    T GetRequired(TKey id) =>
+        TryGet(id, out var item)
+            ? item
+            : throw new KeyNotFoundException($"no entity with id '{id}'");
+
+    /// <summary>Atomic append: the whole batch is checked (against the store
+    /// and within itself) before anything is added.</summary>
+    void AddRange(IEnumerable<T> items)
+    {
+        var batch = items.ToList();
+        var incoming = new HashSet<TKey>();
+        foreach (var item in batch)
+        {
+            if (Exists(item.Id) || !incoming.Add(item.Id))
+                throw new DuplicateKeyException(item.Id);
+        }
+        foreach (var item in batch)
+            Add(item);
+    }
+
+    IReadOnlyList<T> FindAll(Func<T, bool> predicate) =>
+        Snapshot().Where(predicate).ToList();
+}
+
+public sealed class InMemoryRepository<T, TKey> : IRepository<T, TKey>
+    where T : class, IEntity<TKey>
+    where TKey : notnull, IEquatable<TKey>
+{
+    private readonly Dictionary<TKey, T> _byId = new();
+    private readonly List<TKey> _order = new();
+
+    public int Count => _byId.Count;
+
+    public void Add(T item)
+    {
+        if (_byId.ContainsKey(item.Id))
+            throw new DuplicateKeyException(item.Id);
+        _byId.Add(item.Id, item);
+        _order.Add(item.Id);
+    }
+
+    public bool TryGet(TKey id, [MaybeNullWhen(false)] out T item) =>
+        _byId.TryGetValue(id, out item);
+
+    public bool Remove(TKey id)
+    {
+        if (!_byId.Remove(id))
+            return false;
+        _order.Remove(id);
+        return true;
+    }
+
+    public IReadOnlyList<T> Snapshot() => _order.Select(id => _byId[id]).ToList();
+}
+
+public static class DepotAudit
+{
+    public static IReadOnlyList<TKey> MissingIds<T, TKey>(
+        IRepository<T, TKey> repo, IEnumerable<TKey> expected)
+        where T : class, IEntity<TKey>
+        where TKey : notnull, IEquatable<TKey>
+    {
+        var missing = new List<TKey>();
+        var seen = new HashSet<TKey>();
+        foreach (var id in expected)
+        {
+            if (!repo.Exists(id) && seen.Add(id))
+                missing.Add(id);
+        }
+        return missing;
+    }
+}
