+// validPattern checks a subscribe pattern: dot-separated segments
+// where "*" may appear only as a whole segment.
+func validPattern(pattern string) error {
+	for _, seg := range strings.Split(pattern, ".") {
+		if seg != "*" && strings.Contains(seg, "*") {
+			return fmt.Errorf("pubsub: wildcard must be a whole segment in %q", pattern)
+		}
+	}
+	return nil
+}
+
+// matchTopic reports whether a published topic matches a subscribe
+// pattern. "*" in the pattern matches exactly one topic segment.
+func matchTopic(pattern, topic string) bool {
+	if pattern == topic {
+		return true
+	}
+	if !strings.Contains(pattern, "*") {
+		return false
+	}
+	ps := strings.Split(pattern, ".")
+	ts := strings.Split(topic, ".")
+	if len(ps) != len(ts) {
+		return false
+	}
+	for i, p := range ps {
+		if p != "*" && p != ts[i] {
+			return false
+		}
+	}
+	return true
+}
+
+// Subscribe registers a new subscription on a topic pattern with a
+// delivery buffer of the given size. The pattern must be non-empty,
+// any "*" must span a whole segment, and the buffer non-negative.
