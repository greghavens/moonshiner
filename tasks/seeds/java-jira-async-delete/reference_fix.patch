@@ -0,0 +1,107 @@
+import java.net.http.HttpResponse;
+import java.util.Map;
+
+/**
+ * Stage two of the retention pipeline: permanently purge a project through
+ * Jira's documented asynchronous delete, honoring the archived-project
+ * prerequisite (an archived project must be restored before it can be
+ * deleted) and polling the resulting task to a terminal status.
+ */
+public final class ProjectRetirement {
+    /** Injected pause between consecutive task polls; nothing here sleeps. */
+    public interface Backoff {
+        void pause(int attempt);
+    }
+
+    /** Outcome of a successful purge. */
+    public record Result(String taskId, boolean restored, int pollCount, Object taskResult) {}
+
+    /** The deletion task ended in a terminal failure state; the delete is transactional. */
+    public static final class TaskFailedException extends RuntimeException {
+        private final String taskId;
+        private final String taskStatus;
+
+        public TaskFailedException(String taskId, String taskStatus, String message) {
+            super(message);
+            this.taskId = taskId;
+            this.taskStatus = taskStatus;
+        }
+
+        public String taskId() {
+            return taskId;
+        }
+
+        public String taskStatus() {
+            return taskStatus;
+        }
+    }
+
+    private final ProjectAdminClient client;
+    private final int maxPolls;
+    private final Backoff backoff;
+
+    public ProjectRetirement(ProjectAdminClient client, int maxPolls, Backoff backoff) {
+        this.client = client;
+        this.maxPolls = maxPolls;
+        this.backoff = backoff;
+    }
+
+    public Result purge(String projectIdOrKey) {
+        ProjectAdminClient.ProjectInfo info = client.getProject(projectIdOrKey);
+        JiraAdminHttp http = client.http();
+
+        // You can't delete a project while it's archived; restore it first.
+        boolean restored = false;
+        if (info.archived()) {
+            HttpResponse<String> restore =
+                    http.send("POST", "/rest/api/3/project/" + projectIdOrKey + "/restore", null);
+            if (restore.statusCode() != 200) {
+                throw JiraApiException.of(restore.statusCode(), restore.body());
+            }
+            restored = true;
+        }
+
+        HttpResponse<String> delete =
+                http.send("POST", "/rest/api/3/project/" + projectIdOrKey + "/delete", null);
+        if (delete.statusCode() != 303) {
+            throw JiraApiException.of(delete.statusCode(), delete.body());
+        }
+        String taskUrl = delete.headers().firstValue("Location").orElseThrow(
+                () -> new IllegalStateException(
+                        "asynchronous delete answered 303 without a Location header for the task"));
+
+        int polls = 0;
+        while (true) {
+            HttpResponse<String> response = http.send("GET", taskUrl, null);
+            if (response.statusCode() != 200) {
+                throw JiraApiException.of(response.statusCode(), response.body());
+            }
+            polls++;
+            Map<String, Object> task = Json.object(Json.parse(response.body()));
+            String taskId = String.valueOf(task.get("id"));
+            String status = String.valueOf(task.get("status"));
+            switch (status) {
+                case "COMPLETE" -> {
+                    return new Result(taskId, restored, polls, task.get("result"));
+                }
+                case "FAILED", "CANCELLED", "DEAD" -> {
+                    Object message = task.get("message");
+                    throw new TaskFailedException(taskId, status,
+                            "deletion task " + taskId + " ended " + status
+                                    + (message == null ? "" : ": " + message)
+                                    + " — the delete is transactional, so the project was not deleted");
+                }
+                default -> {
+                    // ENQUEUED / RUNNING / CANCEL_REQUESTED: progress and
+                    // lastUpdate may regress between polls; only the status
+                    // decides termination.
+                    if (polls >= maxPolls) {
+                        throw new IllegalStateException("deletion task " + taskId
+                                + " is still running after " + polls + " polls");
+                    }
+                    backoff.pause(polls);
+                }
+            }
+        }
+    }
+}
