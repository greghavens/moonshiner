new file mode 100644
index 0000000..4a7de4f
--- /dev/null
+++ b/reminderstore.py
@@ -0,0 +1,68 @@
+"""JSON persistence for reminders."""
+import json
+import os
+from datetime import date
+
+from recurrence import WEEKDAYS
+
+_WD_NAMES = {v: k for k, v in WEEKDAYS.items()}
+
+
+def _to_rule(rec):
+    """Inflate a stored record into the rule dict recurrence expects."""
+    return {
+        "rule": rec["rule"],
+        "start": date.fromisoformat(rec["start"]),
+        "interval": rec["interval"],
+        "count": rec.get("count"),
+        "until": date.fromisoformat(rec["until"]) if rec.get("until") else None,
+        "byday": [WEEKDAYS[d] for d in rec["byday"]] if rec.get("byday") else None,
+        "skips": {date.fromisoformat(d) for d in rec.get("skips", [])},
+    }
+
+
+class ReminderStore:
+    def __init__(self, path):
+        self.path = path
+        self.reminders = {}
+        self.next_id = 1
+        if os.path.exists(path):
+            with open(path) as f:
+                data = json.load(f)
+            self.reminders = {int(k): v for k, v in data["reminders"].items()}
+            self.next_id = data["next_id"]
+
+    def save(self):
+        tmp = self.path + ".tmp"
+        with open(tmp, "w") as f:
+            json.dump({"next_id": self.next_id,
+                       "reminders": {str(k): v for k, v in self.reminders.items()}},
+                      f, indent=2)
+        os.replace(tmp, self.path)
+
+    def add(self, title, rule, start, interval, count, until, byday):
+        rec = {"title": title, "rule": rule, "start": start.isoformat(),
+               "interval": interval, "count": count,
+               "until": until.isoformat() if until else None,
+               "byday": [_WD_NAMES[d] for d in byday] if byday else None,
+               "skips": []}
+        rid = self.next_id
+        self.reminders[rid] = rec
+        self.next_id += 1
+        self.save()
+        return rid
+
+    def get(self, rid):
+        return self.reminders.get(rid)
+
+    def rule_for(self, rid):
+        return _to_rule(self.reminders[rid])
+
+    def add_skip(self, rid, day):
+        skips = self.reminders[rid].setdefault("skips", [])
+        if day.isoformat() not in skips:
+            skips.append(day.isoformat())
+        self.save()
+
+    def ids(self):
+        return sorted(self.reminders)
