+#!/usr/bin/env python3
+"""Recurring reminder engine (logical clock: every command takes dates).
+
+    python3 remind.py --file r.json add "oil the lathe" --rule weekly \
+        --byday MO,TH --start 2026-07-06
+    python3 remind.py --file r.json next 1 --from 2026-07-06 --n 3
+    python3 remind.py --file r.json agenda --on 2026-07-09
+"""
+import argparse
+import sys
+from datetime import date
+
+import recurrence
+from reminderstore import ReminderStore
+
+USAGE_ERROR, DOMAIN_ERROR = 2, 1
+
+
+class UsageError(Exception):
+    pass
+
+
+def parse_date(text):
+    try:
+        return date.fromisoformat(text)
+    except ValueError:
+        raise UsageError(f"not a YYYY-MM-DD date: {text!r}")
+
+
+def parse_byday(text):
+    days = []
+    for token in text.split(","):
+        token = token.strip().upper()
+        if token not in recurrence.WEEKDAYS:
+            raise UsageError(f"bad weekday token: {token!r}")
+        days.append(recurrence.WEEKDAYS[token])
+    return days
+
+
+def build_parser():
+    parser = argparse.ArgumentParser(prog="remind.py")
+    parser.add_argument("--file", required=True)
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_add = sub.add_parser("add")
+    p_add.add_argument("title")
+    p_add.add_argument("--rule", required=True)
+    p_add.add_argument("--start", required=True)
+    p_add.add_argument("--interval", type=int, default=1)
+    p_add.add_argument("--count", type=int)
+    p_add.add_argument("--until")
+    p_add.add_argument("--byday")
+
+    p_skip = sub.add_parser("skip")
+    p_skip.add_argument("id", type=int)
+    p_skip.add_argument("date")
+
+    p_next = sub.add_parser("next")
+    p_next.add_argument("id", type=int)
+    p_next.add_argument("--from", dest="start_from", required=True)
+    p_next.add_argument("--n", type=int, default=5)
+
+    p_agenda = sub.add_parser("agenda")
+    p_agenda.add_argument("--on", required=True)
+    return parser
+
+
+def cmd_add(store, args):
+    if args.rule not in ("daily", "weekly", "monthly"):
+        raise UsageError(f"unknown rule: {args.rule!r}")
+    start = parse_date(args.start)
+    if args.interval < 1:
+        raise UsageError("--interval must be >= 1")
+    if args.count is not None and args.count < 1:
+        raise UsageError("--count must be >= 1")
+    if args.count is not None and args.until is not None:
+        raise UsageError("--count and --until are mutually exclusive")
+    until = parse_date(args.until) if args.until else None
+    byday = parse_byday(args.byday) if args.byday else None
+    if args.rule == "weekly" and not byday:
+        raise UsageError("weekly rules require --byday")
+    if args.rule != "weekly" and byday:
+        raise UsageError("--byday only makes sense with weekly rules")
+    rid = store.add(args.title, args.rule, start, args.interval,
+                    args.count, until, byday)
+    print(f"added {rid}")
+
+
+def cmd_skip(store, args):
+    day = parse_date(args.date)
+    if store.get(args.id) is None:
+        print(f"no reminder {args.id}", file=sys.stderr)
+        return DOMAIN_ERROR
+    store.add_skip(args.id, day)
+    return 0
+
+
+def cmd_next(store, args):
+    start_from = parse_date(args.start_from)
+    if store.get(args.id) is None:
+        print(f"no reminder {args.id}", file=sys.stderr)
+        return DOMAIN_ERROR
+    rule = store.rule_for(args.id)
+    for day in recurrence.occurrences_after(rule, start_from, args.n):
+        print(day.isoformat())
+    return 0
+
+
+def cmd_agenda(store, args):
+    day = parse_date(args.on)
+    for rid in store.ids():
+        if recurrence.occurs_on(store.rule_for(rid), day):
+            print(f"{rid} {store.get(rid)['title']}")
+    return 0
+
+
+def main(argv=None):
+    parser = build_parser()
+    try:
+        args = parser.parse_args(argv)
+    except SystemExit as e:
+        return USAGE_ERROR if e.code else 0
+    try:
+        store = ReminderStore(args.file)
+        if args.command == "add":
+            cmd_add(store, args)
+            return 0
+        if args.command == "skip":
+            return cmd_skip(store, args)
+        if args.command == "next":
+            return cmd_next(store, args)
+        return cmd_agenda(store, args)
+    except UsageError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return USAGE_ERROR
+
+
+if __name__ == "__main__":
+    sys.exit(main())
