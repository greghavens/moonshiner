+"""Pure recurrence math: no clock, no IO.
+
+A rule dict looks like:
+    {"rule": "daily"|"weekly"|"monthly", "start": date, "interval": int,
+     "count": int|None, "until": date|None, "byday": [weekday ints]|None,
+     "skips": set of dates}
+Occurrences are generated in order; count applies BEFORE skips (EXDATE
+semantics: a skipped date still consumes count).
+"""
+import calendar
+from datetime import date, timedelta
+
+WEEKDAYS = {"MO": 0, "TU": 1, "WE": 2, "TH": 3, "FR": 4, "SA": 5, "SU": 6}
+
+
+def _raw_occurrences(rule):
+    """Yield rule occurrences in order, honoring count/until, ignoring skips."""
+    start = rule["start"]
+    interval = rule["interval"]
+    count = rule.get("count")
+    until = rule.get("until")
+    produced = 0
+
+    def emit(day):
+        nonlocal produced
+        if until is not None and day > until:
+            return False  # signal exhaustion
+        produced += 1
+        return True
+
+    if rule["rule"] == "daily":
+        day = start
+        while count is None or produced < count:
+            if not emit(day):
+                return
+            yield day
+            day += timedelta(days=interval)
+    elif rule["rule"] == "weekly":
+        week0_monday = start - timedelta(days=start.weekday())
+        week_index = 0
+        bydays = sorted(rule["byday"])
+        while count is None or produced < count:
+            monday = week0_monday + timedelta(weeks=week_index)
+            for wd in bydays:
+                day = monday + timedelta(days=wd)
+                if day < start:
+                    continue
+                if count is not None and produced >= count:
+                    return
+                if not emit(day):
+                    return
+                yield day
+            week_index += interval
+    else:  # monthly
+        year, month, dom = start.year, start.month, start.day
+        while count is None or produced < count:
+            if calendar.monthrange(year, month)[1] >= dom:
+                day = date(year, month, dom)
+                if not emit(day):
+                    return
+                yield day
+            month += interval
+            year += (month - 1) // 12
+            month = (month - 1) % 12 + 1
+
+
+def occurrences_after(rule, start_from, n):
+    """The first n occurrence dates on-or-after start_from, skips applied."""
+    out = []
+    for day in _raw_occurrences(rule):
+        if day in rule.get("skips", set()):
+            continue
+        if day < start_from:
+            continue
+        out.append(day)
+        if len(out) >= n:
+            break
+    return out
+
+
+def occurs_on(rule, day):
+    """Does the rule fire on this exact day (skips applied)?"""
+    for occ in _raw_occurrences(rule):
+        if occ > day:
+            return False
+        if occ == day:
+            return occ not in rule.get("skips", set())
+    return False
