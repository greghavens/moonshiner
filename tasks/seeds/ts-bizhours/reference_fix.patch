+// Business-hours calendar: naive wall-clock math at minute resolution.
+// Timestamps are 'YYYY-MM-DDTHH:MM' strings throughout; dates 'YYYY-MM-DD'.
+
+const WEEKDAYS = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'] as const;
+
+type Shift = { open: string; close: string };
+type ShiftSpan = { open: number; close: number }; // minutes since midnight
+
+export type CalendarConfig = {
+  hours: { [day: string]: Shift[] };
+  holidays?: string[];
+  now?: () => string;
+};
+
+const TIME_RE = /^([01]\d|2[0-3]):([0-5]\d)$/;
+const DATE_RE = /^(\d{4})-(\d{2})-(\d{2})$/;
+
+function parseTime(value: string): number {
+  const m = TIME_RE.exec(value);
+  if (!m) throw new Error(`invalid time '${value}': expected zero-padded HH:MM`);
+  return Number(m[1]) * 60 + Number(m[2]);
+}
+
+function parseDate(value: string): void {
+  const m = DATE_RE.exec(value);
+  if (!m) throw new Error(`invalid date '${value}': expected YYYY-MM-DD`);
+  const [y, mo, d] = [Number(m[1]), Number(m[2]), Number(m[3])];
+  const probe = new Date(Date.UTC(y, mo - 1, d));
+  if (
+    probe.getUTCFullYear() !== y ||
+    probe.getUTCMonth() !== mo - 1 ||
+    probe.getUTCDate() !== d
+  ) {
+    throw new Error(`invalid date '${value}': no such calendar day`);
+  }
+}
+
+function parseTimestamp(ts: string): { date: string; minute: number } {
+  const at = ts.indexOf('T');
+  if (at === -1) throw new Error(`invalid timestamp '${ts}': expected YYYY-MM-DDTHH:MM`);
+  const date = ts.slice(0, at);
+  parseDate(date);
+  return { date, minute: parseTime(ts.slice(at + 1)) };
+}
+
+function formatTimestamp(date: string, minute: number): string {
+  const h = String(Math.floor(minute / 60)).padStart(2, '0');
+  const m = String(minute % 60).padStart(2, '0');
+  return `${date}T${h}:${m}`;
+}
+
+function weekdayOf(date: string): string {
+  const m = DATE_RE.exec(date)!;
+  const d = new Date(Date.UTC(Number(m[1]), Number(m[2]) - 1, Number(m[3])));
+  return WEEKDAYS[d.getUTCDay()];
+}
+
+function nextDay(date: string): string {
+  const m = DATE_RE.exec(date)!;
+  const d = new Date(Date.UTC(Number(m[1]), Number(m[2]) - 1, Number(m[3]) + 1));
+  const y = d.getUTCFullYear();
+  const mo = String(d.getUTCMonth() + 1).padStart(2, '0');
+  const day = String(d.getUTCDate()).padStart(2, '0');
+  return `${y}-${mo}-${day}`;
+}
+
+export class BusinessCalendar {
+  private schedule: Map<string, ShiftSpan[]>;
+  private holidays: Set<string>;
+  private clock?: () => string;
+
+  constructor(config: CalendarConfig) {
+    this.schedule = new Map();
+    let anyOpen = false;
+    for (const [day, shifts] of Object.entries(config.hours)) {
+      if (!WEEKDAYS.includes(day as (typeof WEEKDAYS)[number])) {
+        throw new Error(`unknown weekday '${day}': use ${WEEKDAYS.join('/')}`);
+      }
+      const spans: ShiftSpan[] = [];
+      let prevClose = -1;
+      for (const shift of shifts) {
+        const open = parseTime(shift.open);
+        const close = parseTime(shift.close);
+        if (open >= close) {
+          throw new Error(`shift ${shift.open}-${shift.close} on ${day} must open before it closes`);
+        }
+        if (open < prevClose) {
+          throw new Error(`shifts on ${day} must be sorted and non-overlapping`);
+        }
+        prevClose = close;
+        spans.push({ open, close });
+        anyOpen = true;
+      }
+      this.schedule.set(day, spans);
+    }
+    if (!anyOpen) throw new Error('calendar is never open: no shifts on any weekday');
+
+    this.holidays = new Set();
+    for (const holiday of config.holidays ?? []) {
+      parseDate(holiday);
+      this.holidays.add(holiday);
+    }
+    this.clock = config.now;
+  }
+
+  private shiftsOn(date: string): ShiftSpan[] {
+    if (this.holidays.has(date)) return [];
+    return this.schedule.get(weekdayOf(date)) ?? [];
+  }
+
+  isOpen(ts: string): boolean {
+    const { date, minute } = parseTimestamp(ts);
+    return this.shiftsOn(date).some((s) => minute >= s.open && minute < s.close);
+  }
+
+  nextOpen(ts: string): string {
+    let { date, minute } = parseTimestamp(ts);
+    // A week always contains an open shift (enforced in the constructor),
+    // so 8 days of lookahead is guaranteed to hit one — plus holidays,
+    // so keep walking; holidays are finite.
+    for (;;) {
+      for (const s of this.shiftsOn(date)) {
+        if (minute < s.open) return formatTimestamp(date, s.open);
+        if (minute < s.close) return formatTimestamp(date, minute);
+      }
+      date = nextDay(date);
+      minute = 0;
+    }
+  }
+
+  addBusinessMinutes(ts: string, minutes: number): string {
+    if (!Number.isInteger(minutes) || minutes < 0) {
+      throw new Error(`minutes must be a non-negative integer, got ${minutes}`);
+    }
+    let cursor = parseTimestamp(this.nextOpen(ts));
+    let remaining = minutes;
+    for (;;) {
+      const shift = this.shiftsOn(cursor.date).find(
+        (s) => cursor.minute >= s.open && cursor.minute < s.close,
+      )!;
+      const available = shift.close - cursor.minute;
+      if (remaining <= available) {
+        return formatTimestamp(cursor.date, cursor.minute + remaining);
+      }
+      remaining -= available;
+      cursor = parseTimestamp(
+        this.nextOpen(formatTimestamp(cursor.date, shift.close)),
+      );
+    }
+  }
+
+  businessMinutesBetween(from: string, to: string): number {
+    const a = parseTimestamp(from);
+    const b = parseTimestamp(to);
+    if (to < from) throw new Error(`range is inverted: ${to} is before ${from}`);
+    let total = 0;
+    let date = a.date;
+    for (;;) {
+      const windowStart = date === a.date ? a.minute : 0;
+      const windowEnd = date === b.date ? b.minute : 24 * 60;
+      for (const s of this.shiftsOn(date)) {
+        const lo = Math.max(s.open, windowStart);
+        const hi = Math.min(s.close, windowEnd);
+        if (hi > lo) total += hi - lo;
+      }
+      if (date === b.date) return total;
+      date = nextDay(date);
+    }
+  }
+
+  deadline(minutes: number): string {
+    if (!this.clock) throw new Error('deadline needs a now() clock in the configuration');
+    return this.addBusinessMinutes(this.clock(), minutes);
+  }
+}
