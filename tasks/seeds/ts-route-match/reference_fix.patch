@@ -0,0 +1,104 @@
+export interface Match<T> {
+  value: T;
+  params: Record<string, string>;
+}
+
+interface Node<T> {
+  statics: Map<string, Node<T>>;
+  param: { name: string; node: Node<T> } | null;
+  wildcard: { value: T } | null;
+  terminal: { value: T } | null;
+}
+
+function makeNode<T>(): Node<T> {
+  return { statics: new Map(), param: null, wildcard: null, terminal: null };
+}
+
+export class Router<T = unknown> {
+  private root: Node<T>;
+
+  constructor() {
+    this.root = makeNode<T>();
+  }
+
+  add(pattern: string, value: T): void {
+    if (!pattern.startsWith('/')) {
+      throw new Error(`pattern must start with '/': ${JSON.stringify(pattern)}`);
+    }
+    const segments = pattern === '/' ? [] : pattern.slice(1).split('/');
+
+    let node = this.root;
+    for (let i = 0; i < segments.length; i++) {
+      const seg = segments[i];
+      if (seg === '*') {
+        if (i !== segments.length - 1) {
+          throw new Error(`'*' is only allowed as the final segment: ${pattern}`);
+        }
+        if (node.wildcard !== null) {
+          throw new Error(`duplicate route: ${pattern}`);
+        }
+        node.wildcard = { value };
+        return;
+      }
+      if (seg.startsWith(':')) {
+        const name = seg.slice(1);
+        if (name === '') throw new Error(`param segment needs a name: ${pattern}`);
+        if (node.param === null) node.param = { name, node: makeNode<T>() };
+        node = node.param.node;
+      } else {
+        let child = node.statics.get(seg);
+        if (child === undefined) {
+          child = makeNode<T>();
+          node.statics.set(seg, child);
+        }
+        node = child;
+      }
+    }
+    if (node.terminal !== null) {
+      throw new Error(`duplicate route: ${pattern}`);
+    }
+    node.terminal = { value };
+  }
+
+  match(path: string): Match<T> | null {
+    let p = path;
+    const q = p.indexOf('?');
+    if (q !== -1) p = p.slice(0, q);
+    if (p.length > 1 && p.endsWith('/')) p = p.slice(0, -1);
+    if (!p.startsWith('/')) return null;
+
+    const segments = p === '/' ? [] : p.slice(1).split('/');
+    return this.search(this.root, segments, 0, {});
+  }
+
+  private search(
+    node: Node<T>,
+    segments: string[],
+    index: number,
+    params: Record<string, string>,
+  ): Match<T> | null {
+    if (index === segments.length) {
+      return node.terminal !== null ? { value: node.terminal.value, params } : null;
+    }
+    const seg = segments[index];
+
+    const staticChild = node.statics.get(seg);
+    if (staticChild !== undefined) {
+      const hit = this.search(staticChild, segments, index + 1, params);
+      if (hit !== null) return hit;
+    }
+
+    if (node.param !== null && seg !== '') {
+      const nextParams = { ...params, [node.param.name]: decodeURIComponent(seg) };
+      const hit = this.search(node.param.node, segments, index + 1, nextParams);
+      if (hit !== null) return hit;
+    }
+
+    if (node.wildcard !== null) {
+      const rest = segments.slice(index).map((s) => decodeURIComponent(s)).join('/');
+      return { value: node.wildcard.value, params: { ...params, '*': rest } };
+    }
+
+    return null;
+  }
+}
