+std::string_view Application::disabled_reason_name(
+    DisabledReason reason) noexcept {
+  switch (reason) {
+    case DisabledReason::none:
+      return "none";
+    case DisabledReason::not_compiled:
+      return "not-compiled";
+    case DisabledReason::configuration_disabled:
+      return "configuration-disabled";
+    case DisabledReason::no_device:
+      return "no-device";
+    case DisabledReason::permission_denied:
+      return "permission-denied";
+    case DisabledReason::incompatible_driver:
+      return "incompatible-driver";
+    case DisabledReason::probe_failed:
+      return "probe-failed";
+    case DisabledReason::initialization_failed:
+      return "initialization-failed";
+  }
+  return "unknown";
 }
 
