+    capabilities.telemetry.enabled = true;
+    capabilities.telemetry.disabled_reason = DisabledReason::none;
+  } else {
+    capabilities.telemetry.disabled_reason =
+        DisabledReason::initialization_failed;
   }
 #endif
 
-  report_startup_capabilities(options);
