index 0000000..4bb8803
--- /dev/null
+++ b/lifecycle.go
@@ -0,0 +1,97 @@
+package vaultkv
+
+import (
+	"context"
+	"encoding/json"
+	"strconv"
+)
+
+type versionsBody struct {
+	Versions []int `json:"versions"`
+}
+
+// DeleteLatest soft-deletes the latest version of the secret at path.
+func (c *Client) DeleteLatest(ctx context.Context, path string) error {
+	status, body, err := c.do(ctx, "DELETE", "data", path, "", nil)
+	if err != nil {
+		return err
+	}
+	return c.expectNoContent(status, body)
+}
+
+// DeleteVersions soft-deletes the given versions; the data stays recoverable.
+func (c *Client) DeleteVersions(ctx context.Context, path string, versions []int) error {
+	status, body, err := c.do(ctx, "POST", "delete", path, "", versionsBody{Versions: versions})
+	if err != nil {
+		return err
+	}
+	return c.expectNoContent(status, body)
+}
+
+// Undelete restores previously soft-deleted versions.
+func (c *Client) Undelete(ctx context.Context, path string, versions []int) error {
+	status, body, err := c.do(ctx, "POST", "undelete", path, "", versionsBody{Versions: versions})
+	if err != nil {
+		return err
+	}
+	return c.expectNoContent(status, body)
+}
+
+// Destroy permanently removes the given versions' data. The endpoint is
+// documented as PUT, unlike delete/undelete.
+func (c *Client) Destroy(ctx context.Context, path string, versions []int) error {
+	status, body, err := c.do(ctx, "PUT", "destroy", path, "", versionsBody{Versions: versions})
+	if err != nil {
+		return err
+	}
+	return c.expectNoContent(status, body)
+}
+
+// Metadata describes a key's version history and write configuration.
+type Metadata struct {
+	CurrentVersion int
+	OldestVersion  int
+	MaxVersions    int
+	CASRequired    bool
+	Versions       map[int]VersionMetadata
+}
+
+// Metadata reads /v1/<mount>/metadata/<path>.
+func (c *Client) Metadata(ctx context.Context, path string) (*Metadata, error) {
+	status, body, err := c.do(ctx, "GET", "metadata", path, "", nil)
+	if err != nil {
+		return nil, err
+	}
+	if status < 200 || status >= 300 {
+		return nil, decodeError(status, body)
+	}
+	var envelope struct {
+		Data struct {
+			CurrentVersion int                        `json:"current_version"`
+			OldestVersion  int                        `json:"oldest_version"`
+			MaxVersions    int                        `json:"max_versions"`
+			CASRequired    bool                       `json:"cas_required"`
+			Versions       map[string]versionMetaJSON `json:"versions"`
+		} `json:"data"`
+	}
+	if err := json.Unmarshal(body, &envelope); err != nil {
+		return nil, err
+	}
+	meta := &Metadata{
+		CurrentVersion: envelope.Data.CurrentVersion,
+		OldestVersion:  envelope.Data.OldestVersion,
+		MaxVersions:    envelope.Data.MaxVersions,
+		CASRequired:    envelope.Data.CASRequired,
+		Versions:       make(map[int]VersionMetadata, len(envelope.Data.Versions)),
+	}
+	for key, v := range envelope.Data.Versions {
+		n, err := strconv.Atoi(key)
+		if err != nil {
+			continue // not a version entry
+		}
+		vm := v.metadata()
+		vm.Version = n // the entry omits its own version; the map key is it
+		meta.Versions[n] = vm
+	}
+	return meta, nil
+}
