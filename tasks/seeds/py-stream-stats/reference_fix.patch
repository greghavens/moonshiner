+"""Single-pass running statistics (Welford) with parallel merge."""
+import math
+
+
+class RunningStats:
+    """Streaming count/mean/variance/min/max without storing the stream."""
+
+    def __init__(self):
+        self._count = 0
+        self._mean = 0.0
+        self._m2 = 0.0        # sum of squared deviations from the mean
+        self._min = None
+        self._max = None
+
+    def add(self, x):
+        x = float(x)
+        self._count += 1
+        delta = x - self._mean
+        self._mean += delta / self._count
+        self._m2 += delta * (x - self._mean)
+        if self._min is None or x < self._min:
+            self._min = x
+        if self._max is None or x > self._max:
+            self._max = x
+        return self
+
+    @property
+    def count(self):
+        return self._count
+
+    @property
+    def mean(self):
+        if self._count == 0:
+            raise ValueError("mean of an empty accumulator")
+        return self._mean
+
+    @property
+    def variance(self):
+        if self._count < 2:
+            raise ValueError("sample variance needs at least two observations")
+        return self._m2 / (self._count - 1)
+
+    @property
+    def std(self):
+        return math.sqrt(self.variance)
+
+    @property
+    def min(self):
+        return self._min
+
+    @property
+    def max(self):
+        return self._max
+
+    def merge(self, other):
+        """Combine two accumulators into a fresh one (Chan et al.)."""
+        out = RunningStats()
+        n1, n2 = self._count, other._count
+        total = n1 + n2
+        if total == 0:
+            return out
+        if n1 == 0:
+            src = other
+        elif n2 == 0:
+            src = self
+        else:
+            src = None
+        if src is not None:
+            out._count = src._count
+            out._mean = src._mean
+            out._m2 = src._m2
+            out._min = src._min
+            out._max = src._max
+            return out
+        delta = other._mean - self._mean
+        out._count = total
+        out._mean = self._mean + delta * n2 / total
+        out._m2 = self._m2 + other._m2 + delta * delta * n1 * n2 / total
+        out._min = min(self._min, other._min)
+        out._max = max(self._max, other._max)
+        return out
