diff --git a/mkrelease.sh b/mkrelease.sh
index 4fbd5e8..c52ff7d 100644
--- a/mkrelease.sh
+++ b/mkrelease.sh
@@ -8,6 +8,9 @@
 #
 # Produces <outdir>/rel-<version>/ holding every artifact plus RECEIPT
 # (one line per artifact: <path><TAB><cksum-crc><TAB><bytes>).
+#
+# set -e is NOT a guard rail inside `if fn`, `fn && ...`, or $(...) — every
+# failure we care about is checked explicitly and routed through fail().
 set -eu
 LC_ALL=C
 export LC_ALL
@@ -28,18 +31,37 @@ version=''
 stage=''
 receipt=''
 
+fail() { # fail <exit-code> <message> -- report, drop any half-built stage, abort
+  printf 'mkrelease: %s\n' "$2" >&2
+  if [ -n "$stage" ]; then
+    rm -rf "$stage"
+  fi
+  exit "$1"
+}
+
 read_version() {
-  local v=$(cat "$build/VERSION" 2>/dev/null)
-  version=$v
+  if [ ! -f "$build/VERSION" ]; then
+    fail 65 "missing VERSION in $build"
+  fi
+  version=$(cat "$build/VERSION")
+  if [ -z "$version" ]; then
+    fail 65 "missing VERSION in $build"
+  fi
   log "version $version"
 }
 
 stage_artifacts() {
+  local path maxkb
   mkdir -p "$stage"
   while IFS=$'\t' read -r path maxkb; do
     [ -n "$path" ] || continue
+    if [ ! -f "$build/$path" ]; then
+      fail 70 "staging failed: $path"
+    fi
     mkdir -p "$stage/$(dirname "$path")"
-    cp "$build/$path" "$stage/$path" 2>/dev/null
+    if ! cp "$build/$path" "$stage/$path"; then
+      fail 70 "staging failed: $path"
+    fi
     log "staged $path"
   done < "$build/MANIFEST"
   log "stage populated"
@@ -54,13 +76,18 @@ check_budget() { # <path> <bytes> <max-kb>
 }
 
 write_receipt() {
+  local path maxkb stats crc bytes
   : > "$receipt"
   while IFS=$'\t' read -r path maxkb; do
     [ -n "$path" ] || continue
-    set -- $(cksum "$stage/$path" 2>/dev/null)
+    stats=$(cksum "$stage/$path")
+    set -- $stats
     crc=$1
     bytes=$2
-    check_budget "$path" "$bytes" "$maxkb"
+    if ! check_budget "$path" "$bytes" "$maxkb"; then
+      rm -rf "$stage"
+      exit 71
+    fi
     printf '%s\t%s\t%s\n' "$path" "$crc" "$bytes" >> "$receipt"
   done < "$build/MANIFEST"
   log "receipt written"
@@ -70,13 +97,13 @@ read_version
 stage="$out/rel-$version"
 receipt="$stage/RECEIPT"
 
-if stage_artifacts; then
-  log "artifacts in place"
-else
-  printf 'mkrelease: staging failed\n' >&2
-  exit 70
+if [ ! -f "$build/MANIFEST" ]; then
+  fail 67 "no MANIFEST in $build"
 fi
 
-write_receipt && log "sealed"
+stage_artifacts
+log "artifacts in place"
+write_receipt
+log "sealed"
 
 log "release OK: rel-$version"
