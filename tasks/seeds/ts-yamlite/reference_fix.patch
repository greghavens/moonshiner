+// yamlite — dependency-free loader for the block-style YAML subset our
+// workflow tooling emits. See test_yamlite.ts for the contract.
+
+export class YamlParseError extends Error {
+  line: number;
+  col: number;
+  constructor(line: number, col: number, detail: string) {
+    super(`line ${line}, col ${col}: ${detail}`);
+    this.name = 'YamlParseError';
+    this.line = line;
+    this.col = col;
+  }
+}
+
+interface Line {
+  num: number;      // 1-based
+  raw: string;      // \r-stripped source line
+  indent: number;   // leading spaces
+  text: string;     // raw.slice(indent)
+  blank: boolean;   // empty or whitespace-only
+}
+
+function fail(line: number, col: number, detail: string): never {
+  throw new YamlParseError(line, col, detail);
+}
+
+function isCommentStart(text: string, i: number): boolean {
+  return text[i] === '#' && (i === 0 || text[i - 1] === ' ' || text[i - 1] === '\t');
+}
+
+/** Offset of the first `: ` (or colon at EOL) outside a comment, else -1. */
+function separatorOffset(text: string): number {
+  for (let i = 0; i < text.length; i++) {
+    if (isCommentStart(text, i)) return -1;
+    if (text[i] === ':' && (i + 1 === text.length || text[i + 1] === ' ')) return i;
+  }
+  return -1;
+}
+
+function isSeqEntry(text: string): boolean {
+  return text === '-' || text.startsWith('- ');
+}
+
+function typed(s: string): unknown {
+  if (s === '' || s === 'null' || s === '~') return null;
+  if (s === 'true') return true;
+  if (s === 'false') return false;
+  if (/^[+-]?\d+$/.test(s)) return Number(s);
+  if (/^[+-]?(\d+(\.\d*)?|\.\d+)([eE][+-]?\d+)?$/.test(s) && /[.eE]/.test(s)) return Number(s);
+  return s;
+}
+
+class Parser {
+  lines: Line[] = [];
+  idx = 0;
+
+  constructor(text: string) {
+    const rawLines = text.split('\n');
+    for (let n = 0; n < rawLines.length; n++) {
+      let raw = rawLines[n];
+      if (raw.endsWith('\r')) raw = raw.slice(0, -1);
+      let indent = 0;
+      while (indent < raw.length && raw[indent] === ' ') indent++;
+      const blank = /^\s*$/.test(raw);
+      if (!blank && raw[indent] === '\t') {
+        fail(n + 1, indent + 1, 'tab character in indentation');
+      }
+      this.lines.push({ num: n + 1, raw, indent, text: raw.slice(indent), blank });
+    }
+  }
+
+  cur(): Line | null {
+    return this.idx < this.lines.length ? this.lines[this.idx] : null;
+  }
+
+  /** Skip blank and comment-only lines. */
+  skipBlank(): Line | null {
+    for (;;) {
+      const l = this.cur();
+      if (!l) return null;
+      if (l.blank || l.text.startsWith('#')) { this.idx++; continue; }
+      return l;
+    }
+  }
+
+  parseDocument(): unknown {
+    const first = this.skipBlank();
+    if (!first) return null;
+    const value = this.parseBlock(first.indent, false);
+    const left = this.skipBlank();
+    if (left) fail(left.num, left.indent + 1, 'unexpected indentation');
+    return value;
+  }
+
+  /** Parse the block whose first line is the current line, at blockIndent. */
+  parseBlock(blockIndent: number, stopOnNonDash: boolean): unknown {
+    const line = this.cur()!;
+    if (isSeqEntry(line.text)) return this.parseSequence(blockIndent, stopOnNonDash, null);
+    const quotedKey = this.quotedKeyEnd(line);
+    if (quotedKey >= 0 || this.plainKeyEnd(line.text) >= 0) {
+      return this.parseMapping(blockIndent, null);
+    }
+    // single scalar block
+    const value = this.parseInlineNode(line, line.indent, blockIndent, 'value');
+    const next = this.skipBlank();
+    if (next && next.indent >= blockIndent) {
+      fail(next.num, next.indent + 1, 'unexpected content after scalar');
+    }
+    return value;
+  }
+
+  /** Offset of a plain-key separator in text, else -1 (empty keys don't count). */
+  plainKeyEnd(text: string): number {
+    if (text[0] === '"' || text[0] === "'") return -1;
+    const off = separatorOffset(text);
+    return off > 0 ? off : -1;
+  }
+
+  /** If the line opens with a quoted key ("k": / 'k':), offset of its colon, else -1. */
+  quotedKeyEnd(line: Line): number {
+    const t = line.text;
+    if (t[0] !== '"' && t[0] !== "'") return -1;
+    let end: number;
+    try {
+      end = this.scanQuoted(line, line.indent).endOffset;
+    } catch {
+      return -1;
+    }
+    const rel = end - line.indent;
+    if (t[rel] === ':' && (rel + 1 === t.length || t[rel + 1] === ' ')) return rel;
+    return -1;
+  }
+
+  parseMapping(blockIndent: number, virtualFirst: Line | null): unknown {
+    const entries: Array<[string, unknown]> = [];
+    const seen = new Set<string>();
+    let first = virtualFirst;
+    for (;;) {
+      let line: Line;
+      if (first) {
+        line = first;
+        first = null;
+      } else {
+        const l = this.skipBlank();
+        if (!l || l.indent < blockIndent) break;
+        if (l.indent > blockIndent) fail(l.num, l.indent + 1, 'unexpected indentation');
+        line = l;
+      }
+      // key
+      let key: string;
+      let restOffset: number; // offset into line.text just past the colon
+      const qEnd = this.quotedKeyEnd(line);
+      if (qEnd >= 0) {
+        key = this.scanQuoted(line, line.indent).value;
+        restOffset = qEnd + 1;
+      } else {
+        const sep = this.plainKeyEnd(line.text);
+        if (sep < 0) fail(line.num, line.indent + 1, "expected ':' after mapping key");
+        key = line.text.slice(0, sep).trim();
+        restOffset = sep + 1;
+      }
+      if (seen.has(key)) {
+        fail(line.num, line.indent + 1, `duplicate mapping key "${key}"`);
+      }
+      seen.add(key);
+      const value = this.parseEntryValue(line, restOffset, blockIndent);
+      entries.push([key, value]);
+    }
+    return Object.fromEntries(entries);
+  }
+
+  /** Value of `key:<rest>` — inline node, or a child block on following lines. */
+  parseEntryValue(line: Line, restOffset: number, ownerCol: number): unknown {
+    let i = restOffset;
+    while (i < line.text.length && line.text[i] === ' ') i++;
+    if (i >= line.text.length || isCommentStart(line.text, i)) {
+      // no inline value: child block or null
+      this.idx++;
+      const next = this.skipBlank();
+      if (next && next.indent > ownerCol) return this.parseBlock(next.indent, false);
+      if (next && next.indent === ownerCol && isSeqEntry(next.text)) {
+        return this.parseSequence(ownerCol, true, null);
+      }
+      return null;
+    }
+    return this.parseInlineNode(line, line.indent + i, ownerCol, 'value');
+  }
+
+  parseSequence(blockIndent: number, stopOnNonDash: boolean, virtualFirst: Line | null): unknown {
+    const items: unknown[] = [];
+    let first = virtualFirst;
+    for (;;) {
+      let line: Line;
+      if (first) {
+        line = first;
+        first = null;
+      } else {
+        const l = this.skipBlank();
+        if (!l || l.indent < blockIndent) break;
+        if (l.indent > blockIndent) fail(l.num, l.indent + 1, 'unexpected indentation');
+        if (!isSeqEntry(l.text)) {
+          if (stopOnNonDash) break;
+          fail(l.num, l.indent + 1, "expected '-' sequence indicator");
+        }
+        line = l;
+      }
+      let i = 1; // past the dash (relative to line.indent)
+      while (i < line.text.length && line.text[i] === ' ') i++;
+      if (i >= line.text.length || isCommentStart(line.text, i)) {
+        // no inline item: child block or null
+        this.idx++;
+        const next = this.skipBlank();
+        if (next && next.indent > blockIndent) {
+          items.push(this.parseBlock(next.indent, false));
+        } else {
+          items.push(null);
+        }
+        continue;
+      }
+      items.push(this.parseInlineNode(line, line.indent + i, blockIndent, 'item'));
+    }
+    return items;
+  }
+
+  /**
+   * Parse the node starting mid-line at absolute column col0 (0-based).
+   * ownerCol: column of the entry introducing it (key col / dash col) — used
+   * as the boundary for block scalars. context 'item' allows compact
+   * mappings/sequences to open here.
+   */
+  parseInlineNode(line: Line, col0: number, ownerCol: number, context: 'value' | 'item'): unknown {
+    const rel = col0 - line.indent;
+    const text = line.text.slice(rel);
+    const ch = text[0];
+    if (ch === '[' || ch === '{') {
+      fail(line.num, col0 + 1, 'flow collections are not supported');
+    }
+    if (ch === '&' || ch === '*' || ch === '!') {
+      fail(line.num, col0 + 1, 'anchors, aliases, and tags are not supported');
+    }
+    if (ch === '"' || ch === "'") {
+      const { value, endOffset } = this.scanQuoted(line, col0);
+      let j = endOffset - line.indent;
+      while (j < line.text.length && line.text[j] === ' ') j++;
+      if (j < line.text.length && line.text[j] !== '#') {
+        fail(line.num, line.indent + j + 1, 'unexpected content after quoted scalar');
+      }
+      this.idx++;
+      return value;
+    }
+    if (ch === '|' || ch === '>') {
+      return this.parseBlockScalar(line, col0, ownerCol);
+    }
+    if (context === 'item') {
+      const virtual: Line = {
+        num: line.num, raw: line.raw, indent: col0, text, blank: false,
+      };
+      // The current (dash) line stays current: the first virtual entry's own
+      // value parse consumes it exactly once.
+      if (isSeqEntry(text)) {
+        return this.parseSequence(col0, false, virtual);
+      }
+      if (this.plainKeyEnd(text) >= 0 || this.quotedKeyEnd(virtual) >= 0) {
+        return this.parseMapping(col0, virtual);
+      }
+    }
+    // plain scalar: cut trailing comment, reject a second `: ` in value position
+    let end = text.length;
+    for (let i = 0; i < text.length; i++) {
+      if (isCommentStart(text, i)) { end = i; break; }
+      if (text[i] === ':' && text[i + 1] === ' ') {
+        fail(line.num, col0 + i + 1, "unexpected ':' in plain scalar");
+      }
+    }
+    this.idx++;
+    return typed(text.slice(0, end).trim());
+  }
+
+  /** Scan a quoted scalar starting at absolute column start (0-based). */
+  scanQuoted(line: Line, start: number): { value: string; endOffset: number } {
+    const raw = line.raw;
+    const quote = raw[start];
+    let out = '';
+    let i = start + 1;
+    while (i < raw.length) {
+      const c = raw[i];
+      if (c === quote) {
+        if (quote === "'" && raw[i + 1] === "'") { out += "'"; i += 2; continue; }
+        return { value: out, endOffset: i + 1 };
+      }
+      if (quote === '"' && c === '\\') {
+        const e = raw[i + 1];
+        if (e === 'u') {
+          const hex = raw.slice(i + 2, i + 6);
+          if (!/^[0-9a-fA-F]{4}$/.test(hex)) {
+            fail(line.num, i + 1, 'invalid unicode escape');
+          }
+          out += String.fromCharCode(parseInt(hex, 16));
+          i += 6;
+          continue;
+        }
+        const map: Record<string, string> = {
+          '"': '"', '\\': '\\', '/': '/', n: '\n', t: '\t', r: '\r',
+        };
+        if (e === undefined || !(e in map)) {
+          fail(line.num, i + 1, `invalid escape sequence \\${e ?? ''}`);
+        }
+        out += map[e];
+        i += 2;
+        continue;
+      }
+      out += c;
+      i++;
+    }
+    fail(line.num, start + 1,
+      quote === '"' ? 'unterminated double-quoted string' : 'unterminated single-quoted string');
+  }
+
+  /** Parse `|`/`>` (optionally with `-`) starting at absolute column col0. */
+  parseBlockScalar(line: Line, col0: number, ownerCol: number): string {
+    const folded = line.raw[col0] === '>';
+    let j = col0 + 1;
+    let strip = false;
+    if (line.raw[j] === '-') { strip = true; j++; }
+    while (j < line.raw.length && line.raw[j] === ' ') j++;
+    if (j < line.raw.length && line.raw[j] !== '#') {
+      fail(line.num, j + 1, 'unexpected content after block scalar indicator');
+    }
+    this.idx++; // past the indicator line
+    const contents: string[] = [];
+    let blockIndent = -1;
+    for (;;) {
+      const l = this.cur();
+      if (!l) break;
+      if (l.blank) { contents.push(''); this.idx++; continue; }
+      if (l.indent <= ownerCol) break;
+      if (blockIndent < 0) {
+        blockIndent = l.indent;
+      } else if (l.indent < blockIndent) {
+        fail(l.num, l.indent + 1, 'bad indentation in block scalar');
+      }
+      contents.push(l.raw.slice(blockIndent));
+      this.idx++;
+    }
+    while (contents.length && contents[contents.length - 1] === '') contents.pop();
+    let body: string;
+    if (!folded) {
+      body = contents.join('\n');
+    } else {
+      const parts: string[] = [];
+      let run: string[] = [];
+      for (const c of contents) {
+        if (c === '') {
+          if (run.length) { parts.push(run.join(' ')); run = []; }
+          if (parts[parts.length - 1] !== '\n') parts.push('\n');
+        } else {
+          run.push(c);
+        }
+      }
+      if (run.length) parts.push(run.join(' '));
+      body = parts.join('');
+    }
+    if (body === '') return '';
+    return strip ? body : body + '\n';
+  }
+}
+
+export function parse(text: string): unknown {
+  return new Parser(text).parseDocument();
+}
