diff --git a/sokoban.cpp b/sokoban.cpp
new file mode 100644
index 0000000..8e93d1b
--- /dev/null
+++ b/sokoban.cpp
@@ -0,0 +1,152 @@
+#include "sokoban.h"
+
+#include <cctype>
+
+namespace {
+
+bool dir_delta(char dir, int *dr, int *dc) {
+    switch (std::tolower(static_cast<unsigned char>(dir))) {
+        case 'l': *dr = 0;  *dc = -1; return true;
+        case 'u': *dr = -1; *dc = 0;  return true;
+        case 'r': *dr = 0;  *dc = 1;  return true;
+        case 'd': *dr = 1;  *dc = 0;  return true;
+        default: return false;
+    }
+}
+
+}  // namespace
+
+bool sb_load(Sokoban *s, const std::string &level) {
+    *s = Sokoban{};
+    std::vector<std::string> lines;
+    std::string cur;
+    for (char ch : level) {
+        if (ch == '\n') { lines.push_back(cur); cur.clear(); }
+        else cur += ch;
+    }
+    if (!cur.empty()) lines.push_back(cur);
+    if (lines.empty()) return false;
+
+    size_t width = 0;
+    for (const std::string &l : lines) width = std::max(width, l.size());
+    if (width == 0) return false;
+
+    s->width = static_cast<int>(width);
+    s->height = static_cast<int>(lines.size());
+    s->tiles.assign(s->height, std::string(width, ' '));
+    s->boxes.assign(s->height, std::string(width, ' '));
+
+    int players = 0, boxes = 0, goals = 0;
+    for (int r = 0; r < s->height; r++) {
+        for (int c = 0; c < static_cast<int>(lines[r].size()); c++) {
+            char ch = lines[r][c];
+            switch (ch) {
+                case '#': s->tiles[r][c] = '#'; break;
+                case ' ': break;
+                case '.': s->tiles[r][c] = '.'; goals++; break;
+                case '$': s->boxes[r][c] = 'B'; boxes++; break;
+                case '*': s->tiles[r][c] = '.'; s->boxes[r][c] = 'B';
+                          goals++; boxes++; break;
+                case '@': s->player_r = r; s->player_c = c; players++; break;
+                case '+': s->tiles[r][c] = '.'; goals++;
+                          s->player_r = r; s->player_c = c; players++; break;
+                default: return false;
+            }
+        }
+    }
+    if (players != 1 || boxes != goals || boxes < 1) return false;
+    s->ok = true;
+    return true;
+}
+
+namespace {
+
+bool blocked_at(const Sokoban *s, int r, int c) {
+    if (r < 0 || r >= s->height || c < 0 || c >= s->width) return true;
+    return s->tiles[r][c] == '#';
+}
+
+}  // namespace
+
+int sb_move(Sokoban *s, char dir) {
+    int dr, dc;
+    if (!dir_delta(dir, &dr, &dc)) return -1;
+    int tr = s->player_r + dr, tc = s->player_c + dc;
+    if (blocked_at(s, tr, tc)) return 0;
+    bool pushed = false;
+    if (s->boxes[tr][tc] == 'B') {
+        int br = tr + dr, bc = tc + dc;
+        if (blocked_at(s, br, bc) || s->boxes[br][bc] == 'B') return 0;
+        s->boxes[tr][tc] = ' ';
+        s->boxes[br][bc] = 'B';
+        s->push_count++;
+        pushed = true;
+    }
+    s->player_r = tr;
+    s->player_c = tc;
+    s->history.push_back({dir, pushed});
+    return pushed ? 2 : 1;
+}
+
+int sb_run(Sokoban *s, const std::string &lurd) {
+    int applied = 0;
+    for (char ch : lurd) {
+        if (sb_move(s, ch) <= 0) break;
+        applied++;
+    }
+    return applied;
+}
+
+bool sb_undo(Sokoban *s) {
+    if (s->history.empty()) return false;
+    Sokoban::Step step = s->history.back();
+    s->history.pop_back();
+    int dr = 0, dc = 0;
+    dir_delta(step.dir, &dr, &dc);
+    if (step.pushed) {
+        int br = s->player_r + dr, bc = s->player_c + dc;
+        s->boxes[br][bc] = ' ';
+        s->boxes[s->player_r][s->player_c] = 'B';
+        s->push_count--;
+    }
+    s->player_r -= dr;
+    s->player_c -= dc;
+    return true;
+}
+
+bool sb_solved(const Sokoban *s) {
+    for (int r = 0; r < s->height; r++)
+        for (int c = 0; c < s->width; c++)
+            if (s->boxes[r][c] == 'B' && s->tiles[r][c] != '.') return false;
+    return true;
+}
+
+bool sb_deadlocked(const Sokoban *s) {
+    for (int r = 0; r < s->height; r++)
+        for (int c = 0; c < s->width; c++) {
+            if (s->boxes[r][c] != 'B' || s->tiles[r][c] == '.') continue;
+            bool vert = blocked_at(s, r - 1, c) || blocked_at(s, r + 1, c);
+            bool horz = blocked_at(s, r, c - 1) || blocked_at(s, r, c + 1);
+            if (vert && horz) return true;
+        }
+    return false;
+}
+
+int sb_moves(const Sokoban *s) { return static_cast<int>(s->history.size()); }
+
+int sb_pushes(const Sokoban *s) { return s->push_count; }
+
+std::string sb_render(const Sokoban *s) {
+    std::string out;
+    for (int r = 0; r < s->height; r++) {
+        for (int c = 0; c < s->width; c++) {
+            bool goal = s->tiles[r][c] == '.';
+            if (s->tiles[r][c] == '#') out += '#';
+            else if (r == s->player_r && c == s->player_c) out += goal ? '+' : '@';
+            else if (s->boxes[r][c] == 'B') out += goal ? '*' : '$';
+            else out += goal ? '.' : ' ';
+        }
+        out += '\n';
+    }
+    return out;
+}
diff --git a/sokoban.h b/sokoban.h
new file mode 100644
