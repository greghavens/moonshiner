+++ b/sokoban.h
@@ -0,0 +1,30 @@
+#ifndef SOKOBAN_H
+#define SOKOBAN_H
+
+#include <string>
+#include <vector>
+
+struct Sokoban {
+    int width = 0;
+    int height = 0;
+    std::vector<std::string> tiles;   // '#' wall, '.' goal, ' ' floor
+    std::vector<std::string> boxes;   // 'B' where a box stands
+    int player_r = 0;
+    int player_c = 0;
+    struct Step { char dir; bool pushed; };
+    std::vector<Step> history;
+    int push_count = 0;
+    bool ok = false;
+};
+
+bool sb_load(Sokoban *s, const std::string &level);
+int  sb_move(Sokoban *s, char dir);
+int  sb_run(Sokoban *s, const std::string &lurd);
+bool sb_undo(Sokoban *s);
+bool sb_solved(const Sokoban *s);
+bool sb_deadlocked(const Sokoban *s);
+int  sb_moves(const Sokoban *s);
+int  sb_pushes(const Sokoban *s);
+std::string sb_render(const Sokoban *s);
+
+#endif
