+import java.io.IOException;
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.Base64;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Batch encryption/decryption adapter for Vault's Transit engine.
+ *
+ * Requests carry an index-aligned batch_input array plus
+ * partial_failure_response_code=200, so per-item failures come back as a
+ * decodable success response with error strings in batch_results; a
+ * request-level failure still surfaces as VaultApiException.
+ */
+public final class TransitBatch {
+
+    private final VaultClient client;
+    private final String mount;
+
+    public TransitBatch(VaultClient client) {
+        this(client, "transit");
+    }
+
+    public TransitBatch(VaultClient client, String mount) {
+        this.client = client;
+        this.mount = mount;
+    }
+
+    // ------------------------------------------------------------ inputs
+
+    public static final class EncryptItem {
+        private final byte[] plaintext;
+        private byte[] context;
+        private byte[] associatedData;
+        private Integer keyVersion;
+
+        public EncryptItem(byte[] plaintext) {
+            this.plaintext = plaintext.clone();
+        }
+
+        public EncryptItem withContext(byte[] context) {
+            this.context = context.clone();
+            return this;
+        }
+
+        public EncryptItem withAssociatedData(byte[] associatedData) {
+            this.associatedData = associatedData.clone();
+            return this;
+        }
+
+        public EncryptItem withKeyVersion(int keyVersion) {
+            this.keyVersion = keyVersion;
+            return this;
+        }
+    }
+
+    public static final class DecryptItem {
+        private final String ciphertext;
+        private byte[] context;
+        private byte[] associatedData;
+
+        public DecryptItem(String ciphertext) {
+            this.ciphertext = ciphertext;
+        }
+
+        public DecryptItem withContext(byte[] context) {
+            this.context = context.clone();
+            return this;
+        }
+
+        public DecryptItem withAssociatedData(byte[] associatedData) {
+            this.associatedData = associatedData.clone();
+            return this;
+        }
+    }
+
+    // ------------------------------------------------------------ results
+
+    public static final class EncryptResult {
+        private final String ciphertext;
+        private final int keyVersion;
+        private final String error;
+
+        EncryptResult(String ciphertext, int keyVersion, String error) {
+            this.ciphertext = ciphertext;
+            this.keyVersion = keyVersion;
+            this.error = error;
+        }
+
+        public boolean ok() {
+            return error == null;
+        }
+
+        public String ciphertext() {
+            return ciphertext;
+        }
+
+        public int keyVersion() {
+            return keyVersion;
+        }
+
+        public String error() {
+            return error;
+        }
+    }
+
+    public static final class DecryptResult {
+        private final byte[] plaintext;
+        private final String error;
+
+        DecryptResult(byte[] plaintext, String error) {
+            this.plaintext = plaintext;
+            this.error = error;
+        }
+
+        public boolean ok() {
+            return error == null;
+        }
+
+        public byte[] plaintext() {
+            return plaintext == null ? null : plaintext.clone();
+        }
+
+        public String error() {
+            return error;
+        }
+    }
+
+    // ---------------------------------------------------------- operations
+
+    public List<EncryptResult> encrypt(String keyName, List<EncryptItem> items)
+            throws IOException, InterruptedException {
+        List<Object> batch = new ArrayList<>();
+        for (EncryptItem item : items) {
+            Map<String, Object> entry = new LinkedHashMap<>();
+            entry.put("plaintext", b64(item.plaintext));
+            if (item.context != null) entry.put("context", b64(item.context));
+            if (item.associatedData != null) entry.put("associated_data", b64(item.associatedData));
+            if (item.keyVersion != null) entry.put("key_version", item.keyVersion);
+            batch.add(entry);
+        }
+        Map<String, Object> response =
+                client.post(mount + "/encrypt/" + escapePathSegment(keyName), envelope(batch));
+        List<EncryptResult> out = new ArrayList<>();
+        for (Map<String, Object> result : batchResults(response)) {
+            String error = (String) result.get("error");
+            if (error != null) {
+                out.add(new EncryptResult(null, 0, error));
+            } else {
+                out.add(new EncryptResult(
+                        (String) result.get("ciphertext"),
+                        ((Number) result.get("key_version")).intValue(),
+                        null));
+            }
+        }
+        return out;
+    }
+
+    public List<DecryptResult> decrypt(String keyName, List<DecryptItem> items)
+            throws IOException, InterruptedException {
+        List<Object> batch = new ArrayList<>();
+        for (DecryptItem item : items) {
+            Map<String, Object> entry = new LinkedHashMap<>();
+            entry.put("ciphertext", item.ciphertext); // verbatim, never base64d
+            if (item.context != null) entry.put("context", b64(item.context));
+            if (item.associatedData != null) entry.put("associated_data", b64(item.associatedData));
+            batch.add(entry);
+        }
+        Map<String, Object> response =
+                client.post(mount + "/decrypt/" + escapePathSegment(keyName), envelope(batch));
+        List<DecryptResult> out = new ArrayList<>();
+        for (Map<String, Object> result : batchResults(response)) {
+            String error = (String) result.get("error");
+            if (error != null) {
+                out.add(new DecryptResult(null, error));
+            } else {
+                out.add(new DecryptResult(
+                        Base64.getDecoder().decode((String) result.get("plaintext")), null));
+            }
+        }
+        return out;
+    }
+
+    // ------------------------------------------------------------ helpers
+
+    private static Map<String, Object> envelope(List<Object> batch) {
+        Map<String, Object> body = new LinkedHashMap<>();
+        body.put("batch_input", batch);
+        body.put("partial_failure_response_code", 200);
+        return body;
+    }
+
+    @SuppressWarnings("unchecked")
+    private static List<Map<String, Object>> batchResults(Map<String, Object> response) {
+        Map<String, Object> data = (Map<String, Object>) response.get("data");
+        return (List<Map<String, Object>>) (List<?>) data.get("batch_results");
+    }
+
+    private static String b64(byte[] bytes) {
+        return Base64.getEncoder().encodeToString(bytes);
+    }
+
+    /**
+     * RFC 3986 percent-escaping for a single path segment. URLEncoder is the
+     * wrong tool here: it form-encodes space as '+', which in a path is a
+     * literal plus.
+     */
+    static String escapePathSegment(String name) {
+        StringBuilder sb = new StringBuilder();
+        for (byte raw : name.getBytes(StandardCharsets.UTF_8)) {
+            int b = raw & 0xFF;
+            boolean unreserved = (b >= 'A' && b <= 'Z') || (b >= 'a' && b <= 'z')
+                    || (b >= '0' && b <= '9') || b == '-' || b == '.' || b == '_' || b == '~';
+            if (unreserved) {
+                sb.append((char) b);
+            } else {
+                sb.append('%').append(String.format("%02X", b));
+            }
+        }
+        return sb.toString();
+    }
+}
