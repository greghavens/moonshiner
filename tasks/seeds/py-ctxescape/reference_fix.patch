+"""Context-aware template rendering for the status-page renderer.
+
+Placeholders are ``{{ name }}``. The escaping applied to a substituted value
+depends on where in the surrounding HTML the placeholder sits: text node,
+quoted attribute value, or href/src URL (full URL vs. URL component). Static
+template text is the author's own HTML and passes through verbatim.
+"""
+import re
+import urllib.parse
+
+__all__ = [
+    "TemplateContextError",
+    "TemplateSyntaxError",
+    "placeholder_contexts",
+    "render",
+]
+
+
+class TemplateSyntaxError(Exception):
+    """A malformed placeholder: unterminated braces or a bad name."""
+
+
+class TemplateContextError(Exception):
+    """A placeholder in a spot the renderer does not support."""
+
+    def __init__(self, name, where):
+        super().__init__(f"placeholder '{name}' in unsupported context: {where}")
+        self.name = name
+        self.where = where
+
+
+_NAME_RE = re.compile(r"[A-Za-z_][A-Za-z0-9_]*\Z")
+_URL_ATTRS = {"href", "src"}
+_RAW_TAGS = {"script", "style"}
+_SCHEMES = {"http", "https", "mailto"}
+
+# scanner modes
+_TEXT, _TAG, _RAW, _COMMENT = 0, 1, 2, 3
+
+
+def _parse(source):
+    """Split the template into ("lit", text) and ("ph", name, context) parts."""
+    segments = []
+    lit = []
+    i, n = 0, len(source)
+    mode = _TEXT
+    tag_name = ""
+    tag_close = False
+    tstate = ""      # name | attrs | attr | attr_ws | after_eq | unquoted | quoted
+    attr_name = ""
+    quote = ""
+    value_len = 0    # characters seen so far inside the current quoted value
+    raw_end = ""     # e.g. "</script"
+
+    def flush():
+        if lit:
+            segments.append(("lit", "".join(lit)))
+            del lit[:]
+
+    def take_placeholder():
+        nonlocal i
+        end = source.find("}}", i + 2)
+        if end < 0:
+            raise TemplateSyntaxError("'{{' is never closed with '}}'")
+        name = source[i + 2:end].strip()
+        if not _NAME_RE.match(name):
+            raise TemplateSyntaxError(f"bad placeholder name {name!r}")
+        i = end + 2
+        return name
+
+    while i < n:
+        if source.startswith("{{", i):
+            name = take_placeholder()
+            if mode == _TEXT:
+                context = "text"
+            elif mode == _COMMENT:
+                raise TemplateContextError(name, "comment")
+            elif mode == _RAW:
+                raise TemplateContextError(name, "script-style")
+            elif tstate == "quoted":
+                if attr_name in _URL_ATTRS:
+                    context = "url-full" if value_len == 0 else "url-part"
+                else:
+                    context = "attr"
+                value_len += 1
+            elif tstate in ("unquoted", "after_eq"):
+                # right after '=' counts too: the placeholder IS the unquoted value
+                raise TemplateContextError(name, "unquoted-attr")
+            else:
+                raise TemplateContextError(name, "tag")
+            flush()
+            segments.append(("ph", name, context))
+            continue
+
+        c = source[i]
+
+        if mode == _TEXT:
+            if source.startswith("<!--", i):
+                mode = _COMMENT
+                lit.append("<!--")
+                i += 4
+            elif c == "<" and (
+                source.startswith("{{", i + 1)
+                or (i + 1 < n and (source[i + 1].isalpha() or source[i + 1] == "/"))
+            ):
+                mode = _TAG
+                tag_close = source[i + 1] == "/"
+                tstate = "name"
+                tag_name = attr_name = quote = ""
+                value_len = 0
+                lit.append(c)
+                i += 1
+                if tag_close:
+                    lit.append("/")
+                    i += 1
+            else:
+                lit.append(c)
+                i += 1
+            continue
+
+        if mode == _COMMENT:
+            if source.startswith("-->", i):
+                mode = _TEXT
+                lit.append("-->")
+                i += 3
+            else:
+                lit.append(c)
+                i += 1
+            continue
+
+        if mode == _RAW:
+            if source[i:i + len(raw_end)].lower() == raw_end:
+                mode = _TEXT  # rescan the close tag as a normal tag
+            else:
+                lit.append(c)
+                i += 1
+            continue
+
+        # mode == _TAG
+        if tstate == "quoted":
+            lit.append(c)
+            i += 1
+            if c == quote:
+                tstate = "attrs"
+                attr_name = ""
+            else:
+                value_len += 1
+            continue
+        if c == ">":
+            lit.append(c)
+            i += 1
+            self_closed = i >= 2 and source[i - 2] == "/"
+            if not tag_close and tag_name in _RAW_TAGS and not self_closed:
+                mode = _RAW
+                raw_end = "</" + tag_name
+            else:
+                mode = _TEXT
+            continue
+        if tstate == "name":
+            if c.isspace():
+                tstate = "attrs"
+            else:
+                tag_name += c.lower()
+        elif tstate == "attrs":
+            if c == "=":
+                tstate = "after_eq"
+            elif not c.isspace() and c != "/":
+                tstate = "attr"
+                attr_name = c.lower()
+        elif tstate == "attr":
+            if c == "=":
+                tstate = "after_eq"
+            elif c.isspace():
+                tstate = "attr_ws"
+            else:
+                attr_name += c.lower()
+        elif tstate == "attr_ws":
+            if c == "=":
+                tstate = "after_eq"
+            elif not c.isspace() and c != "/":
+                tstate = "attr"
+                attr_name = c.lower()
+        elif tstate == "after_eq":
+            if c in "\"'":
+                tstate = "quoted"
+                quote = c
+                value_len = 0
+            elif not c.isspace():
+                tstate = "unquoted"
+        elif tstate == "unquoted":
+            if c.isspace():
+                tstate = "attrs"
+                attr_name = ""
+        lit.append(c)
+        i += 1
+
+    flush()
+    return segments
+
+
+def _escape_text(value):
+    return value.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
+
+
+def _escape_attr(value):
+    return _escape_text(value).replace('"', "&quot;").replace("'", "&#x27;")
+
+
+def _scheme_supported(value):
+    try:
+        scheme = urllib.parse.urlsplit(value.strip()).scheme
+    except ValueError:
+        return False
+    return scheme == "" or scheme.lower() in _SCHEMES
+
+
+def placeholder_contexts(source):
+    """(name, context) for each placeholder occurrence, in template order."""
+    return [(seg[1], seg[2]) for seg in _parse(source) if seg[0] == "ph"]
+
+
+def render(source, values):
+    """Substitute values into the template, escaping each per its context."""
+    out = []
+    for seg in _parse(source):
+        if seg[0] == "lit":
+            out.append(seg[1])
+            continue
+        _, name, context = seg
+        value = str(values[name])
+        if context == "text":
+            out.append(_escape_text(value))
+        elif context == "attr":
+            out.append(_escape_attr(value))
+        elif context == "url-full":
+            out.append(_escape_attr(value) if _scheme_supported(value) else "#")
+        else:  # url-part
+            out.append(urllib.parse.quote(value, safe=""))
+    return "".join(out)
