diff --git a/OracleRestException.java b/OracleRestException.java
new file mode 100644
index 0000000..88665c4
--- /dev/null
+++ b/OracleRestException.java
@@ -0,0 +1,69 @@
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * Non-2xx response from the HCM REST framework. With REST-Framework-Version 4
+ * or later the body is application/vnd.oracle.adf.error+json:
+ * { "title", "status" (string), "o:errorDetails": [{ "detail", "o:errorCode", "o:errorPath" }] }.
+ * The complete document is preserved; credentials never enter the message.
+ */
+public final class OracleRestException extends RuntimeException {
+    private final int httpStatus;
+    private final String title;
+    private final String errorStatus;
+    private final List<OracleErrorDetail> details;
+
+    public OracleRestException(int httpStatus, String title, String errorStatus,
+                               List<OracleErrorDetail> details) {
+        super(buildMessage(httpStatus, title, details));
+        this.httpStatus = httpStatus;
+        this.title = title;
+        this.errorStatus = errorStatus;
+        this.details = Collections.unmodifiableList(new ArrayList<>(details));
+    }
+
+    private static String buildMessage(int httpStatus, String title, List<OracleErrorDetail> details) {
+        StringBuilder sb = new StringBuilder("Oracle HCM request failed (HTTP ")
+                .append(httpStatus).append("): ").append(title);
+        if (!details.isEmpty()) {
+            sb.append(" [").append(details.get(0).errorCode()).append("] ")
+              .append(details.get(0).detail());
+        }
+        return sb.toString();
+    }
+
+    @SuppressWarnings("unchecked")
+    static OracleRestException from(int httpStatus, String body) {
+        String title = "HTTP " + httpStatus;
+        String errorStatus = String.valueOf(httpStatus);
+        List<OracleErrorDetail> details = new ArrayList<>();
+        try {
+            Map<String, Object> doc = (Map<String, Object>) MiniJson.parse(body);
+            if (doc.get("title") instanceof String t) title = t;
+            if (doc.get("status") instanceof String st) errorStatus = st;
+            Object raw = doc.get("o:errorDetails");
+            if (raw instanceof List<?> list) {
+                for (Object o : list) {
+                    Map<String, Object> d = (Map<String, Object>) o;
+                    details.add(new OracleErrorDetail(
+                            String.valueOf(d.getOrDefault("detail", "")),
+                            String.valueOf(d.getOrDefault("o:errorCode", "")),
+                            String.valueOf(d.getOrDefault("o:errorPath", ""))));
+                }
+            }
+        } catch (RuntimeException parseFailure) {
+            details.add(new OracleErrorDetail(body, "", ""));
+        }
+        return new OracleRestException(httpStatus, title, errorStatus, details);
+    }
+
+    public int httpStatus() { return httpStatus; }
+
+    public String title() { return title; }
+
+    public String errorStatus() { return errorStatus; }
+
+    public List<OracleErrorDetail> details() { return details; }
+}
diff --git a/RosterExport.java b/RosterExport.java
new file mode 100644
index 0000000..1bad141
--- /dev/null
+++ b/RosterExport.java
@@ -0,0 +1,30 @@
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+
+/** Headcount snapshot export: one 'PersonNumber|DisplayName' line per worker effective on the as-of date. */
+public final class RosterExport {
+
+    public record Result(List<String> lines, Long estimatedTotalResults, int pagesFetched) {}
+
+    private RosterExport() {}
+
+    public static Result effectiveRoster(HcmWorkersClient client, String effectiveDate, int pageSize) {
+        WorkersQuery query = WorkersQuery.workers()
+                .onlyData(true)
+                .fields("PersonId", "PersonNumber", "DisplayName")
+                .effectiveDate(effectiveDate)
+                .orderBy("PersonNumber:asc")
+                .totalResults(true)
+                .limit(pageSize)
+                .offset(0);
+        WorkersScan scan = client.scanAll(query);
+        List<WorkerRecord> records = new ArrayList<>(scan.records());
+        records.sort(Comparator.comparing(r -> r.str("PersonNumber")));
+        List<String> lines = new ArrayList<>();
+        for (WorkerRecord r : records) {
+            lines.add(r.str("PersonNumber") + "|" + r.str("DisplayName"));
+        }
+        return new Result(lines, scan.estimatedTotalResults(), scan.pagesFetched());
+    }
+}
