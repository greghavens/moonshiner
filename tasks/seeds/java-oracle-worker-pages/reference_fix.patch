--- /dev/null
+++ b/WorkersPage.java
@@ -0,0 +1,47 @@
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.List;
+import java.util.Map;
+
+/**
+ * One page of the workers collection: the documented envelope
+ * { items, count, hasMore, limit, offset, totalResults? }.
+ * limit/offset reflect what the SERVER actually used, which may differ from
+ * the requested values; totalResults is present only when requested and is
+ * an estimate.
+ */
+public final class WorkersPage {
+    private final List<WorkerRecord> items;
+    private final int count;
+    private final boolean hasMore;
+    private final int limit;
+    private final long offset;
+    private final Long totalResults;
+
+    @SuppressWarnings("unchecked")
+    WorkersPage(Map<String, Object> doc) {
+        List<WorkerRecord> recs = new ArrayList<>();
+        for (Object o : (List<Object>) doc.get("items")) {
+            recs.add(new WorkerRecord((Map<String, Object>) o));
+        }
+        this.items = Collections.unmodifiableList(recs);
+        this.count = ((Number) doc.get("count")).intValue();
+        this.hasMore = (Boolean) doc.get("hasMore");
+        this.limit = ((Number) doc.get("limit")).intValue();
+        this.offset = ((Number) doc.get("offset")).longValue();
+        Object tr = doc.get("totalResults");
+        this.totalResults = tr == null ? null : ((Number) tr).longValue();
+    }
+
+    public List<WorkerRecord> items() { return items; }
+
+    public int count() { return count; }
+
+    public boolean hasMore() { return hasMore; }
+
+    public int limit() { return limit; }
+
+    public long offset() { return offset; }
+
+    public Long totalResults() { return totalResults; }
+}
diff --git a/WorkersQuery.java b/WorkersQuery.java
new file mode 100644
index 0000000..b82461f
--- /dev/null
+++ b/WorkersQuery.java
@@ -0,0 +1,85 @@
+import java.net.URLEncoder;
+import java.nio.charset.StandardCharsets;
+import java.util.ArrayList;
+import java.util.List;
+
+/**
+ * Query builder for the Fusion HCM workers collection
+ * (/hcmRestApi/resources/11.13.18.05/workers).
+ *
+ * Serialization order: onlyData, fields, expand, finder, effectiveDate,
+ * orderBy, totalResults, limit, offset. Options never set are omitted;
+ * boolean options are only emitted when true. Per the documented restriction
+ * on the workers resource, fields and expand cannot be combined.
+ */
+public final class WorkersQuery {
+    private boolean onlyData;
+    private String fields;
+    private String expand;
+    private String finder;
+    private String effectiveDate;
+    private String orderBy;
+    private boolean totalResults;
+    private Integer limit;
+    private Long offset;
+
+    private WorkersQuery() {}
+
+    public static WorkersQuery workers() { return new WorkersQuery(); }
+
+    public WorkersQuery fields(String... names) {
+        if (expand != null) throw new IllegalStateException("fields cannot be combined with expand");
+        this.fields = String.join(",", names);
+        return this;
+    }
+
+    public WorkersQuery expand(String... accessors) {
+        if (fields != null) throw new IllegalStateException("expand cannot be combined with fields");
+        this.expand = String.join(",", accessors);
+        return this;
+    }
+
+    public WorkersQuery onlyData(boolean b) { this.onlyData = b; return this; }
+
+    /** finder("findReports", "PersonId=101", "DirectReportsFlag=true") → finder=findReports;PersonId=101,DirectReportsFlag=true */
+    public WorkersQuery finder(String name, String... vars) {
+        StringBuilder sb = new StringBuilder(name);
+        for (int i = 0; i < vars.length; i++) {
+            int eq = vars[i].indexOf('=');
+            if (eq < 0) throw new IllegalArgumentException("finder variable must be name=value: " + vars[i]);
+            sb.append(i == 0 ? ';' : ',')
+              .append(vars[i], 0, eq + 1)
+              .append(encodeValue(vars[i].substring(eq + 1)));
+        }
+        this.finder = sb.toString();
+        return this;
+    }
+
+    public WorkersQuery effectiveDate(String yyyyMmDd) { this.effectiveDate = yyyyMmDd; return this; }
+
+    public WorkersQuery orderBy(String spec) { this.orderBy = spec; return this; }
+
+    public WorkersQuery totalResults(boolean b) { this.totalResults = b; return this; }
+
+    public WorkersQuery limit(int n) { this.limit = n; return this; }
+
+    public WorkersQuery offset(long n) { this.offset = n; return this; }
+
+    private static String encodeValue(String v) {
+        return URLEncoder.encode(v, StandardCharsets.UTF_8).replace("+", "%20");
+    }
+
+    public String toQueryString() {
+        List<String> parts = new ArrayList<>();
+        if (onlyData) parts.add("onlyData=true");
+        if (fields != null) parts.add("fields=" + fields);
+        if (expand != null) parts.add("expand=" + expand);
+        if (finder != null) parts.add("finder=" + finder);
+        if (effectiveDate != null) parts.add("effectiveDate=" + effectiveDate);
+        if (orderBy != null) parts.add("orderBy=" + orderBy);
+        if (totalResults) parts.add("totalResults=true");
+        if (limit != null) parts.add("limit=" + limit);
+        if (offset != null) parts.add("offset=" + offset);
+        return String.join("&", parts);
+    }
+}
