index 0000000..40005da
--- /dev/null
+++ b/WorkerRecord.java
@@ -0,0 +1,31 @@
+import java.util.ArrayList;
+import java.util.List;
+import java.util.Map;
+
+/** One item of a workers collection response. */
+public final class WorkerRecord {
+    private final Map<String, Object> attrs;
+
+    WorkerRecord(Map<String, Object> attrs) { this.attrs = attrs; }
+
+    public String str(String name) { return (String) attrs.get(name); }
+
+    public long num(String name) { return ((Number) attrs.get(name)).longValue(); }
+
+    public boolean has(String name) { return attrs.containsKey(name); }
+
+    /**
+     * An expanded child accessor arrives as a nested collection envelope
+     * ({ items, count, hasMore, ... }); unwrap it to its item records.
+     */
+    @SuppressWarnings("unchecked")
+    public List<WorkerRecord> inline(String childAccessor) {
+        Object v = attrs.get(childAccessor);
+        if (v == null) throw new IllegalStateException("child accessor not expanded: " + childAccessor);
+        Map<String, Object> envelope = (Map<String, Object>) v;
+        List<Object> items = (List<Object>) envelope.get("items");
+        List<WorkerRecord> out = new ArrayList<>();
+        for (Object o : items) out.add(new WorkerRecord((Map<String, Object>) o));
+        return out;
+    }
+}
