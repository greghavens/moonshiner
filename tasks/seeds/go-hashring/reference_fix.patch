+// Package ring implements a consistent-hash ring with virtual nodes.
+// Key placement is a pure function of the current membership: the same
+// set of nodes always yields the same placement, and membership changes
+// only move the keys that must move.
+package ring
+
+import (
+	"crypto/sha256"
+	"encoding/binary"
+	"errors"
+	"fmt"
+	"sort"
+)
+
+// Sentinel errors returned by Ring operations.
+var (
+	ErrEmptyRing   = errors.New("ring: no nodes")
+	ErrNodeExists  = errors.New("ring: node already present")
+	ErrUnknownNode = errors.New("ring: node not present")
+)
+
+type point struct {
+	hash uint64
+	node string
+}
+
+// Ring is a consistent-hash ring. Construct with New; the zero value is
+// not usable.
+type Ring struct {
+	vnodes int
+	nodes  map[string]struct{}
+	points []point // sorted by (hash, node)
+}
+
+// New returns an empty ring that places each node at virtualNodes
+// positions. virtualNodes must be at least 1.
+func New(virtualNodes int) (*Ring, error) {
+	if virtualNodes < 1 {
+		return nil, fmt.Errorf("ring: virtual node count must be >= 1, got %d", virtualNodes)
+	}
+	return &Ring{
+		vnodes: virtualNodes,
+		nodes:  make(map[string]struct{}),
+	}, nil
+}
+
+// hash64 returns a deterministic, well-dispersed 64-bit hash of s.
+// SHA-256 is used because weaker string hashes (e.g. plain FNV) cluster
+// badly on the short, near-identical labels rings are built from.
+func hash64(s string) uint64 {
+	sum := sha256.Sum256([]byte(s))
+	return binary.BigEndian.Uint64(sum[:8])
+}
+
+// AddNode places name on the ring. It returns ErrNodeExists if the node
+// is already a member; the ring is unchanged on error.
+func (r *Ring) AddNode(name string) error {
+	if _, ok := r.nodes[name]; ok {
+		return fmt.Errorf("%w: %s", ErrNodeExists, name)
+	}
+	r.nodes[name] = struct{}{}
+	for i := 0; i < r.vnodes; i++ {
+		p := point{hash: hash64(fmt.Sprintf("%s#%d", name, i)), node: name}
+		at := sort.Search(len(r.points), func(j int) bool {
+			if r.points[j].hash != p.hash {
+				return r.points[j].hash > p.hash
+			}
+			return r.points[j].node >= p.node
+		})
+		r.points = append(r.points, point{})
+		copy(r.points[at+1:], r.points[at:])
+		r.points[at] = p
+	}
+	return nil
+}
+
+// RemoveNode removes name from the ring. It returns ErrUnknownNode if the
+// node is not a member; the ring is unchanged on error.
+func (r *Ring) RemoveNode(name string) error {
+	if _, ok := r.nodes[name]; !ok {
+		return fmt.Errorf("%w: %s", ErrUnknownNode, name)
+	}
+	delete(r.nodes, name)
+	kept := r.points[:0]
+	for _, p := range r.points {
+		if p.node != name {
+			kept = append(kept, p)
+		}
+	}
+	r.points = kept
+	return nil
+}
+
+// Get returns the node responsible for key: the first ring point at or
+// clockwise after the key's hash. It returns ErrEmptyRing if the ring has
+// no members.
+func (r *Ring) Get(key string) (string, error) {
+	if len(r.points) == 0 {
+		return "", ErrEmptyRing
+	}
+	h := hash64(key)
+	at := sort.Search(len(r.points), func(j int) bool {
+		return r.points[j].hash >= h
+	})
+	if at == len(r.points) {
+		at = 0 // wrap around
+	}
+	return r.points[at].node, nil
+}
+
+// Nodes returns the current members sorted lexicographically. The
+// returned slice is a fresh copy on every call.
+func (r *Ring) Nodes() []string {
+	out := make([]string, 0, len(r.nodes))
+	for n := range r.nodes {
+		out = append(out, n)
+	}
+	sort.Strings(out)
+	return out
+}
