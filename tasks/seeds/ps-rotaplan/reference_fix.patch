diff --git a/rotaplan.ps1 b/rotaplan.ps1
new file mode 100644
index 0000000..ad9ecce
--- /dev/null
+++ b/rotaplan.ps1
@@ -0,0 +1,85 @@
+# rotaplan.ps1 — age/count log-rotation planner with trustworthy -WhatIf.
+# Usage: pwsh -NoProfile -File rotaplan.ps1 -Path <dir> -Now <iso8601-utc>
+#        [-KeepCount <n>] [-MaxAgeDays <n>] [-WhatIf]
+[CmdletBinding(SupportsShouldProcess)]
+param(
+    [Parameter(Mandatory)][string]$Path,
+    [Parameter(Mandatory)][string]$Now,
+    [ValidateRange(0, [int]::MaxValue)][int]$KeepCount = 3,
+    [ValidateRange(0, [int]::MaxValue)][int]$MaxAgeDays = 30
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+$inv = [System.Globalization.CultureInfo]::InvariantCulture
+$styles = [System.Globalization.DateTimeStyles]::AssumeUniversal -bor [System.Globalization.DateTimeStyles]::AdjustToUniversal
+$nowUtc = [datetime]::MinValue
+if (-not [datetime]::TryParse($Now, $inv, $styles, [ref]$nowUtc)) {
+    [Console]::Error.WriteLine("rotaplan: bad -Now value: $Now")
+    exit 64
+}
+
+if (-not (Test-Path -LiteralPath $Path -PathType Container)) {
+    [Console]::Error.WriteLine("rotaplan: path not found: $Path")
+    exit 66
+}
+
+$candidates = @(Get-ChildItem -LiteralPath $Path -Force -File | Where-Object {
+    $_.Name.EndsWith('.log') -or $_.Name.EndsWith('.log.gz')
+})
+
+$maxAge = [timespan]::FromDays($MaxAgeDays)
+$actionByName = [System.Collections.Generic.Dictionary[string, string]]::new([System.StringComparer]::Ordinal)
+$survivors = [System.Collections.Generic.List[System.IO.FileInfo]]::new()
+foreach ($f in $candidates) {
+    if (($nowUtc - $f.LastWriteTimeUtc) -gt $maxAge) {
+        $actionByName[$f.Name] = 'delete'
+    }
+    elseif ($f.Name.EndsWith('.log.gz')) {
+        $actionByName[$f.Name] = 'keep'
+    }
+    else {
+        $survivors.Add($f)
+    }
+}
+
+# Newest KeepCount survivors stay uncompressed; on equal mtimes the
+# ordinal-earlier name counts as newer. Encode that in one sortable key.
+$poolKeys = [string[]]@(foreach ($f in $survivors) {
+    [string]::Format($inv, '{0:D19}', [datetime]::MaxValue.Ticks - $f.LastWriteTimeUtc.Ticks) + '|' + $f.Name
+})
+[Array]::Sort($poolKeys, [System.StringComparer]::Ordinal)
+for ($i = 0; $i -lt $poolKeys.Length; $i++) {
+    $name = $poolKeys[$i].Substring($poolKeys[$i].IndexOf('|') + 1)
+    $actionByName[$name] = if ($i -lt $KeepCount) { 'keep' } else { 'compress' }
+}
+
+$names = [string[]]@($actionByName.Keys)
+[Array]::Sort($names, [System.StringComparer]::Ordinal)
+foreach ($n in $names) {
+    Write-Output "$($actionByName[$n]) $n"
+}
+
+foreach ($n in $names) {
+    $full = Join-Path $Path $n
+    switch ($actionByName[$n]) {
+        'delete' {
+            if ($PSCmdlet.ShouldProcess($n, 'delete')) {
+                Remove-Item -LiteralPath $full -Force
+            }
+        }
+        'compress' {
+            if ($PSCmdlet.ShouldProcess($n, 'compress')) {
+                $bytes = [System.IO.File]::ReadAllBytes($full)
+                $ms = [System.IO.MemoryStream]::new()
+                $gz = [System.IO.Compression.GZipStream]::new($ms, [System.IO.Compression.CompressionMode]::Compress)
+                $gz.Write($bytes, 0, $bytes.Length)
+                $gz.Dispose()
+                [System.IO.File]::WriteAllBytes("$full.gz", $ms.ToArray())
+                Remove-Item -LiteralPath $full -Force
+            }
+        }
+    }
+}
+exit 0
