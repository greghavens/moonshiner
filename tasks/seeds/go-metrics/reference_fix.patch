+// Package metrics is a small in-process metrics registry: labeled
+// counters and gauges with stable, point-in-time snapshots.
+package metrics
+
+import (
+	"fmt"
+	"sort"
+	"strings"
+	"sync"
+)
+
+// Labels identifies one series of a metric.
+type Labels map[string]string
+
+// Metric kinds reported in snapshots.
+const (
+	KindCounter = "counter"
+	KindGauge   = "gauge"
+)
+
+// Metric is one series at a point in time.
+type Metric struct {
+	Name   string
+	Kind   string
+	Labels Labels
+	Value  float64
+}
+
+type series struct {
+	mu     sync.Mutex
+	name   string
+	kind   string
+	labels Labels // registry-owned copy
+	value  float64
+}
+
+// Registry stores metric series and hands out live handles to them.
+// All methods are safe for concurrent use.
+type Registry struct {
+	mu     sync.Mutex
+	kinds  map[string]string  // metric name -> kind
+	series map[string]*series // name + canonical labels -> series
+}
+
+// NewRegistry returns an empty registry.
+func NewRegistry() *Registry {
+	return &Registry{
+		kinds:  make(map[string]string),
+		series: make(map[string]*series),
+	}
+}
+
+// canonicalLabels renders a label set as sorted k=v pairs, giving every
+// equal label set one identity regardless of map order.
+func canonicalLabels(labels Labels) string {
+	keys := make([]string, 0, len(labels))
+	for k := range labels {
+		keys = append(keys, k)
+	}
+	sort.Strings(keys)
+	parts := make([]string, 0, len(keys))
+	for _, k := range keys {
+		parts = append(parts, k+"="+labels[k])
+	}
+	return strings.Join(parts, ",")
+}
+
+func copyLabels(labels Labels) Labels {
+	out := make(Labels, len(labels))
+	for k, v := range labels {
+		out[k] = v
+	}
+	return out
+}
+
+// getOrCreate returns the series for (name, labels), creating it under
+// the given kind. A name registered under a different kind panics.
+func (r *Registry) getOrCreate(name, kind string, labels Labels) *series {
+	key := name + "\x00" + canonicalLabels(labels)
+	r.mu.Lock()
+	defer r.mu.Unlock()
+	if existing, ok := r.kinds[name]; ok && existing != kind {
+		panic(fmt.Sprintf("metrics: %q already registered as %s, cannot use as %s", name, existing, kind))
+	}
+	if s, ok := r.series[key]; ok {
+		return s
+	}
+	r.kinds[name] = kind
+	s := &series{name: name, kind: kind, labels: copyLabels(labels)}
+	r.series[key] = s
+	return s
+}
+
+// Counter returns the counter series for name+labels, creating it if new.
+type Counter struct{ s *series }
+
+// Gauge returns the gauge series for name+labels, creating it if new.
+type Gauge struct{ s *series }
+
+// Counter gets or creates a counter series.
+func (r *Registry) Counter(name string, labels Labels) *Counter {
+	return &Counter{s: r.getOrCreate(name, KindCounter, labels)}
+}
+
+// Gauge gets or creates a gauge series.
+func (r *Registry) Gauge(name string, labels Labels) *Gauge {
+	return &Gauge{s: r.getOrCreate(name, KindGauge, labels)}
+}
+
+// Inc adds one to the counter.
+func (c *Counter) Inc() { c.Add(1) }
+
+// Add increases the counter by delta. Counters are monotonic:
+// negative deltas are dropped.
+func (c *Counter) Add(delta float64) {
+	if delta < 0 {
+		return
+	}
+	c.s.mu.Lock()
+	c.s.value += delta
+	c.s.mu.Unlock()
+}
+
+// Set overwrites the gauge's value.
+func (g *Gauge) Set(v float64) {
+	g.s.mu.Lock()
+	g.s.value = v
+	g.s.mu.Unlock()
+}
+
+// Add moves the gauge by delta, which may be negative.
+func (g *Gauge) Add(delta float64) {
+	g.s.mu.Lock()
+	g.s.value += delta
+	g.s.mu.Unlock()
+}
+
+// Snapshot returns a point-in-time copy of every series, sorted by name
+// and then by canonical labels. The result shares no state with the
+// registry: later updates or caller mutations cannot cross over.
+func (r *Registry) Snapshot() []Metric {
+	r.mu.Lock()
+	all := make([]*series, 0, len(r.series))
+	for _, s := range r.series {
+		all = append(all, s)
+	}
+	r.mu.Unlock()
+
+	out := make([]Metric, 0, len(all))
+	for _, s := range all {
+		s.mu.Lock()
+		out = append(out, Metric{
+			Name:   s.name,
+			Kind:   s.kind,
+			Labels: copyLabels(s.labels),
+			Value:  s.value,
+		})
+		s.mu.Unlock()
+	}
+	sort.Slice(out, func(i, j int) bool {
+		if out[i].Name != out[j].Name {
+			return out[i].Name < out[j].Name
+		}
+		return canonicalLabels(out[i].Labels) < canonicalLabels(out[j].Labels)
+	})
+	return out
+}
