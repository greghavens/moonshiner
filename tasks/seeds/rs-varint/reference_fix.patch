+//! LEB128 varint + zigzag codec for the metrics wire format.
+//!
+//! Unsigned values are base-128 varints: 7 payload bits per byte, least
+//! significant group first, high bit set on every byte except the last.
+//! A `u64` needs at most 10 bytes; in the 10th byte only the lowest payload
+//! bit may be used. Signed values are zigzag-mapped to `u64` first so small
+//! negatives stay small on the wire.
+//!
+//! Decoding is strict: truncated, overlong (non-canonical), and overflowing
+//! varints are rejected with the byte offset of the varint's first byte.
+
+use std::fmt;
+
+/// Why a varint could not be decoded. `start` is the absolute byte offset of
+/// the first byte of the offending varint.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum DecodeError {
+    /// The input ended in the middle of a varint.
+    Truncated { start: usize },
+    /// The varint is longer than one byte and its final byte is zero —
+    /// dead padding, i.e. a non-canonical encoding.
+    Overlong { start: usize },
+    /// The value does not fit in a `u64` (an 11th byte was required, or the
+    /// 10th byte used payload bits above the lowest).
+    Overflow { start: usize },
+}
+
+impl fmt::Display for DecodeError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            DecodeError::Truncated { start } => {
+                write!(f, "truncated varint starting at byte {start}")
+            }
+            DecodeError::Overlong { start } => {
+                write!(f, "overlong varint encoding starting at byte {start}")
+            }
+            DecodeError::Overflow { start } => {
+                write!(f, "varint overflows u64 starting at byte {start}")
+            }
+        }
+    }
+}
+
+impl std::error::Error for DecodeError {}
+
+/// Map a signed value onto the unsigned line: 0→0, -1→1, 1→2, -2→3, ...
+pub fn zigzag_encode(value: i64) -> u64 {
+    ((value << 1) ^ (value >> 63)) as u64
+}
+
+/// Inverse of [`zigzag_encode`].
+pub fn zigzag_decode(value: u64) -> i64 {
+    ((value >> 1) as i64) ^ -((value & 1) as i64)
+}
+
+/// Append the LEB128 encoding of `value` to `out`.
+pub fn encode_u64(mut value: u64, out: &mut Vec<u8>) {
+    loop {
+        let byte = (value & 0x7F) as u8;
+        value >>= 7;
+        if value == 0 {
+            out.push(byte);
+            return;
+        }
+        out.push(byte | 0x80);
+    }
+}
+
+/// Zigzag-map `value` and append its LEB128 encoding to `out`.
+pub fn encode_i64(value: i64, out: &mut Vec<u8>) {
+    encode_u64(zigzag_encode(value), out);
+}
+
+/// Decode one varint starting at `start`. `Ok(None)` when `start` is exactly
+/// the end of the buffer; otherwise the value and the offset just past it.
+fn decode_at(buf: &[u8], start: usize) -> Result<Option<(u64, usize)>, DecodeError> {
+    if start >= buf.len() {
+        return Ok(None);
+    }
+    let mut value: u64 = 0;
+    let mut pos = start;
+    loop {
+        if pos >= buf.len() {
+            return Err(DecodeError::Truncated { start });
+        }
+        let byte = buf[pos];
+        let index = pos - start; // 0-based byte index within this varint
+        if index == 9 && (byte & 0x80 != 0 || byte > 0x01) {
+            return Err(DecodeError::Overflow { start });
+        }
+        value |= u64::from(byte & 0x7F) << (7 * index);
+        pos += 1;
+        if byte & 0x80 == 0 {
+            if index > 0 && byte == 0x00 {
+                return Err(DecodeError::Overlong { start });
+            }
+            return Ok(Some((value, pos)));
+        }
+    }
+}
+
+/// Streaming decoder over a byte slice. Errors are non-consuming: the
+/// position stays parked at the start of the bad varint.
+pub struct Decoder<'a> {
+    buf: &'a [u8],
+    pos: usize,
+}
+
+impl<'a> Decoder<'a> {
+    pub fn new(buf: &'a [u8]) -> Decoder<'a> {
+        Decoder { buf, pos: 0 }
+    }
+
+    /// Absolute byte offset of the next varint.
+    pub fn position(&self) -> usize {
+        self.pos
+    }
+
+    /// Bytes left in the buffer.
+    pub fn remaining(&self) -> usize {
+        self.buf.len() - self.pos
+    }
+
+    /// Decode the next unsigned value; `Ok(None)` at a clean end of input.
+    pub fn decode_u64(&mut self) -> Result<Option<u64>, DecodeError> {
+        match decode_at(self.buf, self.pos)? {
+            None => Ok(None),
+            Some((value, next)) => {
+                self.pos = next;
+                Ok(Some(value))
+            }
+        }
+    }
+
+    /// Decode the next zigzag-encoded signed value.
+    pub fn decode_i64(&mut self) -> Result<Option<i64>, DecodeError> {
+        Ok(self.decode_u64()?.map(zigzag_decode))
+    }
+}
+
+/// Decode a whole stream of unsigned varints; the first error wins.
+pub fn decode_all_u64(buf: &[u8]) -> Result<Vec<u64>, DecodeError> {
+    let mut decoder = Decoder::new(buf);
+    let mut values = Vec::new();
+    while let Some(value) = decoder.decode_u64()? {
+        values.push(value);
+    }
+    Ok(values)
+}
+
+/// Decode a whole stream of zigzag-encoded signed varints.
+pub fn decode_all_i64(buf: &[u8]) -> Result<Vec<i64>, DecodeError> {
+    Ok(decode_all_u64(buf)?.into_iter().map(zigzag_decode).collect())
+}
