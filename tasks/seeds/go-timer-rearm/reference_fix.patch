diff --git a/deadline.go b/deadline.go
index 67430a3..d83fe05 100644
--- a/deadline.go
+++ b/deadline.go
@@ -45,13 +45,24 @@ func New(t Timer) *Watchdog {
 // previous deadline is discarded: only the new job may be reported.
 func (w *Watchdog) Arm(label string, d time.Duration) {
 	if w.armed {
-		w.timer.Stop()
+		w.disarm()
 	}
 	w.timer.Reset(d)
 	w.label = label
 	w.armed = true
 }
 
+// disarm stops the timer and, when the deadline already fired, drains
+// the queued tick so it cannot be attributed to a later job.
+func (w *Watchdog) disarm() {
+	if !w.timer.Stop() {
+		select {
+		case <-w.timer.C():
+		default:
+		}
+	}
+}
+
 // Cancel disarms the watchdog when its job finishes in time. A
 // cancelled job's deadline must never surface, not even after a later
 // re-arm.
@@ -59,7 +70,7 @@ func (w *Watchdog) Cancel() {
 	if !w.armed {
 		return
 	}
-	w.timer.Stop()
+	w.disarm()
 	w.armed = false
 	w.label = ""
 }
