diff --git a/dynarray.c b/dynarray.c
new file mode 100644
index 0000000..9254c40
--- /dev/null
+++ b/dynarray.c
@@ -0,0 +1,83 @@
+#include "dynarray.h"
+
+#include <stdlib.h>
+#include <string.h>
+
+int da_init(dynarray *da, size_t elem_size) {
+    if (elem_size == 0)
+        return -1;
+    da->data = NULL;
+    da->len = 0;
+    da->cap = 0;
+    da->elem_size = elem_size;
+    return 0;
+}
+
+void da_free(dynarray *da) {
+    free(da->data);
+    da->data = NULL;
+    da->len = 0;
+    da->cap = 0;
+}
+
+/* Ensure room for `need` elements: 0 -> 8, then double. */
+static int da_grow(dynarray *da, size_t need) {
+    if (need <= da->cap)
+        return 0;
+    size_t ncap = da->cap ? da->cap * 2 : 8;
+    while (ncap < need)
+        ncap *= 2;
+    void *nd = realloc(da->data, ncap * da->elem_size);
+    if (nd == NULL)
+        return -1;
+    da->data = nd;
+    da->cap = ncap;
+    return 0;
+}
+
+static char *slot(const dynarray *da, size_t idx) {
+    return (char *)da->data + idx * da->elem_size;
+}
+
+int da_push(dynarray *da, const void *elem) {
+    if (da_grow(da, da->len + 1) != 0)
+        return -1;
+    memcpy(slot(da, da->len), elem, da->elem_size);
+    da->len++;
+    return 0;
+}
+
+int da_pop(dynarray *da, void *out) {
+    if (da->len == 0)
+        return -1;
+    da->len--;
+    if (out != NULL)
+        memcpy(out, slot(da, da->len), da->elem_size);
+    return 0;
+}
+
+int da_insert(dynarray *da, size_t idx, const void *elem) {
+    if (idx > da->len)
+        return -1;
+    if (da_grow(da, da->len + 1) != 0)
+        return -1;
+    memmove(slot(da, idx + 1), slot(da, idx),
+            (da->len - idx) * da->elem_size);
+    memcpy(slot(da, idx), elem, da->elem_size);
+    da->len++;
+    return 0;
+}
+
+void *da_get(const dynarray *da, size_t idx) {
+    if (idx >= da->len)
+        return NULL;
+    return slot(da, idx);
+}
+
+size_t da_len(const dynarray *da) {
+    return da->len;
+}
+
+size_t da_cap(const dynarray *da) {
+    return da->cap;
+}
diff --git a/dynarray.h b/dynarray.h
new file mode 100644
index 0000000..dc50a77
--- /dev/null
+++ b/dynarray.h
@@ -0,0 +1,40 @@
+/* dynarray.h — generic growable array (void* + element size). */
+#ifndef DYNARRAY_H
+#define DYNARRAY_H
+
+#include <stddef.h>
+
+typedef struct {
+    void  *data;
+    size_t len;       /* elements in use */
+    size_t cap;       /* elements allocated */
+    size_t elem_size;
+} dynarray;
+
+/* 0 on success; -1 if elem_size == 0. No allocation happens here. */
+int da_init(dynarray *da, size_t elem_size);
+
+/* Release the buffer. len/cap return to 0; safe to call twice; the
+ * struct is reusable after another da_init. Stored elements are copied
+ * values — anything they point at belongs to the caller. */
+void da_free(dynarray *da);
+
+/* Copy one element onto the end. 0 ok; -1 on allocation failure. */
+int da_push(dynarray *da, const void *elem);
+
+/* Copy the last element into out (or discard if out is NULL) and drop
+ * it. 0 ok; -1 if the array is empty. Never reallocates. */
+int da_pop(dynarray *da, void *out);
+
+/* Copy one element in at idx, shifting idx.. one slot right.
+ * idx == len appends. -1 if idx > len or allocation fails. */
+int da_insert(dynarray *da, size_t idx, const void *elem);
+
+/* Pointer to element idx, or NULL if idx >= len. Growth (push/insert)
+ * may realloc and invalidates previously returned pointers. */
+void *da_get(const dynarray *da, size_t idx);
+
+size_t da_len(const dynarray *da);
+size_t da_cap(const dynarray *da);
+
+#endif /* DYNARRAY_H */
