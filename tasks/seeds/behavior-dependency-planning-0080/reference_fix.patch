diff --git a/reference_run.sh b/reference_run.sh
new file mode 100755
--- /dev/null
+++ b/reference_run.sh
@@ -0,0 +1,41 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+rm -f audit.md fleet_journal.jsonl
+
+./fleetctl --help >/dev/null
+
+search_result="$(
+  ./fleetctl search \
+    --pair 'Electric Sedan 9' 'Central Motor Pool' \
+    --pair 'Utility Pickup 14' 'North Motor Pool'
+)"
+
+mapfile -t resolved_ids < <(
+  python3 -c 'import json, sys
+for branch in json.load(sys.stdin):
+    matches = branch["matches"]
+    if len(matches) == 1:
+        print(matches[0]["id"])' <<<"$search_result"
+)
+
+if [[ ${#resolved_ids[@]} -ne 2 ]]; then
+  echo 'reference state did not resolve both branches uniquely' >&2
+  exit 1
+fi
+
+get_result="$(
+  ./fleetctl get \
+    --id "${resolved_ids[0]}" \
+    --id "${resolved_ids[1]}"
+)"
+
+python3 -c 'import json, sys
+from pathlib import Path
+records = json.load(sys.stdin)
+headings = ("First record", "Second record")
+blocks = []
+for heading, record in zip(headings, records):
+    blocks.append("## {heading}\nID: {id}\nName: {name}\nLocation: {location}\nStatus: {status}".format(heading=heading, id=record["id"], name=record["name"], location=record["location"], status=record["status"]))
+comparison = "The statuses differ: {first_name} is {first_status}, while {second_name} is {second_status}.".format(first_name=records[0]["name"], first_status=records[0]["status"], second_name=records[1]["name"], second_status=records[1]["status"])
+Path("audit.md").write_text("\n\n".join((*blocks, comparison)) + "\n", encoding="utf-8")' <<<"$get_result"
