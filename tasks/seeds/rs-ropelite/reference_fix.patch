+//! Rope-lite text buffer for the collab-editor backend.
+//!
+//! The public API speaks CHAR indices (Unicode scalar values) exclusively;
+//! byte offsets exist only as an internal conversion, always derived from
+//! char-boundary walks. Text is stored as an ordered list of small chunks so
+//! middle edits stay cheap-ish; the structural invariant is that every chunk
+//! holds `1..=capacity` chars and the chunks concatenate to the content.
+
+use std::fmt;
+
+/// Default chunk capacity, in chars.
+pub const DEFAULT_CHUNK_CAPACITY: usize = 32;
+
+/// Why an edit was refused. All indices are char indices.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum EditError {
+    /// `insert` past the end of the buffer.
+    IndexOutOfBounds { index: usize, len: usize },
+    /// A range whose end exceeds the buffer length.
+    RangeOutOfBounds { start: usize, end: usize, len: usize },
+    /// A range with `start > end` (checked before bounds).
+    InvalidRange { start: usize, end: usize },
+}
+
+impl fmt::Display for EditError {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            EditError::IndexOutOfBounds { index, len } => {
+                write!(f, "char index {index} out of bounds (len {len})")
+            }
+            EditError::RangeOutOfBounds { start, end, len } => {
+                write!(f, "char range {start}..{end} out of bounds (len {len})")
+            }
+            EditError::InvalidRange { start, end } => {
+                write!(f, "invalid char range {start}..{end}")
+            }
+        }
+    }
+}
+
+impl std::error::Error for EditError {}
+
+#[derive(Debug, Clone)]
+struct Chunk {
+    text: String,
+    /// Cached `text.chars().count()`.
+    chars: usize,
+}
+
+/// Byte offset of the `char_offset`-th char of `text` (or `text.len()` when
+/// `char_offset` equals the char count). Never lands off a char boundary.
+fn byte_at(text: &str, char_offset: usize) -> usize {
+    match text.char_indices().nth(char_offset) {
+        Some((byte, _)) => byte,
+        None => text.len(),
+    }
+}
+
+/// Cut `text` into chunks of at most `cap` chars, none empty.
+fn split_text(text: &str, cap: usize) -> Vec<Chunk> {
+    let mut out = Vec::new();
+    let mut start = 0;
+    let mut count = 0;
+    for (byte, _) in text.char_indices() {
+        if count == cap {
+            out.push(Chunk {
+                text: text[start..byte].to_string(),
+                chars: cap,
+            });
+            start = byte;
+            count = 0;
+        }
+        count += 1;
+    }
+    if start < text.len() {
+        out.push(Chunk {
+            text: text[start..].to_string(),
+            chars: count,
+        });
+    }
+    out
+}
+
+/// A chunked text buffer addressed by char index.
+#[derive(Debug, Clone)]
+pub struct TextBuffer {
+    chunks: Vec<Chunk>,
+    capacity: usize,
+    total_chars: usize,
+}
+
+impl Default for TextBuffer {
+    fn default() -> TextBuffer {
+        TextBuffer::new()
+    }
+}
+
+impl fmt::Display for TextBuffer {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        for chunk in &self.chunks {
+            f.write_str(&chunk.text)?;
+        }
+        Ok(())
+    }
+}
+
+impl TextBuffer {
+    /// Empty buffer with [`DEFAULT_CHUNK_CAPACITY`].
+    pub fn new() -> TextBuffer {
+        TextBuffer::with_chunk_capacity(DEFAULT_CHUNK_CAPACITY)
+    }
+
+    /// Empty buffer with a custom capacity. Panics when `cap == 0`.
+    pub fn with_chunk_capacity(cap: usize) -> TextBuffer {
+        assert!(cap >= 1, "chunk capacity must be at least 1");
+        TextBuffer {
+            chunks: Vec::new(),
+            capacity: cap,
+            total_chars: 0,
+        }
+    }
+
+    /// Buffer initialized with `text`, default capacity.
+    pub fn from_text(text: &str) -> TextBuffer {
+        let mut buf = TextBuffer::new();
+        let chunks = split_text(text, buf.capacity);
+        buf.total_chars = chunks.iter().map(|c| c.chars).sum();
+        buf.chunks = chunks;
+        buf
+    }
+
+    /// Content length in chars.
+    pub fn char_len(&self) -> usize {
+        self.total_chars
+    }
+
+    pub fn is_empty(&self) -> bool {
+        self.total_chars == 0
+    }
+
+    /// The configured per-chunk char capacity.
+    pub fn chunk_capacity(&self) -> usize {
+        self.capacity
+    }
+
+    pub fn chunk_count(&self) -> usize {
+        self.chunks.len()
+    }
+
+    /// The chunks in order; they concatenate to the content.
+    pub fn chunks(&self) -> impl Iterator<Item = &str> + '_ {
+        self.chunks.iter().map(|c| c.text.as_str())
+    }
+
+    fn check_range(&self, start: usize, end: usize) -> Result<(), EditError> {
+        if start > end {
+            return Err(EditError::InvalidRange { start, end });
+        }
+        if end > self.total_chars {
+            return Err(EditError::RangeOutOfBounds {
+                start,
+                end,
+                len: self.total_chars,
+            });
+        }
+        Ok(())
+    }
+
+    /// Insert `text` before char index `at` (`at == char_len()` appends).
+    pub fn insert(&mut self, at: usize, text: &str) -> Result<(), EditError> {
+        if at > self.total_chars {
+            return Err(EditError::IndexOutOfBounds {
+                index: at,
+                len: self.total_chars,
+            });
+        }
+        if text.is_empty() {
+            return Ok(());
+        }
+        let added = text.chars().count();
+
+        if self.chunks.is_empty() {
+            self.chunks = split_text(text, self.capacity);
+            self.total_chars = added;
+            return Ok(());
+        }
+
+        // find the chunk containing the insertion point (an exact boundary
+        // lands at the end of the earlier chunk)
+        let mut acc = 0;
+        let mut index = self.chunks.len() - 1;
+        for (i, chunk) in self.chunks.iter().enumerate() {
+            if at <= acc + chunk.chars {
+                index = i;
+                break;
+            }
+            acc += chunk.chars;
+        }
+        let chunk = &mut self.chunks[index];
+        let byte = byte_at(&chunk.text, at - acc);
+        chunk.text.insert_str(byte, text);
+        chunk.chars += added;
+        self.total_chars += added;
+
+        if chunk.chars > self.capacity {
+            let overgrown = std::mem::take(&mut chunk.text);
+            let pieces = split_text(&overgrown, self.capacity);
+            self.chunks.splice(index..index + 1, pieces);
+        }
+        Ok(())
+    }
+
+    /// Remove the char range `[start, end)`.
+    pub fn delete(&mut self, start: usize, end: usize) -> Result<(), EditError> {
+        self.check_range(start, end)?;
+        if start == end {
+            return Ok(());
+        }
+        let mut acc = 0;
+        for chunk in &mut self.chunks {
+            let chunk_start = acc;
+            let chunk_end = acc + chunk.chars;
+            acc = chunk_end;
+            if chunk_end <= start {
+                continue;
+            }
+            if chunk_start >= end {
+                break;
+            }
+            let local_start = start.max(chunk_start) - chunk_start;
+            let local_end = end.min(chunk_end) - chunk_start;
+            let byte_start = byte_at(&chunk.text, local_start);
+            let byte_end = byte_at(&chunk.text, local_end);
+            chunk.text.replace_range(byte_start..byte_end, "");
+            chunk.chars -= local_end - local_start;
+        }
+        self.chunks.retain(|c| c.chars > 0);
+        self.total_chars -= end - start;
+        Ok(())
+    }
+
+    /// Copy out the char range `[start, end)`.
+    pub fn slice(&self, start: usize, end: usize) -> Result<String, EditError> {
+        self.check_range(start, end)?;
+        let mut out = String::new();
+        let mut acc = 0;
+        for chunk in &self.chunks {
+            let chunk_start = acc;
+            let chunk_end = acc + chunk.chars;
+            acc = chunk_end;
+            if chunk_end <= start {
+                continue;
+            }
+            if chunk_start >= end {
+                break;
+            }
+            let local_start = start.max(chunk_start) - chunk_start;
+            let local_end = end.min(chunk_end) - chunk_start;
+            let byte_start = byte_at(&chunk.text, local_start);
+            let byte_end = byte_at(&chunk.text, local_end);
+            out.push_str(&chunk.text[byte_start..byte_end]);
+        }
+        Ok(out)
+    }
+}
