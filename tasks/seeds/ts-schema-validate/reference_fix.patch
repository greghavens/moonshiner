@@ -0,0 +1,212 @@
+export interface Issue {
+  path: string;
+  message: string;
+}
+
+export type Result<T> = { ok: true; value: T } | { ok: false; errors: Issue[] };
+
+export interface Schema<T = unknown> {
+  validate(value: unknown): Result<T>;
+  check(value: unknown, path: string, errors: Issue[]): void;
+}
+
+function actualType(value: unknown): string {
+  if (value === null) return 'null';
+  if (Array.isArray(value)) return 'array';
+  return typeof value;
+}
+
+function fieldPath(parent: string, key: string): string {
+  return parent === '' ? key : `${parent}.${key}`;
+}
+
+class BaseSchema<T> implements Schema<T> {
+  validate(value: unknown): Result<T> {
+    const errors: Issue[] = [];
+    this.check(value, '', errors);
+    if (errors.length > 0) return { ok: false, errors };
+    return { ok: true, value: value as T };
+  }
+
+  check(_value: unknown, _path: string, _errors: Issue[]): void {
+    throw new Error('not implemented');
+  }
+}
+
+class StringSchema extends BaseSchema<string> {
+  private checks: Array<(value: string, path: string, errors: Issue[]) => void> = [];
+
+  min(n: number): this {
+    this.checks.push((v, path, errors) => {
+      if (v.length < n) errors.push({ path, message: `must have at least ${n} characters` });
+    });
+    return this;
+  }
+
+  max(n: number): this {
+    this.checks.push((v, path, errors) => {
+      if (v.length > n) errors.push({ path, message: `must have at most ${n} characters` });
+    });
+    return this;
+  }
+
+  pattern(re: RegExp): this {
+    this.checks.push((v, path, errors) => {
+      if (!re.test(v)) errors.push({ path, message: 'does not match pattern' });
+    });
+    return this;
+  }
+
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (typeof value !== 'string') {
+      errors.push({ path, message: `expected string, got ${actualType(value)}` });
+      return;
+    }
+    for (const run of this.checks) run(value, path, errors);
+  }
+}
+
+class NumberSchema extends BaseSchema<number> {
+  private checks: Array<(value: number, path: string, errors: Issue[]) => void> = [];
+
+  min(n: number): this {
+    this.checks.push((v, path, errors) => {
+      if (v < n) errors.push({ path, message: `must be >= ${n}` });
+    });
+    return this;
+  }
+
+  max(n: number): this {
+    this.checks.push((v, path, errors) => {
+      if (v > n) errors.push({ path, message: `must be <= ${n}` });
+    });
+    return this;
+  }
+
+  int(): this {
+    this.checks.push((v, path, errors) => {
+      if (!Number.isInteger(v)) errors.push({ path, message: 'must be an integer' });
+    });
+    return this;
+  }
+
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (typeof value !== 'number') {
+      errors.push({ path, message: `expected number, got ${actualType(value)}` });
+      return;
+    }
+    for (const run of this.checks) run(value, path, errors);
+  }
+}
+
+class BooleanSchema extends BaseSchema<boolean> {
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (typeof value !== 'boolean') {
+      errors.push({ path, message: `expected boolean, got ${actualType(value)}` });
+    }
+  }
+}
+
+class OptionalSchema<T> extends BaseSchema<T | undefined> {
+  readonly isOptional = true;
+  inner: Schema<T>;
+
+  constructor(inner: Schema<T>) {
+    super();
+    this.inner = inner;
+  }
+
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (value === undefined) return;
+    this.inner.check(value, path, errors);
+  }
+}
+
+function isOptionalSchema(schema: Schema): schema is OptionalSchema<unknown> {
+  return (schema as { isOptional?: boolean }).isOptional === true;
+}
+
+class ObjectSchema<T> extends BaseSchema<T> {
+  private shape: Record<string, Schema>;
+  private allowUnknown = false;
+
+  constructor(shape: Record<string, Schema>) {
+    super();
+    this.shape = shape;
+  }
+
+  passthrough(): this {
+    this.allowUnknown = true;
+    return this;
+  }
+
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (actualType(value) !== 'object') {
+      errors.push({ path, message: `expected object, got ${actualType(value)}` });
+      return;
+    }
+    const record = value as Record<string, unknown>;
+
+    for (const [key, schema] of Object.entries(this.shape)) {
+      const childPath = fieldPath(path, key);
+      const present = Object.prototype.hasOwnProperty.call(record, key)
+        && record[key] !== undefined;
+      if (!present) {
+        if (!isOptionalSchema(schema)) errors.push({ path: childPath, message: 'is required' });
+        continue;
+      }
+      schema.check(record[key], childPath, errors);
+    }
+
+    if (!this.allowUnknown) {
+      for (const key of Object.keys(record)) {
+        if (!Object.prototype.hasOwnProperty.call(this.shape, key)) {
+          errors.push({ path: fieldPath(path, key), message: 'unexpected key' });
+        }
+      }
+    }
+  }
+}
+
+class ArraySchema<T> extends BaseSchema<T[]> {
+  private item: Schema<T>;
+
+  constructor(item: Schema<T>) {
+    super();
+    this.item = item;
+  }
+
+  check(value: unknown, path: string, errors: Issue[]): void {
+    if (!Array.isArray(value)) {
+      errors.push({ path, message: `expected array, got ${actualType(value)}` });
+      return;
+    }
+    value.forEach((element, index) => {
+      this.item.check(element, `${path}[${index}]`, errors);
+    });
+  }
+}
+
+export function string(): StringSchema {
+  return new StringSchema();
+}
+
+export function number(): NumberSchema {
+  return new NumberSchema();
+}
+
+export function boolean(): BooleanSchema {
+  return new BooleanSchema();
+}
+
+export function object<T = Record<string, unknown>>(shape: Record<string, Schema>): ObjectSchema<T> {
+  return new ObjectSchema<T>(shape);
+}
+
+export function array<T>(item: Schema<T>): ArraySchema<T> {
+  return new ArraySchema<T>(item);
+}
+
+export function optional<T>(inner: Schema<T>): OptionalSchema<T> {
+  return new OptionalSchema<T>(inner);
+}
