@@ -0,0 +1,62 @@
+"""One retry decorator to replace all the copy-pasted loops."""
+import functools
+import time
+
+
+def fixed(delay):
+    """Constant backoff: every retry waits `delay` seconds."""
+    if delay < 0:
+        raise ValueError(f"delay must be >= 0, got {delay}")
+
+    def policy(retry_index):
+        return delay
+
+    return policy
+
+
+def exponential(initial, multiplier=2.0, max_delay=None):
+    """Exponential backoff: initial * multiplier**(i-1), optionally capped."""
+    if initial <= 0:
+        raise ValueError(f"initial delay must be > 0, got {initial}")
+    if multiplier < 1:
+        raise ValueError(f"multiplier must be >= 1, got {multiplier}")
+
+    def policy(retry_index):
+        delay = initial * multiplier ** (retry_index - 1)
+        if max_delay is not None and delay > max_delay:
+            return max_delay
+        return delay
+
+    return policy
+
+
+def retry(attempts, backoff, retry_on=(Exception,), give_up_on=(),
+          sleep=time.sleep, on_retry=None):
+    """Decorator factory: retry the wrapped callable on matching exceptions.
+
+    `attempts` counts total calls. The last exception is re-raised as-is;
+    `give_up_on` beats `retry_on` when both match.
+    """
+    if attempts < 1:
+        raise ValueError(f"attempts must be >= 1, got {attempts}")
+
+    def decorator(func):
+        @functools.wraps(func)
+        def wrapper(*args, **kwargs):
+            for attempt in range(1, attempts + 1):
+                try:
+                    return func(*args, **kwargs)
+                except give_up_on:
+                    raise
+                except retry_on as exc:
+                    if attempt == attempts:
+                        raise
+                    delay = backoff(attempt)
+                    if on_retry is not None:
+                        on_retry(exc, attempt, delay)
+                    sleep(delay)
+            raise AssertionError("unreachable")  # loop always returns or raises
+
+        return wrapper
+
+    return decorator
