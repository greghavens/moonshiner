+namespace GheAudit;
+
+/// <summary>Checkpointed audit-log export: resumes from the stored after
+/// cursor and advances the checkpoint only once a complete page set has been
+/// delivered.</summary>
+public sealed class AuditExporter
+{
+    private readonly AuditLogClient _client;
+    private readonly ICheckpointStore _store;
+
+    public AuditExporter(AuditLogClient client, ICheckpointStore store)
+    {
+        _client = client;
+        _store = store;
+    }
+
+    public async Task<ExportResult> RunAsync(AuditQuery query, CancellationToken ct = default)
+    {
+        string? after = query.After ?? await _store.LoadAsync(ct);
+        string? url = _client.BuildInitialUrl(query with { After = after });
+
+        var events = new List<AuditEvent>();
+        string? checkpoint = null;
+        try
+        {
+            while (url is not null)
+            {
+                ct.ThrowIfCancellationRequested();
+                var page = await _client.GetPageAsync(url, ct);
+                events.AddRange(page.Events);
+                if (page.NextAfter is not null)
+                    checkpoint = page.NextAfter;
+                url = page.NextUrl;
+            }
+        }
+        catch (AuditApiException ex) when (ex.Status >= 500)
+        {
+            // Incomplete page set: hand back what arrived, advance nothing.
+            return new ExportResult(events, false, null, ex);
+        }
+
+        if (events.Count > 0 && checkpoint is not null)
+            await _store.SaveAsync(checkpoint, ct);
+        return new ExportResult(events, true, checkpoint ?? after, null);
+    }
+}
