+using System.Text.Json.Serialization;
+
+namespace GheAudit;
+
+/// <summary>One enterprise audit-log query. Defaults match the exporter's
+/// checkpointing policy: full pages, ascending order.</summary>
+public sealed record AuditQuery
+{
+    public IReadOnlyList<string> Phrase { get; init; } = Array.Empty<string>();
+    public string Include { get; init; } = "web";
+    public string Order { get; init; } = "asc";
+    public int PerPage { get; init; } = 100;
+    public string? After { get; init; }
+}
+
+/// <summary>A decoded audit-log event. Timestamps are UTC epoch milliseconds
+/// as documented; unknown fields are ignored.</summary>
+public sealed record AuditEvent
+{
+    [JsonPropertyName("_document_id")]
+    public string DocumentId { get; init; } = "";
+
+    [JsonPropertyName("action")]
+    public string Action { get; init; } = "";
+
+    [JsonPropertyName("actor")]
+    public string? Actor { get; init; }
+
+    [JsonPropertyName("org")]
+    public string? Org { get; init; }
+
+    [JsonPropertyName("@timestamp")]
+    public long TimestampMs { get; init; }
+
+    [JsonPropertyName("created_at")]
+    public long CreatedAtMs { get; init; }
+}
+
+/// <summary>One page of the audit log plus its continuation.</summary>
+public sealed record AuditPage(
+    IReadOnlyList<AuditEvent> Events, string? NextUrl, string? NextAfter);
+
+/// <summary>Result of one exporter run. Checkpoint is only non-null when the
+/// scan position is known; it is persisted only on a complete page set.</summary>
+public sealed record ExportResult(
+    IReadOnlyList<AuditEvent> Events, bool Complete, string? Checkpoint, Exception? Error);
+
+/// <summary>Durable storage for the after-cursor checkpoint.</summary>
+public interface ICheckpointStore
+{
+    Task<string?> LoadAsync(CancellationToken ct);
+    Task SaveAsync(string cursor, CancellationToken ct);
+}
+
+/// <summary>A non-2xx audit-log response, carrying GitHub's message field.
+/// Never contains credential material.</summary>
+public sealed class AuditApiException : Exception
+{
+    public int Status { get; }
+
+    public AuditApiException(int status, string apiMessage)
+        : base($"github audit-log api error {status}: {apiMessage}")
+    {
+        Status = status;
+    }
+}
+
+/// <summary>Raised when the endpoint stays rate-limited after the single
+/// documented pause-and-retry.</summary>
+public sealed class AuditRateLimitException : Exception
+{
+    public TimeSpan RetryAfter { get; }
+
+    public AuditRateLimitException(TimeSpan retryAfter)
+        : base($"audit-log rate limit persisted; server asked to retry after {retryAfter.TotalSeconds:0}s")
+    {
+        RetryAfter = retryAfter;
+    }
+}
+
+/// <summary>Raised when a pagination link points off the configured origin;
+/// the bearer token is never forwarded to such a host.</summary>
+public sealed class AuditSecurityException : Exception
+{
+    public AuditSecurityException(string host)
+        : base($"refusing to follow audit-log pagination link to untrusted host {host}")
+    {
+    }
+}
