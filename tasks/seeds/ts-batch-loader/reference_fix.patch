+export type BatchFn<K, V> = (keys: K[]) => Promise<Array<V | Error>>;
+
+export interface BatchLoaderOptions {
+  /** Dispatch as soon as this many distinct keys are pending. */
+  maxBatchSize?: number;
+  /** Decides when a batching window closes. Defaults to queueMicrotask. */
+  schedule?: (flush: () => void) => void;
+}
+
+interface Waiter<V> {
+  promise: Promise<V>;
+  resolve: (v: V) => void;
+  reject: (e: unknown) => void;
+}
+
+interface Batch<K, V> {
+  entries: Map<K, Waiter<V>>;
+  dispatched: boolean;
+}
+
+export class BatchLoader<K, V> {
+  private batchFn: BatchFn<K, V>;
+  private maxBatchSize: number;
+  private schedule: (flush: () => void) => void;
+  private current: Batch<K, V> | null = null;
+
+  constructor(batchFn: BatchFn<K, V>, opts: BatchLoaderOptions = {}) {
+    const { maxBatchSize = Infinity, schedule = (flush) => queueMicrotask(flush) } = opts;
+    if (maxBatchSize !== Infinity && (!Number.isInteger(maxBatchSize) || maxBatchSize < 1)) {
+      throw new TypeError(`maxBatchSize must be a positive integer, got ${maxBatchSize}`);
+    }
+    this.batchFn = batchFn;
+    this.maxBatchSize = maxBatchSize;
+    this.schedule = schedule;
+  }
+
+  load(key: K): Promise<V> {
+    if (!this.current) {
+      const batch: Batch<K, V> = { entries: new Map(), dispatched: false };
+      this.current = batch;
+      this.schedule(() => this.dispatch(batch));
+    }
+    const batch = this.current;
+    let waiter = batch.entries.get(key);
+    if (!waiter) {
+      let resolve!: (v: V) => void;
+      let reject!: (e: unknown) => void;
+      const promise = new Promise<V>((res, rej) => {
+        resolve = res;
+        reject = rej;
+      });
+      waiter = { promise, resolve, reject };
+      batch.entries.set(key, waiter);
+      if (batch.entries.size >= this.maxBatchSize) {
+        this.dispatch(batch); // ship the full batch without waiting
+      }
+    }
+    return waiter.promise;
+  }
+
+  private dispatch(batch: Batch<K, V>): void {
+    if (batch.dispatched || batch.entries.size === 0) return;
+    batch.dispatched = true;
+    if (this.current === batch) this.current = null;
+
+    const keys = [...batch.entries.keys()];
+    Promise.resolve()
+      .then(() => this.batchFn(keys))
+      .then(
+        (results) => {
+          if (!Array.isArray(results) || results.length !== keys.length) {
+            const err = new Error(
+              `batchFn must return exactly ${keys.length} results, got ` +
+                (Array.isArray(results) ? String(results.length) : typeof results),
+            );
+            for (const waiter of batch.entries.values()) waiter.reject(err);
+            return;
+          }
+          keys.forEach((key, i) => {
+            const waiter = batch.entries.get(key)!;
+            const result = results[i];
+            if (result instanceof Error) waiter.reject(result);
+            else waiter.resolve(result);
+          });
+        },
+        (error: unknown) => {
+          for (const waiter of batch.entries.values()) waiter.reject(error);
+        },
+      );
+  }
+}
