+"""schedaudit — collision auditor for the ops job calendar.
+
+Jobs are already parsed upstream; this module expands their occurrences over
+an audit window, reports same-resource overlaps, and proposes free slots.
+All times are naive ISO minutes ('YYYY-MM-DDTHH:MM'); nothing reads a clock.
+"""
+from datetime import datetime, timedelta
+
+_UNITS = {"minutes": 1, "hours": 60, "days": 1440}
+_FMT = "%Y-%m-%dT%H:%M"
+
+
+def _parse(when):
+    try:
+        return datetime.strptime(when, _FMT)
+    except (TypeError, ValueError):
+        raise ValueError(f"bad timestamp {when!r}: expected YYYY-MM-DDTHH:MM")
+
+
+def _fmt(dt):
+    return dt.strftime(_FMT)
+
+
+def validate_job(job):
+    for key in ("id", "resource", "start", "duration_min"):
+        if key not in job:
+            raise ValueError(f"job missing {key!r}")
+    duration = job["duration_min"]
+    if not isinstance(duration, int) or isinstance(duration, bool) or duration <= 0:
+        raise ValueError(f"job {job['id']!r}: duration_min must be a positive int")
+    _parse(job["start"])
+    repeat = job.get("repeat")
+    if repeat is not None:
+        every, unit = repeat.get("every"), repeat.get("unit")
+        if unit not in _UNITS:
+            raise ValueError(f"job {job['id']!r}: repeat unit must be one of "
+                             "minutes/hours/days")
+        if not isinstance(every, int) or isinstance(every, bool) or every <= 0:
+            raise ValueError(f"job {job['id']!r}: repeat every must be a positive int")
+
+
+def _window(window_start, window_end):
+    ws, we = _parse(window_start), _parse(window_end)
+    if we <= ws:
+        raise ValueError("window_end must be after window_start")
+    return ws, we
+
+
+def _occurrences(job, ws, we):
+    """Occurrence intervals of `job` intersecting [ws, we), as datetimes."""
+    duration = timedelta(minutes=job["duration_min"])
+    start = _parse(job["start"])
+    repeat = job.get("repeat")
+    out = []
+    if repeat is None:
+        candidates = [start]
+    else:
+        period = timedelta(minutes=repeat["every"] * _UNITS[repeat["unit"]])
+        candidates = []
+        occ = start
+        if occ < ws:
+            # jump close to the window instead of stepping one by one
+            behind = (ws - occ) - duration
+            if behind > timedelta(0):
+                occ += period * (behind // period)
+        while occ < we:
+            candidates.append(occ)
+            occ += period
+    for occ in candidates:
+        occ_end = occ + duration
+        if occ_end > ws and occ < we:
+            out.append((occ, occ_end))
+    return out
+
+
+def expand(job, window_start, window_end):
+    """Occurrences of one job intersecting the window, as ISO pairs."""
+    validate_job(job)
+    ws, we = _window(window_start, window_end)
+    return [(_fmt(s), _fmt(e)) for s, e in _occurrences(job, ws, we)]
+
+
+def find_conflicts(jobs, window_start, window_end):
+    """Same-resource overlaps between job occurrences inside the window."""
+    ws, we = _window(window_start, window_end)
+    seen_ids = set()
+    occs = []   # (start, end, resource, job_id)
+    for job in jobs:
+        validate_job(job)
+        if job["id"] in seen_ids:
+            raise ValueError(f"duplicate job id: {job['id']}")
+        seen_ids.add(job["id"])
+        for s, e in _occurrences(job, ws, we):
+            occs.append((s, e, job["resource"], job["id"]))
+
+    conflicts = []
+    for i in range(len(occs)):
+        for j in range(i + 1, len(occs)):
+            s1, e1, r1, id1 = occs[i]
+            s2, e2, r2, id2 = occs[j]
+            if r1 != r2:
+                continue
+            lo, hi = max(s1, s2), min(e1, e2)
+            if lo < hi:
+                pair = sorted((id1, id2))
+                conflicts.append({
+                    "resource": r1,
+                    "jobs": pair,
+                    "start": _fmt(lo),
+                    "end": _fmt(hi),
+                })
+    conflicts.sort(key=lambda c: (c["start"], c["end"], c["resource"], c["jobs"]))
+    return conflicts
+
+
+def suggest_slots(jobs, resource, duration_min, window_start, window_end,
+                  granularity_min=15, limit=3):
+    """Earliest free starts on `resource` for a job of duration_min minutes.
+
+    Candidates begin at window_start and step by granularity_min; a slot must
+    fit entirely inside the window and overlap no occurrence on the resource.
+    """
+    if not isinstance(duration_min, int) or isinstance(duration_min, bool) or duration_min <= 0:
+        raise ValueError("duration_min must be a positive int")
+    if not isinstance(granularity_min, int) or isinstance(granularity_min, bool) or granularity_min <= 0:
+        raise ValueError("granularity_min must be a positive int")
+    ws, we = _window(window_start, window_end)
+    busy = []
+    seen_ids = set()
+    for job in jobs:
+        validate_job(job)
+        if job["id"] in seen_ids:
+            raise ValueError(f"duplicate job id: {job['id']}")
+        seen_ids.add(job["id"])
+        if job["resource"] == resource:
+            busy.extend(_occurrences(job, ws, we))
+
+    duration = timedelta(minutes=duration_min)
+    step = timedelta(minutes=granularity_min)
+    found = []
+    candidate = ws
+    while candidate + duration <= we and len(found) < limit:
+        cand_end = candidate + duration
+        if all(not (s < cand_end and candidate < e) for s, e in busy):
+            found.append(_fmt(candidate))
+        candidate += step
+    return found
