diff --git a/lifestep.s b/lifestep.s
new file mode 100644
index 0000000..8b2eb39
--- /dev/null
+++ b/lifestep.s
@@ -0,0 +1,80 @@
+# One Conway's Life generation over a row-major byte grid on a torus.
+# System V AMD64: rdi=width, rsi=height, rdx=in, rcx=out.
+	.text
+	.globl	life_step
+	.type	life_step, @function
+life_step:
+	pushq	%rbx
+	pushq	%rbp
+	pushq	%r12
+	pushq	%r13
+	xorq	%r8, %r8		# y
+.Lrow:
+	cmpq	%rsi, %r8
+	jge	.Ldone
+	xorq	%r9, %r9		# x
+.Lcol:
+	cmpq	%rdi, %r9
+	jge	.Lrow_next
+	xorq	%r10, %r10		# live-neighbor count
+	movq	$-1, %r11		# dy
+.Ldy:
+	movq	$-1, %r12		# dx
+.Ldx:
+	movq	%r11, %rax		# skip (0,0): dy|dx == 0 only there
+	orq	%r12, %rax
+	jz	.Ldx_next
+	leaq	(%r8,%r11), %rbx	# ny = y + dy, wrapped into 0..h-1
+	testq	%rbx, %rbx
+	jns	1f
+	addq	%rsi, %rbx
+1:	cmpq	%rsi, %rbx
+	jl	2f
+	subq	%rsi, %rbx
+2:	leaq	(%r9,%r12), %rbp	# nx = x + dx, wrapped into 0..w-1
+	testq	%rbp, %rbp
+	jns	3f
+	addq	%rdi, %rbp
+3:	cmpq	%rdi, %rbp
+	jl	4f
+	subq	%rdi, %rbp
+4:	movq	%rbx, %rax		# count += in[ny*w + nx]
+	imulq	%rdi, %rax
+	addq	%rbp, %rax
+	movzbq	(%rdx,%rax), %rax
+	addq	%rax, %r10
+.Ldx_next:
+	incq	%r12
+	cmpq	$1, %r12
+	jle	.Ldx
+	incq	%r11
+	cmpq	$1, %r11
+	jle	.Ldy
+	movq	%r8, %rax		# rax = y*w + x
+	imulq	%rdi, %rax
+	addq	%r9, %rax
+	movzbq	(%rdx,%rax), %rbx	# current cell
+	xorl	%r13d, %r13d		# next state
+	cmpq	$3, %r10		# birth or survival on 3
+	je	.Lalive
+	cmpq	$2, %r10		# survival on 2 needs a live cell
+	jne	.Lstore
+	testq	%rbx, %rbx
+	jz	.Lstore
+.Lalive:
+	movl	$1, %r13d
+.Lstore:
+	movb	%r13b, (%rcx,%rax)
+	incq	%r9
+	jmp	.Lcol
+.Lrow_next:
+	incq	%r8
+	jmp	.Lrow
+.Ldone:
+	popq	%r13
+	popq	%r12
+	popq	%rbp
+	popq	%rbx
+	ret
+	.size	life_step, .-life_step
+	.section .note.GNU-stack,"",@progbits
