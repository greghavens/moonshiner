diff --git a/retry.sh b/retry.sh
new file mode 100644
index 0000000..4b47229
--- /dev/null
+++ b/retry.sh
@@ -0,0 +1,139 @@
+#!/usr/bin/env bash
+# retry.sh — run a command, retrying transient exit codes with fixed backoff.
+#
+# Usage: retry.sh [--max N] [--retry-on codes] [--fatal-on codes] -- cmd [args...]
+#
+#   --max N          total attempts (default 4)
+#   --retry-on codes comma-separated exit codes worth another attempt (default 1,75)
+#   --fatal-on codes comma-separated exit codes that stop immediately (default 64,78)
+#
+# A nonzero exit code in neither list is fatal. retry.sh exits with the last
+# attempt's exit code (0 on success). Sleeping goes through RETRY_SLEEP_CMD
+# (default: sleep), split on whitespace, with the delay appended as one
+# argument. All retry chatter is on stderr; the command owns stdout.
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  printf 'usage: retry.sh [--max N] [--retry-on codes] [--fatal-on codes] -- cmd [args...]\n' >&2
+  exit 64
+}
+
+note() { printf 'retry: %s\n' "$1" >&2; }
+
+is_posint() {
+  case $1 in
+    ''|*[!0-9]*) return 1 ;;
+  esac
+  [ "$1" -ge 1 ]
+}
+
+valid_csv() { # valid_csv <csv> -- non-empty list of positive integers
+  local csv=$1 item rest
+  [ -n "$csv" ] || return 1
+  rest="$csv,"
+  while [ -n "$rest" ]; do
+    item=${rest%%,*}
+    rest=${rest#*,}
+    is_posint "$item" || return 1
+  done
+  return 0
+}
+
+in_csv() { # in_csv <code> <csv>
+  case ",$2," in
+    *,"$1",*) return 0 ;;
+  esac
+  return 1
+}
+
+backoff() { # backoff <attempt> -- seconds to wait after failed attempt N
+  case $1 in
+    1) printf '1' ;;
+    2) printf '3' ;;
+    3) printf '7' ;;
+    4) printf '15' ;;
+    *) printf '30' ;;
+  esac
+}
+
+sleep_cmd=${RETRY_SLEEP_CMD:-sleep}
+do_sleep() { # do_sleep <secs> -- whitespace-split sleeper, delay appended
+  set -- $sleep_cmd "$1"
+  "$@"
+}
+
+max=4
+retry_csv='1,75'
+fatal_csv='64,78'
+cmd=()
+have_cmd=no
+
+while [ "$#" -gt 0 ]; do
+  case $1 in
+    --max)
+      [ "$#" -ge 2 ] || usage
+      is_posint "$2" || usage
+      max=$2
+      shift 2
+      ;;
+    --retry-on)
+      [ "$#" -ge 2 ] || usage
+      retry_csv=$2
+      shift 2
+      ;;
+    --fatal-on)
+      [ "$#" -ge 2 ] || usage
+      fatal_csv=$2
+      shift 2
+      ;;
+    --)
+      shift
+      have_cmd=yes
+      cmd=("$@")
+      set --
+      ;;
+    *)
+      usage
+      ;;
+  esac
+done
+
+[ "$have_cmd" = yes ] || usage
+[ "${#cmd[@]}" -ge 1 ] || usage
+valid_csv "$retry_csv" || usage
+valid_csv "$fatal_csv" || usage
+
+# a code claimed by both classes is a configuration bug, not a judgment call
+rest="$retry_csv,"
+while [ -n "$rest" ]; do
+  item=${rest%%,*}
+  rest=${rest#*,}
+  in_csv "$item" "$fatal_csv" && usage
+done
+
+attempt=1
+while :; do
+  rc=0
+  "${cmd[@]}" || rc=$?
+  if [ "$rc" -eq 0 ]; then
+    note "attempt $attempt/$max: ok"
+    exit 0
+  fi
+  if ! in_csv "$rc" "$retry_csv"; then
+    note "attempt $attempt/$max: exit $rc (fatal), giving up"
+    exit "$rc"
+  fi
+  if [ "$attempt" -ge "$max" ]; then
+    note "attempt $attempt/$max: exit $rc (retryable), giving up"
+    exit "$rc"
+  fi
+  delay=$(backoff "$attempt")
+  note "attempt $attempt/$max: exit $rc (retryable), sleeping ${delay}s"
+  if ! do_sleep "$delay"; then
+    note "sleep command failed"
+    exit 70
+  fi
+  attempt=$((attempt + 1))
+done
