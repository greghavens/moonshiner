+"""Client-credentials token handling for the Meridian platform API.
+
+TokenManager fetches and caches an access token, refreshing it early by a
+configurable skew on an injectable clock, and guarantees that concurrent
+callers share a single in-flight fetch. ApiClient makes authenticated JSON
+requests through a manager, replaying a request exactly once after a 401
+with a freshly fetched token.
+
+Stdlib only; nothing in here sleeps or reads the wall clock on its own.
+"""
+import json
+import threading
+import time
+import urllib.error
+import urllib.request
+
+__all__ = ["TokenManager", "ApiClient", "TokenError", "ApiError", "AuthError"]
+
+_HTTP_TIMEOUT = 30  # transport safety net; never hit by the test mock
+
+
+class TokenError(Exception):
+    """The token endpoint could not produce a usable access token."""
+
+
+class ApiError(Exception):
+    """A resource request failed with a non-2xx response."""
+
+    def __init__(self, message, status=None):
+        super().__init__(message)
+        self.status = status
+
+
+class AuthError(ApiError):
+    """A resource request kept failing 401 even with a fresh token."""
+
+    def __init__(self, message):
+        super().__init__(message, status=401)
+
+
+def _post_json(url, payload, timeout=_HTTP_TIMEOUT):
+    """POST a JSON body; return (status, parsed-or-None body)."""
+    req = urllib.request.Request(
+        url,
+        data=json.dumps(payload).encode("utf-8"),
+        headers={"Content-Type": "application/json", "Accept": "application/json"},
+        method="POST",
+    )
+    try:
+        with urllib.request.urlopen(req, timeout=timeout) as resp:
+            return resp.status, _decode(resp.read())
+    except urllib.error.HTTPError as e:
+        return e.code, _decode(e.read())
+
+
+def _decode(raw):
+    try:
+        return json.loads(raw.decode("utf-8"))
+    except ValueError:
+        return None
+
+
+class TokenManager:
+    """Fetch, cache, and refresh a client-credentials access token."""
+
+    def __init__(self, token_url, client_id, client_secret, *,
+                 clock=time.monotonic, skew=30.0):
+        self._token_url = token_url
+        self._client_id = client_id
+        self._client_secret = client_secret
+        self._clock = clock
+        self._skew = float(skew)
+        self._lock = threading.Lock()
+        self._token = None
+        self._good_until = None  # clock value at which the cache stops counting
+
+    def get_token(self):
+        """Return the cached token, fetching a fresh one when needed.
+
+        The lock spans the cache check and the fetch, so callers arriving
+        while a fetch is in flight block here and then reuse its result
+        instead of issuing their own token request.
+        """
+        with self._lock:
+            if self._token is not None and self._clock() < self._good_until:
+                return self._token
+            token, expires_in = self._fetch()
+            self._token = token
+            self._good_until = self._clock() + float(expires_in) - self._skew
+            return token
+
+    def invalidate(self, token):
+        """Compare-and-clear: drop the cache only if it still holds ``token``.
+
+        A caller reporting a stale token must not wipe a newer one that a
+        different caller fetched in the meantime.
+        """
+        with self._lock:
+            if self._token == token:
+                self._token = None
+                self._good_until = None
+
+    def _fetch(self):
+        status, body = _post_json(self._token_url, {
+            "grant_type": "client_credentials",
+            "client_id": self._client_id,
+            "client_secret": self._client_secret,
+        })
+        if status != 200:
+            detail = ""
+            if isinstance(body, dict) and body.get("error"):
+                detail = ": %s" % body["error"]
+            raise TokenError("token endpoint returned %d%s" % (status, detail))
+        if not isinstance(body, dict) or not body.get("access_token"):
+            raise TokenError("token endpoint returned 200 without an access_token")
+        return body["access_token"], body.get("expires_in", 0)
+
+
+class ApiClient:
+    """Authenticated JSON GETs through a TokenManager."""
+
+    def __init__(self, base_url, manager):
+        self._base_url = base_url.rstrip("/")
+        self._manager = manager
+
+    def get_json(self, path):
+        """GET a JSON resource; replay exactly once after a 401."""
+        token = self._manager.get_token()
+        status, body = self._get(path, token)
+        if status == 401:
+            # The token we sent is no longer honored: swap it for a fresh
+            # one and replay the request a single time.
+            self._manager.invalidate(token)
+            token = self._manager.get_token()
+            status, body = self._get(path, token)
+            if status == 401:
+                raise AuthError("still unauthorized after a fresh token: GET %s" % path)
+        if not 200 <= status < 300:
+            raise ApiError("GET %s returned %d" % (path, status), status=status)
+        return body
+
+    def _get(self, path, token):
+        req = urllib.request.Request(
+            self._base_url + path,
+            headers={"Authorization": "Bearer %s" % token,
+                     "Accept": "application/json"},
+            method="GET",
+        )
+        try:
+            with urllib.request.urlopen(req, timeout=_HTTP_TIMEOUT) as resp:
+                return resp.status, _decode(resp.read())
+        except urllib.error.HTTPError as e:
+            return e.code, _decode(e.read())
