-//! rs-handleheap: handle-addressable min-heap for the dispatch scheduler.
-//! Implementation pending — see tests/handleheap.rs for the acceptance
-//! contract.
+//! rs-handleheap: a handle-addressable binary min-heap with strict FIFO
+//! tie-breaking, decrease-key, and remove-from-middle.
+//!
+//! Every push mints a never-reused `Handle`; a handle→slot index map is kept
+//! in sync through every sift so targeted operations are O(log n).
+
+use std::collections::HashMap;
+
+/// Opaque ticket for one enqueued entry. Never reused.
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
+pub struct Handle(u64);
+
+#[derive(Debug, PartialEq, Eq)]
+pub enum HeapError {
+    /// The handle's entry was already popped or removed (or never existed).
+    StaleHandle,
+    /// decrease_key was asked to raise a priority.
+    WouldIncrease { current: u64, requested: u64 },
+}
+
+struct Entry<T> {
+    seq: u64,
+    priority: u64,
+    value: T,
+}
+
+impl<T> Entry<T> {
+    /// Total order: (priority, enqueue sequence). The sequence is unique,
+    /// so ties are impossible and dispatch order is fully deterministic.
+    fn rank(&self) -> (u64, u64) {
+        (self.priority, self.seq)
+    }
+}
+
+pub struct HandleHeap<T> {
+    entries: Vec<Entry<T>>,
+    pos: HashMap<u64, usize>, // seq -> current slot in `entries` (lookup only)
+    next_seq: u64,
+}
+
+impl<T> HandleHeap<T> {
+    pub fn new() -> Self {
+        HandleHeap {
+            entries: Vec::new(),
+            pos: HashMap::new(),
+            next_seq: 0,
+        }
+    }
+
+    pub fn len(&self) -> usize {
+        self.entries.len()
+    }
+
+    pub fn is_empty(&self) -> bool {
+        self.entries.is_empty()
+    }
+
+    fn less(&self, a: usize, b: usize) -> bool {
+        self.entries[a].rank() < self.entries[b].rank()
+    }
+
+    /// Swap two slots, keeping the index map honest.
+    fn swap(&mut self, a: usize, b: usize) {
+        self.entries.swap(a, b);
+        self.pos.insert(self.entries[a].seq, a);
+        self.pos.insert(self.entries[b].seq, b);
+    }
+
+    fn sift_up(&mut self, mut i: usize) -> usize {
+        while i > 0 {
+            let parent = (i - 1) / 2;
+            if self.less(i, parent) {
+                self.swap(i, parent);
+                i = parent;
+            } else {
+                break;
+            }
+        }
+        i
+    }
+
+    fn sift_down(&mut self, mut i: usize) {
+        loop {
+            let left = 2 * i + 1;
+            let right = left + 1;
+            let mut smallest = i;
+            if left < self.entries.len() && self.less(left, smallest) {
+                smallest = left;
+            }
+            if right < self.entries.len() && self.less(right, smallest) {
+                smallest = right;
+            }
+            if smallest == i {
+                return;
+            }
+            self.swap(i, smallest);
+            i = smallest;
+        }
+    }
+
+    pub fn push(&mut self, priority: u64, value: T) -> Handle {
+        let seq = self.next_seq;
+        self.next_seq += 1;
+        let slot = self.entries.len();
+        self.entries.push(Entry {
+            seq,
+            priority,
+            value,
+        });
+        self.pos.insert(seq, slot);
+        self.sift_up(slot);
+        Handle(seq)
+    }
+
+    pub fn peek(&self) -> Option<(Handle, u64, &T)> {
+        self.entries
+            .first()
+            .map(|e| (Handle(e.seq), e.priority, &e.value))
+    }
+
+    pub fn pop(&mut self) -> Option<(Handle, u64, T)> {
+        if self.entries.is_empty() {
+            return None;
+        }
+        let last = self.entries.len() - 1;
+        self.entries.swap(0, last);
+        let e = self.entries.pop().expect("checked non-empty");
+        self.pos.remove(&e.seq);
+        if !self.entries.is_empty() {
+            self.pos.insert(self.entries[0].seq, 0);
+            self.sift_down(0);
+        }
+        Some((Handle(e.seq), e.priority, e.value))
+    }
+
+    pub fn decrease_key(&mut self, h: Handle, new_priority: u64) -> Result<(), HeapError> {
+        let &slot = self.pos.get(&h.0).ok_or(HeapError::StaleHandle)?;
+        let current = self.entries[slot].priority;
+        if new_priority > current {
+            return Err(HeapError::WouldIncrease {
+                current,
+                requested: new_priority,
+            });
+        }
+        if new_priority == current {
+            return Ok(()); // no-op; enqueue rank untouched
+        }
+        self.entries[slot].priority = new_priority;
+        self.sift_up(slot);
+        Ok(())
+    }
+
+    pub fn remove(&mut self, h: Handle) -> Result<(u64, T), HeapError> {
+        let &slot = self.pos.get(&h.0).ok_or(HeapError::StaleHandle)?;
+        let last = self.entries.len() - 1;
+        self.entries.swap(slot, last);
+        let e = self.entries.pop().expect("slot exists, heap non-empty");
+        self.pos.remove(&e.seq);
+        if slot < self.entries.len() {
+            // The filler came from the bottom of a *different* subtree, so it
+            // may be smaller than the hole's parent: fix in both directions.
+            self.pos.insert(self.entries[slot].seq, slot);
+            if self.sift_up(slot) == slot {
+                self.sift_down(slot);
+            }
+        }
+        Ok((e.priority, e.value))
+    }
+
+    pub fn contains(&self, h: Handle) -> bool {
+        self.pos.contains_key(&h.0)
+    }
+
+    pub fn priority_of(&self, h: Handle) -> Option<u64> {
+        self.pos.get(&h.0).map(|&slot| self.entries[slot].priority)
+    }
+}
+
+impl<T> Default for HandleHeap<T> {
+    fn default() -> Self {
+        HandleHeap::new()
+    }
+}
