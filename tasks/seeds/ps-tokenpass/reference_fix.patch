diff --git a/tokenpass.ps1 b/tokenpass.ps1
new file mode 100644
index 0000000..bfd7315
--- /dev/null
+++ b/tokenpass.ps1
@@ -0,0 +1,76 @@
+# Token-session client for the metrics API. Session state is a plain value
+# owned by the caller; every function takes the session and updates it.
+Set-StrictMode -Version Latest
+
+function New-ApiSession {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][string]$BaseUrl,
+        [Parameter(Mandatory)][string]$Account,
+        [Parameter(Mandatory)][string]$Secret
+    )
+    $history = [System.Collections.Generic.List[string]]::new()
+    $history.Add('anonymous')
+    @{
+        BaseUrl = $BaseUrl
+        Account = $Account
+        Secret  = $Secret
+        Token   = $null
+        State   = 'anonymous'
+        History = $history
+    }
+}
+
+function Set-SessionState {
+    param([hashtable]$Session, [string]$State)
+    $Session.State = $State
+    $Session.History.Add($State)
+}
+
+function Connect-ApiSession {
+    param([hashtable]$Session)
+    $payload = @{ account = $Session.Account; secret = $Session.Secret } | ConvertTo-Json -Compress
+    $resp = Invoke-WebRequest -Uri "$($Session.BaseUrl)/login" -Method Post `
+        -ContentType 'application/json' -Body $payload -SkipHttpErrorCheck
+    if ([int]$resp.StatusCode -ne 200) {
+        Set-SessionState $Session 'rejected'
+        throw "tokenpass: login rejected for account $($Session.Account)"
+    }
+    $Session.Token = ($resp.Content | ConvertFrom-Json).token
+    Set-SessionState $Session 'active'
+}
+
+function Invoke-ApiGet {
+    [CmdletBinding()]
+    param(
+        [Parameter(Mandatory)][hashtable]$Session,
+        [Parameter(Mandatory)][string]$Path
+    )
+    if ($Session.State -eq 'rejected') {
+        throw 'tokenpass: session rejected'
+    }
+    if ($Session.State -eq 'anonymous') {
+        Connect-ApiSession $Session
+    }
+
+    $renewed = $false
+    while ($true) {
+        $resp = Invoke-WebRequest -Uri "$($Session.BaseUrl)$Path" -Method Get `
+            -Headers @{ Authorization = "Bearer $($Session.Token)" } -SkipHttpErrorCheck
+        $status = [int]$resp.StatusCode
+        if ($status -eq 200) {
+            return $resp.Content
+        }
+        if ($status -eq 401) {
+            if ($renewed) {
+                Set-SessionState $Session 'rejected'
+                throw 'tokenpass: still unauthorized after re-login'
+            }
+            $renewed = $true
+            Set-SessionState $Session 'renewing'
+            Connect-ApiSession $Session
+            continue
+        }
+        throw "tokenpass: unexpected status $status from $Path"
+    }
+}
