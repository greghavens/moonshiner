{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0003",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "hospitality",
  "prompt": "Look up the exact reservation “Maple Hall Reception” at Austin and tell me its record ID, current date, and status. This first turn is read-only. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Now change that reservation's date to 2026-10-11. Keep its location and status as they are, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: I gave you the wrong date. Use 2026-11-15 instead. Leave every other field unchanged and still do not notify anyone."
    }
  ],
  "available_tools": [
    "hospitality_search",
    "hospitality_get",
    "hospitality_list",
    "hospitality_update",
    "hospitality_cancel",
    "hospitality_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "hos-103",
        "name": "Maple Hall Reception",
        "location": "Austin",
        "date": "2026-08-08",
        "status": "active"
      },
      {
        "id": "hos-503",
        "name": "Maple Hall Reception",
        "location": "Dallas",
        "date": "2026-09-15",
        "status": "active"
      },
      {
        "id": "hos-803",
        "name": "Juniper Room Dinner",
        "location": "Austin",
        "date": "2026-09-15",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_search",
            "arguments": {
              "query": "Maple Hall Reception",
              "location": "Austin"
            }
          }
        ],
        "purpose": "Resolve the exact record from its name and location without changing state."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_update",
            "arguments": {
              "id": "hos-103",
              "date": "2026-10-11"
            }
          }
        ],
        "purpose": "Apply the user's first requested date to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "hospitality_update",
            "arguments": {
              "id": "hos-103",
              "date": "2026-11-15"
            }
          }
        ],
        "purpose": "Apply the later correction to the same record, superseding the earlier date."
      }
    ],
    "state_assertions": [
      "hos-103.date == 2026-11-15",
      "hos-103.location == Austin",
      "hos-103.status == active",
      "hos-503.date == 2026-09-15",
      "hos-803.date == 2026-09-15",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "hospitality_notify",
      "hospitality_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "Treat the corrected date as final; do not present the first requested date as current."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:search-update"
  ]
}
