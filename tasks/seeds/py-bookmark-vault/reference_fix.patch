--- /dev/null
+++ b/netscape.py
@@ -0,0 +1,44 @@
+"""Netscape bookmark file format: render and parse. Pure, no IO."""
+import html
+import re
+
+_HEADER = (
+    "<!DOCTYPE NETSCAPE-Bookmark-file-1>\n"
+    "<TITLE>Bookmarks</TITLE>\n"
+    "<H1>Bookmarks</H1>\n"
+    "<DL><p>\n"
+)
+_FOOTER = "</DL><p>\n"
+
+_ANCHOR = re.compile(r"<DT>\s*<A\s+([^>]*)>(.*?)</A>", re.IGNORECASE | re.DOTALL)
+_ATTR = re.compile(r'([A-Za-z_]+)\s*=\s*"([^"]*)"')
+
+
+def render(bookmarks):
+    """Emit the vault as a Netscape bookmark file (sorted by url)."""
+    out = [_HEADER]
+    for b in sorted(bookmarks, key=lambda b: b["url"]):
+        attrs = f'HREF="{html.escape(b["url"])}"'
+        if b.get("tags"):
+            joined = ",".join(sorted(b["tags"]))
+            attrs += f' TAGS="{html.escape(joined)}"'
+        out.append(f"    <DT><A {attrs}>{html.escape(b['title'])}</A>\n")
+    out.append(_FOOTER)
+    return "".join(out)
+
+
+def parse(text):
+    """Extract [{url, title, tags}] from bookmark HTML.
+
+    Folders (<DT><H3>) and any other structure are ignored: we flatten.
+    """
+    books = []
+    for m in _ANCHOR.finditer(text):
+        attrs = {k.upper(): html.unescape(v) for k, v in _ATTR.findall(m.group(1))}
+        if "HREF" not in attrs:
+            continue
+        tags = [t for t in attrs.get("TAGS", "").split(",") if t]
+        books.append({"url": attrs["HREF"],
+                      "title": html.unescape(m.group(2)),
+                      "tags": tags})
+    return books
