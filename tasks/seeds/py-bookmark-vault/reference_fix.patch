@@ -0,0 +1,127 @@
+"""Bookmark vault CLI: add / tag / search / import / export / repair."""
+import argparse
+import json
+import sys
+
+import netscape
+import store
+import vault
+
+
+def cmd_add(args):
+    state = store.load(args.db)
+    try:
+        action, key = vault.upsert(state, args.url, args.title, args.tag)
+    except vault.VaultError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    store.save(args.db, state)
+    print(f"{action} {key}")
+    return 0
+
+
+def cmd_tag(args):
+    state = store.load(args.db)
+    try:
+        vault.add_tags(state, args.url, args.tags)
+    except vault.VaultError as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_search(args):
+    state = store.load(args.db)
+    for url, title, tags in vault.search(state, args.term, args.tag):
+        print(f"{url}\t{title}\t{','.join(tags)}")
+    return 0
+
+
+def _as_book_list(state):
+    return [{"url": url, "title": b["title"], "tags": sorted(b["tags"])}
+            for url, b in sorted(state["bookmarks"].items())]
+
+
+def cmd_export(args):
+    state = store.load(args.db)
+    if args.json:
+        with open(args.json, "w", encoding="utf-8") as f:
+            json.dump(_as_book_list(state), f, indent=2, ensure_ascii=False)
+            f.write("\n")
+    else:
+        with open(args.html, "w", encoding="utf-8") as f:
+            f.write(netscape.render(_as_book_list(state)))
+    return 0
+
+
+def cmd_import(args):
+    state = store.load(args.db)
+    try:
+        if args.json:
+            with open(args.json, "r", encoding="utf-8") as f:
+                entries = json.load(f)
+            for e in entries:  # legacy dumps: tags land verbatim
+                vault.upsert(state, e["url"], e.get("title"), e.get("tags", []),
+                             verbatim_tags=True, require_title=False)
+        else:
+            with open(args.html, "r", encoding="utf-8") as f:
+                entries = netscape.parse(f.read())
+            for e in entries:
+                vault.upsert(state, e["url"], e["title"], e["tags"],
+                             require_title=False)
+    except (OSError, json.JSONDecodeError, vault.VaultError) as e:
+        print(f"error: {e}", file=sys.stderr)
+        return 1
+    store.save(args.db, state)
+    return 0
+
+
+def cmd_repair(args):
+    state = store.load(args.db)
+    changed = vault.repair(state)
+    store.save(args.db, state)
+    print(f"repaired {changed} bookmarks")
+    return 0
+
+
+def build_parser():
+    ap = argparse.ArgumentParser(prog="bookmarks")
+    ap.add_argument("--db", required=True)
+    sub = ap.add_subparsers(dest="command", required=True)
+
+    p = sub.add_parser("add")
+    p.add_argument("url")
+    p.add_argument("--title")
+    p.add_argument("--tag", action="append", default=[])
+    p.set_defaults(func=cmd_add)
+
+    p = sub.add_parser("tag")
+    p.add_argument("url")
+    p.add_argument("tags", nargs="+")
+    p.set_defaults(func=cmd_tag)
+
+    p = sub.add_parser("search")
+    p.add_argument("term", nargs="?")
+    p.add_argument("--tag", action="append", default=[])
+    p.set_defaults(func=cmd_search)
+
+    for name, fn in (("export", cmd_export), ("import", cmd_import)):
+        p = sub.add_parser(name)
+        g = p.add_mutually_exclusive_group(required=True)
+        g.add_argument("--json")
+        g.add_argument("--html")
+        p.set_defaults(func=fn)
+
+    p = sub.add_parser("repair")
+    p.set_defaults(func=cmd_repair)
+    return ap
+
+
+def main(argv=None):
+    args = build_parser().parse_args(argv)
+    return args.func(args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
