+"""URL canonicalization. Pure functions, no IO."""
+from urllib.parse import parse_qsl, urlencode, urlsplit, urlunsplit
+
+_DEFAULT_PORTS = {"http": 80, "https": 443}
+
+
+def normalize(url):
+    """Canonical form of a URL so different spellings of a page collide."""
+    if "://" not in url:
+        url = "https://" + url
+    parts = urlsplit(url)
+    scheme = parts.scheme.lower()
+    host = (parts.hostname or "").lower()
+    netloc = host
+    port = parts.port
+    if port is not None and _DEFAULT_PORTS.get(scheme) != port:
+        netloc = f"{host}:{port}"
+    path = parts.path
+    if path.endswith("/"):
+        path = path[:-1]
+    query = parts.query
+    if query:
+        pairs = parse_qsl(query, keep_blank_values=True)
+        pairs.sort(key=lambda kv: kv[0])  # sort() is stable: equal keys keep order
+        query = urlencode(pairs)
+    return urlunsplit((scheme, netloc, path, query, ""))
