+"""Vault operations: tag hygiene, merging, search, repair."""
+import re
+
+import urlnorm
+
+_WS = re.compile(r"\s+")
+
+
+class VaultError(Exception):
+    pass
+
+
+def normalize_tag(tag):
+    """lowercase, trimmed, whitespace runs -> '-'; may come out empty."""
+    return _WS.sub("-", tag.strip().lower())
+
+
+def clean_tags(tags):
+    """Normalize a tag list, dropping empties and duplicates (first wins)."""
+    out = []
+    for tag in tags:
+        t = normalize_tag(tag)
+        if t and t not in out:
+            out.append(t)
+    return out
+
+
+def upsert(state, url, title, tags, *, verbatim_tags=False, require_title=True):
+    """Add or merge a bookmark. Returns ('added'|'merged', normalized_url)."""
+    key = urlnorm.normalize(url)
+    incoming = list(tags) if verbatim_tags else clean_tags(tags)
+    existing = state["bookmarks"].get(key)
+    if existing is None:
+        if title is None and require_title:
+            raise VaultError(f"new bookmark {key} needs a --title")
+        state["bookmarks"][key] = {"title": title or "", "tags": incoming}
+        return "added", key
+    if title is not None:
+        existing["title"] = title
+    for t in incoming:
+        if t not in existing["tags"]:
+            existing["tags"].append(t)
+    return "merged", key
+
+
+def add_tags(state, url, tags):
+    key = urlnorm.normalize(url)
+    bookmark = state["bookmarks"].get(key)
+    if bookmark is None:
+        raise VaultError(f"no bookmark for {key}")
+    for t in clean_tags(tags):
+        if t not in bookmark["tags"]:
+            bookmark["tags"].append(t)
+
+
+def search(state, term=None, tags=()):
+    """[(url, title, sorted_tags)] sorted by url."""
+    needle = (term or "").lower()
+    want = [normalize_tag(t) for t in tags]
+    hits = []
+    for url in sorted(state["bookmarks"]):
+        b = state["bookmarks"][url]
+        if needle and needle not in url.lower() and needle not in b["title"].lower():
+            continue
+        if any(t not in b["tags"] for t in want):
+            continue
+        hits.append((url, b["title"], sorted(b["tags"])))
+    return hits
+
+
+def repair(state):
+    """Normalize every stored tag list; returns how many bookmarks changed."""
+    changed = 0
+    for b in state["bookmarks"].values():
+        cleaned = clean_tags(b["tags"])
+        if cleaned != b["tags"]:
+            b["tags"] = cleaned
+            changed += 1
+    return changed
