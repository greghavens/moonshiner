+// $batch envelope helpers: batch splitting and nextLink → relative URL.
+
+export interface SubRequest {
+  id: string;
+  method: 'GET';
+  url: string;
+}
+
+export interface SubResponse {
+  id: string;
+  status: number;
+  headers?: Record<string, string>;
+  body?: unknown;
+}
+
+export const BATCH_LIMIT = 20;
+
+/** Split work into consecutive batches, filling each to the 20-request limit. */
+export function buildBatches<T>(items: T[]): T[][] {
+  const batches: T[][] = [];
+  for (let i = 0; i < items.length; i += BATCH_LIMIT) {
+    batches.push(items.slice(i, i + BATCH_LIMIT));
+  }
+  return batches;
+}
+
+/**
+ * Convert an absolute @odata.nextLink into the relative form $batch expects.
+ * The link is opaque: strip exactly the version base and keep path + query
+ * byte-for-byte — never parse or re-encode the token.
+ */
+export function deriveRelativeUrl(link: string, baseUrl: string): string {
+  if (!link.startsWith(baseUrl + '/')) {
+    throw new Error(`nextLink does not extend the expected API base: ${link}`);
+  }
+  return link.slice(baseUrl.length);
+}
diff --git a/batch_mail_client.ts b/batch_mail_client.ts
