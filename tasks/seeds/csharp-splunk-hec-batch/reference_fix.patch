@@ -0,0 +1,24 @@
+namespace Foundry.Telemetry.Splunk;
+
+/// <summary>
+/// Configuration for the Splunk HEC sink. ToString is overridden because
+/// records render every member by default — options get logged, tokens
+/// must not.
+/// </summary>
+public sealed record HecSinkOptions(
+    string BaseUrl,
+    string Token,
+    string Host,
+    string Source,
+    string Sourcetype,
+    int MaxBatchBytes,
+    int MaxAttempts,
+    TimeSpan RetryDelay,
+    string? Index = null)
+{
+    public override string ToString() =>
+        $"HecSinkOptions {{ BaseUrl = {BaseUrl}, Token = ***, Host = {Host}, " +
+        $"Source = {Source}, Sourcetype = {Sourcetype}, Index = {Index}, " +
+        $"MaxBatchBytes = {MaxBatchBytes}, MaxAttempts = {MaxAttempts}, " +
+        $"RetryDelay = {RetryDelay} }}";
+}
diff --git a/src/Splunk/SplunkHecSink.cs b/src/Splunk/SplunkHecSink.cs
