+++ b/src/Splunk/HecRequestException.cs
@@ -0,0 +1,22 @@
+namespace Foundry.Telemetry.Splunk;
+
+/// <summary>
+/// A HEC request that failed terminally, carrying the decoded HEC error
+/// body ({"text": ..., "code": ...}). Never contains the token.
+/// </summary>
+public sealed class HecRequestException : Exception
+{
+    public int Status { get; }
+
+    public int HecCode { get; }
+
+    public string HecText { get; }
+
+    public HecRequestException(int status, int hecCode, string hecText)
+        : base($"Splunk HEC returned {status} (code {hecCode}): {hecText}")
+    {
+        Status = status;
+        HecCode = hecCode;
+        HecText = hecText;
+    }
+}
