diff --git a/bake-planner/src/main/java/com/ovenworks/bakeplanner/PurchasePlanner.java b/bake-planner/src/main/java/com/ovenworks/bakeplanner/PurchasePlanner.java
index 3425c04..b08ffaf 100644
--- a/bake-planner/src/main/java/com/ovenworks/bakeplanner/PurchasePlanner.java
+++ b/bake-planner/src/main/java/com/ovenworks/bakeplanner/PurchasePlanner.java
@@ -1,7 +1,10 @@
 package com.ovenworks.bakeplanner;
 
+import com.ovenworks.bakecore.BatchMath;
 import java.util.List;
+import java.util.Locale;
 import java.util.Map;
+import java.util.TreeMap;
 
 /** Turns the week's order book into a purchasing list. */
 public final class PurchasePlanner {
@@ -17,6 +20,25 @@ public final class PurchasePlanner {
      * bake-core's BatchMath.
      */
     public static List<String> plan(Map<String, Integer> orders, List<Recipe> recipes, int wastePct) {
-        throw new UnsupportedOperationException("TODO: came over in the module split unfinished");
+        Map<String, Integer> totals = new TreeMap<>();
+        for (Map.Entry<String, Integer> order : orders.entrySet()) {
+            String product = order.getKey();
+            int units = order.getValue();
+            if (units == 0) {
+                continue;
+            }
+            Recipe recipe = recipes.stream()
+                    .filter(r -> r.product().equals(product))
+                    .findFirst()
+                    .orElseThrow(() -> new IllegalArgumentException("no recipe for \"" + product + "\""));
+            int batches = BatchMath.batchesForOrders(units, recipe.unitsPerBatch());
+            for (Map.Entry<String, Integer> ingredient : recipe.gramsPerBatch().entrySet()) {
+                int grams = BatchMath.gramsWithWaste(ingredient.getValue(), batches, wastePct);
+                totals.merge(ingredient.getKey(), grams, Integer::sum);
+            }
+        }
+        return totals.entrySet().stream()
+                .map(e -> String.format(Locale.ROOT, "%s: %d g", e.getKey(), e.getValue()))
+                .toList();
     }
 }
