@@ -0,0 +1,94 @@
+"""Frequency-ranked autocomplete over a character trie."""
+
+
+class _Node:
+    __slots__ = ("children", "weight")
+
+    def __init__(self):
+        self.children = {}
+        self.weight = 0          # > 0 iff a stored term ends here
+
+
+class Autocomplete:
+    def __init__(self):
+        self._root = _Node()
+        self._size = 0
+
+    @staticmethod
+    def _norm(term):
+        if not isinstance(term, str):
+            raise ValueError("term must be a string: %r" % (term,))
+        term = term.strip().lower()
+        if not term:
+            raise ValueError("term must not be empty")
+        return term
+
+    def insert(self, term, weight=1):
+        term = self._norm(term)
+        if not isinstance(weight, int) or isinstance(weight, bool) or weight < 1:
+            raise ValueError("weight must be a positive int: %r" % (weight,))
+        node = self._root
+        for ch in term:
+            node = node.children.setdefault(ch, _Node())
+        if node.weight == 0:
+            self._size += 1
+        node.weight += weight
+
+    def _find(self, text):
+        node = self._root
+        for ch in text:
+            node = node.children.get(ch)
+            if node is None:
+                return None
+        return node
+
+    def count(self, term):
+        node = self._find(self._norm(term))
+        return node.weight if node else 0
+
+    def __contains__(self, term):
+        node = self._find(self._norm(term))
+        return node is not None and node.weight > 0
+
+    def __len__(self):
+        return self._size
+
+    def suggest(self, prefix, limit=5):
+        if not isinstance(prefix, str):
+            raise ValueError("prefix must be a string: %r" % (prefix,))
+        prefix = prefix.strip().lower()
+        start = self._find(prefix)
+        if start is None or limit <= 0:
+            return []
+        found = []
+
+        def walk(node, text):
+            if node.weight:
+                found.append((-node.weight, text))
+            for ch in sorted(node.children):
+                walk(node.children[ch], text + ch)
+
+        walk(start, prefix)
+        found.sort()
+        return [text for _, text in found[:limit]]
+
+    def delete(self, term):
+        term = self._norm(term)
+        path = [(None, self._root)]
+        node = self._root
+        for ch in term:
+            node = node.children.get(ch)
+            if node is None:
+                return False
+            path.append((ch, node))
+        if node.weight == 0:
+            return False
+        node.weight = 0
+        self._size -= 1
+        # prune now-dead branches so deleted terms don't leak memory
+        for i in range(len(path) - 1, 0, -1):
+            ch, child = path[i]
+            if child.children or child.weight:
+                break
+            path[i - 1][1].children.pop(ch, None)
+        return True
