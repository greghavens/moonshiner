index 0000000..bc3ecf4
--- /dev/null
+++ b/pagedb.py
@@ -0,0 +1,104 @@
+"""Public facade for the pagedb B-tree page store.
+
+    from pagedb import PageStore, CorruptError
+    st = PageStore.open("data.db", page_size=512)
+    st.put("key", b"value"); st.flush(); st.close()
+
+Durability contract: flush() is the commit point — dirty pages are written
+first, the header (with its checksum) last. open() truncates uncommitted
+trailing bytes and raises CorruptError for a bad header or a file shorter
+than the committed page count.
+"""
+from pager import CorruptError, Pager
+from tree import BTree
+
+__all__ = ["PageStore", "CorruptError"]
+
+
+class PageStore:
+    def __init__(self, pager, tree):
+        self._pager = pager
+        self._tree = tree
+
+    @classmethod
+    def open(cls, path, page_size=4096):
+        """Open or create a store. page_size only applies at creation; an
+        existing file's stored page size always wins."""
+        if page_size < 128:
+            raise ValueError("page_size must be at least 128 bytes")
+        pager = Pager(path, page_size)
+        return cls(pager, BTree(pager))
+
+    # ---- internals ---------------------------------------------------------
+    def _check_open(self):
+        if self._pager is None:
+            raise ValueError("store is closed")
+
+    def _encode_key(self, key):
+        if not isinstance(key, str):
+            raise ValueError("key must be str")
+        kb = key.encode("utf-8")
+        if not 1 <= len(kb) <= self._pager.page_size // 8:
+            raise ValueError(
+                f"key must be 1..{self._pager.page_size // 8} UTF-8 bytes")
+        return kb
+
+    # ---- mutations ---------------------------------------------------------
+    def put(self, key, value):
+        self._check_open()
+        kb = self._encode_key(key)
+        if not isinstance(value, (bytes, bytearray)):
+            raise ValueError("value must be bytes")
+        if len(value) > self._pager.page_size // 4:
+            raise ValueError(
+                f"value exceeds {self._pager.page_size // 4} bytes")
+        if self._tree.put(kb, bytes(value)):
+            self._pager.entries += 1
+
+    def delete(self, key):
+        self._check_open()
+        kb = self._encode_key(key)
+        if self._tree.delete(kb):
+            self._pager.entries -= 1
+            return True
+        return False
+
+    # ---- reads -------------------------------------------------------------
+    def get(self, key):
+        self._check_open()
+        return self._tree.get(self._encode_key(key))
+
+    def scan(self, lo=None, hi=None):
+        """Yield (key, value) in key order; lo inclusive, hi exclusive."""
+        self._check_open()
+        lob = None if lo is None else lo.encode("utf-8")
+        hib = None if hi is None else hi.encode("utf-8")
+        for k, v in self._tree.scan(lob, hib):
+            yield k.decode("utf-8"), v
+
+    def __len__(self):
+        self._check_open()
+        return self._pager.entries
+
+    def stats(self):
+        self._check_open()
+        height, node_count = self._tree.measure()
+        return {
+            "page_size": self._pager.page_size,
+            "pages": self._pager.pages,
+            "height": height,
+            "nodes": node_count,
+            "entries": self._pager.entries,
+            "free_pages": self._pager.free_count(),
+        }
+
+    # ---- durability --------------------------------------------------------
+    def flush(self):
+        self._check_open()
+        self._pager.flush()
+
+    def close(self):
+        if self._pager is None:
+            return
+        self._pager.close()
+        self._pager = None
diff --git a/pager.py b/pager.py
