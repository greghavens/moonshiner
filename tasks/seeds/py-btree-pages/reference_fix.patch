diff --git a/nodes.py b/nodes.py
new file mode 100644
index 0000000..7aa3b8e
--- /dev/null
+++ b/nodes.py
@@ -0,0 +1,79 @@
+"""Node serialization: leaves hold (key, value) pairs, internal nodes hold
+separator keys and child page ids. Keys are UTF-8 bytes; UTF-8 byte order
+equals codepoint order, so byte comparison matches Python str comparison.
+
+Leaf:     b"L" | u16 count | count * (u16 klen, key, u16 vlen, value)
+Internal: b"I" | u16 nkeys | u32 child0 | nkeys * (u16 klen, key, u32 child)
+"""
+import struct
+
+_U16 = struct.Struct("<H")
+_U32 = struct.Struct("<I")
+
+
+class Leaf:
+    __slots__ = ("keys", "vals")
+
+    def __init__(self, keys=None, vals=None):
+        self.keys = keys or []
+        self.vals = vals or []
+
+    def size(self):
+        return 3 + sum(4 + len(k) + len(v) for k, v in zip(self.keys, self.vals))
+
+    def encode(self):
+        parts = [b"L", _U16.pack(len(self.keys))]
+        for k, v in zip(self.keys, self.vals):
+            parts += [_U16.pack(len(k)), k, _U16.pack(len(v)), v]
+        return b"".join(parts)
+
+
+class Internal:
+    __slots__ = ("keys", "children")
+
+    def __init__(self, keys=None, children=None):
+        self.keys = keys or []
+        self.children = children or []  # len(children) == len(keys) + 1
+
+    def size(self):
+        return 3 + 4 + sum(6 + len(k) for k in self.keys)
+
+    def encode(self):
+        parts = [b"I", _U16.pack(len(self.keys)), _U32.pack(self.children[0])]
+        for k, child in zip(self.keys, self.children[1:]):
+            parts += [_U16.pack(len(k)), k, _U32.pack(child)]
+        return b"".join(parts)
+
+
+def decode(data):
+    tag = data[:1]
+    (count,) = _U16.unpack_from(data, 1)
+    off = 3
+    if tag == b"L":
+        node = Leaf()
+        for _ in range(count):
+            (klen,) = _U16.unpack_from(data, off)
+            off += 2
+            key = bytes(data[off:off + klen])
+            off += klen
+            (vlen,) = _U16.unpack_from(data, off)
+            off += 2
+            node.keys.append(key)
+            node.vals.append(bytes(data[off:off + vlen]))
+            off += vlen
+        return node
+    if tag == b"I":
+        node = Internal()
+        (child0,) = _U32.unpack_from(data, off)
+        off += 4
+        node.children.append(child0)
+        for _ in range(count):
+            (klen,) = _U16.unpack_from(data, off)
+            off += 2
+            node.keys.append(bytes(data[off:off + klen]))
+            off += klen
+            (child,) = _U32.unpack_from(data, off)
+            off += 4
+            node.children.append(child)
+        return node
+    raise ValueError(f"unknown node tag {tag!r}")
diff --git a/pagedb.py b/pagedb.py
