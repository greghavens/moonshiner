+#!/usr/bin/env python3
+"""Workout log CLI: log sessions, personal records, progression suggestions,
+weekly volume reports. See storage/stats/rules for the moving parts."""
+import argparse
+import datetime
+import re
+import sys
+
+import rules
+import stats
+import storage
+
+DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")
+SET_RE = re.compile(r"^(\d+)x(\d+(?:\.\d+)?)$")
+WEEK_RE = re.compile(r"^(\d{4})-W(\d{2})$")
+
+
+def fail(message):
+    print(f"error: {message}", file=sys.stderr)
+    return 2
+
+
+def parse_date(text):
+    if not DATE_RE.match(text):
+        raise ValueError(f"date must be YYYY-MM-DD, got {text!r}")
+    try:
+        datetime.date.fromisoformat(text)
+    except ValueError:
+        raise ValueError(f"{text} is not a real date")
+    return text
+
+
+def parse_set(text):
+    m = SET_RE.match(text)
+    if not m:
+        raise ValueError(f"set must look like REPSxWEIGHT (e.g. 5x102.5), got {text!r}")
+    reps, weight = int(m.group(1)), float(m.group(2))
+    if reps < 1:
+        raise ValueError(f"reps must be at least 1, got {text!r}")
+    if weight <= 0:
+        raise ValueError(f"weight must be positive, got {text!r}")
+    return {"reps": reps, "weight": weight}
+
+
+def cmd_add(data, args, log_path):
+    try:
+        date = parse_date(args.date)
+        if not args.sets:
+            raise ValueError("at least one --set is required")
+        sets = [parse_set(s) for s in args.sets]
+    except ValueError as e:
+        return fail(e)
+    storage.add_sets(data, date, args.exercise.lower(), sets)
+    storage.save(log_path, data)
+    return 0
+
+
+def cmd_pr(data, args):
+    sets = stats.all_sets(data, args.exercise.lower())
+    if not sets:
+        return 1
+    weight, reps, date = stats.best_weight(sets)
+    e1rm, e1rm_date = stats.best_e1rm(sets)
+    print(f"best weight: {stats.fmt_kg(weight)} kg x {reps} ({date})")
+    print(f"best e1rm: {stats.fmt_kg(e1rm)} kg ({e1rm_date})")
+    return 0
+
+
+def cmd_suggest(data, args):
+    exercise = args.exercise.lower()
+    suggestion = rules.suggest(stats.sessions_for(data, exercise))
+    if suggestion is None:
+        return 1
+    verb, weight = suggestion
+    print(f"{exercise}: {verb} {stats.fmt_kg(weight)} kg")
+    return 0
+
+
+def cmd_report(data, args):
+    m = WEEK_RE.match(args.week)
+    if not m:
+        return fail(f"week must be YYYY-Www (e.g. 2026-W10), got {args.week!r}")
+    year, week = int(m.group(1)), int(m.group(2))
+    try:
+        datetime.date.fromisocalendar(year, week, 1)
+    except ValueError:
+        return fail(f"{args.week} is not a real ISO week")
+    volumes = stats.weekly_volume(data, year, week)
+    if not volumes:
+        return 1
+    for exercise in sorted(volumes):
+        volume, count = volumes[exercise]
+        noun = "set" if count == 1 else "sets"
+        print(f"{exercise}: {stats.fmt_kg(volume)} kg ({count} {noun})")
+    return 0
+
+
+def main(argv=None):
+    parser = argparse.ArgumentParser(prog="workout", description=__doc__)
+    parser.add_argument("--log", required=True, help="path to the JSON log file")
+    sub = parser.add_subparsers(dest="command", required=True)
+
+    p_add = sub.add_parser("add", help="record a training session")
+    p_add.add_argument("date")
+    p_add.add_argument("exercise")
+    p_add.add_argument("--set", dest="sets", action="append", metavar="REPSxWEIGHT")
+
+    for name, help_text in [("pr", "personal records"), ("suggest", "progression suggestion")]:
+        p = sub.add_parser(name, help=help_text)
+        p.add_argument("exercise")
+
+    p_report = sub.add_parser("report", help="weekly volume report")
+    p_report.add_argument("week", metavar="YYYY-Www")
+
+    args = parser.parse_args(argv)
+    try:
+        data = storage.load(args.log)
+    except storage.StorageError as e:
+        return fail(e)
+
+    if args.command == "add":
+        return cmd_add(data, args, args.log)
+    if args.command == "pr":
+        return cmd_pr(data, args)
+    if args.command == "suggest":
+        return cmd_suggest(data, args)
+    return cmd_report(data, args)
+
+
+if __name__ == "__main__":
+    sys.exit(main())
