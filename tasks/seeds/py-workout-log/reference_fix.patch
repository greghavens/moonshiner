+"""JSON persistence for the workout log.
+
+On disk: {"sessions": [{"date": "YYYY-MM-DD", "exercise": "squat",
+"sets": [{"reps": 5, "weight": 100.0}, ...]}, ...]} with one session per
+(date, exercise) pair; exercise names are stored lowercase.
+"""
+import json
+import os
+
+
+class StorageError(Exception):
+    """The log file exists but cannot be read as a workout log."""
+
+
+def load(path):
+    """Read the log; a missing file is an empty log. Never creates the file."""
+    if not os.path.exists(path):
+        return {"sessions": []}
+    try:
+        with open(path, encoding="utf-8") as f:
+            data = json.load(f)
+    except (json.JSONDecodeError, UnicodeDecodeError) as e:
+        raise StorageError(f"{path} is not a valid workout log: {e}") from e
+    if not isinstance(data, dict) or not isinstance(data.get("sessions"), list):
+        raise StorageError(f"{path} is not a valid workout log: missing sessions")
+    return data
+
+
+def save(path, data):
+    with open(path, "w", encoding="utf-8") as f:
+        json.dump(data, f, indent=2)
+        f.write("\n")
+
+
+def add_sets(data, date, exercise, sets):
+    """Append sets to the session for (date, exercise), creating it if new."""
+    for session in data["sessions"]:
+        if session["date"] == date and session["exercise"] == exercise:
+            session["sets"].extend(sets)
+            return
+    data["sessions"].append({"date": date, "exercise": exercise, "sets": list(sets)})
