+"""Personal records and volume math over the workout log."""
+import datetime
+
+
+def fmt_kg(value):
+    """Render a weight/volume without trailing zeros: 105, 102.5, 119.6."""
+    return f"{value:g}"
+
+
+def epley_e1rm(reps, weight):
+    """Estimated one-rep max, rounded to one decimal."""
+    return round(weight * (1 + reps / 30), 1)
+
+
+def sessions_for(data, exercise):
+    """Chronologically sorted [(date, [set, ...]), ...] for one exercise."""
+    rows = [(s["date"], s["sets"]) for s in data["sessions"]
+            if s["exercise"] == exercise]
+    rows.sort(key=lambda r: r[0])
+    return rows
+
+
+def all_sets(data, exercise):
+    """Chronological [(date, reps, weight), ...] across every session."""
+    out = []
+    for date, sets in sessions_for(data, exercise):
+        for st in sets:
+            out.append((date, st["reps"], st["weight"]))
+    return out
+
+
+def best_weight(sets):
+    """Heaviest set: ties go to more reps, then to the earlier date.
+
+    sets must be chronological; returns (weight, reps, date).
+    """
+    best = None
+    for date, reps, weight in sets:
+        if best is None or (weight, reps) > (best[0], best[1]):
+            best = (weight, reps, date)
+    return best
+
+
+def best_e1rm(sets):
+    """Best estimated 1RM: ties go to the earlier date. Returns (e1rm, date)."""
+    best = None
+    for date, reps, weight in sets:
+        value = epley_e1rm(reps, weight)
+        if best is None or value > best[0]:
+            best = (value, date)
+    return best
+
+
+def weekly_volume(data, iso_year, iso_week):
+    """{exercise: (volume, set_count)} for sets landing in the ISO week."""
+    out = {}
+    for session in data["sessions"]:
+        date = datetime.date.fromisoformat(session["date"])
+        if date.isocalendar()[:2] != (iso_year, iso_week):
+            continue
+        volume, count = out.get(session["exercise"], (0.0, 0))
+        for st in session["sets"]:
+            volume += st["reps"] * st["weight"]
+            count += 1
+        out[session["exercise"]] = (volume, count)
+    return out
