+"""Progressive-overload suggestion rules.
+
+Applied in order: plateau deload, then rep-quality increase, then hold.
+"""
+import math
+
+PLATEAU_SESSIONS = 3
+REP_TARGET = 5
+INCREMENT = 2.5
+DELOAD_FACTOR = 0.9
+
+
+def session_top(sets):
+    """A session's top weight."""
+    return max(st["weight"] for st in sets)
+
+
+def suggest(sessions):
+    """(verb, weight) for chronologically sorted (date, sets) sessions.
+
+    verb is 'deload to' / 'increase to' / 'hold at'. None when there is no
+    history to reason about.
+    """
+    if not sessions:
+        return None
+    tops = [session_top(sets) for _, sets in sessions]
+    top = tops[-1]
+    if len(tops) >= PLATEAU_SESSIONS and len(set(tops[-PLATEAU_SESSIONS:])) == 1:
+        deload = math.floor(top * DELOAD_FACTOR / INCREMENT) * INCREMENT
+        return ("deload to", deload)
+    last_sets = sessions[-1][1]
+    if all(st["reps"] >= REP_TARGET for st in last_sets):
+        return ("increase to", top + INCREMENT)
+    return ("hold at", top)
