+//! Nim engine for the puzzle-night kiosk: multi-heap, normal and misère
+//! play, with a provably optimal bot whose move choice is deterministic.
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum Variant {
+    Normal,
+    Misere,
+}
+
+#[derive(Debug, Clone)]
+pub struct Game {
+    heaps: Vec<u32>,
+    variant: Variant,
+    turn: u8,
+}
+
+/// Is the position (heaps, side to move) a win for the side to move under
+/// optimal play? Closed form: normal play is the plain xor-sum rule; misère
+/// play agrees with it while any heap has 2+ objects, and flips to a parity
+/// rule once every heap holds at most one.
+fn winning(heaps: &[u32], variant: Variant) -> bool {
+    let xor = heaps.iter().fold(0u32, |a, &h| a ^ h);
+    match variant {
+        Variant::Normal => xor != 0,
+        Variant::Misere => {
+            if heaps.iter().all(|&h| h <= 1) {
+                heaps.iter().filter(|&&h| h > 0).count() % 2 == 0
+            } else {
+                xor != 0
+            }
+        }
+    }
+}
+
+impl Game {
+    pub fn new(heaps: &[u32], variant: Variant) -> Result<Game, String> {
+        if heaps.is_empty() {
+            return Err("need at least one heap".to_string());
+        }
+        if heaps.iter().all(|&h| h == 0) {
+            return Err("need at least one object".to_string());
+        }
+        Ok(Game {
+            heaps: heaps.to_vec(),
+            variant,
+            turn: 0,
+        })
+    }
+
+    pub fn heaps(&self) -> &[u32] {
+        &self.heaps
+    }
+
+    pub fn turn(&self) -> u8 {
+        self.turn
+    }
+
+    pub fn variant(&self) -> Variant {
+        self.variant
+    }
+
+    pub fn is_over(&self) -> bool {
+        self.heaps.iter().all(|&h| h == 0)
+    }
+
+    pub fn winner(&self) -> Option<u8> {
+        if !self.is_over() {
+            return None;
+        }
+        // `turn` already points at the player who did NOT take the last
+        // object's... successor; the last mover is the other player.
+        let last_mover = 1 - self.turn;
+        Some(match self.variant {
+            Variant::Normal => last_mover,
+            Variant::Misere => self.turn,
+        })
+    }
+
+    pub fn is_winning(&self) -> bool {
+        !self.is_over() && winning(&self.heaps, self.variant)
+    }
+
+    pub fn apply(&mut self, heap: usize, take: u32) -> Result<(), String> {
+        if self.is_over() {
+            return Err("game over".to_string());
+        }
+        if heap >= self.heaps.len() {
+            return Err(format!("no such heap: {heap}"));
+        }
+        if take == 0 {
+            return Err("must take at least one".to_string());
+        }
+        if take > self.heaps[heap] {
+            return Err(format!("heap {heap} has only {}", self.heaps[heap]));
+        }
+        self.heaps[heap] -= take;
+        self.turn = 1 - self.turn;
+        Ok(())
+    }
+
+    pub fn bot_move(&self) -> Option<(usize, u32)> {
+        if self.is_over() {
+            return None;
+        }
+        // Scan heaps low index first, removals small first; the first move
+        // that lands the opponent in a losing position is the bot's move.
+        for (i, &h) in self.heaps.iter().enumerate() {
+            for take in 1..=h {
+                let mut next = self.heaps.clone();
+                next[i] -= take;
+                if !winning(&next, self.variant) {
+                    return Some((i, take));
+                }
+            }
+        }
+        // Losing position: no winning move exists. Pinned fallback: one
+        // object off the lowest-index non-empty heap.
+        let i = self.heaps.iter().position(|&h| h > 0).unwrap();
+        Some((i, 1))
+    }
+
+    pub fn play_out(&mut self) -> Vec<(u8, usize, u32)> {
+        let mut log = Vec::new();
+        while !self.is_over() {
+            let (heap, take) = self.bot_move().unwrap();
+            let player = self.turn;
+            self.apply(heap, take).unwrap();
+            log.push((player, heap, take));
+        }
+        log
+    }
+}
