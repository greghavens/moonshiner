+// Hangman engine over a fixture word list. Answers are lowercase words or
+// phrases (single spaces); spaces are pre-revealed. The gallows ladder is
+// pinned ASCII, one stage per miss, and a repeated guess costs nothing.
+
+export type Status = 'playing' | 'won' | 'lost';
+
+export const MAX_MISSES = 6;
+
+export interface Game {
+  readonly answer: string;
+  readonly guessed: ReadonlyArray<string>; // letters in guess order
+  readonly misses: number;
+  readonly status: Status;
+}
+
+const ENTRY = /^[a-z]+( [a-z]+)*$/;
+
+export function loadWords(text: string): string[] {
+  const words = text.split('\n').filter((line) => line !== '');
+  if (words.length === 0) throw new Error('empty word list');
+  for (const w of words) {
+    if (!ENTRY.test(w)) throw new Error(`bad word list entry: ${JSON.stringify(w)}`);
+  }
+  return words;
+}
+
+export function newGame(answer: string): Game {
+  if (!ENTRY.test(answer)) throw new Error(`bad answer: ${JSON.stringify(answer)}`);
+  return { answer, guessed: [], misses: 0, status: 'playing' };
+}
+
+export function guess(game: Game, letter: string): Game {
+  if (letter.length !== 1 || letter < 'a' || letter > 'z') {
+    throw new Error(`guess must be a single lowercase letter, got ${JSON.stringify(letter)}`);
+  }
+  if (game.status !== 'playing') throw new Error('game is over');
+  if (game.guessed.includes(letter)) return game; // no penalty, no history change
+  const guessed = [...game.guessed, letter];
+  if (game.answer.includes(letter)) {
+    const done = [...game.answer].every((ch) => ch === ' ' || guessed.includes(ch));
+    return { ...game, guessed, status: done ? 'won' : 'playing' };
+  }
+  const misses = game.misses + 1;
+  return { ...game, guessed, misses, status: misses >= MAX_MISSES ? 'lost' : 'playing' };
+}
+
+// Masked word: guessed letters show, spaces are free, the rest are '_'.
+export function mask(game: Game): string {
+  return [...game.answer]
+    .map((ch) => (ch === ' ' || game.guessed.includes(ch) ? ch : '_'))
+    .join('');
+}
+
+const STAGES = [
+  ['+---+', '|   |', '|', '|', '|', '====='],
+  ['+---+', '|   |', '|   o', '|', '|', '====='],
+  ['+---+', '|   |', '|   o', '|   |', '|', '====='],
+  ['+---+', '|   |', '|   o', '|  /|', '|', '====='],
+  ['+---+', '|   |', '|   o', '|  /|\\', '|', '====='],
+  ['+---+', '|   |', '|   o', '|  /|\\', '|  /', '====='],
+  ['+---+', '|   |', '|   o', '|  /|\\', '|  / \\', '====='],
+];
+
+export function gallows(game: Game): string {
+  return STAGES[game.misses].join('\n');
+}
+
+// Replay a guess script. Lines: 'guess <x>: hit <mask>', 'miss <n>/6
+// <mask>' or 'repeat <mask>'; on game end append 'won <answer>' or
+// 'lost <answer>' and ignore the rest of the script.
+export function transcript(answer: string, guesses: string): string {
+  let game = newGame(answer);
+  const lines: string[] = [];
+  for (const letter of guesses) {
+    const next = guess(game, letter);
+    if (next === game) {
+      lines.push(`guess ${letter}: repeat ${mask(game)}`);
+      continue;
+    }
+    if (next.misses > game.misses) {
+      lines.push(`guess ${letter}: miss ${next.misses}/${MAX_MISSES} ${mask(next)}`);
+    } else {
+      lines.push(`guess ${letter}: hit ${mask(next)}`);
+    }
+    game = next;
+    if (game.status !== 'playing') {
+      lines.push(`${game.status} ${game.answer}`);
+      break;
+    }
+  }
+  return lines.join('\n');
+}
