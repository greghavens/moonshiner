@@ -0,0 +1,77 @@
+export interface Post {
+  title: string;
+  date: string;
+  tags: string[];
+  slug: string;
+  draft: boolean;
+  body: string;
+}
+
+export function slugify(s: string): string {
+  return s
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '');
+}
+
+const KNOWN_KEYS = new Set(['title', 'date', 'tags', 'draft', 'slug']);
+const DATE_RE = /^(\d{4})-(\d{2})-(\d{2})$/;
+
+function validateDate(value: string): void {
+  const m = DATE_RE.exec(value);
+  if (!m) throw new Error(`invalid date "${value}" (expected YYYY-MM-DD)`);
+  const [, y, mo, d] = m;
+  const dt = new Date(Date.UTC(Number(y), Number(mo) - 1, Number(d)));
+  const roundTrips =
+    dt.getUTCFullYear() === Number(y) &&
+    dt.getUTCMonth() === Number(mo) - 1 &&
+    dt.getUTCDate() === Number(d);
+  if (!roundTrips) throw new Error(`invalid date "${value}" (not a real calendar date)`);
+}
+
+export function parsePost(source: string): Post {
+  const lines = source.split('\n');
+  if ((lines[0] ?? '').trim() !== '---') throw new Error('missing front matter opening fence');
+
+  const meta: Record<string, string> = {};
+  let closed = -1;
+  for (let i = 1; i < lines.length; i++) {
+    const line = lines[i];
+    if (line.trim() === '---') {
+      closed = i;
+      break;
+    }
+    if (line.trim() === '') continue;
+    const colon = line.indexOf(':');
+    if (colon === -1) throw new Error(`malformed front matter line: ${line}`);
+    const key = line.slice(0, colon).trim();
+    const value = line.slice(colon + 1).trim();
+    if (!KNOWN_KEYS.has(key)) throw new Error(`unknown front matter key "${key}"`);
+    meta[key] = value;
+  }
+  if (closed === -1) throw new Error('unterminated front matter block');
+
+  if (!meta.title) throw new Error('front matter is missing a title');
+  if (!meta.date) throw new Error('front matter is missing a date');
+  validateDate(meta.date);
+
+  let draft = false;
+  if (meta.draft !== undefined) {
+    if (meta.draft === 'true') draft = true;
+    else if (meta.draft === 'false') draft = false;
+    else throw new Error(`invalid draft value "${meta.draft}" (expected true or false)`);
+  }
+
+  const tags: string[] = [];
+  if (meta.tags !== undefined) {
+    for (const raw of meta.tags.split(',')) {
+      const tag = slugify(raw);
+      if (tag !== '' && !tags.includes(tag)) tags.push(tag);
+    }
+  }
+
+  const slug = meta.slug !== undefined && meta.slug !== '' ? meta.slug : slugify(meta.title);
+  const body = lines.slice(closed + 1).join('\n').trim();
+
+  return { title: meta.title, date: meta.date, tags, slug, draft, body };
+}
