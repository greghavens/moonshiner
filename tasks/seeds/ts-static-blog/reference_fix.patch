+export function escapeHtml(s: string): string {
+  return s
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+/** Inline formatting: code spans are carved out first so their contents stay literal. */
+export function renderInline(text: string): string {
+  const parts = text.split(/(`[^`]+`)/);
+  return parts
+    .map((part) => {
+      if (part.length >= 2 && part.startsWith('`') && part.endsWith('`')) {
+        return `<code>${escapeHtml(part.slice(1, -1))}</code>`;
+      }
+      let s = escapeHtml(part);
+      s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
+      s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
+      s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
+      return s;
+    })
+    .join('');
+}
+
+function renderBlock(block: string): string {
+  const heading = /^(#{1,3}) (.*)$/s.exec(block);
+  if (heading && !heading[2].startsWith('#')) {
+    const level = heading[1].length;
+    return `<h${level}>${renderInline(heading[2])}</h${level}>`;
+  }
+
+  const lines = block.split('\n').map((l) => l.trim());
+  if (lines.every((l) => l.startsWith('- '))) {
+    const items = lines.map((l) => `<li>${renderInline(l.slice(2))}</li>`);
+    return `<ul>\n${items.join('\n')}\n</ul>`;
+  }
+
+  return `<p>${renderInline(lines.join(' '))}</p>`;
+}
+
+export function renderMarkdown(body: string): string {
+  const blocks = body
+    .split(/\n[ \t]*\n/)
+    .map((b) => b.trim())
+    .filter((b) => b !== '');
+  return blocks.map(renderBlock).join('\n');
+}
diff --git a/site.ts b/site.ts
new file mode 100644
index 0000000..1552dc4
--- /dev/null
+++ b/site.ts
@@ -0,0 +1,73 @@
+import { parsePost, type Post } from './posts.ts';
+import { renderMarkdown, escapeHtml } from './render.ts';
+
+/** Newest first; slug ascending breaks date ties. */
+function byRecency(a: Post, b: Post): number {
+  if (a.date !== b.date) return a.date < b.date ? 1 : -1;
+  return a.slug < b.slug ? -1 : a.slug > b.slug ? 1 : 0;
+}
+
+function archiveList(posts: Post[], prefix: string): string {
+  const items = posts.map(
+    (p) => `<li><a href="${prefix}${p.slug}.html">${escapeHtml(p.title)}</a> — ${p.date}</li>`,
+  );
+  return ['<ul class="archive">', ...items, '</ul>'].join('\n');
+}
+
+function postPage(post: Post): string {
+  let meta = post.date;
+  if (post.tags.length > 0) {
+    const links = [...post.tags]
+      .sort()
+      .map((t) => `<a href="../tags/${t}.html">${t}</a>`)
+      .join(', ');
+    meta += ` · tags: ${links}`;
+  }
+  return [
+    '<article>',
+    `<h1>${escapeHtml(post.title)}</h1>`,
+    `<p class="meta">${meta}</p>`,
+    renderMarkdown(post.body),
+    '</article>',
+  ].join('\n');
+}
+
+export function buildSite(sources: string[]): Map<string, string> {
+  const all = sources.map(parsePost);
+
+  const seen = new Set<string>();
+  for (const post of all) {
+    if (seen.has(post.slug)) throw new Error(`duplicate slug "${post.slug}"`);
+    seen.add(post.slug);
+  }
+
+  const published = all.filter((p) => !p.draft).sort(byRecency);
+  const pages = new Map<string, string>();
+
+  for (const post of published) {
+    pages.set(`posts/${post.slug}.html`, postPage(post));
+  }
+
+  pages.set('index.html', `<h1>Archive</h1>\n${archiveList(published, 'posts/')}`);
+
+  const byTag = new Map<string, Post[]>();
+  for (const post of published) {
+    for (const tag of post.tags) {
+      const bucket = byTag.get(tag) ?? [];
+      bucket.push(post);
+      byTag.set(tag, bucket);
+    }
+  }
+
+  const tagNames = [...byTag.keys()].sort();
+  for (const tag of tagNames) {
+    pages.set(`tags/${tag}.html`, `<h1>Tag: ${tag}</h1>\n${archiveList(byTag.get(tag)!, '../posts/')}`);
+  }
+
+  const tagItems = tagNames.map(
+    (t) => `<li><a href="${t}.html">${t}</a> (${byTag.get(t)!.length})</li>`,
+  );
+  pages.set('tags/index.html', ['<h1>Tags</h1>', '<ul class="tags">', ...tagItems, '</ul>'].join('\n'));
+
+  return pages;
+}
