@@ -0,0 +1,26 @@
+/**
+ * Split a stream of text chunks into lines.
+ *
+ * Terminators are `\n` and `\r\n` (a pair split across chunks still counts
+ * as one). A lone `\r` is ordinary content. The terminator is not included
+ * in the yielded line. A trailing unterminated line is yielded last.
+ */
+export async function* splitLines(
+  chunks: AsyncIterable<string> | Iterable<string>,
+): AsyncGenerator<string, void, undefined> {
+  let buffer = '';
+  for await (const chunk of chunks) {
+    buffer += chunk;
+    let start = 0;
+    for (;;) {
+      const nl = buffer.indexOf('\n', start);
+      if (nl === -1) break;
+      let end = nl;
+      if (end > start && buffer.charCodeAt(end - 1) === 13 /* \r */) end--;
+      yield buffer.slice(start, end);
+      start = nl + 1;
+    }
+    buffer = buffer.slice(start);
+  }
+  if (buffer !== '') yield buffer;
+}
