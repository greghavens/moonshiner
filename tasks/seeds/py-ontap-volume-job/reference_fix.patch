@@ -0,0 +1,73 @@
+"""Minimal ONTAP REST client: basic auth, HAL+JSON, documented error decode."""
+
+import base64
+import json
+import urllib.error
+import urllib.parse
+import urllib.request
+
+from .errors import OntapApiError, ResolutionError
+
+
+class OntapClient:
+    def __init__(self, base_url, username, password):
+        self.base_url = base_url.rstrip("/")
+        token = base64.b64encode(("%s:%s" % (username, password)).encode("utf-8")).decode("ascii")
+        self._auth_header = "Basic " + token
+
+    def request(self, method, path, params=None, body=None):
+        url = self.base_url + path
+        if params:
+            url += "?" + urllib.parse.urlencode(params)
+        data = None
+        req_headers = {"Authorization": self._auth_header, "Accept": "application/hal+json"}
+        if body is not None:
+            data = json.dumps(body).encode("utf-8")
+            req_headers["Content-Type"] = "application/json"
+        req = urllib.request.Request(url, data=data, method=method, headers=req_headers)
+        try:
+            with urllib.request.urlopen(req) as resp:
+                raw = resp.read()
+                return resp.status, json.loads(raw.decode("utf-8")) if raw else {}
+        except urllib.error.HTTPError as exc:
+            err = {}
+            try:
+                err = json.loads(exc.read().decode("utf-8")).get("error", {})
+            except (ValueError, AttributeError):
+                pass
+            raise OntapApiError(
+                exc.code, err.get("code"), err.get("message"), err.get("target")
+            ) from None
+
+    def get(self, path, params=None):
+        return self.request("GET", path, params=params)[1]
+
+    def _resolve_one(self, path, name, kind):
+        doc = self.get(path, params={"name": name, "fields": "uuid,name"})
+        records = doc.get("records") or []
+        if doc.get("num_records") != 1:
+            raise ResolutionError(
+                "expected exactly one %s named %r, found %s"
+                % (kind, name, doc.get("num_records", 0))
+            )
+        return records[0]
+
+    def resolve_svm(self, name):
+        return self._resolve_one("/api/svm/svms", name, "SVM")
+
+    def resolve_aggregate(self, name):
+        return self._resolve_one("/api/storage/aggregates", name, "aggregate")
+
+    def find_volume(self, svm_name, name):
+        doc = self.get(
+            "/api/storage/volumes",
+            params={"name": name, "svm.name": svm_name, "fields": "uuid,name,size,state"},
+        )
+        count = doc.get("num_records", 0)
+        if count == 0:
+            return None
+        if count > 1:
+            raise ResolutionError(
+                "volume lookup for %r on SVM %r matched %d records" % (name, svm_name, count)
+            )
+        return (doc.get("records") or [])[0]
