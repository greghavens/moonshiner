+++ b/ontapvol/errors.py
@@ -0,0 +1,28 @@
+"""Errors raised by the ontapvol package."""
+
+
+class OntapApiError(Exception):
+    """A non-2xx ONTAP REST response carrying the documented error object."""
+
+    def __init__(self, status, code, message, target=None):
+        self.status = status
+        self.code = code
+        self.message = message or ""
+        self.target = target
+        detail = "ONTAP API error %s (code %s): %s" % (status, code, self.message)
+        if target:
+            detail += " [target: %s]" % target
+        super().__init__(detail)
+
+
+class JobFailedError(Exception):
+    """An asynchronous job ended in the failure state or never went terminal."""
+
+    def __init__(self, message, code=None):
+        self.message = message
+        self.code = code
+        super().__init__(message)
+
+
+class ResolutionError(Exception):
+    """A name lookup did not resolve to exactly one record."""
