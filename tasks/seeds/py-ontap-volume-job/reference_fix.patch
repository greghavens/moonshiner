@@ -0,0 +1,79 @@
+"""Idempotent volume provisioning over the ONTAP asynchronous job pattern."""
+
+from .errors import JobFailedError, ResolutionError
+
+POLL_INTERVAL = 1.0
+
+
+class ProvisionSpec:
+    def __init__(self, name, svm, aggregates, size, junction_path=None):
+        self.name = name
+        self.svm = svm
+        self.aggregates = list(aggregates)
+        self.size = size
+        self.junction_path = junction_path
+
+
+class VolumeProvisioner:
+    def __init__(self, client, sleep, max_polls=20):
+        self.client = client
+        self.sleep = sleep
+        self.max_polls = max_polls
+
+    def provision(self, spec):
+        existing = self.client.find_volume(spec.svm, spec.name)
+        if existing is not None:
+            return self._result(existing, created=False)
+
+        svm = self.client.resolve_svm(spec.svm)
+        aggregates = [self.client.resolve_aggregate(name) for name in spec.aggregates]
+        body = {
+            "name": spec.name,
+            "svm": {"uuid": svm["uuid"]},
+            "aggregates": [{"uuid": aggr["uuid"]} for aggr in aggregates],
+            "size": spec.size,
+        }
+        if spec.junction_path:
+            body["nas"] = {"path": spec.junction_path}
+        _, doc = self.client.request(
+            "POST", "/api/storage/volumes", params={"return_timeout": 0}, body=body
+        )
+        self.wait_for_job(doc.get("job") or {})
+
+        created = self.client.find_volume(spec.svm, spec.name)
+        if created is None:
+            raise ResolutionError(
+                "volume %r missing after successful creation job" % spec.name
+            )
+        return self._result(created, created=True)
+
+    def wait_for_job(self, job):
+        href = ((job.get("_links") or {}).get("self") or {}).get("href")
+        if not href:
+            raise JobFailedError("creation response carried no job link", code=None)
+        for poll in range(self.max_polls):
+            if poll:
+                self.sleep(POLL_INTERVAL)
+            doc = self.client.get(href)
+            state = doc.get("state")
+            if state == "success":
+                return doc
+            if state == "failure":
+                error = doc.get("error") or {}
+                raise JobFailedError(
+                    error.get("message") or doc.get("message") or "job failed",
+                    code=error.get("code"),
+                )
+        raise JobFailedError(
+            "poll budget exhausted after %d polls; job still not terminal" % self.max_polls,
+            code=None,
+        )
+
+    @staticmethod
+    def _result(record, created):
+        return {
+            "uuid": record.get("uuid"),
+            "name": record.get("name"),
+            "created": created,
+            "state": record.get("state"),
+        }
