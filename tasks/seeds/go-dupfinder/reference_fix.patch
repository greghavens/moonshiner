new file mode 100644
index 0000000..723f4d1
--- /dev/null
+++ b/hash.go
@@ -0,0 +1,73 @@
+package dupfinder
+
+import (
+	"crypto/sha256"
+	"encoding/hex"
+	"fmt"
+	"io"
+	"os"
+	"sync"
+)
+
+type hashedFile struct {
+	fileRef
+	hash string
+}
+
+// hashAll digests every candidate with at most opts.Workers files in
+// flight. Workers pull from one shared queue, so any pending file can
+// occupy any idle worker — no per-size-class serialization.
+func hashAll(cands []fileRef, opts Options) ([]hashedFile, error) {
+	if len(cands) == 0 {
+		return nil, nil
+	}
+	workers := opts.Workers
+	if workers > len(cands) {
+		workers = len(cands)
+	}
+
+	jobs := make(chan int)
+	out := make([]hashedFile, len(cands))
+	errs := make([]error, len(cands))
+	var wg sync.WaitGroup
+	for w := 0; w < workers; w++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			for i := range jobs {
+				out[i].fileRef = cands[i]
+				out[i].hash, errs[i] = digest(cands[i].abs, opts)
+			}
+		}()
+	}
+	for i := range cands {
+		jobs <- i
+	}
+	close(jobs)
+	wg.Wait()
+
+	for _, err := range errs {
+		if err != nil {
+			return nil, err
+		}
+	}
+	return out, nil
+}
+
+// digest hashes one file, bracketing the read with Progress events.
+func digest(path string, opts Options) (string, error) {
+	if opts.Progress != nil {
+		opts.Progress(StageHashStart, path)
+		defer opts.Progress(StageHashEnd, path)
+	}
+	f, err := os.Open(path)
+	if err != nil {
+		return "", fmt.Errorf("dupfinder: hash %s: %w", path, err)
+	}
+	defer f.Close()
+	h := sha256.New()
+	if _, err := io.Copy(h, f); err != nil {
+		return "", fmt.Errorf("dupfinder: hash %s: %w", path, err)
+	}
+	return hex.EncodeToString(h.Sum(nil)), nil
+}
