+// Package dupfinder locates duplicate files under a directory tree with a
+// size-then-hash strategy: only files whose size collides with another
+// distinct file's are ever opened, and hashing runs on a bounded worker
+// pool.
+package dupfinder
+
+import (
+	"fmt"
+	"os"
+)
+
+// Stage identifies a Progress callback event.
+type Stage string
+
+const (
+	StageHashStart Stage = "hash-start"
+	StageHashEnd   Stage = "hash-end"
+)
+
+// Options configures a scan.
+type Options struct {
+	// Workers caps how many files are hashed concurrently. Mandatory, >= 1.
+	Workers int
+	// MinSize skips regular files smaller than this many bytes. Zero-byte
+	// files are always skipped.
+	MinSize int64
+	// Progress, when non-nil, is invoked from worker goroutines as each
+	// hash candidate starts and finishes.
+	Progress func(stage Stage, path string)
+}
+
+// Group is one set of identical files: at least two distinct files with the
+// same size and content hash.
+type Group struct {
+	Size  int64
+	Hash  string   // sha256, lowercase hex
+	Paths []string // relative to root, slash-separated, sorted
+}
+
+// Report is the outcome of a scan.
+type Report struct {
+	Groups      []Group // size descending, ties by first path
+	WastedBytes int64   // sum of Size*(len(Paths)-1) over groups
+}
+
+// Find walks root and reports groups of duplicate regular files.
+func Find(root string, opts Options) (*Report, error) {
+	if opts.Workers < 1 {
+		return nil, fmt.Errorf("dupfinder: Workers must be >= 1, got %d", opts.Workers)
+	}
+	info, err := os.Stat(root)
+	if err != nil {
+		return nil, fmt.Errorf("dupfinder: root: %w", err)
+	}
+	if !info.IsDir() {
+		return nil, fmt.Errorf("dupfinder: root %q is not a directory", root)
+	}
+
+	files, err := scanTree(root, opts.MinSize)
+	if err != nil {
+		return nil, err
+	}
+	hashed, err := hashAll(hashCandidates(files), opts)
+	if err != nil {
+		return nil, err
+	}
+	return assemble(hashed), nil
+}
