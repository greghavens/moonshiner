--- /dev/null
+++ b/scan.go
@@ -0,0 +1,97 @@
+package dupfinder
+
+import (
+	"fmt"
+	"io/fs"
+	"path/filepath"
+	"syscall"
+)
+
+// fileRef is one distinct regular file; hardlink aliases have already been
+// collapsed onto the lexicographically smallest relative path.
+type fileRef struct {
+	rel  string // slash-separated, relative to root — the report path
+	abs  string // the path used for reading
+	size int64
+}
+
+type devino struct {
+	dev uint64
+	ino uint64
+}
+
+// scanTree walks root without following symlinks and returns one fileRef
+// per distinct regular file at or above the size threshold.
+func scanTree(root string, minSize int64) ([]fileRef, error) {
+	if minSize < 1 {
+		minSize = 1 // zero-byte files are never duplicate candidates
+	}
+	byInode := map[devino]*fileRef{}
+	var synth uint64 // fallback key space if inode info is unavailable
+	walk := func(path string, d fs.DirEntry, err error) error {
+		if err != nil {
+			return err
+		}
+		// Symlinks (to anything), directories, FIFOs, sockets and devices
+		// all fail IsRegular; WalkDir already refuses to descend through
+		// symlinked directories.
+		if !d.Type().IsRegular() {
+			return nil
+		}
+		info, err := d.Info()
+		if err != nil {
+			return err
+		}
+		if info.Size() < minSize {
+			return nil
+		}
+		rel, err := filepath.Rel(root, path)
+		if err != nil {
+			return err
+		}
+		rel = filepath.ToSlash(rel)
+
+		var key devino
+		if st, ok := info.Sys().(*syscall.Stat_t); ok {
+			key = devino{dev: uint64(st.Dev), ino: uint64(st.Ino)}
+		} else {
+			synth++
+			key = devino{dev: ^uint64(0), ino: synth}
+		}
+		if prev, seen := byInode[key]; seen {
+			// Another name for a file we already have: keep the smallest
+			// path as the alias set's representative.
+			if rel < prev.rel {
+				prev.rel, prev.abs = rel, path
+			}
+			return nil
+		}
+		byInode[key] = &fileRef{rel: rel, abs: path, size: info.Size()}
+		return nil
+	}
+	if err := filepath.WalkDir(root, walk); err != nil {
+		return nil, fmt.Errorf("dupfinder: scan: %w", err)
+	}
+
+	out := make([]fileRef, 0, len(byInode))
+	for _, f := range byInode {
+		out = append(out, *f)
+	}
+	return out, nil
+}
+
+// hashCandidates keeps only files whose size collides with another distinct
+// file's — anything else cannot have a duplicate and must never be opened.
+func hashCandidates(files []fileRef) []fileRef {
+	bySize := map[int64]int{}
+	for _, f := range files {
+		bySize[f.size]++
+	}
+	var out []fileRef
+	for _, f := range files {
+		if bySize[f.size] >= 2 {
+			out = append(out, f)
+		}
+	}
+	return out
+}
