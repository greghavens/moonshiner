index 0000000..7189413
--- /dev/null
+++ b/report.go
@@ -0,0 +1,35 @@
+package dupfinder
+
+import "sort"
+
+// assemble buckets hashed files by (size, hash), drops singletons, and
+// produces the deterministic report ordering.
+func assemble(files []hashedFile) *Report {
+	type content struct {
+		size int64
+		hash string
+	}
+	buckets := map[content][]string{}
+	for _, f := range files {
+		k := content{f.size, f.hash}
+		buckets[k] = append(buckets[k], f.rel)
+	}
+
+	rep := &Report{}
+	for k, paths := range buckets {
+		if len(paths) < 2 {
+			continue
+		}
+		sort.Strings(paths)
+		rep.Groups = append(rep.Groups, Group{Size: k.size, Hash: k.hash, Paths: paths})
+		rep.WastedBytes += k.size * int64(len(paths)-1)
+	}
+	sort.Slice(rep.Groups, func(i, j int) bool {
+		a, b := rep.Groups[i], rep.Groups[j]
+		if a.Size != b.Size {
+			return a.Size > b.Size
+		}
+		return a.Paths[0] < b.Paths[0]
+	})
+	return rep
+}
