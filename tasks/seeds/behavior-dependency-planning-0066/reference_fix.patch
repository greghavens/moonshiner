 #!/usr/bin/env python3
 """Run the procurement reconciliation audit.
 
 The verifier supplies PROCUREMENT_CLI, PROCUREMENT_DATA, PROCUREMENT_TRACE,
 and AUDIT_REPORT. A normal manual run may rely on the defaults documented by
 the executable client's help.
 """
 
+from __future__ import annotations
+
+import json
+import os
+import subprocess
+import sys
+from pathlib import Path
+
+
+HERE = Path(__file__).resolve().parent
+TARGETS = [
+    ("Winter Field Jacket Order", "North Depot"),
+    ("Safety Boot Order", "South Depot"),
+]
+
+
+def call_client(arguments: list[str]) -> dict[str, object]:
+    client = Path(os.environ.get("PROCUREMENT_CLI", HERE / "procurement_cli.py"))
+    completed = subprocess.run(
+        [sys.executable, str(client), *arguments],
+        env=os.environ.copy(),
+        capture_output=True,
+        text=True,
+        check=False,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(f"procurement client failed: {completed.stderr.strip()}")
+    return json.loads(completed.stdout)
+
+
+def record_line(record: dict[str, str]) -> str:
+    return " | ".join(
+        [
+            record["order_date"],
+            record["stable_id"],
+            record["name"],
+            record["location"],
+            record["status"],
+        ]
+    )
+
 
 def main() -> int:
-    raise NotImplementedError("implement the audit runner")
