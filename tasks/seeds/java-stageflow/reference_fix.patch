+++ b/TaskScheduler.java
@@ -0,0 +1,18 @@
+import java.time.Duration;
+
+/**
+ * The orchestrator's only notion of time: something that can run an action
+ * after a delay and let the caller cancel it. Tests inject a virtual-time
+ * implementation (ManualScheduler); production would wrap a real timer.
+ */
+public interface TaskScheduler {
+
+    /** Cancellation token for one scheduled action. Must stay a SAM type. */
+    @FunctionalInterface
+    interface Handle {
+        /** True if the action was revoked; false if it already fired or was cancelled. */
+        boolean cancel();
+    }
+
+    Handle schedule(Runnable action, Duration delay);
+}
