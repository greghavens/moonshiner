diff --git a/reconcile_facilities.sh b/reconcile_facilities.sh
new file mode 100755
index 0000000..8891dec
--- /dev/null
+++ b/reconcile_facilities.sh
@@ -0,0 +1,125 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+work_dir=$(mktemp -d)
+trap 'rm -rf -- "$work_dir"' EXIT
+
+./facilityctl search \
+  --name 'Loading dock door inspection' \
+  --location 'Building B' >"$work_dir/loading-search.json" &
+loading_search_pid=$!
+./facilityctl search \
+  --name 'Fourth-floor thermostat request' \
+  --location 'Civic Annex' >"$work_dir/thermostat-search.json" &
+thermostat_search_pid=$!
+
+loading_search_status=0
+thermostat_search_status=0
+wait "$loading_search_pid" || loading_search_status=$?
+wait "$thermostat_search_pid" || thermostat_search_status=$?
+if (( loading_search_status != 0 || thermostat_search_status != 0 )); then
+  echo 'one or more scoped searches failed' >&2
+  exit 1
+fi
+
+unique_match_id() {
+  python3 - "$1" "$2" "$3" <<'PY'
+import json
+import sys
+
+path, expected_name, expected_location = sys.argv[1:]
+with open(path, encoding="utf-8") as handle:
+    payload = json.load(handle)
+matches = payload.get("matches")
+if not isinstance(matches, list) or len(matches) != 1:
+    raise SystemExit(f"ambiguous lookup: {expected_name} at {expected_location}")
+match = matches[0]
+if (
+    match.get("name") != expected_name
+    or match.get("location") != expected_location
+    or not isinstance(match.get("id"), str)
+    or not match["id"]
+):
+    raise SystemExit(f"invalid lookup result: {expected_name} at {expected_location}")
+print(match["id"])
+PY
+}
+
+loading_id=$(unique_match_id \
+  "$work_dir/loading-search.json" \
+  'Loading dock door inspection' \
+  'Building B')
+thermostat_id=$(unique_match_id \
+  "$work_dir/thermostat-search.json" \
+  'Fourth-floor thermostat request' \
+  'Civic Annex')
+
+./facilityctl get "$loading_id" >"$work_dir/loading-record.json" &
+loading_get_pid=$!
+./facilityctl get "$thermostat_id" >"$work_dir/thermostat-record.json" &
+thermostat_get_pid=$!
+
+loading_get_status=0
+thermostat_get_status=0
+wait "$loading_get_pid" || loading_get_status=$?
+wait "$thermostat_get_pid" || thermostat_get_status=$?
+if (( loading_get_status != 0 || thermostat_get_status != 0 )); then
+  echo 'one or more record retrievals failed' >&2
+  exit 1
+fi
+
+validated_record() {
+  python3 - "$1" "$2" "$3" "$4" <<'PY'
+import json
+import sys
+
+path, expected_id, expected_name, expected_location = sys.argv[1:]
+with open(path, encoding="utf-8") as handle:
+    record = json.load(handle)
+if (
+    record.get("id") != expected_id
+    or record.get("name") != expected_name
+    or record.get("location") != expected_location
+    or not isinstance(record.get("status"), str)
+    or not record["status"]
+):
+    raise SystemExit(f"retrieved record does not match {expected_name}")
+print(record["status"])
+PY
+}
+
+loading_status=$(validated_record \
+  "$work_dir/loading-record.json" \
+  "$loading_id" \
+  'Loading dock door inspection' \
+  'Building B')
+thermostat_status=$(validated_record \
+  "$work_dir/thermostat-record.json" \
+  "$thermostat_id" \
+  'Fourth-floor thermostat request' \
+  'Civic Annex')
+
+thermostat_final_status=$thermostat_status
+if [[ $thermostat_status == queued ]]; then
+  ./facilityctl update "$thermostat_id" --status awaiting-access \
+    >"$work_dir/thermostat-update.json"
+  thermostat_final_status=$(python3 - "$work_dir/thermostat-update.json" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as handle:
+    record = json.load(handle)
+if record.get("status") != "awaiting-access":
+    raise SystemExit("thermostat status update was not confirmed")
+print(record["status"])
+PY
+  )
+  action='changed Fourth-floor thermostat request from queued to awaiting-access'
+else
+  action="made no change because Fourth-floor thermostat request was $thermostat_status"
+fi
+
+printf '%s\n' \
+  "- Fourth-floor thermostat request | $thermostat_id | Civic Annex | $thermostat_final_status" \
+  "- Loading dock door inspection | $loading_id | Building B | $loading_status" \
+  "- Action | $action" >reconciliation.md
