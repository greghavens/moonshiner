diff --git a/snake.py b/snake.py
new file mode 100644
index 0000000..ce5eb66
--- /dev/null
+++ b/snake.py
@@ -0,0 +1,85 @@
+"""Grid snake as a deterministic tick engine; food comes from a fixture queue."""
+
+DELTAS = {"N": (0, -1), "E": (1, 0), "S": (0, 1), "W": (-1, 0)}
+OPPOSITE = {"N": "S", "S": "N", "E": "W", "W": "E"}
+
+
+class Game:
+    def __init__(self, width, height, segments, direction, food_queue):
+        if width < 2 or height < 2:
+            raise ValueError("board too small")
+        if direction not in DELTAS:
+            raise ValueError(f"bad direction {direction!r}")
+        if not segments:
+            raise ValueError("snake needs at least one segment")
+        for x, y in segments:
+            if not (0 <= x < width and 0 <= y < height):
+                raise ValueError(f"segment off the board: {x},{y}")
+        if len(set(segments)) != len(segments):
+            raise ValueError("snake overlaps itself")
+        self.width = width
+        self.height = height
+        self.segments = list(segments)          # head first
+        self.direction = direction
+        self._food_queue = list(food_queue)
+        self.food = self._food_queue.pop(0) if self._food_queue else None
+        self.score = 0
+        self.alive = True
+
+    def tick(self, command=None):
+        """Advance one tick. `command` is N/E/S/W or None to keep heading."""
+        if not self.alive:
+            raise RuntimeError("game over")
+        if command is not None:
+            if command not in DELTAS:
+                raise ValueError(f"bad command {command!r}")
+            reverses = (command == OPPOSITE[self.direction]
+                        and len(self.segments) > 1)
+            if not reverses:
+                self.direction = command
+        dx, dy = DELTAS[self.direction]
+        hx, hy = self.segments[0]
+        new_head = (hx + dx, hy + dy)
+        growing = self.food is not None and new_head == self.food
+        blocked = self.segments if growing else self.segments[:-1]
+        if not (0 <= new_head[0] < self.width and 0 <= new_head[1] < self.height) \
+                or new_head in blocked:
+            self.alive = False
+            return
+        self.segments.insert(0, new_head)
+        if growing:
+            self.score += 1
+            self.food = self._food_queue.pop(0) if self._food_queue else None
+        else:
+            self.segments.pop()
+
+    def render(self):
+        """The board in a +--+ frame: @ head, # body, * food, . empty."""
+        grid = [["."] * self.width for _ in range(self.height)]
+        if self.food is not None:
+            fx, fy = self.food
+            grid[fy][fx] = "*"
+        for x, y in self.segments[1:]:
+            grid[y][x] = "#"
+        hx, hy = self.segments[0]
+        grid[hy][hx] = "@"
+        bar = "+" + "-" * self.width + "+"
+        return "\n".join([bar] + ["|" + "".join(row) + "|" for row in grid] + [bar])
+
+
+def load(path):
+    with open(path, encoding="utf-8") as fh:
+        lines = [ln.strip() for ln in fh.read().splitlines() if ln.strip()]
+    if len(lines) < 3:
+        raise ValueError("fixture needs size, snake and direction lines")
+    width, height = map(int, lines[0].split())
+    nums = list(map(int, lines[1].split()))
+    if len(nums) < 2 or len(nums) % 2:
+        raise ValueError("snake line must hold x y pairs")
+    segments = [(nums[i], nums[i + 1]) for i in range(0, len(nums), 2)]
+    direction = lines[2]
+    food = []
+    for ln in lines[3:]:
+        x, y = map(int, ln.split())
+        food.append((x, y))
+    return Game(width, height, segments, direction, food)
