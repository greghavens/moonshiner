@@ -0,0 +1,63 @@
+using Amazon.CloudWatchLogs;
+using Amazon.CloudWatchLogs.Model;
+
+namespace CloudWatchTokenExport;
+
+public enum LogErrorKind
+{
+    /// <summary>Retryable request-rate errors.</summary>
+    Throttled,
+
+    /// <summary>
+    /// Legacy write-path pair (InvalidSequenceTokenException /
+    /// DataAlreadyAcceptedException). Current PutLogEvents docs state
+    /// sequence tokens are ignored and these are never returned anymore;
+    /// they are terminal and must never be treated as throttling.
+    /// </summary>
+    InvalidSequenceToken,
+
+    /// <summary>Malformed request, e.g. a corrupted or expired page token.</summary>
+    InvalidParameter,
+
+    NotFound,
+
+    Unknown,
+}
+
+public static class LogErrorClassifier
+{
+    // Matches both the SDK's typed exception classes and the service
+    // ErrorCode, because generic AmazonCloudWatchLogsException instances can
+    // carry the code without the typed class.
+    public static LogErrorKind Classify(Exception exception) => exception switch
+    {
+        InvalidSequenceTokenException or DataAlreadyAcceptedException => LogErrorKind.InvalidSequenceToken,
+        InvalidParameterException => LogErrorKind.InvalidParameter,
+        ResourceNotFoundException => LogErrorKind.NotFound,
+        AmazonCloudWatchLogsException e => e.ErrorCode switch
+        {
+            "ThrottlingException" or "Throttling" or "LimitExceededException" => LogErrorKind.Throttled,
+            "InvalidSequenceTokenException" or "DataAlreadyAcceptedException" => LogErrorKind.InvalidSequenceToken,
+            "InvalidParameterException" => LogErrorKind.InvalidParameter,
+            "ResourceNotFoundException" => LogErrorKind.NotFound,
+            _ => LogErrorKind.Unknown,
+        },
+        _ => LogErrorKind.Unknown,
+    };
+}
+
+/// <summary>A failed export step with its service context preserved.</summary>
+public sealed class ExportException : Exception
+{
+    public string LogGroup { get; }
+    public string? StreamName { get; }
+    public LogErrorKind Kind { get; }
+
+    public ExportException(string logGroup, string? streamName, LogErrorKind kind, Exception inner)
+        : base($"export of {logGroup}{(streamName is null ? "" : "/" + streamName)} failed ({kind})", inner)
+    {
+        LogGroup = logGroup;
+        StreamName = streamName;
+        Kind = kind;
+    }
+}
