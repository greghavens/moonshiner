@@ -0,0 +1,13 @@
+namespace CloudWatchTokenExport;
+
+public sealed record ExportedEvent(long TimestampMs, string Message, long IngestionMs);
+
+public sealed record StreamExport(string StreamName, IReadOnlyList<ExportedEvent> Events, int Pages);
+
+public sealed record ExportReport(int Streams, int Events, int Pages);
+
+/// <summary>Receives events per non-empty page so partial progress survives.</summary>
+public interface ILogSink
+{
+    void Append(string streamName, IReadOnlyList<ExportedEvent> events);
+}
