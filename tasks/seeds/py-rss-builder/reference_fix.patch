+import email.utils
+from xml.sax.saxutils import escape, quoteattr
 
 CHANNEL_REQUIRED = ("title", "link", "description")
 
@@ -15,20 +20,82 @@ def _tag(name, text, indent):
     return "%s<%s>%s</%s>" % (" " * indent, name, escape(str(text)), name)
 
 
+def _valid_pubdate(value):
+    """True when value parses as an RFC-2822 date."""
+    try:
+        email.utils.parsedate_to_datetime(value)
+    except (TypeError, ValueError):
+        return False
+    return True
+
+
+def _valid_length(value):
+    """Enclosure lengths may be non-negative ints or digit-only strings."""
+    if isinstance(value, bool):
+        return False
+    if isinstance(value, int):
+        return value >= 0
+    return isinstance(value, str) and value.isdigit()
+
+
+def _enclosure_errors(enclosure, where):
+    errors = []
+    if not enclosure.get("url"):
+        errors.append("%s: enclosure missing url" % where)
+    mime = enclosure.get("type", "")
+    halves = str(mime).split("/")
+    if len(halves) != 2 or not halves[0] or not halves[1]:
+        errors.append("%s: enclosure type %r is not type/subtype" % (where, mime))
+    if not _valid_length(enclosure.get("length")):
+        errors.append("%s: enclosure length %r is not a non-negative integer"
+                      % (where, enclosure.get("length")))
+    return errors
+
+
+def validate_feed(channel, items):
+    """Collect every problem in the feed as a list of error strings.
+
+    Channel complaints come first in required-field order, then items in
+    input order (1-based), each checking title, pubDate, then enclosure.
+    An empty list means the feed is publishable.
+    """
+    errors = []
+    for field in CHANNEL_REQUIRED:
+        if not channel.get(field):
+            errors.append("channel: missing %s" % field)
+    for n, item in enumerate(items, 1):
+        where = "item %d" % n
+        if not item.get("title"):
+            errors.append("%s: missing title" % where)
+        if item.get("pubdate") and not _valid_pubdate(item["pubdate"]):
+            errors.append("%s: invalid pubDate %r" % (where, item["pubdate"]))
+        if "enclosure" in item:
+            errors.extend(_enclosure_errors(item["enclosure"], where))
+    return errors
+
+
+def _categories(container, indent):
+    return [_tag("category", c, indent) for c in container.get("categories", [])]
+
+
 def render_item(item):
     """Render one ``<item>`` block as a list of lines.
 
-    ``title`` is mandatory; ``link``, ``description`` and ``pubdate`` are
-    emitted only when present, always in that order.
+    Order: title, link, description, categories, enclosure, pubDate —
+    optional pieces are emitted only when present.
     """
-    if not item.get("title"):
-        raise ValueError("item missing title")
     lines = ["    <item>"]
     lines.append(_tag("title", item["title"], 6))
     if item.get("link"):
         lines.append(_tag("link", item["link"], 6))
     if item.get("description"):
         lines.append(_tag("description", item["description"], 6))
+    lines.extend(_categories(item, 6))
+    if "enclosure" in item:
+        enc = item["enclosure"]
+        lines.append("      <enclosure url=%s length=%s type=%s/>" % (
+            quoteattr(str(enc["url"])), quoteattr(str(enc["length"])),
+            quoteattr(str(enc["type"]))))
     if item.get("pubdate"):
         lines.append(_tag("pubDate", item["pubdate"], 6))
     lines.append("    </item>")
@@ -38,12 +105,12 @@ def render_item(item):
