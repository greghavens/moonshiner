+// Package ringbuf provides a generic fixed-capacity FIFO ring buffer
+// with a choice of full-buffer policy: overwrite the oldest element or
+// reject the new one.
+package ringbuf
+
+import "fmt"
+
+// Policy selects what Push does when the ring is full.
+type Policy int
+
+// Full-buffer policies.
+const (
+	// Overwrite drops the oldest element to make room.
+	Overwrite Policy = iota
+	// Reject refuses the push and leaves the ring untouched.
+	Reject
+)
+
+// Ring is a fixed-capacity circular FIFO buffer. It is not
+// concurrency-safe; callers synchronize externally.
+type Ring[T any] struct {
+	buf    []T
+	policy Policy
+	head   int // index of the oldest element
+	count  int
+}
+
+// New builds a ring holding at most capacity elements.
+func New[T any](capacity int, policy Policy) (*Ring[T], error) {
+	if capacity < 1 {
+		return nil, fmt.Errorf("ringbuf: capacity must be at least 1, got %d", capacity)
+	}
+	if policy != Overwrite && policy != Reject {
+		return nil, fmt.Errorf("ringbuf: unknown policy %d", policy)
+	}
+	return &Ring[T]{buf: make([]T, capacity), policy: policy}, nil
+}
+
+// Push appends v as the newest element. On a full ring it follows the
+// policy: Overwrite evicts the oldest and reports true; Reject reports
+// false and changes nothing.
+func (r *Ring[T]) Push(v T) bool {
+	if r.count == len(r.buf) {
+		if r.policy == Reject {
+			return false
+		}
+		// Overwrite: the slot holding the oldest element becomes the newest.
+		r.buf[r.head] = v
+		r.head = (r.head + 1) % len(r.buf)
+		return true
+	}
+	r.buf[(r.head+r.count)%len(r.buf)] = v
+	r.count++
+	return true
+}
+
+// Pop removes and returns the oldest element.
+func (r *Ring[T]) Pop() (T, bool) {
+	var zero T
+	if r.count == 0 {
+		return zero, false
+	}
+	v := r.buf[r.head]
+	r.buf[r.head] = zero // don't retain popped values
+	r.head = (r.head + 1) % len(r.buf)
+	r.count--
+	return v, true
+}
+
+// Peek returns the oldest element without removing it.
+func (r *Ring[T]) Peek() (T, bool) {
+	if r.count == 0 {
+		var zero T
+		return zero, false
+	}
+	return r.buf[r.head], true
+}
+
+// Len reports how many elements are buffered.
+func (r *Ring[T]) Len() int { return r.count }
+
+// Cap reports the fixed capacity.
+func (r *Ring[T]) Cap() int { return len(r.buf) }
+
+// Snapshot copies the contents oldest-to-newest. The returned slice is
+// independent of the ring's backing storage.
+func (r *Ring[T]) Snapshot() []T {
+	out := make([]T, r.count)
+	for i := 0; i < r.count; i++ {
+		out[i] = r.buf[(r.head+i)%len(r.buf)]
+	}
+	return out
+}
