-        files.insert(writer.filename(report), writer.render(report));
-    }
-    for plugin in &summaries {
-        summary.extend(plugin.lines(report));
+    if config.dry_run {
+        summary.push("DRY RUN - no files written".to_string());
+        for writer in &writers {
+            let filename = writer.filename(report);
+            let content = writer.render(report);
+            summary.push(format!(
+                "plan: {} ({} bytes, {} lines)",
+                filename,
+                content.len(),
+                content.matches('\n').count()
+            ));
+        }
+        for plugin in &summaries {
+            for line in plugin.lines(report) {
+                summary.push(format!("[dry-run] {line}"));
+            }
+        }
+    } else {
+        for writer in &writers {
+            files.insert(writer.filename(report), writer.render(report));
+        }
+        for plugin in &summaries {
+            summary.extend(plugin.lines(report));
+        }
     }
 
     Ok(RunOutcome { files, summary })
