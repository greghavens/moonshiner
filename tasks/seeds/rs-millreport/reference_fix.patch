diff --git a/src/pipeline.rs b/src/pipeline.rs
index 5ed312e..dfc80ed 100644
--- a/src/pipeline.rs
+++ b/src/pipeline.rs
@@ -24,11 +24,30 @@ pub fn run_pipeline(
     let mut files = BTreeMap::new();
     let mut summary = Vec::new();
 
