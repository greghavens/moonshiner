+  class JsonArrayStream
+    class SyntaxError < StandardError; end
+
+    JSON_WHITESPACE = [0x20, 0x09, 0x0a, 0x0d].freeze
+
+    def initialize(input, buffer_tracker)
+      @reader = ChunkReader.new(input, buffer_tracker)
+    end
+
+    def each
+      opening = next_non_whitespace
+      raise SyntaxError unless opening == 0x5b
+
+      first_byte = next_non_whitespace
+      if first_byte == 0x5d
+        ensure_only_trailing_whitespace
+        return
+      end
+      raise SyntaxError unless first_byte
+
+      loop do
+        source, delimiter = read_value(first_byte)
+        raise SyntaxError if source.empty?
+
+        yield source
+        break if delimiter == 0x5d
+
+        first_byte = next_non_whitespace
+        raise SyntaxError unless first_byte && first_byte != 0x5d
+      end
+
+      ensure_only_trailing_whitespace
+    end
+
+    private
+
+    def next_non_whitespace
+      while (byte = @reader.next_byte)
+        return byte unless JSON_WHITESPACE.include?(byte)
+      end
+      nil
+    end
+
+    def read_value(first_byte)
+      source = String.new(encoding: Encoding::BINARY)
+      depth = 0
+      in_string = false
+      escaped = false
+      byte = first_byte
+
+      loop do
+        if !in_string && depth.zero? && (byte == 0x2c || byte == 0x5d)
+          return [trim_trailing_whitespace(source), byte]
+        end
+
+        source << byte
+        @reader.observe_with(source.bytesize)
+
+        if in_string
+          if escaped
+            escaped = false
+          elsif byte == 0x5c
+            escaped = true
+          elsif byte == 0x22
+            in_string = false
+          end
+        else
+          case byte
+          when 0x22
+            in_string = true
+          when 0x7b, 0x5b
+            depth += 1
+          when 0x7d
+            depth -= 1
+          when 0x5d
+            depth -= 1
+          end
+        end
+
+        byte = @reader.next_byte(source.bytesize)
+        raise SyntaxError unless byte
+      end
+    end
+
+    def trim_trailing_whitespace(source)
+      length = source.bytesize
+      while length.positive? && JSON_WHITESPACE.include?(source.getbyte(length - 1))
+        length -= 1
+      end
+      source.slice!(length, source.bytesize - length) if length < source.bytesize
+      source
+    end
+
+    def ensure_only_trailing_whitespace
+      while (byte = @reader.next_byte)
+        raise SyntaxError unless JSON_WHITESPACE.include?(byte)
+      end
+    end
+
+    class ChunkReader
+      def initialize(input, buffer_tracker)
+        @input = input
+        @buffer_tracker = buffer_tracker
+        @chunk = "".b
+        @offset = 0
+      end
+
+      def next_byte(retained_bytes = 0)
+        return nil unless fill_chunk(retained_bytes)
+
+        byte = @chunk.getbyte(@offset)
+        @offset += 1
+        byte
+      end
+
+      def observe_with(retained_bytes)
+        @buffer_tracker.observe(retained_bytes + @chunk.bytesize)
+      end
+
+      private
+
+      def fill_chunk(retained_bytes)
+        return true if @offset < @chunk.bytesize
+
+        chunk = @input.read(CHUNK_SIZE)
+        return false if chunk.nil? || chunk.empty?
+
+        @chunk = chunk
+        @chunk.force_encoding(Encoding::BINARY)
+        @offset = 0
+        @buffer_tracker.observe(retained_bytes + @chunk.bytesize)
+        true
+      end
+    end
+  end
