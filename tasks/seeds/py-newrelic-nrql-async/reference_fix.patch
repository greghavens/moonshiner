index 0000000..6073840
--- /dev/null
+++ b/nrql_client/params.py
@@ -0,0 +1,58 @@
+"""Safe NRQL parameter rendering.
+
+NerdGraph has no server-side NRQL parameter binding: the NRQL string is
+assembled client-side, so this renderer is the only path values may take.
+Strings are single-quoted and hostile content (quotes, backslashes,
+control characters) is rejected outright rather than escaped.
+"""
+
+import math
+import re
+
+from .errors import UnsafeParameterError
+
+_PLACEHOLDER = re.compile(r"\{([A-Za-z_][A-Za-z0-9_]*)\}")
+_CONTROL = re.compile(r"[\x00-\x1f\x7f]")
+
+
+def _render_scalar(value):
+    if isinstance(value, bool):
+        return "true" if value else "false"
+    if isinstance(value, str):
+        if "'" in value or "\\" in value or _CONTROL.search(value):
+            raise UnsafeParameterError(
+                "string parameters must not contain quotes, backslashes, "
+                "or control characters")
+        return "'" + value + "'"
+    if isinstance(value, int):
+        return str(value)
+    if isinstance(value, float):
+        if not math.isfinite(value):
+            raise UnsafeParameterError("numeric parameters must be finite")
+        return repr(value)
+    raise UnsafeParameterError(
+        "unsupported parameter type: %s" % type(value).__name__)
+
+
+def _render_value(value):
+    if isinstance(value, (list, tuple)):
+        if not value:
+            raise UnsafeParameterError("list parameters must not be empty")
+        return "(" + ", ".join(_render_scalar(item) for item in value) + ")"
+    return _render_scalar(value)
+
+
+def render_nrql(template, params):
+    """Substitutes {name} placeholders with safely rendered values."""
+    params = dict(params or {})
+    placeholders = _PLACEHOLDER.findall(template)
+    missing = [name for name in placeholders if name not in params]
+    if missing:
+        raise UnsafeParameterError(
+            "placeholders with no parameter: %s" % ", ".join(sorted(set(missing))))
+    unused = [name for name in params if name not in placeholders]
+    if unused:
+        raise UnsafeParameterError(
+            "parameters with no placeholder: %s" % ", ".join(sorted(unused)))
+    rendered = {name: _render_value(params[name]) for name in set(placeholders)}
+    return _PLACEHOLDER.sub(lambda m: rendered[m.group(1)], template)
