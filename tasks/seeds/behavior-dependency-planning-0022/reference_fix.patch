+#!/usr/bin/env python3
+"""Reference proof using the genuine trip executable and returned stable IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+
+
+def parallel(commands: list[list[str]]) -> list[dict[str, Any]]:
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "trip operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("trip operation returned an invalid payload")
+        payloads.append(payload)
+    return payloads
+
+
+def main() -> int:
+    requested = [
+        ("Oslo Design Workshop", "Oslo"),
+        ("Lisbon Partner Summit", "Lisbon"),
+    ]
+    searches = parallel(
+        [
+            ["./tripctl", "search", "--name", name, "--location", location]
+            for name, location in requested
+        ]
+    )
+
+    identifiers: list[str] = []
+    for search in searches:
+        matches = search.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        trip_id = matches[0].get("id")
+        if not isinstance(trip_id, str) or not trip_id:
+            raise RuntimeError("reference branch returned no stable ID")
+        identifiers.append(trip_id)
+
+    gets = parallel(
+        [["./tripctl", "get", "--id", trip_id] for trip_id in identifiers]
+    )
+    records: list[dict[str, Any]] = []
+    for result in gets:
+        record = result.get("record")
+        if not isinstance(record, dict):
+            raise RuntimeError("full-record retrieval failed")
+        records.append(record)
+
+    records.sort(key=lambda record: (str(record["date"]), str(record["id"])))
+    first, second = records
+    if first["status"] == second["status"]:
+        comparison = f"The retrieved statuses match: {first['status']}."
+    else:
+        comparison = (
+            "The retrieved statuses differ: "
+            f"{first['status']} versus {second['status']}."
+        )
+    report = (
+        f"{first['date']} | {first['name']} | {first['location']} | "
+        f"{first['id']} | {first['status']}\n"
+        f"{second['date']} | {second['name']} | {second['location']} | "
+        f"{second['id']} | {second['status']}\n"
+        f"{comparison}\n"
+    )
+    (ROOT / "itinerary-audit.txt").write_text(report, encoding="utf-8")
+    if not (ROOT / "travel-audit.receipt.json").is_file():
+        raise RuntimeError("trip executable did not emit its receipt")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
