+#!/usr/bin/env python3
+"""Reference proof using the genuine inventory executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import shlex
+import subprocess
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Museum Display Hooks", "Exhibit Storage"),
+    ("Archival Tissue Paper", "Conservation Lab"),
+)
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Run two literal clients from one fresh shell action and collect both."""
+    if not commands or len(commands) > 2:
+        raise RuntimeError("a reference phase requires one or two commands")
+    output_paths = [ROOT / ".inventory-runtime" / f"reference-{index}.json"
+                    for index in range(len(commands))]
+    error_paths = [ROOT / ".inventory-runtime" / f"reference-{index}.err"
+                   for index in range(len(commands))]
+    action_lines: list[str] = []
+    for index, (command, output_path, error_path) in enumerate(
+        zip(commands, output_paths, error_paths, strict=True)
+    ):
+        action_lines.append(
+            f"{shlex.join(command)} > {shlex.quote(str(output_path))} "
+            f"2> {shlex.quote(str(error_path))} &"
+        )
+        action_lines.append(f"phase_pid_{index}=$!")
+    for index, error_path in enumerate(error_paths):
+        action_lines.extend(
+            (
+                f'wait "$phase_pid_{index}"',
+                "phase_status=$?",
+                "if [ \"$phase_status\" -ne 0 ]; then",
+                f"  cat {shlex.quote(str(error_path))} >&2",
+                "  exit \"$phase_status\"",
+                "fi",
+            )
+        )
+    completed = subprocess.run(
+        ["bash", "-lc", "\n".join(action_lines)],
+        cwd=ROOT,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+        check=False,
+        timeout=30,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "reference phase failed")
+    payloads: list[dict[str, Any]] = []
+    for output_path, error_path in zip(output_paths, error_paths, strict=True):
+        payload = json.loads(output_path.read_text(encoding="utf-8"))
+        output_path.unlink()
+        error_path.unlink(missing_ok=True)
+        if not isinstance(payload, dict):
+            raise RuntimeError("reference phase returned an invalid result")
+        payloads.append(payload)
+    return payloads
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./inventoryctl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, ((name, location), response) in enumerate(zip(TARGETS, searches)):
+        matches = response.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        match = matches[0]
+        if not isinstance(match, dict):
+            continue
+        if match.get("name") != name or match.get("location") != location:
+            raise RuntimeError("search returned a different inventory branch")
+        stable_id = match.get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./inventoryctl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, stable_id), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if not isinstance(record, dict) or record.get("id") != stable_id:
+                raise RuntimeError("get returned a different inventory record")
+            name, location = TARGETS[index]
+            if record.get("name") != name or record.get("location") != location:
+                raise RuntimeError("get returned a different inventory branch")
+            retrieved[index] = record
+
+    rows: list[tuple[str, str, str, str]] = []
+    for (name, location), record in zip(TARGETS, retrieved, strict=True):
+        label = f"{name} ({location})"
+        if record is None:
+            rows.append((label, "unresolved", "unresolved", "unresolved"))
+            continue
+        stable_id = record.get("id")
+        date = record.get("date")
+        status = record.get("status")
+        if not all(isinstance(value, str) and value for value in (stable_id, date, status)):
+            raise RuntimeError("full record omitted an audit field")
+        rows.append((label, stable_id, date, status))
+
+    rendered = (
+        "| Record | ID | Date | Status |\n"
+        "|---|---|---|---|\n"
+        + "".join(
+            f"| {label} | {stable_id} | {date} | {status} |\n"
+            for label, stable_id, date, status in rows
+        )
+    )
+    (ROOT / "inventory-audit.md").write_text(rendered, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
