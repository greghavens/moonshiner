+const CIVIL_DATE = /^\d{4}-\d{2}-\d{2}$/;
+
+// A civil date is a calendar label, not an instant. Parse it as UTC
+// midnight only as an intermediate "wall clock" value for offset math.
+function parseCivilWall(date: string): number {
+  if (!CIVIL_DATE.test(date)) {
+    throw new TypeError(`expected a YYYY-MM-DD civil date, got: ${JSON.stringify(date)}`);
+  }
+  return Date.parse(`${date}T00:00:00Z`);
+}
+
 export function startOfCivilDay(date: string, zone: Zone): number {
-  const wall = Date.parse(date);
-  return wall + zone.offsetMinutes(wall) * 60_000;
+  const wall = parseCivilWall(date);
+  // The offset in force at the resulting instant, not at the wall-clock
+  // value: guess with the wall value, then refine once for DST edges.
+  let utc = wall - zone.offsetMinutes(wall) * 60_000;
+  utc = wall - zone.offsetMinutes(utc) * 60_000;
+  return utc;
 }
 
