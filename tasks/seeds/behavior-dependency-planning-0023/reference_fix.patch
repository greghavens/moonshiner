+#!/usr/bin/env python3
+"""Reference proof using the genuine lodging executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Harborview Workshop Block", "Baltimore"),
+    ("Cedar Court Guest Block", "Richmond"),
+)
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Start every direct client process before collecting any response."""
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    payloads: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "lodging operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("lodging operation returned an invalid payload")
+        payloads.append(payload)
+    return payloads
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./lodgectl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    resolved: list[tuple[int, str]] = []
+    for index, result in enumerate(searches):
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            continue
+        stable_id = matches[0].get("id")
+        if isinstance(stable_id, str) and stable_id:
+            resolved.append((index, stable_id))
+
+    retrieved: list[dict[str, Any] | None] = [None, None]
+    if resolved:
+        results = run_phase(
+            [["./lodgectl", "get", "--id", stable_id] for _, stable_id in resolved]
+        )
+        for (index, _), result in zip(resolved, results, strict=True):
+            record = result.get("record")
+            if isinstance(record, dict):
+                retrieved[index] = record
+
+    rendered: list[str] = []
+    for index, ((name, location), record) in enumerate(zip(TARGETS, retrieved, strict=True)):
+        if record is None:
+            status = "unresolved"
+        else:
+            status_value = record.get("status")
+            if not isinstance(status_value, str):
+                raise RuntimeError("full record returned no status")
+            status = status_value
+        if index == 0:
+            rendered.append(f"- {name} ({location}): {status}")
+            continue
+        if retrieved[0] is None or retrieved[1] is None:
+            comparison = "unavailable"
+        else:
+            comparison = (
+                "same"
+                if retrieved[0]["status"] == retrieved[1]["status"]
+                else "different"
+            )
+        rendered.append(
+            f"- {name} ({location}): {status}; comparison: {comparison}"
+        )
+
+    (ROOT / "lodging-audit.md").write_text(
+        "\n".join(rendered) + "\n",
+        encoding="utf-8",
+    )
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
