+import java.util.regex.Matcher;
+import java.util.regex.Pattern;
+
+/**
+ * Glob matching and rename planning for the media-library batch renamer.
+ * Literal runs are handed to Pattern.quote so regex metacharacters (and
+ * embedded \Q / \E text) never leak into the compiled pattern.
+ */
+public final class GlobRename {
+
+    private GlobRename() {
+    }
+
+    /**
+     * Compiles a glob into an anchored Pattern. Each {@code *} and
+     * {@code ?} becomes a capturing group, numbered left to right.
+     */
+    public static Pattern compile(String glob) {
+        StringBuilder regex = new StringBuilder();
+        StringBuilder literal = new StringBuilder();
+        int i = 0;
+        while (i < glob.length()) {
+            char c = glob.charAt(i);
+            switch (c) {
+                case '*' -> {
+                    flushLiteral(regex, literal);
+                    regex.append("([^/]*)");
+                    i++;
+                }
+                case '?' -> {
+                    flushLiteral(regex, literal);
+                    regex.append("([^/])");
+                    i++;
+                }
+                case '\\' -> {
+                    if (i + 1 >= glob.length()) {
+                        throw new IllegalArgumentException(
+                                "glob ends in a lone backslash: " + glob);
+                    }
+                    literal.append(glob.charAt(i + 1));
+                    i += 2;
+                }
+                default -> {
+                    literal.append(c);
+                    i++;
+                }
+            }
+        }
+        flushLiteral(regex, literal);
+        return Pattern.compile(regex.toString());
+    }
+
+    private static void flushLiteral(StringBuilder regex, StringBuilder literal) {
+        if (literal.length() > 0) {
+            regex.append(Pattern.quote(literal.toString()));
+            literal.setLength(0);
+        }
+    }
+
+    /**
+     * Applies the rename plan: null when the glob does not match name,
+     * otherwise the target with {n} placeholders replaced by the n-th
+     * wildcard capture and every other character taken literally.
+     */
+    public static String rename(String name, String glob, String target) {
+        Matcher matcher = compile(glob).matcher(name);
+        if (!matcher.matches()) {
+            return null;
+        }
+        StringBuilder out = new StringBuilder();
+        int i = 0;
+        while (i < target.length()) {
+            char c = target.charAt(i);
+            if (c == '{') {
+                int close = target.indexOf('}', i + 1);
+                if (close > i + 1 && allAsciiDigits(target, i + 1, close)) {
+                    int group = Integer.parseInt(target.substring(i + 1, close));
+                    if (group < 1 || group > matcher.groupCount()) {
+                        throw new IllegalArgumentException("placeholder {" + group
+                                + "} but the glob has " + matcher.groupCount() + " wildcard(s)");
+                    }
+                    out.append(matcher.group(group));
+                    i = close + 1;
+                    continue;
+                }
+            }
+            out.append(c);
+            i++;
+        }
+        return out.toString();
+    }
+
+    private static boolean allAsciiDigits(String s, int from, int to) {
+        for (int i = from; i < to; i++) {
+            char c = s.charAt(i);
+            if (c < '0' || c > '9') {
+                return false;
+            }
+        }
+        return true;
+    }
+}
