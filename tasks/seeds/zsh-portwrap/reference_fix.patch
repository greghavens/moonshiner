diff --git a/portwrap.zsh b/portwrap.zsh
new file mode 100644
index 0000000..4b164d4
--- /dev/null
+++ b/portwrap.zsh
@@ -0,0 +1,117 @@
+# portwrap.zsh — one home for the stat/sed/date dialect differences between
+# the GNU and BSD userlands our scripts run on.
+#
+# Source this file, then call the helpers. Nothing in here looks at the OS
+# name: each tool is asked once, on first use, which dialect it actually
+# speaks (the tool on PATH is the truth; the platform label is not), and the
+# answer is remembered for the rest of the session. portwrap_reset forgets
+# the cached answers.
+
+typeset -g _portwrap_stat='' _portwrap_sed='' _portwrap_date=''
+
+portwrap_reset() {
+  emulate -L zsh
+  _portwrap_stat=''
+  _portwrap_sed=''
+  _portwrap_date=''
+}
+
+_portwrap_detect_stat() {
+  emulate -L zsh
+  [[ -n $_portwrap_stat ]] && return 0
+  if command stat --version >/dev/null 2>&1; then
+    _portwrap_stat=gnu
+  else
+    _portwrap_stat=bsd
+  fi
+}
+
+_portwrap_detect_sed() {
+  emulate -L zsh
+  [[ -n $_portwrap_sed ]] && return 0
+  if command sed --version >/dev/null 2>&1; then
+    _portwrap_sed=gnu
+  else
+    _portwrap_sed=bsd
+  fi
+}
+
+_portwrap_detect_date() {
+  emulate -L zsh
+  [[ -n $_portwrap_date ]] && return 0
+  if command date -u -d @0 +%s >/dev/null 2>&1; then
+    _portwrap_date=gnu
+  else
+    _portwrap_date=bsd
+  fi
+}
+
+stat_flavor() {
+  emulate -L zsh
+  _portwrap_detect_stat
+  print -r -- "$_portwrap_stat"
+}
+
+sed_flavor() {
+  emulate -L zsh
+  _portwrap_detect_sed
+  print -r -- "$_portwrap_sed"
+}
+
+date_flavor() {
+  emulate -L zsh
+  _portwrap_detect_date
+  print -r -- "$_portwrap_date"
+}
+
+_portwrap_need_file() {
+  emulate -L zsh
+  if [[ ! -f $1 ]]; then
+    print -u2 -r -- "portwrap: no such file: $1"
+    return 1
+  fi
+}
+
+file_mtime_epoch() {
+  emulate -L zsh
+  _portwrap_need_file "$1" || return 1
+  _portwrap_detect_stat
+  case $_portwrap_stat in
+    gnu) command stat -c %Y -- "$1" ;;
+    bsd) command stat -f %m "$1" ;;
+  esac
+}
+
+file_size_bytes() {
+  emulate -L zsh
+  _portwrap_need_file "$1" || return 1
+  _portwrap_detect_stat
+  case $_portwrap_stat in
+    gnu) command stat -c %s -- "$1" ;;
+    bsd) command stat -f %z "$1" ;;
+  esac
+}
+
+sed_inplace() {
+  emulate -L zsh
+  _portwrap_need_file "$2" || return 1
+  _portwrap_detect_sed
+  case $_portwrap_sed in
+    gnu) command sed -i -e "$1" -- "$2" ;;
+    bsd) command sed -i '' -e "$1" "$2" ;;
+  esac
+}
+
+date_from_epoch() {
+  emulate -L zsh
+  if [[ $1 != <-> ]]; then
+    print -u2 -r -- "portwrap: not an epoch: $1"
+    return 1
+  fi
+  local fmt=${2:-%Y-%m-%dT%H:%M:%SZ}
+  _portwrap_detect_date
+  case $_portwrap_date in
+    gnu) command date -u -d "@$1" "+$fmt" ;;
+    bsd) command date -u -r "$1" "+$fmt" ;;
+  esac
+}
