+import java.util.ArrayList;
+import java.util.Collection;
+import java.util.LinkedHashSet;
+import java.util.List;
+import java.util.Set;
+import java.util.TreeSet;
+
+/** 4x4 word-hunt board: tile parsing, path search and scoring. */
+public final class Boggle {
+
+    private static final int SIZE = 4;
+
+    private final String[][] tiles = new String[SIZE][SIZE];
+
+    private Boggle() {}
+
+    /** Parses four rows of four tiles: single letters A-Z (Q only as the "Qu" face). */
+    public static Boggle parse(String text) {
+        List<String> rows = new ArrayList<>();
+        for (String raw : text.split("\n", -1)) {
+            String line = raw.trim();
+            if (!line.isEmpty()) rows.add(line);
+        }
+        if (rows.size() != SIZE) {
+            throw new IllegalArgumentException("expected " + SIZE + " rows, got " + rows.size());
+        }
+        Boggle b = new Boggle();
+        for (int r = 0; r < SIZE; r++) {
+            String[] toks = rows.get(r).split("\\s+");
+            if (toks.length != SIZE) {
+                throw new IllegalArgumentException("row " + (r + 1) + " has " + toks.length + " tiles");
+            }
+            for (int c = 0; c < SIZE; c++) {
+                String t = toks[c];
+                boolean plain = t.length() == 1 && t.charAt(0) >= 'A' && t.charAt(0) <= 'Z'
+                        && t.charAt(0) != 'Q';
+                if (!plain && !t.equals("Qu")) {
+                    throw new IllegalArgumentException("bad tile: " + t);
+                }
+                b.tiles[r][c] = t.equals("Qu") ? "QU" : t;
+            }
+        }
+        return b;
+    }
+
+    /** Loads a word list: one word per line, uppercased, blanks skipped. */
+    public static List<String> dictionary(String text) {
+        List<String> words = new ArrayList<>();
+        for (String raw : text.split("\n", -1)) {
+            String w = raw.trim();
+            if (!w.isEmpty()) words.add(w.toUpperCase());
+        }
+        return words;
+    }
+
+    /** True when the word can be traced through adjacent tiles, no tile reused. */
+    public boolean contains(String word) {
+        String target = word.toUpperCase();
+        if (target.isEmpty()) return false;
+        boolean[][] used = new boolean[SIZE][SIZE];
+        for (int r = 0; r < SIZE; r++) {
+            for (int c = 0; c < SIZE; c++) {
+                if (dfs(target, 0, r, c, used)) return true;
+            }
+        }
+        return false;
+    }
+
+    private boolean dfs(String target, int at, int r, int c, boolean[][] used) {
+        String tile = tiles[r][c];
+        if (!target.regionMatches(at, tile, 0, tile.length())) return false;
+        int next = at + tile.length();
+        if (next == target.length()) return true;
+        used[r][c] = true;
+        for (int dr = -1; dr <= 1; dr++) {
+            for (int dc = -1; dc <= 1; dc++) {
+                int nr = r + dr, nc = c + dc;
+                if ((dr == 0 && dc == 0) || nr < 0 || nr >= SIZE || nc < 0 || nc >= SIZE) continue;
+                if (!used[nr][nc] && dfs(target, next, nr, nc, used)) {
+                    used[r][c] = false;
+                    return true;
+                }
+            }
+        }
+        used[r][c] = false;
+        return false;
+    }
+
+    /** All distinct dictionary words of length >= 3 on the board, sorted. */
+    public List<String> findAll(Collection<String> words) {
+        Set<String> found = new TreeSet<>();
+        Set<String> candidates = new LinkedHashSet<>();
+        for (String w : words) candidates.add(w.toUpperCase());
+        for (String w : candidates) {
+            if (w.length() >= 3 && contains(w)) found.add(w);
+        }
+        return new ArrayList<>(found);
+    }
+
+    /** Standard length scoring: 3-4 -> 1, 5 -> 2, 6 -> 3, 7 -> 5, 8+ -> 11. */
+    public static int score(String word) {
+        int n = word.length();
+        if (n < 3) return 0;
+        if (n <= 4) return 1;
+        if (n == 5) return 2;
+        if (n == 6) return 3;
+        if (n == 7) return 5;
+        return 11;
+    }
+
+    public int totalScore(Collection<String> words) {
+        int total = 0;
+        for (String w : findAll(words)) total += score(w);
+        return total;
+    }
+
+    /** One line per found word ("WORD score"), then the total. */
+    public String report(Collection<String> words) {
+        StringBuilder sb = new StringBuilder();
+        int total = 0;
+        for (String w : findAll(words)) {
+            sb.append(w).append(' ').append(score(w)).append('\n');
+            total += score(w);
+        }
+        sb.append("total ").append(total).append('\n');
+        return sb.toString();
+    }
+}
