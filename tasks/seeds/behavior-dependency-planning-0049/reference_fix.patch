+#!/usr/bin/env python3
+"""Reference proof using the genuine account executable and returned IDs."""
+
+from __future__ import annotations
+
+import json
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+TARGETS = (
+    ("Elm Learning Network", "Northeast Region"),
+    ("Frost Community Health", "Mountain Region"),
+)
+PHASE_WORKER = r"""
+import json
+import subprocess
+import sys
+
+commands = json.loads(sys.argv[1])
+processes = [
+    subprocess.Popen(
+        command,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    for command in commands
+]
+outputs = []
+for process in processes:
+    stdout, stderr = process.communicate(timeout=15)
+    if process.returncode != 0:
+        raise RuntimeError(stderr.strip() or "account operation failed")
+    outputs.append(json.loads(stdout))
+print(json.dumps(outputs))
+"""
+
+
+def run_phase(commands: list[list[str]]) -> list[dict[str, Any]]:
+    """Give each phase its own parent while overlapping its direct clients."""
+    completed = subprocess.run(
+        [sys.executable, "-B", "-c", PHASE_WORKER, json.dumps(commands)],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=20,
+    )
+    if completed.returncode != 0:
+        raise RuntimeError(completed.stderr.strip() or "account phase failed")
+    payload = json.loads(completed.stdout)
+    if not isinstance(payload, list) or len(payload) != len(commands):
+        raise RuntimeError("account phase returned an invalid payload")
+    return payload
+
+
+def main() -> int:
+    searches = run_phase(
+        [
+            ["./accountctl", "search", "--name", name, "--location", location]
+            for name, location in TARGETS
+        ]
+    )
+
+    identifiers: list[str] = []
+    for (name, location), search in zip(TARGETS, searches, strict=True):
+        matches = search.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference branch did not resolve uniquely")
+        match = matches[0]
+        if not isinstance(match, dict):
+            raise RuntimeError("search returned an invalid match")
+        if match.get("name") != name or match.get("location") != location:
+            raise RuntimeError("search returned a different account branch")
+        stable_id = match.get("id")
+        if not isinstance(stable_id, str) or not stable_id:
+            raise RuntimeError("reference branch returned no stable ID")
+        identifiers.append(stable_id)
+
+    gets = run_phase(
+        [["./accountctl", "get", "--id", stable_id] for stable_id in identifiers]
+    )
+    records: list[dict[str, Any]] = []
+    for stable_id, result in zip(identifiers, gets, strict=True):
+        record = result.get("record")
+        if not isinstance(record, dict) or record.get("id") != stable_id:
+            raise RuntimeError("full-record retrieval failed")
+        records.append(record)
+
+    earlier, later = sorted(
+        records,
+        key=lambda record: (record["date"], record["id"]),
+    )
+    report = (
+        f"{earlier['date']} | {earlier['name']} | {earlier['location']} | "
+        f"{earlier['id']} | {earlier['status']}\n"
+        f"{later['date']} | {later['name']} | {later['location']} | "
+        f"{later['id']} | {later['status']}\n"
+        f"Status comparison: earlier is {earlier['status']}; "
+        f"later is {later['status']}.\n"
+    )
+    (ROOT / "account-audit.txt").write_text(report, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
