+"""GNU-style unified diff generator (no difflib)."""
+
+
+def _opcodes(a, b):
+    """LCS alignment as [tag, i1, i2, j1, j2] runs.
+
+    Ties prefer consuming from `a`, so deletions always precede the
+    insertions that replace them.
+    """
+    n, m = len(a), len(b)
+    table = [[0] * (m + 1) for _ in range(n + 1)]
+    for i in range(n - 1, -1, -1):
+        row, below = table[i], table[i + 1]
+        for j in range(m - 1, -1, -1):
+            if a[i] == b[j]:
+                row[j] = below[j + 1] + 1
+            else:
+                row[j] = below[j] if below[j] >= row[j + 1] else row[j + 1]
+
+    codes = []
+
+    def emit(tag, di, dj):
+        if codes and codes[-1][0] == tag:
+            codes[-1][2] += di
+            codes[-1][4] += dj
+        else:
+            codes.append([tag, i, i + di, j, j + dj])
+
+    i = j = 0
+    while i < n and j < m:
+        if a[i] == b[j]:
+            emit("equal", 1, 1)
+            i += 1
+            j += 1
+        elif table[i + 1][j] >= table[i][j + 1]:
+            emit("delete", 1, 0)
+            i += 1
+        else:
+            emit("insert", 0, 1)
+            j += 1
+    if i < n:
+        emit("delete", n - i, 0)
+        i = n
+    if j < m:
+        emit("insert", 0, m - j)
+    return codes
+
+
+def _grouped(codes, n):
+    """Split opcodes into hunk groups, keeping n lines of context."""
+    if not codes:
+        return
+    codes = [list(c) for c in codes]
+    if codes[0][0] == "equal":
+        tag, i1, i2, j1, j2 = codes[0]
+        codes[0] = [tag, max(i1, i2 - n), i2, max(j1, j2 - n), j2]
+    if codes[-1][0] == "equal":
+        tag, i1, i2, j1, j2 = codes[-1]
+        codes[-1] = [tag, i1, min(i2, i1 + n), j1, min(j2, j1 + n)]
+
+    group = []
+    for tag, i1, i2, j1, j2 in codes:
+        if tag == "equal" and i2 - i1 > 2 * n and group:
+            group.append(("equal", i1, min(i2, i1 + n), j1, min(j2, j1 + n)))
+            yield group
+            group = []
+            i1, j1 = max(i1, i2 - n), max(j1, j2 - n)
+        group.append((tag, i1, i2, j1, j2))
+    if group and any(tag != "equal" for tag, *_ in group):
+        yield group
+
+
+def _fmt_range(start, count):
+    """0-based start + count -> the '-l,c' payload (1-based, GNU quirks)."""
+    if count == 1:
+        return str(start + 1)
+    if count == 0:
+        return f"{start},0"
+    return f"{start + 1},{count}"
+
+
+def unified_diff(a, b, from_label, to_label, context=3):
+    """Unified diff between two lists of lines (newline-free in and out)."""
+    if context < 0:
+        raise ValueError(f"context must be >= 0, got {context}")
+    groups = list(_grouped(_opcodes(a, b), context))
+    if not groups:
+        return []
+    out = [f"--- {from_label}", f"+++ {to_label}"]
+    for group in groups:
+        i1, i2 = group[0][1], group[-1][2]
+        j1, j2 = group[0][3], group[-1][4]
+        out.append(f"@@ -{_fmt_range(i1, i2 - i1)} +{_fmt_range(j1, j2 - j1)} @@")
+        for tag, gi1, gi2, gj1, gj2 in group:
+            if tag == "equal":
+                out.extend(" " + line for line in a[gi1:gi2])
+            elif tag == "delete":
+                out.extend("-" + line for line in a[gi1:gi2])
+            else:
+                out.extend("+" + line for line in b[gj1:gj2])
+    return out
