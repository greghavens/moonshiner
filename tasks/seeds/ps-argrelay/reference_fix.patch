diff --git a/relay.ps1 b/relay.ps1
new file mode 100644
index 0000000..1ee1e32
--- /dev/null
+++ b/relay.ps1
@@ -0,0 +1,37 @@
+# relay.ps1 — run a child pwsh script and prove what was forwarded to it.
+# No param() block on purpose: the relay must never eat a forwarded value
+# that happens to look like a parameter (-Verbose, --target=web1, ...).
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if ($args.Count -lt 2) {
+    [Console]::Error.WriteLine('relay: usage: relay.ps1 <report> <child.ps1> [args...]')
+    exit 64
+}
+
+$report = [string]$args[0]
+$child = [string]$args[1]
+$forward = [string[]]@(if ($args.Count -gt 2) { $args[2..($args.Count - 1)] } else { @() })
+
+if (-not (Test-Path -LiteralPath $child -PathType Leaf)) {
+    [Console]::Error.WriteLine("relay: no such script: $child")
+    exit 65
+}
+
+$manifest = @("argc=$($forward.Count)")
+for ($i = 0; $i -lt $forward.Count; $i++) {
+    $manifest += ('[{0}] {1}:{2}' -f $i, $forward[$i].Length, $forward[$i])
+}
+
+$reportPath = if ([System.IO.Path]::IsPathRooted($report)) {
+    $report
+} else {
+    Join-Path (Get-Location).Path $report
+}
+[System.IO.File]::WriteAllText($reportPath, ($manifest -join "`n") + "`n")
+
+& pwsh -NoProfile -NonInteractive -File $child @forward
+$childExit = $LASTEXITCODE
+
+[System.IO.File]::AppendAllText($reportPath, "exit=$childExit`n")
+exit $childExit
