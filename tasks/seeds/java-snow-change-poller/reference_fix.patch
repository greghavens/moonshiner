+import java.io.IOException;
+import java.util.ArrayList;
+import java.util.List;
+import java.util.function.IntConsumer;
+
+/**
+ * Polls approved change requests updated strictly after a checkpoint.
+ *
+ * Query and option contract per docs/contract.json (current Table API docs):
+ * raw values (sysparm_display_value=false), reference links excluded
+ * (sysparm_exclude_reference_link=true), ordered by sys_updated_on so the
+ * offset scan is stable. The checkpoint only advances after a complete scan;
+ * on 401/403 or an exhausted 429 the records collected so far are returned
+ * with the old checkpoint.
+ */
+public class ChangePoller {
+
+    private static final String TABLE = "change_request";
+    private static final int MAX_RETRIES = 3;
+    private static final List<String> FIELDS = List.of(
+            "sys_id", "number", "short_description",
+            "assignment_group", "approval", "sys_updated_on");
+
+    private final SnowTableClient client;
+    private final int pageSize;
+    private final IntConsumer sleeper;
+
+    public ChangePoller(SnowTableClient client, int pageSize, IntConsumer sleeper) {
+        this.client = client;
+        this.pageSize = pageSize;
+        this.sleeper = sleeper;
+    }
+
+    public PollResult poll(String checkpoint)
+            throws SnowApiException, IOException, InterruptedException {
+        String query = "approval=approved^sys_updated_on>" + checkpoint
+                + "^ORDERBYsys_updated_on";
+        List<ChangeRecord> collected = new ArrayList<>();
+        int offset = 0;
+        while (true) {
+            SnowTableClient.Page page;
+            int retries = 0;
+            while (true) {
+                try {
+                    page = client.fetchPage(TABLE, query, FIELDS,
+                            pageSize, offset, false, true);
+                    break;
+                } catch (SnowApiException e) {
+                    if (e.statusCode == 401) {
+                        return new PollResult(collected, checkpoint, false, "UNAUTHORIZED");
+                    }
+                    if (e.statusCode == 403) {
+                        return new PollResult(collected, checkpoint, false, "FORBIDDEN");
+                    }
+                    if (e.statusCode == 429) {
+                        if (retries >= MAX_RETRIES) {
+                            return new PollResult(collected, checkpoint, false, "RATE_LIMITED");
+                        }
+                        retries++;
+                        sleeper.accept(e.retryAfter > 0 ? e.retryAfter : 1);
+                        continue;
+                    }
+                    throw e;
+                }
+            }
+            for (var raw : page.records) {
+                collected.add(ChangeRecord.from(raw));
+            }
+            if (page.records.size() < pageSize) {
+                break;
+            }
+            offset += pageSize;
+        }
+        String advanced = checkpoint;
+        for (ChangeRecord r : collected) {
+            if (r.sysUpdatedOn.compareTo(advanced) > 0) {
+                advanced = r.sysUpdatedOn;
+            }
+        }
+        return new PollResult(collected, advanced, true, null);
+    }
+}
