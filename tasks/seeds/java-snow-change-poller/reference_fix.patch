@@ -0,0 +1,18 @@
+import java.util.Collections;
+import java.util.List;
+
+/** Outcome of one ChangePoller scan. */
+public final class PollResult {
+    public final List<ChangeRecord> records;
+    public final String checkpoint;
+    public final boolean complete;
+    public final String failure; // null, "UNAUTHORIZED", "FORBIDDEN" or "RATE_LIMITED"
+
+    public PollResult(List<ChangeRecord> records, String checkpoint,
+                      boolean complete, String failure) {
+        this.records = Collections.unmodifiableList(records);
+        this.checkpoint = checkpoint;
+        this.complete = complete;
+        this.failure = failure;
+    }
+}
