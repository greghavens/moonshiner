@@ -0,0 +1,209 @@
+"""Klondike solitaire engine (draw-3) dealt from a fixture deck file."""
+import sys
+
+RANKS = "A23456789TJQK"
+SUITS = "SHDC"
+RED = "HD"
+
+
+class IllegalMove(Exception):
+    pass
+
+
+def _rank(card):
+    return RANKS.index(card[0]) + 1
+
+
+def _is_red(card):
+    return card[1] in RED
+
+
+class Game:
+    def __init__(self, lines):
+        cards = [ln.strip().upper() for ln in lines if ln.strip()]
+        if len(cards) != 52:
+            raise ValueError(f"deck must hold 52 cards, got {len(cards)}")
+        for card in cards:
+            if len(card) != 2 or card[0] not in RANKS or card[1] not in SUITS:
+                raise ValueError(f"bad card {card!r}")
+        if len(set(cards)) != 52:
+            raise ValueError("duplicate card in deck")
+        # row-major deal: row r drops one card on each of piles r..6;
+        # the last card a pile receives is its face-up top.
+        self.tableau = [[] for _ in range(7)]
+        it = iter(cards[:28])
+        for row in range(7):
+            for pile in range(row, 7):
+                self.tableau[pile].append([next(it), False])
+        for pile in self.tableau:
+            pile[-1][1] = True
+        self.stock = list(cards[28:])       # stock[0] is drawn first
+        self.waste = []                     # waste[-1] is the playable top
+        self.foundations = {s: [] for s in SUITS}
+
+    # -- helpers ---------------------------------------------------------
+    @property
+    def stock_count(self):
+        return len(self.stock)
+
+    @property
+    def won(self):
+        return all(len(f) == 13 for f in self.foundations.values())
+
+    def _fits_foundation(self, card):
+        return _rank(card) == len(self.foundations[card[1]]) + 1
+
+    def _fits_tableau(self, card, pile):
+        if not pile:
+            return card[0] == "K"
+        top, face_up = pile[-1]
+        return (face_up and _is_red(card) != _is_red(top)
+                and _rank(card) + 1 == _rank(top))
+
+    def _flip(self, pile):
+        if pile and not pile[-1][1]:
+            pile[-1][1] = True
+
+    # -- moves -----------------------------------------------------------
+    def draw(self):
+        """Flip up to three stock cards onto the waste; recycle when empty."""
+        if not self.stock:
+            if not self.waste:
+                raise IllegalMove("nothing to draw")
+            self.stock = self.waste          # turning the waste over restores
+            self.waste = []                  # the original draw order
+        taken = self.stock[:3]
+        del self.stock[:3]
+        self.waste.extend(taken)
+
+    def move(self, src, dst, count=1):
+        if src != "w" and not (len(src) == 2 and src[0] == "t"
+                               and src[1] in "1234567"):
+            raise ValueError(f"bad source {src!r}")
+        if dst != "f" and not (len(dst) == 2 and dst[0] == "t"
+                               and dst[1] in "1234567"):
+            raise ValueError(f"bad destination {dst!r}")
+        if count < 1:
+            raise ValueError("count must be positive")
+        if count != 1 and (src == "w" or dst == "f"):
+            raise IllegalMove("can only move one card there")
+        if src == "w":
+            if not self.waste:
+                raise IllegalMove("waste is empty")
+            card = self.waste[-1]
+            if dst == "f":
+                if not self._fits_foundation(card):
+                    raise IllegalMove(f"{card} does not fit its foundation")
+                self.foundations[card[1]].append(self.waste.pop())
+            else:
+                pile = self.tableau[int(dst[1]) - 1]
+                if not self._fits_tableau(card, pile):
+                    raise IllegalMove(f"{card} does not fit on {dst}")
+                pile.append([self.waste.pop(), True])
+            return
+        pile = self.tableau[int(src[1]) - 1]
+        if not pile:
+            raise IllegalMove(f"{src} is empty")
+        if dst == "f":
+            card, _ = pile[-1]
+            if not self._fits_foundation(card):
+                raise IllegalMove(f"{card} does not fit its foundation")
+            self.foundations[card[1]].append(pile.pop()[0])
+            self._flip(pile)
+            return
+        if dst == src:
+            raise IllegalMove("source and destination are the same pile")
+        face_up = sum(1 for _, up in pile if up)
+        if count > face_up:
+            raise IllegalMove("cannot move face-down cards")
+        block = pile[-count:]
+        target = self.tableau[int(dst[1]) - 1]
+        if not self._fits_tableau(block[0][0], target):
+            raise IllegalMove(f"{block[0][0]} does not fit on {dst}")
+        del pile[-count:]
+        target.extend(block)
+        self._flip(pile)
+
+    def auto(self):
+        """Send every eligible top card to its foundation: waste first, then
+        piles left to right, restarting after each move. Returns the moves."""
+        moves = []
+        while True:
+            if self.waste and self._fits_foundation(self.waste[-1]):
+                card = self.waste.pop()
+                self.foundations[card[1]].append(card)
+                moves.append(("w", card))
+                continue
+            for i, pile in enumerate(self.tableau):
+                if pile and self._fits_foundation(pile[-1][0]):
+                    card = pile.pop()[0]
+                    self.foundations[card[1]].append(card)
+                    self._flip(pile)
+                    moves.append((f"t{i + 1}", card))
+                    break
+            else:
+                return moves
+
+    # -- rendering -------------------------------------------------------
+    def render(self):
+        tail = self.waste[-3:]
+        waste = " ".join(tail) if tail else "-"
+        lines = [f"stock:{len(self.stock)} waste:{waste}"]
+        tops = " ".join(
+            f"{s}:{self.foundations[s][-1][0] if self.foundations[s] else '-'}"
+            for s in SUITS)
+        lines.append(f"F: {tops}")
+        for i, pile in enumerate(self.tableau):
+            cells = " ".join(card if up else "#" for card, up in pile)
+            lines.append(f"t{i + 1}: {cells or '-'}")
+        return "\n".join(lines)
+
+
+def load(path):
+    with open(path, encoding="utf-8") as fh:
+        return Game(fh.read().splitlines())
+
+
+def main(argv=None):
+    argv = sys.argv if argv is None else argv
+    if len(argv) != 2:
+        print("usage: klondike.py DECKFILE", file=sys.stderr)
+        return 2
+    game = load(argv[1])
+    print(game.render())
+    for raw in sys.stdin:
+        parts = raw.split()
+        if parts == ["q"]:
+            return 0
+        try:
+            if parts == ["draw"]:
+                game.draw()
+            elif parts == ["auto"]:
+                for src, card in game.auto():
+                    print(f"auto: {src} {card}")
+            elif len(parts) in (3, 4) and parts[0] == "move":
+                count = 1
+                if len(parts) == 4:
+                    if not parts[3].isdigit():
+                        print("bad command")
+                        continue
+                    count = int(parts[3])
+                game.move(parts[1], parts[2], count)
+            else:
+                print("bad command")
+                continue
+        except IllegalMove:
+            print("illegal move")
+            continue
+        except ValueError:
+            print("bad command")
+            continue
+        print(game.render())
+        if game.won:
+            print("you win")
+            return 0
+    return 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
