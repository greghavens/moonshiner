+package quota
+
+import "time"
+
+// periodKey identifies the UTC calendar month a moment belongs to. Usage
+// counters live and die with their period key.
+func periodKey(t time.Time) string {
+	return t.UTC().Format("2006-01")
+}
+
+// syncPeriod lazily rolls the account into the current period: if the clock
+// has entered a new UTC month since the account was last touched, its
+// counters reset. Caller holds the service lock.
+func (s *Service) syncPeriod(a *account) {
+	key := periodKey(s.now())
+	if a.period != key {
+		a.period = key
+		a.usage = make(map[string]int64)
+	}
+}
diff --git a/plan.go b/plan.go
new file mode 100644
index 0000000..370abbf
--- /dev/null
+++ b/plan.go
@@ -0,0 +1,81 @@
+// Package quota is an embeddable entitlement service: plans define
+// per-metric monthly limits, accounts meter usage against them, and overage
+// policies decide whether a request past the limit is blocked or allowed
+// with a flag for billing.
+package quota
+
+import (
+	"errors"
+	"fmt"
+)
+
+// OveragePolicy selects what happens when a request would exceed a limit.
+type OveragePolicy int
+
+const (
+	// OverageBlock refuses the whole request; the meter is untouched.
+	OverageBlock OveragePolicy = iota
+	// OverageAllowFlagged lets the request through, keeps counting past the
+	// limit, and flags the decision so overage can be invoiced.
+	OverageAllowFlagged
+)
+
+// Plan is a named set of per-metric limits and overage policies. Metrics
+// absent from Limits are unlimited; metrics absent from Overage block.
+type Plan struct {
+	Name    string
+	Limits  map[string]int64
+	Overage map[string]OveragePolicy
+}
+
+// DefinePlan registers a plan. Plans are immutable once defined.
+func (s *Service) DefinePlan(p Plan) error {
+	if p.Name == "" {
+		return errors.New("quota: plan name must not be empty")
+	}
+	for metric, limit := range p.Limits {
+		if limit < 0 {
+			return fmt.Errorf("quota: plan %q: metric %q has negative limit %d", p.Name, metric, limit)
+		}
+	}
+	for metric, pol := range p.Overage {
+		if pol != OverageBlock && pol != OverageAllowFlagged {
+			return fmt.Errorf("quota: plan %q: metric %q has unknown overage policy %d", p.Name, metric, pol)
+		}
+	}
+
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if _, exists := s.plans[p.Name]; exists {
+		return fmt.Errorf("quota: plan %q is already defined", p.Name)
+	}
+	s.plans[p.Name] = clonePlan(p)
+	return nil
+}
+
+// clonePlan deep-copies p so later caller mutations can't change the
+// registered definition.
+func clonePlan(p Plan) Plan {
+	out := Plan{Name: p.Name}
+	if p.Limits != nil {
+		out.Limits = make(map[string]int64, len(p.Limits))
+		for k, v := range p.Limits {
+			out.Limits[k] = v
+		}
+	}
+	if p.Overage != nil {
+		out.Overage = make(map[string]OveragePolicy, len(p.Overage))
+		for k, v := range p.Overage {
+			out.Overage[k] = v
+		}
+	}
+	return out
+}
+
+// policyFor returns the plan's overage policy for metric (default: block).
+func (p Plan) policyFor(metric string) OveragePolicy {
+	if pol, ok := p.Overage[metric]; ok {
+		return pol
+	}
+	return OverageBlock
+}
