+"""Credential handling for the Deskline client."""
+
+
+class ApiKeyAuth:
+    def __init__(self, api_key):
+        self.api_key = api_key
+
+    def headers(self):
+        """Auth headers for one request -- a fresh dict every call, so no
+        caller can mutate shared state behind another caller's back."""
+        return {"X-Api-Key": self.api_key}
