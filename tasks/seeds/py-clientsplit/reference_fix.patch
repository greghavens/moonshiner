+"""Deskline domain resources, programmed against an injectable transport.
+
+Any object with `request(method, path, headers=None, json_body=None)`
+returning `(status, body)` works as a transport -- the real UrllibTransport
+or a scripted fake in tests.
+"""
+
+
+class ApiError(Exception):
+    """A Deskline error response, decoded from their error envelope."""
+
+    def __init__(self, code, message, status):
+        super().__init__("%s: %s (HTTP %d)" % (code, message, status))
+        self.code = code
+        self.message = message
+        self.status = status
+
+
+class AuthError(ApiError):
+    """A 401 -- the key is wrong, revoked, or missing."""
+
+
+class TicketsApi:
+    def __init__(self, transport, auth):
+        self._transport = transport
+        self._auth = auth
+
+    def _call(self, method, path, json_body=None):
+        status, body = self._transport.request(
+            method, path, headers=self._auth.headers(), json_body=json_body
+        )
+        if status >= 400:
+            err = (body or {}).get("error", {})
+            code = err.get("code", "error")
+            message = err.get("message", "")
+            if status == 401:
+                raise AuthError(code, message, status)
+            raise ApiError(code, message, status)
+        return body
+
+    def get(self, ticket_id):
+        """Fetch one ticket; None when Deskline has no such ticket."""
+        try:
+            return self._call("GET", "/tickets/%s" % ticket_id)
+        except AuthError:
+            raise
+        except ApiError as e:
+            if e.status == 404:
+                return None
+            raise
+
+    def create(self, subject, body, priority="normal"):
+        if not subject or not subject.strip():
+            raise ValueError("subject must not be empty")
+        if priority not in ("low", "normal", "high"):
+            raise ValueError("unknown priority: %r" % (priority,))
+        return self._call(
+            "POST", "/tickets",
+            {"subject": subject, "body": body, "priority": priority},
+        )
+
+    def close(self, ticket_id, resolution):
+        return self._call(
+            "POST", "/tickets/%s/close" % ticket_id, {"resolution": resolution}
+        )
+
+    def list_open(self):
+        body = self._call("GET", "/tickets?state=open")
+        return (body or {}).get("tickets", [])
