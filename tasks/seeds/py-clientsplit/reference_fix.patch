+"""Layered Deskline API client.
+
+- client.transport -- plain HTTP, no auth, no status-code opinions
+- client.auth      -- credential headers
+- client.resources -- domain calls + the API error types
+"""
+from client.auth import ApiKeyAuth
+from client.resources import ApiError, AuthError, TicketsApi
+from client.transport import TransportError, UrllibTransport
+
+__all__ = [
+    "ApiError", "ApiKeyAuth", "AuthError", "TicketsApi",
+    "TransportError", "UrllibTransport",
+]
