+"""HTTP transport for the Deskline client: bytes in, parsed JSON out.
+
+The transport has exactly one job. It never inspects status codes beyond
+handing them back, attaches no credentials, and raises only for
+socket-level trouble.
+"""
+import json
+import socket
+import urllib.error
+import urllib.request
+
+
+class TransportError(Exception):
+    """Connection-level failure: refused, unreachable, timed out."""
+
+
+class UrllibTransport:
+    def __init__(self, base_url, timeout=10):
+        self.base_url = base_url.rstrip("/")
+        self.timeout = timeout
+
+    def request(self, method, path, headers=None, json_body=None):
+        """Perform one HTTP exchange; returns (status, parsed_body_or_None)."""
+        url = self.base_url + path
+        send_headers = {"Accept": "application/json"}
+        send_headers.update(headers or {})
+        data = None
+        if json_body is not None:
+            data = json.dumps(json_body).encode("utf-8")
+            send_headers["Content-Type"] = "application/json"
+        req = urllib.request.Request(url, data=data, headers=send_headers, method=method)
+        try:
+            with urllib.request.urlopen(req, timeout=self.timeout) as resp:
+                status = resp.status
+                raw = resp.read()
+        except urllib.error.HTTPError as e:
+            # an HTTP status is an answer, not an exception, at this layer
+            status = e.code
+            raw = e.read()
+        except (urllib.error.URLError, socket.timeout, OSError) as e:
+            raise TransportError("request to %s failed: %s" % (url, e)) from e
+        body = json.loads(raw.decode("utf-8")) if raw else None
+        return status, body
