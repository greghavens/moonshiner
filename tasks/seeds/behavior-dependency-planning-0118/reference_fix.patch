diff --git a/reconcile_telecom.sh b/reconcile_telecom.sh
new file mode 100755
--- /dev/null
+++ b/reconcile_telecom.sh
@@ -0,0 +1,145 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+run_dir="$(mktemp -d)"
+trap 'rm -rf -- "$run_dir"' EXIT
+
+./telecomctl search \
+  --name 'Library hotspot plan' \
+  --location 'Studio Account' >"$run_dir/library-search.json" &
+library_search_pid=$!
+./telecomctl search \
+  --name 'Workshop phone line' \
+  --location 'Field Office' >"$run_dir/workshop-search.json" &
+workshop_search_pid=$!
+wait "$library_search_pid"
+wait "$workshop_search_pid"
+
+unique_id() {
+  python3 - "$1" "$2" "$3" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+matches = result.get("matches")
+if not isinstance(matches, list) or len(matches) != 1:
+    raise SystemExit("search did not return exactly one match")
+match = matches[0]
+if (
+    not isinstance(match, dict)
+    or match.get("name") != sys.argv[2]
+    or match.get("location") != sys.argv[3]
+    or not isinstance(match.get("id"), str)
+    or not match["id"]
+):
+    raise SystemExit("search match was incomplete or incorrectly scoped")
+print(match["id"])
+PY
+}
+
+library_id="$(unique_id \
+  "$run_dir/library-search.json" \
+  'Library hotspot plan' \
+  'Studio Account')"
+workshop_id="$(unique_id \
+  "$run_dir/workshop-search.json" \
+  'Workshop phone line' \
+  'Field Office')"
+
+./telecomctl get --id "$library_id" >"$run_dir/library-get.json" &
+library_get_pid=$!
+./telecomctl get --id "$workshop_id" >"$run_dir/workshop-get.json" &
+workshop_get_pid=$!
+wait "$library_get_pid"
+wait "$workshop_get_pid"
+
+record_status() {
+  python3 - "$1" "$2" "$3" "$4" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+record = result.get("record")
+if (
+    not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("name") != sys.argv[3]
+    or record.get("location") != sys.argv[4]
+    or not isinstance(record.get("status"), str)
+):
+    raise SystemExit("retrieved record was incomplete or mismatched")
+print(record["status"])
+PY
+}
+
+record_status \
+  "$run_dir/library-get.json" \
+  "$library_id" \
+  'Library hotspot plan' \
+  'Studio Account' >/dev/null
+workshop_status="$(record_status \
+  "$run_dir/workshop-get.json" \
+  "$workshop_id" \
+  'Workshop phone line' \
+  'Field Office')"
+
+action='left unchanged'
+final_status="$workshop_status"
+if [[ "$workshop_status" == 'pending-activation' ]]; then
+  ./telecomctl update \
+    --id "$workshop_id" \
+    --status 'review-required' >"$run_dir/update.json"
+  final_status="$(python3 - "$run_dir/update.json" "$workshop_id" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    result = json.load(stream)
+record = result.get("record")
+if (
+    result.get("updated") != 1
+    or result.get("before_status") != "pending-activation"
+    or not isinstance(record, dict)
+    or record.get("id") != sys.argv[2]
+    or record.get("status") != "review-required"
+):
+    raise SystemExit("conditional update did not succeed as requested")
+print(record["status"])
+PY
+)"
+  action='changed'
+fi
+
+python3 - \
+  "$run_dir/library-get.json" \
+  "$run_dir/workshop-get.json" \
+  "$action" \
+  "$final_status" <<'PY'
+import json
+import sys
+
+with open(sys.argv[1], encoding="utf-8") as stream:
+    library = json.load(stream)["record"]
+with open(sys.argv[2], encoding="utf-8") as stream:
+    workshop = json.load(stream)["record"]
+
+def field(record, key):
+    value = record.get(key)
+    return str(value) if value not in (None, "") else "unknown"
+
+print(
+    "Library hotspot plan: "
+    f"id={field(library, 'id')}; name={field(library, 'name')}; "
+    f"location={field(library, 'location')}; status={field(library, 'status')}; "
+    f"activation_date={field(library, 'activation_date')}"
+)
+print(
+    "Workshop phone line: "
+    f"id={field(workshop, 'id')}; name={field(workshop, 'name')}; "
+    f"location={field(workshop, 'location')}; status={field(workshop, 'status')}; "
+    f"activation_date={field(workshop, 'activation_date')}"
+)
+print(f"Result: {sys.argv[3]}; final_status={sys.argv[4]}")
+PY
