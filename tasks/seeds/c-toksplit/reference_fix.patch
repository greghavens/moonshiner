diff --git a/tok.c b/tok.c
new file mode 100644
index 0000000..914f9c9
--- /dev/null
+++ b/tok.c
@@ -0,0 +1,97 @@
+#include "tok.h"
+
+static int is_ws(char c) {
+    return c == ' ' || c == '\t' || c == '\n' || c == '\r';
+}
+
+void tok_init(tok_state *st) {
+    st->pos = 0;
+}
+
+/* Append one byte to out, respecting the outsz bound (room for the NUL). */
+static int put(char *out, size_t outsz, size_t *o, char c) {
+    if (*o + 1 >= outsz)
+        return -1;
+    out[*o] = c;
+    (*o)++;
+    return 0;
+}
+
+int tok_next(tok_state *st, const char *input, char *out, size_t outsz) {
+    if (outsz == 0)
+        return -1;
+    out[0] = '\0';
+
+    size_t i = st->pos;
+    while (is_ws(input[i]))
+        i++;
+    if (input[i] == '\0') {
+        st->pos = i;
+        return 0;
+    }
+
+    size_t o = 0;
+    while (input[i] != '\0' && !is_ws(input[i])) {
+        char c = input[i];
+        if (c == '\'') {
+            i++;
+            while (input[i] != '\0' && input[i] != '\'') {
+                if (put(out, outsz, &o, input[i]) != 0)
+                    goto too_small;
+                i++;
+            }
+            if (input[i] == '\0')
+                goto bad_input; /* unterminated single quote */
+            i++;
+        } else if (c == '"') {
+            i++;
+            for (;;) {
+                char d = input[i];
+                if (d == '\0')
+                    goto bad_input; /* unterminated double quote */
+                if (d == '"') {
+                    i++;
+                    break;
+                }
+                if (d == '\\') {
+                    char e = input[i + 1];
+                    if (e == '\0')
+                        goto bad_input; /* backslash then end of input */
+                    if (e == '"' || e == '\\') {
+                        if (put(out, outsz, &o, e) != 0)
+                            goto too_small;
+                        i += 2;
+                    } else {
+                        /* keep the backslash literally */
+                        if (put(out, outsz, &o, '\\') != 0)
+                            goto too_small;
+                        i++;
+                    }
+                } else {
+                    if (put(out, outsz, &o, d) != 0)
+                        goto too_small;
+                    i++;
+                }
+            }
+        } else if (c == '\\') {
+            char e = input[i + 1];
+            if (e == '\0')
+                goto bad_input; /* dangling escape */
+            if (put(out, outsz, &o, e) != 0)
+                goto too_small;
+            i += 2;
+        } else {
+            if (put(out, outsz, &o, c) != 0)
+                goto too_small;
+            i++;
+        }
+    }
+    out[o] = '\0';
+    st->pos = i;
+    return 1;
+
+too_small:
+bad_input:
+    out[0] = '\0';
+    return -1;
+}
diff --git a/tok.h b/tok.h
new file mode 100644
index 0000000..3792a3c
--- /dev/null
+++ b/tok.h
@@ -0,0 +1,21 @@
+/* tok.h — reentrant shell-style tokenizer for job lines. */
+#ifndef TOK_H
+#define TOK_H
+
+#include <stddef.h>
+
+typedef struct {
+    size_t pos; /* resume offset into the input string */
+} tok_state;
+
+/* Reset the cursor to the start of the input. */
+void tok_init(tok_state *st);
+
+/* Copy the next token from input into out (NUL-terminated).
+ * Returns 1 on a token, 0 at end of input, -1 on error (unterminated
+ * quote, dangling backslash, out buffer too small, outsz == 0).
+ * On 0 or -1 with outsz > 0, out is set to the empty string.
+ * On -1 the state is unchanged so the caller may retry. */
+int tok_next(tok_state *st, const char *input, char *out, size_t outsz);
+
+#endif /* TOK_H */
