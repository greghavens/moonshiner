+
+    def add_discount(self, code, kind, value, priority=100, exclusive=False):
+        """Register a discount rule; how it combines is decided at total time."""
+        if not code or code in self._discounts:
+            raise ValueError("duplicate or empty discount code: %r" % (code,))
+        if kind == "percent":
+            if not isinstance(value, int) or isinstance(value, bool) \
+                    or not 1 <= value <= 100:
+                raise ValueError("percent value must be an int in 1..100")
+        elif kind == "fixed":
+            if not isinstance(value, int) or isinstance(value, bool) or value < 1:
+                raise ValueError("fixed value must be an int >= 1 cent")
+        else:
+            raise ValueError("unknown discount kind: %r" % (kind,))
+        self._discounts[code] = {"kind": kind, "value": value,
+                                 "priority": priority, "exclusive": exclusive}
+
+    @staticmethod
+    def _cents_off(rule, running):
+        if rule["kind"] == "percent":
+            # half-up in integer arithmetic; running is never negative
+            return (running * rule["value"] + 50) // 100
+        return min(rule["value"], running)
+
+    def _plan(self):
+        """Discounts in the order total_cents applies them."""
+        rules = [dict(r, code=c) for c, r in self._discounts.items()]
+        exclusives = [r for r in rules if r["exclusive"]]
+        if exclusives:
+            subtotal = self.subtotal_cents()
+            best = min(exclusives,
+                       key=lambda r: (-self._cents_off(r, subtotal),
+                                      r["priority"], r["code"]))
+            return [best]
+        return sorted(rules, key=lambda r: (r["priority"], r["code"]))
+
+    def applied_discounts(self):
+        """(code, cents_off) pairs in application order, clamped at zero."""
+        running = self.subtotal_cents()
+        applied = []
+        for rule in self._plan():
+            off = self._cents_off(rule, running)
+            applied.append((rule["code"], off))
+            running -= off
+        return applied
 
