+"""Slash-aware glob matching for ignore patterns.
+
+Semantics (deliberately not fnmatch):
+  *      any run of characters except '/', including empty
+  ?      exactly one character, never '/'
+  [...]  one character from the listed set; ranges, leading ! negation,
+         literal ']' first, literal '-' at the edges; unclosed '[' is literal
+Case-sensitive everywhere.
+"""
+
+
+def _parse_class(pattern, i):
+    """Parse a class starting at pattern[i] == '['.
+
+    Returns (token, next_index) or (None, i) when the bracket never closes.
+    """
+    j = i + 1
+    negate = False
+    if j < len(pattern) and pattern[j] == "!":
+        negate = True
+        j += 1
+    chars = set()
+    ranges = []
+    first = True
+    while j < len(pattern):
+        c = pattern[j]
+        if c == "]" and not first:
+            return ("class", negate, chars, ranges), j + 1
+        if j + 2 < len(pattern) and pattern[j + 1] == "-" and pattern[j + 2] != "]":
+            ranges.append((c, pattern[j + 2]))
+            j += 3
+        else:
+            chars.add(c)
+            j += 1
+        first = False
+    return None, i
+
+
+def _tokenize(pattern):
+    tokens = []
+    i = 0
+    while i < len(pattern):
+        c = pattern[i]
+        if c == "*":
+            if not tokens or tokens[-1][0] != "star":
+                tokens.append(("star",))
+            i += 1
+        elif c == "?":
+            tokens.append(("q",))
+            i += 1
+        elif c == "[":
+            token, end = _parse_class(pattern, i)
+            if token is None:
+                tokens.append(("char", "["))
+                i += 1
+            else:
+                tokens.append(token)
+                i = end
+        else:
+            tokens.append(("char", c))
+            i += 1
+    return tokens
+
+
+def _class_hit(c, negate, chars, ranges):
+    listed = c in chars or any(lo <= c <= hi for lo, hi in ranges)
+    return listed != negate
+
+
+def glob_match(pattern, name):
+    """True if name matches pattern. Polynomial time by construction:
+
+    tracks the SET of reachable positions in name per token instead of
+    backtracking, so star-heavy patterns cannot go exponential.
+    """
+    positions = {0}
+    for token in _tokenize(pattern):
+        kind = token[0]
+        advanced = set()
+        if kind == "star":
+            for p in positions:
+                advanced.add(p)
+                q = p
+                while q < len(name) and name[q] != "/":
+                    q += 1
+                    advanced.add(q)
+        elif kind == "q":
+            for p in positions:
+                if p < len(name) and name[p] != "/":
+                    advanced.add(p + 1)
+        elif kind == "char":
+            for p in positions:
+                if p < len(name) and name[p] == token[1]:
+                    advanced.add(p + 1)
+        else:  # class
+            _, negate, chars, ranges = token
+            for p in positions:
+                if p < len(name) and _class_hit(name[p], negate, chars, ranges):
+                    advanced.add(p + 1)
+        positions = advanced
+        if not positions:
+            return False
+    return len(name) in positions
+
+
+def glob_filter(pattern, names):
+    """Names matching pattern, in their original order."""
+    return [n for n in names if glob_match(pattern, n)]
