diff --git a/pool.sh b/pool.sh
new file mode 100644
index 0000000..7ce899c
--- /dev/null
+++ b/pool.sh
@@ -0,0 +1,88 @@
+#!/usr/bin/env bash
+# pool.sh — run a manifest of named shell jobs with a bounded worker count.
+#
+# Manifest: one job per line, `<name><TAB><command>`; blanks and #-comments
+# skipped. The whole manifest is validated before anything runs. Jobs start
+# in manifest order, at most <max-workers> at a time (wait -n frees slots).
+# Per-job output lands in logs/<name>.log, exit statuses in results.txt.
+set -u
+LC_ALL=C
+export LC_ALL
+
+usage() {
+  echo "usage: pool.sh <manifest> <max-workers>" >&2
+  exit 64
+}
+
+[[ $# -eq 2 ]] || usage
+manifest=$1
+workers=$2
+case $workers in
+  '' | *[!0-9]*) usage ;;
+esac
+[[ "$workers" -ge 1 ]] || usage
+
+if [[ ! -f "$manifest" || ! -r "$manifest" ]]; then
+  echo "pool.sh: cannot read: $manifest" >&2
+  exit 66
+fi
+
+tab=$'\t'
+names=()
+cmds=()
+declare -A seen=()
+lineno=0
+bad=0
+while IFS= read -r line || [[ -n "$line" ]]; do
+  lineno=$((lineno + 1))
+  [[ -z "$line" || ${line:0:1} == '#' ]] && continue
+  if [[ "$line" != *"$tab"* ]]; then
+    echo "pool.sh: line $lineno: malformed" >&2
+    bad=1
+    continue
+  fi
+  name=${line%%"$tab"*}
+  cmd=${line#*"$tab"}
+  if [[ -z "$name" || -z "$cmd" || "$name" == *[!A-Za-z0-9_-]* ]]; then
+    echo "pool.sh: line $lineno: malformed" >&2
+    bad=1
+    continue
+  fi
+  if [[ -n "${seen[$name]:-}" ]]; then
+    echo "pool.sh: line $lineno: duplicate job name: $name" >&2
+    bad=1
+    continue
+  fi
+  seen[$name]=1
+  names+=("$name")
+  cmds+=("$cmd")
+done < "$manifest"
+[[ "$bad" -eq 0 ]] || exit 65
+
+mkdir -p logs
+: > results.txt
+
+run_one() { # run_one <name> <command>
+  local name=$1 cmd=$2 rc=0
+  bash -c "$cmd" > "logs/$name.log" 2>&1 || rc=$?
+  printf '%s\t%d\n' "$name" "$rc" >> results.txt
+}
+
+running=0
+for i in "${!names[@]}"; do
+  if (( running >= workers )); then
+    wait -n
+    running=$((running - 1))
+  fi
+  run_one "${names[$i]}" "${cmds[$i]}" &
+  running=$((running + 1))
+done
+wait
+
+total=${#names[@]}
+failed=0
+while IFS=$'\t' read -r _ rc; do
+  [[ "$rc" -eq 0 ]] || failed=$((failed + 1))
+done < results.txt
+printf 'pool: %d jobs, %d failed\n' "$total" "$failed"
+[[ "$failed" -eq 0 ]]
