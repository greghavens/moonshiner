@@ -0,0 +1,41 @@
+"""orderdesk — pricing, tax, shipping and reporting for wholesale orders.
+
+Facade over the domain modules so existing callers keep working:
+
+    import orderdesk
+    orderdesk.order_total(order)
+    orderdesk.render_report(order)
+
+See pricing, tax, shipping and report for the pieces.
+"""
+
+from .pricing import PRICE_BREAKS, line_total_cents, price_lines, subtotal_cents
+from .report import render_report
+from .shipping import (
+    FREE_SHIPPING_MIN_CENTS,
+    OVERWEIGHT_CENTS,
+    SHIPPING_BANDS,
+    shipping_cents,
+    total_weight_g,
+)
+from .tax import TAX_RATES_BP, tax_cents
+
+__all__ = [
+    "PRICE_BREAKS", "line_total_cents", "price_lines", "subtotal_cents",
+    "TAX_RATES_BP", "tax_cents",
+    "SHIPPING_BANDS", "OVERWEIGHT_CENTS", "FREE_SHIPPING_MIN_CENTS",
+    "shipping_cents", "total_weight_g",
+    "render_report", "order_total",
+]
+
+
+def order_total(order):
+    subtotal = subtotal_cents(order)
+    tax = tax_cents(order)
+    shipping = shipping_cents(order)
+    return {
+        "subtotal_cents": subtotal,
+        "tax_cents": tax,
+        "shipping_cents": shipping,
+        "total_cents": subtotal + tax + shipping,
+    }
diff --git a/orderdesk/pricing.py b/orderdesk/pricing.py
new file mode 100644
index 0000000..09a64cc
--- /dev/null
+++ b/orderdesk/pricing.py
@@ -0,0 +1,30 @@
+"""Pricing: quantity breaks, line totals and the order subtotal.
+
+All money is integer cents; all arithmetic stays in integers so the
+invoice batch is reproducible to the cent.
+"""
+
+# Quantity breaks, checked top down: buy at least `min_qty` of a line and
+# the whole line gets `percent` off. Only the first matching break applies.
+PRICE_BREAKS = [
+    (50, 10),  # pallet pricing
+    (10, 5),   # case pricing
+]
+
+
+def line_total_cents(line):
+    """Extended line total after the quantity break, floored to a cent."""
+    base = line["unit_cents"] * line["qty"]
+    for min_qty, percent in PRICE_BREAKS:
+        if line["qty"] >= min_qty:
+            return base * (100 - percent) // 100
+    return base
+
+
+def price_lines(order):
+    """[(sku, line_total_cents), ...] in the order the lines appear."""
+    return [(line["sku"], line_total_cents(line)) for line in order["lines"]]
+
+
+def subtotal_cents(order):
+    return sum(total for _, total in price_lines(order))
diff --git a/orderdesk/report.py b/orderdesk/report.py
new file mode 100644
index 0000000..35da0a8
--- /dev/null
+++ b/orderdesk/report.py
@@ -0,0 +1,30 @@
+"""The printed order report used by the fulfillment desk."""
+
+from .pricing import line_total_cents, subtotal_cents
+from .shipping import shipping_cents
+from .tax import tax_cents
+
+
+def _dollars(cents):
+    return "$%d.%02d" % divmod(cents, 100)
+
+
+def render_report(order):
+    """Fixed-width text summary. The fulfillment desk prints these and
+    files them, so the layout is load-bearing — do not tweak it."""
+    subtotal = subtotal_cents(order)
+    tax = tax_cents(order)
+    shipping = shipping_cents(order)
+    out = []
+    out.append("ORDER %s — %s" % (order["id"], order["customer"]["name"]))
+    out.append("%-12s%4s%12s" % ("SKU", "QTY", "LINE TOTAL"))
+    for line in order["lines"]:
+        out.append("%-12s%4d%12s"
+                   % (line["sku"], line["qty"],
+                      _dollars(line_total_cents(line))))
+    out.append("-" * 28)
+    out.append("%-16s%12s" % ("Subtotal", _dollars(subtotal)))
+    out.append("%-16s%12s" % ("Tax", _dollars(tax)))
+    out.append("%-16s%12s" % ("Shipping", _dollars(shipping)))
+    out.append("%-16s%12s" % ("TOTAL", _dollars(subtotal + tax + shipping)))
+    return "\n".join(out) + "\n"
diff --git a/orderdesk/shipping.py b/orderdesk/shipping.py
new file mode 100644
index 0000000..dd6edab
--- /dev/null
+++ b/orderdesk/shipping.py
@@ -0,0 +1,31 @@
+"""Shipping: weight bands and the free-shipping threshold."""
+
+from .pricing import subtotal_cents
+
+# Weight bands: (max total grams inclusive, cents). Heavier than the last
+# band pays the overweight flat rate.
+SHIPPING_BANDS = [
+    (500, 495),
+    (2000, 795),
+    (10000, 1495),
+]
+OVERWEIGHT_CENTS = 2495
+
+# Orders at or above this subtotal (after quantity breaks) ship free.
+FREE_SHIPPING_MIN_CENTS = 15000
+
+
+def total_weight_g(order):
+    return sum(line["weight_g"] * line["qty"] for line in order["lines"])
+
+
+def shipping_cents(order):
+    if not order["lines"]:
+        return 0
+    if subtotal_cents(order) >= FREE_SHIPPING_MIN_CENTS:
+        return 0
+    weight = total_weight_g(order)
+    for max_g, cents in SHIPPING_BANDS:
+        if weight <= max_g:
+            return cents
+    return OVERWEIGHT_CENTS
