+"""A small URL toolkit: parse, edit, rebuild. No urllib anywhere."""
+
+_UNRESERVED = frozenset(
+    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._~-"
+)
+_HEX = "0123456789ABCDEFabcdef"
+
+
+def _pct_decode(text):
+    """Percent-decode `text` (query component: '+' is a space)."""
+    out = bytearray()
+    i = 0
+    while i < len(text):
+        ch = text[i]
+        if ch == "+":
+            out.append(0x20)
+            i += 1
+        elif ch == "%":
+            if len(text) - i < 3:
+                raise ValueError(f"truncated percent escape in {text!r}")
+            hi, lo = text[i + 1], text[i + 2]
+            if hi not in _HEX or lo not in _HEX:
+                raise ValueError(f"bad percent escape %{hi}{lo} in {text!r}")
+            out.append(int(hi + lo, 16))
+            i += 3
+        else:
+            out.extend(ch.encode("utf-8"))
+            i += 1
+    return out.decode("utf-8")
+
+
+def _pct_encode(text):
+    """Percent-encode a query key/value: space -> '+', unreserved bare."""
+    out = []
+    for byte in text.encode("utf-8"):
+        ch = chr(byte)
+        if ch in _UNRESERVED:
+            out.append(ch)
+        elif ch == " ":
+            out.append("+")
+        else:
+            out.append(f"%{byte:02X}")
+    return "".join(out)
+
+
+def _parse_query(raw):
+    pairs = []
+    for chunk in raw.split("&"):
+        if not chunk:
+            continue
+        key, sep, value = chunk.partition("=")
+        pairs.append((_pct_decode(key), _pct_decode(value)))
+    return pairs
+
+
+def normalize_path(path):
+    """Resolve '.' and '..' segments; never collapse doubled slashes."""
+    if path == "":
+        return ""
+    absolute = path.startswith("/")
+    trailing = path.endswith("/") or path.endswith("/.") or path.endswith("/..") \
+        or path in (".", "..")
+    segments = path.split("/")
+    if absolute:
+        segments = segments[1:]
+    out = []
+    for seg in segments:
+        if seg == ".":
+            continue
+        if seg == "..":
+            if out and out[-1] != "..":
+                out.pop()
+            elif not absolute:
+                out.append("..")
+            # absolute: clamp at root (drop it)
+        else:
+            out.append(seg)
+    # drop a trailing empty segment produced by an input trailing slash;
+    # we re-add the slash below
+    if out and out[-1] == "" and trailing:
+        out.pop()
+    result = "/".join(out)
+    if trailing and (result or absolute):
+        result += "/"
+        if result.endswith("//"):
+            result = result[:-1]
+    if absolute:
+        result = "/" + result
+        if result.startswith("//") and not (out and out[0] == ""):
+            result = result[1:]
+    return result
+
+
+class URL:
+    def __init__(self, scheme=None, host=None, port=None, path="",
+                 query=None, fragment=None):
+        self.scheme = scheme
+        self.host = host
+        self.port = port
+        self.path = path
+        self.query = list(query) if query else []
+        self.fragment = fragment
+
+    # -- query helpers ----------------------------------------------------
+    def get(self, key):
+        for k, v in self.query:
+            if k == key:
+                return v
+        return None
+
+    def get_all(self, key):
+        return [v for k, v in self.query if k == key]
+
+    def add(self, key, value):
+        self.query.append((key, value))
+
+    def remove(self, key):
+        before = len(self.query)
+        self.query = [(k, v) for k, v in self.query if k != key]
+        return before - len(self.query)
+
+    def replace(self, key, value):
+        out = []
+        placed = False
+        for k, v in self.query:
+            if k == key:
+                if not placed:
+                    out.append((key, value))
+                    placed = True
+            else:
+                out.append((k, v))
+        if not placed:
+            out.append((key, value))
+        self.query = out
+
+    # -- normalization ----------------------------------------------------
+    def normalize(self):
+        self.path = normalize_path(self.path)
+        return self
+
+    # -- building ---------------------------------------------------------
+    def __str__(self):
+        parts = []
+        if self.host is not None:
+            parts.append(f"{self.scheme}://{self.host}")
+            if self.port is not None:
+                parts.append(f":{self.port}")
+        parts.append(self.path)
+        if self.query:
+            rendered = []
+            for k, v in self.query:
+                ek = _pct_encode(k)
+                rendered.append(ek if v == "" else f"{ek}={_pct_encode(v)}")
+            parts.append("?" + "&".join(rendered))
+        if self.fragment is not None:
+            parts.append("#" + self.fragment)
+        return "".join(parts)
+
+    def __repr__(self):
+        return f"URL({str(self)!r})"
+
+
+def _is_scheme(text):
+    if not text or not text[0].isalpha():
+        return False
+    return all(c.isalnum() or c in "+.-" for c in text)
+
+
+def parse(url):
+    scheme = host = fragment = None
+    port = None
+    rest = url
+
+    head, sep, tail = url.partition("://")
+    if sep and _is_scheme(head):
+        scheme = head.lower()
+        # authority runs to the next /, ? or #
+        end = len(tail)
+        for i, ch in enumerate(tail):
+            if ch in "/?#":
+                end = i
+                break
+        authority, rest = tail[:end], tail[end:]
+        if "@" in authority:
+            raise ValueError("userinfo in URLs is not supported")
+        hostpart, sep2, portpart = authority.partition(":")
+        host = hostpart.lower()
+        if sep2:
+            if not portpart or not portpart.isdigit():
+                raise ValueError(f"invalid port {portpart!r}")
+            port = int(portpart)
+            if port > 65535:
+                raise ValueError(f"port {port} out of range")
+
+    rest, hash_sep, frag = rest.partition("#")
+    if hash_sep:
+        fragment = frag
+    path, q_sep, raw_query = rest.partition("?")
+    query = _parse_query(raw_query) if q_sep else []
+
+    return URL(scheme=scheme, host=host, port=port, path=path,
+               query=query, fragment=fragment)
