diff --git a/uttt.cpp b/uttt.cpp
new file mode 100644
index 0000000..3a4bf7d
--- /dev/null
+++ b/uttt.cpp
@@ -0,0 +1,91 @@
+#include "uttt.h"
+
+#include <cstdlib>
+#include <sstream>
+
+namespace {
+
+const int LINES[8][3] = {{0, 1, 2}, {3, 4, 5}, {6, 7, 8}, {0, 3, 6},
+                         {1, 4, 7}, {2, 5, 8}, {0, 4, 8}, {2, 4, 6}};
+
+bool has_line(const int *nine, int side) {
+    for (const int *L : LINES)
+        if (nine[L[0]] == side && nine[L[1]] == side && nine[L[2]] == side)
+            return true;
+    return false;
+}
+
+}  // namespace
+
+void ut_init(UTTT *g) {
+    for (int b = 0; b < 9; b++) {
+        g->sub[b] = 0;
+        for (int c = 0; c < 9; c++) g->cells[b][c] = 0;
+    }
+    g->to_move = 1;
+    g->forced = -1;
+    g->winner = 0;
+}
+
+int ut_to_move(const UTTT *g) { return g->to_move; }
+
+int ut_forced(const UTTT *g) { return g->forced; }
+
+int ut_cell(const UTTT *g, int b, int c) {
+    if (b < 0 || b > 8 || c < 0 || c > 8) return -1;
+    return g->cells[b][c];
+}
+
+int ut_subwinner(const UTTT *g, int b) { return g->sub[b]; }
+
+int ut_winner(const UTTT *g) { return g->winner; }
+
+bool ut_play(UTTT *g, int b, int c) {
+    if (g->winner != 0) return false;
+    if (b < 0 || b > 8 || c < 0 || c > 8) return false;
+    if (g->sub[b] != 0 || g->cells[b][c] != 0) return false;
+    if (g->forced != -1 && b != g->forced) return false;
+
+    int side = g->to_move;
+    g->cells[b][c] = side;
+
+    if (has_line(g->cells[b], side)) {
+        g->sub[b] = side;
+    } else {
+        bool full = true;
+        for (int i = 0; i < 9; i++)
+            if (g->cells[b][i] == 0) { full = false; break; }
+        if (full) g->sub[b] = 3;
+    }
+
+    if (has_line(g->sub, side)) {
+        g->winner = side;
+    } else {
+        bool all_closed = true;
+        for (int i = 0; i < 9; i++)
+            if (g->sub[i] == 0) { all_closed = false; break; }
+        if (all_closed) g->winner = 3;
+    }
+
+    g->forced = (g->sub[c] == 0) ? c : -1;
+    g->to_move = 3 - side;
+    return true;
+}
+
+int ut_replay(UTTT *g, const std::string &moves) {
+    ut_init(g);
+    std::istringstream in(moves);
+    std::string tok;
+    int idx = 0;
+    while (in >> tok) {
+        size_t colon = tok.find(':');
+        int b = -1, c = -1;
+        if (colon != std::string::npos) {
+            b = std::atoi(tok.substr(0, colon).c_str());
+            c = std::atoi(tok.substr(colon + 1).c_str());
+        }
+        if (!ut_play(g, b, c)) return idx;
+        idx++;
+    }
+    return -1;
+}
diff --git a/uttt.h b/uttt.h
