--- /dev/null
+++ b/uttt.h
@@ -0,0 +1,23 @@
+#ifndef UTTT_H
+#define UTTT_H
+
+#include <string>
+
+struct UTTT {
+    int cells[9][9];   // [board][cell]: 0 empty, 1 X, 2 O
+    int sub[9];        // 0 open, 1/2 won, 3 drawn
+    int to_move;       // 1 or 2
+    int forced;        // 0..8 or -1
+    int winner;        // 0 in progress, 1/2 won, 3 drawn
+};
+
+void ut_init(UTTT *g);
+int  ut_to_move(const UTTT *g);
+int  ut_forced(const UTTT *g);
+int  ut_cell(const UTTT *g, int b, int c);
+int  ut_subwinner(const UTTT *g, int b);
+int  ut_winner(const UTTT *g);
+bool ut_play(UTTT *g, int b, int c);
+int  ut_replay(UTTT *g, const std::string &moves);
+
+#endif
