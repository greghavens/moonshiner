-//! Weather-station file importer for the field-network archive.
+//! Weather-station report importer.
 //!
-//! Nothing implemented yet — tests/import.rs pins the parsing rules, the
-//! error taxonomy, and the app-layer import behavior.
+//! Layered error handling: the parsing/loading layer returns the typed
+//! [`WxError`] (thiserror), while the directory-import driver returns
+//! `anyhow::Result` and wraps each file's failure with the file name as
+//! context. The typed error stays downcastable through the wrap.
+
+use std::fs;
+use std::path::Path;
+
+use anyhow::{bail, Context};
+use thiserror::Error;
+
+/// A single parsed station file.
+#[derive(Debug, Clone, PartialEq)]
+pub struct Report {
+    pub station: String,
+    pub readings: Vec<Reading>,
+}
+
+/// One observation line.
+#[derive(Debug, Clone, PartialEq)]
+pub struct Reading {
+    pub date: String,
+    pub temp_c: f64,
+    pub wind_kt: f64,
+}
+
+/// What `import_dir` reports on success.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct ImportSummary {
+    pub files: usize,
+    pub readings: usize,
+}
+
+/// Typed library-level errors for the .wx format.
+#[derive(Debug, Error)]
+pub enum WxError {
+    #[error("missing STATION header")]
+    MissingHeader,
+
+    #[error("line {line}: unreadable field {field:?}")]
+    BadField { line: usize, field: String },
+
+    #[error("line {line}: missing field {field:?}")]
+    MissingField { line: usize, field: String },
+
+    #[error("line {line}: {field} out of range ({value})")]
+    OutOfRange {
+        line: usize,
+        field: String,
+        value: f64,
+    },
+
+    #[error("could not read {path}")]
+    Io {
+        path: String,
+        #[source]
+        source: std::io::Error,
+    },
+}
+
+const TEMP_RANGE: std::ops::RangeInclusive<f64> = -90.0..=60.0;
+const WIND_RANGE: std::ops::RangeInclusive<f64> = 0.0..=250.0;
+
+/// Parse the text of one .wx file.
+///
+/// Line 1 must be `STATION <code>`; every following non-blank line is
+/// `<date> temp_c=<f64> wind_kt=<f64>` (key order free). Line numbers in
+/// errors are physical and 1-based; blank lines still count.
+pub fn parse_report(text: &str) -> Result<Report, WxError> {
+    let mut lines = text.lines().enumerate();
+
+    let station = match lines.next() {
+        Some((_, first)) => {
+            let mut parts = first.split_whitespace();
+            match (parts.next(), parts.next(), parts.next()) {
+                (Some("STATION"), Some(code), None) => code.to_string(),
+                _ => return Err(WxError::MissingHeader),
+            }
+        }
+        None => return Err(WxError::MissingHeader),
+    };
+
+    let mut readings = Vec::new();
+    for (idx, raw) in lines {
+        let line = idx + 1; // physical, 1-based
+        if raw.trim().is_empty() {
+            continue;
+        }
+        readings.push(parse_reading(line, raw)?);
+    }
+
+    Ok(Report { station, readings })
+}
+
+fn parse_reading(line: usize, raw: &str) -> Result<Reading, WxError> {
+    let mut tokens = raw.split_whitespace();
+    let date = tokens
+        .next()
+        .expect("non-blank line has at least one token")
+        .to_string();
+
+    let mut temp_c: Option<f64> = None;
+    let mut wind_kt: Option<f64> = None;
+
+    for token in tokens {
+        let bad = || WxError::BadField {
+            line,
+            field: token.to_string(),
+        };
+        let (key, value) = token.split_once('=').ok_or_else(bad)?;
+        let value: f64 = value.parse().map_err(|_| bad())?;
+        match key {
+            "temp_c" => temp_c = Some(value),
+            "wind_kt" => wind_kt = Some(value),
+            _ => return Err(bad()),
+        }
+    }
+
+    let require = |field: &str, slot: Option<f64>| {
+        slot.ok_or_else(|| WxError::MissingField {
+            line,
+            field: field.to_string(),
+        })
+    };
+    let temp_c = require("temp_c", temp_c)?;
+    let wind_kt = require("wind_kt", wind_kt)?;
+
+    let check = |field: &str, value: f64, range: &std::ops::RangeInclusive<f64>| {
+        if range.contains(&value) {
+            Ok(value)
+        } else {
+            Err(WxError::OutOfRange {
+                line,
+                field: field.to_string(),
+                value,
+            })
+        }
+    };
+    let temp_c = check("temp_c", temp_c, &TEMP_RANGE)?;
+    let wind_kt = check("wind_kt", wind_kt, &WIND_RANGE)?;
+
+    Ok(Reading {
+        date,
+        temp_c,
+        wind_kt,
+    })
+}
+
+/// Read and parse one station file, keeping the io error as the source.
+pub fn load_station_file(path: &Path) -> Result<Report, WxError> {
+    let text = fs::read_to_string(path).map_err(|source| WxError::Io {
+        path: path.display().to_string(),
+        source,
+    })?;
+    parse_report(&text)
+}
+
+/// Import every `*.wx` file in a directory.
+///
+/// Library errors are wrapped with `importing <filename>` context so the
+/// operator knows which file failed; the typed `WxError` remains
+/// downcastable underneath. A directory with no station files is an
+/// app-level error, not a `WxError`.
+pub fn import_dir(path: &Path) -> anyhow::Result<ImportSummary> {
+    let mut entries: Vec<_> = fs::read_dir(path)
+        .map_err(|source| WxError::Io {
+            path: path.display().to_string(),
+            source,
+        })
+        .with_context(|| format!("importing {}", path.display()))?
+        .filter_map(|entry| entry.ok().map(|e| e.path()))
+        .filter(|p| p.extension().is_some_and(|ext| ext == "wx"))
+        .collect();
+    entries.sort();
+
+    if entries.is_empty() {
+        bail!("no .wx files in {}", path.display());
+    }
+
+    let mut files = 0usize;
+    let mut readings = 0usize;
+    for file in entries {
+        let name = file
+            .file_name()
+            .expect("*.wx path has a file name")
+            .to_string_lossy()
+            .into_owned();
+        let report = load_station_file(&file).with_context(|| format!("importing {name}"))?;
+        files += 1;
+        readings += report.readings.len();
+    }
+
+    Ok(ImportSummary { files, readings })
+}
