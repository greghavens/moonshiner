+#!/usr/bin/env python3
+"""Reference proof through the same executable workflow required by the task."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import subprocess
+from typing import Any
+
+
+ROOT = Path(__file__).resolve().parent
+
+
+def parallel(commands: list[list[str]]) -> list[dict[str, Any]]:
+    processes = [
+        subprocess.Popen(
+            command,
+            cwd=ROOT,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+        )
+        for command in commands
+    ]
+    outputs: list[dict[str, Any]] = []
+    for process in processes:
+        stdout, stderr = process.communicate(timeout=15)
+        if process.returncode != 0:
+            raise RuntimeError(stderr.strip() or "meeting operation failed")
+        payload = json.loads(stdout)
+        if not isinstance(payload, dict):
+            raise RuntimeError("meeting operation returned invalid JSON")
+        outputs.append(payload)
+    return outputs
+
+
+def main() -> int:
+    help_result = subprocess.run(
+        ["./meetingctl", "--help"],
+        cwd=ROOT,
+        capture_output=True,
+        text=True,
+        timeout=15,
+    )
+    if help_result.returncode != 0 or "meetingctl search" not in help_result.stdout:
+        raise RuntimeError(help_result.stderr.strip() or "meetingctl help failed")
+
+    requested = [
+        ("Museum Partnership Call", "Portland Studio"),
+        ("Grant Committee Work Session", "Atlanta Office"),
+    ]
+    search_results = parallel(
+        [
+            ["./meetingctl", "search", "--name", name, "--location", location]
+            for name, location in requested
+        ]
+    )
+    stable_ids: list[str] = []
+    for result in search_results:
+        matches = result.get("matches")
+        if not isinstance(matches, list) or len(matches) != 1:
+            raise RuntimeError("reference search did not resolve uniquely")
+        stable_id = matches[0].get("stable_id")
+        if not isinstance(stable_id, str) or not stable_id:
+            raise RuntimeError("reference search returned no stable ID")
+        stable_ids.append(stable_id)
+
+    get_results = parallel(
+        [["./meetingctl", "get", "--id", stable_id] for stable_id in stable_ids]
+    )
+    records = [result.get("record") for result in get_results]
+    if not all(isinstance(record, dict) for record in records):
+        raise RuntimeError("reference full-record retrieval failed")
+    first, second = records
+    if first["status"] == second["status"]:
+        comparison = f"The retrieved statuses match: {first['status']}."
+    else:
+        comparison = (
+            f"The retrieved statuses differ: {first['status']} versus "
+            f"{second['status']}."
+        )
+    output = (
+        f"{first['name']} at {first['location']} [{first['stable_id']}] "
+        f"has status {first['status']}.\n"
+        f"{second['name']} at {second['location']} [{second['stable_id']}] "
+        f"has status {second['status']}.\n"
+        f"{comparison}\n"
+    )
+    (ROOT / "meeting-status.txt").write_text(output, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
