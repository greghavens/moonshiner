+#!/usr/bin/env ruby
+# Battleduel: a loopback TCP referee for one two-player battleship duel.
+require "socket"
+
+ROWS = ("A".."H").to_a.freeze
+COLS = (1..8).to_a.freeze
+FLEET = {
+  "BATTLESHIP" => 4,
+  "CRUISER"    => 3,
+  "SUBMARINE"  => 3,
+  "DESTROYER"  => 2,
+}.freeze
+
+class Player
+  attr_reader :sock, :name
+  attr_accessor :ready
+  # ship name -> array of cells; cells are "C5"-style strings
+  attr_reader :ships, :hits_taken, :shots
+
+  def initialize(sock, name)
+    @sock = sock
+    @name = name
+    @ships = {}
+    @hits_taken = Hash.new { |h, k| h[k] = [] }
+    @shots = {}
+    @ready = false
+  end
+
+  def occupied
+    @ships.values.flatten
+  end
+
+  def all_sunk?
+    FLEET.keys.all? { |s| @hits_taken[s].size == FLEET[s] }
+  end
+
+  def say(line)
+    @sock.write("#{line}\n")
+  rescue SystemCallError, IOError
+    nil # a vanished client surfaces as EOF in its own reader thread
+  end
+end
+
+class Duel
+  def initialize
+    @mutex = Mutex.new
+    @players = []
+    @turn = 0
+    @started = false
+    @decided = Queue.new
+  end
+
+  attr_reader :decided
+
+  def seat(sock)
+    @mutex.synchronize do
+      return nil if @players.size >= 2
+      player = Player.new(sock, "P#{@players.size + 1}")
+      @players << player
+      player.say("HELLO #{player.name}")
+      player
+    end
+  end
+
+  def broadcast(line)
+    @players.each { |p| p.say(line) }
+  end
+
+  def handle(player, raw)
+    line = raw.chomp("\r")
+    tokens = line.split(" ")
+    @mutex.synchronize do
+      return if @done
+      case tokens.first
+      when "PLACE" then place(player, tokens)
+      when "READY" then ready(player, tokens)
+      when "FIRE"  then fire(player, tokens)
+      else player.say("ERR bad-command")
+      end
+    end
+  end
+
+  def close_all
+    @mutex.synchronize do
+      @players.each do |p|
+        p.sock.close unless p.sock.closed?
+      rescue SystemCallError, IOError
+        nil
+      end
+    end
+  end
+
+  def forfeit(player)
+    @mutex.synchronize do
+      return if @done
+      @done = true
+      other = @players.find { |p| !p.equal?(player) }
+      other&.say("WIN #{other.name} forfeit")
+      @decided << true
+    end
+  end
+
+  private
+
+  def place(player, tokens)
+    return player.say("ERR bad-command") unless tokens.size == 4
+    _, ship, coord, orient = tokens
+    return player.say("ERR already-ready") if player.ready
+    return player.say("ERR bad-ship") unless FLEET.key?(ship)
+    return player.say("ERR already-placed") if player.ships.key?(ship)
+    return player.say("ERR bad-coord") unless valid_coord?(coord)
+    return player.say("ERR bad-orient") unless %w[H V].include?(orient)
+    cells = span(coord, orient, FLEET[ship])
+    return player.say("ERR off-board") if cells.nil?
+    return player.say("ERR overlap") unless (cells & player.occupied).empty?
+    player.ships[ship] = cells
+    player.say("OK PLACE #{ship}")
+  end
+
+  def ready(player, tokens)
+    return player.say("ERR bad-command") unless tokens.size == 1
+    return player.say("ERR already-ready") if player.ready
+    return player.say("ERR fleet-incomplete") unless player.ships.size == FLEET.size
+    player.ready = true
+    player.say("OK READY")
+    if @players.size == 2 && @players.all?(&:ready)
+      @started = true
+      broadcast("START")
+      broadcast("TURN #{@players[@turn].name}")
+    end
+  end
+
+  def fire(player, tokens)
+    return player.say("ERR bad-command") unless tokens.size == 2
+    coord = tokens[1]
+    return player.say("ERR not-started") unless @started
+    return player.say("ERR not-your-turn") unless @players[@turn].equal?(player)
+    return player.say("ERR bad-coord") unless valid_coord?(coord)
+    return player.say("ERR repeat-shot") if player.shots.key?(coord)
+    player.shots[coord] = true
+
+    target = @players[1 - @turn]
+    hit_ship, _cells = target.ships.find { |_s, cells| cells.include?(coord) }
+    if hit_ship.nil?
+      broadcast("SHOT #{player.name} #{coord} MISS")
+      @turn = 1 - @turn
+    else
+      target.hits_taken[hit_ship] << coord
+      if target.hits_taken[hit_ship].size == FLEET[hit_ship]
+        broadcast("SHOT #{player.name} #{coord} SUNK #{hit_ship}")
+      else
+        broadcast("SHOT #{player.name} #{coord} HIT")
+      end
+      if target.all_sunk?
+        @done = true
+        broadcast("WIN #{player.name}")
+        @decided << true
+        return
+      end
+    end
+    broadcast("TURN #{@players[@turn].name}")
+  end
+
+  def valid_coord?(coord)
+    coord.match?(/\A[A-H][1-8]\z/)
+  end
+
+  # nil if the ship would leave the board
+  def span(coord, orient, length)
+    row = ROWS.index(coord[0])
+    col = coord[1].to_i
+    cells = (0...length).map do |i|
+      r = orient == "V" ? row + i : row
+      c = orient == "H" ? col + i : col
+      return nil if r > 7 || c > 8
+      "#{ROWS[r]}#{c}"
+    end
+    cells
+  end
+end
+
+server = TCPServer.new("127.0.0.1", 0)
+$stdout.sync = true
+puts "PORT #{server.addr[1]}"
+
+duel = Duel.new
+
+Thread.new do
+  loop do
+    sock = server.accept
+    player = duel.seat(sock)
+    if player.nil?
+      begin
+        sock.write("ERR full\n")
+      rescue SystemCallError, IOError
+        nil
+      end
+      sock.close
+      next
+    end
+    Thread.new do
+      begin
+        while (line = sock.gets)
+          duel.handle(player, line.chomp)
+        end
+      rescue SystemCallError, IOError
+        nil
+      end
+      duel.forfeit(player)
+    end
+  end
+end
+
+duel.decided.pop
+duel.close_all
+exit 0
