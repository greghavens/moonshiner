@@ -2,8 +2,15 @@
 
 A Table is a declared column list plus rows; render() produces the
 aligned plain-text block we drop into the nightly report body.
+
+to_csv()/to_json() give the same rows to machines: CSV per RFC 4180
+(CRLF rows, minimal quoting), JSON as an array of column-ordered objects.
 """
 
+import csv
+import io
+import json
+
 
 class Table:
     def __init__(self, columns):
@@ -48,3 +55,19 @@ class Table:
         for r in self._rows:
             out.append(line([r[c] for c in self.columns]))
         return "\n".join(out)
+
+    def to_csv(self):
+        """RFC-4180-style CSV: header first, CRLF rows, minimal quoting."""
+        buf = io.StringIO()
+        writer = csv.writer(buf)  # QUOTE_MINIMAL + \r\n terminator
+        writer.writerow(self.columns)
+        for r in self._rows:
+            writer.writerow(["" if r[c] is None else str(r[c])
+                             for c in self.columns])
+        return buf.getvalue()
+
+    def to_json(self):
+        """Compact JSON array of row objects, keys in declared column order."""
+        return json.dumps(
+            [{c: r[c] for c in self.columns} for r in self._rows],
+            ensure_ascii=False)
