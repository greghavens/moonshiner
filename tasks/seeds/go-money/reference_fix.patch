+package money
+
+import (
+	"errors"
+	"fmt"
+	"sort"
+)
+
+// Allocate splits m into len(ratios) parts proportional to ratios,
+// preserving the total exactly. Each part first gets the floor of its
+// proportional share; leftover minor units are then handed out by the
+// largest-remainder method, one to each part with the biggest
+// fractional loss, breaking ties toward the earlier slot. Negative
+// amounts allocate as the mirror image of the positive case.
+func (m Money) Allocate(ratios []int) ([]Money, error) {
+	if len(ratios) == 0 {
+		return nil, errors.New("money: allocate needs at least one ratio")
+	}
+	var total int64
+	for _, r := range ratios {
+		if r < 0 {
+			return nil, fmt.Errorf("money: negative ratio %d", r)
+		}
+		total += int64(r)
+	}
+	if total == 0 {
+		return nil, errors.New("money: ratios sum to zero")
+	}
+
+	amount, neg := m.amount, false
+	if amount < 0 {
+		amount, neg = -amount, true
+	}
+
+	parts := make([]int64, len(ratios))
+	type slot struct {
+		idx int
+		rem int64
+	}
+	slots := make([]slot, len(ratios))
+	var assigned int64
+	for i, r := range ratios {
+		scaled := amount * int64(r)
+		parts[i] = scaled / total
+		assigned += parts[i]
+		slots[i] = slot{idx: i, rem: scaled % total}
+	}
+	sort.SliceStable(slots, func(i, j int) bool { return slots[i].rem > slots[j].rem })
+	for k := int64(0); k < amount-assigned; k++ {
+		parts[slots[k].idx]++
+	}
+
+	out := make([]Money, len(parts))
+	for i, p := range parts {
+		if neg {
+			p = -p
+		}
+		out[i] = Money{amount: p, currency: m.currency}
+	}
+	return out, nil
+}
+
+// Split divides m into n equal shares, spare minor units landing on
+// the earliest shares.
+func (m Money) Split(n int) ([]Money, error) {
+	if n < 1 {
+		return nil, fmt.Errorf("money: cannot split into %d parts", n)
+	}
+	ratios := make([]int, n)
+	for i := range ratios {
+		ratios[i] = 1
+	}
+	return m.Allocate(ratios)
+}
