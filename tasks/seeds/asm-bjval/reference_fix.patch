diff --git a/bjval.s b/bjval.s
new file mode 100644
index 0000000..d86fbe9
--- /dev/null
+++ b/bjval.s
@@ -0,0 +1,52 @@
+# Blackjack hand value over rank bytes 1..13 (ace=1, faces count 10).
+# Returns total | soft<<8 | bust<<9 | natural<<10.
+# System V AMD64: rdi=cards, rsi=n.
+	.text
+	.globl	bj_value
+	.type	bj_value, @function
+bj_value:
+	xorl	%eax, %eax		# hard total (all aces as 1)
+	xorl	%ecx, %ecx		# hand holds an ace
+	xorq	%r8, %r8		# card index
+.Lsum:
+	cmpq	%rsi, %r8
+	jge	.Lflags
+	movzbl	(%rdi,%r8), %edx
+	cmpl	$1, %edx
+	jne	1f
+	movl	$1, %ecx
+1:	cmpl	$10, %edx		# J/Q/K clamp to 10
+	jle	2f
+	movl	$10, %edx
+2:	addl	%edx, %eax
+	incq	%r8
+	jmp	.Lsum
+.Lflags:
+	xorl	%r9d, %r9d		# soft
+	testl	%ecx, %ecx		# one ace may promote to 11
+	jz	3f
+	leal	10(%rax), %edx
+	cmpl	$21, %edx
+	jg	3f
+	movl	%edx, %eax
+	movl	$1, %r9d
+3:	xorl	%r10d, %r10d		# bust
+	cmpl	$21, %eax
+	jle	4f
+	movl	$1, %r10d
+4:	xorl	%r11d, %r11d		# natural: two cards totalling 21
+	cmpq	$2, %rsi
+	jne	5f
+	cmpl	$21, %eax
+	jne	5f
+	movl	$1, %r11d
+5:	shll	$8, %r9d
+	shll	$9, %r10d
+	shll	$10, %r11d
+	orl	%r9d, %eax
+	orl	%r10d, %eax
+	orl	%r11d, %eax
+	ret
+	.size	bj_value, .-bj_value
+
+	.section .note.GNU-stack,"",@progbits
