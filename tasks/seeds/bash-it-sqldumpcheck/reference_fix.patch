diff --git a/sqldumpcheck.sh b/sqldumpcheck.sh
--- a/sqldumpcheck.sh
+++ b/sqldumpcheck.sh
@@ -81,7 +81,9 @@ trap 'rm -f -- "$content"' EXIT
 
 if [ "$compressed" = yes ]; then
   # Retain decoded bytes so the structural checks can report useful errors.
-  gzip -dc -- "$dump" > "$content" 2>/dev/null || true
+  if ! gzip -dc -- "$dump" > "$content" 2>/dev/null; then
+    die "invalid gzip stream: $dump"
+  fi
 else
   cp -- "$dump" "$content" || die "cannot read dump: $dump"
 fi
