diff --git a/stagerun.ps1 b/stagerun.ps1
new file mode 100644
index 0000000..f21c9bb
--- /dev/null
+++ b/stagerun.ps1
@@ -0,0 +1,109 @@
+# stagerun.ps1 — run a maintenance plan's steps against a working area.
+# The plan is a JSON array of steps: {"name": ..., "action": ..., "arg": ...};
+# arg paths resolve against -Work. A failed step never stops the run: it is
+# caught, classified by exception type, and reported in the failures table.
+#
+# Error handling contract: this script runs with $ErrorActionPreference =
+# 'Stop' so that cmdlet errors (like the pull action's Get-Content, which is
+# non-terminating by default) become terminating and reach the typed catch
+# handlers like the .NET method exceptions do.
+#
+# Exit codes: 0 all steps ok, 65 plan not valid JSON, 66 plan file missing,
+# 70 at least one step failed, 75 lock already held.
+[CmdletBinding()]
+param(
+    [Parameter(Mandatory)][string]$Plan,
+    [Parameter(Mandatory)][string]$Work
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+if (-not (Test-Path -LiteralPath $Plan -PathType Leaf)) {
+    [Console]::Error.WriteLine("stagerun: plan not found: $Plan")
+    exit 66
+}
+
+try {
+    $steps = @([System.IO.File]::ReadAllText($Plan) | ConvertFrom-Json)
+} catch {
+    [Console]::Error.WriteLine("stagerun: plan is not valid JSON: $Plan")
+    exit 65
+}
+
+$lock = Join-Path $Work 'stage.lock'
+if (Test-Path -LiteralPath $lock) {
+    [Console]::Error.WriteLine("stagerun: lock present: $lock")
+    exit 75
+}
+
+[System.IO.File]::WriteAllText($lock, "held`n")
+
+$ok = 0
+$fail = 0
+$failRows = [System.Collections.Generic.List[object]]::new()
+
+Write-Output ("stage run: {0}" -f (Split-Path -Leaf $Plan))
+try {
+    foreach ($step in $steps) {
+        try {
+            $detail = ''
+            switch ($step.action) {
+                'read' {
+                    $text = [System.IO.File]::ReadAllText((Join-Path $Work $step.arg))
+                    $detail = "chars=$($text.Length)"
+                }
+                'sum' {
+                    $total = 0
+                    foreach ($line in [System.IO.File]::ReadAllLines((Join-Path $Work $step.arg))) {
+                        if ($line.Trim().Length -eq 0) { continue }
+                        $total += [int]::Parse($line.Trim())
+                    }
+                    $detail = "sum=$total"
+                }
+                'scan' {
+                    $files = [System.IO.Directory]::GetFiles((Join-Path $Work $step.arg))
+                    $detail = "files=$($files.Length)"
+                }
+                'pull' {
+                    $content = @(Get-Content -LiteralPath (Join-Path $Work $step.arg))
+                    $detail = "lines=$($content.Count)"
+                }
+                default {
+                    throw [System.NotSupportedException]::new("unknown action: $($step.action)")
+                }
+            }
+            Write-Output "ok $($step.name) $detail"
+            $ok++
+        } catch [System.IO.FileNotFoundException] {
+            $fail++; Write-Output "fail $($step.name) $($_.Exception.GetType().Name)"
+            $failRows.Add(@($step.name, $_.Exception.GetType().Name, 'missing-file'))
+        } catch [System.Management.Automation.ItemNotFoundException] {
+            $fail++; Write-Output "fail $($step.name) $($_.Exception.GetType().Name)"
+            $failRows.Add(@($step.name, $_.Exception.GetType().Name, 'missing-item'))
+        } catch [System.IO.DirectoryNotFoundException] {
+            $fail++; Write-Output "fail $($step.name) $($_.Exception.GetType().Name)"
+            $failRows.Add(@($step.name, $_.Exception.GetType().Name, 'missing-dir'))
+        } catch [System.FormatException] {
+            $fail++; Write-Output "fail $($step.name) $($_.Exception.GetType().Name)"
+            $failRows.Add(@($step.name, $_.Exception.GetType().Name, 'bad-number'))
+        } catch {
+            $fail++; Write-Output "fail $($step.name) $($_.Exception.GetType().Name)"
+            $failRows.Add(@($step.name, $_.Exception.GetType().Name, 'unexpected'))
+        }
+    }
+
+    if ($failRows.Count -gt 0) {
+        Write-Output 'failures:'
+        foreach ($row in $failRows) {
+            Write-Output ('{0,-12} {1,-28} {2}' -f $row[0], $row[1], $row[2])
+        }
+    }
+    Write-Output "steps: $($steps.Count) ok: $ok fail: $fail"
+} finally {
+    Remove-Item -LiteralPath $lock -Force
+    [System.IO.File]::WriteAllText((Join-Path $Work 'last.status'), "steps=$($steps.Count) ok=$ok fail=$fail`n")
+}
+
+if ($fail -gt 0) { exit 70 }
+exit 0
