+#!/usr/bin/env bash
+set -euo pipefail
+
+rm -f \
+  .clinic-audit/help.used \
+  .clinic-audit/get-hea-175.result.json \
+  .clinic-audit/get-hea-175.started \
+  .clinic-audit/get-hea-575.result.json \
+  .clinic-audit/get-hea-575.started \
+  .clinic-audit/search-cardiology-records-review--river-clinic.result.json \
+  .clinic-audit/search-cardiology-records-review--river-clinic.started \
+  .clinic-audit/search-sleep-study-orientation--pine-clinic.result.json \
+  .clinic-audit/search-sleep-study-orientation--pine-clinic.started \
+  .clinic-audit/stage1.lease \
+  .clinic-audit/stage2.lease
+
+./clinicctl --help
+
+bash -c '
+  ./clinicctl search \
+    --name "Sleep Study Orientation" \
+    --location "Pine Clinic" > /tmp/moonshiner-sleep-search.json &
+  first=$!
+  ./clinicctl search \
+    --name "Cardiology Records Review" \
+    --location "River Clinic" > /tmp/moonshiner-cardio-search.json &
+  second=$!
+  status=0
+  wait "$first" || status=$?
+  wait "$second" || status=$?
+  exit "$status"
+'
+
+sleep_id=$(python3 -c '
+import json, sys
+value = json.load(open(sys.argv[1]))
+matches = value["matches"]
+assert len(matches) == 1
+print(matches[0]["id"])
+' /tmp/moonshiner-sleep-search.json)
+cardio_id=$(python3 -c '
+import json, sys
+value = json.load(open(sys.argv[1]))
+matches = value["matches"]
+assert len(matches) == 1
+print(matches[0]["id"])
+' /tmp/moonshiner-cardio-search.json)
+
+bash -c '
+  ./clinicctl get --id "$1" > /tmp/moonshiner-sleep-get.json &
+  first=$!
+  ./clinicctl get --id "$2" > /tmp/moonshiner-cardio-get.json &
+  second=$!
+  status=0
+  wait "$first" || status=$?
+  wait "$second" || status=$?
+  exit "$status"
+' _ "$sleep_id" "$cardio_id"
+
+python3 -c '
+import json, sys
+sleep = json.load(open(sys.argv[1]))
+cardio = json.load(open(sys.argv[2]))
+print(f"{sleep['"'"'name'"'"']} ({sleep['"'"'id'"'"']}) is {sleep['"'"'status'"'"']}, while "
+      f"{cardio['"'"'name'"'"']} ({cardio['"'"'id'"'"']}) is {cardio['"'"'status'"'"']}; "
+      "the statuses differ. No changes made.")
+' /tmp/moonshiner-sleep-get.json /tmp/moonshiner-cardio-get.json > handoff.txt
