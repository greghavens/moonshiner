diff --git a/effconf.ps1 b/effconf.ps1
new file mode 100644
index 0000000..db5d755
--- /dev/null
+++ b/effconf.ps1
@@ -0,0 +1,117 @@
+# effconf.ps1 — print the metrics shipper's effective configuration.
+# Precedence: built-in defaults < config file < explicit arguments.
+[CmdletBinding()]
+param(
+    [string]$Config,
+    [string]$Endpoint,
+    [int]$BatchSize,
+    [int]$FlushSeconds,
+    [string]$Region,
+    [switch]$Compress
+)
+
+Set-StrictMode -Version Latest
+$ErrorActionPreference = 'Stop'
+
+function Exit-Usage {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit 64
+}
+
+function Exit-Data {
+    param([string]$Message)
+    [Console]::Error.WriteLine($Message)
+    exit 65
+}
+
+$resolved = @{
+    BatchSize    = 50
+    Compress     = $false
+    Endpoint     = 'http://127.0.0.1:9009/ingest'
+    FlushSeconds = 10
+    Region       = 'local'
+}
+$settingNames = [string[]]@($resolved.Keys)
+[Array]::Sort($settingNames, [System.StringComparer]::Ordinal)
+
+if ($PSBoundParameters.ContainsKey('Config')) {
+    if ($Config -eq '') {
+        Exit-Usage 'effconf: -Config requires a non-empty path'
+    }
+    if (-not (Test-Path -LiteralPath $Config -PathType Leaf)) {
+        Exit-Data "effconf: config not found: $Config"
+    }
+    $raw = Get-Content -LiteralPath $Config -Raw
+    try {
+        $parsed = ConvertFrom-Json -InputObject $raw -AsHashtable
+    } catch {
+        Exit-Data "effconf: config is not valid JSON: $Config"
+    }
+    if ($parsed -isnot [hashtable]) {
+        Exit-Data 'effconf: config must be a JSON object'
+    }
+
+    # Report problems deterministically: ordinal key order, unknown first.
+    $configKeys = [string[]]@($parsed.Keys)
+    [Array]::Sort($configKeys, [System.StringComparer]::Ordinal)
+    foreach ($key in $configKeys) {
+        if ($settingNames -cnotcontains $key) {
+            Exit-Data "effconf: unknown setting in config: $key"
+        }
+    }
+    foreach ($key in $configKeys) {
+        $value = $parsed[$key]
+        switch ($key) {
+            { $_ -in @('BatchSize', 'FlushSeconds') } {
+                if (-not ($value -is [long] -or $value -is [int])) {
+                    Exit-Data "effconf: setting $key must be a whole number"
+                }
+                $resolved[$key] = [int]$value
+            }
+            'Compress' {
+                if ($value -isnot [bool]) {
+                    Exit-Data 'effconf: setting Compress must be true or false'
+                }
+                $resolved[$key] = $value
+            }
+            default {
+                if ($value -isnot [string]) {
+                    Exit-Data "effconf: setting $key must be a string"
+                }
+                $resolved[$key] = $value
+            }
+        }
+    }
+}
+
+# Explicit arguments win regardless of their value ($PSBoundParameters,
+# not truthiness: -BatchSize 50 and -Compress:$false still count).
+foreach ($name in $settingNames) {
+    if ($PSBoundParameters.ContainsKey($name)) {
+        if ($name -eq 'Compress') {
+            $resolved[$name] = [bool]$Compress
+        } else {
+            $resolved[$name] = Get-Variable -Name $name -ValueOnly
+        }
+    }
+}
+
+if ($resolved['BatchSize'] -lt 1 -or $resolved['BatchSize'] -gt 10000) {
+    Exit-Data "effconf: BatchSize out of range: $($resolved['BatchSize'])"
+}
+if ($resolved['FlushSeconds'] -lt 1 -or $resolved['FlushSeconds'] -gt 3600) {
+    Exit-Data "effconf: FlushSeconds out of range: $($resolved['FlushSeconds'])"
+}
+
+$lines = @(foreach ($name in $settingNames) {
+    $value = $resolved[$name]
+    $rendered = if ($value -is [bool]) {
+        if ($value) { 'true' } else { 'false' }
+    } else {
+        [string]$value
+    }
+    "$name=$rendered"
+})
+Write-Output ($lines -join "`n")
+exit 0
