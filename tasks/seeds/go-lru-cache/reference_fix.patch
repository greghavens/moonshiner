+// Package lru implements a bounded, concurrency-safe cache with strict
+// least-recently-used eviction and an optional eviction callback.
+package lru
+
+import (
+	"fmt"
+	"sync"
+)
+
+type node[K comparable, V any] struct {
+	key        K
+	value      V
+	prev, next *node[K, V]
+}
+
+// Cache is a fixed-capacity LRU cache. All methods are safe for
+// concurrent use.
+type Cache[K comparable, V any] struct {
+	mu       sync.Mutex
+	capacity int
+	onEvict  func(K, V)
+	items    map[K]*node[K, V]
+	// head is most recently used, tail is least recently used.
+	head, tail *node[K, V]
+}
+
+// New builds a cache holding at most capacity entries. onEvict, if
+// non-nil, is called synchronously with each entry displaced by
+// capacity pressure (not by overwrites or Remove).
+func New[K comparable, V any](capacity int, onEvict func(K, V)) (*Cache[K, V], error) {
+	if capacity < 1 {
+		return nil, fmt.Errorf("lru: capacity must be at least 1, got %d", capacity)
+	}
+	return &Cache[K, V]{
+		capacity: capacity,
+		onEvict:  onEvict,
+		items:    make(map[K]*node[K, V], capacity),
+	}, nil
+}
+
+// unlink removes n from the recency list. Callers hold c.mu.
+func (c *Cache[K, V]) unlink(n *node[K, V]) {
+	if n.prev != nil {
+		n.prev.next = n.next
+	} else {
+		c.head = n.next
+	}
+	if n.next != nil {
+		n.next.prev = n.prev
+	} else {
+		c.tail = n.prev
+	}
+	n.prev, n.next = nil, nil
+}
+
+// pushFront makes n the most recently used entry. Callers hold c.mu.
+func (c *Cache[K, V]) pushFront(n *node[K, V]) {
+	n.next = c.head
+	if c.head != nil {
+		c.head.prev = n
+	}
+	c.head = n
+	if c.tail == nil {
+		c.tail = n
+	}
+}
+
+// Put inserts or replaces the value for key, marking it most recently
+// used. If the insert exceeds capacity, the least recently used entry
+// is evicted and reported to the callback.
+func (c *Cache[K, V]) Put(key K, value V) {
+	c.mu.Lock()
+	if n, ok := c.items[key]; ok {
+		n.value = value
+		c.unlink(n)
+		c.pushFront(n)
+		c.mu.Unlock()
+		return
+	}
+	n := &node[K, V]{key: key, value: value}
+	c.items[key] = n
+	c.pushFront(n)
+	var evictedKey K
+	var evictedVal V
+	evicted := false
+	if len(c.items) > c.capacity {
+		lru := c.tail
+		c.unlink(lru)
+		delete(c.items, lru.key)
+		evictedKey, evictedVal, evicted = lru.key, lru.value, true
+	}
+	c.mu.Unlock()
+	if evicted && c.onEvict != nil {
+		c.onEvict(evictedKey, evictedVal)
+	}
+}
+
+// Get returns the value for key and marks it most recently used.
+func (c *Cache[K, V]) Get(key K) (V, bool) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	n, ok := c.items[key]
+	if !ok {
+		var zero V
+		return zero, false
+	}
+	c.unlink(n)
+	c.pushFront(n)
+	return n.value, true
+}
+
+// Remove deletes key without invoking the eviction callback and
+// reports whether it was present.
+func (c *Cache[K, V]) Remove(key K) bool {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	n, ok := c.items[key]
+	if !ok {
+		return false
+	}
+	c.unlink(n)
+	delete(c.items, key)
+	return true
+}
+
+// Len reports the number of resident entries.
+func (c *Cache[K, V]) Len() int {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	return len(c.items)
+}
