+namespace PatchBay;
+
+/// <summary>
+/// Sign-out board for the shared outboard rack. Units are checked out to a
+/// session as a <see cref="GearLease"/> and come back via Dispose — exactly
+/// once, deterministically, no finalizers anywhere.
+/// </summary>
+public sealed class GearBoard
+{
+    private readonly Dictionary<string, string?> _holders;   // unit -> session or null when racked
+    private readonly List<string> _releaseLog = new();
+
+    public GearBoard(params string[] units)
+    {
+        _holders = new Dictionary<string, string?>(StringComparer.Ordinal);
+        foreach (var unit in units)
+        {
+            if (!_holders.TryAdd(unit, null))
+                throw new ArgumentException($"duplicate unit '{unit}'", nameof(units));
+        }
+    }
+
+    public int ActiveCount => _holders.Count(kv => kv.Value is not null);
+
+    public IReadOnlyList<string> ActiveUnits =>
+        _holders.Where(kv => kv.Value is not null)
+                .Select(kv => kv.Key)
+                .OrderBy(u => u, StringComparer.Ordinal)
+                .ToList();
+
+    public IReadOnlyList<string> ReleaseLog => _releaseLog;
+
+    public GearLease Acquire(string unit, string session)
+    {
+        if (!_holders.TryGetValue(unit, out var holder))
+            throw new KeyNotFoundException($"no such unit '{unit}'");
+        if (holder is not null)
+            throw new InvalidOperationException($"unit '{unit}' is already leased to session '{holder}'");
+        _holders[unit] = session;
+        return new GearLease(this, unit, session);
+    }
+
+    public void AssertAllReleased()
+    {
+        var stillOut = _holders.Where(kv => kv.Value is not null)
+                               .Select(kv => kv.Key)
+                               .OrderBy(u => u, StringComparer.Ordinal)
+                               .ToList();
+        if (stillOut.Count > 0)
+            throw new InvalidOperationException($"unreleased units: {string.Join(", ", stillOut)}");
+    }
+
+    internal void Release(string unit, string session)
+    {
+        _holders[unit] = null;
+        _releaseLog.Add($"{unit}:{session}");
+    }
+}
+
+/// <summary>One unit checked out to one session. Dispose returns it — once.</summary>
+public sealed class GearLease : IDisposable
+{
+    private readonly GearBoard _board;
+    private bool _released;
+
+    internal GearLease(GearBoard board, string unit, string session)
+    {
+        _board = board;
+        Unit = unit;
+        Session = session;
+    }
+
+    public string Unit { get; }
+    public string Session { get; }
+    public bool IsReleased => _released;
+
+    /// <summary>Patch the unit into a console channel.</summary>
+    public string Route(string channel)
+    {
+        if (_released)
+            throw new ObjectDisposedException(nameof(GearLease));
+        return $"{Unit}<-{channel}";
+    }
+
+    public void Dispose()
+    {
+        if (_released)
+            return;
+        _released = true;
+        _board.Release(Unit, Session);
+    }
+}
