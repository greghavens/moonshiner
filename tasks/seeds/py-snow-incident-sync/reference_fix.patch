index 0000000..73393d5
--- /dev/null
+++ b/snow_sync/sync.py
@@ -0,0 +1,55 @@
+"""Idempotent incident synchronization on top of the Table API client."""
+
+from dataclasses import dataclass, field
+
+from snow_sync.client import TableClient
+
+
+@dataclass
+class SyncReport:
+    created: int = 0
+    updated: int = 0
+    skipped: int = 0
+    sys_ids: dict = field(default_factory=dict)
+
+
+class IncidentSyncer:
+    TABLE = "incident"
+
+    def __init__(self, client: TableClient, key_field="correlation_id"):
+        self.client = client
+        self.key_field = key_field
+
+    def sync(self, desired):
+        report = SyncReport()
+        if not desired:
+            return report
+        keys = [d[self.key_field] for d in desired]
+        value_fields = sorted(
+            {f for d in desired for f in d if f != self.key_field})
+        lookup_fields = ["sys_id", self.key_field] + value_fields
+        query = f"{self.key_field}IN{','.join(keys)}^ORDERBYsys_id"
+        existing = {
+            rec[self.key_field]: rec
+            for rec in self.client.get_records(
+                self.TABLE, query=query, fields=lookup_fields)
+        }
+        for want in desired:
+            key = want[self.key_field]
+            current = existing.get(key)
+            if current is None:
+                created = self.client.create_record(self.TABLE, dict(want))
+                report.created += 1
+                report.sys_ids[key] = created["sys_id"]
+                continue
+            changes = {
+                f: v for f, v in want.items()
+                if f != self.key_field and str(current.get(f, "")) != str(v)
+            }
+            if changes:
+                self.client.update_record(self.TABLE, current["sys_id"], changes)
+                report.updated += 1
+            else:
+                report.skipped += 1
+            report.sys_ids[key] = current["sys_id"]
+        return report
