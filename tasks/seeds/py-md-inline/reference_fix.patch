+"""Inline markdown -> HTML for one-line strings (bold/italic/code/links).
+
+Deliberately not CommonMark: the supported subset is defined by the
+acceptance tests. Recursive descent, no regex.
+"""
+
+_SPECIALS = "\\`*[]()"
+
+
+def _esc(text):
+    return (text.replace("&", "&amp;").replace("<", "&lt;")
+                .replace(">", "&gt;").replace('"', "&quot;"))
+
+
+def _skip_code_span(text, i):
+    """text[i] == '`': return index just past the span, or i+1 if unmatched."""
+    end = text.find("`", i + 1)
+    if end > i + 1:
+        return end + 1
+    return i + 1
+
+
+def _find_close(text, start, double):
+    """Find the '*' (or '**') closing an emphasis opened before `start`.
+
+    Skips escapes and code spans. A '**' pair never closes a single '*'
+    and a lone '*' never closes '**'. Returns -1 when unmatched.
+    """
+    j = start
+    while j < len(text):
+        c = text[j]
+        if c == "\\" and j + 1 < len(text) and text[j + 1] in _SPECIALS:
+            j += 2
+        elif c == "`":
+            j = _skip_code_span(text, j)
+        elif double and text.startswith("**", j):
+            if j > start:
+                return j
+            j += 2
+        elif not double and c == "*":
+            if text.startswith("**", j):
+                j += 2  # a bold pair cannot close a single star
+            elif j > start:
+                return j
+            else:
+                j += 1
+        else:
+            j += 1
+    return -1
+
+
+def _find_bracket_close(text, start):
+    """Index of the ']' matching a '[' just before start, honoring escapes."""
+    j = start
+    while j < len(text):
+        c = text[j]
+        if c == "\\" and j + 1 < len(text) and text[j + 1] in _SPECIALS:
+            j += 2
+        elif c == "]":
+            return j
+        else:
+            j += 1
+    return -1
+
+
+def render_inline(text):
+    out = []
+    i = 0
+    n = len(text)
+    while i < n:
+        c = text[i]
+        if c == "\\" and i + 1 < n and text[i + 1] in _SPECIALS:
+            out.append(_esc(text[i + 1]))
+            i += 2
+        elif c == "`":
+            end = text.find("`", i + 1)
+            if end > i + 1:
+                out.append(f"<code>{_esc(text[i + 1:end])}</code>")
+                i = end + 1
+            else:
+                out.append("`")
+                i += 1
+        elif c == "[":
+            i = _render_link(text, i, out)
+        elif text.startswith("**", i):
+            close = _find_close(text, i + 2, double=True)
+            if close != -1:
+                out.append(f"<strong>{render_inline(text[i + 2:close])}</strong>")
+                i = close + 2
+            else:
+                out.append("**")
+                i += 2
+        elif c == "*":
+            close = _find_close(text, i + 1, double=False)
+            if close != -1:
+                out.append(f"<em>{render_inline(text[i + 1:close])}</em>")
+                i = close + 1
+            else:
+                out.append("*")
+                i += 1
+        else:
+            out.append(_esc(c))
+            i += 1
+    return "".join(out)
+
+
+def _render_link(text, i, out):
+    """Render a link starting at text[i] == '['. Returns the resume index."""
+    bracket = _find_bracket_close(text, i + 1)
+    if bracket == -1 or bracket + 1 >= len(text) or text[bracket + 1] != "(":
+        out.append("[")
+        return i + 1
+    paren = text.find(")", bracket + 2)
+    if paren == -1:
+        out.append("[")
+        return i + 1
+    label = render_inline(text[i + 1:bracket])
+    url = _esc(text[bracket + 2:paren])
+    out.append(f'<a href="{url}">{label}</a>')
+    return paren + 1
