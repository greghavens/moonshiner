+// Package bloom implements a deterministic bloom filter: a fixed-size bit
+// set with k hash functions derived from FNV variants via double hashing.
+// It never yields false negatives and supports unioning same-shape filters.
+package bloom
+
+import (
+	"errors"
+	"fmt"
+	"hash/fnv"
+	"math/bits"
+)
+
+// ErrShapeMismatch reports a Union between filters whose bit counts or
+// hash counts differ.
+var ErrShapeMismatch = errors.New("bloom: filters have different shapes")
+
+// Filter is a bloom filter over string keys. The zero value is not usable;
+// construct with New.
+type Filter struct {
+	bits   int
+	hashes int
+	words  []uint64
+}
+
+// New returns a filter with the given number of bits and hash functions.
+// Both must be positive.
+func New(bitCount, hashes int) (*Filter, error) {
+	if bitCount <= 0 {
+		return nil, fmt.Errorf("bloom: bit count must be positive, got %d", bitCount)
+	}
+	if hashes <= 0 {
+		return nil, fmt.Errorf("bloom: hash count must be positive, got %d", hashes)
+	}
+	return &Filter{
+		bits:   bitCount,
+		hashes: hashes,
+		words:  make([]uint64, (bitCount+63)/64),
+	}, nil
+}
+
+// Bits returns the size of the underlying bit set.
+func (f *Filter) Bits() int { return f.bits }
+
+// Hashes returns the number of hash functions applied per key.
+func (f *Filter) Hashes() int { return f.hashes }
+
+// indexes derives the k bit positions for key using double hashing over
+// two deterministic FNV-64 hashes.
+func (f *Filter) indexes(key string, visit func(idx int)) {
+	h1sum := fnv.New64a()
+	h1sum.Write([]byte(key))
+	h1 := h1sum.Sum64()
+
+	h2sum := fnv.New64()
+	h2sum.Write([]byte(key))
+	h2 := h2sum.Sum64() | 1 // force odd so the probe sequence cycles well
+
+	m := uint64(f.bits)
+	for i := 0; i < f.hashes; i++ {
+		visit(int((h1 + uint64(i)*h2) % m))
+	}
+}
+
+// Add records key in the filter.
+func (f *Filter) Add(key string) {
+	f.indexes(key, func(idx int) {
+		f.words[idx/64] |= 1 << uint(idx%64)
+	})
+}
+
+// MaybeContains reports whether key may have been added. False means the
+// key was definitely never added; true means it probably was.
+func (f *Filter) MaybeContains(key string) bool {
+	present := true
+	f.indexes(key, func(idx int) {
+		if f.words[idx/64]&(1<<uint(idx%64)) == 0 {
+			present = false
+		}
+	})
+	return present
+}
+
+// EstimatedFill returns the fraction of bits currently set, in [0, 1].
+func (f *Filter) EstimatedFill() float64 {
+	set := 0
+	for _, w := range f.words {
+		set += bits.OnesCount64(w)
+	}
+	return float64(set) / float64(f.bits)
+}
+
+// Union ORs other into the receiver. Both filters must have identical
+// shapes (bit count and hash count); otherwise ErrShapeMismatch is
+// returned and the receiver is left unchanged. The argument is never
+// modified.
+func (f *Filter) Union(other *Filter) error {
+	if other.bits != f.bits || other.hashes != f.hashes {
+		return fmt.Errorf("%w: %dx%d vs %dx%d", ErrShapeMismatch, f.bits, f.hashes, other.bits, other.hashes)
+	}
+	for i, w := range other.words {
+		f.words[i] |= w
+	}
+	return nil
+}
