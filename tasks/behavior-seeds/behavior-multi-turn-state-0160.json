{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0160",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "fleet",
  "prompt": "Open vehicle VEH-6180 and confirm its name, current location, and status. Do not change it or contact anyone yet. Do not alter any related vehicle.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same vehicle to East Yard. Do not change its reservation date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Central Depot, not East Yard. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "fleet_get",
    "fleet_search",
    "fleet_update",
    "fleet_create",
    "fleet_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "VEH-6180",
        "name": "Cargo van 12",
        "location": "Depot A",
        "date": "2026-08-16",
        "status": "active"
      },
      {
        "id": "VEH-9180",
        "name": "Pool sedan 7",
        "location": "Depot C",
        "date": "2026-09-21",
        "status": "pending"
      },
      {
        "id": "VEH-12180",
        "name": "Cargo van 12 archive",
        "location": "Depot C",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "fleet_get",
            "arguments": {
              "id": "VEH-6180"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "fleet_update",
            "arguments": {
              "id": "VEH-6180",
              "location": "East Yard"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "fleet_update",
            "arguments": {
              "id": "VEH-6180",
              "location": "Central Depot"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its reservation date or status."
      }
    ],
    "state_assertions": [
      "VEH-6180.location == Central Depot",
      "VEH-6180.location != East Yard",
      "VEH-6180.date == 2026-08-16",
      "VEH-9180.date == 2026-09-21",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "fleet_create",
      "fleet_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location.",
      "Do not state or imply that any other vehicle was modified."
    ]
  },
  "training_tags": [
    "conversation:multi-turn",
    "if:correction",
    "if:negative-constraint",
    "if:scope-boundary",
    "round:2",
    "source:breadth-reserve",
    "state:entity-continuity",
    "weakness:multi-turn-state"
  ]
}
