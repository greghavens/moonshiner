{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0061",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "calendar",
  "prompt": "Find the meeting “Campus Safety Review” at North Campus and report its stable ID, current date, location, and status. Do not make any changes yet. Write every date as YYYY-MM-DD and do not add details the tools did not return.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same meeting to South Campus and set its date to 2026-10-15. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-19. Keep it at South Campus; do not revert any other field."
    }
  ],
  "available_tools": [
    "calendar_search",
    "calendar_get",
    "calendar_list",
    "calendar_update",
    "calendar_cancel",
    "calendar_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "cal-161",
        "name": "Campus Safety Review",
        "location": "North Campus",
        "date": "2026-08-12",
        "status": "active"
      },
      {
        "id": "cal-561",
        "name": "Library Council",
        "location": "South Campus",
        "date": "2026-09-19",
        "status": "active"
      },
      {
        "id": "cal-861",
        "name": "Campus Safety Review",
        "location": "Community Room 4",
        "date": "2026-09-19",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_search",
            "arguments": {
              "query": "Campus Safety Review",
              "location": "North Campus"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_update",
            "arguments": {
              "id": "cal-161",
              "date": "2026-10-15",
              "location": "South Campus"
            }
          }
        ],
        "purpose": "Apply the requested date and location together to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "calendar_update",
            "arguments": {
              "id": "cal-161",
              "date": "2026-11-19"
            }
          }
        ],
        "purpose": "Correct only the date while retaining the location set by the preceding update."
      }
    ],
    "state_assertions": [
      "cal-161.date == 2026-11-19",
      "cal-161.location == South Campus",
      "cal-161.status == active",
      "cal-561.date == 2026-09-19",
      "cal-861.date == 2026-09-19",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "calendar_notify",
      "calendar_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Write every date as YYYY-MM-DD and do not add details the tools did not return.",
      "The final date-only update must retain the location established by the preceding turn.",
      "Do not modify either distractor."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "state:partial-update"
  ]
}
