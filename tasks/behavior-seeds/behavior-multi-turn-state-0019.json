{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0019",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "public-services",
  "prompt": "Look up the exact application “Pet License Renewal” at Aurora Service Center and tell me its record ID, current date, and status. This first turn is read-only. Include the stable record ID whenever you report or confirm a date.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Now change that application's date to 2026-10-09. Keep its location and status as they are, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: I gave you the wrong date. Use 2026-11-13 instead. Leave every other field unchanged and still do not notify anyone."
    }
  ],
  "available_tools": [
    "public-services_search",
    "public-services_get",
    "public-services_list",
    "public-services_update",
    "public-services_cancel",
    "public-services_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "pub-119",
        "name": "Pet License Renewal",
        "location": "Aurora Service Center",
        "date": "2026-08-06",
        "status": "active"
      },
      {
        "id": "pub-519",
        "name": "Pet License Renewal",
        "location": "Lakewood Service Center",
        "date": "2026-09-13",
        "status": "active"
      },
      {
        "id": "pub-819",
        "name": "Bicycle Registration",
        "location": "Aurora Service Center",
        "date": "2026-09-13",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_search",
            "arguments": {
              "query": "Pet License Renewal",
              "location": "Aurora Service Center"
            }
          }
        ],
        "purpose": "Resolve the exact record from its name and location without changing state."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-119",
              "date": "2026-10-09"
            }
          }
        ],
        "purpose": "Apply the user's first requested date to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-119",
              "date": "2026-11-13"
            }
          }
        ],
        "purpose": "Apply the later correction to the same record, superseding the earlier date."
      }
    ],
    "state_assertions": [
      "pub-119.date == 2026-11-13",
      "pub-119.location == Aurora Service Center",
      "pub-119.status == active",
      "pub-519.date == 2026-09-13",
      "pub-819.date == 2026-09-13",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "public-services_notify",
      "public-services_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Include the stable record ID whenever you report or confirm a date.",
      "Treat the corrected date as final; do not present the first requested date as current."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:search-update"
  ]
}
