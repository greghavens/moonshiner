{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0075",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "health-admin",
  "prompt": "Find the appointment “Imaging Consultation” at Dale Clinic and report its stable ID, current date, location, and status. Do not make any changes yet. Use one concise sentence at each turn and include the stable record ID.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same appointment to Cedar Clinic and set its date to 2026-10-11. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-15. Keep it at Cedar Clinic; do not revert any other field."
    }
  ],
  "available_tools": [
    "health-admin_search",
    "health-admin_get",
    "health-admin_list",
    "health-admin_update",
    "health-admin_cancel",
    "health-admin_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "hea-175",
        "name": "Imaging Consultation",
        "location": "Dale Clinic",
        "date": "2026-08-08",
        "status": "active"
      },
      {
        "id": "hea-575",
        "name": "Orthopedic Follow-up",
        "location": "Cedar Clinic",
        "date": "2026-09-15",
        "status": "active"
      },
      {
        "id": "hea-875",
        "name": "Imaging Consultation",
        "location": "South Health Center",
        "date": "2026-09-15",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "health-admin_search",
            "arguments": {
              "query": "Imaging Consultation",
              "location": "Dale Clinic"
            }
          }
        ],
        "purpose": "Resolve the target record before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "health-admin_update",
            "arguments": {
              "id": "hea-175",
              "date": "2026-10-11",
              "location": "Cedar Clinic"
            }
          }
        ],
        "purpose": "Apply the requested date and location together to the resolved record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "health-admin_update",
            "arguments": {
              "id": "hea-175",
              "date": "2026-11-15"
            }
          }
        ],
        "purpose": "Correct only the date while retaining the location set by the preceding update."
      }
    ],
    "state_assertions": [
      "hea-175.date == 2026-11-15",
      "hea-175.location == Cedar Clinic",
      "hea-175.status == active",
      "hea-575.date == 2026-09-15",
      "hea-875.date == 2026-09-15",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "health-admin_notify",
      "health-admin_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Use one concise sentence at each turn and include the stable record ID.",
      "The final date-only update must retain the location established by the preceding turn.",
      "Do not modify either distractor."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "state:partial-update"
  ]
}
