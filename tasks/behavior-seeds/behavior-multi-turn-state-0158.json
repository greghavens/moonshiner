{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0158",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "telecom",
  "prompt": "Check subscription SUB-6154 and confirm its name, current location, and status. Do not change it or contact anyone yet. If the tool omits a requested field, call it unknown instead of filling it in.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move that same subscription to Business Accounts. Do not change its renewal date or status, and do not notify anyone."
    },
    {
      "after_stage": 2,
      "content": "Correction: the new location should be Studio Services, not Business Accounts. Keep every other field as it is."
    }
  ],
  "available_tools": [
    "telecom_get",
    "telecom_search",
    "telecom_update",
    "telecom_create",
    "telecom_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "SUB-6154",
        "name": "Studio mobile bundle",
        "location": "Pine Street Studio",
        "date": "2026-08-14",
        "status": "active"
      },
      {
        "id": "SUB-9154",
        "name": "Library branch broadband",
        "location": "East Branch",
        "date": "2026-09-19",
        "status": "pending"
      },
      {
        "id": "SUB-12154",
        "name": "Studio mobile bundle archive",
        "location": "East Branch",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_get",
            "arguments": {
              "id": "SUB-6154"
            }
          }
        ],
        "purpose": "Retrieve the explicitly identified target before any mutation."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_update",
            "arguments": {
              "id": "SUB-6154",
              "location": "Business Accounts"
            }
          }
        ],
        "purpose": "Change only the target's location to the first requested value."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "telecom_update",
            "arguments": {
              "id": "SUB-6154",
              "location": "Studio Services"
            }
          }
        ],
        "purpose": "Correct the location on the same target without changing its renewal date or status."
      }
    ],
    "state_assertions": [
      "SUB-6154.location == Studio Services",
      "SUB-6154.location != Business Accounts",
      "SUB-6154.date == 2026-08-14",
      "SUB-9154.date == 2026-09-19",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "telecom_create",
      "telecom_notify"
    ],
    "response_constraints": [
      "Keep both location changes tied to the record retrieved by the explicit ID.",
      "Do not claim a retrieval or update succeeded unless the corresponding tool result confirms it.",
      "State that the first location was superseded and report the corrected location.",
      "Label any requested field omitted by a tool result as unknown."
    ]
  },
  "training_tags": [
