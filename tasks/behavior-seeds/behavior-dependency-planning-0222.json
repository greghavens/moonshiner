  "category": "dependency-planning",
  "expected": {
    "decision": "tool_calls",
    "forbidden_tools": [
      "travel_update",
      "travel_cancel",
      "travel_notify"
    ],
    "response_constraints": [
      "Base the comparison only on records returned by travel_get, not on search snippets or fixture knowledge.",
      "Do not call travel_update, travel_cancel, or travel_notify.",
      "Label absent retrieved fields as unknown rather than inferring them."
    ],
    "stages": [
      {
        "calls": [
          {
            "arguments": {
              "location": "Kyoto",
              "query": "Kyoto archives visit"
            },
            "tool": "travel_search"
          },
          {
            "arguments": {
              "location": "Osaka",
              "query": "Osaka supplier tour"
            },
            "tool": "travel_search"
          }
        ],
        "parallel": true,
        "purpose": "Issue both independent searches together in one assistant action; neither call uses another call's output."
      },
      {
        "calls": [
          {
            "arguments": {
              "id": "tra-322"
            },
            "tool": "travel_get"
          },
          {
            "arguments": {
              "id": "tra-722"
            },
            "tool": "travel_get"
          }
        ],
        "parallel": true,
        "purpose": "After stage 1 returns one unique ID per query, retrieve both records together in a later assistant action."
      }
    ],
    "state_assertions": [
      "The IDs used by travel_get come from the corresponding stage-1 search results.",
      "All three fixture records remain unchanged.",
      "The distractor tra-322-alt is never retrieved or mutated."
    ]
  },
