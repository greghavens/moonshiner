      },
      {
        "id": "shi-588",
        "name": "Festival Banner Crate",
        "location": "Civic Center",
        "date": "2026-09-10",
        "status": "active"
      },
      {
        "id": "shi-888",
        "name": "Stage Lighting Crate",
        "location": "Arts Warehouse",
        "date": "2026-09-10",
        "status": "pending"
      }
