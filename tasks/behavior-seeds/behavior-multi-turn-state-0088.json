  "category": "multi-turn-state",
  "world": "shipping",
  "prompt": "Locate the exact shipment “Festival Banner Crate” at Arts Warehouse and tell me its stable ID, date, and status. Do not update it until I follow up. Do not send a notification or message at any point.",
