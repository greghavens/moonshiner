{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0053",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "library",
  "prompt": "Look up two records without changing either one: the title record “River Glass” at Riverside Branch, and “Mosslight” at Central Branch. Report each stable ID, date, and status. Do not send a notification or message at any point.",
  "follow_up_turns": [
    {
      "after_stage": 1,
      "content": "Move only the first title record, “River Glass,” to 2026-10-25. Leave “Mosslight” untouched and do not send a notification."
    },
    {
      "after_stage": 2,
      "content": "Date correction for “River Glass” only: use 2026-11-11. The other record must remain unchanged."
    }
  ],
  "available_tools": [
    "library_search",
    "library_get",
    "library_list",
    "library_update",
    "library_cancel",
    "library_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "lib-153",
        "name": "River Glass",
        "location": "Riverside Branch",
        "date": "2026-08-22",
        "status": "active"
      },
      {
        "id": "lib-553",
        "name": "River Glass",
        "location": "Central Branch",
        "date": "2026-09-11",
        "status": "active"
      },
      {
        "id": "lib-853",
        "name": "Mosslight",
        "location": "Central Branch",
        "date": "2026-09-11",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": true,
        "calls": [
          {
            "tool": "library_search",
            "arguments": {
              "query": "River Glass",
              "location": "Riverside Branch"
            }
          },
          {
            "tool": "library_search",
            "arguments": {
              "query": "Mosslight",
              "location": "Central Branch"
            }
          }
        ],
        "purpose": "Run two independent record lookups in one assistant action."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "library_update",
            "arguments": {
              "id": "lib-153",
              "date": "2026-10-25"
            }
          }
        ],
        "purpose": "Change only the first record named by the follow-up."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "library_update",
            "arguments": {
              "id": "lib-153",
              "date": "2026-11-11"
            }
          }
        ],
        "purpose": "Apply the corrected date to that same first record."
      }
    ],
    "state_assertions": [
      "lib-153.date == 2026-11-11",
      "lib-553.date == 2026-09-11",
      "lib-853.date == 2026-09-11",
      "lib-853.status == pending",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "library_notify",
      "library_cancel"
    ],
    "response_constraints": [
      "Base every reported field and confirmation on tool results.",
      "Use the resolved target ID for both update turns; do not repeat the search after the correction.",
      "Do not call the notification or cancellation tools.",
      "Do not send a notification or message at any point.",
      "Report both lookup results before the follow-up.",
      "Never imply that the comparison record was updated.",
      "The two initial searches must be issued together because neither depends on the other."
    ]
  },
  "training_tags": [
    "behavior:multi-turn",
    "state:entity-continuity",
    "instruction:latest-correction",
    "constraint:no-notification",
    "flow:parallel-lookup",
    "parallel:independent"
  ]
}
