{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0039",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "public-services",
  "prompt": "Search for the exact application “Block-party Permit” at Lakewood Service Center, then open the matching record before reporting its ID, date, and status. Do not change it on this turn. Include the stable record ID whenever you report or confirm a date.",
  "follow_up_turns": [
    {
      "after_stage": 2,
      "content": "Thanks. Move that same application to 2026-10-11; change no other field and send no notification."
    },
    {
      "after_stage": 3,
      "content": "One correction: the date should be 2026-11-15, not 2026-10-11. Keep the same record and do not notify anyone."
    }
  ],
  "available_tools": [
    "public-services_search",
    "public-services_get",
    "public-services_list",
    "public-services_update",
    "public-services_cancel",
    "public-services_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "pub-139",
        "name": "Block-party Permit",
        "location": "Lakewood Service Center",
        "date": "2026-08-08",
