      },
      {
        "id": "pub-539",
        "name": "Block-party Permit",
        "location": "Aurora Service Center",
        "date": "2026-09-15",
        "status": "active"
      },
      {
        "id": "pub-839",
        "name": "Street Closure Permit",
        "location": "Lakewood Service Center",
        "date": "2026-09-15",
        "status": "pending"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_search",
            "arguments": {
              "query": "Block-party Permit",
              "location": "Lakewood Service Center"
            }
          }
        ],
        "purpose": "Find the stable identifier for the uniquely located record."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_get",
            "arguments": {
              "id": "pub-139"
            }
          }
        ],
        "purpose": "Retrieve the exact record identified by the search; this call depends on the search result."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-139",
              "date": "2026-10-11"
            }
          }
        ],
        "purpose": "Update only the resolved record after the user's follow-up."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "public-services_update",
            "arguments": {
              "id": "pub-139",
              "date": "2026-11-15"
            }
          }
