      "after_stage": 1,
      "content": "Move that same support case to Delta Hardware and set its date to 2026-10-19. Keep its status unchanged and notify no one."
    },
    {
      "after_stage": 2,
      "content": "The new location is right, but correct the date to 2026-11-23. Keep it at Delta Hardware; do not revert any other field."
    }
  ],
  "available_tools": [
    "support_search",
    "support_get",
    "support_list",
    "support_update",
    "support_cancel",
    "support_notify"
  ],
