        "name": "Warranty Replacement Case",
        "location": "Delta Bikes",
        "date": "2026-08-16",
        "status": "active"
      },
      {
        "id": "sup-565",
        "name": "Repair Status Case",
        "location": "Delta Hardware",
        "date": "2026-09-05",
        "status": "active"
      },
      {
        "id": "sup-865",
        "name": "Warranty Replacement Case",
        "location": "Cedar Clinic",
        "date": "2026-09-05",
        "status": "pending"
      }
