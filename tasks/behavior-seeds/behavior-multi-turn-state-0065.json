  "world": "support",
  "prompt": "Find the support case “Warranty Replacement Case” at Delta Bikes and report its stable ID, current date, location, and status. Do not make any changes yet. Use one concise sentence at each turn and include the stable record ID.",
  "follow_up_turns": [
