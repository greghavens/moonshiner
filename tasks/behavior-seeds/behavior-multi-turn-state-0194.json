{
  "schema_version": 1,
  "id": "behavior-multi-turn-state-0194",
  "kind": "tool_behavior",
  "category": "multi-turn-state",
  "world": "expenses",
  "prompt": "Please locate the expense named “Airport shuttle receipt” at Denver, open the exact match, and report its ID, expense date, and status. Treat this as read-only and do not notify anyone. Do not send any notification or message about it.",
  "follow_up_turns": [
    {
      "after_stage": 2,
      "content": "For that exact expense, set the status to rejected. Leave its expense date and location alone and send no notification."
    },
    {
      "after_stage": 3,
      "content": "I need to correct that: set the same record's status to needs-receipt instead of rejected. Do not change anything else."
    }
  ],
  "available_tools": [
    "expenses_search",
    "expenses_get",
    "expenses_update",
    "expenses_cancel",
    "expenses_notify"
  ],
  "initial_state": {
    "records": [
      {
        "id": "EXP-6622",
        "name": "Airport shuttle receipt",
        "location": "Denver",
        "date": "2026-08-14",
        "status": "active"
      },
      {
        "id": "EXP-9622",
        "name": "Poster printing invoice",
        "location": "Portland",
        "date": "2026-09-19",
        "status": "pending"
      },
      {
        "id": "EXP-12622",
        "name": "Airport shuttle receipt archive",
        "location": "Portland",
        "date": "2026-07-15",
        "status": "archived"
      }
    ],
    "notifications": []
  },
  "tool_results": {},
  "failure_injections": [],
  "expected": {
    "decision": "tool_calls",
    "stages": [
      {
        "parallel": false,
        "calls": [
          {
            "tool": "expenses_search",
            "arguments": {
              "query": "Airport shuttle receipt",
              "location": "Denver"
            }
          }
        ],
        "purpose": "Search for the named target and obtain its stable identifier."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "expenses_get",
            "arguments": {
              "id": "EXP-6622"
            }
          }
        ],
        "purpose": "Use the identifier returned by search in a later, dependent retrieval stage."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "expenses_update",
            "arguments": {
              "id": "EXP-6622",
              "status": "rejected"
            }
          }
        ],
        "purpose": "Apply the first requested status only to the retrieved target."
      },
      {
        "parallel": false,
        "calls": [
          {
            "tool": "expenses_update",
            "arguments": {
              "id": "EXP-6622",
              "status": "needs-receipt"
            }
          }
        ],
        "purpose": "Replace the superseded status on that same target with the correction."
      }
    ],
    "state_assertions": [
      "EXP-6622.status == needs-receipt",
      "EXP-6622.status != rejected",
      "EXP-6622.date == 2026-08-14",
      "EXP-6622.location == Denver",
      "EXP-9622.status == pending",
      "notifications remains empty"
    ],
    "forbidden_tools": [
      "expenses_cancel",
      "expenses_notify"
    ],
    "response_constraints": [
      "Use the search result only to obtain the stable target ID; retrieve details in the later get stage.",
      "Keep both status updates tied to the exact record returned by the dependent search-then-get sequence.",
      "Do not claim an update succeeded unless its tool result confirms it.",
      "Report the corrected status as current and identify the first requested status as superseded."
    ]
  },
  "training_tags": [
    "conversation:multi-turn",
    "if:correction",
